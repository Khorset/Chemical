    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДатаМобайл_СвязиДополнительныхФормИШаблонов.ДополнительнаяФорма.Наименование КАК Наименование,
	ДатаМобайл_СвязиДополнительныхФормИШаблонов.ДополнительнаяФорма.ТипДанных КАК ТипДанных,
	ДатаМобайл_СвязиДополнительныхФормИШаблонов.Порядок,
	ДатаМобайл_СвязиДополнительныхФормИШаблонов.ВыгружаемыйРеквизит,
	ДатаМобайл_СвязиДополнительныхФормИШаблонов.ЗаполняемыйРеквизит,
	ВЫБОР
		КОГДА ДатаМобайл_СвязиДополнительныхФормИШаблонов.РеквизитИзШапки = 1
			ТОГДА &quot;для шапки&quot;
		ИНАЧЕ &quot;для строки&quot;
	КОНЕЦ КАК РеквизитИзШапки,
	ВЫБОР КОГДА ДатаМобайл_СвязиДополнительныхФормИШаблонов.РежимВвода = 1 ТОГДА &quot;Вручную&quot;
	КОГДА ДатаМобайл_СвязиДополнительныхФормИШаблонов.РежимВвода = 2 ТОГДА &quot;Автоматически&quot;
	ИНАЧЕ &quot;По умолчанию&quot;
	КОНЕЦ КАК РежимВвода,
	ВЫБОР КОГДА ДатаМобайл_СвязиДополнительныхФормИШаблонов.ПодборРазмещение = 1 ТОГДА &quot;Р&quot;
	ИНАЧЕ &quot;П&quot; КОНЕЦ КАК ПодборРазмещение
ИЗ
	РегистрСведений.ДатаМобайл_СвязиДополнительныхФормИШаблонов КАК ДатаМобайл_СвязиДополнительныхФормИШаблонов
ГДЕ
	ДатаМобайл_СвязиДополнительныхФормИШаблонов.Шаблон = &amp;Шаблон
	И НЕ ДатаМобайл_СвязиДополнительныхФормИШаблонов.РеквизитИзШапки = 1</queryText>
      <mainTable>InformationRegister.ДатаМобайл_СвязиДополнительныхФормИШаблонов</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
