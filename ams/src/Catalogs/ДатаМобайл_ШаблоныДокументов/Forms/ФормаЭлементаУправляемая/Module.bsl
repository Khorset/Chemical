КонецПроцедуры

&НаКлиенте
Процедура ТипБизнесПроцессаПриИзменении(Элемент)
	
	Если Объект.ИспользоватьМаркировку Тогда
		БППриемка = Объект.ТипБизнесПроцесса = 1;
		
		Если БППриемка И Объект.МаркировкаОнлайнПроверкаВложенностиУпаковок Тогда
			Объект.МаркировкаОнлайнПроверкаВложенностиУпаковок = Ложь;
			ДатаМобайл_ОбщийМодульКлиент.СообщитьПользователю("Данная настройка недоступна для типа бизнес-процесса ""Приемка"" ");	
		КонецЕсли;
		
		Элементы.МаркировкаОнлайнПроверкаВложенностиУпаковок.Доступность = Не БППриемка;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НеИзменятьОтветственногоМенеджераПриИзменении(Элемент)
	
	ДоступностьЗаписиПользователя();
	
КонецПроцедуры 

&НаКлиенте
Процедура ДоступностьЗаписиПользователя()  
	
	НастройкаДоступна = Не Объект.НеИзменятьОтветственногоМенеджера;
	
	Элементы.ЗаписыватьПользователяТСДВРеквизит.Доступность = НастройкаДоступна;
	
	Если Не НастройкаДоступна И Не Объект.ЗаписыватьПользователяТСДВРеквизит = "" Тогда
		Объект.ЗаписыватьПользователяТСДВРеквизит = "";
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ЗаполнитьСписокВыбораРеквизитаФиксацииПользователяТСД(УстанавливатьПоУмолчанию = Ложь)
	
	СписокРеквизитов = Новый Массив;
	
	Если ЗначениеЗаполнено(Объект.ВидДокументаНового) Тогда
		ИмяДокумента = Объект.ВидДокументаНового;
	Иначе
		ИмяДокумента = Объект.ВидДокумента;
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(ИмяДокумента) Тогда
		Возврат;
	КонецЕсли;
	
	МетаданныеРек = Метаданные.Документы[ИмяДокумента].Реквизиты;
	
	РеквизитыПоиска = Новый Массив;
	РеквизитыПоиска.Добавить("Ответственный");
	РеквизитыПоиска.Добавить("Менеджер");
	РеквизитыПоиска.Добавить("Автор");
	РеквизитыПоиска.Добавить("Исполнитель");
	РеквизитыПоиска.Добавить("Кассир");
	РеквизитыПоиска.Добавить("Отпустил");
	РеквизитыПоиска.Добавить("Контролер");	
	
	Для каждого РеквизитПоиска Из РеквизитыПоиска Цикл
		Если Не МетаданныеРек.Найти(РеквизитПоиска) = Неопределено Тогда 
			СписокРеквизитов.Добавить(РеквизитПоиска);
		КонецЕсли;
	КонецЦикла;	
	
	Элементы.ЗаписыватьПользователяТСДВРеквизит.СписокВыбора.ЗагрузитьЗначения(СписокРеквизитов); 
	
	Если УстанавливатьПоУмолчанию И СписокРеквизитов.Количество() > 0 И Не Объект.НеИзменятьОтветственногоМенеджера Тогда
		Объект.ЗаписыватьПользователяТСДВРеквизит = СписокРеквизитов[0];
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область Подбор

