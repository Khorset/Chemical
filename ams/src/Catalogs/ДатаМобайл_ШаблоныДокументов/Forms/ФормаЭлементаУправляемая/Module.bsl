&НаКлиенте
Процедура ПеречитатьПараметры(Команда)
	
	ИмяДокумента = Объект.ВидДокумента;
	
	Если Объект.ИспользоватьПриемку Тогда
		ИмяТЧ = Объект.ИмяТабличнойЧастиПриемка;
	Иначе
		ИмяТЧ = Объект.ИмяТабличнойЧастиПодбор;
	КонецЕсли;	
	
	лТекст = СтрЗаменить(Объект.УсловиеВыгрузки, "&", " &");
	лТекст = СтрЗаменить(лТекст, " ", Символы.ПС);
	лТекст = СтрЗаменить(лТекст, "Документ1с.", "Документ1С.");
	лТекст = СтрЗаменить(лТекст, "Документ1стч.", "Документ1СТЧ.");
	лТекст = СтрЗаменить(лТекст, "Документ1сТЧ.", "Документ1СТЧ.");
	
	Попытка Объект.ПараметрыУсловияВыгрузки.Очистить(); Исключение КонецПопытки;
	Попытка Объект.ПараметрыУсловияВыгрузкиТЧ.Очистить(); Исключение КонецПопытки;
	
	ПараметрТЧ = Ложь;
	
	Для ш = 1 По СтрЧислоСтрок(лТекст) Цикл
		ТекстСтроки = СокрЛП(СтрПолучитьСтроку(лТекст, ш));
		
		Если СтрНайти(ТекстСтроки, "Документ1СТЧ.") > 0 Тогда
			ПараметрТЧ = Истина;			
			
			ИмяРеквизита = Сред(ТекстСтроки, СтрНайти(ТекстСтроки, "Документ1СТЧ.") + 13);
			КонецФразы = ОпределитьКонецФразы(ТекстСтроки);
			
			МассивРеквизитов = СтрРазделить(ИмяРеквизита, ".", Ложь);
			
			Если Не КонецФразы = 0 Тогда
				ИмяРеквизита = Сред(ТекстСтроки, 1, КонецФразы - 1);
			КонецЕсли;
		ИначеЕсли СтрНайти(ТекстСтроки, "Документ1С.") > 0 Тогда
			ИмяРеквизита = Сред(ТекстСтроки, СтрНайти(ТекстСтроки, "Документ1С.") + 11);
			КонецФразы = ОпределитьКонецФразы(ТекстСтроки);
			МассивРеквизитов = СтрРазделить(ИмяРеквизита, ".", Ложь);
			
			Если Не КонецФразы = 0 Тогда
				ИмяРеквизита = Сред(ТекстСтроки, 1, КонецФразы - 1);
			КонецЕсли;
		Иначе
			ИмяРеквизита = "";	
		КонецЕсли;
		
		Если Не ИмяРеквизита = "" Тогда
			ТипРеквизита = ПолучитьТипРеквизита(ПараметрТЧ, ИмяДокумента, ИмяТЧ, МассивРеквизитов);
		КонецЕсли;
				
		Если Лев(ТекстСтроки, 1) = "&" Тогда
			Если ПараметрТЧ Тогда
				новСтр = Объект.ПараметрыУсловияВыгрузкиТЧ.Добавить();
				ПараметрТЧ = Ложь;
			Иначе
				новСтр = Объект.ПараметрыУсловияВыгрузки.Добавить();	
			КонецЕсли; 
			
			ИмяПараметра = Сред(ТекстСтроки, 2);
			ИмяПараметра = СтрЗаменить(ИмяПараметра, ",", "");
			ИмяПараметра = СтрЗаменить(ИмяПараметра, ")", "");
			
			новСтр.ИмяПараметра = ИмяПараметра; 
			
			Попытка
				ПустоеЗначение = ТипРеквизита.ПривестиЗначение();
			Исключение
				ПустоеЗначение = Неопределено;
			КонецПопытки;
			
			новСтр.ЗначениеПараметра = ПустоеЗначение;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры 

&НаСервере
Функция ОпределитьКонецФразы(ТекстСтроки) 
	
	КонецФразы = 0;
	КонецФразы = СтрНайти(ТекстСтроки, " ");
	
	Если Не КонецФразы = 0 Тогда
		Возврат КонецФразы;
	КонецЕсли;
	
	КонецФразы = СтрНайти(ТекстСтроки, "=");
	
	Если Не КонецФразы = 0 Тогда
		Возврат КонецФразы;
	КонецЕсли;
	
	КонецФразы = СтрНайти(ТекстСтроки, "<");
	
	Если Не КонецФразы = 0 Тогда
		Возврат КонецФразы;
	КонецЕсли;
	
	КонецФразы = СтрНайти(ТекстСтроки, ">");
	
	Если Не КонецФразы = 0 Тогда
		Возврат КонецФразы;
	КонецЕсли;
	
	Возврат КонецФразы;
	
КонецФункции

&НаСервере
Функция ПолучитьТипРеквизита(ПараметрТЧ, ИмяДокумента, ИмяТЧ, МассивРеквизитов)
	
	Если ПараметрТЧ Тогда
		Попытка
			ТестовыйДокумент = Документы[ИмяДокумента].СоздатьДокумент();
			ТестоваяСтрока   = ТестовыйДокумент[ИмяТЧ].Добавить();
			УровеньРеквизита = ТестоваяСтрока;
			
			Для каждого ИмяРеквизита Из МассивРеквизитов Цикл
				УровеньРеквизита = УровеньРеквизита[ИмяРеквизита];
			КонецЦикла;
			
			ТипРеквизита = ТипЗнч(УровеньРеквизита);
		Исключение
			ТипРеквизита = "";
		КонецПопытки;
		
	Иначе
		Попытка
			ТестовыйДокумент = Документы[ИмяДокумента].СоздатьДокумент();
			УровеньРеквизита = ТестовыйДокумент;
			
			Для каждого ИмяРеквизита Из МассивРеквизитов Цикл
				УровеньРеквизита = УровеньРеквизита[ИмяРеквизита];
			КонецЦикла;
			
			ТипРеквизита = ТипЗнч(УровеньРеквизита);
		Исключение
			ТипРеквизита = "";
		КонецПопытки;
	КонецЕсли; 
	
	Если ТипЗнч(ТипРеквизита) = Тип("Тип") Тогда
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(ТипРеквизита);
		ТипРеквизита = Новый ОписаниеТипов(МассивТипов);
		
	ИначеЕсли ТипЗнч(ТипРеквизита) = Тип("ОписаниеТипов") Тогда
		МассивТипов = ТипРеквизита.Типы();		
		
		// первый какой нть
		Если МассивТипов.Количество() > 1 Тогда			
			МассивТиповЗн = Новый Массив;
			
			Для каждого ТипМассива Из МассивТипов Цикл
				МассивТиповЗн.Добавить(ТипМассива);
				Прервать;
			КонецЦикла;
			
			ТипРеквизита = Новый ОписаниеТипов(МассивТиповЗн);
		КонецЕсли;
	КонецЕсли;
			
	Возврат ТипРеквизита;
	
КонецФункции

&НаКлиенте
Процедура ВыгружатьРоботомПриИзменении(Элемент)
	
	ДоступностьВыгружатьВсеДокументыШаблона();
	Если Не Объект.ВыгружатьРоботом И Объект.ВыгружатьВсеДокументыШаблона Тогда
		Объект.ВыгружатьВсеДокументыШаблона = Объект.ВыгружатьРоботом;
	КонецЕсли;
	
	Если Не Объект.ВыгружатьРоботом И Объект.МаркировкаВыгружатьРоботом Тогда
		Объект.МаркировкаВыгружатьРоботом = Объект.ВыгружатьРоботом;
	КонецЕсли;
	
	Элементы.ГруппаАвтовыгрузкаФоновая.Видимость = Объект.ВыгружатьРоботом;
	
	Если Не Объект.ВыгружатьРоботом Тогда
		
		Объект.ФоноваяАвтовыгрузка = Ложь;	
		Объект.ФоноваяАвтовыгрузкаКоличество = 0;
		
	КонецЕсли;
	
	ФоноваяАвтовыгрузкаПриИзменении(Неопределено);
	ФоноваяАвтозагрузкаПриИзменении(Неопределено);
	ФоновоеАвтоудалениеПриИзменении(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбрабатыватьРоботомПриИзменении(Элемент)
	
	Если Объект.ОбрабатыватьРоботом Тогда	
		Элементы.ОткрыватьДокументыПослеЗагрузкиБезЗаписи.Видимость = Ложь;
		Если Объект.ОткрыватьДокументыПослеЗагрузкиБезЗаписи Тогда
			Попытка Объект.ОткрыватьДокументыПослеЗагрузкиБезЗаписи = Ложь; Исключение КонецПопытки;
		КонецЕсли;		
	Иначе
		Если Не Объект.ОбрабатыватьРоботом И Не Объект.ПроводитьРоботом И Не Объект.ИспользоватьМаркировку И Не Объект.ИспользоватьГрупповойДокумент Тогда
			Элементы.ОткрыватьДокументыПослеЗагрузкиБезЗаписи.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.грФоноваяАвтозагрузка.Видимость = Объект.ОбрабатыватьРоботом;
	
	Если Не Объект.ОбрабатыватьРоботом Тогда
		
		Объект.ФоноваяАвтозагрузка = Ложь;	
		Объект.ФоноваяАвтозагрузкаКоличество = 0;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроводитьРоботомПриИзменении(Элемент)
	
	Если Объект.ПроводитьРоботом Тогда	
		Элементы.ОткрыватьДокументыПослеЗагрузкиБезЗаписи.Видимость = Ложь;
		Если Объект.ОткрыватьДокументыПослеЗагрузкиБезЗаписи Тогда
			Попытка Объект.ОткрыватьДокументыПослеЗагрузкиБезЗаписи = Ложь; Исключение КонецПопытки;
		КонецЕсли;		
	Иначе
		Если Не Объект.ОбрабатыватьРоботом И Не Объект.ПроводитьРоботом И Не Объект.ИспользоватьМаркировку И Не Объект.ИспользоватьГрупповойДокумент Тогда
			Элементы.ОткрыватьДокументыПослеЗагрузкиБезЗаписи.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;		
	
	Элементы.РежимПроведения.Видимость 	= Объект.ПроводитьРоботом;
	Элементы.ОтменаПроведения.Видимость = Объект.ПроводитьРоботом;
	
	РежимПроведенияПриИзменении("");
	
КонецПроцедуры

&НаКлиенте
Процедура РежимПроведенияПриИзменении(Элемент)
	Если Объект.РежимПроведения = 1 Тогда	
		ОперативноеПроведениеЗапрещено = ЗапретитьОперативноеПроведение(Объект.ВидДокумента) Или ЗапретитьОперативноеПроведение(Объект.ВидДокументаНового);
		Если ОперативноеПроведениеЗапрещено Тогда 
			Объект.РежимПроведения = 0;
			Модифицированность = Истина;
			ДатаМобайл_ОбщийМодульКлиент.СообщитьПользователю("Для выбранного вида документа оперативный режим проведения запрещен, установлен неоперативный режим проведения");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗапретитьОперативноеПроведение(ВидДокумента)
	Возврат ЗначениеЗаполнено(ВидДокумента) И Метаданные.Документы[ВидДокумента].ОперативноеПроведение = Метаданные.СвойстваОбъектов.ОперативноеПроведение.Запретить;	
КонецФункции

&НаСервереБезКонтекста
Функция ВычислитьОперациюСравнения(Условие)
	
	// Условия
	// (0, "Равно")
	// (1, "Не Равно")
	// (3, "Больше")
	// (4, "Меньше")
	// (5, "Больше или Равно")
	// (6, "Меньше или Равно")
	// (7, "В Списке")
	// (8, "Не В Списке")
	
	Если Условие = "Не Равно" Тогда
		Операция = " <> ";
	ИначеЕсли Условие = "Больше" Тогда
		Операция = " > ";
	ИначеЕсли Условие = "Меньше" Тогда
		Операция = " < ";
	ИначеЕсли Условие = "Больше или Равно" Тогда
		Операция = " >= ";
	ИначеЕсли Условие = "Меньше или Равно" Тогда
		Операция = " <= ";
	ИначеЕсли Условие = "В Списке" Тогда
		Операция = " В ";
	ИначеЕсли Условие = "Не В Списке" Тогда
		Операция = " НЕ В ";	
	Иначе
		Операция = " = ";
	КонецЕсли; 
	
	Возврат Операция;
	
КонецФункции

