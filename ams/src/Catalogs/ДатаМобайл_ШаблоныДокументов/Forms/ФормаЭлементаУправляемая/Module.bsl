&НаКлиенте
Процедура ПараметрыУсловияВыгрузкиПриАктивизацииЯчейки(Элемент)
	
	ТекЭлемент = Элемент.ТекущийЭлемент;
	
	Если ТекЭлемент.Имя = "ПараметрыУсловияВыгрузкиЗначениеПараметра" Тогда
		ТекДанные = Элементы.ПараметрыУсловияВыгрузки.ТекущиеДанные;
		
		Если ТекДанные = Неопределено Тогда 
			Возврат; 
		КонецЕсли;
		
		Если Не ТипЗнч(ТекДанные.ЗначениеПараметра) = Тип("Неопределено") Тогда
			МассивТипов = Новый Массив;
			МассивТипов.Добавить(ТипЗнч(ТекДанные.ЗначениеПараметра));
			ТекЭлемент.ОграничениеТипа = Новый ОписаниеТипов(МассивТипов);
		Иначе
			ТекЭлемент.ОграничениеТипа = Новый ОписаниеТипов();
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

