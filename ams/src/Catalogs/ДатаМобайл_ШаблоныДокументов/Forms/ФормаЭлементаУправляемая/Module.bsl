		МассивТиповПоРеквизиту.Добавить(Тип("Булево"));
	ИначеЕсли ИмяРеквизита = "Дата" Тогда
		МассивТиповПоРеквизиту.Добавить(Тип("Дата"));
	ИначеЕсли ИмяРеквизита = "Номер" Тогда
