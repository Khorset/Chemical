		<field xsi:type="DataSetFieldField">
			<dataPath>КонечныйОстаток</dataPath>
			<field>КонечныйОстаток</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Конечный остаток</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:balance>true</dcscom:balance>
				<dcscom:balanceGroupName>Группа</dcscom:balanceGroupName>
				<dcscom:balanceType>ClosingBalance</dcscom:balanceType>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УдалитьЗаказКлиента</dataPath>
			<field>УдалитьЗаказКлиента</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	т.ЗаказКлиента КАК ЗаказКлиента,
	т.ДатаПлатежа КАК ДатаПлатежа
ПОМЕСТИТЬ дат
ИЗ
	РегистрНакопления.РасчетыСКлиентамиПоДокументам КАК т
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК а
		ПО т.АналитикаУчетаПоПартнерам = а.КлючАналитики
ГДЕ
	а.Партнер = &amp;Партнер
	И т.Период МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
	И т.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияКлиенту)

ИНДЕКСИРОВАТЬ ПО
	ЗаказКлиента
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	т.Период КАК Период,
	т.ЗаказКлиента КАК ЗаказКлиента,
	т.Регистратор КАК Регистратор,
	т.ДолгНачальныйОстаток КАК ДолгНачальныйОстаток,
	т.ДолгПриход КАК ДолгПриход,
	т.ДолгРасход КАК ДолгРасход,
	т.ДолгКонечныйОстаток КАК ДолгКонечныйОстаток
ПОМЕСТИТЬ ост
ИЗ
	РегистрНакопления.РасчетыСКлиентамиПоДокументам.ОстаткиИОбороты(,, Регистратор,, ЗаказКлиента В
		(ВЫБРАТЬ
			т.ЗаказКлиента КАК ЗаказКлиента
		ИЗ
			дат КАК т)) КАК т

ИНДЕКСИРОВАТЬ ПО
	ЗаказКлиента
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	ост.Период КАК Период,
	ост.ЗаказКлиента КАК ЗаказКлиента,
	ост.Регистратор КАК Регистратор,
	ост.ДолгНачальныйОстаток КАК ДолгНачальныйОстаток,
	ост.ДолгПриход КАК ДолгПриход,
	ост.ДолгРасход КАК ДолгРасход,
	ост.ДолгКонечныйОстаток КАК ДолгКонечныйОстаток,
	дат.ДатаПлатежа КАК ДатаПлатежа,
	РАЗНОСТЬДАТ(дат.ДатаПлатежа, ост.Период, ДЕНЬ) КАК ПросроченоДней
ПОМЕСТИТЬ вт
ИЗ
	ост КАК ост
		ЛЕВОЕ СОЕДИНЕНИЕ дат КАК дат
		ПО ост.ЗаказКлиента = дат.ЗаказКлиента
ГДЕ
	ост.ДолгРасход &gt; 0

ИНДЕКСИРОВАТЬ ПО
	ЗаказКлиента
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	вт.Период КАК Период,
	вт.ЗаказКлиента КАК ЗаказКлиента,
	вт.Регистратор КАК Регистратор,
	вт.ДолгНачальныйОстаток КАК НачальныйОстаток,
	вт.ДолгПриход КАК Приход,
	вт.ДолгРасход КАК Расход,
	вт.ДолгКонечныйОстаток КАК КонечныйОстаток,
	вт.ДатаПлатежа КАК ДатаПлатежа,
	вт.ПросроченоДней КАК ПросроченоДней
ИЗ
	вт КАК вт
ГДЕ
	вт.ПросроченоДней &gt; 0</query>
	</dataSet>
	<calculatedField>
		<dataPath>Пени</dataPath>
		<expression>НачальныйОстаток * ПросроченоДней * &amp;ПроцентПени</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Пени</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ЧДЦ=2</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>Контрагент</dataPath>
		<expression>ЗаказКлиента.Контрагент</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Контрагент</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">20</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<totalField>
		<dataPath>Пени</dataPath>
		<expression>Сумма(Пени)</expression>
	</totalField>
