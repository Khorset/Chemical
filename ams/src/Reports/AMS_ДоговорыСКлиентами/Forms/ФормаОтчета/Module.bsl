#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура НастройкаФормы()
	Элементы.Статус.СписокВыбора.Очистить();
	Элементы.Статус.СписокВыбора.Добавить(Перечисления.СтатусыДоговоровКонтрагентов.НеСогласован);
	Элементы.Статус.СписокВыбора.Добавить(Перечисления.СтатусыДоговоровКонтрагентов.Действует);
	Если Не СкрытьЗакрытыеДоговоры Тогда
		Элементы.Статус.СписокВыбора.Добавить(Перечисления.СтатусыДоговоровКонтрагентов.Закрыт);
	КонецЕсли;

	Если Не AMS_ВызовСервера.ЭтоKhors() Тогда
		ЭтоЮрист           = AMS_ВызовСервера.ДоступнаКонкретнаяРоль("_Юрист");
		ЭтоСтаршийМенеджер = Пользователи.РолиДоступны("_СтаршийМенеджер,_СтаршийМенеджерМЕГА");
		ЭтоГлавБухгалтер   = AMS_ВызовСервера.ДоступнаКонкретнаяРоль("_ГлавныйБухгалтер");
		ЭтоДиректор        = AMS_ВызовСервера.ДоступнаКонкретнаяРоль("_Директор");
		ЭтоСекретарь       = AMS_ВызовСервера.ДоступнаКонкретнаяРоль("_Секретарь");

		СогласованиеДоговораЗаРуководителя = AMS_ВызовСервера.ЕстьПравоАМС(Перечисления.AMS_Права.СогласованиеДоговораЗаРуководителя);

		Элементы.ТаблСтатус.ТолькоПросмотр                      = Не ЭтоЮрист;
		Элементы.ТаблСторонаОформления.ТолькоПросмотр           = Не (ЭтоЮрист Или ЭтоСтаршийМенеджер);
		Элементы.ТаблДатаНачалаДействия.ТолькоПросмотр          = Не (ЭтоЮрист Или ЭтоСтаршийМенеджер);
		Элементы.ТаблДатаОкончанияДействия.ТолькоПросмотр       = Не (ЭтоЮрист Или ЭтоСтаршийМенеджер);
		Элементы.ТаблСогласованРуководитель.ТолькоПросмотр      = Не (ЭтоСтаршийМенеджер Или СогласованиеДоговораЗаРуководителя);
		Элементы.ТаблСогласованЮрист.ТолькоПросмотр             = Не ЭтоЮрист;
		Элементы.ТаблСогласованГлавбух.ТолькоПросмотр           = Не ЭтоГлавБухгалтер;
		Элементы.ТаблСогласованДиректор.ТолькоПросмотр          = Не (ЭтоГлавБухгалтер Или ЭтоДиректор);
		Элементы.ТаблСпособОтправки.ТолькоПросмотр              = Не ЭтоСекретарь;
		Элементы.ТаблДатаОтправки.ТолькоПросмотр                = Не ЭтоСекретарь;
		Элементы.ТаблДатаПолученияСкана.ТолькоПросмотр          = Не ЭтоЮрист;
		Элементы.ТаблДатаПолученияОригинала.ТолькоПросмотр      = Не (ЭтоСекретарь Или ЭтоЮрист);
		Элементы.ТаблСрокУведомленияОбИзменениях.ТолькоПросмотр = Не (ЭтоЮрист Или ЭтоСтаршийМенеджер);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	УсловноеОформление.Элементы.Очистить();
	
	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Табл.Имя);

	ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;

	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Табл.ДатаПолученияОригинала");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Заполнено;

	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Табл.КоличествоПродаж");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Заполнено;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаПолностьюОбеспечен);
	
	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Табл.Имя);

	ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;

	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Табл.ДатаПолученияОригинала");
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.НеЗаполнено;

	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Табл.ДатаПолученияСкана");
	ОтборЭлемента.ВидСравнения  = ВидСравненияКомпоновкиДанных.Заполнено;

	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Табл.КоличествоПродаж");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Заполнено;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаВнимание);
	
	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Табл.Имя);

