#Область ОбработчикиСобытийЭлементовТаблицыФормыТабл

&НаКлиенте
Процедура ТаблПриАктивизацииСтроки(Элемент)
	Если Не Элемент.ТекущиеДанные = Неопределено Тогда
		Договор = Элемент.ТекущиеДанные.Договор;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТаблВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Имя = Поле.Имя;

	Если Имя = "ТаблСтатус" И Элемент.ТекущиеДанные.Статус = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент(
		"Перечисление.СтатусыДоговоровКонтрагентов.Действует") Тогда

		ПоказатьВопрос(Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект), "Закрыть договор?",
			РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);

	ИначеЕсли Имя = "ТаблПлюс" Тогда
		ОткрытьФорму("Отчет.AMS_ДоговорыСКлиентами.Форма.ФормаПриложений", Новый Структура("Договор", Договор), , , , ,
			Новый ОписаниеОповещения("ОткрытьФормуПриложенийЗавершение", ЭтотОбъект),
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	ИначеЕсли Имя = "ТаблСтатус" 
		Или	Имя = "ТаблСогласованРуководитель" Или Имя = "ТаблСогласованЮрист"
		Или Имя = "ТаблСогласованГлавбух" Или Имя = "ТаблСогласованДиректор" Тогда
		Возврат;
		
	Иначе
		ПоказатьЗначение( , Договор);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТаблСтатусНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекСтатус = ТекущийЭлемент.ТекущиеДанные.Статус;

	Элемент.СписокВыбора.Очистить();

	НеСогласован = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент(
		"Перечисление.СтатусыДоговоровКонтрагентов.НеСогласован");
	Действует    = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление.СтатусыДоговоровКонтрагентов.Действует");

	Если Не ЗначениеЗаполнено(ТекСтатус) Или ТекСтатус = НеСогласован Тогда
		Элементы.ТаблСтатус.СписокВыбора.Добавить(НеСогласован);
		Элементы.ТаблСтатус.СписокВыбора.Добавить(Действует);

	ИначеЕсли ТекСтатус = Действует Тогда
		Элементы.ТаблСтатус.СписокВыбора.Добавить(Действует);
		Элементы.ТаблСтатус.СписокВыбора.Добавить(ОбщегоНазначенияКлиент.ПредопределенныйЭлемент(
			"Перечисление.СтатусыДоговоровКонтрагентов.Закрыт"));
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТаблСтатусПриИзменении(Элемент)
	ТекСтатус = ТекущийЭлемент.ТекущиеДанные.Статус;

	Если ЗначениеЗаполнено(ТекСтатус) И ПравоИзмененияДоговора() Тогда
		ИзменитьДоговор(Договор, "Статус", ТекСтатус);
		ПоказатьОтчет();
	КонецЕсли;
КонецПроцедуры

