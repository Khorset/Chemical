	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблСторонаОформления.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблДатаНачалаДействия.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблДатаОкончанияДействия.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблСогласованРуководитель.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблСогласованЮрист.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблСогласованГлавбух.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблСогласованДиректор.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблСпособОтправки.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблДатаОтправки.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблДатаПолученияСкана.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблДатаПолученияОригинала.Имя);

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТаблСрокУведомленияОбИзменениях.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Табл.Статус");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = ОбщегоНазначения.ПредопределенныйЭлемент(
		"Перечисление.СтатусыДоговоровКонтрагентов.Закрыт");

	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	//
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьПериодЗавершение(РезультатВыбора, ДопПараметры) Экспорт
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДатаОкончания = РезультатВыбора.КонецПериода;

	УстановитьЗаголовокПериода();

	ПоказатьИсполнениеДоговоров();
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокПериода()
	Если Не ЗначениеЗаполнено(ДатаОкончания) Тогда
		ДатаОкончания = КонецМесяца(НачалоМесяца(ТекущаяДатаСеанса()) - 600);
	КонецЕсли;

	ДатаНачала = НачалоМесяца(ДобавитьМесяц(ДатаОкончания, -12));
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОтчет()
	ПоказатьОтчетНаСервере();

	ИдентификаторСтроки = 0;
	Для Каждого Стр Из Табл Цикл
		Если Стр.Договор = Договор Тогда
			ИдентификаторСтроки = Стр.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Элементы.Табл.ТекущаяСтрока = ИдентификаторСтроки;

	ПоказатьИсполнениеДоговоров();
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеПоля(Расшифровка)
	ДанныеРасшифровкиКД = ПолучитьИзВременногоХранилища(ДанныеРасшифровки);

	Поля = ДанныеРасшифровкиКД.Элементы[Расшифровка].ПолучитьПоля();

	Возврат Новый Структура("Поле,Значение", Поля[0].Поле, Поля[0].Значение);
КонецФункции

&НаСервере
Процедура ПоказатьИсполнениеДоговоров()
	Результат.Очистить();

	СКД = РеквизитФормыВЗначение("Отчет").ПолучитьМакет("скдИсполнение");

	Парам = Новый Структура;
	Парам.Вставить("Договора", Табл.Выгрузить( , "Договор").ВыгрузитьКолонку("Договор"));
	Парам.Вставить("ДатаОкончания", ДатаОкончания);
	Парам.Вставить("СкладПродукции", AMS_ВызовСервера.СкладПродукции());

	Расшифровка = Новый ДанныеРасшифровкиКомпоновкиДанных;

	Данные = Новый Структура;
	Данные.Вставить("СКД", СКД);
	Данные.Вставить("Результат", Результат);
	Данные.Вставить("Параметры", Парам);
	Данные.Вставить("Расшифровка", Расшифровка);

	AMS_ВызовСервера.ВыполнитьСКД(Данные);

	ДанныеРасшифровки = ПоместитьВоВременноеХранилище(Данные.Расшифровка, УникальныйИдентификатор);
КонецПроцедуры

&НаСервере
Процедура ПоказатьОтчетНаСервере()
	СписокСтатус = Новый СписокЗначений;
	Если ЗначениеЗаполнено(Статус) Тогда
		СписокСтатус.Добавить(Статус);
	Иначе
		СписокСтатус.Добавить(Перечисления.СтатусыДоговоровКонтрагентов.НеСогласован);
		СписокСтатус.Добавить(Перечисления.СтатусыДоговоровКонтрагентов.Действует);
		Если Не СкрытьЗакрытыеДоговоры Тогда
			СписокСтатус.Добавить(Перечисления.СтатусыДоговоровКонтрагентов.Закрыт);
		КонецЕсли;
	КонецЕсли;

	ТипыДокументов = Новый СписокЗначений;
	ТипыДокументов.Добавить(Справочники.ИдентификаторыОбъектовМетаданных.НайтиПоНаименованию(
		"Акт выполненных работ для клиента (Документ)", Истина));
	ТипыДокументов.Добавить(Справочники.ИдентификаторыОбъектовМетаданных.НайтиПоНаименованию(
		"Передача товаров (Документ)", Истина));
	ТипыДокументов.Добавить(Справочники.ИдентификаторыОбъектовМетаданных.НайтиПоНаименованию(
		"Реализация товаров и услуг (Документ)", Истина));

	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("СписокСтатус", СписокСтатус);
	Запрос.УстановитьПараметр("ТипыДокументов", ТипыДокументов);

	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	д.Организация КАК Организация,
	|	д.Партнер КАК Партнер,
	|	п.ГруппаДоступа КАК ГруппаДоступа,
	|	д.Контрагент КАК Контрагент,
	|	д.Ссылка КАК Договор,
	|	д.Статус КАК Статус,
	|	д.ДатаНачалаДействия КАК ДатаНачалаДействия,
	|	д.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
	|	дд.СогласованРуководитель КАК СогласованРуководитель,
	|	дд.СогласованЮрист КАК СогласованЮрист,
	|	дд.СогласованГлавбух КАК СогласованГлавбух,
	|	дд.СогласованДиректор КАК СогласованДиректор,
	|	дд.ДатаОтправки КАК ДатаОтправки,
	|	дд.СпособОтправки КАК СпособОтправки,
	|	дд.ДатаПолученияСкана КАК ДатаПолученияСкана,
	|	дд.ДатаПолученияОригинала КАК ДатаПолученияОригинала,
	|	дд.СторонаОформления КАК СторонаОформления,
	|	ВЫБОР
	|		КОГДА дд.СрокУведомленияОбИзменениях ЕСТЬ NULL
	|		ИЛИ дд.СрокУведомленияОбИзменениях = 0
	|			ТОГДА 14
	|		ИНАЧЕ дд.СрокУведомленияОбИзменениях
	|	КОНЕЦ КАК СрокУведомленияОбИзменениях,
	|	п.БизнесРегион КАК БизнесРегион,
	|	д.Менеджер КАК Менеджер,
	|	ВЫБОР
	|		КОГДА п.Родитель = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|			ТОГДА д.Партнер.Наименование
	|		ИНАЧЕ п.Родитель.Наименование
	|	КОНЕЦ КАК РодительНаименование,
	|	д.Партнер.Наименование КАК ПартнерНаименование,
	|	д.Контрагент.Наименование КАК КонтрагентНаименование,
	|	д.Наименование КАК ДоговорНаименование
	|ПОМЕСТИТЬ дог
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК д
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.AMS_ДанныеДоговоров КАК дд
	|		ПО д.Ссылка = дд.Договор
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК п
	|		ПО д.Партнер = п.Ссылка
	|ГДЕ
	|	НЕ д.ПометкаУдаления
	|	И (д.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СПокупателем)
	|	ИЛИ д.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СКомиссионером))
	|	И д.Статус В (&СписокСтатус)";

	Если ЗначениеЗаполнено(ГруппаДоступа) Тогда
		Запрос.УстановитьПараметр("ГруппаДоступа", ГруппаДоступа);

		ТекстЗапроса = ТекстЗапроса + "
		|	И п.ГруппаДоступа = &ГруппаДоступа";
	КонецЕсли;

	Если ЗначениеЗаполнено(Менеджер) Тогда
		Запрос.УстановитьПараметр("Менеджер", Менеджер);

		ТекстЗапроса = ТекстЗапроса + "
		|	И д.Менеджер = &Менеджер";
	КонецЕсли;

	Если ЗначениеЗаполнено(Клиент) Тогда
		Запрос.УстановитьПараметр("Партнер", Клиент);

		ТекстЗапроса = ТекстЗапроса + "
		|	И д.Партнер = &Партнер";
	КонецЕсли;

	Если ЗначениеЗаполнено(Контрагент) Тогда
		Запрос.УстановитьПараметр("Контрагент", Контрагент);

		ТекстЗапроса = ТекстЗапроса + "
		|	И д.Контрагент = &Контрагент";
	КонецЕсли;

	Если ЗначениеЗаполнено(Организация) Тогда
		Запрос.УстановитьПараметр("Организация", Организация);

		ТекстЗапроса = ТекстЗапроса + "
		|	И д.Организация = &Организация";
	КонецЕсли;

	ТекстЗапроса = ТекстЗапроса + "
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Согл.Ссылка КАК Соглашение,
	|	Согл.СегментПартнеров КАК Сегмент
	|ПОМЕСТИТЬ Согл
	|ИЗ
	|	Справочник.СоглашенияСКлиентами КАК Согл
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГрафикиОплаты.Этапы КАК Этап
	|		ПО Согл.ГрафикОплаты = Этап.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК Цены
	|		ПО Согл.Ссылка = Цены.Ссылка
	|ГДЕ
	|	Согл.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
	|	И НЕ Согл.ЦенаВключаетНДС
	|	И Согл.Типовое
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Сегмент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.Партнер КАК Партнер,
	|	МАКСИМУМ(т.Сегмент) КАК Сегмент
	|ПОМЕСТИТЬ Сегм
	|ИЗ
	|	РегистрСведений.ПартнерыСегмента КАК т
	|ГДЕ
	|	т.Сегмент В
	|		(ВЫБРАТЬ
	|			т.Сегмент КАК Сегмент
	|		ИЗ
	|			Согл КАК т)
	|СГРУППИРОВАТЬ ПО
	|	т.Партнер
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ т.Сегмент) = 1
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Сегмент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Сегм.Партнер КАК Партнер,
	|	Согл.Соглашение КАК Соглашение
	|ПОМЕСТИТЬ СоглТип
	|ИЗ
	|	Сегм КАК Сегм
	|		ЛЕВОЕ СОЕДИНЕНИЕ Согл КАК Согл
	|		ПО Сегм.Сегмент = Согл.Сегмент
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Соглашение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(д.Ссылка) КАК Соглашение,
	|	д.Организация КАК Организация,
	|	д.Партнер КАК Партнер,
	|	д.Контрагент КАК Контрагент
	|ПОМЕСТИТЬ СоглИнд
	|ИЗ
	|	Справочник.СоглашенияСКлиентами КАК д
	|ГДЕ
	|	НЕ д.Типовое
	|	И д.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
	|СГРУППИРОВАТЬ ПО
	|	д.Организация,
	|	д.Партнер,
	|	д.Контрагент
	|ИМЕЮЩИЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ д.Ссылка) = 1
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Соглашение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	дог.Договор КАК Договор,
	|	ВЫБОР
	|		КОГДА СоглИнд.Соглашение ЕСТЬ NULL
	|			ТОГДА СоглТип.Соглашение
	|		ИНАЧЕ СоглИнд.Соглашение
	|	КОНЕЦ КАК Соглашение
	|ПОМЕСТИТЬ Соглашения
	|ИЗ
	|	дог КАК дог
	|		ЛЕВОЕ СОЕДИНЕНИЕ СоглИнд КАК СоглИнд
	|		ПО дог.Организация = СоглИнд.Организация
	|		И дог.Партнер = СоглИнд.Партнер
	|		И дог.Контрагент = СоглИнд.Контрагент
	|		ЛЕВОЕ СОЕДИНЕНИЕ СоглТип КАК СоглТип
	|		ПО дог.Партнер = СоглТип.Партнер
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Соглашение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.Договор КАК Договор,
	|	МАКСИМУМ(т.ДатаПервичногоДокумента) КАК ПоследняяОперация,
	|	СУММА(1) КАК КоличествоПродаж
	|ПОМЕСТИТЬ док
	|ИЗ
	|	РегистрСведений.РеестрДокументов КАК т
	|ГДЕ
	|	т.Договор В (ВЫБРАТЬ т.Договор КАК Договор ИЗ дог КАК т)
	|	И т.ТипСсылки В(&ТипыДокументов)
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Договор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.Договор КАК Договор,
	|	КОЛИЧЕСТВО(т.ВидПриложения) КАК Плюс
	|ПОМЕСТИТЬ Прилож
	|ИЗ
	|	РегистрСведений._ПриложенияКДоговорам КАК т
	|СГРУППИРОВАТЬ ПО
	|	т.Договор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Соглашения.Договор КАК Договор,
	|	Соглашения.Соглашение КАК Соглашение,
	|	МАКСИМУМ(СпрСогл.ВидЦен) КАК ВидЦенБХ,
	|	МАКСИМУМ(ЦенГруппы.ВидЦен) КАК ВидЦенМЕГА,
	|	МАКСИМУМ(Графики.Сдвиг) КАК Отсрочка
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Соглашения КАК Соглашения
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК СпрСогл
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК ЦенГруппы
	|			ПО СпрСогл.Ссылка = ЦенГруппы.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГрафикиОплаты.Этапы КАК Графики
	|			ПО СпрСогл.ГрафикОплаты = Графики.Ссылка
	|		ПО Соглашения.Соглашение = СпрСогл.Ссылка
	|ГДЕ
	|	Соглашения.Соглашение <> НЕОПРЕДЕЛЕНО
	|СГРУППИРОВАТЬ ПО
	|	Соглашения.Договор,
	|	Соглашения.Соглашение
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Договор,
	|	Соглашение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	дог.БизнесРегион КАК БизнесРегион,
	|	вт.ВидЦенБХ КАК ВидЦенБХ,
	|	вт.ВидЦенМЕГА КАК ВидЦенМЕГА,
	|	дог.ДатаНачалаДействия КАК ДатаНачалаДействия,
	|	дог.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
	|	дог.ДатаОтправки КАК ДатаОтправки,
	|	дог.ДатаПолученияОригинала КАК ДатаПолученияОригинала,
	|	дог.ДатаПолученияСкана КАК ДатаПолученияСкана,
	|	дог.Договор КАК Договор,
	|	ЕСТЬNULL(док.КоличествоПродаж, 0) КАК КоличествоПродаж,
	|	дог.Контрагент КАК Контрагент,
	|	дог.Менеджер КАК Менеджер,
	|	вт.Отсрочка КАК Отсрочка,
	|	дог.Партнер КАК Партнер,
	|	Прилож.Плюс КАК Плюс,
	|	док.ПоследняяОперация КАК ПоследняяОперация,
	|	дог.СогласованГлавбух КАК СогласованГлавбух,
	|	дог.СогласованДиректор КАК СогласованДиректор,
	|	дог.СогласованРуководитель КАК СогласованРуководитель,
	|	дог.СогласованЮрист КАК СогласованЮрист,
	|	вт.Соглашение КАК Соглашение,
	|	дог.СпособОтправки КАК СпособОтправки,
	|	дог.СрокУведомленияОбИзменениях КАК СрокУведомленияОбИзменениях,
	|	дог.Статус КАК Статус,
	|	дог.СторонаОформления КАК СторонаОформления,
	|	дог.Организация КАК Организация,
	|	дог.ГруппаДоступа КАК ГруппаДоступа,
	|	дог.РодительНаименование КАК РодительНаименование,
	|	дог.ПартнерНаименование КАК ПартнерНаименование,
	|	дог.КонтрагентНаименование КАК КонтрагентНаименование,
	|	дог.ДоговорНаименование КАК ДоговорНаименование
	|ИЗ
	|	дог КАК дог
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт КАК вт
	|		ПО дог.Договор = вт.Договор
	|		ЛЕВОЕ СОЕДИНЕНИЕ док КАК док
	|		ПО дог.Договор = док.Договор
	|		ЛЕВОЕ СОЕДИНЕНИЕ Прилож КАК Прилож
	|		ПО дог.Договор = Прилож.Договор";

	Отбор = "";
	Если НетСкана Тогда
		Отбор = Отбор + "
	|	" + ?(ПустаяСтрока(Отбор), "", "И ") + "дог.ДатаПолученияСкана = ДАТАВРЕМЯ(1,1,1) И дог.ДатаПолученияОригинала = ДАТАВРЕМЯ(1,1,1)";
	КонецЕсли;
	
	Если НетОригинала Тогда
		Отбор = Отбор + "
	|	" + ?(ПустаяСтрока(Отбор), "", "И ") + "дог.ДатаПолученияОригинала = ДАТАВРЕМЯ(1,1,1)";
	КонецЕсли;
	
	Если Продажи = 1 Тогда
		Отбор = Отбор + "
	|	" + ?(ПустаяСтрока(Отбор), "", "И ") + "ЕСТЬNULL(док.КоличествоПродаж, 0) <> 0";
 	КонецЕсли;

	Если Продажи = 2 Тогда
		Отбор = Отбор + "
	|	" + ?(ПустаяСтрока(Отбор), "", "И ") + "ЕСТЬNULL(док.КоличествоПродаж, 0) = 0";
 	КонецЕсли;

	Если Не ПустаяСтрока(Отбор) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|ГДЕ";
		ТекстЗапроса = ТекстЗапроса + Отбор;
	КонецЕсли;
		
	ТекстЗапроса = ТекстЗапроса + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	РодительНаименование,
	|	ПартнерНаименование,
	|	КонтрагентНаименование,
	|	ДоговорНаименование";

	Запрос.Текст = ТекстЗапроса;

	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();

	Табл.Очистить();

	НомерСтроки = 0;

	Пока Выб.Следующий() Цикл
		НомерСтроки = НомерСтроки + 1;

		Стр = Табл.Добавить();

		ЗаполнитьЗначенияСвойств(Стр, Выб);

		Стр.НомерСтроки = НомерСтроки;
	КонецЦикла;

	ПоказатьПриложенияКДоговорам();
КонецПроцедуры

&НаСервере
Процедура ПоказатьПриложенияКДоговорам()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивДоговоров", Табл.Выгрузить().ВыгрузитьКолонку("Договор"));
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	дог.Партнер КАК Партнер,
	|	дог.Контрагент КАК Контрагент,
	|	дог.Ссылка КАК Договор,
	|	рег.Номер КАК Номер,
	|	рег.Дата КАК Дата,
	|	рег.ВидПриложения КАК ВидПриложения,
	|	рег.ДатаПолученияСкана КАК ДатаПолученияСкана,
	|	рег.ДатаПолученияОригинала КАК ДатаПолученияОригинала,
	|	рег.Описание КАК Описание
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК дог
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений._ПриложенияКДоговорам КАК рег
	|		ПО дог.Ссылка = рег.Договор
	|ГДЕ
	|	дог.Ссылка В (&МассивДоговоров)";
	
	Отбор = "";
	Если НетСканаПриложения Тогда
		Отбор = Отбор + "
	|	" + ?(ПустаяСтрока(Отбор), "", "И ") + "рег.ДатаПолученияСкана = ДАТАВРЕМЯ(1,1,1) И рег.ДатаПолученияОригинала = ДАТАВРЕМЯ(1,1,1)";
	КонецЕсли;
	
	Если НетОригиналаПриложения Тогда
		Отбор = Отбор + "
	|	" + ?(ПустаяСтрока(Отбор), "", "И ") + "И рег.ДатаПолученияОригинала = ДАТАВРЕМЯ(1,1,1)";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидПриложения) Тогда
		Отбор = Отбор + "
	|	" + ?(ПустаяСтрока(Отбор), "", "И ") + "И рег.ВидПриложения = &ВидПриложения";
 	КонецЕсли;

	Если Не ПустаяСтрока(Отбор) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|ГДЕ";
		ТекстЗапроса = ТекстЗапроса + Отбор;
	КонецЕсли;
		
	ТекстЗапроса = ТекстЗапроса + "
	|УПОРЯДОЧИТЬ ПО
	|	дог.Партнер.Родитель.Наименование,
	|	дог.Партнер.Наименование,
	|	дог.Контрагент.Наименование,
	|	дог.Наименование,
	|	Номер";
	
	Запрос.Текст = ТекстЗапроса;
	
	Приложения.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПравоИзмененияДоговора()
	Возврат ПравоДоступа("Изменение", Метаданные.Справочники.ДоговорыКонтрагентов);
КонецФункции

&НаСервереБезКонтекста
Процедура ИзменитьДоговор(Договор, Реквизит, Значение)
	ДоговорОбъект = Договор.ПолучитьОбъект();
	ДоговорОбъект[Реквизит] = Значение;
	ДоговорОбъект.Записать();
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ИзменитьДопДанныеДоговора(Договор, Реквизит, Значение)
	Запись = РегистрыСведений.AMS_ДанныеДоговоров.СоздатьМенеджерЗаписи();

	Запись.Договор = Договор;

	Запись.Прочитать();

	Запись.Договор = Договор;
	Запись[Реквизит] = Значение;

	Запись.Записать();
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПриложенийЗавершение(Результат, ДополнительныеПераметры) Экспорт
	Если Не Результат = Неопределено Тогда
		ПоказатьОтчет();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗакрытьДоговор();

		Если СкрытьЗакрытыеДоговоры Тогда
			ПоказатьОтчет();
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗакрытьДоговор()
	ДоговорОбъект = Договор.ПолучитьОбъект();
	ДоговорОбъект.Статус = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.СтатусыДоговоровКонтрагентов.Закрыт");
	ДоговорОбъект.Записать();
КонецПроцедуры

#КонецОбласти