			<field>ДатаПолученияСкана</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СторонаОформления</dataPath>
			<field>СторонаОформления</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПартнерЗакрыт</dataPath>
			<field>ПартнерЗакрыт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Партнер закрыт</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КонтрагентЗакрыт</dataPath>
			<field>КонтрагентЗакрыт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Контрагент закрыт</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Наименование</dataPath>
			<field>Наименование</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ответственный</dataPath>
			<field>Ответственный</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Ответственный</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПредметДоговора</dataPath>
			<field>ПредметДоговора</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СпособДоставки</dataPath>
			<field>СпособДоставки</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СогласованРуководитель</dataPath>
			<field>СогласованРуководитель</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СогласованДиректор</dataPath>
			<field>СогласованДиректор</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Согласован директор</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ГруппаДоступа</dataPath>
			<field>ГруппаДоступа</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПоследняяЗакупка</dataPath>
			<field>ПоследняяЗакупка</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Последняя закупка</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоЗакупок</dataPath>
			<field>КоличествоЗакупок</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество закупок</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Договор КАК Договор,
	КОЛИЧЕСТВО(т.Ссылка) КАК КоличествоЗакупок,
	МАКСИМУМ(т.Дата) КАК ПоследняяЗакупка
ПОМЕСТИТЬ КолЗакупок
ИЗ
	Документ.ПриобретениеТоваровУслуг КАК т
ГДЕ
	т.Проведен
СГРУППИРОВАТЬ ПО
	т.Договор

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	т.Договор,
	КОЛИЧЕСТВО(т.Ссылка),
	МАКСИМУМ(т.Дата)
ИЗ
	Документ.ПриобретениеУслугПрочихАктивов КАК т
СГРУППИРОВАТЬ ПО
	т.Договор

ИНДЕКСИРОВАТЬ ПО
	Договор
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КолЗакупок.Договор КАК Договор,
	КолЗакупок.КоличествоЗакупок КАК КоличествоЗакупок,
	КолЗакупок.ПоследняяЗакупка КАК ПоследняяЗакупка
ПОМЕСТИТЬ вт
ИЗ
	КолЗакупок КАК КолЗакупок

ИНДЕКСИРОВАТЬ ПО
	Договор
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	д.Организация КАК Организация,
	д.Партнер КАК Партнер,
	п.ГруппаДоступа КАК ГруппаДоступа,
	п._Закрыт КАК ПартнерЗакрыт,
	д.Контрагент КАК Контрагент,
	к._Закрыт КАК КонтрагентЗакрыт,
	д.Ссылка КАК Договор,
	д.Менеджер КАК Ответственный,
	д.Наименование КАК Наименование,
	д.НаименованиеДляПечати КАК НаименованиеДляПечати,
	д.Статус КАК Статус,
	д.ДатаНачалаДействия КАК ДатаНачалаДействия,
	д.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
	дд.СогласованРуководитель КАК СогласованРуководитель,
	дд.СогласованЮрист КАК СогласованЮрист,
	дд.СогласованГлавбух КАК СогласованГлавбух,
	дд.СогласованДиректор КАК СогласованДиректор,
	дд.ДатаОтправки КАК ДатаОтправки,
	дд.СпособОтправки КАК СпособОтправки,
	дд.ДатаПолученияСкана КАК ДатаПолученияСкана,
	дд.ДатаПолученияОригинала КАК ДатаПолученияОригинала,
	дд.СторонаОформления КАК СторонаОформления,
	дд.ПредметДоговора КАК ПредметДоговора,
	дд.СпособДоставки КАК СпособДоставки,
	вт.ПоследняяЗакупка КАК ПоследняяЗакупка,
	ЕСТЬNULL(вт.КоличествоЗакупок, 0) КАК КоличествоЗакупок
ИЗ
	Справочник.ДоговорыКонтрагентов КАК д
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.AMS_ДанныеДоговоров КАК дд
		ПО д.Ссылка = дд.Договор
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК п
		ПО д.Партнер = п.Ссылка
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК к
		ПО д.Контрагент = к.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ вт КАК вт
		ПО д.Ссылка = вт.Договор
ГДЕ
	НЕ д.ПометкаУдаления
	И НЕ д.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СПокупателем)</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Приложения</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Договор</dataPath>
			<field>Договор</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Плюс</dataPath>
			<field>Плюс</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Плюс</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Договор КАК Договор,
	КОЛИЧЕСТВО(т.ВидПриложения) КАК Плюс
ИЗ
	РегистрСведений._ПриложенияКДоговорам КАК т

СГРУППИРОВАТЬ ПО
	т.Договор</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Соглашения</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Контрагент</dataPath>
			<field>Контрагент</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Организация</dataPath>
			<field>Организация</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Партнер</dataPath>
			<field>Партнер</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Соглашение</dataPath>
			<field>Соглашение</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Соглашение</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПроцентПлатежа</dataPath>
			<field>ПроцентПлатежа</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Сдвиг</dataPath>
			<field>Сдвиг</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВариантОплаты</dataPath>
			<field>ВариантОплаты</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВариантОтсчета</dataPath>
			<field>ВариантОтсчета</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Организация КАК Организация,
	т.Партнер КАК Партнер,
	т.Контрагент КАК Контрагент,
	МАКСИМУМ(т.Ссылка) КАК Соглашение
ПОМЕСТИТЬ вт1
ИЗ
	Справочник.СоглашенияСПоставщиками КАК т
ГДЕ
	НЕ т.ПометкаУдаления
	И т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСПоставщиками.Действует)
СГРУППИРОВАТЬ ПО
	т.Организация,
	т.Партнер,
	т.Контрагент

ИНДЕКСИРОВАТЬ ПО
	Соглашение
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	вт1.Соглашение КАК Соглашение,
	Оплаты.ВариантОплаты КАК ВариантОплаты,
	Оплаты.Сдвиг КАК Сдвиг,
	Оплаты.ВариантОтсчета КАК ВариантОтсчета,
	Оплаты.ПроцентПлатежа КАК ПроцентПлатежа
ПОМЕСТИТЬ вт2
ИЗ
	вт1 КАК вт1
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СоглашенияСПоставщиками.ЭтапыГрафикаОплаты КАК Оплаты
		ПО вт1.Соглашение = Оплаты.Ссылка
		И (Оплаты.НомерСтроки = 1)

ИНДЕКСИРОВАТЬ ПО
	Соглашение
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	вт1.Организация КАК Организация,
	вт1.Партнер КАК Партнер,
	вт1.Контрагент КАК Контрагент,
	вт1.Соглашение КАК Соглашение,
	вт2.ВариантОплаты КАК ВариантОплаты,
	вт2.Сдвиг КАК Сдвиг,
	вт2.ВариантОтсчета КАК ВариантОтсчета,
	вт2.ПроцентПлатежа КАК ПроцентПлатежа
ИЗ
	вт1 КАК вт1
		ЛЕВОЕ СОЕДИНЕНИЕ вт2 КАК вт2
		ПО вт1.Соглашение = вт2.Соглашение</query>
	</dataSet>
	<dataSetLink>
		<sourceDataSet>Договора</sourceDataSet>
		<destinationDataSet>Приложения</destinationDataSet>
		<sourceExpression>Договор</sourceExpression>
		<destinationExpression>Договор</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>Договора</sourceDataSet>
		<destinationDataSet>Соглашения</destinationDataSet>
		<sourceExpression>Организация</sourceExpression>
		<destinationExpression>Организация</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>Договора</sourceDataSet>
		<destinationDataSet>Соглашения</destinationDataSet>
		<sourceExpression>Партнер</sourceExpression>
		<destinationExpression>Партнер</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>Договора</sourceDataSet>
		<destinationDataSet>Соглашения</destinationDataSet>
		<sourceExpression>Контрагент</sourceExpression>
		<destinationExpression>Контрагент</destinationExpression>
	</dataSetLink>
	<settingsVariant>
		<dcsset:name>Основной</dcsset:name>
		<dcsset:presentation xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Договора партнёров</v8:content>
			</v8:item>
		</dcsset:presentation>
		<dcsset:settings xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows">
			<dcsset:selection>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>СистемныеПоля.НомерПоПорядку</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Партнер</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Контрагент</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Соглашение</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Договор</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Наименование</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>НаименованиеДляПечати</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Статус</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>СторонаОформления</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>ДатаНачалаДействия</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>ДатаОкончанияДействия</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>СогласованРуководитель</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>СогласованЮрист</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>СогласованГлавбух</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>СогласованДиректор</dcsset:field>
