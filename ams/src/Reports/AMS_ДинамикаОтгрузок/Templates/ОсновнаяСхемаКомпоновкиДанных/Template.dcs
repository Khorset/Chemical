		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Номенклатура КАК Номенклатура,
	СУММА(т.Количество) КАК Количество,
	СУММА(т.СуммаСНДС) КАК Сумма
ПОМЕСТИТЬ вт1
ИЗ
	Документ.РеализацияТоваровУслуг КАК д
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК т
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
			ПО т.Номенклатура = ном.Ссылка
			И ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			И ном.Качество = ЗНАЧЕНИЕ(Перечисление.ГрадацииКачества.Новый)
		ПО д.Ссылка = т.Ссылка
ГДЕ
	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&amp;Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&amp;Дата, ДЕНЬ)
	И д.Проведен
	И НЕ д.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))
СГРУППИРОВАТЬ ПО
	т.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Номенклатура КАК Номенклатура,
	СУММА(т.Количество) КАК Количество,
	СУММА(т.СуммаСНДС) КАК Сумма
ПОМЕСТИТЬ вт2
ИЗ
	Документ.РеализацияТоваровУслуг КАК д
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК т
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
			ПО т.Номенклатура = ном.Ссылка
			И ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			И ном.Качество = ЗНАЧЕНИЕ(Перечисление.ГрадацииКачества.Новый)
		ПО д.Ссылка = т.Ссылка
ГДЕ
	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, 1), ДЕНЬ) И КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, 1), ДЕНЬ)
	И д.Проведен
	И НЕ д.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))
СГРУППИРОВАТЬ ПО
	т.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

