			<dataPath>Кфц</dataPath>
			<field>Кфц</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Кфц</v8:content>
				</v8:item>
