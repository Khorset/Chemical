			ПО т.Номенклатура = ном.Ссылка
			И ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			И ном.Качество = ЗНАЧЕНИЕ(Перечисление.ГрадацииКачества.Новый)
		ПО д.Ссылка = т.Ссылка
ГДЕ
	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, 4), ДЕНЬ) И КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, 4), ДЕНЬ)
	И д.Проведен
	И НЕ д.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))
СГРУППИРОВАТЬ ПО
	т.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Номенклатура КАК Номенклатура,
	СУММА(т.Количество) КАК Количество,
	СУММА(т.СуммаСНДС) КАК Сумма
ПОМЕСТИТЬ вт6
ИЗ
	Документ.РеализацияТоваровУслуг КАК д
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК т
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
			ПО т.Номенклатура = ном.Ссылка
			И ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			И ном.Качество = ЗНАЧЕНИЕ(Перечисление.ГрадацииКачества.Новый)
		ПО д.Ссылка = т.Ссылка
ГДЕ
	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, 5), ДЕНЬ) И КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, 5), ДЕНЬ)
	И д.Проведен
	И НЕ д.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))
СГРУППИРОВАТЬ ПО
	т.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Номенклатура КАК Номенклатура,
	СУММА(т.Количество) КАК Количество,
	СУММА(т.СуммаСНДС) КАК Сумма
ПОМЕСТИТЬ вт7
ИЗ
	Документ.РеализацияТоваровУслуг КАК д
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК т
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
			ПО т.Номенклатура = ном.Ссылка
			И ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			И ном.Качество = ЗНАЧЕНИЕ(Перечисление.ГрадацииКачества.Новый)
		ПО д.Ссылка = т.Ссылка
ГДЕ
	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, 6), ДЕНЬ) И КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&amp;Дата, ДЕНЬ, 6), ДЕНЬ)
	И д.Проведен
	И НЕ д.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))
СГРУППИРОВАТЬ ПО
	т.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	AMS_Продукция.Родитель.Наименование КАК ТипПродукции,
	AMS_Продукция.Наименование КАК НазначениеПродукции,
	AMS_ПродукцияТовары.ТоварныйЗнак КАК ТоварныйЗнак,
	AMS_ПродукцияТовары.ТоварныйЗнак.Порядок КАК ТоварныйЗнакПорядок,
	AMS_ПродукцияТовары.НомерСтроки КАК НомерСтроки,
	AMS_ПродукцияТовары.Номенклатура КАК Номенклатура,
	Ном.Наименование КАК Наименование,
	Ном.КоэффициентЕдиницыДляОтчетов КАК Кфц
ПОМЕСТИТЬ Продукция
ИЗ
	Справочник.AMS_Продукция КАК AMS_Продукция
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция.Товары КАК AMS_ПродукцияТовары
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
			ПО AMS_ПродукцияТовары.Номенклатура = Ном.Ссылка
		ПО AMS_Продукция.Ссылка = AMS_ПродукцияТовары.Ссылка
ГДЕ
	НЕ AMS_Продукция.ЭтоГруппа
	И НЕ AMS_Продукция.ПометкаУдаления

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	т.ТипПродукции КАК ТипПродукции,
	т.НазначениеПродукции КАК НазначениеПродукции,
	т.ТоварныйЗнак КАК ТоварныйЗнак,
	т.ТоварныйЗнакПорядок КАК ТоварныйЗнакПорядок,
	т.НомерСтроки КАК НомерСтроки,
	т.Номенклатура КАК Номенклатура,
	т.Наименование КАК Наименование,
	т.Кфц КАК Кфц,
	ЕСТЬNULL(вт1.Количество, 0) / т.Кфц КАК Количество1,
	ЕСТЬNULL(вт1.Сумма, 0) КАК Сумма1,
	ЕСТЬNULL(вт2.Количество, 0) / т.Кфц КАК Количество2,
	ЕСТЬNULL(вт2.Сумма, 0) КАК Сумма2,
	ЕСТЬNULL(вт3.Количество, 0) / т.Кфц КАК Количество3,
	ЕСТЬNULL(вт3.Сумма, 0) КАК Сумма3,
	ЕСТЬNULL(вт4.Количество, 0) / т.Кфц КАК Количество4,
	ЕСТЬNULL(вт4.Сумма, 0) КАК Сумма4,
	ЕСТЬNULL(вт5.Количество, 0) / т.Кфц КАК Количество5,
	ЕСТЬNULL(вт5.Сумма, 0) КАК Сумма5,
	ЕСТЬNULL(вт6.Количество, 0) / т.Кфц КАК Количество6,
	ЕСТЬNULL(вт6.Сумма, 0) КАК Сумма6,
	ЕСТЬNULL(вт7.Количество, 0) / т.Кфц КАК Количество7,
	ЕСТЬNULL(вт7.Сумма, 0) КАК Сумма7,
	(ЕСТЬNULL(вт1.Количество, 0) + ЕСТЬNULL(вт2.Количество, 0) + ЕСТЬNULL(вт3.Количество, 0) + ЕСТЬNULL(вт4.Количество,
		0) + ЕСТЬNULL(вт5.Количество, 0) + ЕСТЬNULL(вт6.Количество, 0) + ЕСТЬNULL(вт7.Количество, 0)) / т.Кфц КАК
		КоличествоИтого,
	ЕСТЬNULL(вт1.Сумма, 0) + ЕСТЬNULL(вт2.Сумма, 0) + ЕСТЬNULL(вт3.Сумма, 0) + ЕСТЬNULL(вт4.Сумма, 0) +
		ЕСТЬNULL(вт5.Сумма, 0) + ЕСТЬNULL(вт6.Сумма, 0) + ЕСТЬNULL(вт7.Сумма, 0) КАК СуммаИтого
ИЗ
	Продукция КАК т
		ЛЕВОЕ СОЕДИНЕНИЕ вт1 КАК вт1
		ПО т.Номенклатура = вт1.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ вт2 КАК вт2
		ПО т.Номенклатура = вт2.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ вт3 КАК вт3
		ПО т.Номенклатура = вт3.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ вт4 КАК вт4
		ПО т.Номенклатура = вт4.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ вт5 КАК вт5
		ПО т.Номенклатура = вт5.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ вт6 КАК вт6
		ПО т.Номенклатура = вт6.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ вт7 КАК вт7
		ПО т.Номенклатура = вт7.Номенклатура</query>
