		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъектРасчетов</dataPath>
			<field>ОбъектРасчетов</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УдалитьЗаказКлиента</dataPath>
			<field>УдалитьЗаказКлиента</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъектРасчетовОбъект</dataPath>
			<field>ОбъектРасчетовОбъект</field>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
			<attributeUseRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</attributeUseRestriction>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Анал.Организация КАК Организация,
	Анал.Партнер КАК Партнер,
	Анал.Контрагент КАК Контрагент,
	Анал.Договор КАК Договор,
	РегОст.ОбъектРасчетов КАК ОбъектРасчетов,
	РегОст.СуммаОстаток КАК Остаток,
	РегОст.ОбъектРасчетов.Объект КАК ОбъектРасчетовОбъект
ИЗ
	РегистрНакопления.РасчетыСКлиентами.Остатки(КОНЕЦПЕРИОДА(&amp;Период, ДЕНЬ), ) КАК РегОст
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Анал
		ПО РегОст.АналитикаУчетаПоПартнерам = Анал.КлючАналитики
ГДЕ
	РегОст.СуммаОстаток &lt;&gt; 0
	И НЕ Анал.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.НашеПредприятие)</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>ЭтапыОплаты</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаПлатежа</dataPath>
			<field>ДатаПлатежа</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъектРасчетов</dataPath>
			<field>ОбъектРасчетов</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Объект расчетов</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Ссылка КАК ОбъектРасчетов,
	МАКСИМУМ(т.ДатаПлатежа) КАК ДатаПлатежа
ИЗ
	Документ.АктВыполненныхРабот.ЭтапыГрафикаОплаты КАК т

СГРУППИРОВАТЬ ПО
	т.Ссылка

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	т.Ссылка,
	МАКСИМУМ(т.ДатаПлатежа)
ИЗ
	Документ.РеализацияТоваровУслуг.ЭтапыГрафикаОплаты КАК т

СГРУППИРОВАТЬ ПО
	т.Ссылка</query>
	</dataSet>
	<dataSetLink>
		<sourceDataSet>Долги</sourceDataSet>
		<destinationDataSet>ЭтапыОплаты</destinationDataSet>
		<sourceExpression>ОбъектРасчетовОбъект</sourceExpression>
		<destinationExpression>ОбъектРасчетов</destinationExpression>
	</dataSetLink>
	<calculatedField>
		<dataPath>ДолгКлиента</dataPath>
		<expression>ВЫБОР
		КОГДА Остаток &gt; 0
			ТОГДА Остаток
		ИНАЧЕ 0
	КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Долг клиента</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">12</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>НашДолг</dataPath>
		<expression>ВЫБОР
		КОГДА Остаток &lt; 0
			ТОГДА -Остаток
		ИНАЧЕ 0
	КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Наш долг</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">12</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>ГруппаДоступа</dataPath>
		<expression>Партнер.ГруппаДоступа</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Группа доступа</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>ДатаПлатежа</dataPath>
		<expression>ДатаПлатежа</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата платежа</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>Отсрочка</dataPath>
		<expression>РАЗНОСТЬДАТ(ОбъектРасчетов.Дата, ДатаПлатежа, "ДЕНЬ")</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Отсрочка</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>Просрочено</dataPath>
		<expression>РАЗНОСТЬДАТ(ДатаПлатежа, &amp;Период,"ДЕНЬ")</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Просрочено</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<totalField>
		<dataPath>Остаток</dataPath>
		<expression>Сумма(Остаток)</expression>
	</totalField>
	<totalField>
		<dataPath>ДолгКлиента</dataPath>
		<expression>Сумма(ДолгКлиента)</expression>
	</totalField>
	<totalField>
		<dataPath>НашДолг</dataPath>
		<expression>Сумма(НашДолг)</expression>
	</totalField>
	<totalField>
		<dataPath>ДатаПлатежа</dataPath>
		<expression>Максимум(ДатаПлатежа)</expression>
		<group>ОбъектРасчетов</group>
	</totalField>
	<totalField>
		<dataPath>Отсрочка</dataPath>
		<expression>Максимум(Отсрочка)</expression>
		<group>ОбъектРасчетов</group>
	</totalField>
	<totalField>
		<dataPath>Просрочено</dataPath>
		<expression>Максимум(Просрочено)</expression>
		<group>ОбъектРасчетов</group>
	</totalField>
	<parameter>
		<name>Период</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>false</useRestriction>
		<inputParameters>
			<dcscor:item>
				<dcscor:use>false</dcscor:use>
				<dcscor:parameter>ФорматРедактирования</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ДФ=dd.MM.yyyy</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
		</inputParameters>
	</parameter>
