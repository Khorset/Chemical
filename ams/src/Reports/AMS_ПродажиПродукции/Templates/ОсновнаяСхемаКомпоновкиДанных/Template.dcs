		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	АналП.Организация КАК Организация,
	АналП.Партнер КАК Партнер,
	АналП.Контрагент КАК Контрагент,
	Выручка.Договор КАК Договор,
	Выручка.ЗаказКлиента КАК ЗаказКлиента,
	Выручка.Регистратор КАК Регистратор,
	Выручка.Менеджер КАК Менеджер,
	АналН.Номенклатура КАК Номенклатура,
	АналН.МестоХранения КАК Склад,
	Выручка.ПериодДень КАК ПериодДень,
	Выручка.ПериодМесяц КАК ПериодМесяц,
	Выручка.ПериодКвартал КАК ПериодКвартал,
	Выручка.ПериодГод КАК ПериодГод,
	Контр._Закрыт КАК КонтрагентЗакрыт,
	Парт.БизнесРегион КАК БизнесРегион,
	Парт.ГруппаДоступа КАК ГруппаДоступа,
	Парт._Закрыт КАК ПартнерЗакрыт,
	Ном.Артикул КАК Артикул,
	Ном._НомерВПрайсе КАК НомерВПрайсе,
	Ном.НаборУпаковок КАК НаборУпаковок,
	Ном._Упаковка КАК ЕдУпак,
	Ном.КоэффициентЕдиницыДляОтчетов КАК КфцУпак,
	ЕСТЬNULL(Выручка.КоличествоОборот, 0) КАК Количество,
	ЕСТЬNULL(Выручка.СуммаВыручкиОборот, 0) КАК Сумма
ПОМЕСТИТЬ Товары
ИЗ
	РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Авто,) КАК Выручка
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК АналП
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контр
			ПО АналП.Контрагент = Контр.Ссылка
		ПО Выручка.АналитикаУчетаПоПартнерам = АналП.КлючАналитики
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаНоменклатуры КАК АналН
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
			ПО АналН.Номенклатура = Ном.Ссылка
		ПО Выручка.АналитикаУчетаНоменклатуры = АналН.КлючАналитики
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Парт
		ПО АналП.Партнер = Парт.Ссылка
ГДЕ
	Ном.ВидНоменклатуры В (&amp;ВидыНоменклатурыПродукции)

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	Товары.Номенклатура КАК Номенклатура,
	Упак.Ссылка КАК ЕдШт
ПОМЕСТИТЬ Шт
ИЗ
	Товары КАК Товары
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Упак
		ПО Товары.НаборУпаковок = Упак.Владелец
		И Упак.Числитель = 1

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	Товары.Номенклатура КАК Номенклатура,
	Упак.Ссылка КАК ЕдПал,
	Упак.Числитель КАК КфцПал
ПОМЕСТИТЬ Пал
ИЗ
	Товары КАК Товары
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Упак
		ПО Товары.НаборУпаковок = Упак.Владелец
		И Упак.ЕдиницаИзмерения.Наименование = "пал"

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Товары.Организация КАК Организация,
	Товары.Партнер КАК Партнер,
	Товары.Контрагент КАК Контрагент,
	Товары.Договор КАК Договор,
	Товары.ЗаказКлиента КАК ЗаказКлиента,
	Товары.Регистратор КАК Регистратор,
	Товары.Менеджер КАК Менеджер,
	Товары.Склад КАК Склад,
	Товары.Номенклатура КАК Номенклатура,
	Товары.ПериодДень КАК ПериодДень,
	Товары.ПериодМесяц КАК ПериодМесяц,
	Товары.ПериодКвартал КАК ПериодКвартал,
	Товары.ПериодГод КАК ПериодГод,
	Товары.КонтрагентЗакрыт КАК КонтрагентЗакрыт,
	Товары.БизнесРегион КАК БизнесРегион,
	Товары.ГруппаДоступа КАК ГруппаДоступа,
	Товары.ПартнерЗакрыт КАК ПартнерЗакрыт,
	Товары.Артикул КАК Артикул,
	Товары.НомерВПрайсе КАК НомерВПрайсе,
	Шт.ЕдШт КАК ЕдШт,
	Товары.ЕдУпак КАК ЕдУпак,
	Пал.ЕдПал КАК ЕдПал,
	Товары.Количество КАК Количество,
	ВЫБОР
		КОГДА Товары.КфцУпак ЕСТЬ NULL
			ТОГДА 0
		ИНАЧЕ Товары.Количество / Товары.КфцУпак
	КОНЕЦ КАК КоличествоУпаковок,
	ВЫБОР
		КОГДА Пал.КфцПал ЕСТЬ NULL
			ТОГДА 0
		ИНАЧЕ Товары.Количество / Пал.КфцПал
	КОНЕЦ КАК КоличествоПалет,
	Товары.Сумма КАК Сумма
ИЗ
	Товары КАК Товары
		ЛЕВОЕ СОЕДИНЕНИЕ Шт КАК Шт
		ПО Товары.Номенклатура = Шт.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ Пал КАК Пал
		ПО Товары.Номенклатура = Пал.Номенклатура</query>
	</dataSet>
