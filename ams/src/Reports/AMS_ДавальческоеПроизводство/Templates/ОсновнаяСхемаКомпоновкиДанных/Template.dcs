		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоМатериал</dataPath>
			<field>КоличествоМатериал</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество материал</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПриемИзПереработки</dataPath>
			<field>ПриемИзПереработки</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Прием из переработки</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	д.Ссылка КАК ПриемИзПереработки,
	д.Партнер КАК Партнер,
	д.Контрагент КАК Контрагент,
	д.Склад КАК Склад,
	т.Номенклатура КАК Номенклатура,
	т.Количество КАК Количество,
	т.СборкаТоваров КАК СборкаТоваров
ПОМЕСТИТЬ Прием
ИЗ
	Документ._ПриемИзПереработки.Товары КАК т
		ЛЕВОЕ СОЕДИНЕНИЕ Документ._ПриемИзПереработки КАК д
		ПО т.Ссылка = д.Ссылка
ГДЕ
	д.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания

ИНДЕКСИРОВАТЬ ПО
	СборкаТоваров,
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Прием.ПриемИзПереработки КАК ПриемИзПереработки,
	Прием.Партнер КАК Партнер,
	Прием.Контрагент КАК Контрагент,
	Прием.Склад КАК Склад,
	Прием.Номенклатура КАК Номенклатура,
	Прием.Количество КАК Количество,
	Прием.СборкаТоваров КАК СборкаТоваров,
	т.Ссылка.ВариантКомплектации КАК ВариантКомплектации,
	т.Номенклатура КАК Материал,
	т.Количество КАК КоличествоМатериал
ИЗ
	Прием КАК Прием
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СборкаТоваров КАК д
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СборкаТоваров.Товары КАК т
			ПО д.Ссылка = т.Ссылка
		ПО Прием.СборкаТоваров = д.Ссылка
		И Прием.Номенклатура = д.Номенклатура</query>
	</dataSet>
	<totalField>
		<dataPath>Количество</dataPath>
		<expression>Сумма(Количество)</expression>
		<group>ВариантКомплектации</group>
		<group>Материал</group>
		<group>Номенклатура</group>
	</totalField>
	<totalField>
		<dataPath>КоличествоМатериал</dataPath>
		<expression>Сумма(КоличествоМатериал)</expression>
		<group>ВариантКомплектации</group>
		<group>Материал</group>
		<group>Номенклатура</group>
	</totalField>
