		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗЛИЧНЫЕ
	Контр.Партнер КАК Партнер,
	Контр.Ссылка КАК Контрагент,
	Контр.НаименованиеПолное КАК НаименованиеПолное,
	Контр.ЮрФизЛицо КАК ЮрФизЛицо,
	Контр.СтранаРегистрации КАК СтранаРегистрации,
	Контр.ГоловнойКонтрагент КАК ГоловнойКонтрагент,
	Контр.ИНН КАК ИНН,
	Контр.КПП КАК КПП,
	Контр.РегистрационныйНомер КАК РегистрационныйНомер,
	Контр.НалоговыйНомер КАК НалоговыйНомер,
	Контр.НаименованиеМеждународное КАК НаименованиеМеждународное,
	Контр._Закрыт КАК ЗакрытКонтрагент,
	Контр.AMS_ЧЗ_МаслоСмазочное КАК ЧЗ_МаслоСмазочное,
	Контр.AMS_ЧЗ_БытоваяХимия КАК ЧЗ_БытоваяХимия,
	ПочтАдрес.Представление КАК ПочтовыйАдресКонтрагента,
	Контр.Партнер.ГруппаДоступа КАК ГруппаДоступа
ПОМЕСТИТЬ Контр
ИЗ
	Справочник.Контрагенты КАК Контр
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК ПочтАдрес
		ПО Контр.Ссылка = ПочтАдрес.Ссылка
			И (ПочтАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПочтовыйАдресКонтрагента)
				ИЛИ ПочтАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресДляИнформированияФизическиеЛица))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Контр.Контрагент КАК Контрагент,
	МАКСИМУМ(ЮрАдрес.ДействуетС) КАК ДействуетС
ПОМЕСТИТЬ Юр1
ИЗ
	Контр КАК Контр
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК ЮрАдрес
		ПО Контр.Контрагент = ЮрАдрес.Ссылка
			И (ЮрАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента)
				ИЛИ ЮрАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресПоПропискеФизическиеЛица))

СГРУППИРОВАТЬ ПО
	Контр.Контрагент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Юр1.Контрагент КАК Контрагент,
	ЮрАдрес.Представление КАК ЮрАдрес,
	ЮрАдрес.Страна КАК Страна,
	ЮрАдрес.Регион КАК Регион,
	ЮрАдрес.Город КАК Город
ПОМЕСТИТЬ Юр
ИЗ
	Юр1 КАК Юр1
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК ЮрАдрес
		ПО Юр1.Контрагент = ЮрАдрес.Ссылка
			И Юр1.ДействуетС = ЮрАдрес.ДействуетС
			И (ЮрАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента)
				ИЛИ ЮрАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресПоПропискеФизическиеЛица))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Контр.Партнер КАК Партнер,
	Контр.Контрагент КАК Контрагент,
	Контр.НаименованиеПолное КАК НаименованиеПолное,
	Контр.НаименованиеМеждународное КАК НаименованиеМеждународное,
	Контр.ЮрФизЛицо КАК ЮрФизЛицо,
	Контр.СтранаРегистрации КАК СтранаРегистрации,
	Контр.ГоловнойКонтрагент КАК ГоловнойКонтрагент,
	Контр.ИНН КАК ИНН,
	Контр.КПП КАК КПП,
	Контр.РегистрационныйНомер КАК РегистрационныйНомер,
	Контр.НалоговыйНомер КАК НалоговыйНомер,
	Емейлы.АдресЭП КАК АдресЭП,
	Тел.НомерТелефона КАК НомерТелефона,
	Юр.Страна КАК Страна,
	Юр.Регион КАК Регион,
	Юр.Город КАК Город,
	Юр.ЮрАдрес КАК ЮридическийАдрес,
	Факт.Страна КАК Страна1,
	Факт.Регион КАК Регион1,
	Факт.Город КАК Город1,
	Факт.Представление КАК ФактическийАдрес,
	Контр.ПочтовыйАдресКонтрагента КАК ПочтовыйАдрес,
	Контр.ЧЗ_МаслоСмазочное КАК ЧЗ_МаслоСмазочное,
	Контр.ЧЗ_БытоваяХимия КАК ЧЗ_БытоваяХимия,
	Контр.ЗакрытКонтрагент КАК Закрыт,
	Контр.ГруппаДоступа КАК ГруппаДоступа
ИЗ
	Контр КАК Контр
		ЛЕВОЕ СОЕДИНЕНИЕ Юр КАК Юр
		ПО Контр.Контрагент = Юр.Контрагент
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК Факт
		ПО Контр.Контрагент = Факт.Ссылка
			И (Факт.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента)
				ИЛИ Факт.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресМестаПроживанияФизическиеЛица))
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК Емейлы
		ПО Контр.Контрагент = Емейлы.Ссылка
			И (Емейлы.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагента)
				ИЛИ Емейлы.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EMailФизическиеЛица))
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК Тел
		ПО Контр.Контрагент = Тел.Ссылка
			И (Тел.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента)
				ИЛИ Тел.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонРабочийФизическиеЛица))</query>
	</dataSet>
	<settingsVariant>
		<dcsset:name>Основной</dcsset:name>
