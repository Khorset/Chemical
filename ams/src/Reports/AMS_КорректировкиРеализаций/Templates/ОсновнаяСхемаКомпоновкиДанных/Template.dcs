				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаСрокГодности</dataPath>
			<field>СуммаСрокГодности</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма срок годности</v8:content>
				</v8:item>
			</title>
			<appearance>
