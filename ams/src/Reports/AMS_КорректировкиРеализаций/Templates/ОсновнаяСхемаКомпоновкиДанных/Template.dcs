				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаНетВНаличии</dataPath>
			<field>СуммаНетВНаличии</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
