		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоБрак</dataPath>
			<field>КоличествоБрак</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество брак</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоИзлишки</dataPath>
			<field>КоличествоИзлишки</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество излишки</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоНедостача</dataPath>
			<field>КоличествоНедостача</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество недостача</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоСрокГодности</dataPath>
			<field>КоличествоСрокГодности</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество срок годности</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоНетВНаличии</dataPath>
			<field>КоличествоНетВНаличии</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество нет в наличии</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоКорректировок</dataPath>
			<field>КоличествоКорректировок</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество корректировок</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Ссылка КАК КорректировкаРеализации,
	т.СуммаСНДС КАК Сумма,
	т._Причина КАК Причина
ПОМЕСТИТЬ вт
ИЗ
	Документ.КорректировкаРеализации.Расхождения КАК т

ИНДЕКСИРОВАТЬ ПО
	КорректировкаРеализации
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	вт.КорректировкаРеализации КАК КорректировкаРеализации,
	вт.Сумма КАК Сумма,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.Брак)
			ТОГДА вт.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК СуммаБрак,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.Излишки)
			ТОГДА вт.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК СуммаИзлишки,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.Недостача)
			ТОГДА вт.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК СуммаНедостача,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.СрокГодности)
			ТОГДА вт.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК СуммаСрокГодности,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.НетВНаличии)
			ТОГДА вт.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК СуммаНетВНаличии,
	вт.КорректировкаРеализации КАК КоличествоКорректировок,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.Брак)
			ТОГДА вт.КорректировкаРеализации
		ИНАЧЕ NULL
	КОНЕЦ КАК КоличествоБрак,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.Излишки)
			ТОГДА вт.КорректировкаРеализации
		ИНАЧЕ NULL
	КОНЕЦ КАК КоличествоИзлишки,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.Недостача)
			ТОГДА вт.КорректировкаРеализации
		ИНАЧЕ NULL
	КОНЕЦ КАК КоличествоНедостача,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.СрокГодности)
			ТОГДА вт.КорректировкаРеализации
		ИНАЧЕ NULL
	КОНЕЦ КАК КоличествоСрокГодности,
	ВЫБОР
		КОГДА вт.Причина = ЗНАЧЕНИЕ(Перечисление._ПричиныКорректировкиРеализации.НетВНаличии)
			ТОГДА вт.КорректировкаРеализации
		ИНАЧЕ NULL
	КОНЕЦ КАК КоличествоНетВНаличии
ИЗ
	вт КАК вт</query>
	</dataSet>
	<dataSetLink>
		<sourceDataSet>Реализации</sourceDataSet>
		<destinationDataSet>Корректировки</destinationDataSet>
		<sourceExpression>РеализацияТоваровУслуг</sourceExpression>
		<destinationExpression>РеализацияТоваровУслуг</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>Корректировки</sourceDataSet>
		<destinationDataSet>Расхождения</destinationDataSet>
		<sourceExpression>КорректировкаРеализации</sourceExpression>
		<destinationExpression>КорректировкаРеализации</destinationExpression>
	</dataSetLink>
	<calculatedField>
		<dataPath>ПроцентИзлишки</dataPath>
		<expression>100 * СуммаИзлишки / СуммаДокумента</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Процент излишки</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="xs:string">ЧДЦ='2'</dcscor:value>
