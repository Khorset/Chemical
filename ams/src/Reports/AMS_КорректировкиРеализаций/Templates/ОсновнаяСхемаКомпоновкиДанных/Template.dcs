		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоРеализаций</dataPath>
			<field>КоличествоРеализаций</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Количество реализаций</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Ссылка КАК РеализацияТоваровУслуг,
	т.AMS_СтатусРеализации КАК Статус,
	т.Автор КАК Автор,
	т.Организация КАК Организация,
	т.Партнер КАК Партнер,
	т.Контрагент КАК Контрагент,
	т.Партнер.ГруппаДоступа КАК ГруппаДоступа,
	т.Партнер.БизнесРегион КАК БизнесРегион,
	т.СуммаДокумента КАК СуммаДокумента,
	т.Ссылка КАК КоличествоРеализаций
ИЗ
	Документ.РеализацияТоваровУслуг КАК т
ГДЕ
	т.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
