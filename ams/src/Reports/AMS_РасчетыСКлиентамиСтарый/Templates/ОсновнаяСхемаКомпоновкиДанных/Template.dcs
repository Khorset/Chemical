<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>Расчеты</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>АналитикаУчетаПоПартнерам</dataPath>
			<field>АналитикаУчетаПоПартнерам</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Валюта</dataPath>
			<field>Валюта</field>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:use>false</dcscor:use>
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">36</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:use>false</dcscor:use>
					<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">38</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЗаказКлиента</dataPath>
			<field>ЗаказКлиента</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Регистратор</dataPath>
			<field>Регистратор</field>
			<role>
				<dcscom:periodNumber>1</dcscom:periodNumber>
				<dcscom:periodType>Main</dcscom:periodType>
				<dcscom:ignoreNullValues>true</dcscom:ignoreNullValues>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаОплачено</dataPath>
			<field>СуммаОплачено</field>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ=2</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:use>false</dcscor:use>
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:use>false</dcscor:use>
					<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">13</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаПродано</dataPath>
			<field>СуммаПродано</field>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ=2</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>ВыделятьОтрицательные</dcscor:parameter>
					<dcscor:value xsi:type="xs:boolean">true</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:use>false</dcscor:use>
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:use>false</dcscor:use>
					<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">13</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НашДолг</dataPath>
			<field>НашДолг</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Наш долг</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Контрагент</dataPath>
			<field>Контрагент</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">20</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">25</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Партнер</dataPath>
			<field>Партнер</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Клиент</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">20</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">25</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Организация</dataPath>
			<field>Организация</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Договор</dataPath>
			<field>Договор</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Договор</v8:content>
				</v8:item>
			</title>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">20</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">25</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДолгКлиента</dataPath>
			<field>ДолгКлиента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Долг клиента</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>УдалитьЗаказКлиента</dataPath>
			<field>УдалитьЗаказКлиента</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъектРасчетов</dataPath>
			<field>ОбъектРасчетов</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	АналитикаПоПартнерам.КлючАналитики КАК КлючАналитики,
	АналитикаПоПартнерам.Организация КАК Организация,
	АналитикаПоПартнерам.Партнер КАК Партнер,
	АналитикаПоПартнерам.Контрагент КАК Контрагент
ПОМЕСТИТЬ Аналитика
ИЗ
	РегистрСведений.АналитикаУчетаПоПартнерам КАК АналитикаПоПартнерам
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
		ПО АналитикаПоПартнерам.Партнер = Партнеры.Ссылка
{ГДЕ
	АналитикаПоПартнерам.Организация}

ИНДЕКСИРОВАТЬ ПО
	КлючАналитики
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	ЕСТЬNULL(Обороты.АналитикаУчетаПоПартнерам, Долги.АналитикаУчетаПоПартнерам) КАК АналитикаУчетаПоПартнерам,
	ВЫБОР
		КОГДА Обороты.ОбъектРасчетов ЕСТЬ NULL
			ТОГДА ВЫБОР
				КОГДА Долги.ОбъектРасчетов.Объект ССЫЛКА Справочник.ДоговорыКонтрагентов
					ТОГДА Долги.ОбъектРасчетов
				ИНАЧЕ Долги.ОбъектРасчетов.Договор
			КОНЕЦ
		ИНАЧЕ ВЫБОР
			КОГДА Обороты.ОбъектРасчетов.Объект ССЫЛКА Справочник.ДоговорыКонтрагентов
				ТОГДА Обороты.ОбъектРасчетов
			ИНАЧЕ Обороты.ОбъектРасчетов.Договор
		КОНЕЦ
	КОНЕЦ КАК Договор,
	ЕСТЬNULL(Обороты.ОбъектРасчетов.Объект, Долги.ОбъектРасчетов.Объект) КАК ЗаказКлиента,
	Обороты.Регистратор КАК Регистратор,
	ВЫБОР
		КОГДА Обороты.Регистратор ССЫЛКА Документ.ВозвратТоваровОтКлиента
		ИЛИ Обороты.Регистратор ССЫЛКА Документ.КорректировкаРеализации
			ТОГДА Обороты.СуммаОборот
		ИНАЧЕ Обороты.СуммаПриход
	КОНЕЦ КАК СуммаПродано,
	ВЫБОР
		КОГДА Обороты.Регистратор ССЫЛКА Документ.ВозвратТоваровОтКлиента
		ИЛИ Обороты.Регистратор ССЫЛКА Документ.КорректировкаРеализации
			ТОГДА 0
		ИНАЧЕ Обороты.СуммаРасход
	КОНЕЦ КАК СуммаОплачено,
	ВЫБОР
		КОГДА Долги.СуммаОстаток &gt; 0
			ТОГДА Долги.СуммаОстаток
		ИНАЧЕ 0
	КОНЕЦ КАК ДолгКлиента,
	ВЫБОР
		КОГДА Долги.СуммаОстаток &lt; 0
			ТОГДА -Долги.СуммаОстаток
		ИНАЧЕ 0
	КОНЕЦ КАК НашДолг
ПОМЕСТИТЬ Расчеты
ИЗ
	РегистрНакопления.РасчетыСКлиентами.Остатки(, АналитикаУчетаПоПартнерам В
		(ВЫБРАТЬ
			Аналитика.КлючАналитики
		ИЗ
			Аналитика КАК Аналитика)) КАК Долги
		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСКлиентами.Обороты(,, Регистратор, АналитикаУчетаПоПартнерам В
			(ВЫБРАТЬ
				Аналитика.КлючАналитики
			ИЗ
				Аналитика КАК Аналитика)) КАК Обороты
		ПО Долги.ОбъектРасчетов = Обороты.ОбъектРасчетов
		И Долги.ОбъектРасчетов = Обороты.Регистратор

ИНДЕКСИРОВАТЬ ПО
	АналитикаУчетаПоПартнерам
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Аналитика.Организация КАК Организация,
	Аналитика.Партнер КАК Партнер,
	Аналитика.Контрагент КАК Контрагент,
	Расчеты.Договор КАК Договор,
	Расчеты.ЗаказКлиента КАК ЗаказКлиента,
	Расчеты.Регистратор КАК Регистратор,
	Расчеты.СуммаПродано КАК СуммаПродано,
	Расчеты.СуммаОплачено КАК СуммаОплачено,
	Расчеты.ДолгКлиента КАК ДолгКлиента,
	Расчеты.НашДолг КАК НашДолг
ИЗ
	Расчеты КАК Расчеты
		ЛЕВОЕ СОЕДИНЕНИЕ Аналитика КАК Аналитика
		ПО Расчеты.АналитикаУчетаПоПартнерам = Аналитика.КлючАналитики</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>ЭтапыОплаты</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаПлатежа</dataPath>
			<field>ДатаПлатежа</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЗаказКлиента</dataPath>
			<field>ЗаказКлиента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Заказ клиента</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Ссылка КАК ЗаказКлиента,
	МАКСИМУМ(т.ДатаПлатежа) КАК ДатаПлатежа
ИЗ
	Документ.АктВыполненныхРабот.ЭтапыГрафикаОплаты КАК т

СГРУППИРОВАТЬ ПО
	т.Ссылка

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	т.Ссылка,
	МАКСИМУМ(т.ДатаПлатежа)
ИЗ
	Документ.РеализацияТоваровУслуг.ЭтапыГрафикаОплаты КАК т

СГРУППИРОВАТЬ ПО
	т.Ссылка</query>
	</dataSet>
	<dataSetLink>
		<sourceDataSet>Расчеты</sourceDataSet>
		<destinationDataSet>ЭтапыОплаты</destinationDataSet>
		<sourceExpression>ЗаказКлиента</sourceExpression>
		<destinationExpression>ЗаказКлиента</destinationExpression>
	</dataSetLink>
	<calculatedField>
		<dataPath>ДолгПросрочен</dataPath>
		<expression>ВЫБОР КОГДА &amp;ТекущаяДата &gt; ДатаПлатежа ТОГДА ДолгКлиента ИНАЧЕ 0 КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Долг просрочен</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:use>false</dcscor:use>
				<dcscor:parameter>ЦветТекста</dcscor:parameter>
				<dcscor:value xmlns:d5p1="http://v8.1c.ru/8.1/data/ui/style" xsi:type="v8ui:Color">d5p1:NegativeTextColor</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="xs:string">ЧЦ=15; ЧДЦ=2</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:use>false</dcscor:use>
				<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:use>false</dcscor:use>
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">12</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>ДатаПлатежа</dataPath>
		<expression>ВЫБОР КОГДА ДолгКлиента = 0 ТОГДА ДАТАВРЕМЯ(1, 1, 1) ИНАЧЕ ВЫБОР КОГДА ЗаказКлиента ЕСТЬ NULL ТОГДА ДАТАВРЕМЯ(2013, 1, 1) ИНАЧЕ ДатаПлатежа КОНЕЦ КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата платежа</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
				<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="xs:string">ДФ='dd.MM.yyyy'</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">7</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">9</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>ГруппаДоступа</dataPath>
		<expression>Партнер.ГруппаДоступа</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Группа доступа</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>ГоловноеПредприятие</dataPath>
		<expression>ВЫБОР КОГДА Партнер.Родитель = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка) ТОГДА Партнер	ИНАЧЕ Партнер.Родитель КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Головное предприятие</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>Отсрочка</dataPath>
		<expression>ВЫБОР КОГДА ДолгКлиента = 0 ТОГДА 0 ИНАЧЕ РАЗНОСТЬДАТ(ЗаказКлиента.Дата, ДатаПлатежа, "ДЕНЬ") КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Отсрочка</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
				<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">9</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
