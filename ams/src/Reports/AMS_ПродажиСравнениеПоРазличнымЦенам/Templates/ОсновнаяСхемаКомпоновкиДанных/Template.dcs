		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Ссылка КАК ДокументПродажи,
	т.Номенклатура КАК Номенклатура,
	т.ВидЦены КАК ВидЦены,
	т.Количество КАК Количество,
	т.Сумма / т.Количество * 1.2 КАК Цена,
	ЕСТЬNULL(Цены1.Цена, 0) * 1.2 КАК Цена1,
	ЕСТЬNULL(Цены2.Цена, 0) * 1.2 КАК Цена2,
	т.Сумма * 1.2 КАК Сумма,
	т.Количество * ЕСТЬNULL(Цены1.Цена, 0) * 1.2 КАК Сумма1,
	т.Количество * ЕСТЬNULL(Цены2.Цена, 0) * 1.2 КАК Сумма2
ИЗ
	Документ.РеализацияТоваровУслуг КАК д
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК т
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&amp;ДатаНачала,) КАК Цены1
			ПО т.Номенклатура = Цены1.Номенклатура
			И т.ВидЦены = Цены1.ВидЦены
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&amp;ДатаПрайса,) КАК Цены2
			ПО т.Номенклатура = Цены2.Номенклатура
			И т.ВидЦены = Цены2.ВидЦены
		ПО д.Ссылка = т.Ссылка
ГДЕ
	д.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
	И д.Проведен
	И НЕ д.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))
	И НЕ т.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)</query>
	</dataSet>
	<calculatedField>
		<dataPath>Разница1</dataPath>
