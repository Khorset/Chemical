		<field xsi:type="DataSetFieldField">
			<dataPath>Партнер</dataPath>
			<field>Партнер</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДокументТУ</dataPath>
			<field>ДокументТУ</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Документ ТУ</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	т.Период КАК Период,
	т.Регистратор КАК ДокументТУ,
	т.Организация КАК Организация,
	т.ОрганизацияЗаказа КАК ОрганизацияЗаказа,
	т.Партнер КАК Партнер,
	т.Водитель КАК Водитель,
	т.ТранспортноеСредство КАК ТранспортноеСредство,
	т.ЛогистическийЛист КАК ЛогистическийЛист,
	т.ЗаказКлиента КАК ЗаказКлиента,
	т.Вес КАК Вес,
	т.Стоимость КАК Стоимость
ИЗ
	РегистрСведений._ОплатаРейсов КАК т
ГДЕ
	т.Период МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания</query>
	</dataSet>
