		<field xsi:type="DataSetFieldField">
			<dataPath>Упаковка</dataPath>
			<field>Упаковка</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Упаковка</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.Ссылка.Проведен КАК Проведен,
	т.НомерСтроки КАК НомерСтроки,
	т.Номенклатура.Артикул КАК Артикул,
	т.Номенклатура КАК Номенклатура,
	т.Количество КАК Количество,
	т.Номенклатура._Упаковка КАК Упаковка,
	т.Номенклатура.КоэффициентЕдиницыДляОтчетов КАК Кфц
ПОМЕСТИТЬ тов
ИЗ
	Документ.РеализацияТоваровУслуг.Товары КАК т
ГДЕ
	т.Ссылка = &amp;Ссылка

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВЫБОР
		КОГДА т.Ссылка.Проведен
		И т.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.КОтгрузке)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ,
	т.НомерСтроки,
	т.Номенклатура.Артикул,
	т.Номенклатура,
	т.Количество,
	т.Номенклатура._Упаковка,
	т.Номенклатура.КоэффициентЕдиницыДляОтчетов
ИЗ
	Документ.ЗаказКлиента.Товары КАК т
ГДЕ
	т.Ссылка = &amp;Ссылка

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	т.Номенклатура КАК Номенклатура,
	ЕСТЬNULL(т.ВНаличииОстаток, 0) КАК ВНаличии
ПОМЕСТИТЬ ост
ИЗ
	РегистрНакопления.ТоварыНаСкладах.Остатки(, Склад = &amp;СкладПродукции
	И Номенклатура В
		(ВЫБРАТЬ
			т.Номенклатура КАК Номенклатура
		ИЗ
			тов КАК т)) КАК т

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	т.Номенклатура КАК Номенклатура,
	ЕСТЬNULL(т.КОтгрузкеОстаток, 0) КАК КОтгрузке
ПОМЕСТИТЬ рез
ИЗ
	РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &amp;СкладПродукции
	И Номенклатура В
		(ВЫБРАТЬ
			т.Номенклатура КАК Номенклатура
		ИЗ
			тов КАК т)) КАК т

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	тов.НомерСтроки КАК НомерСтроки,
	тов.Артикул КАК Артикул,
	тов.Номенклатура КАК Номенклатура,
	тов.Упаковка КАК Упаковка,
	тов.Кфц КАК Кфц,
	ЕСТЬNULL(ост.ВНаличии, 0) КАК ВНаличии,
	ВЫБОР
		КОГДА тов.Проведен
			ТОГДА ЕСТЬNULL(рез.КОтгрузке, 0) - ЕСТЬNULL(тов.Количество, 0)
		ИНАЧЕ ЕСТЬNULL(рез.КОтгрузке, 0)
	КОНЕЦ КАК Резерв,
	ЕСТЬNULL(ост.ВНаличии, 0) - ВЫБОР
		КОГДА тов.Проведен
			ТОГДА ЕСТЬNULL(рез.КОтгрузке, 0) - ЕСТЬNULL(тов.Количество, 0)
		ИНАЧЕ ЕСТЬNULL(рез.КОтгрузке, 0)
	КОНЕЦ КАК Доступно,
	ЕСТЬNULL(тов.Количество, 0) КАК Расход,
	ЕСТЬNULL(ост.ВНаличии, 0) - ВЫБОР
		КОГДА тов.Проведен
			ТОГДА ЕСТЬNULL(рез.КОтгрузке, 0) - ЕСТЬNULL(тов.Количество, 0)
		ИНАЧЕ ЕСТЬNULL(рез.КОтгрузке, 0)
	КОНЕЦ - ЕСТЬNULL(тов.Количество, 0) КАК Остаток
ПОМЕСТИТЬ вт
ИЗ
	тов КАК тов
		ЛЕВОЕ СОЕДИНЕНИЕ ост КАК ост
		ПО тов.Номенклатура = ост.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ рез КАК рез
		ПО тов.Номенклатура = рез.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	вт.НомерСтроки КАК НомерСтроки,
	вт.Артикул КАК Артикул,
	вт.Номенклатура КАК Номенклатура,
	вт.Упаковка КАК Упаковка,
	вт.ВНаличии / вт.Кфц КАК ВНаличии,
	вт.Резерв / вт.Кфц КАК Резерв,
	вт.Доступно / вт.Кфц КАК Доступно,
	вт.Расход / вт.Кфц КАК Расход,
	вт.Остаток / вт.Кфц КАК Остаток
ИЗ
	вт КАК вт</query>
	</dataSet>
	<parameter>
		<name>Период</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Период</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
		<availableAsField>false</availableAsField>
	</parameter>
	<parameter>
		<name>СкладПродукции</name>
