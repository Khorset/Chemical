		<name>Распоряжения</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТранспортноеСредство</dataPath>
			<field>ТранспортноеСредство</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЛогистическийЛист</dataPath>
			<field>ЛогистическийЛист</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Логистический лист</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПорядокВМаршруте</dataPath>
			<field>ПорядокВМаршруте</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЕстьНарушениеДоговора</dataPath>
			<field>ЕстьНарушениеДоговора</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Распоряжение</dataPath>
			<field>Распоряжение</field>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">32</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЕстьЧек</dataPath>
			<field>ЕстьЧек</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЕстьПретензия</dataPath>
			<field>ЕстьПретензия</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭтоДоставка</dataPath>
			<field>ЭтоДоставка</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Это доставка</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Расстояние</dataPath>
			<field>Расстояние</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СтоимостьЧека1</dataPath>
			<field>СтоимостьЧека1</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Стоимость чека1</v8:content>
				</v8:item>
			</title>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаШтрафа1</dataPath>
			<field>СуммаШтрафа1</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма штрафа1</v8:content>
				</v8:item>
			</title>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаПретензии1</dataPath>
			<field>СуммаПретензии1</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма претензии1</v8:content>
				</v8:item>
			</title>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПунктДоговора1</dataPath>
			<field>ПунктДоговора1</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Пункт договора1</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СодержаниеПретензии1</dataPath>
			<field>СодержаниеПретензии1</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Содержание претензии1</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЕстьУПД</dataPath>
			<field>ЕстьУПД</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Есть УПД</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ссылка</dataPath>
			<field>Ссылка</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	т.Ссылка КАК ЛогистическийЛист,
	т.ТранспортноеСредство КАК ТранспортноеСредство,
	т.ПорядокВМаршруте КАК ПорядокВМаршруте,
	ВЫБОР
		КОГДА т.ОбъединеннаяЗагрузка = ЗНАЧЕНИЕ(Документ.AMS_ОбъединеннаяЗагрузка.ПустаяСсылка)
			ТОГДА т.Распоряжение
		ИНАЧЕ т.ОбъединеннаяЗагрузка
	КОНЕЦ КАК Распоряжение,
	т.Расстояние КАК Расстояние,
	ВЫБОР
		КОГДА т.Распоряжение ССЫЛКА Документ.РеализацияТоваровУслуг
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоДоставка,
	т.ЕстьЧек КАК ЕстьЧек,
	т.СтоимостьЧека КАК СтоимостьЧека1,
	т.ЕстьНарушениеДоговора КАК ЕстьНарушениеДоговора,
	т.ПунктДоговора КАК ПунктДоговора1,
	т.СуммаШтрафа КАК СуммаШтрафа1,
	т.ЕстьПретензия КАК ЕстьПретензия,
	т.СодержаниеПретензии КАК СодержаниеПретензии1,
	т.СуммаПретензии КАК СуммаПретензии1,
	Реал.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА Реал.Проведен
		И НЕ т.Распоряжение.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
			ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке),
			ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Отгружено))
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЕстьУПД
ИЗ
	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реал
		ПО т.Распоряжение = Реал.Ссылка</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>ТУ</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЛогистическийЛист</dataPath>
			<field>ЛогистическийЛист</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТранспортноеСредство</dataPath>
			<field>ТранспортноеСредство</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>РейсОплачен</dataPath>
			<field>РейсОплачен</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Рейс оплачен</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	т.ЛогистическийЛист КАК ЛогистическийЛист,
	т.ТранспортноеСредство КАК ТранспортноеСредство,
	т.Метка КАК РейсОплачен
ИЗ
	Документ._ТранспортныеУслуги.Рейсы КАК т
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ._ТранспортныеУслуги КАК д
		ПО т.Ссылка = д.Ссылка
ГДЕ
	д.Проведен</query>
	</dataSet>
