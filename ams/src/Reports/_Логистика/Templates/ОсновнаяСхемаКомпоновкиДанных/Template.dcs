		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	т.ЛогистическийЛист КАК ЛогистическийЛист,
	т.ТранспортноеСредство КАК ТранспортноеСредство,
	т.Распоряжение КАК Распоряжение,
	т.Метка КАК МеткаШтрафа,
	т.ПунктДоговора КАК ПунктДоговора2,
	т.СуммаШтрафа КАК СуммаШтрафа2
ИЗ
	Документ._ТранспортныеУслуги.ШтрафыЗаНарушенияДоговора КАК т</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Претензии</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЛогистическийЛист</dataPath>
			<field>ЛогистическийЛист</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТранспортноеСредство</dataPath>
			<field>ТранспортноеСредство</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Распоряжение</dataPath>
			<field>Распоряжение</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>МеткаПретензии</dataPath>
			<field>МеткаПретензии</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Метка претензии</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаПретензии2</dataPath>
			<field>СуммаПретензии2</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма претензии2</v8:content>
				</v8:item>
			</title>
			<useRestriction>
				<field>true</field>
				<condition>true</condition>
				<group>true</group>
				<order>true</order>
			</useRestriction>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СодержаниеПретензии2</dataPath>
			<field>СодержаниеПретензии2</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Содержание претензии2</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	т.ЛогистическийЛист КАК ЛогистическийЛист,
	т.ТранспортноеСредство КАК ТранспортноеСредство,
	т.Распоряжение КАК Распоряжение,
	т.Метка КАК МеткаПретензии,
	т.СуммаПретензии КАК СуммаПретензии2,
	т.СодержаниеПретензии КАК СодержаниеПретензии2
ИЗ
	Документ._ТранспортныеУслуги.ШтрафыЗаПретензии КАК т</query>
	</dataSet>
