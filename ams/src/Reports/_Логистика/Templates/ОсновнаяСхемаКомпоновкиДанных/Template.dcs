	<calculatedField>
		<dataPath>Перевозчик</dataPath>
		<expression>ТранспортноеСредство._Перевозчик</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Перевозчик</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>Водитель</dataPath>
		<expression>ТранспортноеСредство._Водитель</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Водитель</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>АдресДоставки</dataPath>
		<expression>ВЫБОР КОГДА Распоряжение.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчикаПоАдресу) ТОГДА Распоряжение.АдресДоставкиПеревозчика ИНАЧЕ Распоряжение.АдресДоставки КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Адрес доставки</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">28</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>Клиент</dataPath>
		<expression>Распоряжение.Партнер</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Клиент</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">28</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>ВремяДоставкиС</dataPath>
		<expression>Распоряжение.ВремяДоставкиС</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>с</v8:content>
			</v8:item>
		</title>
		<presentationExpression>Формат(Распоряжение.ВремяДоставкиС, "ДФ=""HH:mm""")</presentationExpression>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
				<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">5</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>ВремяДоставкиПо</dataPath>
		<expression>Распоряжение.ВремяДоставкиПо</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>по</v8:content>
			</v8:item>
		</title>
		<presentationExpression>Формат(Распоряжение.ВремяДоставкиПо, "ДФ=""HH:mm""")</presentationExpression>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
				<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">5</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>КОплате</dataPath>
		<expression>ЕСТЬNULL(СтоимостьДоставки,0) + ЕСТЬNULL(СтоимостьЧека,0) - ЕСТЬNULL(СуммаШтрафа,0) - ЕСТЬNULL(СуммаПретензии,0)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Сумма к оплате за доставку</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">12</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>КоличествоРейсов</dataPath>
		<expression>ЛогистическийЛист</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Количество рейсов</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>Дата</dataPath>
		<expression>ЛогистическийЛист.Дата</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ДФ=dd.MM.yy</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>КоличествоПалет</dataPath>
		<expression>Распоряжение.AMS_КоличествоПалет</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Количество палет</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:use>false</dcscor:use>
				<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
				<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">6</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>Вес</dataPath>
		<expression>Распоряжение.AMS_Вес</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Вес</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:use>false</dcscor:use>
				<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
				<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ЧДЦ=1</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>Менеджер</dataPath>
		<expression>Распоряжение.Менеджер</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Менеджер</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">28</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>РейсОплачен</dataPath>
		<expression>ЕСТЬNULL(РейсОплачен,ЛОЖЬ)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Рейс оплачен</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>ПроцентПалет</dataPath>
		<expression>100 * Распоряжение.AMS_КоличествоПалет / ВместимостьПалет</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Процент палет</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:use>false</dcscor:use>
				<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
				<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ЧДЦ=0</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">4</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>ПроцентВес</dataPath>
		<expression>100 * Распоряжение.AMS_Вес / ВместимостьТонн</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Процент вес</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:use>false</dcscor:use>
				<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
				<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>ЧДЦ=0</v8:content>
					</v8:item>
				</dcscor:value>
			</dcscor:item>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>МаксимальнаяШирина</dcscor:parameter>
				<dcscor:value xsi:type="xs:decimal">4</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<calculatedField>
		<dataPath>СтоимостьЧека</dataPath>
		<expression>ЕСТЬNULL(СтоимостьЧека2, СтоимостьЧека1)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Стоимость чека</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>СуммаШтрафа</dataPath>
		<expression>ЕСТЬNULL(СуммаШтрафа2, СуммаШтрафа1)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Сумма штрафа</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>СуммаПретензии</dataPath>
		<expression>ЕСТЬNULL(СуммаПретензии2, СуммаПретензии1)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Сумма претензии</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>ПунктДоговора</dataPath>
		<expression>ЕСТЬNULL(ПунктДоговора2, ПунктДоговора1)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Пункт договора</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>СодержаниеПретензии</dataPath>
		<expression>ЕСТЬNULL(СодержаниеПретензии2, СодержаниеПретензии1)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Содержание претензии</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<totalField>
		<dataPath>ВремяДоставкиС</dataPath>
		<expression>Формат(Максимум(ВремяДоставкиС), "ДФ=""HH:mm""")</expression>
	</totalField>
	<totalField>
		<dataPath>ВремяДоставкиПо</dataPath>
		<expression>Формат(Максимум(ВремяДоставкиПо), "ДФ=""HH:mm""")</expression>
	</totalField>
	<totalField>
		<dataPath>КОплате</dataPath>
		<expression>Сумма(СтоимостьДоставки) + Сумма(СтоимостьЧека) - Сумма(СуммаШтрафа) - Сумма(СуммаПретензии)</expression>
	</totalField>
	<totalField>
		<dataPath>КоличествоРейсов</dataPath>
		<expression>Количество(КоличествоРейсов)</expression>
	</totalField>
	<totalField>
		<dataPath>ВремяЗагрузки</dataPath>
		<expression>Формат(Максимум(ВремяЗагрузки), "ДФ=""дд.ММ.гг HH:mm""")</expression>
		<group>ТранспортноеСредство</group>
	</totalField>
	<totalField>
		<dataPath>ВремяЗагрузкиФакт</dataPath>
		<expression>Формат(Максимум(ВремяЗагрузкиФакт), "ДФ=""HH:mm""")</expression>
		<group>ТранспортноеСредство</group>
	</totalField>
	<totalField>
		<dataPath>Отправлено</dataPath>
		<expression>Формат(Максимум(Отправлено), "ДФ=""HH:mm""")</expression>
		<group>ТранспортноеСредство</group>
	</totalField>
	<totalField>
		<dataPath>ВремяДоставкиПо</dataPath>
		<expression>Формат(Максимум(ВремяДоставкиПо), "ДФ=""HH:mm""")</expression>
		<group>ТранспортноеСредство</group>
	</totalField>
	<totalField>
		<dataPath>ВремяДоставкиС</dataPath>
		<expression>Формат(Максимум(ВремяДоставкиС), "ДФ=""HH:mm""")</expression>
		<group>ТранспортноеСредство</group>
	</totalField>
	<totalField>
		<dataPath>Вес</dataPath>
		<expression>Сумма(Вес)</expression>
	</totalField>
	<totalField>
		<dataPath>КоличествоПалет</dataPath>
		<expression>Сумма(КоличествоПалет)</expression>
	</totalField>
	<totalField>
		<dataPath>СтоимостьДоставки</dataPath>
		<expression>Сумма(СтоимостьДоставки)</expression>
	</totalField>
	<totalField>
		<dataPath>ЕстьУПД</dataPath>
		<expression>Максимум(ЕстьУПД)</expression>
	</totalField>
	<totalField>
		<dataPath>РейсОплачен</dataPath>
		<expression>Минимум(РейсОплачен)</expression>
	</totalField>
	<totalField>
		<dataPath>Пробег</dataPath>
		<expression>Сумма(Пробег)</expression>
	</totalField>
	<totalField>
		<dataPath>ВместимостьПалет</dataPath>
		<expression>Сумма(ВместимостьПалет)</expression>
	</totalField>
	<totalField>
		<dataPath>ВместимостьТонн</dataPath>
		<expression>Сумма(ВместимостьТонн)</expression>
	</totalField>
	<totalField>
		<dataPath>ПроцентВес</dataPath>
		<expression>100 * Сумма(Вес) / Сумма(ВместимостьТонн)</expression>
	</totalField>
	<totalField>
		<dataPath>ПроцентПалет</dataPath>
		<expression>100 * Сумма(КоличествоПалет) / Сумма(ВместимостьПалет)</expression>
	</totalField>
	<totalField>
		<dataPath>СтоимостьЧека</dataPath>
		<expression>Сумма(СтоимостьЧека)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаШтрафа</dataPath>
		<expression>Сумма(СуммаШтрафа)</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаПретензии</dataPath>
		<expression>Сумма(СуммаПретензии)</expression>
	</totalField>
