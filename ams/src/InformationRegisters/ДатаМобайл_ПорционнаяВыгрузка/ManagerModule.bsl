#Область Контрагенты  

Процедура ЗарегистрироватьКонтрагентовПодПорционнуюВыгрузку(УзелПО, Значение) Экспорт
	
	Если Значение Тогда
		
		ДатаМобайл_ОбщийМодуль.СообщитьПользователю("Регистрация контрагентов под выгрузку...");
		
		// 1. Очищаем регистр от возможных данных с других обменов:
		
		НаборЗаписей = РегистрыСведений.ДатаМобайл_ПорционнаяВыгрузка.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТСД.Установить(УзелПО);
		// 1-товары
		НаборЗаписей.Отбор.ТипОбъекта.Установить(3);
		НаборЗаписей.Прочитать();
		НаборЗаписей.Очистить(); 
		НаборЗаписей.Записать(Истина);  
		
		КоличествоКонтрагентовВПорции = УзелПО.КоличествоКонтрагентовВПорции;
		Если Не ЗначениеЗаполнено(КоличествоКонтрагентовВПорции) Тогда
			КоличествоКонтрагентовВПорции = 1000;
		КонецЕсли;	
		
		// 2. Запрашиваем данные:  

		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПартнерыСправочник.Ссылка КАК ОбъектВыгрузки
		|ИЗ
		|	Справочник.Партнеры КАК ПартнерыСправочник
		|ГДЕ
		|	НЕ ПартнерыСправочник.ПометкаУдаления           
		|	И (&ВсеКонтрагенты ИЛИ ПартнерыСправочник.Ссылка В ИЕРАРХИИ (&Контрагенты))";                          
		
		СписокКонтрагентов = УзелПО.Контрагенты.ВыгрузитьКолонку("Контрагент");
		Запрос.УстановитьПараметр("Контрагенты", СписокКонтрагентов);	
		Запрос.УстановитьПараметр("ВсеКонтрагенты", СписокКонтрагентов.Количество() = 0);		
		Результат = Запрос.Выполнить(); 
		
		// 3. Регистрируем под выгрузку:
		
		НомерПакетаДляРегистрации = 1;
		
		ВыборкаДанныхДляРегистрации = Результат.Выбрать();
		КоличествоКонтрагентовВТекущейПорции = 0;
		
		МассивКонтрагентовВПорции = Новый Массив;
		
		// создаем набор записей:  
		
		НаборЗаписей = РегистрыСведений.ДатаМобайл_ПорционнаяВыгрузка.СоздатьНаборЗаписей();
		
		Пока ВыборкаДанныхДляРегистрации.Следующий() Цикл 
			
			// сравниваем настройку с  количеством контрагентов в текущей порции:	
			
			Если (КоличествоКонтрагентовВТекущейПорции + 1) = КоличествоКонтрагентовВПорции Тогда
				
				МассивКонтрагентовВПорции.Добавить(ВыборкаДанныхДляРегистрации.ОбъектВыгрузки);
				
				НаборЗаписей.Отбор.ТСД.Установить(УзелПО); 
				НаборЗаписей.Отбор.НомерПакета.Установить(НомерПакетаДляРегистрации);
				// 3-контаргенты
				НаборЗаписей.Отбор.ТипОбъекта.Установить(3);
				НаборЗаписей.Прочитать();
				
				Для каждого ЭлементМассива Из МассивКонтрагентовВПорции Цикл
					
					НоваяЗапись = НаборЗаписей.Добавить();
					НоваяЗапись.ТСД = УзелПО;
					НоваяЗапись.ОбъектВыгрузки = ЭлементМассива;
					НоваяЗапись.НомерПакета = НомерПакетаДляРегистрации;
					НоваяЗапись.ТипОбъекта = 3;   
					
				КонецЦикла;
				
				// сбрасываем счетчик товаров в порции:	
				КоличествоКонтрагентовВТекущейПорции = 0;
				// берем номер следующего пакета:
				НомерПакетаДляРегистрации = НомерПакетаДляРегистрации + 1;
				// очищаем массив товаров в порции:
				МассивКонтрагентовВПорции.Очистить();
				
				// записываем данные текущей порции:
				НаборЗаписей.Записать(Истина);  
				
			Иначе
				
				МассивКонтрагентовВПорции.Добавить(ВыборкаДанныхДляРегистрации.ОбъектВыгрузки);
				КоличествоКонтрагентовВТекущейПорции = КоличествоКонтрагентовВТекущейПорции + 1;
				
			КонецЕсли;   					
			
		КонецЦикла;	
		
		// записываем остатки последней порции:
		Если МассивКонтрагентовВПорции.Количество() Тогда
			
			НаборЗаписей.Отбор.ТСД.Установить(УзелПО); 
			НаборЗаписей.Отбор.НомерПакета.Установить(НомерПакетаДляРегистрации);
			// 3-товары
			НаборЗаписей.Отбор.ТипОбъекта.Установить(3);
			НаборЗаписей.Прочитать();
			
			Для каждого ЭлементМассива Из МассивКонтрагентовВПорции Цикл
				
				НоваяЗапись = НаборЗаписей.Добавить();
				НоваяЗапись.ТСД = УзелПО;
				НоваяЗапись.ОбъектВыгрузки = ЭлементМассива;
				НоваяЗапись.НомерПакета = НомерПакетаДляРегистрации;
				НоваяЗапись.ТипОбъекта = 3;   
				
			КонецЦикла;
			
			НаборЗаписей.Записать(Истина);
			
			МассивКонтрагентовВПорции.Очистить();
			
		КонецЕсли;	  		
		
		
		
		ДатаМобайл_ОбщийМодуль.СообщитьПользователю("Регистрация контрагентов завершена!");   
		
	Иначе
		
		НаборЗаписей = РегистрыСведений.ДатаМобайл_ПорционнаяВыгрузка.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТСД.Установить(УзелПО); 
		// 3-товары
		НаборЗаписей.Отбор.ТипОбъекта.Установить(3);
		НаборЗаписей.Прочитать();
		НаборЗаписей.Очистить(); 
		
		НаборЗаписей.Записать(Истина);     
		
	КонецЕсли;	
	
КонецПроцедуры

