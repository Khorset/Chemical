
Функция ЕстьЗаписиВРегистре(Шаблон) Экспорт
	
	СтруктураОтвета = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ДатаМобайл_УчетКМ.ДокументТСД КАК ДокументТСД
	|ИЗ
	|	РегистрСведений.ДатаМобайл_УчетКМ КАК ДатаМобайл_УчетКМ";
	Результат = Запрос.Выполнить();
	
	СтруктураОтвета.Вставить("РегистрПустой", Результат.Пустой()); 
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	ДатаМобайл_УчетКМ.ДокументТСД КАК ДокументТСД
	|ИЗ
	|	РегистрСведений.ДатаМобайл_УчетКМ КАК ДатаМобайл_УчетКМ
	|ГДЕ
	|	ДатаМобайл_УчетКМ.ДокументТСД.Шаблон = &Шаблон";
	Запрос.УстановитьПараметр("Шаблон", Шаблон);  
	
	Результат = Запрос.Выполнить();
	
	СтруктураОтвета.Вставить("ЕстьЗаписиПоШаблону", Не Результат.Пустой());
		 
	Возврат СтруктураОтвета;
	
КонецФункции

Процедура ЗарегистрироватьДанные() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ     
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка КАК ЦРПТМарка,    
	|	МАКСИМУМ(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка) КАК ДокументТСД,
	|	МАКСИМУМ(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.ИсходныйДокумент) КАК ИсходныйДокумент,
	|	&ТекущаяДата КАК Дата
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор
	|ГДЕ
	|	НЕ ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка = &ПустоеЗначение
	|	И НЕ ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка
	|
	|ИМЕЮЩИЕ
	|	СУММА(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Количество) > 0"; 
	
	Запрос.УстановитьПараметр("ПустоеЗначение", "");
	Запрос.УстановитьПараметр("ТекущаяДата", ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату());
	
	НаборЗаписей = РегистрыСведений.ДатаМобайл_УчетКМ.СоздатьНаборЗаписей();
	НаборЗаписей.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Попытка
	    НаборЗаписей.Записать(Истина);
		Сообщить("Регистрация данных в регистр ""Учет КМ"" завершена!");
	Исключение
	 	ДатаМобайл_ОбщийМодуль.ОбработатьИсключение(1, "ЗарегистрироватьДанные", ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры	

