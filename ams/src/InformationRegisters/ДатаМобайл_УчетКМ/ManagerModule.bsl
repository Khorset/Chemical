Процедура ДобавитьЗапись(Параметры) Экспорт
	
	НаборЗаписей = РегистрыСведений.ДатаМобайл_УчетКМ.СоздатьНаборЗаписей();
	
	НаборЗаписей.Отбор.ЦРПТМарка.Установить(Параметры.ЦРПТМарка);
	НаборЗаписей.Отбор.УпаковочныйЛист.Установить(Параметры.УпаковочныйЛист);
    НаборЗаписей.Отбор.ДокументТСД.Установить(Параметры.ДокументТСД);

	
	НаборЗаписей.Прочитать();
	НаборЗаписей.Очистить();
	
	НоваяЗапись = НаборЗаписей.Добавить();
	НоваяЗапись.УпаковочныйЛист =  Параметры.УпаковочныйЛист;
	НоваяЗапись.ЦРПТМарка = Параметры.ЦРПТМарка;
	НоваяЗапись.ДокументТСД = Параметры.ДокументТСД;
	НоваяЗапись.Дата = Параметры.Дата;
	НоваяЗапись.ИсходныйДокумент = Параметры.ИсходныйДокумент;
	Попытка
		НаборЗаписей.Записать(Истина);	
	Исключение
		ДатаМобайл_ОбщийМодуль.ОбработатьИсключение(0, "ДобавитьЗапись", ОписаниеОшибки());     
	КонецПопытки; 
	
КонецПроцедуры
		
