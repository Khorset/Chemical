
&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ПустойИД = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
	
	Если Не ЗначениеЗаполнено(ТекущийОбъект.ИД) Или ТекущийОбъект.ИД = ПустойИД Тогда
		ТекущийОбъект.ИД = Новый УникальныйИдентификатор();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущийОбъект.ДатаПечати) Тогда
		ТекущийОбъект.ДатаПечати = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
	КонецЕсли;
	
КонецПроцедуры
