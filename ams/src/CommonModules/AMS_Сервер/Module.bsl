Функция JsonВЗначение(JSON)
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(JSON);
	
	Возврат ПрочитатьJSON(ЧтениеJSON);
КонецФункции

Функция JSONВСоответствие(JSON) Экспорт
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(JSON);
	Результат = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();

	Возврат Результат;
КонецФункции

Функция СтруктураВJson(Знач Структура) Экспорт
	ЗаписьJSON = Новый ЗаписьJSON();
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Структура);
	
	Результат = ЗаписьJSON.Закрыть();

	Возврат Результат;
КонецФункции

Функция СоответствиеВJSON(Знач Соответствие)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Unix, "  "));
	ЗаписатьJSON(ЗаписьJSON, Соответствие, , "ПреобразоватьВЗначениеJSON"); 
			
	Результат = ЗаписьJSON.Закрыть();

	Возврат Результат;
КонецФункции

Функция ПреобразоватьВЗначениеJSON(Свойство, Значение, ДополнительныеПараметры, Отказ) Экспорт
	НовоеЗначение = Значение;

	Если Значение = Null Или Значение = Неопределено Тогда
		НовоеЗначение = Новый Структура();
	КонецЕсли;

	Возврат НовоеЗначение;
КонецФункции

Функция ПолучитьИмяПеречисления(Перечисление)
    МетаданныеПеречисления = Перечисление.Метаданные();
    
    ИндексЗначения = Перечисления[МетаданныеПеречисления.Имя].Индекс(Перечисление);
    
    ЗначениеМетаданных = МетаданныеПеречисления.ЗначенияПеречисления[ИндексЗначения];
    
    Возврат ЗначениеМетаданных.Имя;  
КонецФункции

