Функция ПолучитьСотрудниковСкладаПродукции() Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СкладПродукции", AMS_ВызовСервера.СкладПродукции());

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ФизическиеЛица КАК т
	|ГДЕ
	|	НЕ т.ПометкаУдаления
	|	И НЕ т.ЭтоГруппа
	|	И т._РаботникПроизводства
	|	И т._Склад = &СкладПродукции
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Наименование";

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
КонецФункции

Функция ПолучитьУпаковкиПродукции(НаборУпаковок) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НаборУпаковок", НаборУпаковок);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Упаковка,
	|	т.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ПРЕДСТАВЛЕНИЕ(т.ЕдиницаИзмерения) КАК Ед,
	|	т.Числитель / ВЫБОР
	|		КОГДА т.Знаменатель = 0
	|			ТОГДА 1
	|		ИНАЧЕ т.Знаменатель
	|	КОНЕЦ КАК Количество,
	|	т.КоличествоУпаковок КАК КоличествоУпаковок,
	|	т.Вес КАК Вес,
	|	т.Объем КАК Объем
	|ИЗ
	|	Справочник.УпаковкиЕдиницыИзмерения КАК т
	|ГДЕ
	|	т.Владелец = &НаборУпаковок
	|
	|УПОРЯДОЧИТЬ ПО
	|	Количество";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ПолучитьДанныеДляРасчетаТоварныхЗапасов(ПараметрыЗапроса) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыЗапроса.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ПараметрыЗапроса.КонецПериода);
	Запрос.УстановитьПараметр("СкладПродукции", AMS_ВызовСервера.СкладПродукции());
	Запрос.УстановитьПараметр("СегментыПродукцияКомпании", AMS_ВызовСервера.СегментыНоменклатурыПродукцияКомпании());
	Запрос.УстановитьПараметр("ГрафикРаботы", Справочники.Календари.НайтиПоНаименованию("Календарь РФ", Истина));
	Запрос.УстановитьПараметр("ПроцентА", 80);
	Запрос.УстановитьПараметр("ПроцентВ", 15);
	Запрос.УстановитьПараметр("AX", ПараметрыЗапроса.AX);
	Запрос.УстановитьПараметр("AY", ПараметрыЗапроса.AY);
	Запрос.УстановитьПараметр("AZ", ПараметрыЗапроса.AZ);
	Запрос.УстановитьПараметр("CZ", ПараметрыЗапроса.CZ);
	Запрос.УстановитьПараметр("ВидНоменклатурыПродукцияЦеха1", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха1());
	Запрос.УстановитьПараметр("ВидНоменклатурыПродукцияЦеха2", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха2());
	Запрос.УстановитьПараметр("ВидНоменклатурыПродукцияЦеха3", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха3());
	
	Запрос.Текст =
		"ВЫБРАТЬ
