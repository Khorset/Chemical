Функция ЗагрузитьОстаткиСоСкладеВ2В() 
	ТокенАвторизации = Константы.AMS_В2В_ТокенАвторизации.Получить();
	
	Если Не ЗначениеЗаполнено(ТокенАвторизации) Тогда
		ВызватьИсключение "Нет токена авторизации";
	КонецЕсли;  
	
	Табл = Новый ТаблицаЗначений;
	КвалификаторыСтроки = Новый КвалификаторыСтроки(20);
	Табл.Колонки.Добавить("SKU", Новый ОписаниеТипов("Строка", ,КвалификаторыСтроки));
	КвалификаторыЧисла = Новый КвалификаторыЧисла(10, 2, ДопустимыйЗнак.Любой);
	Табл.Колонки.Добавить("count", Новый ОписаниеТипов("Число", КвалификаторыЧисла));
	
	HTTPСоединение = Новый HTTPСоединение("b2b.cafe",,,,, ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1.4.9/store/get_balance_product");
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("Accept-Language", "ru");
	
	ДанныеЗапроса = Новый Структура();
	ДанныеЗапроса.Вставить("store", Константы.AMS_В2В_Склад.Получить());
	ТелоЗапроса = СтруктураВJson(ДанныеЗапроса);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		СтруктураОтвета = JSONВСоответствие(ТелоОтвета);
		
		//Табл.Очистить();
		Для Каждого Элемент Из СтруктураОтвета["result"] Цикл
			Стр = Табл.Добавить();
			Стр.SKU   = Элемент["sku"];
			Стр.count = Элемент["count"];
		КонецЦикла; 
		
	Иначе
		ОбщегоНазначения.СообщитьПользователю("КоннекторB2bCafe.ПолучитьОстаткиНаСкладе.Ошибка. Код ответа: " + HTTPОтвет.КодСостояния);
		ЗаписьЖурналаРегистрации("КоннекторB2bCafe.ПолучитьОстаткиНаСкладе.Ошибка", УровеньЖурналаРегистрации.Ошибка);
	КонецЕсли;
	
	Возврат Табл;
КонецФункции

Функция ПолучитьЦеныКлиентаНаВ2В(КодКлиентаВ2В) Экспорт
	ТокенАвторизации = ПолучитьТокенАвторизации(Пользователи.АвторизованныйПользователь());
	
	Если Не ЗначениеЗаполнено(ТокенАвторизации) Тогда
		ВызватьИсключение "Нет токена авторизации";
	КонецЕсли;  
	
	HTTPСоединение = Новый HTTPСоединение("b2b.cafe",,,,, ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1.5.3/prices/list_client");
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("Accept-Language", "ru");
	
	ДанныеЗапроса = Новый Структура();
	ДанныеЗапроса.Вставить("userId", КодКлиентаВ2В);
	
	ТелоЗапроса = СтруктураВJson(ДанныеЗапроса);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		Табл = Новый ТаблицаЗначений();
		Табл.Колонки.Добавить("Код",  Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(20)));
		Табл.Колонки.Добавить("Цена", Новый ОписаниеТипов("Число"));

		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		СтруктураОтвета = JSONВСоответствие(ТелоОтвета); 
		
		Результат = СтруктураОтвета["result"];
		
		Для Каждого Стр Из Результат Цикл
			НовСтр = Табл.Добавить();
			
			НовСтр.Код  = Стр["sku"];
			НовСтр.Цена = Число(Стр["value"]);
		КонецЦикла; 
		
		Возврат Табл;
	
	ИначеЕсли HTTPОтвет.КодСостояния = 401 Тогда	
		ТокенАвторизации = ПолучитьТокенАвторизации(Пользователи.АвторизованныйПользователь());
		
		ТекстОшибки = НСтр("ru = 'ПолучитьЦеныКлиентаНаВ2В.Ошибка: Истекла авторизация: Повторите операцию'");
		
		ВызватьИсключение ТекстОшибки;
	
	Иначе
		ТекстОшибки = НСтр("ru = 'ПолучитьЦеныКлиентаНаВ2В.Ошибка: Не удалось прочитать файл из временного хранилища по причине: %Причина%'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Причина%", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
КонецФункции

Функция ПолучитьДанныеЗаказаВ2В(ИдентификаторЗаказа, ТокенАвторизации)
	РежимБезопасности = БезопасныйРежим();
	
	Если ТипЗнч(РежимБезопасности) = тип("Булево") и РежимБезопасности = Истина тогда
		УстановитьОтключениеБезопасногоРежима(Истина);
	КОнецЕсли;
	
	Если Не ЗначениеЗаполнено(ТокенАвторизации) Тогда
		ВызватьИсключение "Нет токена авторизации";
	КонецЕсли;  

	HTTPСоединение = Новый HTTPСоединение("b2b.cafe",,,,, ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1.4.10/order/one");
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("Accept-Language", "ru");
	
	ДанныеЗапроса = Новый Структура();
	ДанныеЗапроса.Вставить("id", ИдентификаторЗаказа);
	 
	ТелоЗапроса = СтруктураВJson(ДанныеЗапроса);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		СтруктураОтвета = JSONВСоответствие(ТелоОтвета); 
		
		Результат = СтруктураОтвета["result"];
		
		ШапкаЗаказа  = Результат["order"];
		
		Шапка = Новый Структура();
		
		Шапка.Вставить("Id", ШапкаЗаказа["id"]); //Идентификатор заказа.
		Шапка.Вставить("extId",          ШапкаЗаказа["extId"]); //Идентификатор заказа для 1С.
		Шапка.Вставить("creationTime",   Дата(1970,1,1) + ШапкаЗаказа["creationTime"]); //Дата создания заказа.
		Шапка.Вставить("updateTime",     Дата(1970,1,1) + ШапкаЗаказа["updateTime"]); //Дата обновления заказа.
		Шапка.Вставить("amount",         ШапкаЗаказа["amount"]); //Сумма заказа с учетом скидок.
		Шапка.Вставить("baseAmount",     ШапкаЗаказа["baseAmount"]); //Сумма заказа без учета скидок.
		Шапка.Вставить("discountAmount", ШапкаЗаказа["discountAmount"]); //Сумма скидок в заказе.
		Шапка.Вставить("paymentType",    ШапкаЗаказа["paymentType"]); //Тип оплаты. 1 - Постоплата, 2 - Предоплата.
		Шапка.Вставить("comment",        ШапкаЗаказа["comment"]); //Комментарий заказа.
		Шапка.Вставить("boxlabel",       ШапкаЗаказа["boxlabel"]); //Маркировка заказа.
		Шапка.Вставить("isReserved",     ШапкаЗаказа["isReserved"]); //Флаг, указывающий, проходил ли заказ через резерв
		
		Шапка.Вставить("clientid",       ШапкаЗаказа["client"]["id"]); //Идентификатор пользователя.
		Шапка.Вставить("clientfullName", ШапкаЗаказа["client"]["fullName"]); //Полное имя пользователя.
		Шапка.Вставить("clientcode1c",   ШапкаЗаказа["client"]["code1c"]); //Код клиента
		
		Шапка.Вставить("addressid",           ШапкаЗаказа["address"]["id"]);//Идентификатор адреса.
		Шапка.Вставить("addresscreationTime", ШапкаЗаказа["address"]["creationTime"]);//Время создания адреса.
		Шапка.Вставить("addressplace",        ШапкаЗаказа["address"]["place"]);//Место.
		Шапка.Вставить("addressdata",         ШапкаЗаказа["address"]["data"]);//Адрес
		Шапка.Вставить("addresscode",         ШапкаЗаказа["address"]["code"]);//Код в системе 1С.
		
		Шапка.Вставить("companyid",             ШапкаЗаказа["company"]["id"]);//Идентификатор компании.
		Шапка.Вставить("companyname",           ШапкаЗаказа["company"]["name"]);//Одно из значений: Название, ИНН, ОГРН. Выводится что то одно, что есть.
		Шапка.Вставить("companycompanyName",    ШапкаЗаказа["company"]["companyName"]);//Название компании.
		Шапка.Вставить("companyogrn",           ШапкаЗаказа["company"]["ogrn"]);//ОГРН компании. (КПП)
		Шапка.Вставить("companytaxpayerNumber", Формат(ШапкаЗаказа["company"]["taxpayerNumber"], "ЧГ=0"));//ИНН компании.
		
		Шапка.Вставить("managerid",       ШапкаЗаказа["manager"]["id"]);//Идентификатор пользователя.
		Шапка.Вставить("managerfullName", ШапкаЗаказа["manager"]["fullName"]);//Полное имя пользователя.
		Шапка.Вставить("managercode1c",   ШапкаЗаказа["manager"]["code1c"]);//ID клиента для 1с.

		Шапка.Вставить("statusid",        ШапкаЗаказа["status"]["id"]);//Идентификатор статуса.
		Шапка.Вставить("statuscode",      ШапкаЗаказа["status"]["code"]);//Значение статуса.
		Шапка.Вставить("statustextColor", ШапкаЗаказа["status"]["textColor"]);//Название цвета статуса.
		Шапка.Вставить("statuscolor",     ШапкаЗаказа["status"]["color"]);//Цвет статуса.
		
		Шапка.Вставить("storeid",   ШапкаЗаказа["store"]["id"]);//Идентификатор склада.
		Шапка.Вставить("storename", ШапкаЗаказа["store"]["name"]);//Название склада.

		Шапка.Вставить("originalStoreid",   ШапкаЗаказа["originalStore"]["id"]);//Идентификатор склада
		Шапка.Вставить("originalStorename", ШапкаЗаказа["originalStore"]["name"]);//Название склада.
		
		Шапка.Вставить("distributorid",   ШапкаЗаказа["distributor"]["id"]);//Идентификатор дистрибьютера.
		Шапка.Вставить("distributorname", ШапкаЗаказа["distributor"]["name"]);//Название дистрибьютера.
		
		Шапка.Вставить("currencyid",     ШапкаЗаказа["currency"]["id"]);//Идентификатор валюты.
		Шапка.Вставить("currencyname",   ШапкаЗаказа["currency"]["name"]);//Название валюты.
		Шапка.Вставить("currencycode",   ШапкаЗаказа["currency"]["code"]);//Код валюты.
		Шапка.Вставить("currencysymbol", ШапкаЗаказа["currency"]["symbol"]);//Символ валюты.

		Шапка.Вставить("typeid",    ШапкаЗаказа["type"]["id"]);//Идентификатор типа.
		Шапка.Вставить("typecode",  ШапкаЗаказа["type"]["code"]);//Значение типа.
		Шапка.Вставить("typename",  ШапкаЗаказа["type"]["name"]);//Название типа.
		Шапка.Вставить("typecolor", ШапкаЗаказа["type"]["color"]);//Цвет типа.

		ТоварыЗаказа = Результат["products"];
		Товары = Новый Массив();
		
		Для Каждого Стр Из ТоварыЗаказа Цикл
			НовСтр = Новый Структура();
			
			НовСтр.Вставить("id",         Стр["id"]);        //Идентификатор записи.
			НовСтр.Вставить("model_id",   Стр["model_id"]);  //Идентификатор модели.
			НовСтр.Вставить("product_id", Стр["product_id"]);//Идентификатор продукта.
			НовСтр.Вставить("sku",        Стр["sku"]);       //Артикул продукта.
			НовСтр.Вставить("barcode",    Стр["barcode"]);   //Штрихкод продукта.
			НовСтр.Вставить("skuMf",      Стр["skuMf"]);     //Артикул модели.
			НовСтр.Вставить("enSkuMf",    Стр["enSkuMf"]);   //Артикул модели на английском.
			НовСтр.Вставить("type",       Стр["type"]);      //Категория продукта.
			НовСтр.Вставить("name",       Стр["name"]);      //Название продукта.
			НовСтр.Вставить("color",      Стр["color"]);     //Название цвета.
			НовСтр.Вставить("colorSrc",   Стр["colorSrc"]);  //Ссылка на иконку цвета.
			НовСтр.Вставить("size",       Стр["size"]);      //Размер продукта.
			НовСтр.Вставить("amount",     Стр["amount"]);    //Сумма продуктов.
			НовСтр.Вставить("price",      Стр["price"]);     //Цена продукта.
			НовСтр.Вставить("count",      Стр["count"]);     //Количество продуктов в корзине.
			НовСтр.Вставить("oldCount",   Стр["oldCount"]);  //Старое количество продуктов в корзине.
			
			НовСтр.Вставить("currencyid",     Стр["currency"]["id"]);    //Идентификатор валюты.
			НовСтр.Вставить("currencyname",   Стр["currency"]["name"]);  //Название валюты.
			НовСтр.Вставить("currencycode",   Стр["currency"]["code"]);  //Код валюты.
			НовСтр.Вставить("currencysymbol", Стр["currency"]["symbol"]);//Символ валюты.
			
			Массивbadge = Стр["badge"];
			Если Массивbadge.Количество() > 0 Тогда
				Стрbadge = Стр["badge"][0];
				
				НовСтр.Вставить("badgetype",  Стрbadge["type"]); //Тип бейджа.
				НовСтр.Вставить("badgetext",  Стрbadge["text"]); //Текст на бейдже.
				НовСтр.Вставить("badgecolor", Стрbadge["color"]);//Список цветов для бейджа.
			КонецЕсли;

			НовСтр.Вставить("imagesoriginal", Стр["images"]["original"]);//Оригинальная картинка товара.
			НовСтр.Вставить("imagesthump_1",  Стр["images"]["thump_1"]); //Уменьшенная версия картинки товара 1.
			НовСтр.Вставить("imagesthump_2",  Стр["images"]["thump_2"]); //Уменьшенная версия картинки товара 2.

			Товары.Добавить(НовСтр);
		КонецЦикла; 

	Иначе
		ТекстОшибки = НСтр("ru = 'AMS_Сервер.ПолучитьДанныеЗаказаВ2В.Ошибка: Не удалось получить данные заказа по причине: %Причина%'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Причина%", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
	КонецЕсли;
	
	ДанныеЗаказа = Новый Структура("Шапка, Товары");
	ДанныеЗаказа.Шапка 	= Шапка;	
	ДанныеЗаказа.Товары = Товары;
	
	Возврат ДанныеЗаказа;
КонецФункции

Функция СоздатьЗаказКлиентаПоДаннымВ2В(ДанныеЗаказа)
	ШапкаВ2В  = ДанныеЗаказа.Шапка;
	ТоварыВ2В = ДанныеЗаказа.Товары;
	
	Док = Документы.ЗаказКлиента.СоздатьДокумент();

	Док.Дата                    = ШапкаВ2В.creationTime;
	Док.AMS_ID                  = ШапкаВ2В.id;	
	Док.AMS_ДатаСчета           = Док.Дата;	
	Док.AMS_ДоверенностьКлиента = 2;	
	Док.Партнер                 = Справочники.Партнеры.НайтиПоКоду(ШапкаВ2В.clientcode1c);
	Док.Контрагент              = AMS_ВызовСервера.ПолучитьКонтрагентаПартнёра(Док.Партнер, ШапкаВ2В.companytaxpayerNumber, ШапкаВ2В.companyogrn);
	
	ПараметрыЗаполнения = Новый Структура("Партнет ,Контрагент", Док.Партнер, Док.Контрагент);
	
	Док.Заполнить(ПараметрыЗаполнения);
	
	Правило = AMS_ВызовСервера.ПолучитьПравилоПродажи(Док.Дата, Док.Партнер, Док.Контрагент);
	
	Если ЗначениеЗаполнено(Правило) Тогда
		Док.AMS_ПравилоПродажи = Правило;
		
		ДанныеПравила = AMS_ВызовСервера.ПолучитьДанныеПравилПродажи(Правило);
		
		ЗаполнитьЗначенияСвойств(Док, ДанныеПравила);
	КонецЕсли;	
	
	Док.УстановитьНовыйНомер();	
	
	Док.Статус             = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению;
	Док.Склад              = AMS_ВызовСервера.СкладПродукции();
	Док.ДатаСогласования   = мср.ПолучитьРабочийДень(1, Док.Дата);
	Док.ДатаОтгрузки       = мср.ПолучитьРабочийДень(3, Док.Дата);
	Док.Приоритет          = Справочники.Приоритеты.ПолучитьНизшийПриоритет();
	Док.СкидкиРассчитаны   = Истина;
	Док.ЦенаВключаетНДС    = Ложь;
	Док.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
	Док.Валюта             = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док.Договор, "ВалютаВзаиморасчетов");
	
	ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(Док);

	ЗаполнитьТоварыЗаказа(Док, ТоварыВ2В);
	
	ЗаполнитьВесОбъемКолПалетЗаказКлиента(Док);
	
	мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Запись);
	
	Возврат Док.Ссылка;
КонецФункции

Процедура ЗаполнитьТоварыЗаказа(Док, Товары)
	Табл = Новый ТаблицаЗначений();
	Табл.Колонки.Добавить("Код",        Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(20)));
	Табл.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	
	Для Каждого Стр Из Товары Цикл
		НовСтр = Табл.Добавить();
		НовСтр.Код = Стр.sku;
		НовСтр.Количество = Стр.count;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	//@skip-check bsl-legacy-check-string-literal
	Запрос.УстановитьПараметр("ВидЦеныОсновная", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док.Соглашение, "ВидЦен"));
	Запрос.УстановитьПараметр("ВидЦеныМега",     AMS_ВызовСервера.ПолучитьИзСоглашенияВидЦеныМега(Док.Соглашение));
	Запрос.УстановитьПараметр("Дата",            Док.Дата);
	Запрос.УстановитьПараметр("ДатаОтгрузки",    Док.ДатаОтгрузки);
	Запрос.УстановитьПараметр("Товары",          Табл);
	Запрос.УстановитьПараметр("Склад",           Док.Склад);
	Запрос.УстановитьПараметр("Соглашение",      Док.Соглашение);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Код КАК Код,
		|	т.Количество КАК Количество
		|ПОМЕСТИТЬ в2в
		|ИЗ
		|	&Товары КАК т
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Ном.Артикул КАК Артикул,
		|	Ном.Ссылка КАК Номенклатура,
		|	в2в.Количество КАК Количество,
		|	Ном.ЦеноваяГруппа КАК ЦеноваяГруппа,
		|	Ном.СтавкаНДС КАК СтавкаНДС,
		|	СтавкиНДС.Ставка КАК Ставка,
		|	Ном._Упаковка КАК Упаковка,
		|	Ном.КоэффициентЕдиницыДляОтчетов КАК Кфц
		|ПОМЕСТИТЬ то
		|ИЗ
		|	в2в КАК в2в
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтавкиНДС КАК СтавкиНДС
		|			ПО Ном.СтавкаНДС = СтавкиНДС.Ссылка
		|		ПО в2в.Код = Ном.Код
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	то.Артикул КАК Артикул,
		|	то.Номенклатура КАК Номенклатура,
		|	то.ЦеноваяГруппа КАК ЦеноваяГруппа,
		|	то.СтавкаНДС КАК СтавкаНДС,
		|	то.Ставка КАК Ставка,
		|	ВЫБОР
		|		КОГДА то.Количество / то.Кфц > ЦЕЛ(то.Количество / то.Кфц)
		|			ТОГДА ЦЕЛ(то.Количество / то.Кфц) + 1
		|		ИНАЧЕ то.Количество / то.Кфц
		|	КОНЕЦ * то.Кфц КАК Количество,
		|	ВЫБОР
		|		КОГДА то.Количество / то.Кфц > ЦЕЛ(то.Количество / то.Кфц)
		|			ТОГДА ЦЕЛ(то.Количество / то.Кфц) + 1
		|		ИНАЧЕ то.Количество / то.Кфц
		|	КОНЕЦ КАК КоличествоУпаковок,
		|	то.Упаковка КАК Упаковка,
		|	то.Кфц КАК Кфц
		|ПОМЕСТИТЬ тов
		|ИЗ
		|	то КАК то
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Цен.Номенклатура КАК Номенклатура,
		|	Цен.Цена КАК Цена,
		|	Цен.ВидЦены КАК ВидЦены
		|ПОМЕСТИТЬ ЦеныОсн
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, ВидЦены = &ВидЦеныОсновная
		|	И Номенклатура В
		|		(ВЫБРАТЬ
		|			тов.Номенклатура КАК Номенклатура
		|		ИЗ
		|			тов КАК тов)) КАК Цен
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Цен.Номенклатура,
		|	Цен.Цена,
		|	Цен.ВидЦены
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, ВидЦены = &ВидЦеныМега
		|	И Номенклатура В
		|		(ВЫБРАТЬ
		|			тов.Номенклатура КАК Номенклатура
		|		ИЗ
		|			тов КАК тов)) КАК Цен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Согл.Номенклатура КАК Номенклатура,
		|	Согл.Цена КАК Цена,
		|	NULL КАК ВидЦены
		|ПОМЕСТИТЬ ЦенДоп
		|ИЗ
		|	Справочник.СоглашенияСКлиентами.Товары КАК Согл
		|ГДЕ
		|	Согл.Ссылка = &Соглашение
		|	И Согл.Номенклатура В
		|		(ВЫБРАТЬ
		|			тов.Номенклатура КАК Номенклатура
		|		ИЗ
		|			тов КАК тов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	&ДатаОтгрузки КАК ДатаОтгрузки,
		|	тов.Номенклатура КАК Номенклатура,
		|	тов.Упаковка КАК Упаковка,
		|	тов.Количество / тов.Кфц КАК КоличествоУпаковок,
		|	тов.Количество КАК Количество,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ЦенДоп.Цена, ЦеныОсн.Цена) = ЦенДоп.Цена
		|			ТОГДА NULL
		|		ИНАЧЕ ЦеныОсн.ВидЦены
		|	КОНЕЦ КАК ВидЦены,
		|	ЕСТЬNULL(ЦенДоп.Цена, ЦеныОсн.Цена) * тов.Кфц КАК Цена,
		|	ЕСТЬNULL(ЦенДоп.Цена, ЦеныОсн.Цена) * тов.Количество КАК Сумма,
		|	тов.СтавкаНДС КАК СтавкаНДС,
		|	тов.Ставка * ЕСТЬNULL(ЦенДоп.Цена, ЦеныОсн.Цена) * тов.Количество / 100 КАК СуммаНДС,
		|	ЕСТЬNULL(ЦенДоп.Цена, ЦеныОсн.Цена) * тов.Количество + тов.Ставка * ЕСТЬNULL(ЦенДоп.Цена, ЦеныОсн.Цена) *
		|		тов.Количество / 100 КАК СуммаСНДС,
		|	&Склад КАК Склад,
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыОбеспечения.КОбеспечению) КАК ВариантОбеспечения
		|ИЗ
		|	тов КАК тов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныОсн КАК ЦеныОсн
		|		ПО тов.Номенклатура = ЦеныОсн.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенДоп КАК ЦенДоп
		|		ПО тов.Номенклатура = ЦенДоп.Номенклатура";
	
	Док.Товары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

#КонецОбласти

#Область ВыгрузкаНаВ2В

Процедура ОбновитьЗаказКлиентаНаВ2В(ЗаказКлиента, Статус = Неопределено, ТокенАвторизации = Неопределено) Экспорт
	AMS_ID = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗаказКлиента, "AMS_ID");
	
	Если AMS_ID = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ТокенАвторизации = Неопределено Тогда
		ТокенАвторизации = ПолучитьТокенАвторизации(Константы.AMS_В2В_МенеджерЗагрузкиЗаказов.Получить());
	КонецЕсли;  
	
	МассивДанных = ПолучитьМассивТоваровЗаказа(ЗаказКлиента);
	
	ОбъектТела = Новый Соответствие();
	ОбъектТела.Вставить("id",    AMS_ID); 
	ОбъектТела.Вставить("items", МассивДанных);
	
	Если Не Статус = Неопределено Тогда
		ОбъектТела.Вставить("status", ПолучитьИмяПеречисления(Статус));
	КонецЕсли;

	Послание = СоответствиеВJSON(ОбъектТела);
	
	HTTPСоединение = Новый HTTPСоединение("b2b.cafe",,,,, ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1.5.0/order/update");
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("Accept-Language", "ru");
	
	HTTPЗапрос.УстановитьТелоИзСтроки(Послание);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		//@skip-check module-unused-local-variable
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
	Иначе
		ТекстОшибки = НСтр("ru = 'AMS_Сервер.ОбновитьЗаказКлиентаНаВ2В.Ошибка: Не удалось обновить заказ ID %ID%'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ID%", AMS_ID);
		ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка,,
		ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьМассивТоваровЗаказа(ЗаказКлиента)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Номенклатура КАК Номенклатура,
		|	т.Количество КАК Количество
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	Документ.ЗаказКлиента.Товары КАК т
		|ГДЕ
		|	т.Ссылка = &ЗаказКлиента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ном.Код КАК sku,
		|	СУММА(вт.Количество) КАК count
		|ИЗ
		|	вт КАК вт
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
		|		ПО вт.Номенклатура = ном.Ссылка
		|СГРУППИРОВАТЬ ПО
		|	ном.Код";
	Табл = Запрос.Выполнить().Выгрузить();
	
	МассивДанных = Новый Массив;
	
	Для каждого Стр Из Табл Цикл
		Строка = Новый Соответствие();
		Строка.Вставить("sku",   Стр.SKU);
		Строка.Вставить("count", Стр.count);
		
		МассивДанных.Добавить(Строка);
	КонецЦикла;
	
	Возврат МассивДанных;
КонецФункции 

#КонецОбласти

#Область Прочее_В2В

Функция ПолучитьТокенАвторизации(Пользователь) Экспорт
	ТокенАвторизации = "";
	
	УстановитьПривилегированныйРежим(Истина);

 	РежимБезопасности = БезопасныйРежим();
	
	Если ТипЗнч(РежимБезопасности) = тип("Булево") и РежимБезопасности = Истина тогда
		УстановитьОтключениеБезопасногоРежима(Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Логин КАК Логин,
	|	т.Пароль КАК Пароль
	|ИЗ
	|	РегистрСведений.AMS_МенеджерыВ2В КАК т
	|ГДЕ
	|	т.Пользователь = &Пользователь";
	
	Рез = Запрос.Выполнить();
	
	Если Не Рез.Пустой() Тогда
		Выб = Рез.Выбрать(); 
		Выб.Следующий();

		HTTPСоединение = Новый HTTPСоединение("conteb2b.com",,,,, ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
		HTTPЗапрос = Новый HTTPЗапрос("/api/v1.5.0/security/login");
		HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
		
		ДанныеЗапроса = Новый Структура();
		ДанныеЗапроса.Вставить("login", Выб.Логин);
		ДанныеЗапроса.Вставить("password", Выб.Пароль);
		ТелоЗапроса = СтруктураВJson(ДанныеЗапроса);
		
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
		
		//@skip-check bsl-legacy-check-dynamic-feature-access
		HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если HTTPОтвет.КодСостояния = 200 Тогда
			ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
			СтруктураОтвета = JsonВЗначение(ТелоОтвета);
			
			ТокенАвторизации = СтруктураОтвета["result"]["accessToken"]["token"];
		
		Иначе
			ЗаписьЖурналаРегистрации("ПолучитьТокенАвторизации.Ошибка", УровеньЖурналаРегистрации.Ошибка);
		КонецЕсли;
	КонецЕсли;

	Возврат ТокенАвторизации;
КонецФункции

Функция ПолучитьОстаткиНаСкладеАМС()
	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("Дата",               ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("СкладПродукции",     AMS_ВызовСервера.СкладПродукции());
	Запрос.УстановитьПараметр("СписокЦехов",        AMS_ВызовСервера.СписокЦеховПроизводстваПродукции());

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура.Код КАК sku,
	|	т.Номенклатура.Артикул КАК Артикул,
	|	т.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	Справочник.AMS_Продукция.Товары КАК т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция КАК д
	|		ПО т.Ссылка = д.Ссылка
	|ГДЕ
	|	т.В2В
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	рег.Номенклатура КАК Номенклатура,
	|	рег.ВНаличииОстаток КАК ОстЦех
	|ПОМЕСТИТЬ ОстЦехВечер
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(КОНЕЦПЕРИОДА(&Дата, ДЕНЬ), Склад В (&СписокЦехов)
	|	И Номенклатура В
	|		(ВЫБРАТЬ
	|			т.Номенклатура КАК Номенклатура
	|		ИЗ
	|			тов КАК т)) КАК рег
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	рег.Номенклатура КАК Номенклатура,
	|	рег.ВНаличииОстаток КАК ОстСклУ
	|ПОМЕСТИТЬ ОстСкл
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&Дата, ДЕНЬ, -1), ДЕНЬ), Склад = &СкладПродукции
	|	И Номенклатура В
	|		(ВЫБРАТЬ
	|			т.Номенклатура КАК Номенклатура
	|		ИЗ
	|			тов КАК т)) КАК рег
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	рег.Номенклатура КАК Номенклатура,
	|	СУММА(ЕСТЬNULL(рег.ВНаличииПриход, 0)) КАК Приход,
	|	СУММА(ЕСТЬNULL(рег.ВНаличииРасход, 0)) КАК Расход
	|ПОМЕСТИТЬ Движ
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Обороты(НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ), КОНЕЦПЕРИОДА(&Дата, ДЕНЬ),,
	|		Склад = &СкладПродукции
	|	И Номенклатура В
	|		(ВЫБРАТЬ
	|			т.Номенклатура КАК Номенклатура
	|		ИЗ
	|			тов КАК т)) КАК рег
	|СГРУППИРОВАТЬ ПО
	|	рег.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.КОтгрузкеОстаток КАК Количество,
	|	т.ДокументОтгрузки.Дата КАК Дата
	|ПОМЕСТИТЬ КОтгр
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &СкладПродукции
	|	И Номенклатура В
	|		(ВЫБРАТЬ
	|			т.Номенклатура КАК Номенклатура
	|		ИЗ
	|			тов КАК т)) КАК т
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОтгр.Номенклатура КАК Номенклатура,
	|	СУММА(КОтгр.Количество) КАК КОтгрузке
	|ПОМЕСТИТЬ КОтг
	|ИЗ
	|	КОтгр КАК КОтгр
	|ГДЕ
	|	КОтгр.Дата > НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ)
	|СГРУППИРОВАТЬ ПО
	|	КОтгр.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.sku КАК sku,
	|	тов.Артикул КАК Артикул,
	|	тов.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ОстЦехВечер.ОстЦех, 0) + ЕСТЬNULL(ОстСкл.ОстСклУ, 0) + ЕСТЬNULL(Движ.Приход, 0) - ЕСТЬNULL(Движ.Расход, 0) -
	|		ЕСТЬNULL(КОтг.КОтгрузке, 0) КАК count
	|ПОМЕСТИТЬ склад
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстЦехВечер КАК ОстЦехВечер
	|		ПО тов.Номенклатура = ОстЦехВечер.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстСкл КАК ОстСкл
	|		ПО тов.Номенклатура = ОстСкл.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Движ КАК Движ
	|		ПО тов.Номенклатура = Движ.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ КОтг КАК КОтг
	|		ПО тов.Номенклатура = КОтг.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.sku КАК sku,
	|	тов.Артикул КАК Артикул,
	|	тов.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА склад.count < 0
	|			ТОГДА 0
	|		ИНАЧЕ склад.count
	|	КОНЕЦ КАК count
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ склад КАК склад
	|		ПО тов.sku = склад.sku";
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

