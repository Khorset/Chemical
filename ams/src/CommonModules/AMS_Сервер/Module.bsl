Процедура ПередЗаписьюЗаказПоставщику(Источник, РежимЗаписи)
	Если Источник.Статус = ОбщегоНазначения.ПредопределенныйЭлемент(
		"Перечисление.СтатусыЗаказовПоставщикам.НеСогласован") Тогда
		Если Источник.Проведен Тогда
			РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
		Иначе
			РежимЗаписи = РежимЗаписиДокумента.Запись;
		КонецЕсли;
	КонецЕсли;

	ТекстТовары = Источник._Товары;
	ТекстТовары = "";
	Для Каждого Стр Из Источник.Товары Цикл
		ТекстТовары = ТекстТовары + Стр.Номенклатура + " - " + Строка(?(Стр.Количество = 0, Стр._КоличествоЗаказано,
			Стр.Количество)) + ", ";
	КонецЦикла;
	Источник._Товары = Лев(ТекстТовары, СтрДлина(ТекстТовары) - 2);
КонецПроцедуры

Процедура ПередЗаписьюКорректировкаРеализации(Источник, Отказ, РежимЗаписи)
	ПеремещениеТоваров = Источник._ПеремещениеТоваров;

	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ПередатьБракНаСкладБракованнойПродукции(Источник, Отказ);

	ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения И ЗначениеЗаполнено(ПеремещениеТоваров) Тогда
		мср.ЗаписатьДокумент(ПеремещениеТоваров, РежимЗаписиДокумента.ОтменаПроведения, Отказ, Истина);
	КонецЕсли;

	Если Источник.ПометкаУдаления И ЗначениеЗаполнено(ПеремещениеТоваров) Тогда
		мср.УстановитьПометкуУдаленияДокументу(ПеремещениеТоваров, Истина);
		Источник._ПеремещениеТоваров = Неопределено;
	КонецЕсли;
КонецПроцедуры

Процедура ПередатьБракНаСкладБракованнойПродукции(Источник, Отказ)
	Отбор = Новый Структура;
	Отбор.Вставить("ВариантОтражения", ОбщегоНазначения.ПредопределенныйЭлемент(
		"Перечисление.ВариантыОтраженияКорректировокРеализаций.УменьшитьРеализациюУвеличитьСкладскиеОстатки"));
	Отбор.Вставить("_Брак", Истина);

	Табл = Источник.Расхождения.Выгрузить(Отбор, "Номенклатура,Количество");

	ПеремещениеТоваров = Источник._ПеремещениеТоваров;

	Если Табл.Количество() = 0 Тогда
		Если ЗначениеЗаполнено(ПеремещениеТоваров) Тогда
			мср.УстановитьПометкуУдаленияДокументу(ПеремещениеТоваров, Истина);
			Источник._ПеремещениеТоваров = Неопределено;
		КонецЕсли;

	Иначе
		Если ЗначениеЗаполнено(ПеремещениеТоваров) Тогда
			Док = ПеремещениеТоваров.ПолучитьОбъект();
		Иначе
			Док = Документы.ПеремещениеТоваров.СоздатьДокумент();
		КонецЕсли;

		Док.Дата = Источник.Дата;

		Док.Организация                = AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию();
		Док.Статус                     = Перечисления.СтатусыПеремещенийТоваров.Принято;
		Док.СкладОтправитель           = Источник.Склад;
		Док.СкладПолучатель            = AMS_ВызовСервера.СкладБракованнойПродукции();
		Док.ВидЦены                    = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Склад, "УчетныйВидЦены");
		Док.СпособДоставки             = Перечисления.СпособыДоставки.Самовывоз;
		Док.ВариантПриемкиТоваров      = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
		Док.ПеремещениеПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		Док.ХозяйственнаяОперация      = Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
		Док.Автор                      = Пользователи.ТекущийПользователь();
		Док.Ответственный              = Источник.Менеджер;
		Док.Подразделение              = AMS_ВызовСервера.ПодразделениеПроизводство();
		Док.НаправлениеДеятельности    = Справочники.НаправленияДеятельности.НайтиПоНаименованию("Продажа", Истина);
		Док.Комментарий                = "Сформирован автоматичестки. Перемещение брака на склад бракованной продукции на основании документа Корректировка реализации №"
			+ Источник.Номер + " от " + Формат(Источник.Дата, "ДЛФ=Д") + " г.";

		Док._Основание                = Источник.Ссылка;
		Док._ОперацияПроизводства     = Перечисления.AMS_ОперацииПроизводства.ПеремещениеПослеКорректировки;
		Док._СформированАвтоматически = Истина;
		
		Док.Товары.Очистить();

		Для Каждого Стр Из Табл Цикл
			НовСтр = Док.Товары.Добавить();

			НовСтр.Номенклатура       = Стр.Номенклатура;
			НовСтр.КоличествоУпаковок = -Стр.Количество;
			НовСтр.Количество         = -Стр.Количество;
		КонецЦикла;

		мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ, Истина);

		Если Отказ Тогда
			ОбщегоНазначения.СообщитьПользователю(
				"Не удалось провести документ перемещения брака на склад бракованной продукции.");
		Иначе
			Источник._ПеремещениеТоваров = Док.Ссылка;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПередЗаписьюПередачаТоваровХранителю(Источник, Отказ, РежимЗаписи)
	Если Источник.Склад = AMS_ВызовСервера.СкладМПКТ() Тогда
		Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			Ответственный = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Склад, "ТекущийОтветственный");
			Подразделение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Склад, "Подразделение");
			
			МассивСборкаТоваров = Новый Массив();
			
			Табл = ПолучитьДанныеСборкиТоваров(Источник);
			
			// Удалить лишние сборки товаров на одну и ту же номенклатуру
			Таб = Табл.Скопировать(, "Номенклатура");
			Таб.Свернуть("Номенклатура");
			
			Для Каждого СтрТаб Из Таб Цикл
				МассивСтрок = Табл.НайтиСтроки(Новый Структура("Номенклатура", СтрТаб.Номенклатура));
				
				Если МассивСтрок.Количество() > 1 Тогда
					Счет = 0;
					Для Каждого Стр Из МассивСтрок Цикл
						Счет = Счет + 1;
						Если Счет > 1 Тогда
							мср.УстановитьПометкуУдаленияДокументу(Стр.СборкаТоваров, Истина);
							Табл.Удалить(Стр);		
						КонецЕсли;						
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
			// Удалить лишние сборки товаров на одну и ту же номенклатуру
			
			// Удалить лишние сборки товаров со ссылкой на Источник, но на другую номенклатуру
			СписокСборкаТоваров = Табл.ВыгрузитьКолонку("СборкаТоваров");
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("СписокСборкаТоваров", СписокСборкаТоваров);
			Запрос.УстановитьПараметр("ПередачаТоваровНаКомиссию", Источник.Ссылка);
			Запрос.Текст =
			"ВЫБРАТЬ
			|	т.Ссылка КАК СборкаТоваров
			|ИЗ
			|	Документ.СборкаТоваров КАК т
			|ГДЕ
			|	НЕ т.Ссылка В (&СписокСборкаТоваров)
			|	И т.AMS_Основание = &ПередачаТоваровНаКомиссию
			|	И т.AMS_Операция = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацияСборкаТоваров.СборкаНаборов)
			|	И НЕ т.ПометкаУдаления";
			Таб = Запрос.Выполнить().Выгрузить();
			Для Каждого Стр Из Таб Цикл
				мср.УстановитьПометкуУдаленияДокументу(Стр.СборкаТоваров, Истина);
			КонецЦикла;
			// Удалить лишние сборки товаров со ссылкой на Источник, но на другую номенклатуру

			Для Каждого Стр Из Табл Цикл
				Если ЗначениеЗаполнено(Стр.СборкаТоваров) Тогда
					Док = Стр.СборкаТоваров.ПолучитьОбъект();
				Иначе
					Док = Документы.СборкаТоваров.СоздатьДокумент();
					
					Док.Дата                  = Источник.Дата - 600;
					Док.Организация           = Источник.Организация;
					Док.Склад                 = Источник.Склад;
					Док.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СборкаТоваров;
					Док.ВариантПриемкиТоваров = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
					Док.Ответственный         = Ответственный;
					Док.AMS_Операция          = Перечисления.AMS_ОперацияСборкаТоваров.СборкаНаборов;
					Док.Подразделение         = Подразделение;
					Док.Статус                = Перечисления.СтатусыСборокТоваров.СобраноРазобрано;
					Док.СборкаПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
					
					Док.Номенклатура          = Стр.Номенклатура;
					Док.ВариантКомплектации   = Стр.ВариантКомплектации;
					
					Док.УстановитьНовыйНомер();
				КонецЕсли;
				
				Если Док.Дата = Источник.Дата - 600 Тогда
					Док.Дата = Источник.Дата - 600;
				КонецЕсли;

				Если Не ЗначениеЗаполнено(Док.ВариантКомплектации) Тогда
					Док.ВариантКомплектации = Стр.ВариантКомплектации;
				КонецЕсли;
				
				Док.Упаковка           = Стр.Упаковка;
				Док.Количество         = Стр.Количество;
				Док.КоличествоУпаковок = Стр.Количество;
				
				Док.Комментарий = "Основание: Передача на комиссию " + Источник.Номер + " от " + Формат(Источник.Дата, "ДЛФ=Д");
				
				// Удалить лишние комплектующие
				Комплектующие = Справочники.ВариантыКомплектацииНоменклатуры.ПолучитьКомплектующиеНоменклатуры(
									Док.ВариантКомплектации, , Док.Количество);
				Запрос = Новый Запрос;
				Запрос.УстановитьПараметр("Товары", Комплектующие);
				Запрос.УстановитьПараметр("ВидНоменклатуры", AMS_ВызовСервера.ВидыНоменклатурыПродукции());
				Запрос.Текст =
				"ВЫБРАТЬ
				|	т.Номенклатура КАК Номенклатура,
				|	т.Упаковка КАК Упаковка,
				|	т.КоличествоУпаковок КАК КоличествоУпаковок,
				|	т.Количество КАК Количество
				|ПОМЕСТИТЬ вт
				|ИЗ
				|	&Товары КАК т
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	Ном.Ссылка КАК Номенклатура,
				|	вт.Упаковка КАК Упаковка,
				|	вт.КоличествоУпаковок КАК КоличествоУпаковок,
				|	вт.Количество КАК Количество
				|ИЗ
				|	вт КАК вт
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
				|		ПО вт.Номенклатура = Ном.Ссылка
				|ГДЕ
				|	Ном.ВидНоменклатуры В (&ВидНоменклатуры)";
				//@skip-check query-in-loop
				Товары = Запрос.Выполнить().Выгрузить();
				// Удалить лишние комплектующие

				Док.Товары.Загрузить(Товары);
				
				мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение);
				
				МассивСборкаТоваров.Добавить(Док.Ссылка);
			КонецЦикла;
			
			Источник. ДополнительныеСвойства.Вставить("МассивСборкаТоваров", МассивСборкаТоваров);
		
		ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
			Для Каждого Стр Из Табл Цикл
				Если ЗначениеЗаполнено(Стр.СборкаТоваров) Тогда
					мср.ЗаписатьДокумент(Стр.СборкаТоваров, РежимЗаписиДокумента.ОтменаПроведения);
				КонецЕсли;
			КонецЦикла;				
		
		ИначеЕсли Источник.ПометкаУдаления Тогда
			Для Каждого Стр Из Табл Цикл
				Если ЗначениеЗаполнено(Стр.СборкаТоваров) Тогда
					мср.УстановитьПометкуУдаленияДокументу(Стр.СборкаТоваров, Истина);
				КонецЕсли;
			КонецЦикла;				
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьДанныеСборкиТоваров(Источник)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Источник.Товары.Выгрузить(, "Номенклатура, Количество"));
	Запрос.УстановитьПараметр("ВидНоменклатуры", AMS_ВызовСервера.ВидНоменклатурыПродукцияНаборы());
	Запрос.УстановитьПараметр("Передача", Источник.Ссылка);
	Запрос.УстановитьПараметр("Дата", Источник.Дата);
	Запрос.УстановитьПараметр("Склад", Источник.Склад);
		
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ тч
	|ИЗ
	|	&Товары КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ном.Ссылка КАК Номенклатура,
	|	СУММА(тч.Количество) КАК Количество
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	тч КАК тч
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО тч.Номенклатура = Ном.Ссылка
	|		И Ном.ВидНоменклатуры = &ВидНоменклатуры
	|СГРУППИРОВАТЬ ПО
	|	Ном.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	Сборка.Ссылка КАК СборкаТоваров,
	|	Сборка.ВариантКомплектации КАК ВариантКомплектации
	|ПОМЕСТИТЬ сбор
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СборкаТоваров КАК Сборка
	|		ПО тов.Номенклатура = Сборка.Номенклатура
	|		И &Передача = Сборка.AMS_Основание
	|ГДЕ
	|	НЕ Сборка.ПометкаУдаления
	|	И Сборка.Склад = &Склад
	|	И Сборка.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	ВариантыКомпл.Ссылка КАК ВариантКомплектации
	|ПОМЕСТИТЬ комп
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомпл
	|		ПО тов.Номенклатура = ВариантыКомпл.Владелец
	|ГДЕ
	|	ВариантыКомпл.Основной
	|	И НЕ ВариантыКомпл.ПометкаУдаления
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	Упак.Ссылка КАК Упаковка
	|ПОМЕСТИТЬ упак
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Упак
	|		ПО тов.Номенклатура = Упак.Владелец
	|ГДЕ
	|	Упак.Числитель = 1
	|	И НЕ Упак.ПометкаУдаления
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Количество КАК Количество,
	|	сбор.СборкаТоваров КАК СборкаТоваров,
	|	ВЫБОР
	|		КОГДА сбор.ВариантКомплектации ЕСТЬ NULL
	|		ИЛИ сбор.ВариантКомплектации = ЗНАЧЕНИЕ(Справочник.ВариантыКомплектацииНоменклатуры.ПустаяСсылка)
	|			ТОГДА комп.ВариантКомплектации
	|		ИНАЧЕ сбор.ВариантКомплектации
	|	КОНЕЦ КАК ВариантКомплектации,
	|	упак.Упаковка КАК Упаковка
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ сбор КАК сбор
	|		ПО тов.Номенклатура = сбор.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ комп КАК комп
	|		ПО тов.Номенклатура = комп.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ упак КАК упак
	|		ПО тов.Номенклатура = упак.Номенклатура";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Процедура ПередЗаписьюПеремещениеТоваров(Источник, Отказ, РежимЗаписи)
	Если Источник.СкладПолучатель = AMS_ВызовСервера.СкладБракованнойПродукции() Тогда
		Для Каждого Стр Из Источник.Товары Цикл
			Если Не AMS_ВызовСервера.ЭтоПродукцияAMS(Стр.Номенклатура) Тогда
				Текст = "Указанная номенклатура не является продукцией";
				ОбщегоНазначения.СообщитьПользователю(Текст,,,,Отказ);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура УстановитьВремяДокумента(Источник, Имя, ВремяОт, ВремяДо) Экспорт
	Дата     = Источник.Дата;
	ТекВремя = Дата - НачалоДня(Дата);
	Ссылка   = Источник.Ссылка;

	Если Не ЗначениеЗаполнено(Ссылка) Или ТекВремя < ВремяОт Или ТекВремя > ВремяДо Или ЕстьДокументЭтойДаты(Ссылка,
		Имя, Дата) Тогда
		Источник.Дата = ПолучитьДатуДокумента(Ссылка, Имя, ВремяОт, ВремяДо, Дата);
	КонецЕсли;
КонецПроцедуры

Функция ЕстьДокументЭтойДаты(Ссылка, Имя, Дата)
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.Текст = "ВЫБРАТЬ д.Ссылка ИЗ Документ." + Имя + " КАК д ГДЕ д.Дата = &Дата И д.Ссылка <> &Ссылка";

	Возврат Не Запрос.Выполнить().Пустой();
КонецФункции

Функция ПолучитьДатуДокумента(Ссылка, Имя, ВремяОт, ВремяДо, Дата)
	УстановитьПривилегированныйРежим(Истина);

	НачалоДня = НачалоДня(Дата);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ДатаОт", НачалоДня + ВремяОт);
	Запрос.УстановитьПараметр("ДатаДо", НачалоДня + ВремяДо);

	Запрос.Текст = "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РАЗНОСТЬДАТ(НАЧАЛОПЕРИОДА(д.Дата, ДЕНЬ), д.Дата, СЕКУНДА) КАК КолСек
		|ИЗ
		|	Документ." + Имя + " КАК д
		|ГДЕ
		|	д.Дата МЕЖДУ &ДатаОт И &ДатаДо И д.Ссылка <> &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	КолСек";

	Табл = Запрос.Выполнить().Выгрузить();

	Для Сч = ВремяОт По ВремяДо Цикл
		НайденнаяСтрока = Табл.Найти(Сч);
		Если НайденнаяСтрока = Неопределено Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат НачалоДня + Сч;
КонецФункции

Процедура ПередЗаписьюРеализацияТоваровУслуг(Источник, Отказ, РежимЗаписи)
	Источник.ДополнительныеСвойства.Вставить("AMS_УтвержденаОтгрузка", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Ссылка, "AMS_УтвержденаОтгрузка"));
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения
		И Не Пользователи.РолиДоступны("_Бухгалтер") 
		И Не Источник.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.КОтгрузке Тогда
			ТекстОшибки = НСтр("ru='Нет прав на отмену проведения.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
		Возврат;
	КонецЕсли;

	Если Источник.ПометкаУдаления Тогда
		Если Не Источник.Проведен Тогда
			//При установки пометки удаления у непроведённого документа, убрать данные из доставки
			УстановитьПривилегированныйРежим(Истина);
			ДоставкаТоваров.ОтразитьСостояниеДоставки(Источник.Ссылка, Отказ, Истина);
			УстановитьПривилегированныйРежим(Ложь);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Источник.AMS_ЦенаИзменена = ЕстьЦеныНеПоУсловиямПродаж(Источник);
	
	Если Источник.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.КОтгрузке Тогда
		ПроверитьЗагрузкуВТранспорт(Источник, РежимЗаписи, Отказ);
			
		Если Источник.РеализацияПоЗаказам Тогда
			ЗаказКлиента = Источник.ЗаказКлиента;
			
			Если ЗначениеЗаполнено(ЗаказКлиента) Тогда
				AMS_ЗаказКлиентаНомер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗаказКлиента, "Номер");
				
				Если Не ЗначениеЗаполнено(Источник.Ссылка) И ЕстьРеализацияЗаказа(AMS_ЗаказКлиентаНомер, Отказ) Тогда
					Возврат;
				КонецЕсли;
					
				Источник.AMS_ЗаказКлиентаНомер = AMS_ЗаказКлиентаНомер;
				
				мср.ЗаписатьДокумент(ЗаказКлиента, РежимЗаписиДокумента.ОтменаПроведения, Отказ, Истина);
				
				Источник.ЗаказКлиента        = Неопределено;
				Источник.РеализацияПоЗаказам = Ложь;
				
				Для Каждого Стр Из Источник.ВидыЗапасов Цикл
					Стр.ЗаказКлиента   = Неопределено;
					Стр.ОбъектРасчетов = Неопределено;
				КонецЦикла;
				
				Для Каждого Стр Из Источник.Товары Цикл
					Стр.ЗаказКлиента   = Неопределено;
					Стр.ОбъектРасчетов = Неопределено;
				КонецЦикла;
				
				Для Каждого Стр Из Источник.ЭтапыГрафикаОплаты Цикл
					Стр.Заказ = Неопределено;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ПриЗаписи

Процедура ПриЗаписиДокумента(Источник, Отказ) Экспорт
	Имя = Источник.Метаданные().Имя;

	Если Имя = "ЗаказКлиента" Тогда
		ПриЗаписиЗаказКлиента(Источник, Отказ);
		
	ИначеЕсли Имя = "ПередачаТоваровХранителю" Тогда
		ПриЗаписиПередачаТоваровХранителю(Источник, Отказ);
		
	ИначеЕсли Имя = "РасходныйОрдерНаТовары" Тогда
		ПриЗаписиРасходныйОрдерНаТовары(Источник, Отказ);

	ИначеЕсли Имя = "РеализацияТоваровУслуг" Тогда
		ПриЗаписиРеализацияТоваровУслуг(Источник, Отказ);
	КонецЕсли;
КонецПроцедуры

Процедура ПриЗаписиЗаказКлиента(Источник, Отказ)
	Если Не Источник.Проведен Тогда
		Возврат;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗаказКлиента", Источник.Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	т.ВариантОбеспечения КАК ВариантОбеспечения
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &ЗаказКлиента";
		
	Табл = Запрос.Выполнить().Выгрузить();
	
	КоличествоВариантОбеспечения = Табл.Количество();
	
	Если КоличествоВариантОбеспечения = 0 Тогда
		Возврат;
	КонецЕсли;
		
		
	Если КоличествоВариантОбеспечения = 1 И Табл[0].ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить Тогда
		СтатусВ2В = Перечисления.AMS_СтатусыВ2В.readyTogo;
	Иначе
		СтатусВ2В = Перечисления.AMS_СтатусыВ2В.packed;
	КонецЕсли;
	
	ОбновитьЗаказКлиентаНаВ2В(Источник.Ссылка, СтатусВ2В);
КонецПроцедуры

Процедура ПриЗаписиПередачаТоваровХранителю(Источник, Отказ)
	Если Источник.Организация = AMS_ВызовСервера.ОрганизацияСобственникПродукции() Тогда
		Возврат;
	КонецЕсли;
	
	Если Источник.Проведен Тогда
		МассивСборкаТоваров = Неопределено;
		Источник. ДополнительныеСвойства.Свойство("МассивСборкаТоваров", МассивСборкаТоваров);
		Если Не МассивСборкаТоваров = Неопределено Тогда
			Для Каждого СборкаТоваров Из МассивСборкаТоваров Цикл
				Док = СборкаТоваров.ПолучитьОбъект();
				Док.AMS_Основание = Источник.Ссылка;
				мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Запись);
			КонецЦикла;
		КонецЕсли;
		
		Если Источник.Организация = AMS_ВызовСервера.ОрганизацияТрейд() Тогда
			ПередатьТоварыДругойОрганизации(Источник.Ссылка, Источник.Дата - 3600, Отказ);
		КонецЕсли;
		
	Иначе // отменено проведение
		ПередачаТоваровМеждуОрганизациями = ПолучитьПередачаТоваровМеждуОрганизациями(Источник.Ссылка);
		
		Если ЗначениеЗаполнено(ПередачаТоваровМеждуОрганизациями) Тогда
			мср.УстановитьПометкуУдаленияДокументу(ПередачаТоваровМеждуОрганизациями, Истина);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПриЗаписиРасходныйОрдерНаТовары(Источник, Отказ)
	УстановитьПривилегированныйРежим(Истина);
	
	Табл = Источник.ТоварыПоРаспоряжениям.Выгрузить(, "Распоряжение");
	Табл.Свернуть("Распоряжение");
	МассивРаспоряжение = Табл.ВыгрузитьКолонку("Распоряжение");
	
	Распоряжение = МассивРаспоряжение[0];
	
	Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Стр = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Распоряжение, "AMS_СтатусРеализации, AMS_ЗаказКлиентаНомер, AMS_ID");
		
		Если Источник.Проведен И Источник.Статус = Перечисления.СтатусыРасходныхОрдеров.Отгружен Тогда
			Если Стр.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.Заказ
				Или Стр.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.Стикерование
				Или Стр.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.КОтгрузке Тогда
				
				ЗаказКлиента = ПолучитьЗаказКлиента(Стр.AMS_ЗаказКлиентаНомер);
				
				Если ЗначениеЗаполнено(ЗаказКлиента) Тогда
					Если Не Стр.AMS_ID = 0 Тогда
						ОбновитьЗаказКлиентаНаВ2В(ЗаказКлиента, Перечисления.AMS_СтатусыВ2В.closed); // завершен
					КонецЕсли;

					ЗаказКлиентаОбъект = ЗаказКлиента.ПолучитьОбъект();
					ЗаказКлиентаОбъект.УстановитьПометкуУдаления(Истина);
				КонецЕсли;
				
				Реализация = Распоряжение.ПолучитьОбъект();
				Реализация.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.Отгружено;
				Реализация.Записать(РежимЗаписиДокумента.Запись);
				
				РегистрыСведений.AMS_ИсторияРеализации.ЗаписатьСобытиеДокумента(Распоряжение, Перечисления.AMS_СобытияРеализации.Отгрузка);
			КонецЕсли;
				
		Иначе // отменено проведение или изменен статус	ордера
			Если Не Стр.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.КОтгрузке Тогда
				Реализация = Распоряжение.ПолучитьОбъект();
				Реализация.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.КОтгрузке;
				Реализация.Записать(РежимЗаписиДокумента.Запись);
				
				РегистрыСведений.AMS_ИсторияРеализации.ЗаписатьСобытиеДокумента(Распоряжение, Перечисления.AMS_СобытияРеализации.ОтменаОтгрузки);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПриЗаписиРеализацияТоваровУслуг(Источник, Отказ)
	Статус = Источник.AMS_СтатусРеализации;

	// Временно
	Если Статус = Перечисления.AMS_СтатусыРеализаций.Заказ Или Статус = Перечисления.AMS_СтатусыРеализаций.Стикерование Тогда
		Возврат;
	КонецЕсли;
	
	СоздатьСчетФактуруДляРеализации(Источник);		
	
	ИзменитьСчетФактуруДляРеализации(Источник); 
	
	Если Источник.Проведен Тогда
		ЗаказКлиента = ПолучитьЗаказКлиента(Источник.AMS_ЗаказКлиентаНомер);
		
		Если ЗначениеЗаполнено(ЗаказКлиента) И Статус = Перечисления.AMS_СтатусыРеализаций.КОтгрузке Тогда
			Стр = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЗаказКлиента, "AMS_ID, Проведен");
			
			Если Стр.AMS_ID > 0 Тогда
				ОбновитьЗаказКлиентаНаВ2В(ЗаказКлиента, Перечисления.AMS_СтатусыВ2В.readyTogo); // готов к отгрузке
			КонецЕсли;
			
			Если Стр.Проведен Тогда
				мср.ЗаписатьДокумент(ЗаказКлиента, РежимЗаписиДокумента.ОтменаПроведения, Отказ, Истина);
			КонецЕсли;
		КонецЕсли;
		
		Если Не Статус = Перечисления.AMS_СтатусыРеализаций.Заказ 
			И Источник.Организация = AMS_ВызовСервера.ОрганизацияТрейд() 
			И Не AMS_ВызовСервера.ПолучитьИмяГруппыДоступаРеализации(Источник.Ссылка) = "Маркетплейс" Тогда
			
			ПередатьТоварыДругойОрганизации(Источник.Ссылка, Источник.Дата - 3600, Отказ);
		КонецЕсли;
		
	Иначе // отменено проведение
		ПередачаТоваровМеждуОрганизациями = ПолучитьПередачаТоваровМеждуОрганизациями(Источник.Ссылка);
		Если ЗначениеЗаполнено(ПередачаТоваровМеждуОрганизациями) Тогда
			мср.УстановитьПометкуУдаленияДокументу(ПередачаТоваровМеждуОрганизациями, Истина, Отказ);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#Область ПередачаТоваровДругойОрганизации

Процедура ПередатьТоварыДругойОрганизации(Распоряжение, Дата, Отказ)
	УстановитьПривилегированныйРежим(Истина);

	Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Данные = ПолучитьДанныеИзРеализацияТоваровУслуг(Распоряжение);
	
	ИначеЕсли ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ПередачаТоваровХранителю") Тогда
		Данные = ПолучитьДанныеИзПередачаТоваровХранителю(Распоряжение);
	КонецЕсли;
	
	ПередачаТоваровМеждуОрганизациями = ПолучитьПередачаТоваровМеждуОрганизациями(Распоряжение);
	
	Если ПередачаТоваровМеждуОрганизациями = Неопределено Тогда
		ПередачаОбъект = Документы.ПередачаТоваровМеждуОрганизациями.СоздатьДокумент();
	Иначе
		ПередачаОбъект = ПередачаТоваровМеждуОрганизациями.ПолучитьОбъект();
	КонецЕсли;

	Шапка = Данные.Шапка;

	ЗаполнитьЗначенияСвойств(ПередачаОбъект, Шапка);

	ПередачаОбъект.Дата        = Дата - 60;
	ПередачаОбъект.Организация = AMS_ВызовСервера.ОрганизацияСобственникПродукции();
	ПередачаОбъект._Основание  = Распоряжение;

	ПередачаОбъект.Комментарий = "Основание " + Шапка.Ссылка + Символы.ПС + "Клиент """ + Шапка.Партнер + """.";

	Если ПередачаОбъект.ЭтоНовый() И Не ЗначениеЗаполнено(ПередачаОбъект.Номер) Тогда
		ПередачаОбъект.УстановитьНовыйНомер();
	КонецЕсли;

	ПередачаОбъект.Товары.Загрузить(Данные.Товары);

	мср.ЗаписатьДокумент(ПередачаОбъект, РежимЗаписиДокумента.Проведение, Отказ);
	
	Если Не Отказ Тогда 
		СоздатьСчетФактуруДляПередачи(ПередачаОбъект.Ссылка, ПередачаОбъект.Номер);
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьДанныеИзРеализацияТоваровУслуг(Распоряжение)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);
	Запрос.УстановитьПараметр("СтавкаНДС", Справочники.СтавкиНДС.НайтиПоНаименованию("22%", Истина));
	Запрос.УстановитьПараметр("НалогообложениеНДС", Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС);
	Запрос.УстановитьПараметр("Подразделение", AMS_ВызовСервера.ПодразделениеПроизводство());
	Запрос.УстановитьПараметр("ВидыНоменклатурыПродукции", AMS_ВызовСервера.ВидыНоменклатурыПродукции());

	ЗапросТекст =
	"ВЫБРАТЬ
	|	т.Ссылка,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Упаковка КАК Упаковка,
	|	т.КоличествоУпаковок КАК КоличествоУпаковок,
	|	т.Количество КАК Количество,
	|	ВЫРАЗИТЬ(100 * т.Цена / 130 КАК ЧИСЛО(10, 2)) КАК Цена,
	|	&СтавкаНДС КАК СтавкаНДС,
	|	т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
	|	ном.ВидНоменклатуры КАК ВидНоменклатуры
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|		ПО т.Номенклатура = ном.Ссылка
	|ГДЕ
	|	т.Ссылка = &Распоряжение
	|	И ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|	И ном.ВидНоменклатуры В (&ВидыНоменклатурыПродукции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Упаковка КАК Упаковка,
	|	тов.КоличествоУпаковок КАК КоличествоУпаковок,
	|	тов.Количество КАК Количество,
	|	тов.Цена КАК Цена,
	|	тов.СтавкаНДС КАК СтавкаНДС,
	|	0.22 * тов.Цена * тов.КоличествоУпаковок КАК СуммаНДС,
	|	тов.Цена * тов.КоличествоУпаковок КАК Сумма,
	|	1.22 * тов.Цена * тов.КоличествоУпаковок КАК СуммаСНДС,
	|	0.22 * тов.Цена * тов.КоличествоУпаковок КАК СуммаНДСВзаиморасчетов,
	|	1.22 * тов.Цена * тов.КоличествоУпаковок КАК СуммаВзаиморасчетов,
	|	тов.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры
	|ИЗ
	|	тов КАК тов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Ссылка,
	|	т.Валюта КАК Валюта,
	|	т.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	т.ВариантОформленияПродажи КАК ВариантОформленияПродажи,
	|	т.Дата КАК Дата,
	|	т.Дата КАК ДатаПлатежа,
	|	т.Номер КАК НомерРеал,
	|	т.Партнер КАК Партнер,
	|	&НалогообложениеНДС КАК НалогообложениеНДС,
	|	т.Организация КАК ОрганизацияПолучатель,
	|	т.НалогообложениеНДС КАК ПередачаПодДеятельность,
	|	т.Склад КАК Склад,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияТоваровВДругуюОрганизацию) КАК ХозяйственнаяОперация,
	|	&Подразделение КАК Подразделение
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК т
	|ГДЕ
	|	т.Ссылка = &Распоряжение";

	Запрос.Текст = ЗапросТекст;

	Рез = Запрос.ВыполнитьПакет();

	Возврат Новый Структура("Товары, Шапка", Рез[1].Выгрузить(), Рез[2].Выгрузить()[0]);
КонецФункции

Функция ПолучитьДанныеИзПередачаТоваровХранителю(Распоряжение)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);
	Запрос.УстановитьПараметр("СтавкаНДС", Справочники.СтавкиНДС.НайтиПоНаименованию("20%", Истина));
	Запрос.УстановитьПараметр("НалогообложениеНДС", Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС);
	Запрос.УстановитьПараметр("ПередачаПодДеятельность", Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС);
	Запрос.УстановитьПараметр("Подразделение", AMS_ВызовСервера.ПодразделениеПроизводство());
	Запрос.УстановитьПараметр("ВидыНоменклатурыПродукции", AMS_ВызовСервера.ВидыНоменклатурыПродукции());

	ЗапросТекст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Упаковка КАК Упаковка,
	|	т.КоличествоУпаковок КАК КоличествоУпаковок,
	|	т.Количество КАК Количество,
	|	т.Цена * 100 / 122 КАК Цена,
	|	&СтавкаНДС КАК СтавкаНДС,
	|	т.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
	|	ном.ВидНоменклатуры КАК ВидНоменклатуры
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	Документ.ПередачаТоваровХранителю.Товары КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|		ПО т.Номенклатура = ном.Ссылка
	|ГДЕ
	|	т.Ссылка = &Распоряжение
	|	И ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|	И ном.ВидНоменклатуры В (&ВидыНоменклатурыПродукции)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка,
	|	т.Валюта КАК Валюта,
	|	т.Валюта КАК ВалютаВзаиморасчетов,
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыОформленияПродажи.РеализацияТоваровУслуг) КАК ВариантОформленияПродажи,
	|	т.Дата КАК Дата,
	|	т.Дата КАК ДатаПлатежа,
	|	т.Номер КАК НомерРеал,
	|	т.Партнер КАК Партнер,
	|	&НалогообложениеНДС КАК НалогообложениеНДС,
	|	т.Организация КАК ОрганизацияПолучатель,
	|	&ПередачаПодДеятельность КАК ПередачаПодДеятельность,
	|	т.Склад КАК Склад,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияТоваровВДругуюОрганизацию) КАК ХозяйственнаяОперация,
	|	НЕОПРЕДЕЛЕНО КАК ВидЦены,
	|	&Подразделение КАК Подразделение,
	|	т.Менеджер КАК Менеджер
	|ИЗ
	|	Документ.ПередачаТоваровХранителю КАК т
	|ГДЕ
	|	т.Ссылка = &Распоряжение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Упаковка КАК Упаковка,
	|	тов.КоличествоУпаковок КАК КоличествоУпаковок,
	|	тов.Количество КАК Количество,
	|	тов.Цена КАК Цена,
	|	тов.СтавкаНДС КАК СтавкаНДС,
	|	0.22 * тов.Цена * тов.КоличествоУпаковок КАК СуммаНДС,
	|	тов.Цена * тов.КоличествоУпаковок КАК Сумма,
	|	1.22 * тов.Цена * тов.КоличествоУпаковок КАК СуммаСНДС,
	|	0.22 * тов.Цена * тов.КоличествоУпаковок КАК СуммаНДСВзаиморасчетов,
	|	1.22 * тов.Цена * тов.КоличествоУпаковок КАК СуммаВзаиморасчетов,
	|	НЕОПРЕДЕЛЕНО КАК АналитикаУчетаНоменклатуры
	|ИЗ
	|	тов КАК тов";

	Запрос.Текст = ЗапросТекст;

	Рез = Запрос.ВыполнитьПакет();
	
	Шапка  = Рез[1].Выгрузить()[0];
	Товары = Рез[2].Выгрузить();

	Возврат Новый Структура("Шапка, Товары", Шапка, Товары);
КонецФункции

Процедура СоздатьСчетФактуруДляПередачи(ДокументОснование, Номер)
	СчетФактура = ПолучитьСчетФактураВыданный(ДокументОснование);

	Если ЗначениеЗаполнено(СчетФактура) Тогда
		СчетФактура = СчетФактура.ПолучитьОбъект();

		Если СчетФактура.ПометкаУдаления Тогда
			мср.УстановитьПометкуУдаленияДокументу(СчетФактура, Ложь);
		КонецЕсли;

	Иначе
		СчетФактура = Документы.СчетФактураВыданный.СоздатьДокумент();
	КонецЕсли;

	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ДокументОснование", ДокументОснование);

	СчетФактура.Заполнить(ДанныеЗаполнения);

	СчетФактура.Номер = Номер;

	мср.ЗаписатьДокумент(СчетФактура, РежимЗаписиДокумента.Проведение);
КонецПроцедуры

Функция ПолучитьПередачаТоваровМеждуОрганизациями(Основание) Экспорт
	Если ЗначениеЗаполнено(Основание) Тогда
		УстановитьПривилегированныйРежим(Истина);
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Основание", Основание);
		Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПередачаТоваровМеждуОрганизациями КАК т
		|ГДЕ
		|	т._Основание = &Основание
		|	И НЕ т.ПометкаУдаления";
	
		Рез = Запрос.Выполнить();
	
		Если Рез.Пустой() Тогда
			Возврат Неопределено;
		Иначе
			Выб = Рез.Выбрать(); Выб.Следующий();
			Возврат Выб.Ссылка;
		КонецЕсли;
	КонецЕсли;
КонецФункции

#КонецОбласти

#Область СозданиеСчетаФактура

Процедура СоздатьСчетФактуруДляРеализации(Источник)
	СчетФактура = ПолучитьСчетФактураВыданный(Источник.Ссылка);

	Если ЗначениеЗаполнено(СчетФактура) Тогда
		СчетФактура = СчетФактура.ПолучитьОбъект();

		Если Не Источник.ПометкаУдаления = СчетФактура.ПометкаУдаления Тогда
			мср.УстановитьПометкуУдаленияДокументу(СчетФактура, Источник.ПометкаУдаления);
		КонецЕсли;
		
		Если Не Источник.Проведен Тогда
	
			Если СчетФактура.Проведен Тогда
				мср.ЗаписатьДокумент(СчетФактура, РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;
			
			Возврат;
		КонецЕсли;

	Иначе
			СчетФактура = Документы.СчетФактураВыданный.СоздатьДокумент();
	КонецЕсли;

	ПараметрыРегистрации = Документы.РеализацияТоваровУслуг.ПараметрыРегистрацииСчетовФактурВыданных(Источник);
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ДокументОснование", ПараметрыРегистрации.Ссылка);
	ДанныеЗаполнения.Вставить("Организация",       ПараметрыРегистрации.Организация);
	ДанныеЗаполнения.Вставить("Контрагент",        ПараметрыРегистрации.Контрагент);
	ДанныеЗаполнения.Вставить("Исправление",       ПараметрыРегистрации.ИсправлениеОшибок);
	ДанныеЗаполнения.Вставить("Корректировочный",  ПараметрыРегистрации.КорректировкаПоСогласованиюСторон);

	Если Источник.Проведен Тогда
		СчетФактура.Заполнить(ДанныеЗаполнения);
		
		СчетФактура.Номер = Источник.Номер;
		
		мср.ЗаписатьДокумент(СчетФактура, РежимЗаписиДокумента.Проведение);
	КонецЕсли;
КонецПроцедуры

Процедура ИзменитьСчетФактуруДляРеализации(Источник)
	Если Источник.ЭтапыГрафикаОплаты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Источник.ЭтапыГрафикаОплаты[0].Сдвиг = 0 Тогда
		Возврат;
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументРегистратор", Источник.Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	т.ДокументРегистратор КАК Реализация,
	|	т.РасчетныйДокумент КАК Платежка
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентамиПоСрокам КАК т
	|ГДЕ
	|	т.ДокументРегистратор = &ДокументРегистратор
	|	И т.РасчетныйДокумент ССЫЛКА Документ.ПоступлениеБезналичныхДенежныхСредств
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	вт.Реализация КАК Реализация,
	|	вт.Платежка КАК РасчетныйДокумент,
	|	вт.Платежка.НомерВходящегоДокумента КАК НомерПлатежноРасчетногоДокумента,
	|	вт.Платежка.ДатаВходящегоДокумента КАК ДатаПлатежноРасчетногоДокумента,
	|	СчетФактураАванс.Ссылка КАК СчетФактураВыданныйАванс,
	|	СчетФактураАванс.Номер КАК НомерСчетаФактурыНаАванс,
	|	СчетФактураАванс.Дата КАК ДатаСчетаФактурыНаАванс,
	|	СчетФактура.Ссылка КАК СчетФактураВыданный
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданныйАванс КАК СчетФактураАванс
	|		ПО вт.Платежка = СчетФактураАванс.ДокументОснование
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК СчетФактура
	|		ПО вт.Реализация = СчетФактура.ДокументОснование";
	
	Табл = Запрос.Выполнить().Выгрузить();
	
	Если Табл.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Стр = Табл[0];
	
	Если Не (ЗначениеЗаполнено(Стр.РасчетныйДокумент) 
			И ЗначениеЗаполнено(Стр.СчетФактураВыданныйАванс)
			И ЗначениеЗаполнено(Стр.СчетФактураВыданный)) Тогда
		Возврат;
	Иначе
		
		Фактура = Стр.СчетФактураВыданный.ПолучитьОбъект();
		
		Фактура.ПлатежноРасчетныеДокументы.Очистить();
		
		НовСтр = Фактура.ПлатежноРасчетныеДокументы.Добавить();
		
		НовСтр.НомерПлатежноРасчетногоДокумента = Стр.НомерПлатежноРасчетногоДокумента;
		НовСтр.ДатаПлатежноРасчетногоДокумента  = Стр.ДатаПлатежноРасчетногоДокумента;
		НовСтр.РасчетныйДокумент                = Стр.РасчетныйДокумент;
		НовСтр.НомерСчетаФактурыНаАванс         = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Стр.НомерСчетаФактурыНаАванс);
		НовСтр.ДатаСчетаФактурыНаАванс          = Стр.ДатаСчетаФактурыНаАванс;
		
		Фактура.СтрокаПлатежноРасчетныеДокументы = Документы.СчетФактураВыданный.СтрокаРасчетноПлатежныхДокументов(Фактура.ПлатежноРасчетныеДокументы);
		Фактура.СтрокаАвансовыеСчетаФактуры      = Документы.СчетФактураВыданный.СтрокаАвансовыеСчетаФактуры(Фактура.ПлатежноРасчетныеДокументы);
		
		мср.ЗаписатьДокумент(Фактура, РежимЗаписиДокумента.Проведение);
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьСчетФактураВыданный(Основание)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Основание", Основание);

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	д.Ссылка КАК СчетФактура,
	|	д.Организация КАК Организация
	|ИЗ
	|	Документ.СчетФактураВыданный.ДокументыОснования КАК тч
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК д
	|		ПО тч.Ссылка = д.Ссылка
	|ГДЕ
	|	тч.ДокументОснование = &Основание
	|	И НЕ д.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	д.НомерИсправления УБЫВ";
	
	Табл = Запрос.Выполнить().Выгрузить();

	Если Табл.Количество() > 0 Тогда
		Возврат Табл[0].СчетФактура;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

