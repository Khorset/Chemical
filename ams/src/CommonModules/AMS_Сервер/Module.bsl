#КонецОбласти

#Область Прочие

Процедура ПроверитьЗагрузкуВТранспорт(Источник, РежимЗаписи, Отказ)
	Если Не ЗначениеЗаполнено(Источник.Ссылка) 
		Или Не РежимЗаписи = РежимЗаписиДокумента.Проведение Или Пользователи.РолиДоступны("_Бухгалтер") Тогда
		Возврат;
	КонецЕсли;
		
	Если ТипЗнч(Источник.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг")	
		И Не Источник.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.КОтгрузке Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЛогистическийЛист = AMS_ВызовСервера.ПолучитьЛогистическийЛист(Источник.Ссылка);
	
	Если ЗначениеЗаполнено(ЛогистическийЛист) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ЛогистическийЛист", ЛогистическийЛист);
		Запрос.УстановитьПараметр("Распоряжение", Источник.Ссылка);
		
		Запрос.Текст =
			"ВЫБРАТЬ
			|	т.Ссылка КАК Ссылка,
			|	т.ТранспортноеСредство КАК ТранспортноеСредство,
			|	т.Распоряжение КАК Распоряжение,
			|	т.ТранспортноеСредство.AMS_КоличествоПалет КАК КоличествоПалетАвто
			|ПОМЕСТИТЬ Авто
			|ИЗ
			|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
			|ГДЕ
			|	НЕ т.Подвоз
			|	И т.Ссылка = &ЛогистическийЛист
			|	И т.Распоряжение = &Распоряжение
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	т.ТранспортноеСредство КАК ТранспортноеСредство,
			|	СУММА(т.Распоряжение.AMS_КоличествоПалет) КАК КоличествоПалет
			|ПОМЕСТИТЬ Загрузки
			|ИЗ
			|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Авто КАК Авто
			|		ПО т.Ссылка = Авто.Ссылка
			|		И т.ТранспортноеСредство = Авто.ТранспортноеСредство
			|		И т.Распоряжение <> Авто.Распоряжение
			|СГРУППИРОВАТЬ ПО
			|	т.ТранспортноеСредство
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Авто.ТранспортноеСредство КАК ТранспортноеСредство,
			|	Авто.КоличествоПалетАвто КАК КоличествоПалетАвто,
			|	ЕСТЬNULL(Загрузки.КоличествоПалет, 0) КАК КоличествоПалет
			|ИЗ
			|	Авто КАК Авто
			|		ЛЕВОЕ СОЕДИНЕНИЕ Загрузки КАК Загрузки
			|		ПО Авто.ТранспортноеСредство = Загрузки.ТранспортноеСредство";
		
		Стр = Запрос.Выполнить().Выгрузить()[0];
		
		Перегруз = (Стр.КоличествоПалет + Источник.AMS_КоличествоПалет) - Стр.КоличествоПалетАвто;
		
		Если Перегруз > 0 Тогда
			ТекстОшибки = "Перегруз " + Перегруз + " палет(ы) в транспортное средство " + Стр.ТранспортноеСредство;
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьВесОбъемКолПалетЗаказКлиента(Объект) Экспорт
	Стр = ПолучитьВесОбъемТоваров(Объект.Товары.Выгрузить(,"Номенклатура, Количество"), Объект.AMS_СпособПередачиТоваров);
	
	Объект.AMS_Вес   = Стр.Вес;
	Объект.AMS_Объем = Стр.Объем;
	
	Объект.AMS_КоличествоПалет        = Стр.КоличествоПалетМоно + Стр.КоличествоПалетСборных;
	Объект.AMS_КоличествоПалетСборных = Стр.КоличествоПалетСборных;
	Объект.AMS_КоличествоПалетРасчет  = Стр.КоличествоПалетРасчет;
	Объект.AMS_КоличествоУпаковок     = Стр.КоличествоУпаковок;
	Объект.AMS_КоличествоПалетПлан    = Объект.AMS_КоличествоПалет;
	Объект.AMS_ВесПлан                = Объект.AMS_Вес;
КонецПроцедуры

Функция ПолучитьВесОбъемТоваров(Товары, СпособПередачиТоваров = 0) Экспорт
	Данные = Новый Структура;
	Данные.Вставить("КоличествоУпаковок", 0);
	Данные.Вставить("Вес", 0);
	Данные.Вставить("Объем", 0);
	Данные.Вставить("КоличествоПалет", 0);
	Данные.Вставить("КоличествоПалетМоно", 0);
	Данные.Вставить("КоличествоПалетСборных", 0);
	Данные.Вставить("КоличествоПалетРасчет", 0);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Товары);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ тч
	|ИЗ
	|	&Товары КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ном.Ссылка КАК Номенклатура,
	|	СУММА(тч.Количество) КАК Количество,
	|	Ном.НаборУпаковок КАК НаборУпаковок,
	|	Ном.КоэффициентЕдиницыДляОтчетов КАК Кфц,
	|	Ном._Упаковка КАК ОсновнаяУпаковка
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	тч КАК тч
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО тч.Номенклатура = Ном.Ссылка
	|ГДЕ
	|	тч.Количество > 0
	|	И Ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|
	|СГРУППИРОВАТЬ ПО
	|	Ном.Ссылка,
	|	Ном.НаборУпаковок,
	|	Ном.КоэффициентЕдиницыДляОтчетов,
	|	Ном._Упаковка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	Ед.Ссылка КАК ШтУпак,
	|	Ед.Вес КАК ШтВес,
	|	Ед.Объем КАК ШтОбъем
	|ПОМЕСТИТЬ шт
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Ед
	|		ПО (вт.Номенклатура = Ед.Владелец
	|				ИЛИ вт.НаборУпаковок = Ед.Владелец)
	|			И (Ед.Числитель = 1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	Ед.Ссылка КАК УпакУпак,
	|	Ед.Вес КАК УпакВес,
	|	Ед.Объем КАК УпакОбъем,
	|	Ед.Числитель КАК УпакЧислитель
	|ПОМЕСТИТЬ упак
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Ед
	|		ПО вт.ОсновнаяУпаковка = Ед.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	Ед.Ссылка КАК ПалУпак,
	|	Ед.Вес КАК ПалВес,
	|	Ед.Объем КАК ПалОбъем,
	|	Ед.Числитель КАК ПалЧислитель
	|ПОМЕСТИТЬ пал
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Ед
	|		ПО (вт.Номенклатура = Ед.Владелец
	|				ИЛИ вт.НаборУпаковок = Ед.Владелец)
	|			И (Ед.ЕдиницаИзмерения.Код = ""999"")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	вт.Количество КАК Количество,
	|	ЕСТЬNULL(шт.ШтВес, 0) КАК ШтВес,
	|	ЕСТЬNULL(упак.УпакЧислитель, 1) КАК УпакЧислитель,
	|	ЕСТЬNULL(упак.УпакВес, 0) КАК УпакВес,
	|	ЕСТЬNULL(упак.УпакОбъем, 0) КАК УпакОбъем,
	|	вт.Количество / ЕСТЬNULL(упак.УпакЧислитель, 1) КАК КоличествоУпаковок,
	|	ЕСТЬNULL(пал.ПалЧислитель, 1) КАК ПалЧислитель,
	|	ЕСТЬNULL(пал.ПалВес, 0) КАК ПалВес,
	|	ЕСТЬNULL(пал.ПалОбъем, 0) КАК ПалОбъем,
	|	ВЫБОР
	|		КОГДА пал.ПалУпак ЕСТЬ NULL
	|			ТОГДА 0
	|		ИНАЧЕ вт.Количество / пал.ПалЧислитель
	|	КОНЕЦ КАК КоличествоПалет
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ шт КАК шт
	|		ПО вт.Номенклатура = шт.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ упак КАК упак
	|		ПО вт.Номенклатура = упак.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ пал КАК пал
	|		ПО вт.Номенклатура = пал.Номенклатура";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Данные;
	КонецЕсли;
	
	КоличествоУпаковок = 0;
	Вес = 0;
	Объем = 0;
	КоличествоПалет = 0;
	КоличествоПалетМоно = 0;
	КоличествоПалетРасчет = 0;
	КоличествоПалетСборных = 0;

	Выб = Рез.Выбрать();
	Пока Выб.Следующий() Цикл
		//Палета
		КолПалетМоно = Цел(Выб.КоличествоПалет);
		КолПалетОстат = Выб.КоличествоПалет - КолПалетМоно;

		ВесПалет = Выб.ПалВес * КолПалетМоно;
		ОбъемПалет = Выб.ПалОбъем * КолПалетМоно;
		
		//Упаковка
		ОстатокКоличество = Выб.Количество - КолПалетМоно * Выб.ПалЧислитель;

		КолУпаковок = ОстатокКоличество / Выб.УпакЧислитель;
		КолУпаковокЦелых = Цел(КолУпаковок);

		ВесУпак = Выб.УпакВес * КолУпаковокЦелых;
		ОбъемУпак = Выб.УпакОбъем * КолУпаковокЦелых;
		
		//Единица
		ОстатокКоличество = ОстатокКоличество - КолУпаковокЦелых * Выб.УпакЧислитель;
		ВесШт = Выб.ШтВес * ОстатокКоличество;
		
		//Итог
		КоличествоУпаковок    = КоличествоУпаковок + Выб.КоличествоУпаковок;
		Вес                   = Вес + ВесПалет + ВесУпак + ВесШт;
		Объем                 = Объем + ОбъемПалет + ОбъемУпак;
		КоличествоПалетРасчет = КоличествоПалетРасчет + Выб.КоличествоПалет;

		КоличествоПалет = КоличествоПалет + Выб.КоличествоПалет;
		КоличествоПалетМоно = КоличествоПалетМоно + КолПалетМоно;
		КоличествоПалетСборных = КоличествоПалетСборных + КолПалетОстат;
	КонецЦикла;

	Данные.КоличествоУпаковок = КоличествоУпаковок;

	Данные.КоличествоПалет = КоличествоПалет;
	Данные.КоличествоПалетМоно = КоличествоПалетМоно;
	Данные.КоличествоПалетРасчет = КоличествоПалетРасчет;
	Данные.КоличествоПалетСборных = ?(КоличествоПалетСборных - Цел(КоличествоПалетСборных) > 0, Цел(
		КоличествоПалетСборных) + 1, Цел(КоличествоПалетСборных));

	Данные.Вес = (Вес + ?(СпособПередачиТоваров = 0, 20, 0) * Данные.КоличествоПалетСборных) / 1000;
	Данные.Объем = (Объем + ?(СпособПередачиТоваров = 0, 200, 0) * Данные.КоличествоПалетСборных) / 1000;

	Возврат Данные;
КонецФункции

Функция ПолучитьЗаказКлиента(Номер)
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номер", Номер);
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	т.Ссылка КАК ЗаказКлиента
	|ИЗ
	|	Документ.ЗаказКлиента КАК т
	|ГДЕ
	|	т.Номер = &Номер
	|	И т.Дата > ДОБАВИТЬКДАТЕ(&Дата, МЕСЯЦ, -1)";
	
	Рез = Запрос.Выполнить();
	
	Если Рез.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Выб = Рез.Выбрать(); Выб.Следующий();
		Возврат Выб.ЗаказКлиента;
	КонецЕсли;
КонецФункции

