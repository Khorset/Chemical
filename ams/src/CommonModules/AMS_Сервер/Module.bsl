		|	СУММА(КоррРасхождения.Количество) КАК Количество,
		|	СУММА(КоррРасхождения.Сумма) КАК Сумма,
		|	СУММА(КоррРасхождения.СуммаНДС) КАК СуммаНДС,
		|	СУММА(КоррРасхождения.СуммаСНДС) КАК СуммаСНДС,
		|	МАКСИМУМ(КоррРасхождения.НомерСтроки) КАК НомерСтроки,
		|	КоррРасхождения.Серия КАК Серия,
		|	КоррРасхождения.Серия.Наименование КАК СерияНаименование,
		|	КоррРасхождения.СтавкаНДС КАК СтавкаНДС,
		|	КоррРасхождения.НомерГТД.ТипНомераГТД КАК ТипНомераГТД,
		|	КоррРасхождения.Характеристика КАК Характеристика,
		|	КоррРасхождения.Характеристика.Наименование КАК ХарактеристикаНаименование,
		|	КоррРасхождения.НоменклатураНабора КАК НоменклатураНабора,
		|	КоррРасхождения.ХарактеристикаНабора КАК ХарактеристикаНабора
		|ПОМЕСТИТЬ Расх
		|ИЗ
		|	Документ.СчетФактураВыданный КАК СчетФактура
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации КАК Корр
		|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации.Расхождения КАК КоррРасхождения
		|			ПО Корр.Ссылка = КоррРасхождения.Ссылка
		|		ПО СчетФактура.ДокументОснование = Корр.Ссылка
		|ГДЕ
		|	СчетФактура.Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО
		|	КоррРасхождения.НоменклатураНабора,
		|	КоррРасхождения.Характеристика,
		|	СчетФактура.Ссылка,
		|	КоррРасхождения.СтавкаНДС,
		|	КоррРасхождения.ХарактеристикаНабора,
		|	КоррРасхождения.НомерГТД.ТипНомераГТД,
		|	КоррРасхождения.Серия,
		|	КоррРасхождения.Номенклатура,
		|	Корр.Ссылка,
		|	КоррРасхождения.Серия.Наименование,
		|	КоррРасхождения.Характеристика.Наименование
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КоррРасхождения.Ссылка КАК Ссылка,
		|	КоррРасхождения.Номенклатура КАК Номенклатура,
		|	ВЫБОР
		|		КОГДА КоррТовары.Количество ЕСТЬ NULL
		|			ТОГДА -КоррРасхождения.Количество
		|		ИНАЧЕ КоррТовары.Количество - КоррРасхождения.Количество
		|	КОНЕЦ КАК КоличествоДо,
		|	ЕСТЬNULL(КоррТовары.Количество, 0) КАК Количество,
		|	ВЫБОР
		|		КОГДА КоррТовары.Сумма ЕСТЬ NULL
		|			ТОГДА -КоррРасхождения.Сумма
		|		ИНАЧЕ КоррТовары.Сумма - КоррРасхождения.Сумма
		|	КОНЕЦ КАК СуммаБезНДСДо,
		|	ЕСТЬNULL(КоррТовары.Сумма, 0) КАК СуммаБезНДС,
		|	ВЫБОР
		|		КОГДА КоррТовары.СуммаНДС ЕСТЬ NULL
		|			ТОГДА -КоррРасхождения.СуммаНДС
		|		ИНАЧЕ КоррТовары.СуммаНДС - КоррРасхождения.СуммаНДС
		|	КОНЕЦ КАК СуммаНДСДо,
		|	ЕСТЬNULL(КоррТовары.СуммаНДС, 0) КАК СуммаНДС,
		|	ВЫБОР
		|		КОГДА КоррТовары.СуммаСНДС ЕСТЬ NULL
		|			ТОГДА -КоррРасхождения.СуммаСНДС
		|		ИНАЧЕ КоррТовары.СуммаСНДС - КоррРасхождения.СуммаСНДС
		|	КОНЕЦ КАК СуммаСНДСДо,
		|	ЕСТЬNULL(КоррТовары.СуммаСНДС, 0) КАК СуммаСНДС,
		|	КоррРасхождения.НомерСтроки КАК НомерСтроки,
		|	КоррТовары.НомерСтроки КАК НомерСтрокиИсходногоСФ,
		|	КоррРасхождения.Серия КАК Серия,
		|	КоррРасхождения.СерияНаименование КАК СерияНаименование,
		|	КоррРасхождения.СтавкаНДС КАК СтавкаНДС,
		|	КоррРасхождения.ТипНомераГТД КАК ТипНомераГТД,
		|	КоррРасхождения.Характеристика КАК Характеристика,
		|	КоррРасхождения.ХарактеристикаНаименование КАК ХарактеристикаНаименование,
		|	КоррРасхождения.НоменклатураНабора КАК НоменклатураНабора,
		|	КоррРасхождения.ХарактеристикаНабора КАК ХарактеристикаНабора
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	Расх КАК КоррРасхождения
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации.Товары КАК КоррТовары
		|		ПО КоррРасхождения.Корректировка = КоррТовары.Ссылка
		|		И КоррРасхождения.Номенклатура = КоррТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт.Ссылка КАК Ссылка,
		|	вт.Номенклатура КАК Номенклатура,
		|	ВЫБОР
		|		КОГДА вт.КоличествоДо = 0
		|			ТОГДА 0
		|		ИНАЧЕ вт.СуммаБезНДСДо / вт.КоличествоДо
		|	КОНЕЦ КАК ЦенаДо,
		|	ВЫБОР
		|		КОГДА вт.Количество = 0
		|			ТОГДА 0
		|		ИНАЧЕ вт.СуммаБезНДС / вт.Количество
		|	КОНЕЦ КАК Цена,
		|	вт.КоличествоДо КАК КоличествоДо,
		|	вт.КоличествоДо КАК КоличествоБазовыхЕдиницДо,
		|	вт.Количество КАК КоличествоБазовыхЕдиниц,
		|	вт.Количество КАК Количество,
		|	вт.СуммаБезНДСДо КАК СуммаБезНДСДо,
		|	вт.СуммаБезНДС КАК СуммаБезНДС,
		|	вт.СуммаНДСДо КАК СуммаНДСДо,
		|	вт.СуммаНДС КАК СуммаНДС,
		|	вт.СуммаСНДСДо КАК СуммаСНДСДо,
		|	вт.СуммаСНДС КАК СуммаСНДС,
		|	ВЫБОР
		|		КОГДА вт.СуммаБезНДСДо > вт.СуммаБезНДС
		|			ТОГДА 0
		|		ИНАЧЕ вт.СуммаБезНДС - вт.СуммаБезНДСДо
		|	КОНЕЦ КАК РазницаБезНДСУвеличение,
		|	ВЫБОР
		|		КОГДА вт.СуммаБезНДСДо > вт.СуммаБезНДС
		|			ТОГДА вт.СуммаБезНДСДо - вт.СуммаБезНДС
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК РазницаБезНДСУменьшение,
		|	ВЫБОР
		|		КОГДА вт.СуммаНДСДо > вт.СуммаНДС
		|			ТОГДА 0
		|		ИНАЧЕ вт.СуммаНДС - вт.СуммаНДСДо
		|	КОНЕЦ КАК РазницаНДСУвеличение,
		|	ВЫБОР
		|		КОГДА вт.СуммаНДСДо > вт.СуммаНДС
		|			ТОГДА вт.СуммаНДСДо - вт.СуммаНДС
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК РазницаНДСУменьшение,
		|	ВЫБОР
		|		КОГДА вт.СуммаСНДСДо > вт.СуммаСНДС
		|			ТОГДА 0
		|		ИНАЧЕ вт.СуммаСНДС - вт.СуммаСНДСДо
		|	КОНЕЦ КАК РазницаСНДСУвеличение,
		|	ВЫБОР
		|		КОГДА вт.СуммаСНДСДо > вт.СуммаСНДС
		|			ТОГДА вт.СуммаСНДСДо - вт.СуммаСНДС
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК РазницаСНДСУменьшение,
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыПредставленияНаборовВПечатныхФормах.ПустаяСсылка) КАК
		|		ВариантПредставленияНабораВПечатныхФормах,
		|	ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка) КАК ВариантРасчетаЦеныНабора,
		|	Ном.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	Ном.ЕдиницаИзмерения.Код КАК ЕдиницаИзмеренияКод,
		|	Ном.ЕдиницаИзмерения.Наименование КАК ЕдиницаИзмеренияНаименование,
		|	НЕОПРЕДЕЛЕНО КАК ЕдиницаИзмеренияТНВЭД,
		|	НЕОПРЕДЕЛЕНО КАК ЕдиницаИзмеренияТНВЭДКод,
		|	НЕОПРЕДЕЛЕНО КАК ЕдиницаИзмеренияТНВЭДНаименование,
		|	ЗНАЧЕНИЕ(Справочник.КлассификаторТНВЭД.ПустаяСсылка) КАК КодТНВЭД,
		|	0 КАК КоличествоПоРНПТДо,
		|	0 КАК КоличествоПоРНПТ,
		|	0 КАК КоличествоПрослежУвеличение,
		|	0 КАК КоличествоПрослежУменьшение,
		|	0 КАК МежценоваяРазницаДо,
		|	0 КАК МежценоваяРазница,
		|	Ном.Артикул КАК НоменклатураКод,
		|	вт.НоменклатураНабора КАК НоменклатураНабора,
		|	Ном.НаименованиеПолное КАК НоменклатураНаименование,
		|	ЗНАЧЕНИЕ(Справочник.НоменклатураКонтрагентов.ПустаяСсылка) КАК НоменклатураПартнера,
		|	НЕОПРЕДЕЛЕНО КАК НомерГТД,
		|	вт.НомерСтроки КАК НомерСтроки,
		|	вт.НомерСтрокиИсходногоСФ КАК НомерСтрокиИсходногоСФ,
		|	вт.НомерСтроки КАК НомерСтрокиНаборы,
		|	ЛОЖЬ КАК ПолныйНабор,
		|	вт.Серия КАК Серия,
		|	вт.СерияНаименование КАК СерияНаименование,
		|	вт.СтавкаНДС КАК СтавкаНДС,
		|	Ном.СтранаПроисхождения КАК СтранаПроисхождения,
		|	Ном.СтранаПроисхождения.Код КАК СтранаПроисхожденияКод,
		|	вт.ТипНомераГТД КАК ТипНомераГТД,
		|	вт.Характеристика КАК Характеристика,
		|	вт.ХарактеристикаНабора КАК ХарактеристикаНабора,
