Функция ЕстьРеализацияЗаказа(AMS_ЗаказКлиентаНомер, Отказ)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("AMS_ЗаказКлиентаНомер", AMS_ЗаказКлиентаНомер);
	Запрос.УстановитьПараметр("AMS_СтатусРеализации", Перечисления.AMS_СтатусыРеализаций.КОтгрузке);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Дата КАК Дата,
	|	т.Номер КАК Номер
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК т
	|ГДЕ
	|	т.AMS_ЗаказКлиентаНомер = &AMS_ЗаказКлиентаНомер
	|	И НЕ т.ПометкаУдаления
	|	И т.AMS_СтатусРеализации = &AMS_СтатусРеализации";

	Рез = Запрос.Выполнить();
	
	Если Рез.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Выб = Рез.Выбрать();
		Пока Выб.Следующий() Цикл
			Текст = НСтр("ru='На основании данного заказа уже создан документ реализации № %1 от %2 г.'");
			Текст = СтрШаблон(Текст, Выб.Номер, Формат(Выб.Дата, "ДЛФ=Д"));
			ОбщегоНазначения.СообщитьПользователю(Текст, , , , Отказ);
		КонецЦикла;
		
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция ЕстьЦеныНеПоУсловиямПродаж(Источник)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Источник.Товары.Выгрузить(, "Номенклатура, ВидЦены, СуммаРучнойСкидки, СуммаАвтоматическойСкидки"));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.ВидЦены КАК ВидЦены,
	|	т.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
	|	т.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Товары КАК т
	|ГДЕ
	|	(т.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|			ИЛИ т.СуммаРучнойСкидки > 0
	|			ИЛИ т.СуммаАвтоматическойСкидки > 0)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	вт.ВидЦены КАК ВидЦены,
	|	вт.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
	|	вт.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки
	|ИЗ
	|	вт КАК вт";

	Возврат Не Запрос.Выполнить().Пустой();
КонецФункции

