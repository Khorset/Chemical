#Область ПередЗаписьюНаСервереИзФормыДокумента

Процедура ПередЗаписьюНаСервереРасходныйОрдерНаТовары(Отказ, Форма, ТекущийОбъект, ПараметрыЗаписи) Экспорт
    // Если указано более одного Распоряжения, то запретить запись 
	ТоварыПоРаспоряжениям = ТекущийОбъект.ТоварыПоРаспоряжениям.Выгрузить( , "Распоряжение");
	ТоварыПоРаспоряжениям.Свернуть("Распоряжение");
	Если ТоварыПоРаспоряжениям.Количество() > 1 Тогда
		ТекстОшибки = НСтр("ru='Расходный ордер на товары может быть оформлен только одно Распоряжение.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
	КонецЕсли;

	Распоряжение = ТоварыПоРаспоряжениям[0].Распоряжение;
    
    // Если уже оформлен Ордер по укажанному Распоряжению, то запретить запись 
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);
	Запрос.УстановитьПараметр("Ссылка", ТекущийОбъект.Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК т
	|ГДЕ
	|	т.Распоряжение = &Распоряжение
	|	И НЕ т.Ссылка = &Ссылка
	|	И НЕ т.Ссылка.ПометкаУдаления";
	Если Не Запрос.Выполнить().Пустой() Тогда
		ТекстОшибки = НСтр("ru='Расходный ордер уже оформлен на данное Распоряжение.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
	КонецЕсли;
    
    // Если Товары в Расходном ордере не равны товарам, указанным в Распоряжении, то запретить запись
	Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
		И ЕстиРазличияМеждуРеализациейИОрдером(ПолучитьТоварыРаспоряжения(Распоряжение),
			ТекущийОбъект.ОтгружаемыеТовары.Выгрузить(, "Номенклатура,Количество")) Тогда
		ТекстОшибки = НСтр("ru='Товары в Расходном ордере не равны товарам, указанным в Распоряжении.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
	КонецЕсли;
    
    // Если Дата отгрузки не соответствует дате отгрузки в распоряжении, то запретить запись
	Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
		Или ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			
		Табл = ТекущийОбъект.ТоварыПоРаспоряжениям.Выгрузить(, "Распоряжение");
		Табл.Свернуть("Распоряжение");

		Для Каждого Стр Из Табл Цикл
			Док = Стр.Распоряжение;

			Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
				//@skip-check bsl-legacy-check-string-literal
				ДатаОтгрузки = НачалоДня(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "Дата"));
			
			ИначеЕсли ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
				//@skip-check bsl-legacy-check-string-literal
				ДатаОтгрузки = НачалоДня(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "ДатаОтгрузки"));
			КонецЕсли;	

			Если ДатаОтгрузки > НачалоДня(ТекущийОбъект.ДатаОтгрузки) Тогда
				ТекстОшибки = НСтр("ru='Дата отгрузки не соответствует дате отгрузки в распоряжении.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
			КонецЕсли;
		КонецЦикла;

		Если ТекущийОбъект.Статус = Перечисления.СтатусыРасходныхОрдеров.Отгружен Тогда
			//Есть ли отгрузка с Основного склада
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("ТоварыПоРаспоряжениям", ТекущийОбъект.ТоварыПоРаспоряжениям.Выгрузить( ,
				"Номенклатура,Количество"));
			Запрос.УстановитьПараметр("Товары", ТекущийОбъект._Товары.Выгрузить( , "Номенклатура,Количество"));
			Запрос.Текст =
			"ВЫБРАТЬ
			|	т.Номенклатура КАК Номенклатура,
			|	т.Количество КАК Количество
			|ПОМЕСТИТЬ ТоварыПоРаспоряжениям
			|ИЗ
			|	&ТоварыПоРаспоряжениям КАК т
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	т.Номенклатура КАК Номенклатура,
			|	т.Количество КАК Количество
			|ПОМЕСТИТЬ ТоварыВерхние
			|ИЗ
			|	&Товары КАК т
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТоварыПоРаспоряжениям.Номенклатура КАК Номенклатура,
			|	СУММА(ТоварыПоРаспоряжениям.Количество) КАК Количество
			|ПОМЕСТИТЬ вт1
			|ИЗ
			|	ТоварыПоРаспоряжениям КАК ТоварыПоРаспоряжениям
			|
			|СГРУППИРОВАТЬ ПО
			|	ТоварыПоРаспоряжениям.Номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТоварыВерхние.Номенклатура КАК Номенклатура,
			|	СУММА(ТоварыВерхние.Количество) КАК Количество
			|ПОМЕСТИТЬ вт2
			|ИЗ
			|	ТоварыВерхние КАК ТоварыВерхние
			|
			|СГРУППИРОВАТЬ ПО
			|	ТоварыВерхние.Номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	вт1.Номенклатура КАК Номенклатура,
			|	вт1.Количество - ЕСТЬNULL(вт2.Количество, 0) * Ном.КоэффициентЕдиницыДляОтчетов КАК Количество
			|ПОМЕСТИТЬ вт
			|ИЗ
			|	вт1 КАК вт1
			|		ЛЕВОЕ СОЕДИНЕНИЕ вт2 КАК вт2
			|		ПО вт1.Номенклатура = вт2.Номенклатура
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
			|		ПО вт1.Номенклатура = Ном.Ссылка
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	вт.Номенклатура КАК Номенклатура,
			|	вт.Количество КАК Количество
			|ИЗ
			|	вт КАК вт
			|ГДЕ
			|	вт.Количество > 0";
			Рез = Запрос.Выполнить();

			ЕстьОтгрузкаНаОсновомСкладе = Не Рез.Пустой();
			ЕстьОтгрузкаНаВерхнемСкладе = ТекущийОбъект._Товары.Количество() > 0;

			РаботыНаОсновномСкладе = ТекущийОбъект._Работы.НайтиСтроки(Новый Структура("МестоПогрузки",
				ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._МестаПогрузки.Основной")));
			ЕстьРаботыНаОсновомСкладе = РаботыНаОсновномСкладе.Количество() > 0;

			РаботыНаВерхнемСкладе = ТекущийОбъект._Работы.НайтиСтроки(Новый Структура("МестоПогрузки",
				ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._МестаПогрузки.Верхний")));
			ЕстьРаботыНаВерхнемСкладе = РаботыНаВерхнемСкладе.Количество() > 0;
			
			// Если есть отгрузка с Основного склада, то должна быть и работы Основного склада
			Если ЕстьОтгрузкаНаОсновомСкладе И Не ЕстьРаботыНаОсновомСкладе Тогда
				ОбщегоНазначения.СообщитьПользователю(НСтр("ru='Не указаны Работы на Основном складе.'"),
					ТекущийОбъект.Ссылка, ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Объект._Работы", 0,
					"Номенклатура"), , Отказ);
			КонецЕсли;
			
			// Если есть работы на верхнем складе, то должны быть и товары на верхнем складе
			Если ЕстьОтгрузкаНаВерхнемСкладе И Не ЕстьРаботыНаВерхнемСкладе Тогда
				ОбщегоНазначения.СообщитьПользователю(НСтр("ru='Не указаны Работы на Верхнем складе.'"),
					ТекущийОбъект.Ссылка, ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Объект._Работы", 0,
					"Номенклатура"), , Отказ);
			КонецЕсли;
		
			// Если есть отгрузка с Верхнего склада, то должна быть и работа Кладовщика Верхнего склада - Справочники._Работы.СкладКладовщикВерхний
			Если ЕстьРаботыНаОсновомСкладе И Не ЕстьОтгрузкаНаОсновомСкладе Тогда
				ОбщегоНазначения.СообщитьПользователю(НСтр(
					"ru='Работы на Основном складе есть, а отгруженных там товаров нет.'"), ТекущийОбъект.Ссылка,
					ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Объект._Товары", 0, "Номенклатура"), , Отказ);
			КонецЕсли;
			
			// Если есть отгрузка с Верхнего склада, то должна быть и работа Кладовщика Верхнего склада - Справочники._Работы.СкладКладовщикВерхний
			Если ЕстьРаботыНаВерхнемСкладе И Не ЕстьОтгрузкаНаВерхнемСкладе Тогда
				ОбщегоНазначения.СообщитьПользователю(НСтр(
					"ru='Работы на Верхнем складе есть, а отгруженных там товаров нет.'"), ТекущийОбъект.Ссылка,
					ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Объект._Товары", 0, "Номенклатура"), , Отказ);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ЕстиРазличияМеждуРеализациейИОрдером(ТоварыРеал, ТоварыОрдер)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", ТоварыРеал);
	Запрос.УстановитьПараметр("ОтгружаемыеТовары", ТоварыОрдер);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ Ордер1
	|ИЗ
	|	&ОтгружаемыеТовары КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ордер1.Номенклатура КАК Номенклатура,
	|	СУММА(Ордер1.Количество) КАК Количество
	|ПОМЕСТИТЬ Ордер
	|ИЗ
	|	Ордер1 КАК Ордер1
	|
	|СГРУППИРОВАТЬ ПО
	|	Ордер1.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ Реал1
	|ИЗ
	|	&Товары КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Реал1.Номенклатура КАК Номенклатура,
	|	СУММА(Реал1.Количество) КАК Количество
	|ПОМЕСТИТЬ Реал
	|ИЗ
	|	Реал1 КАК Реал1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|		ПО Реал1.Номенклатура = ном.Ссылка
	|			И (ном.ТипНоменклатуры В (ЗНАЧЕНИЕ(перечисление.ТипыНоменклатуры.Товар),ЗНАЧЕНИЕ(перечисление.ТипыНоменклатуры.МногооборотнаяТара)))
	|
	|СГРУППИРОВАТЬ ПО
	|	Реал1.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Ордер.Номенклатура ЕСТЬ NULL
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Номенклатура.Пустаяссылка)
	|		ИНАЧЕ Ордер.Номенклатура
	|	КОНЕЦ КАК НоменклатураОрдер,
	|	ЕСТЬNULL(Ордер.Количество, 0) КАК КоличествоОрдер,
	|	ВЫБОР
	|		КОГДА Реал.Номенклатура ЕСТЬ NULL
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Номенклатура.Пустаяссылка)
	|		ИНАЧЕ Реал.Номенклатура
	|	КОНЕЦ КАК НоменклатураРеал,
	|	ЕСТЬNULL(Реал.Количество, 0) КАК КоличествоРеал
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Ордер КАК Ордер
	|		ПОЛНОЕ СОЕДИНЕНИЕ Реал КАК Реал
	|		ПО Ордер.Номенклатура = Реал.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.НоменклатураОрдер КАК НоменклатураОрдер,
	|	вт.КоличествоОрдер КАК КоличествоОрдер,
	|	вт.НоменклатураРеал КАК НоменклатураРеал,
	|	вт.КоличествоРеал КАК КоличествоРеал
	|ИЗ
	|	вт КАК вт
	|ГДЕ
	|	(вт.НоменклатураОрдер <> вт.НоменклатураРеал
	|			ИЛИ вт.КоличествоОрдер <> вт.КоличествоРеал)";

	Возврат Не Запрос.Выполнить().Пустой();
КонецФункции

Функция ПолучитьТоварыРаспоряжения(Док)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Док", Док);

	Если ТипЗнч(Док) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Номенклатура,
		|	СУММА(т.Количество) КАК Количество
		|ИЗ
		|	Документ.ЗаказКлиента.Товары КАК т
		|ГДЕ
		|	т.Ссылка = &Док
		|СГРУППИРОВАТЬ ПО
		|	т.Номенклатура";

	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Номенклатура,
		|	СУММА(т.Количество) КАК Количество
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК т
		|ГДЕ
		|	т.Ссылка = &Док
		|СГРУППИРОВАТЬ ПО
		|	т.Номенклатура";
	КонецЕсли;

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

#КонецОбласти

#Область Производство

Функция ПолучитьДокументыПроизводстваПродукции(Основание) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Основание", Основание);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т._ОперацияПроизводства КАК ОперацияПроизводства,
	|	т.Дата КАК Дата,
	|	т.Номер КАК Номер,
	|	NULL КАК Статус,
	|	т.Ответственный КАК Ответственный,
	|	т.Ссылка КАК Ссылка,
	|	т._ОперацияПроизводства.Порядок КАК Порядок,
	|	т.ПометкаУдаления КАК ПометкаУдаления,
	|	т.Проведен КАК Проведен,
	|	т.СкладПолучатель КАК Склад
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК т
	|ГДЕ
	|	т._Основание = &Основание
	|	И т._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПеремещениеМатериаловВПроизводство)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т._ОперацияПроизводства,
	|	т.Дата,
	|	т.Номер,
	|	NULL,
	|	т.Ответственный,
	|	т.Ссылка,
	|	т._ОперацияПроизводства.Порядок,
	|	т.ПометкаУдаления,
	|	т.Проведен,
	|	т.Склад
	|ИЗ
	|	Документ.ПрочееОприходованиеТоваров КАК т
	|ГДЕ
	|	т._Основание = &Основание
	|	И т._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПроизводствоФабрикатов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т._ОперацияПроизводства,
	|	т.Дата,
	|	т.Номер,
	|	NULL,
	|	т.Ответственный,
	|	т.Ссылка,
	|	т._ОперацияПроизводства.Порядок,
	|	т.ПометкаУдаления,
	|	т.Проведен,
	|	т.Склад
	|ИЗ
	|	Документ.ПрочееОприходованиеТоваров КАК т
	|ГДЕ
	|	т._Основание = &Основание
	|	И т._ОперацияПроизводства В (ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПроизводствоПродукции),
	|		ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПроизводствоФлаконов))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т._ОперацияПроизводства,
	|	т.Дата,
	|	т.Номер,
	|	т.Статус,
	|	т.Ответственный,
	|	т.Ссылка,
	|	т._ОперацияПроизводства.Порядок,
	|	т.ПометкаУдаления,
	|	т.Проведен,
	|	т.Склад
	|ИЗ
	|	Документ.ВнутреннееПотребление КАК т
	|ГДЕ
	|	т._Основание = &Основание
	|	И т._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.СписаниеМатериаловСПроизводства)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т._ОперацияПроизводства,
	|	т.Дата,
	|	т.Номер,
	|	т.Статус,
	|	т.Ответственный,
	|	т.Ссылка,
	|	т._ОперацияПроизводства.Порядок,
	|	т.ПометкаУдаления,
	|	т.Проведен,
	|	т.Склад
	|ИЗ
	|	Документ.ВнутреннееПотребление КАК т
	|ГДЕ
	|	т._Основание = &Основание
	|	И т._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.СписаниеФабрикатаСПроизводства)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т._ОперацияПроизводства,
	|	т.Дата,
	|	т.Номер,
	|	т.Статус,
	|	т.Ответственный,
	|	т.Ссылка,
	|	т._ОперацияПроизводства.Порядок,
	|	т.ПометкаУдаления,
	|	т.Проведен,
	|	т.СкладПолучатель
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК т
	|ГДЕ
	|	т._Основание = &Основание
