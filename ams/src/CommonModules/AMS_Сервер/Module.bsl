
#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗагрузитьЗаказыВОжиданииРегламентноеЗадание(ТокенАвторизации = Неопределено) Экспорт
	Если ТокенАвторизации = Неопределено Тогда
		ТокенАвторизации = ПолучитьТокенАвторизации(Константы.AMS_В2В_МенеджерЗагрузкиЗаказов.Получить());
	КонецЕсли;  

	ЗагрузитьНовыеЗаказыВ2В(ТокенАвторизации);
КонецПроцедуры

Процедура СинхронизироватьОстаткиВ2В() Экспорт
	ТокенАвторизации = ПолучитьТокенАвторизации(Константы.AMS_В2В_МенеджерЗагрузкиЗаказов.Получить());
	
	ОстаткиНаСкладеАМС = ПолучитьОстаткиНаСкладеАМС();

	МассивДанных = Новый Массив;
	Для каждого Стр Из ОстаткиНаСкладеАМС Цикл
		МассивСтрока = Новый Массив;
		МассивСтрока.Добавить(Стр.SKU);
		МассивСтрока.Добавить(Формат(Стр.count, "ЧН=; ЧГ="));
		
		МассивДанных.Добавить(МассивСтрока);
	КонецЦикла;
	
	ОбъектТела = Новый Соответствие;
	ОбъектТела.Вставить("store", Константы.AMS_В2В_Склад.Получить());
	ОбъектТела.Вставить("items", МассивДанных);

	Послание = СоответствиеВJSON(ОбъектТела);
	
	HTTPСоединение = Новый HTTPСоединение("b2b.cafe",,,,, ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1.4.9/store/update_balance_product");
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("Accept-Language", "ru");
	
	HTTPЗапрос.УстановитьТелоИзСтроки(Послание);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		//@skip-check module-unused-local-variable
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
	Иначе
		ЗаписьЖурналаРегистрации("ВыгрузитьОстаткиНаСкладВ2В.Ошибка", УровеньЖурналаРегистрации.Ошибка);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПодпискиНаСобытияДокументов

#Область ОбработкаЗаполнения

Процедура ОбработкаЗаполненияДокументов(Источник, ДанныеЗаполнения, СтандартнаяОбработка) Экспорт
	ИмяДок = Источник.Метаданные().Имя;

	Если ИмяДок = "АктВыполненныхРабот" Тогда
		Источник.Организация = AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию();

	ИначеЕсли ИмяДок = "ЗаказПоставщику" Тогда
		Источник.Статус                       = Перечисления.СтатусыЗаказовПоставщикам.НеСогласован;
		Источник.Приоритет                    = Справочники.Приоритеты.НайтиПоНаименованию("Низкий", Истина);
		Источник.Организация                  = AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию();
		Источник.РегистрироватьЦеныПоставщика = Истина;
		Источник.Склад                        = AMS_ВызовСервера.ПолучитьСвойСклад();
		Источник.ПоступлениеОднойДатой        = Истина;

	ИначеЕсли ИмяДок = "ЗаявкаНаВозвратТоваровОтКлиента" Тогда
		Источник.СпособДоставки = Перечисления.СпособыДоставки.ДоКлиента;
			
	ИначеЕсли ИмяДок = "КорректировкаРеализации" Тогда
		ОбработкаЗаполненияКорректировкаРеализации(Источник);

	ИначеЕсли ИмяДок = "ОприходованиеИзлишковТоваров" Тогда
		Источник.АналитикаДоходов = Неопределено;
		
	ИначеЕсли ИмяДок = "ОтгрузкаТоваровКлиенту" Тогда

	ИначеЕсли ИмяДок = "ОтчетОСписанииТоваровУХранителя" Тогда
		Источник.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СписаниеНедостачЗаСчетКомитента;

	ИначеЕсли ИмяДок = "ПередачаТоваровХранителю" Тогда
		Источник.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПередачаНаКомиссию;
	
	ИначеЕсли ИмяДок = "ПеремещениеТоваров" Тогда
		ОбработкаЗаполненияПеремещениеТоваров(Источник, ДанныеЗаполнения);

	ИначеЕсли ИмяДок = "ПоступлениеТоваровОтХранителя" Тогда
		Источник.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОтКомиссионера;
    
	ИначеЕсли ИмяДок = "ПриобретениеТоваровУслуг" Тогда
		ОбработкаЗаполненияПриобретениеТоваровУслуг(Источник, ДанныеЗаполнения);

	ИначеЕсли ИмяДок = "РеализацияТоваровУслуг" Тогда
		ОбработкаЗаполненияРеализацияТоваровУслуг(Источник, ДанныеЗаполнения);

	ИначеЕсли ИмяДок = "СписаниеНедостачТоваров" Тогда
		Источник.АналитикаРасходов = Неопределено;

	ИначеЕсли ИмяДок = "СчетФактураВыданный" Тогда
		ОбработкаЗаполненияСчетФактураВыданный(Источник);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполненияКорректировкаРеализации(Источник)
	СтатьяДоходовПрочиеДоходы   = ПланыВидовХарактеристик.СтатьиДоходов.НайтиПоКоду("01-000001");
	СтатьяРасходовПрочиеРасходы = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("01-000022");

	Источник.ВидКорректировки = Перечисления.ХозяйственныеОперации.КорректировкаПоСогласованиюСторон;

	СтатьяДоходов  = Ложь;
	СтатьяРасходов = Ложь;

	Для Каждого Стр Из Источник.Расхождения Цикл
		Если Стр.Количество > 0 Тогда
			СтатьяДоходов = Истина;
		ИначеЕсли Стр.Количество < 0 Тогда
			СтатьяРасходов = Истина;
		КонецЕсли;
	КонецЦикла;

	Источник.СтатьяДоходов  = ?(СтатьяДоходов, СтатьяДоходовПрочиеДоходы, Источник.СтатьяДоходов);
	Источник.СтатьяРасходов = ?(СтатьяРасходов, СтатьяРасходовПрочиеРасходы, Источник.СтатьяРасходов);
КонецПроцедуры

Процедура ОбработкаЗаполненияПеремещениеТоваров(Источник, ДанныеЗаполнения)
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);

	Если ТипДанныхЗаполнения = Тип("Структура") Тогда
		Если ДанныеЗаполнения.Свойство("_Основание")
			И ТипЗнч(ДанныеЗаполнения._Основание) = Тип("ДокументСсылка.AMS_ПроизводствоЗаСмену") Тогда

			ЗаполнитьЗначенияСвойств(Источник, ДанныеЗаполнения);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполненияПриобретениеТоваровУслуг(Источник, ДанныеЗаполнения)
	Если Источник.Организация = AMS_ВызовСервера.ОрганизацияТД() И ЗначениеЗаполнено(Источник.Партнер) Тогда
		КодПартнера = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Партнер, "Код");
		Если КодПартнера = "01-01001303" Тогда
			ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(Источник);
		КонецЕсли;
	
	Иначе
		Источник.Организация                  = AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию();
		Источник.РегистрироватьЦеныПоставщика = Истина;
		Источник.Склад                        = AMS_ВызовСервера.ПолучитьСвойСклад();
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполненияРеализацияТоваровУслуг(Источник, ДанныеЗаполнения)
	Если Источник.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПереходПраваСобственности Тогда
		Возврат;
	КонецЕсли;
	
	Источник.Статус = Перечисления.СтатусыРеализацийТоваровУслуг.Отгружено;
	
	Если ДанныеЗаполнения = Неопределено Тогда
		Источник.Организация = AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию();

	ИначеЕсли Источник.РеализацияПоЗаказам  И ТипЗнч(Источник.ЗаказКлиента) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		ЗаказКлиента = Источник.ЗаказКлиента;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	т.ДатаОтгрузки КАК Дата,
		|	ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке) КАК AMS_СтатусРеализации,
		|	т.AMS_ID КАК AMS_ID,
		|	т.AMS_Вес КАК AMS_Вес,
		|	т.AMS_ВесПлан КАК AMS_ВесПлан,
		|	т.AMS_Объем КАК AMS_Объем,
		|	т.AMS_ДатаОтгрузки КАК AMS_ДатаОтгрузки,
		|	т.AMS_ДатаСчета КАК AMS_ДатаСчета,
		|	т.AMS_КоличествоПалет КАК AMS_КоличествоПалет,
		|	т.AMS_КоличествоПалетПлан КАК AMS_КоличествоПалетПлан,
		|	т.AMS_КоличествоПалетРасчет КАК AMS_КоличествоПалетРасчет,
		|	т.AMS_КоличествоПалетСборных КАК AMS_КоличествоПалетСборных,
		|	т.AMS_КоличествоУпаковок КАК AMS_КоличествоУпаковок,
		|	т.AMS_Обрешетка КАК AMS_Обрешетка,
		|	т.AMS_Основание КАК Основание,
		|	т.AMS_ОснованиеНомер КАК ОснованиеНомер,
		|	т.AMS_ОснованиеДата КАК ОснованиеДата,
		|	т.AMS_ПравилоПродажи КАК AMS_ПравилоПродажи,
		|	т.AMS_СпособПередачиТоваров КАК AMS_СпособПередачиТоваров,
		|	т.AMS_ДоверенностьКлиента КАК AMS_ДоверенностьКлиента,
		|	т.AMS_УсловияОтгрузки КАК AMS_УсловияОтгрузки,
		|	т.AMS_ВидТранспортаПеревозчика КАК AMS_ВидТранспортаПеревозчика,
		|	т.AMS_НомерЗаявкиПеревозчика КАК AMS_НомерЗаявкиПеревозчика,
		|	т.AMS_ТелефонВодителяКлиента КАК AMS_ТелефонВодителяКлиента,
		|	т.AMS_ТранспортКлиента КАК AMS_ТранспортКлиента,
		|	т.Номер КАК AMS_ЗаказКлиентаНомер,
		|	т.АдресДоставки КАК АдресДоставки,
		|	т.ЗонаДоставки КАК ЗонаДоставки,
		|	т.Грузополучатель КАК Грузополучатель,
		|	т.БанковскийСчетГрузополучателя КАК БанковскийСчетГрузополучателя,
		|	т.ПорядокРасчетов КАК ПорядокРасчетов,
		|	т.ПеревозчикПартнер КАК ПеревозчикПартнер,
		|	т.СпособДоставки КАК СпособДоставки,
		|	т.ВремяДоставкиС КАК ВремяДоставкиС,
		|	т.ВремяДоставкиПо КАК ВремяДоставкиПо,
		|	т.АдресДоставкиПеревозчика КАК АдресДоставкиПеревозчика,
		|	т.ДополнительнаяИнформацияПоДоставке КАК ДополнительнаяИнформацияПоДоставке,
		|	т.КонтактноеЛицо КАК КонтактноеЛицо,
		|	т.ОсобыеУсловияПеревозки КАК ОсобыеУсловияПеревозки,
		|	т.ОсобыеУсловияПеревозкиОписание КАК ОсобыеУсловияПеревозкиОписание,
		|	т.Комментарий КАК Комментарий
		|ИЗ
		|	Документ.ЗаказКлиента КАК т
		|ГДЕ
		|	т.Ссылка = &ЗаказКлиента";
		
		Рез = Запрос.Выполнить();
		Выб = Рез.Выбрать();
		Выб.Следующий();
		
		ЗаполнитьЗначенияСвойств(Источник, Выб);
		
		Источник.Дата = Источник.Дата + (ТекущаяДатаСеанса() - НачалоДня(ТекущаяДатаСеанса()));
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполненияСчетФактураВыданный(Источник)
	ДокументОснование = Источник.ДокументОснование;

	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		ДокументОснование = Источник.ДокументыОснования[0].ДокументОснование;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		Возврат;
	КонецЕсли;

	Номер       = ДокументОснование.Номер;
	НомерСлева  = Лев(Номер, 5);
	НомерСправа = Прав(Номер, 5);

	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Или ТипЗнч(ДокументОснование) = Тип(
		"ДокументСсылка.РеализацияУслугПрочихАктивов") Тогда

		Источник.Номер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснование, "Номер");

	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
		Источник.Номер = НомерСлева + 1 + НомерСправа;

	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда
		Источник.Номер = НомерСлева + 2 + НомерСправа;

	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ВозвратТоваровМеждуОрганизациями") Тогда
		Источник.Номер = НомерСлева + 4 + НомерСправа;

	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаписьКнигиПродаж") Тогда
		Источник.Номер = НомерСлева + 5 + НомерСправа;
	КонецЕсли;

	ДатаОснования = Источник.ДокументыОснования[0].ДокументОснование.Дата;

	Если ДатаОснования <> Дата(1, 1, 1) Тогда
		Источник.Дата            = ДатаОснования + 1;
		Источник.ДатаВыставления = ДатаОснования;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработкаПроверкиЗаполнения

Процедура ОбработкаПроверкиЗаполненияДокументов(Источник, Отказ, ПроверяемыеРеквизиты) Экспорт
	ИмяДок = Источник.Метаданные().Имя;

	Если ИмяДок = "ЗаказКлиента" Или ИмяДок = "ОтгрузкаТоваровКлиенту" Или ИмяДок = "РеализацияТоваровУслуг" Тогда
		ОбработкаПроверкиЗаполненияЗаказКлиентаОтгрузкаТоваровКлиентуРеализацияТоваровУслуг(Источник, Отказ);
		
		Если (ИмяДок = "ЗаказКлиента" И Не Источник.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПередачаНаКомиссию)
			Или (ИмяДок = "РеализацияТоваровУслуг" 
				И (Источник.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.Заказ
					Или Источник.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.Стикерование
					Или Источник.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.КОтгрузке)) Тогда
			
			ПроверяемыеРеквизиты.Добавить("AMS_ПравилоПродажи");
		КонецЕсли;
				
	ИначеЕсли ИмяДок = "КорректировкаРеализации" Тогда
		ОбработкаПроверкиЗаполнения_КорректировкаРеализации(Источник, Отказ);

	ИначеЕсли ИмяДок = "ПриобретениеТоваровУслуг" Тогда
		ОбработкаПроверкиЗаполнения_ПриобретениеТоваровУслуг(Источник, Отказ);

	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполненияЗаказКлиентаОтгрузкаТоваровКлиентуРеализацияТоваровУслуг(Источник, Отказ)
	Если Пользователи.РолиДоступны("_Бухгалтер") Тогда
		Возврат;
	КонецЕсли;
	
	ТранспортУслугиПоступление = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор("d573ef93-9e57-11ed-8e1a-a4bf015601f8"));
	ТранспортУслугиРеализация  = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор("5e448643-bf70-11dc-b366-0013d41f76d0"));

	Товары = Источник.Товары;
	Для ТекИндекс = 0 По Товары.Количество() - 1 Цикл
		Стр = Товары[ТекИндекс];

		Если Стр.Номенклатура = ТранспортУслугиПоступление Тогда
			Стр.Номенклатура = ТранспортУслугиРеализация;
		КонецЕсли;
	КонецЦикла;
	
	Если Не Источник.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз И Источник.AMS_КоличествоПалет = 0 Тогда
		ТекстОшибки = НСтр("ru='Не заполнено поле ""Количество палет""'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,, "Объект.AMS_КоличествоПалет",, Отказ);
	КонецЕсли;

	Стр = ПолучитьВесОбъемТоваров(Источник.Товары.Выгрузить(, "Номенклатура,Количество"));

	КоличествоПалетМинимум = Стр.КоличествоПалетМоно + Стр.КоличествоПалетСборных;

	Если Стр.КоличествоПалетРасчет - Цел(Стр.КоличествоПалетРасчет) < 0.1 Тогда
		Если Источник.AMS_КоличествоПалет < КоличествоПалетМинимум - 1 Тогда
			ТекстОшибки = "Количество палет не может быть меньше " + КоличествоПалетМинимум + " шт.";
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, Источник.Ссылка, "Объект.AMS_КоличествоПалет",, Отказ);
		КонецЕсли;
	Иначе
		Если Источник.AMS_КоличествоПалет < КоличествоПалетМинимум Тогда
			ТекстОшибки = "Количество палет не может быть меньше " + КоличествоПалетМинимум + " шт.";
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, Источник.Ссылка, "Объект.AMS_КоличествоПалет",, Отказ);
		КонецЕсли;
	КонецЕсли;

	Если Источник.AMS_КоличествоПалетСборных > Источник.AMS_КоличествоПалет Тогда
		ТекстОшибки = "Количество палет сборных не может быть больше общего количества палет.";
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, Источник.Ссылка, "Объект.AMS_КоличествоПалетСборных",, Отказ);
	КонецЕсли;

	Если AMS_ВызовСервера.ЭтоKhors() Или Не Источник.Склад = AMS_ВызовСервера.СкладПродукции() Тогда
		Возврат;
	КонецЕсли;

	Если Источник.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз Тогда
		Если Источник.AMS_ДоверенностьКлиента = 0 Тогда
			ТекстОшибки = "Не заполнено поле ""Доверенность клиента""";
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,,, Отказ);
		КонецЕсли;

	Иначе
		Если Не ЗначениеЗаполнено(Источник.ЗонаДоставки) Тогда
			ТекстОшибки = "Не заполнено поле ""Зона доставки""";
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,,, Отказ);
		КонецЕсли;

		Если Источник.ВремяДоставкиС = Дата(1, 1, 1) Тогда
			ТекстОшибки = "Не заполнено поле ""Желаемое время доставки с""";
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,,, Отказ);
		КонецЕсли;

		Если Источник.ВремяДоставкиПо = Дата(1, 1, 1) Тогда
			ТекстОшибки = "Не заполнено поле ""Желаемое время доставки по""";
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,,, Отказ);
		КонецЕсли;

		Если Источник.СпособДоставки = Перечисления.СпособыДоставки.КПолучателюОпределяетСлужбаДоставки Тогда
			Если ПустаяСтрока(Источник.AMS_ТранспортКлиента) Тогда
				ТекстОшибки = "Не указан транспорт клиента.";
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,,, Отказ);
			КонецЕсли;
			Если Источник.AMS_ДоверенностьКлиента = 0 Тогда
				ТекстОшибки = "Не указана доверенность клиента.";
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,,, Отказ);
			КонецЕсли;
			Если ПустаяСтрока(Источник.AMS_ТранспортКлиента) Тогда
				ТекстОшибки = "Не указан телефон водителя клиента.";
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,,, Отказ);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения_КорректировкаРеализации(Источник, Отказ)
	//@skip-check bsl-legacy-check-string-literal
	Менеджер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.ДокументОснование, "Менеджер");

	Если Не Источник.Менеджер = Менеджер Тогда
		Источник.Менеджер = Менеджер;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Склад", Источник.Склад);
	Запрос.УстановитьПараметр("Расхождения", Источник.Расхождения.Выгрузить( ,
		"Номенклатура,Количество,ВариантОтражения"));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	&Расхождения КАК т
	|ГДЕ
	|	т.ВариантОтражения = ЗНАЧЕНИЕ(Перечисление.ВариантыОтраженияКорректировокРеализаций.УвеличитьРеализациюУменьшитьСкладскиеОстатки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.ВНаличииОстаток КАК Остаток
	|ПОМЕСТИТЬ Остатки
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(
	|			,
	|			Склад = &Склад
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						т.Номенклатура КАК Номенклатура
	|					ИЗ
	|						Товары КАК т)) КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Количество КАК Количество,
	|	ЕСТЬNULL(Остатки.Остаток, 0) КАК Остаток
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Остатки КАК Остатки
	|		ПО Товары.Номенклатура = Остатки.Номенклатура
	|ГДЕ
	|	Товары.Количество > ЕСТЬNULL(Остатки.Остаток, 0)";

	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	Пока Выб.Следующий() Цикл
		Текст = "Для отгрузки товара """ + Выб.Номенклатура + """ на складе """ + Источник.Склад
			+ """ недостаточно свободного остатка в количестве " + Строка(Выб.Количество - Выб.Остаток) + " шт.";
		ОбщегоНазначения.СообщитьПользователю(Текст, , , , Отказ);
	КонецЦикла;
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения_ПриобретениеТоваровУслуг(Источник, Отказ)
	Если Не ЗначениеЗаполнено(Источник.Соглашение) Тогда
		Текст = "Не заполнено поле ""Соглашение"".";
		ОбщегоНазначения.СообщитьПользователю(Текст, , , , Отказ);
	КонецЕсли;

	Если Не (Источник.Склад = AMS_ВызовСервера.Цех1() 
		 Или Источник.Склад = AMS_ВызовСервера.Цех2() 
		 Или Источник.Склад = AMS_ВызовСервера.Цех3() 
		 Или Источник.Склад = AMS_ВызовСервера.СкладКомпании() 
		 Или Источник.Склад	= AMS_ВызовСервера.СкладРасходныхМатериалов()) Тогда

		Возврат;
	КонецЕсли;

	Товары = Источник.Товары.Выгрузить(, "НомерСтроки,Номенклатура,Склад");

	Если Не Отказ Тогда
		ТолькоУслуги = Истина;
		
		Для Каждого Стр Из Товары Цикл
			Если Стр.Склад <> Справочники.Склады.ПустаяСсылка() Тогда
				ТолькоУслуги = Ложь;
			КонецЕсли;
		КонецЦикла;
		
		Если ТолькоУслуги Тогда
			Источник.Склад = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ПередЗаписью

Процедура ПередЗаписьюДокумента(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	Имя = Источник.Метаданные().Имя;

	Если Имя = "ВозвратТоваровОтКлиента" Тогда
		УстановитьВремяДокумента(Источник, Имя, AMS_ВызовСервера.ПолучитьВремя(9, 0), AMS_ВызовСервера.ПолучитьВремя(9,	30));

	ИначеЕсли Имя = "ВозвратТоваровПоставщику" Тогда
		УстановитьВремяДокумента(Источник, Имя, AMS_ВызовСервера.ПолучитьВремя(16, 0), AMS_ВызовСервера.ПолучитьВремя(18, 0));

	ИначеЕсли Имя = "ЗаказКлиента" Тогда
		ПередЗаписьюЗаказКлиента(Источник, Отказ, РежимЗаписи);
	
	ИначеЕсли Имя = "ЗаказПоставщику" Тогда
		УстановитьВремяДокумента(Источник, Имя, AMS_ВызовСервера.ПолучитьВремя(9, 0), AMS_ВызовСервера.ПолучитьВремя(9, 30));
		ПередЗаписьюЗаказПоставщику(Источник, РежимЗаписи);

	ИначеЕсли Имя = "КорректировкаРеализации" Тогда
		ПередЗаписьюКорректировкаРеализации(Источник, Отказ, РежимЗаписи);

	ИначеЕсли Имя = "ПередачаТоваровХранителю" Тогда
		ПередЗаписьюПередачаТоваровХранителю(Источник, Отказ, РежимЗаписи);

	ИначеЕсли Имя = "ПеремещениеТоваров" Тогда
		ПередЗаписьюПеремещениеТоваров(Источник, Отказ, РежимЗаписи);

	ИначеЕсли Имя = "ПриобретениеТоваровУслуг" Тогда
		УстановитьВремяДокумента(Источник, Имя, AMS_ВызовСервера.ПолучитьВремя(7, 50), AMS_ВызовСервера.ПолучитьВремя(8, 10));

	ИначеЕсли Имя = "ПрочееОприходованиеТоваров" Тогда
		Если ЗначениеЗаполнено(Источник._ПроизводствоЗаСмену) Тогда 
			//@skip-check wrong-string-literal-content
			Источник.Дата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник._ПроизводствоЗаСмену, "Дата");
		КонецЕсли;

	ИначеЕсли Имя = "ПоступлениеБезналичныхДенежныхСредств" Или Имя = "ПриходныйКассовыйОрдер" Тогда
		УстановитьВремяДокумента(Источник, Имя, AMS_ВызовСервера.ПолучитьВремя(18, 0), AMS_ВызовСервера.ПолучитьВремя(19, 0));

	ИначеЕсли Имя = "РасходныйКассовыйОрдер" Или Имя = "СписаниеБезналичныхДенежныхСредств" Тогда
		УстановитьВремяДокумента(Источник, Имя, AMS_ВызовСервера.ПолучитьВремя(19, 0), AMS_ВызовСервера.ПолучитьВремя(10, 0));

	ИначеЕсли Имя = "РасходныйОрдерНаТовары" Тогда
		Пользователь = Пользователи.ТекущийПользователь();
		Если Источник.Модифицированность() И Не (Пользователь = AMS_ВызовСервера.Иванова() Или Пользователи.РолиДоступны(
			"_НачальникСклада,_ГлавныйБухгалтер,_Бухгалтер") Или AMS_ВызовСервера.ЭтоKhors()) Тогда

			ОбщегоНазначения.СообщитьПользователю("Изменения запрещены. Обратитесь в Главному бухгалтеру.", , , , Отказ);
			Возврат;
		КонецЕсли;

		Если Источник.ОтгрузкаПоЗаданиюНаПеревозку = Истина Тогда
			Источник.ОтгрузкаПоЗаданиюНаПеревозку = Ложь;
			Источник.ПорядокДоставки = "";
			Источник.ЗаданиеНаПеревозку = Неопределено;
		КонецЕсли;

	ИначеЕсли Имя = "РеализацияТоваровУслуг" Тогда
		ПередЗаписьюРеализацияТоваровУслуг(Источник, Отказ, РежимЗаписи);
	КонецЕсли;
КонецПроцедуры

