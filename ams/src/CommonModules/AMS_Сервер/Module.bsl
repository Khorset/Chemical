Функция ПолучитьВыборкаПоДокументамУКД(Ссылка) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СчетФактура.Ссылка КАК Ссылка,
		|	Корр.Ссылка КАК Корректировка,
