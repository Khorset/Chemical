Функция ПолучитьИспользованиеРазделенияСписка(УзелПО) Экспорт
	
	РезультатФункции = Ложь;
	
	Если УзелПО = Неопределено Тогда
		Возврат РезультатФункции;
	КонецЕсли; 
	
	ВерсияПО = ДатаМобайл_ОбщийМодуль.ЧтениеЗначенийУзлаОбменаТСД(УзелПО, "ВерсияПО");
	
	// Если версия 3.12.10 - пример версии, разделим список
	Если Лев(ВерсияПО,1) = "3" Тогда
		Попытка
			ВерсияРелиза = Число(Сред(ВерсияПО, 3, 2));
		Исключение 
			ВерсияРелиза = 0;
		КонецПопытки;
		
		Попытка
			Подверсия = Число(Прав(ВерсияПО, СтрДлина(ВерсияПО) - СтрНайти(ВерсияПО, ".", НаправлениеПоиска.СКонца)));
		Исключение
			Подверсия = 0;
		КонецПопытки;	
		
		РезультатФункции = ВерсияРелиза > 12 Или (ВерсияРелиза = 12 И Подверсия >= 10);
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

