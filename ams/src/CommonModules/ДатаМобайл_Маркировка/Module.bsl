			КонецЕсли;
			
			ПараметрыСканированияКМ = ПараметрыСканированияКодовМаркировки(ДанныеШтрихкода);
			
			ДанныеРазбора = Модуль_РазборКодаМаркировкиИССлужебный.РазобратьКодМаркировки(ДанныеШтрихкода.Штрихкод, ВидМаркируемойПродукции); 
			Если ДанныеРазбора = Неопределено Тогда
				НормализованныйШтрихкод = ДанныеШтрихкода.Штрихкод;
			Иначе
				НормализованныйШтрихкод = ДанныеРазбора.НормализованныйКодМаркировки;
			КонецЕсли;
			
			Попытка
				Модуль_ШтрихкодированиеИСКлиентСервер.ЗакодироватьШтрихкодДанныхBase64(ДанныеШтрихкода);
			Исключение
				Модуль_ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.ЗакодироватьШтрихкодДанныхBase64(ДанныеШтрихкода);
			КонецПопытки;
			
			Попытка
				Штрихкод = Модуль_ШтрихкодированиеИСКлиентСервер.Base64ВШтрихкод(ДанныеШтрихкода.Штрихкод);
			Исключение
				Штрихкод = Модуль_ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.Base64ВШтрихкод(ДанныеШтрихкода.Штрихкод);
			КонецПопытки;
			
			ДанныеШтрихкодаСтруктура = Новый Структура(
			"Штрихкод, ШтрихкодBase64, Количество",
			Штрихкод, ДанныеШтрихкода.Штрихкод, ДанныеШтрихкода.Количество);
			
			ДанныеШтрихкодов.Добавить(ДанныеШтрихкодаСтруктура);
			
			ВидМаркируемойПродукцииПредыдущий = ВидМаркируемойПродукции;
		КонецЦикла;
		
		Если ДанныеШтрихкодов.Количество() > 0 Тогда
			Попытка
				РезультатОбработкиШтрихкодов = Модуль_ШтрихкодированиеИС.ОбработатьШтрихкоды(
				ДанныеШтрихкодов, ДанныеШтрихкодаМассив[0].ПараметрыСканирования,
				Неопределено, Новый УникальныйИдентификатор);
			Исключение
				Попытка
					РезультатОбработкиШтрихкодов = Модуль_ШтрихкодированиеОбщегоНазначенияИС.ОбработатьШтрихкоды(
					ДанныеШтрихкодов, ДанныеШтрихкодаМассив[0].ПараметрыСканирования,
					Неопределено, Новый УникальныйИдентификатор);
				Исключение
				КонецПопытки;
			КонецПопытки;	
		КонецЕсли;
		                                             
	КонецЦикла;	
                                                                           			
КонецПроцедуры

&НаСервере
Функция ПараметрыСканированияКодовМаркировки(ДанныеШтрихкода)
	
	ДоступнаПечатьЭтикеток 	= Ложь;
	ВидМаркируемойПродукции = ДанныеШтрихкода.ВидПродукцииИС;
	ПроверяемыйДокумент    	= ДанныеШтрихкода.ПроверяемыйДокумент;
	Организация    			= ДанныеШтрихкода.Организация;
	Контрагент              = ДанныеШтрихкода.Контрагент;
	ПараметрыСканирования   = ДанныеШтрихкода.ПараметрыСканирования;
	
	ЭтоМаркировкаИСМП = ТипЗнч(ПроверяемыйДокумент) = Тип("ДокументСсылка.МаркировкаТоваровИСМП");
	
	Попытка 
		ПараметрыСканирования.Вставить("ДопустимыеВидыПродукции", Новый Массив);
		ПараметрыСканирования.ДопустимыеВидыПродукции.Очистить();
		ПараметрыСканирования.ДопустимыеВидыПродукции.Добавить(ВидМаркируемойПродукции);
	Исключение 
	КонецПопытки;
	
	ДанныеВыбора = Неопределено;
	
	ПараметрыСканирования.Вставить("СоздаватьШтрихкодУпаковки", Ложь);
	ПараметрыСканирования.КэшМаркируемойПродукции                            = Неопределено;
	ПараметрыСканирования.ДанныеВыбораПоМаркируемойПродукции                 = ДанныеВыбора;
	ПараметрыСканирования.ИспользуютсяДанныеВыбораПоМаркируемойПродукции     = Истина;
	ПараметрыСканирования.ПроверятьДублиКодовМаркировки                      = "Элементы";
	ПараметрыСканирования.ВозможнаЗагрузкаТСД                                = Истина;
	ПараметрыСканирования.ИспользуетсяСоответствиеШтрихкодовСтрокДерева      = Истина;
	ПараметрыСканирования.ДоступнаПечатьЭтикеток                             = ДоступнаПечатьЭтикеток;
	ПараметрыСканирования.КонтрольУникальностиКодовМаркировки                = Ложь;
	ПараметрыСканирования.СсылкаНаОбъект                                     = ПроверяемыйДокумент;
	ПараметрыСканирования.РазрешенаОбработкаБезУказанияМарки                 = Ложь;  
	
	Если Не ПараметрыСканирования.Свойство("ЭтоСканированиеВФормеПроверкиИПодбора") Тогда
		ПараметрыСканирования.Вставить("ЭтоСканированиеВФормеПроверкиИПодбора",Ложь);
	КонецЕсли;

	ПараметрыСканирования.ЭтоСканированиеВФормеПроверкиИПодбора              = Истина;
	
	Если Не ПараметрыСканирования.Свойство("КонтролироватьРасхождениеСоставаУпаковокМеждуИБиИСМП") Тогда
		ПараметрыСканирования.Вставить("КонтролироватьРасхождениеСоставаУпаковокМеждуИБиИСМП",Ложь);
	КонецЕсли;
	
	Если Не ПараметрыСканирования.Свойство("ЗапрашиватьДанныеСервисаИСМП") Тогда
		ПараметрыСканирования.Вставить("ЗапрашиватьДанныеСервисаИСМП", Ложь);
	Иначе
		Если ПараметрыСканирования.ЗапрашиватьДанныеСервисаИСМП = "ПоУмолчанию" Тогда 
			ПараметрыСканирования.Вставить("ЗапрашиватьДанныеСервисаИСМП", Ложь);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПараметрыСканирования.Свойство("КонтролироватьВладельцевКодовМаркировкиИСМП") Тогда
		ПараметрыСканирования.Вставить("КонтролироватьВладельцевКодовМаркировкиИСМП",Ложь);
	КонецЕсли;
	
	Если Не ПараметрыСканирования.Свойство("КонтролироватьСтатусыКодовМаркировкиИСМП") Тогда
		ПараметрыСканирования.Вставить("КонтролироватьСтатусыКодовМаркировкиИСМП",Ложь);
	КонецЕсли;
	
	ПараметрыСканирования.РазрешенаОбработкаНеНайденныхЛогистическихУпаковок = ПараметрыСканирования.ПоддерживаютсяОперацииАгрегации;
	
	Модуль_ИнтеграцияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСКлиентСервер");
	
	Если ДоступнаПечатьЭтикеток Тогда
		Если Модуль_ИнтеграцияИСКлиентСервер.ВидПродукцииИспользуетОтчетыОНанесенииКодовМаркировки(ВидМаркируемойПродукции) Тогда
			ПараметрыСканирования.СтатусКодаМаркировкиПоУмолчанию = ПредопределенноеЗначение(
			"Перечисление.СтатусыКодовМаркировкиИСМП.Эмитирован");
		Иначе
			ПараметрыСканирования.СтатусКодаМаркировкиПоУмолчанию = ПредопределенноеЗначение(
			"Перечисление.СтатусыКодовМаркировкиИСМП.Нанесен");
		КонецЕсли;
	КонецЕсли;
	
	КонтрольСоставаУпаковок = Истина;
	
	ПараметрыСканирования.КонтролироватьРасхождениеСоставаУпаковокМеждуИБиИСМП = КонтрольСоставаУпаковок
	И ПараметрыСканирования.ЗапрашиватьДанныеСервисаИСМП;
	
	ПараметрыПроверкиКодовМаркировки = СформироватьПараметрыПроверкиКодовМаркировки(ПроверяемыйДокумент, Организация, Контрагент);	
	
	Если ЭтоМаркировкаИСМП Тогда         
		
		Если ПараметрыСканирования.Свойство("ТребуетсяПроверкаСредствамиККТ") Тогда
			ПараметрыСканирования.ТребуетсяПроверкаСредствамиККТ 	= Истина;
		КонецЕсли;
		
		Если ПараметрыСканирования.Свойство("СохранятьКодыМаркировкиВПулИСМП") Тогда
			ПараметрыСканирования.СохранятьКодыМаркировкиВПулИСМП	= Истина;
		КонецЕсли;
		
		Если ПараметрыСканирования.Свойство("ЗаполнятьСрокГодности") Тогда
			ПараметрыСканирования.ЗаполнятьСрокГодности = Ложь;	
		КонецЕсли;
		
		Если ПараметрыСканирования.Свойство("ЗаполнятьДанныеВЕТИС") Тогда
			ПараметрыСканирования.ЗаполнятьДанныеВЕТИС = Ложь;	
		КонецЕсли; 
		
	КонецЕсли; 
	
	Если ПараметрыПроверкиКодовМаркировки.КонтролироватьВладельцевКодовМаркировки Тогда
		ПараметрыСканирования.Владелец                                    = ПараметрыПроверкиКодовМаркировки.Владелец;
		ПараметрыСканирования.КонтролироватьВладельцевКодовМаркировкиИСМП = Истина;
	Иначе
		ПараметрыСканирования.Владелец = Неопределено;
		ПараметрыСканирования.КонтролироватьВладельцевКодовМаркировкиИСМП = Ложь;
	КонецЕсли;
	
	Если ПараметрыПроверкиКодовМаркировки.КонтролироватьСтатусыКодовМаркировки Тогда
		ПараметрыСканирования.КонтролироватьСтатусыКодовМаркировкиИСМП = Истина;
	Иначе
		ПараметрыСканирования.КонтролироватьСтатусыКодовМаркировкиИСМП = Ложь;
	КонецЕсли;
	
	ПараметрыСканирования.ЗапрашиватьДанныеСервисаИСМП = Ложь; 
	
	Если Не ПараметрыСканирования.Свойство("ЭтоПроверкаКодовМаркировкиИСМП") Тогда
		ПараметрыСканирования.Вставить("ЭтоПроверкаКодовМаркировкиИСМП",Ложь);
	КонецЕсли;

	Если Не ПараметрыСканирования.Свойство("ЭтоОтчетПроизводственнойЛинии") Тогда
		ПараметрыСканирования.Вставить("ЭтоОтчетПроизводственнойЛинии",Ложь);
	КонецЕсли;   
	
	Если Не ПараметрыСканирования.Свойство("ВидОперацииИСМП") Тогда
		ПараметрыСканирования.Вставить("ВидОперацииИСМП", Неопределено);
	КонецЕсли;                                                 
	
	Если Не ПараметрыСканирования.Свойство("ОпределениеВидаПродукцииИСМП") Тогда
		ПараметрыСканирования.Вставить("ОпределениеВидаПродукцииИСМП", Ложь);
	КонецЕсли;    
	
	Если Не ПараметрыСканирования.Свойство("ЭтоПечатьКодаМаркировкиИзПулаИСМП") Тогда
		ПараметрыСканирования.Вставить("ЭтоПечатьКодаМаркировкиИзПулаИСМП", Ложь);
	КонецЕсли;    
	
	Если Не ПараметрыСканирования.Свойство("СохранятьКодыМаркировкиВПулИСМП") Тогда
		ПараметрыСканирования.Вставить("СохранятьКодыМаркировкиВПулИСМП", Ложь);
	КонецЕсли;
	
	Если Не ПараметрыСканирования.Свойство("ТребуетсяПроверкаСредствамиККТ") Тогда
		ПараметрыСканирования.Вставить("ТребуетсяПроверкаСредствамиККТ", Ложь);
	КонецЕсли; 
	
	Если Не ПараметрыСканирования.Свойство("ТолькоЕГАИС") Тогда
		ПараметрыСканирования.Вставить("ТолькоЕГАИС", Ложь);
	КонецЕсли;
		
	Возврат ПараметрыСканирования;
	
КонецФункции

&НаСервере
функция СформироватьПараметрыПроверкиКодовМаркировки(ПроверяемыйДокумент, Организация, Контрагент)
	
	РежимПодбораСуществующихУпаковок = Истина;
	
	Модуль_ЭлектронноеВзаимодействиеИСМП = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ЭлектронноеВзаимодействиеИСМП");
	
	ПараметрыПроверкиКодовМаркировки = Новый Структура();
	ПараметрыПроверкиКодовМаркировки.Вставить("ОтсутствуетПодключениеИСМП", Ложь);
	ПараметрыПроверкиКодовМаркировки.Вставить("ЗапрашиватьДанныеСервиса",
	Не Модуль_ЭлектронноеВзаимодействиеИСМП.ЗавершенОбменПоЭДО(ПроверяемыйДокумент));
	ПараметрыПроверкиКодовМаркировки.Вставить("ДопустимыеСтатусыКодовМаркировки");
	ПараметрыПроверкиКодовМаркировки.Вставить("ДопустимыеСтатусыУпаковок");
	
	Модуль_ПроверкаИПодборПродукцииИСМП = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ПроверкаИПодборПродукцииИСМП");
	Модуль_ИнтеграцияИСВызовСервера = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСВызовСервера");
	Модуль_РаботаСКонтрагентамиИСВызовСервера = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("РаботаСКонтрагентамиИСВызовСервера");
	
	Если РежимПодбораСуществующихУпаковок
		Или Модуль_ПроверкаИПодборПродукцииИСМП.КонтрагентНеРезидент(Контрагент) Тогда
		Попытка
			ИННВладельца = Модуль_ИнтеграцияИСВызовСервера.ИННКПППоОрганизацииКонтрагенту(Организация).ИНН;
		Исключение
			ИННВладельца = Модуль_РаботаСКонтрагентамиИСВызовСервера.ИННКПППоОрганизацииКонтрагенту(Организация).ИНН;
		КонецПопытки;
		Владелец     = Организация;
	Иначе
		Попытка
			ИННВладельца = Модуль_ИнтеграцияИСВызовСервера.ИННКПППоОрганизацииКонтрагенту(Контрагент).ИНН;
		Исключение
			ИННВладельца = Модуль_РаботаСКонтрагентамиИСВызовСервера.ИННКПППоОрганизацииКонтрагенту(Контрагент).ИНН;
		КонецПопытки;
		Владелец     = Контрагент;
	КонецЕсли;
	ПараметрыПроверкиКодовМаркировки.Вставить("КонтролироватьСтатусыКодовМаркировки",    Ложь);
	ПараметрыПроверкиКодовМаркировки.Вставить("КонтролироватьВладельцевКодовМаркировки", Ложь);
	
	ПараметрыПроверкиКодовМаркировки.Вставить("ИННВладельца",            ИННВладельца);
	ПараметрыПроверкиКодовМаркировки.Вставить("Владелец",                Владелец);
	ПараметрыПроверкиКодовМаркировки.Вставить("ОбратноеСканирование",    Ложь);
	
	ПараметрыПроверкиКодовМаркировки.Вставить("ДопустимыйСпособВводаВОборот", Новый Массив);
	
	ПараметрыПроверкиКодовМаркировки.Вставить("КонтролироватьВложенностьУпаковок", Ложь);
	ПараметрыПроверкиКодовМаркировки.Вставить("ДопустимыеВложенияАгрегатов",       Неопределено);
	
	Возврат ПараметрыПроверкиКодовМаркировки;
	
КонецФункции

функция ЗаменитьТэгиВПолныйКодМаркировки(ПолныйКодМаркировки, ВидПродукцииИС)
	
	ЭтоТабак = ЭтоТабакПоВидыПродукцииИС(ВидПродукцииИС);
	
	// По 93 тэгу и 240 при табачке не надо сохранять символ 29
	// СпецСимвол = ?(ЭтоТабак, "", Символ(29)); в утапе 11.5.11.56 даный спецсимвол нужен, также нужен и при 8005
	СпецСимвол = ?(ЭтоТабак, Символ(29), "");
	
	// подмена скобок
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "(01)"	, "01");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "(21)"	, "21");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "(8005)"	, СпецСимвол + "8005");
	
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "[01]"	, "01");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "[21]"	, "21");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "[8005]"	, СпецСимвол + "8005");
	
	// подмена скобок и добавление символа 29
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "(91)"	, Символ(29) + "91");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "(92)"	, Символ(29) + "92");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "(93)"	, Символ(29) + "93");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "(240)"	, Символ(29) + "240");
	
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "[91]"	, Символ(29) + "91");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "[92]"	, Символ(29) + "92");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "[93]"	, Символ(29) + "93");
	ПолныйКодМаркировки = СтрЗаменить(ПолныйКодМаркировки, "[240]"	, Символ(29) + "240");
	
	Если СтрНайти(ПолныйКодМаркировки, "(3103)") > 0 Тогда
		ПолныйКодМаркировки = Лев(ПолныйКодМаркировки, СтрНайти(ПолныйКодМаркировки, "(3103)") - 1);	
	КонецЕсли;
	
	Если СтрНайти(ПолныйКодМаркировки, "[3103]") > 0 Тогда
		ПолныйКодМаркировки = Лев(ПолныйКодМаркировки, СтрНайти(ПолныйКодМаркировки, "[3103]") - 1);	
	КонецЕсли;
	
	Возврат ПолныйКодМаркировки;
	
КонецФункции

#КонецОбласти

#Область Казахстан

Функция ПолучитьДокументМаркировкиКазахстан(ПараметрыДокумента, ДокументТСД, ЭтоНовыйДокумент, УзелПО, СтрокаОшибок) Экспорт
	
	ИсходныйДокумент = ПараметрыДокумента.Док;
	
	ВидДокумента 		= ПараметрыДокумента.ПараметрыШаблона.ВидДокумента;
	ВидДокументаНового 	= ПараметрыДокумента.ПараметрыШаблона.ВидДокументаНового;
	
	Если ВидДокумента = "АктПриемаПередачиИСМПТК" 
		Или ВидДокументаНового = "АктПриемаПередачиИСМПТК"
		Тогда  
				
		Возврат ОбработатьВидДокументаАктПриемаПередачиИСМПТККазахстан(ПараметрыДокумента, ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, УзелПО, СтрокаОшибок);
		
	Иначе	
		СтрокаОшибок = "Указанный в шаблоне вид документа не поддерживается при работе с маркировкой в данной конфигурации.";
	КонецЕсли;
	
КонецФункции // ()

Функция ОбработатьВидДокументаАктПриемаПередачиИСМПТККазахстан(ПараметрыДокумента, ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, УзелПО, СтрокаОшибок)
	
	Шаблон = ПараметрыДокумента.Шаблон;
	РеквизитыШаблона = ПараметрыДокумента.ПараметрыШаблона;
	
	ТЧПриЗагрузкеПодбор 	= РеквизитыШаблона.ТабличнуюЧастьПриЗагрузкеПодбор;
	ИмяТЧПодбор 			= РеквизитыШаблона.ИмяТабличнойЧастиПодбор;
	СоздаватьЕслиНеНайдена 	= РеквизитыШаблона.МаркировкаСоздаватьСправочникКМЕслиНеНайден;	
	ПривязыватьGTIN 		= РеквизитыШаблона.МаркировкаПривязыватьGTINКакШтрихкод;
	ЗаписыватьПолныйКМ      = РеквизитыШаблона.МаркировкаЗаписыватьПолныйКМ;
	
	ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);
	
	Если ЭтоНовыйДокумент Тогда
		ЗаполнитьШапкуДокумента(Новый Структура("Об, Док", ДокументТСД, ИсходныйДокумент));
		ПеренестиВДокументНовыеЗначенияРеквизитов(ДокументТСД, ИсходныйДокумент, Шаблон);		
	КонецЕсли;
	
	Если ТЧПриЗагрузкеПодбор <> 0 Тогда
		ОбработатьИзменениеТЧПодборКазахстан(ПараметрыДокумента, ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор);
	КонецЕсли;
	
	СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, УзелПО, ПривязыватьGTIN);
	
	СоздатьСтрокиМарокПоМассивуКазахстан(СтруктураСобранныхМарокИУпаковок.Короба, ИсходныйДокумент);
	СоздатьСтрокиМарокПоМассивуКазахстан(СтруктураСобранныхМарокИУпаковок.Марки, ИсходныйДокумент);           
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура КАК Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры КАК Характеристика,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.СерияСсылка КАК Серия,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМСсылка КАК КМСсылка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка КАК ЦРПТМарка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка_Длина КАК ЦРПТМарка_Длина,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_RawMrc КАК KM_RawMrc,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_TNVED КАК KM_TNVED,
	|	СУММА(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Количество) КАК Количество,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Короб КАК Короб
	|ПОМЕСТИТЬ ДанныеПодбор
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор
	|ГДЕ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка = &Ссылка
	|	И НЕ(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.Шаблон.ЗагрузкаСтрокПодбораСДокументами
	|				И ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.Шаблон.ВидДокументаНового <> """"
	|				И ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ПризнакПовторнойВыгрузки)
	|
	|СГРУППИРОВАТЬ ПО
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.СерияСсылка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМСсылка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка_Длина,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_RawMrc,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_TNVED,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Короб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеПодбор.УпаковочныйЛист КАК Упаковка,
	|	ДанныеПодбор.Номенклатура КАК Номенклатура,
	|	ДанныеПодбор.Характеристика КАК Характеристика,
	|	ДанныеПодбор.Серия КАК Серия,
	|	ДанныеПодбор.КМСсылка КАК СсылкаМарка,
	|	ДанныеПодбор.ЦРПТМарка КАК Марка,
	|	ДанныеПодбор.ЦРПТМарка_Длина КАК ЦРПТМарка_Длина,
	|	ДанныеПодбор.KM_RawMrc КАК KM_RawMrc,
	|	ДанныеПодбор.KM_TNVED КАК KM_TNVED,
	|	ДанныеПодбор.Короб КАК Короб	
	|ИЗ
	|	ДанныеПодбор КАК ДанныеПодбор
	|ГДЕ
	|	ДанныеПодбор.Количество > 0
	|ИТОГИ ПО
	|	Упаковка,
	|	Короб";
		
	Запрос.УстановитьПараметр("Ссылка", ДокументТСД.Ссылка);	
	ВыборкаУпаковка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	
	Пока ВыборкаУпаковка.Следующий()  Цикл
		
		УпакСсылка = ПолучитьСправочникСсылкаУпаковка(ВыборкаУпаковка.Упаковка, Истина, Неопределено);
		
		Если ЗначениеЗаполнено(УпакСсылка) Тогда
			
			УпакОбъект = УпакСсылка.ПолучитьОбъект();
			
			ВыборкаКороба = ВыборкаУпаковка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаКороба.Следующий() Цикл			
				
				Если ЗначениеЗаполнено(ВыборкаКороба.Короб) Тогда
					
					КоробСсылка = ПолучитьСправочникСсылкаУпаковка(ВыборкаКороба.Короб, Истина, Неопределено);										
					КоробОбъект = КоробСсылка.ПолучитьОбъект();
					
					ПроверитьМаркаНаходитсяВДругомКоробе(КоробСсылка, УпакОбъект.Ссылка);
					
					РезультатПоиска = УпакОбъект.ВложенныеШтрихкоды.НайтиСтроки(Новый Структура("Штрихкод", КоробСсылка));
					Если РезультатПоиска.Количество() = 0 Тогда
						НовыйВложенныйШтрихкод = УпакОбъект.ВложенныеШтрихкоды.Добавить();
						НовыйВложенныйШтрихкод.Штрихкод = КоробСсылка;
					КонецЕсли;
					
					КоробОбъект.Записать();			
					ОпределитьУпаковкуМоноМульти(КоробОбъект);
					
				Иначе
					
					ВыборкаМарки = ВыборкаКороба.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					
					Пока ВыборкаМарки.Следующий() Цикл
						
						Если ЗначениеЗаполнено(ВыборкаМарки.СсылкаМарка) Тогда
							СсылкаМарка = ВыборкаМарки.СсылкаМарка;
						Иначе	
							СтруктураТовара = Новый Структура("Номенклатура, Характеристика", ВыборкаМарки.Номенклатура, ВыборкаМарки.Характеристика);
							СсылкаМарка = ПолучитьСправочникСсылкаМарка(ВыборкаМарки.Марка, ВыборкаМарки.ЦРПТМарка_Длина, ВыборкаМарки.KM_RawMrc, ВыборкаМарки.KM_TNVED, СоздаватьЕслиНеНайдена, СтруктураТовара, ДокументТСД.Шаблон);
						КонецЕсли;
						
						Если ЗначениеЗаполнено(СсылкаМарка) Тогда								
							
							ПроверитьМаркаНаходитсяВДругомКоробе(СсылкаМарка, УпакОбъект.Ссылка);
							
							РезультатПоиска = УпакОбъект.ВложенныеШтрихкоды.НайтиСтроки(Новый Структура("Штрихкод", СсылкаМарка));
							Если РезультатПоиска.Количество() = 0 Тогда
								НовыйВложенныйШтрихкод = УпакОбъект.ВложенныеШтрихкоды.Добавить();
								НовыйВложенныйШтрихкод.Штрихкод = СсылкаМарка;
							КонецЕсли;								
							
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли;			
				
			КонецЦикла;
			
			УпакОбъект.Записать();	
			ОпределитьУпаковкуМоноМульти(УпакОбъект);
			
		КонецЕсли;
					
	КонецЦикла;
	
	Попытка
		ИзменитьРеквизитыШапкиИзДополнительныхФорм(ИсходныйДокумент, Шаблон, ДокументТСД);
	Исключение КонецПопытки;
	
	Попытка
		ВыполнитьДопОбработкуДокумента(ИсходныйДокумент, ДокументТСД, Шаблон, ЭтоНовыйДокумент)
	Исключение 
	КонецПопытки;
		
	ИсходныйДокумент.Записать();
	
	Если ЗаписыватьПолныйКМ Тогда
		
	КонецЕсли;
	
	Если РеквизитыШаблона.ВидДокументаНового = "" Тогда
		ДокументТСД.ИсходныйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	Иначе
		ДокументТСД.НовыйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	КонецЕсли;		
		
КонецФункции

Процедура ОбработатьИзменениеТЧПодборКазахстан(ПараметрыДокумента, ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор)
	
	КопияТЧ = Неопределено;
	
	ЭтоГрупповойДокумент = Ложь;
	
	МетаданныеДокумента = ИсходныйДокумент.Метаданные();
	ИмяДока = МетаданныеДокумента.Имя;    
			
	Шаблон = ПараметрыДокумента.Шаблон;
	РеквизитыШаблона = ПараметрыДокумента.ПараметрыШаблона;
 	
	БазовыеЕдиницыПриЗагрузке 				= РеквизитыШаблона.БазовыеЕдиницыПриЗагрузке;
	СерииВОтдельнойТЧ 						= РеквизитыШаблона.СерииВОтдельнойТЧ;
	ТабличнуюЧастьПриЗагрузкеПодбор			= РеквизитыШаблона.ТабличнуюЧастьПриЗагрузкеПодбор;
	ИспользованиеСерийниковПодбор			= РеквизитыШаблона.ИспользованиеСерийниковПодбор;
	ИспользованиеСерийниковПриемка			= РеквизитыШаблона.ИспользованиеСерийниковПриемка;
	ИсточникСерии							= РеквизитыШаблона.ИсточникСерии;
	ИспользованиеЯчеекПодбор				= РеквизитыШаблона.ИспользованиеЯчеекПодбор;
	БазовыеУпаковкиПриЗагрузке              = РеквизитыШаблона.БазовыеУпаковкиПриЗагрузке;
		
	СобранныеДанныеПодбор = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
	ТЗСобранныеДанныеПодбор = СобранныеДанныеПодбор; 	
	ТЗСобранныеДанныеПодбор.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, ЯчейкаСсылка", "Количество");	 
	
	лЕстьGTIN = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("GTIN") <> Неопределено);
		
	Если Не лЕстьGTIN Тогда	
		ТЗСобранныеДанныеПодбор.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЯчейкаСсылка", "Количество");					
	КонецЕсли; 
	
	Если ТабличнуюЧастьПриЗагрузкеПодбор = 5 Тогда
		КопияТЧ = Неопределено;		
	КонецЕсли; 
			
	СерииВОтдельнойТЧ = СерииВОтдельнойТЧ;
	лЕстьСерия = ((ИспользованиеСерийниковПодбор > 0 Или ИсточникСерии = 2) И (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("Серия") <> Неопределено)) И Не ЭтоГрупповойДокумент;
	лЕстьСерияВОтдельнойТЧ = МетаданныеДокумента.ТабличныеЧасти.Найти("Серии") <> Неопределено;				
	//В задании в отдельной ТЧ, в подчиненном в основной ТЧ
	Если лЕстьСерия тогда 
		Если лЕстьСерияВОтдельнойТЧ тогда
			лЕстьСерия = Ложь;
		КонецЕсли;	
	КонецЕсли;
	
	лЕстьЯчейка = (ИспользованиеЯчеекПодбор > 0 И (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("Ячейка") <> Неопределено));
	лЕстьЕдиницаИзмерения = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("ЕдиницаИзмерения") <> Неопределено);
	лЕстьУпаковка = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("Упаковка") <> Неопределено);
	лЕстьИдентификаторСтроки = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("ИдентификаторСтроки") <> Неопределено);
	лЕстьКоличествоИсточник = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("КоличествоИсточник") <> Неопределено);
	
	Если лЕстьСерия Тогда		
		ТЗСобранныеДанныеПодбор = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		ТЗСобранныеДанныеПодбор.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, СерияСсылка, ЯчейкаСсылка", "Количество");			
	КонецЕсли;
	
	ПустаяУпаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
	
	Для каждого СтрТЧ Из ТЗСобранныеДанныеПодбор Цикл
		
		Если СтрТЧ.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
				
		ОсобенностьУчета = СтрТЧ.Номенклатура.ОсобенностьУчета;
				
		Попытка 
			КоэффициентУпаковки = СтрТЧ.ЕдиницаИзмерения.Числитель / СтрТЧ.ЕдиницаИзмерения.Знаменатель;
			КоэффициентУпаковки = ?(КоэффициентУпаковки = 0, 1, КоэффициентУпаковки);
		Исключение
			КоэффициентУпаковки = ?(СтрТЧ.ЕдиницаИзмерения.Числитель = 0, 1, СтрТЧ.ЕдиницаИзмерения.Числитель);
		Конецпопытки;
		
		Если БазовыеЕдиницыПриЗагрузке Тогда					
			//ТекущаяЕдиницаИзмерения = СтрТЧ.Номенклатура.ЕдиницаИзмерения;
			СтрТЧ.Количество = СтрТЧ.Количество * КоэффициентУпаковки;
			ТекущаяЕдиницаИзмерения = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
			КоэффициентУпаковки = 1;
		Иначе
			ТекущаяЕдиницаИзмерения = СтрТЧ.ЕдиницаИзмерения;
		КонецЕсли;	
						
		лСтруктураПоиска = Новый Структура("Номенклатура, Характеристика", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры);
		
		Если лЕстьУпаковка Тогда
			// Проверка на заполненность упаковок
			//Если БазовыеУпаковкиПриЗагрузке И СтрТЧ.Номенклатура.ИспользоватьУпаковки И Не СтрТЧ.Номенклатура.ВесИспользовать И Не ЗначениеЗаполнено(СтрТЧ.ЕдиницаИзмерения) Тогда
			Если БазовыеУпаковкиПриЗагрузке И СтрТЧ.Номенклатура.ИспользоватьУпаковки Тогда
				ТекущаяЕдиницаИзмерения = Обработки.ДатаМобайл_АРМДиспетчера.ПолучитьБазовуюУпаковкуНоменклатуры(СтрТЧ.Номенклатура);	
				
				Если Не ЗначениеЗаполнено(ТекущаяЕдиницаИзмерения) И ИмяДока = "ОтборРазмещениеТоваров" Тогда
					СтрокаОшибок = "Не выбрана упаковка, для документа обязательно указание упаковок!!!";
					Возврат; 
				КонецЕсли;	
			КонецЕсли;
			
			лСтруктураПоиска.Вставить("Упаковка", ТекущаяЕдиницаИзмерения);												
		КонецЕсли; 
		
		Если лЕстьЕдиницаИзмерения Тогда
			лСтруктураПоиска.Вставить("ЕдиницаИзмерения", ТекущаяЕдиницаИзмерения);
		КонецЕсли;
		
		//Если лЕстьGTIN Тогда
		//	лСтруктураПоиска.Вставить("GTIN", СтрТЧ.KM_GTIN);
		//КонецЕсли;
		
		Если лЕстьСерия Тогда
			лСтруктураПоиска.Вставить("Серия", СтрТЧ.СерияСсылка);
		КонецЕсли;
		
		Если лЕстьЯчейка Тогда
			лСтруктураПоиска.Вставить("Ячейка", СтрТЧ.ЯчейкаСсылка);
		КонецЕсли;
				
		СтрокиПоискаКопияТЧ = Неопределено;
		Если КопияТЧ <> Неопределено И (ИмяДока = "РеализацияТоваровУслуг" Или ИмяДока = "ПриобретениеТоваровУслуг" Или ИмяДока = "ВозвратТоваровОтКлиента") Тогда
	
			СтрокиПоискаКопияТЧ = КопияТЧ.НайтиСтроки(лСтруктураПоиска);	
			
			Если СтрокиПоискаКопияТЧ.Количество() = 0 И КоэффициентУпаковки = 1 Тогда				
				Попытка лСтруктураПоиска.Упаковка = ПустаяУпаковка; Исключение Конецпопытки;	
				СтрокиПоискаКопияТЧ = КопияТЧ.НайтиСтроки(лСтруктураПоиска);				
			КонецЕсли;
			
			Если СтрокиПоискаКопияТЧ.Количество() = 0 И лЕстьСерия Тогда				
				лСтруктураПоиска.Удалить("Серия");
				СтрокиПоискаКопияТЧ = КопияТЧ.НайтиСтроки(лСтруктураПоиска);				
			КонецЕсли;
			
		КонецЕсли;
						
		СтрокиПоиска = ИсходныйДокумент[ИмяТЧПодбор].НайтиСтроки(лСтруктураПоиска);			
		Если КоэффициентУпаковки = 1 И СтрокиПоиска.Количество() = 0 Тогда
			Попытка лСтруктураПоиска.Упаковка = ПустаяУпаковка; Исключение Конецпопытки;
			СтрокиПоиска = ИсходныйДокумент[ИмяТЧПодбор].НайтиСтроки(лСтруктураПоиска);
		КонецЕсли;
						
		Если СтрокиПоиска.Количество() <> 0 Тогда		
			СтрокаТабличнойЧасти = СтрокиПоиска[0];  
			
			Если КопияТЧ <> Неопределено и СтрокиПоискаКопияТЧ <> Неопределено Тогда
				Если СтрокиПоискаКопияТЧ.Количество() <> 0 Тогда
					Если СтрТЧ.Количество > 0 Тогда
						//ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаКопияТЧ[0]);
						Попытка			
							ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаКопияТЧ[0], , "КоличествоУпаковок, Количество");
						Исключение
							Попытка
								ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаКопияТЧ[0], , "Количество");
							Исключение
								ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаКопияТЧ[0]);
							КонецПопытки;
						КонецПопытки;					
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;			
			
		Иначе
			
			СтрокаТабличнойЧасти = ИсходныйДокумент[ИмяТЧПодбор].Добавить();
			
			СтрокаТабличнойЧасти.Номенклатура = СтрТЧ.Номенклатура;
			СтрокаТабличнойЧасти.Характеристика = СтрТЧ.ХарактеристикаНоменклатуры;
						
			Если лЕстьУпаковка Тогда				
				СтрокаТабличнойЧасти.Упаковка = ТекущаяЕдиницаИзмерения;				
			КонецЕсли; 
			
			Если лЕстьЕдиницаИзмерения Тогда				
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = ТекущаяЕдиницаИзмерения;				
			КонецЕсли;
			
			//Если лЕстьGTIN Тогда
			//	СтрокаТабличнойЧасти.GTIN = СтрТЧ.KM_GTIN;
			//КонецЕсли;
			
			Если лЕстьСерия Тогда				
				СтрокаТабличнойЧасти.Серия = СтрТЧ.СерияСсылка;								
			КонецЕсли;
			
			Если лЕстьЯчейка Тогда
				СтрокаТабличнойЧасти.Ячейка = СтрТЧ.ЯчейкаСсылка;
			КонецЕсли;
			
			Если лЕстьИдентификаторСтроки Тогда
				СтрокаТабличнойЧасти.ИдентификаторСтроки = Новый УникальныйИдентификатор();
			КонецЕсли;		
						
			Обработки.ДатаМобайл_АРМДиспетчера.ОбработатьНовуюСтрокуТЧ(Новый Структура("Об", ДокументТСД), ИсходныйДокумент, ИмяТЧПодбор, СтрокаТабличнойЧасти); 
					
		КонецЕсли;
				
		Если ТабличнуюЧастьПриЗагрузкеПодбор = 5 Тогда
				
			Попытка				
				СтрокаТабличнойЧасти.КоличествоУпаковок = СтрТЧ.Количество;  
				СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.КоличествоУпаковок * КоэффициентУпаковки;				
			Исключение
				Если лЕстьКоличествоИсточник Тогда
					СтрокаТабличнойЧасти.КоличествоИсточник = СтрТЧ.Количество;	
				Иначе
					СтрокаТабличнойЧасти.Количество = СтрТЧ.Количество;
				КонецЕсли;
			КонецПопытки;
			
		Иначе			
						
			Попытка			
				СтрокаТабличнойЧасти.КоличествоУпаковок = СтрокаТабличнойЧасти.КоличествоУпаковок + СтрТЧ.Количество;  
				СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.КоличествоУпаковок * КоэффициентУпаковки;					
			Исключение
				Если лЕстьКоличествоИсточник Тогда
					СтрокаТабличнойЧасти.КоличествоИсточник = СтрокаТабличнойЧасти.КоличествоИсточник + СтрТЧ.Количество * КоэффициентУпаковки;	
				Иначе
					СтрокаТабличнойЧасти.Количество = СтрТЧ.Количество;
				КонецЕсли;
			КонецПопытки;
			
		КонецЕсли;
				
		Обработки.ДатаМобайл_АРМДиспетчера.ОбработатьСтрокуТЧ(ИсходныйДокумент, ИмяТЧПодбор, СтрокаТабличнойЧасти, Шаблон);
		
	КонецЦикла;
	
	// Серии в отдельной ТЧ
	Если МетаданныеДокумента.ТабличныеЧасти.Найти("Серии") <> Неопределено И СерииВОтдельнойТЧ И Не ЭтоГрупповойДокумент Тогда
		
		Если ТабличнуюЧастьПриЗагрузкеПодбор > 1 И ТабличнуюЧастьПриЗагрузкеПодбор < 5 Тогда
			Попытка ИсходныйДокумент.Серии.Очистить(); Исключение КонецПопытки;	
		КонецЕсли; 
		
		ТЗСобранныеДанныеПодбор = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		ТЗСобранныеДанныеПодбор.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, СерияСсылка", "Количество");
		
		Для каждого СтрТЧ Из ТЗСобранныеДанныеПодбор Цикл
			
			Если СтрТЧ.СерияСсылка.Пустая() Или СтрТЧ.Количество = 0 Тогда
				Продолжить;	
			КонецЕсли; 
			
			Попытка 
				
				КоэффициентУпаковки = СтрТЧ.ЕдиницаИзмерения.Числитель/СтрТЧ.ЕдиницаИзмерения.Знаменатель;
				КоэффициентУпаковки = ?(КоэффициентУпаковки = 0, 1, КоэффициентУпаковки);
				
			Исключение
				КоэффициентУпаковки = ?(СтрТЧ.ЕдиницаИзмерения.Числитель = 0, 1, СтрТЧ.ЕдиницаИзмерения.Числитель);
			Конецпопытки;	
			
			лСтруктураПоискаСерий = Новый Структура("Номенклатура,Характеристика,Серия", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры, СтрТЧ.СерияСсылка);
			СтрокиПоискаСерий = ИсходныйДокумент["Серии"].НайтиСтроки(лСтруктураПоискаСерий);
			
			Если СтрокиПоискаСерий.Количество() = 0 Тогда
				
				СтрокаТабличнойЧастиСерии = ИсходныйДокумент["Серии"].Добавить();
				
				СтрокаТабличнойЧастиСерии.Номенклатура = СтрТЧ.Номенклатура;
				СтрокаТабличнойЧастиСерии.Характеристика = СтрТЧ.ХарактеристикаНоменклатуры;
				СтрокаТабличнойЧастиСерии.Серия = СтрТЧ.СерияСсылка;
				
				СтрокиПоискаПоТоварам = ИсходныйДокумент[ИмяТЧПодбор].НайтиСтроки(Новый Структура("Номенклатура,Характеристика", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры));
				
				Если СтрокиПоискаПоТоварам.Количество() = 1 Или СтрокиПоискаПоТоварам.Количество() > 1 Тогда
					
					Попытка СтрокаТабличнойЧастиСерии.Склад = СтрокиПоискаПоТоварам[0].Склад; Исключение КонецПопытки;
					Попытка СтрокаТабличнойЧастиСерии.Назначение = СтрокиПоискаПоТоварам[0].Назначение; Исключение КонецПопытки;					
					
				КонецЕсли;
				
			Иначе	
				СтрокаТабличнойЧастиСерии = СтрокиПоискаСерий[0];
			КонецЕсли;
			
			СтрокаТабличнойЧастиСерии.Количество = СтрокаТабличнойЧастиСерии.Количество + СтрТЧ.Количество * КоэффициентУпаковки;			
			
		КонецЦикла; 
				
	КонецЕсли;	
	// Серии в отдельной ТЧ
	
	Если ИспользованиеСерийниковПодбор <> 0 Или ИспользованиеСерийниковПриемка <> 0 Тогда
		Обработки.ДатаМобайл_АРМДиспетчера.УстановитьСерииВдокументе(ИсходныйДокумент);
	КонецЕсли;
	
	Если ТабличнуюЧастьПриЗагрузкеПодбор = 3 Тогда
		ПроверкаНаНулевоеКоличество(ИсходныйДокумент, ИмяТЧПодбор, лЕстьКоличествоИсточник);	
	КонецЕсли;
		
КонецПроцедуры

Процедура СоздатьСтрокиМарокПоМассивуКазахстан(лМассив, ИсходныйДокумент)
	
	Модуль_РазборИОбработкаКодовМаркировкиИСМПТКСлужебныйКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("РазборИОбработкаКодовМаркировкиИСМПТКСлужебныйКлиентСервер");
	Модуль_ИнтеграцияИСМПТКВызовСервера = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСМПТКВызовСервера");
	Модуль_ОбщегоНазначенияИСМПТККлиентСерверПереопределяемый = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначенияИСМПТККлиентСерверПереопределяемый");
	
	Для каждого лЭлемент Из лМассив Цикл		
		Если лЭлемент = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		лСтруктураПоиска = Новый Структура("КодМаркировки", лЭлемент);	
		СтрокиПоиска = ИсходныйДокумент.Марки.НайтиСтроки(лСтруктураПоиска);
		Если СтрокиПоиска.Количество() <> 0 Тогда
			Продолжить;
		КонецЕсли;
						
		лСтруктураПоиска = Новый Структура("Номенклатура", лЭлемент.Номенклатура);	
		СтрокиПоиска = ИсходныйДокумент.Товары.НайтиСтроки(лСтруктураПоиска);
		Если СтрокиПоиска.Количество() > 0 Тогда
			ДанныеШтрихкода = Новый Структура;
			ДанныеШтрихкода.Вставить("Количество", 1);
			ДанныеШтрихкода.Вставить("Штрихкод", УбратьСкобкиТеговМарка(лЭлемент.ЗначениеШтрихкода, 0));
			Если Не Модуль_РазборИОбработкаКодовМаркировкиИСМПТКСлужебныйКлиентСервер.ПроверкаФорматаТранспортногоКодаПройденаУспешно(ДанныеШтрихкода) Тогда
				Возврат;
			КонецЕсли;
			
			//Для передачи на сервер КМ, в составе которого есть символы GS (29), требуется дополнительное кодирование
			Модуль_РазборИОбработкаКодовМаркировкиИСМПТКСлужебныйКлиентСервер.ЗакодироватьШтрихкодДанныхBase64(ДанныеШтрихкода);
			ДанныеШтрихкода.Вставить("ФорматBase64", Истина);	
			СтруктураКодовМаркировки = Модуль_ИнтеграцияИСМПТКВызовСервера.ПолучитьКодыМаркировки(ДанныеШтрихкода);   
			
			//Если удалось разобрать код, вернется структура. Если нет - текст сообщения об ошибке.
			Если ТипЗнч(СтруктураКодовМаркировки) = Тип("Строка") Тогда
				Модуль_ОбщегоНазначенияИСМПТККлиентСерверПереопределяемый.СообщитьПользователю(СтруктураКодовМаркировки);
				Возврат;
			КонецЕсли;
		
			НоваяСтрокаТЧ = ИсходныйДокумент.Марки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧ, СтруктураКодовМаркировки, , "GTINВерхнегоУровня");
			НоваяСтрокаТЧ.Номенклатура = СтрокиПоиска[0].Номенклатура;
		КонецЕсли;		
	КонецЦикла;
	
КонецПроцедуры
 
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура УбратьНемаркированныйТовар(ДокументОбъект, ИмяТЧ)
	
	КоличествоСтрок = ДокументОбъект[ИмяТЧ].Количество() - 1;
	
	Пока КоличествоСтрок >= 0 Цикл            
		
		ТекущаяСтрока = ДокументОбъект[ИмяТЧ][КоличествоСтрок];
		
		Если ПолучитьТипМаркированнойПродукции(ТекущаяСтрока.Номенклатура) = 0 Тогда
			
			ДокументОбъект[ИмяТЧ].Удалить(ТекущаяСтрока);
			
		КонецЕсли;
		
		КоличествоСтрок = КоличествоСтрок - 1;
		
	КонецЦикла;	
	
КонецПроцедуры

Процедура АгрегацияКомплектующихВНаборы(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок, ИзМаркировки = Ложь, СтруктураСобранныхМарокИУпаковок)
	
	МодульОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");

	МассивКМНаборов = СтруктураСобранныхМарокИУпаковок.Наборы;
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("КМНабораСсылка");
	
	СтруктураПоискаШтрихкода = Новый Структура;
	СтруктураПоискаШтрихкода.Вставить("Штрихкод", Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());
	
	СобранныеДанныеПодбор = ДокументТСД.СобранныеДанныеПодбор.Выгрузить();	
	
	ТаблицаНоменклатурыХарактеристики = СобранныеДанныеПодбор.СкопироватьКолонки("Номенклатура, ХарактеристикаНоменклатуры");
	ТаблицаНоменклатурыХарактеристики.Очистить();     
	
	СтруктураПоискаНоменклатурыИХарактеристики = Новый Структура;
	СтруктураПоискаНоменклатурыИХарактеристики.Вставить("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
	СтруктураПоискаНоменклатурыИХарактеристики.Вставить("ХарактеристикаНоменклатуры", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	
	СтруктураПоискаВложенныхТоваров = Новый Структура;
	СтруктураПоискаВложенныхТоваров.Вставить("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
	СтруктураПоискаВложенныхТоваров.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	
	Для каждого КМНабораСсылка Из МассивКМНаборов Цикл
		
		ТаблицаНоменклатурыХарактеристики.Очистить();
		
		СтруктураПоиска.КМНабораСсылка = КМНабораСсылка;
		МассивСтрок = СобранныеДанныеПодбор.НайтиСтроки(СтруктураПоиска);
		
		Если МассивСтрок.Количество() Тогда    
					
			КМНабораОбъект = КМНабораСсылка.ПолучитьОбъект();
			
			МассивНоменклатурКомплектующих = Новый Массив;
			МассивХарактеристикКомплектующих = Новый Массив;
			
			Для каждого СтрокаМассива Из МассивСтрок Цикл
				
				Если Не ЗначениеЗаполнено(СтрокаМассива.КМНабораСсылка) Тогда
					СтрокаМассива.КМНабораСсылка = КМНабораСсылка;		
				КонецЕсли;	    
				
				РеквизитыВариантаКомплектации = МодульОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаМассива.ВариантКомплектацииНабора,
					"Владелец,Характеристика,Упаковка,Количество");
				
				ВариантКомплектацииНабора = СтрокаМассива.ВариантКомплектацииНабора;
				НоменклатураНабора = РеквизитыВариантаКомплектации.Владелец;
				ХарактеристикаНабора = РеквизитыВариантаКомплектации.Характеристика;
				УпаковкаНабора = РеквизитыВариантаКомплектации.Упаковка;
				КоличествоНаборов = РеквизитыВариантаКомплектации.Количество;
				
				СтруктураПоискаНоменклатурыИХарактеристики.Номенклатура = СтрокаМассива.Номенклатура;
				СтруктураПоискаНоменклатурыИХарактеристики.ХарактеристикаНоменклатуры = СтрокаМассива.ХарактеристикаНоменклатуры; 
				
				СтруктураПоискаВложенныхТоваров.Номенклатура = СтрокаМассива.Номенклатура;
				СтруктураПоискаВложенныхТоваров.Характеристика = СтрокаМассива.ХарактеристикаНоменклатуры;
				
				МассивСтрокНоменклатурИХарактеристик = ТаблицаНоменклатурыХарактеристики.НайтиСтроки(СтруктураПоискаНоменклатурыИХарактеристики);
				
				Если МассивСтрокНоменклатурИХарактеристик.Количество() = 0 Тогда
					
					НоваяСтрокаТаблицы = ТаблицаНоменклатурыХарактеристики.Добавить();
					НоваяСтрокаТаблицы.Номенклатура = СтрокаМассива.Номенклатура;
				    НоваяСтрокаТаблицы.ХарактеристикаНоменклатуры = СтрокаМассива.ХарактеристикаНоменклатуры;
					
				КонецЕсли;	
					
				СтруктураПоискаШтрихкода.Штрихкод = СтрокаМассива.КМСсылка;
				
				РезультатПоиска = КМНабораОбъект.ВложенныеШтрихкоды.НайтиСтроки(СтруктураПоискаШтрихкода);
				
				ТребуетсяЗапись = Ложь;
				
				Если РезультатПоиска.Количество() = 0 Тогда
					НовыйВложенныйШтрихкод = КМНабораОбъект.ВложенныеШтрихкоды.Добавить();
					НовыйВложенныйШтрихкод.Штрихкод = СтрокаМассива.КМСсылка;	
					ТребуетсяЗапись = Истина;	
				КонецЕсли;  
				
				Если Не ЗначениеЗаполнено(КМНабораОбъект.Номенклатура) И ЗначениеЗаполнено(НоменклатураНабора) Тогда
					КМНабораОбъект.Номенклатура = НоменклатураНабора;
					ТребуетсяЗапись = Истина;
				КонецЕсли; 
				
				Если Не ЗначениеЗаполнено(КМНабораОбъект.Характеристика) И ЗначениеЗаполнено(ХарактеристикаНабора) Тогда
					КМНабораОбъект.Характеристика = ХарактеристикаНабора;
					ТребуетсяЗапись = Истина;
				КонецЕсли; 
				
				Если Не КМНабораОбъект.ТипШтрихкода = Перечисления.ТипыШтрихкодов.GS1_DataMatrix Тогда
					КМНабораОбъект.ТипШтрихкода = Перечисления.ТипыШтрихкодов.GS1_DataMatrix;
					ТребуетсяЗапись = Истина;
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(КМНабораОбъект.Упаковка) И ЗначениеЗаполнено(УпаковкаНабора) Тогда
					КМНабораОбъект.Упаковка = УпаковкаНабора;
					ТребуетсяЗапись = Истина;
				КонецЕсли;  
				
				Если Не ЗначениеЗаполнено(КМНабораОбъект.Количество) И ЗначениеЗаполнено(КоличествоНаборов) Тогда	
					КМНабораОбъект.Количество = КоличествоНаборов;
					ТребуетсяЗапись = Истина;
				КонецЕсли;
				
				Если ТаблицаНоменклатурыХарактеристики.Количество() > 1 Тогда			 
					Если Не КМНабораОбъект.ТипУпаковки = Перечисления.ТипыУпаковок.МультитоварнаяУпаковка Тогда					
						КМНабораОбъект.ТипУпаковки = Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
						ТребуетсяЗапись = Истина;  
					КонецЕсли;
				Иначе  					
					Если Не КМНабораОбъект.ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка Тогда						
						КМНабораОбъект.ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;  
						ТребуетсяЗапись = Истина; 					
					КонецЕсли;  					
				КонецЕсли;
				
				Если ТребуетсяЗапись Тогда
					
					// ОбменДанными.Загрузка = Истина требуется для записи без проверок
					КМНабораОбъект.ОбменДанными.Загрузка = Истина;
					КМНабораОбъект.Записать();
										
				КонецЕсли;
								
			КонецЦикла; 
			
			МассивСтрокДокументаТСД = ДокументТСД.СобранныеДанныеПодбор.НайтиСтроки(СтруктураПоиска);
			
			Для каждого СтрокаДокументаТСД Из МассивСтрокДокументаТСД Цикл
				СтрокаДокументаТСД.КМНабораСсылка = КМНабораОбъект.Ссылка;	      
			КонецЦикла;
						
		КонецЕсли;	
		
	КонецЦикла;	
		
КонецПроцедуры

Процедура АгрегацияНаборовВУпакЛисты(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок, ИзМаркировки = Ложь, СтруктураСобранныхМарокИУпаковок)
	
	ТаблицаМарокВнеНабора = СтруктураСобранныхМарокИУпаковок.ТаблицаМарокВнеНабора;
	
	Шаблон = ДокументТСД.Шаблон;
	СоздаватьЕслиНеНайдена 	= Шаблон.МаркировкаСоздаватьСправочникКМЕслиНеНайден;	
	ЗаписыватьПолныйКМ      = Шаблон.МаркировкаЗаписыватьПолныйКМ;
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура КАК Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры КАК Характеристика,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.СерияСсылка КАК Серия,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_RawMrc КАК KM_RawMrc,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_TNVED КАК KM_TNVED,
	|	СУММА(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Количество) КАК Количество,
	|	ВЫБОР
	|		КОГДА ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМНабора = """"
	|			ТОГДА ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка
	|		ИНАЧЕ ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМНабора
	|	КОНЕЦ КАК КМНабора
	|ПОМЕСТИТЬ ДанныеПодбор
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор
	|ГДЕ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка = &Ссылка
	|	И НЕ ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМНабора = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|	И НЕ(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.Шаблон.ЗагрузкаСтрокПодбораСДокументами
	|				И ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.Шаблон.ВидДокументаНового <> """"
	|				И ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ПризнакПовторнойВыгрузки)
	|
	|СГРУППИРОВАТЬ ПО
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.СерияСсылка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_RawMrc,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_TNVED,
	|	ВЫБОР
	|		КОГДА ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМНабора = """"
	|			ТОГДА ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка
	|		ИНАЧЕ ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМНабора
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеПодбор.УпаковочныйЛист КАК Упаковка,
	|	ДанныеПодбор.Номенклатура КАК Номенклатура,
	|	ДанныеПодбор.Характеристика КАК Характеристика,
	|	ДанныеПодбор.Серия КАК Серия,
	|	ДанныеПодбор.KM_RawMrc КАК KM_RawMrc,
	|	ДанныеПодбор.KM_TNVED КАК KM_TNVED,
	|	ДанныеПодбор.КМНабора КАК КМНабора	
	|ИЗ
	|	ДанныеПодбор КАК ДанныеПодбор
	|ГДЕ
	|	ДанныеПодбор.Количество > 0
	|ИТОГИ ПО
	|	Упаковка";
		
	Запрос.УстановитьПараметр("Ссылка", ДокументТСД.Ссылка);	
	ВыборкаУпаковка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("УпаковочныйЛист", "");
	СтруктураПоискаКМ = Новый Структура;
	СтруктураПоискаКМ.Вставить("Штрихкод", Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка());

	Пока ВыборкаУпаковка.Следующий() Цикл 
		
		Если ЗначениеЗаполнено(ВыборкаУпаковка.Упаковка) Тогда
			
			УпакСсылка = ПолучитьСправочникСсылкаУпаковка(ВыборкаУпаковка.Упаковка, Истина, Неопределено);
			
			Если ЗначениеЗаполнено(УпакСсылка) Тогда
				
				УпакОбъект = УпакСсылка.ПолучитьОбъект();
				ТребуетсяЗапись = Ложь;
				
				ВыборкаНабора = ВыборкаУпаковка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаНабора.Следующий() Цикл			
					
					Если ЗначениеЗаполнено(ВыборкаНабора.КМНабора) Тогда
						
						НаборСсылка = ПолучитьСправочникСсылкаУпаковка(ВыборкаНабора.КМНабора, Истина, Неопределено);										
																
						ПроверитьМаркаНаходитсяВДругомКоробе(НаборСсылка, УпакОбъект.Ссылка);
						
						РезультатПоиска = УпакОбъект.ВложенныеШтрихкоды.НайтиСтроки(Новый Структура("Штрихкод", НаборСсылка));
						
						Если РезультатПоиска.Количество() = 0 Тогда
							
							НовыйВложенныйШтрихкод = УпакОбъект.ВложенныеШтрихкоды.Добавить();
							НовыйВложенныйШтрихкод.Штрихкод = НаборСсылка;
							
							ТребуетсяЗапись = Истина;
							
						КонецЕсли;
						
						Если ТаблицаМарокВнеНабора.Количество() Тогда
							
							СтруктураПоиска.УпаковочныйЛист = Строка(УпакОбъект.Ссылка);
							МассивСтрок = ТаблицаМарокВнеНабора.НайтиСтроки(СтруктураПоиска);
							
							Если МассиВСтрок.Количество() Тогда
								
								Для Каждого СтрокаМассива Из МассиВСтрок Цикл
									
									СтруктураПоискаКМ.Штрихкод = СтрокаМассива.КМСсылка;
									
									МассивСтрокКМ = УпакОбъект.ВложенныеШтрихкоды.НайтиСтроки(СтруктураПоискаКМ); 
									
									Если МассивСтрокКМ.Количество() = 0 Тогда 
										
										НовыйВложенныйШтрихкод = УпакОбъект.ВложенныеШтрихкоды.Добавить();
										НовыйВложенныйШтрихкод.Штрихкод = СтрокаМассива.КМСсылка;
									
										ТребуетсяЗапись = Истина;
										
	                                КонецЕсли;
									
								КонецЦикла;	
								
							КонецЕсли;
							
							
						КонецЕсли;	
																				
					КонецЕсли;
					
					МассивСтрокДокументаТСД = ДокументТСД.СобранныеДанныеПодбор.НайтиСтроки(СтруктураПоиска);
			
					Для Каждого СтрокаДокументаТСД Из МассивСтрокДокументаТСД Цикл
						СтрокаДокументаТСД.УпаковочныйЛистСсылка = УпакСсылка;	      
					КонецЦикла;

					
				КонецЦикла;
				
				Если ТребуетсяЗапись Тогда
					
					УпакОбъект.Записать();
					ОпределитьУпаковкуМоноМульти(УпакОбъект);
					
				КонецЕсли;	
				
			КонецЕсли; 
					
		КонецЕсли;
		
	КонецЦикла;    
	
	Если Не ИзМаркировки Тогда
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьДокументОснования(ЗаказПоставщикуСсылка)	
	
	Запрос = Новый Запрос;
	
	запрос.Текст = 
	"ВЫБРАТЬ
	|	ПриобретениеТоваровУслуг.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг КАК ПриобретениеТоваровУслуг
	|ГДЕ
	|	ПриобретениеТоваровУслуг.ЗаказПоставщику = &ЗаказПоставщику
	|	И ПриобретениеТоваровУслуг.Проведен";
	Запрос.УстановитьПараметр("ЗаказПоставщику", ЗаказПоставщикуСсылка);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Документы.ПриобретениеТоваровУслуг.ПустаяСсылка();
	Иначе
		
		Выборка = Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			ПриобретениеСсылка = Выборка.Ссылка;
			
		КонецЦикла;	
	
	КонецЕсли; 
	
	Возврат ПриобретениеСсылка;
	
КонецФункции

Функция ПолучитьВСДПоТовару(Номенклатура)
	
	ДанныеВСД = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДатаМобайл_ВСДПоТовару.ВСД КАК ИдентификаторПроисхожденияВЕТИС,
	|	ДатаМобайл_ВСДПоТовару.ВСД.СрокГодностиНачалоПериода КАК СрокГодности
	|ИЗ
	|	РегистрСведений.ДатаМобайл_ВСДПоТовару КАК ДатаМобайл_ВСДПоТовару
	|ГДЕ
	|	ДатаМобайл_ВСДПоТовару.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ДанныеВСД = Выборка;	
	КонецЕсли; 
	
	Возврат ДанныеВСД;
	
КонецФункции

Функция ЗаписатьВТЧДанныеОтчетаПроизводственнойЛинии(ВидПродукции)
	
	Если ВидПродукции = Перечисления.ВидыПродукцииИС.МолочнаяПродукцияПодконтрольнаяВЕТИС 
		Или ВидПродукции = Перечисления.ВидыПродукцииИС.МолочнаяПродукцияБезВЕТИС
		Или ВидПродукции = Перечисления.ВидыПродукцииИС.КормаДляЖивотныхПодконтрольныеВЕТИС
		Или ВидПродукции = Перечисления.ВидыПродукцииИС.УпакованнаяВода Тогда
		Возврат Истина;	
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ЭтоТабакПоВидыПродукцииИС(ВидМаркируемойПродукцииДокумента) Экспорт
	
	Модуль_ИнтеграцияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСКлиентСервер");
	Модуль_ОбщегоНазначенияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначенияИСКлиентСервер");
	
	Попытка
		ЭтоТабак = Модуль_ИнтеграцияИСКлиентСервер.ЭтоПродукцияМОТП(ВидМаркируемойПродукцииДокумента);	
