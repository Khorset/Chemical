Функция ПолучитьВложенныеТоварыВУпаковку(ДокументТСД)
	
	ТЗСобранныеДанныеУпаковки = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
	ТЗРезультат = ТЗСобранныеДанныеУпаковки.СкопироватьКолонки();
	ТЗСобранныеДанныеУпаковки.Свернуть("ЯчейкаСсылка, УпаковочныйЛист", "Количество");
	
	Для каждого СтрокаПодбора Из ТЗСобранныеДанныеУпаковки Цикл
		Если ЗначениеЗаполнено(СтрокаПодбора.УпаковочныйЛист) Тогда 			
			ТЗВложенности = ПолучитьВложенностьУпаковокПоШтрихкоду(СтрокаПодбора.УпаковочныйЛист);
			
			Для каждого СтрВложенности Из ТЗВложенности Цикл

				
				Если ЗначениеЗаполнено(СтрВложенности.Номенклатура) Тогда
					
					НоваяСтрока = ТЗРезультат.Добавить();
					
					НоваяСтрока.Номенклатура 			   = СтрВложенности.Номенклатура;
					НоваяСтрока.ХарактеристикаНоменклатуры = СтрВложенности.Характеристика;
					НоваяСтрока.ЕдиницаИзмерения = ?(ЗначениеЗаполнено(СтрВложенности.Ед), СтрВложенности.Ед, СтрВложенности.Номенклатура.ЕдиницаИзмерения);
					НоваяСтрока.СерияСсылка  	 = СтрВложенности.Серия;
					НоваяСтрока.ЯчейкаСсылка 	 = СтрокаПодбора.ЯчейкаСсылка;
					НоваяСтрока.Количество   	 = ?(СтрВложенности.Количество = 0, 1, СтрВложенности.Количество); //НоваяСтрока.Количество   	 = СтрокаПодбора.Количество * ?(СтрВложенности.Количество = 0, 1, СтрВложенности.Количество);
					
				КонецЕсли;
								
			КонецЦикла; 
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ТЗРезультат.Количество() = 0 Тогда
		
		ТЗСобранныеДанныеМарки = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		ТЗСобранныеДанныеМарки.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, СерияСсылка, ЯчейкаСсылка, УпаковочныйЛист, УпаковочныйЛистСсылка, КМНабора", "Количество");
		
		Для каждого СтрокаПодбора Из ТЗСобранныеДанныеМарки Цикл
					
			Если ЗначениеЗаполнено(СтрокаПодбора.УпаковочныйЛист)
				И Не ЗначениеЗаполнено(СтрокаПодбора.КМНабора) Тогда
				НоваяСтрока = ТЗРезультат.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПодбора);
			КонецЕсли;		
			
		КонецЦикла; 

	КонецЕсли;
	
	ТЗСобранныеДанныеМарки = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
	ТЗСобранныеДанныеМарки.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, СерияСсылка, ЯчейкаСсылка, УпаковочныйЛист", "Количество");
	
	Для каждого СтрокаПодбора Из ТЗСобранныеДанныеМарки Цикл
		Если Не ЗначениеЗаполнено(СтрокаПодбора.УпаковочныйЛист) Тогда
			НоваяСтрока = ТЗРезультат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПодбора);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТЗРезультат;
	
КонецФункции

Функция ПолучитьВложенныеТоварыВУпаковку_МаркировкаТоваровИСМП(ДокументТСД, ЭтоСозданиеВторогоДокументаМаркировки)
	
	ТЗСобранныеДанныеУпаковки = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД); 
	
	ТЗРезультат = ТЗСобранныеДанныеУпаковки.СкопироватьКолонки(); 
	
	МассивОбработанныхУпакЛистов = Новый Массив;
	
	Для каждого СтрокаПодбора Из ТЗСобранныеДанныеУпаковки Цикл
		
		Если Не ЭтоСозданиеВторогоДокументаМаркировки Тогда
			
			Если Не ЗначениеЗаполнено(СтрокаПодбора.КМНабора) И ЗначениеЗаполнено(СтрокаПодбора.КМСсылка) Тогда
				НоваяСтрока = ТЗРезультат.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПодбора);
			КонецЕсли;	
			
		Иначе    
			
			УпакЛист = СтрокаПодбора.УпаковочныйЛистСсылка;
			
			Если ЗначениеЗаполнено(УпакЛист) Тогда
				
				Если МассивОбработанныхУпакЛистов.Найти(УпакЛист) = Неопределено Тогда
					
					МассивОбработанныхУпакЛистов.Добавить(УпакЛист);	
							
					Для каждого ВложенныеШтрихкод Из УпакЛист.ВложенныеШтрихкоды Цикл
						
						Штрихкод = ВложенныеШтрихкод.Штрихкод;
						
						НоваяСтрока = ТЗРезультат.Добавить();
					
						НоваяСтрока.Номенклатура 			    = Штрихкод.Номенклатура;
						НоваяСтрока.ХарактеристикаНоменклатуры  = Штрихкод.Характеристика;
						НоваяСтрока.ЕдиницаИзмерения 			= ?(ЗначениеЗаполнено(Штрихкод.Упаковка), Штрихкод.Упаковка, Штрихкод.Номенклатура.ЕдиницаИзмерения);
						НоваяСтрока.СерияСсылка  	 			= Штрихкод.Серия;
						НоваяСтрока.Количество   	 			= ?(Штрихкод.Количество = 0, 1, Штрихкод.Количество); //НоваяСтрока.Количество   	 = СтрокаПодбора.Количество * ?(СтрВложенности.Количество = 0, 1, СтрВложенности.Количество);
					
					КонецЦикла;   
					
				КонецЕсли;	   
				
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТЗРезультат;
	
КонецФункции

Функция ПолучитьКМИзПулаПоЗаказНаЭмиссию(СсылкаНаДок) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПулКодовМаркировкиСУЗ.ШтрихкодУпаковки КАК ШтрихкодУпаковки,
	|	ПулКодовМаркировкиСУЗ.КодМаркировки КАК ЗначениеШтрихкода,
	|	ПулКодовМаркировкиСУЗ.ЗаказНаЭмиссию.Ссылка КАК Ссылка
	|ИЗ
	|	РегистрСведений.ПулКодовМаркировкиСУЗ КАК ПулКодовМаркировкиСУЗ
	|ГДЕ
	|	ПулКодовМаркировкиСУЗ.ЗаказНаЭмиссию = &ЗаказНаЭмиссию";
	
	Запрос.УстановитьПараметр("ЗаказНаЭмиссию", СсылкаНаДок);
	
	Возврат Запрос.Выполнить().Выгрузить();
		
КонецФункции

Функция ПолучитьТаблицуШКПоВидуПродукции(ТаблицаШтрихкодыУпаковок, ВидПродукцииИС) Экспорт
	
	ТаблицаВозврата = ТаблицаШтрихкодыУпаковок.СкопироватьКолонки();
	Модуль_ИнтеграцияИСУТКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСУТКлиентСервер");
	
	Для каждого СтрокаШК Из ТаблицаШтрихкодыУпаковок Цикл
		СпрШКСсылка = СтрокаШК.ШтрихкодУпаковки;
		ВидПродукцииИСШК = Неопределено;
		
		ТабВложенности = ПолучитьВложенностьУпаковокПоШтрихкоду(СпрШКСсылка.ЗначениеШтрихкода);
		
		Если ТабВложенности.Количество() = 0 Тогда
			Попытка ВидПродукцииИСШК = Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(СпрШКСсылка.Номенклатура.ОсобенностьУчета);
			Исключение КонецПопытки; 
		Иначе			
			Попытка ВидПродукцииИСШК = Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(ТабВложенности[0].Номенклатура.ОсобенностьУчета);
			Исключение КонецПопытки;
		КонецЕсли;
		
		Если ВидПродукцииИСШК = ВидПродукцииИС Тогда
			НоваяСтрока = ТаблицаВозврата.Добавить();
			НоваяСтрока.ШтрихкодУпаковки = СпрШКСсылка; 
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТаблицаВозврата;
	
КонецФункции

Функция ОписаниеGTINИСЭтоНаборИлиУпаковка(GTIN)
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИСТИНА КАК ЭтоНабор,
	|	ЛОЖЬ КАК ЭтоУпаковка
	|ИЗ
	|	РегистрСведений.ОписаниеGTINИС КАК ОписаниеGTINИС
	|ГДЕ
	|	ОписаниеGTINИС.GTIN ПОДОБНО ""%"" + &GTIN
	|	И ОписаниеGTINИС.ВидУпаковки = ЗНАЧЕНИЕ(Перечисление.ВидыУпаковокИС.Набор)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ЛОЖЬ КАК ЭтоНабор,
	|	ИСТИНА КАК ЭтоУпаковка
	|ИЗ
	|	РегистрСведений.ОписаниеGTINИС КАК ОписаниеGTINИС
	|ГДЕ
	|	ОписаниеGTINИС.GTIN ПОДОБНО ""%"" + &GTIN
	|	И (ОписаниеGTINИС.ВидУпаковки = ЗНАЧЕНИЕ(Перечисление.ВидыУпаковокИС.Групповая)
	|	ИЛИ ОписаниеGTINИС.ВидУпаковки = ЗНАЧЕНИЕ(Перечисление.ВидыУпаковокИС.Логистическая))";
	
	Запрос.УстановитьПараметр("GTIN", GTIN);
		
	Возврат Запрос.Выполнить().Выгрузить(); 
		
КонецФункции

Функция ПолучитьКодТНВЭДПоВидуПродукции(ОсобенностьУчета)
	
	Модуль_ИнтеграцияИСУТКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСУТКлиентСервер");
	
	ВидПродукции = Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(ОсобенностьУчета);
	
	КодТНВЭД = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КодыТНВЭДИСМП.КодТНВЭД КАК КодТНВЭД,
	|	КодыТНВЭДИСМП.ВидПродукции КАК ВидПродукции,
	|	КодыТНВЭДИСМП.НаименованиеПолное КАК НаименованиеПолное
	|ИЗ
	|	РегистрСведений.КодыТНВЭДИСМП КАК КодыТНВЭДИСМП
	|ГДЕ
	|	КодыТНВЭДИСМП.ВидПродукции = &ВидПродукции";
	
	Запрос.УстановитьПараметр("ВидПродукции", ВидПродукции);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		КодТНВЭД = Выборка.КодТНВЭД;	
	КонецЕсли; 
	
	Возврат КодТНВЭД;
	
КонецФункции

Функция ПересчитатьКоличествоЕдиницуИзмерения(Ссылка, ЭтоПриемка = Ложь)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДокументыТСД_ДанныеПодбора.Номенклатура КАК Номенклатура,
	|	ДокументыТСД_ДанныеПодбора.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	ДокументыТСД_ДанныеПодбора.KM_GTIN КАК KM_GTIN,
	|	ДокументыТСД_ДанныеПодбора.ЯчейкаСсылка КАК ЯчейкаСсылка,
	|	ДокументыТСД_ДанныеПодбора.СерияСсылка КАК СерияСсылка,
	|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.) КАК ЕдиницаИзмерения,
	|	ВЫБОР
	|		КОГДА ДокументыТСД_ДанныеПодбора.ЕдиницаИзмерения.Числитель = 0
	|				ИЛИ ДокументыТСД_ДанныеПодбора.ЕдиницаИзмерения.Числитель ЕСТЬ NULL
	|			ТОГДА 1
	|		ИНАЧЕ ДокументыТСД_ДанныеПодбора.ЕдиницаИзмерения.Числитель
	|	КОНЕЦ / ВЫБОР
	|		КОГДА ДокументыТСД_ДанныеПодбора.ЕдиницаИзмерения.Знаменатель = 0
	|				ИЛИ ДокументыТСД_ДанныеПодбора.ЕдиницаИзмерения.Знаменатель ЕСТЬ NULL
	|			ТОГДА 1
	|		ИНАЧЕ ДокументыТСД_ДанныеПодбора.ЕдиницаИзмерения.Знаменатель
	|	КОНЕЦ * ДокументыТСД_ДанныеПодбора.Количество КАК Количество
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК ДокументыТСД_ДанныеПодбора
	|ГДЕ
	|	ДокументыТСД_ДанныеПодбора.Ссылка = &Ссылка
	|	И НЕ(ДокументыТСД_ДанныеПодбора.Ссылка.Шаблон.ЗагрузкаСтрокПодбораСДокументами 
	|				И ДокументыТСД_ДанныеПодбора.Ссылка.Шаблон.ВидДокументаНового <> """"
	|				И ДокументыТСД_ДанныеПодбора.ПризнакПовторнойВыгрузки)";
	
	Если ЭтоПриемка Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "СобранныеДанныеПодбор", "СобранныеДанныеПриемка");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ВыгрузитьСобранныеДанныеПодбор(ДокументТСД) Экспорт
	
	РеквизитыШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(ДокументТСД.Шаблон, "ЗагрузкаСтрокПодбораСДокументами, ВидДокументаНового");
	
	Если РеквизитыШаблона.ЗагрузкаСтрокПодбораСДокументами И ЗначениеЗаполнено(РеквизитыШаблона.ВидДокументаНового) Тогда	
		СтруктураОтбора = Новый Структура("ПризнакПовторнойВыгрузки", Ложь);
		МассивСтрок = ДокументТСД.СобранныеДанныеПодбор.НайтиСтроки(СтруктураОтбора);
		
		СобранныеДанныеПодбор = ДокументТСД.СобранныеДанныеПодбор.Выгрузить(МассивСтрок);
	Иначе
		СобранныеДанныеПодбор = ДокументТСД.СобранныеДанныеПодбор.Выгрузить();
	КонецЕсли;
	
	Возврат СобранныеДанныеПодбор;
	
КонецФункции

Функция ВыгрузитьСобранныеДанныеПриемка(ДокументТСД) Экспорт
	
	РеквизитыШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(ДокументТСД.Шаблон, "ЗагрузкаСтрокПодбораСДокументами, ВидДокументаНового");
	
	Если РеквизитыШаблона.ЗагрузкаСтрокПодбораСДокументами И ЗначениеЗаполнено(РеквизитыШаблона.ВидДокументаНового) Тогда	
		СтруктураОтбора = Новый Структура("ПризнакПовторнойВыгрузки", Ложь);
		МассивСтрок = ДокументТСД.СобранныеДанныеПриемка.НайтиСтроки(СтруктураОтбора);
		
		СобранныеДанныеПриемка = ДокументТСД.СобранныеДанныеПриемка.Выгрузить(МассивСтрок);
	Иначе
		СобранныеДанныеПриемка = ДокументТСД.СобранныеДанныеПриемка.Выгрузить();
	КонецЕсли;
	
	Возврат СобранныеДанныеПриемка;
	
КонецФункции

#КонецОбласти