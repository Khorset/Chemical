Функция ПолучитьДокументМаркировки(ПараметрыДокумента, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок) Экспорт
	
	ИсходныйДокумент = ПараметрыДокумента.Док;
	
	Если ТипЗнч(ИсходныйДокумент) = Тип("ДокументОбъект.МаркировкаТоваровИСМП") Тогда
		УбратьНемаркированныйТовар(ИсходныйДокумент, "Товары");
	КонецЕсли;

	Шаблон = ДокументТСД.Шаблон;
	ВидДокумента 		= Шаблон.ВидДокумента;
	ВидДокументаНового 	= Шаблон.ВидДокументаНового;
	ПроверкаОтборРазмещение = Шаблон.ПроверкаОтборРазмещение;
	
	МаркиУказаныПоставщиком = Ложь;
	Если ВидДокумента = "ВозвратТоваровОтКлиента" Тогда
		Если ЭтоНовыйДокумент Тогда
		Иначе
			Попытка
				Если ИсходныйДокумент.ШтрихкодыУпаковок.Количество() > 0 Тогда
					МаркиУказаныПоставщиком = Истина;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЕсли;	
	КонецЕсли;	
	
	Если ВидДокумента = "ВозвратВОборотИСМП" 
		Или ВидДокументаНового = "ВозвратВОборотИСМП" 
		Или ВидДокумента = "ПеремаркировкаТоваровИСМП" 
		Или ВидДокументаНового = "ПеремаркировкаТоваровИСМП"Тогда
		
		Возврат ОбработатьВидДокументаВозвратВОборотИСМП(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок);
				
	ИначеЕсли ВидДокумента = "ЧекККМ" Или ВидДокументаНового = "ЧекККМ"
		Или ВидДокумента = "ЧекККМВозврат" Или ВидДокументаНового = "ЧекККМВозврат" Тогда
		
		Возврат ОбработатьВидДокументаЧекККМ(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок);
		
	ИначеЕсли ВидДокумента = "ПриобретениеТоваровУслуг" 
		Или (ВидДокумента = "ПриобретениеТоваровУслуг" И ВидДокументаНового = "ПриходныйОрдерНаТовары")
		Или (ВидДокумента = "ПриемкаТоваровИСМП" И Шаблон.ТабличнуюЧастьПриЗагрузкеПодбор = 0)
		Или (ВидДокумента = "ВозвратТоваровОтКлиента" И (МаркиУказаныПоставщиком Или Шаблон.ТабличнуюЧастьПриЗагрузкеПодбор = 0)) 
		Или (ВидДокумента = "ЗаказПоставщику" И ВидДокументаНового = "ПриобретениеТоваровУслуг") Тогда
		
		Возврат ОбработатьВидДокументаПриобретениеТоваровУслуг(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок);
		
	ИначеЕсли (ВидДокумента = "ПриемкаТоваровИСМП" И Шаблон.ТабличнуюЧастьПриЗагрузкеПодбор <> 0) Тогда
		
		Возврат ОбработатьВидДокументаПриемкаТоваровИСМП(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок);
		
	ИначеЕсли ВидДокумента = "РеализацияТоваровУслуг" 
		Или ВидДокумента = "ОтгрузкаТоваровИСМП" 
		Или ВидДокумента = "ВозвратТоваровПоставщику" 
		Или (ВидДокумента = "ВозвратТоваровОтКлиента" И (Не МаркиУказаныПоставщиком Или Шаблон.ТабличнуюЧастьПриЗагрузкеПодбор <> 0))
		Или ВидДокументаНового = "ВозвратТоваровОтКлиента"
		Или ВидДокументаНового = "РеализацияТоваровУслуг"
		Или ВидДокумента = "ВыводИзОборотаИСМП" 
		Или ВидДокументаНового = "ВыводИзОборотаИСМП" 
		Или ВидДокумента = "СписаниеКодовМаркировкиИСМП" 
		Или ВидДокументаНового = "СписаниеКодовМаркировкиИСМП"
		Или ВидДокумента = "ПередачаТоваровМеждуОрганизациями" 
		Или ВидДокументаНового = "ПередачаТоваровМеждуОрганизациями" 
		Или ВидДокумента = "ВозвратТоваровМеждуОрганизациями" 
		Или ВидДокументаНового = "ВозвратТоваровМеждуОрганизациями" 
		Или ВидДокумента = "КорректировкаРеализации"
		Или ВидДокумента = "РасходныйОрдерНаТовары" И ВидДокументаНового <> "МаркировкаТоваровИСМП"
		Или ВидДокументаНового = "РасходныйОрдерНаТовары" 
		Или ВидДокумента = "ПриходныйОрдерНаТовары"
		Или ВидДокументаНового = "ПриходныйОрдерНаТовары"	
		Или ВидДокумента = "ОтборРазмещениеТоваров" И ВидДокументаНового <> "МаркировкаТоваровИСМП" 
		Или ВидДокументаНового = "ОтборРазмещениеТоваров"
		Или ВидДокумента = "ЗаказНаЭмиссиюКодовМаркировкиСУЗ" И ВидДокументаНового <> "МаркировкаТоваровИСМП" 
		Или ВидДокументаНового = "ЗаказНаЭмиссиюКодовМаркировкиСУЗ"
		Или ВидДокумента = "ПеремещениеТоваров" 
		Или ВидДокументаНового = "ПеремещениеТоваров"
		Или ВидДокумента = "ПередачаТоваровХранителю" 
		Или ВидДокументаНового = "ПередачаТоваровХранителю"
		Или ВидДокумента = "ВнутреннееПотребление" 
		Или ВидДокументаНового = "ВнутреннееПотребление"
		Или ВидДокумента = "ПоступлениеТоваровОтХранителя" 
		Или ВидДокументаНового = "ПоступлениеТоваровОтХранителя"
		Или ВидДокумента = "ПоступлениеТоваров" 
		Или ВидДокументаНового = "ПоступлениеТоваров"
		Или ВидДокумента = "ОтгрузкаТоваровСХранения" 
		Или ВидДокументаНового = "ОтгрузкаТоваровСХранения"
		Или ВидДокумента = "ПриемкаТоваровНаХранение" 
		Или ВидДокументаНового = "ПриемкаТоваровНаХранение"
		Или ВидДокумента = "ПроизводствоБезЗаказа" 
		Или ВидДокументаНового = "ПроизводствоБезЗаказа"
		
		Тогда  
		
		Если (ВидДокумента = "РеализацияТоваровУслуг" И ВидДокументаНового = "РасходныйОрдерНаТовары"
				И ТипЗнч(ИсходныйДокумент) = Тип("ДокументОбъект.РасходныйОрдерНаТовары")) 
				Или ТипЗнч(ИсходныйДокумент) = Тип("ДокументОбъект.ПриходныйОрдерНаТовары") Тогда  
				
			Если ПараметрыДокумента.Свойство("ИсходныйДокумент") = Ложь Тогда
				ПараметрыДокумента.Вставить("ИсходныйДокумент", ДокументТСД.ИсходныйДокумент);		
			КонецЕсли;		
				
			Обработки.ДатаМобайл_АРМДиспетчера.ЗаполнитьНаОсновании(ПараметрыДокумента);		
				
		КонецЕсли;
		
		// ОТБОР РАЗМЕЩЕНИЕ ДЛЯ ПРОВЕРКИ СТАТУСА
		Если ВидДокумента = "ОтборРазмещениеТоваров" Тогда
			Попытка
				СтатусПослеЗагрузки = Обработки.ДатаМобайл_АРМДиспетчера.ПолучитьСтатусОтбораРазмещенияТоваровПослеЗагрузки(ДокументТСД, ИсходныйДокумент);
			Исключение
				СтатусПослеЗагрузки = Перечисления.СтатусыОтборовРазмещенийТоваров.ВыполненоБезОшибок;
			КонецПопытки;
			
			Если ПроверкаОтборРазмещение И СтатусПослеЗагрузки <> Неопределено Тогда
				Попытка ИсходныйДокумент.Статус = СтатусПослеЗагрузки; Исключение КонецПопытки;
			КонецЕсли;
		КонецЕсли;  
		
		Возврат ОбработатьВидДокументаРеализацияТоваровУслуг(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок);
		
	ИначеЕсли ВидДокумента = "МаркировкаТоваровИСМП" Или ВидДокументаНового = "МаркировкаТоваровИСМП" Тогда
		
		Возврат ОбработатьВидДокументаМаркировкаТоваровИСМП(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок, ПараметрыДокумента);
		
	ИначеЕсли ВидДокумента = "ДатаМобайл_УпаковочныйЛист" Тогда
		
		ОбработатьВидДокументаДатаМобайл_УпаковочныйЛист(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, Неопределено, СтрокаОшибок);
		Возврат "";
		
	КонецЕсли;
	
КонецФункции // ()

Функция ПолучитьТЗПоДаннымТСДиГрупповымДокументам(ДокументТСДСсылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСДЗадания.Задание КАК Задание,
	|	ДатаМобайл_ДокументыТСДЗадания.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТ_Задание
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.Задания КАК ДатаМобайл_ДокументыТСДЗадания
	|ГДЕ
	|	ДатаМобайл_ДокументыТСДЗадания.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура КАК Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка КАК ЦРПТМарка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист КАК УпаковочныйЛист,
	|	СУММА(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Количество) КАК Количество
	|ПОМЕСТИТЬ ВТ_ПодборТСДГрязный
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор
	|ГДЕ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка = &Ссылка
	|	И НЕ(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.Шаблон.ЗагрузкаСтрокПодбораСДокументами
	|				И ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.Шаблон.ВидДокументаНового <> """"
	|				И ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ПризнакПовторнойВыгрузки)
	|
	|СГРУППИРОВАТЬ ПО
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЕдиницаИзмерения,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	РеализацияТоваровУслугТовары.Характеристика КАК Характеристика,
	|	РеализацияТоваровУслугТовары.Количество КАК Количество,
	|	РеализацияТоваровУслугТовары.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ТоварыПоДокументам
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ВТ_Задание.Задание КАК Задание
	|			ИЗ
	|				ВТ_Задание КАК ВТ_Задание)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ОсобенностьУчета <> ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.ПустаяСсылка)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ОсобенностьУчета <> ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.АлкогольнаяПродукция)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ОсобенностьУчета <> ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.СодержитДрагоценныеМатериалы)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ОсобенностьУчета <> ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.КиЗГИСМ)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ОсобенностьУчета <> ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.ПодконтрольнаяПродукцияВЕТИС)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ОсобенностьУчета <> ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.ОрганизациейПродавцом)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ОсобенностьУчета <> ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.ОрганизациейПоАгентскойСхеме)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ОсобенностьУчета <> ЗНАЧЕНИЕ(Перечисление.ОсобенностиУчетаНоменклатуры.Партнером)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПодборТСДГрязный.Номенклатура КАК Номенклатура,
	|	ВТ_ПодборТСДГрязный.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	ВТ_ПодборТСДГрязный.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ВТ_ПодборТСДГрязный.ЦРПТМарка КАК ЦРПТМарка,
	|	ВТ_ПодборТСДГрязный.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ВТ_ПодборТСДГрязный.Количество КАК Количество
	|ПОМЕСТИТЬ ВТ_ПодборТСД
	|ИЗ
	|	ВТ_ПодборТСДГрязный КАК ВТ_ПодборТСДГрязный
	|ГДЕ
	|	ВТ_ПодборТСДГрязный.Количество <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПодборТСД.Номенклатура КАК Номенклатура,
	|	ВТ_ПодборТСД.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	ВТ_ПодборТСД.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ВТ_ПодборТСД.ЦРПТМарка КАК ЦРПТМарка,
	|	СУММА(ВТ_ТоварыПоДокументам.Количество) КАК КоличествоПоДокументу,
	|	ВТ_ТоварыПоДокументам.Ссылка КАК Ссылка,
	|	ВТ_ПодборТСД.Количество КАК КоличествоПоТСД,
	|	ВТ_Задание.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТ_Данные
	|ИЗ
	|	ВТ_ТоварыПоДокументам КАК ВТ_ТоварыПоДокументам
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_ПодборТСД КАК ВТ_ПодборТСД
	|		ПО ВТ_ТоварыПоДокументам.Номенклатура = ВТ_ПодборТСД.Номенклатура
	|			И ВТ_ТоварыПоДокументам.Характеристика = ВТ_ПодборТСД.ХарактеристикаНоменклатуры
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_Задание КАК ВТ_Задание
	|		ПО ВТ_ТоварыПоДокументам.Ссылка = ВТ_Задание.Задание
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ПодборТСД.Номенклатура,
	|	ВТ_ПодборТСД.ХарактеристикаНоменклатуры,
	|	ВТ_ПодборТСД.ЕдиницаИзмерения,
	|	ВТ_ПодборТСД.ЦРПТМарка,
	|	ВТ_ТоварыПоДокументам.Ссылка,
	|	ВТ_ПодборТСД.Количество,
	|	ВТ_Задание.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Данные.Номенклатура КАК Номенклатура,
	|	ВТ_Данные.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	ВТ_Данные.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ВТ_Данные.ЦРПТМарка КАК ЦРПТМарка,
	|	ВТ_Данные.КоличествоПоДокументу КАК КоличествоПоДокументу,
	|	ВТ_Данные.Ссылка КАК Ссылка,
	|	ВТ_Данные.КоличествоПоТСД КАК КоличествоПоТСД
	|ИЗ
	|	ВТ_Данные КАК ВТ_Данные
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ВТ_Данные.Номенклатура) = ТИП(Справочник.номенклатура)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_Данные.НомерСтроки";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументТСДСсылка);
	
	ЭтоКАДляКазахстана = ДатаМобайл_ОбщийМодуль.ПроверкаИмениКонфигурации("КомплекснаяАвтоматизацияДляКазахстана");
	ЭтоУТДляКазахстана = ДатаМобайл_ОбщийМодуль.ПроверкаИмениКонфигурации("УправлениеТорговлейДляКазахстана");
	
	Если ЭтоКАДляКазахстана Или ЭтоУТДляКазахстана Тогда
		ДатаМобайл_ОбщийМодуль.СкорректироватьЗапросЕслиЭтоКАДляКазахстана(Запрос.Текст, "ПолучитьТЗПоДаннымТСДиГрупповымДокументам");	
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ВнестиВбазуНесколькоДокументов(МассивДокументов, ДокументТСД, ПараметрыШаблона) Экспорт
	
	Модуль_ШтрихкодированиеИС 		= ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИС");
	
	СтрокаОшибок            		= "";
	Шаблон							= ДокументТСД.Шаблон;
	СоздаватьЕслиНеНайдена 			= ПараметрыШаблона.МаркировкаСоздаватьСправочникКМЕслиНеНайден;
	ПривязыватьGTIN 				= ПараметрыШаблона.МаркировкаПривязыватьGTINКакШтрихкод;
	ТЧПриЗагрузкеПодбор     		= ПараметрыШаблона.ТабличнуюЧастьПриЗагрузкеПодбор;
	ИмяТЧПодбор     				= ПараметрыШаблона.ИмяТабличнойЧастиПодбор;
	ВидДокумента					= ПараметрыШаблона.ВидДокумента;
	ВидДокументаНового				= ПараметрыШаблона.ВидДокументаНового;
	МножествоДокументовКакЗадание   = ПараметрыШаблона.МножествоДокументовКакЗадание;
	ИмяТабличнойЧастиПриемка		= ПараметрыШаблона.ИмяТабличнойЧастиПриемка;
	
	// нужна для создания КМ в базе 1с
	СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, ПривязыватьGTIN);
	
	ТЗ = ПолучитьТЗПоДаннымТСДиГрупповымДокументам(ДокументТСД.Ссылка);
	
	ТЗДляИзменений = ТЗ.Скопировать();
	ТЗДляИзменений.Колонки.Добавить("КМСсылка");
	
	ЭтоПоследнийДокумент = Ложь;
	
	ЭтоРеализацияПоНесколькимЗаказам = Ложь;
	
	Если МножествоДокументовКакЗадание 
		 И ВидДокумента = "ЗаказКлиента"
		 И ВидДокументаНового = "РеализацияТоваровУслуг" Тогда
		 
		 ЭтоРеализацияПоНесколькимЗаказам = Истина;
		 
		 ПараметрыДокумента = Новый Структура;
		 
		 ПараметрыДокумента.Вставить("Пользователь", ПараметрыСеанса.ТекущийПользователь);	
		 ПараметрыДокумента.Вставить("ИмяТЧПодбор",  ИмяТЧПодбор);
		 ПараметрыДокумента.Вставить("ИмяТЧПриемка", ИмяТабличнойЧастиПриемка);
		 ДокументТСД.ИсходныйДокумент = Документы.ЗаказКлиента.ПустаяСсылка();
		 ПараметрыДокумента.Вставить("Об", ДокументТСД); 	 
		 
		 Если ЗначениеЗаполнено(ДокументТСД.НовыйДокумент) Тогда
			 ДокументРеализации = ДокументТСД.НовыйДокумент.ПолучитьОбъект();
		 Иначе
			 ДокументРеализации = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
		 КонецЕсли;
		
		 ДокументРеализации.Дата = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
		 ДокументРеализации.Заполнить(МассивДокументов[0]); 		
		 ДокументРеализации.СкидкиРассчитаны = Истина;
		 ДокументРеализации.РеализацияПоЗаказам = Истина;
		 ДокументРеализации.ЗаказКлиента = Документы.ЗаказКлиента.ПустаяСсылка();
		 ИзменитьРеквизитыШапкиИзДополнительныхФорм(ДокументРеализации, Шаблон, ДокументТСД);		 
		 ДокументРеализации.Товары.Очистить();
		 ДокументРеализации.ШтрихкодыУпаковок.Очистить();
		 
		 // Заполняем ТЧ Штрихкоды
		 
		 ТаблицаМарок = ТЗ.ВыгрузитьКолонку("ЦРПТМарка");
		 
		 Для Каждого КМ Из ТаблицаМарок Цикл
			 
			 НоваяСтрока = ДокументРеализации.ШтрихкодыУпаковок.Добавить();
			 НоваяСтрока.ШтрихкодУпаковки = ПолучитьСправочникСсылкаМарка(КМ, СтрДлина(КМ), "", "", СоздаватьЕслиНеНайдена, Неопределено, Шаблон)
			 
		 КонецЦикла;	 
		 
		 // Заполняем ТЧ Товары
		 
		 Для каждого СтрокаЗаказа Из МассивДокументов Цикл
			 
			 Для Каждого СтрокаТЧ Из СтрокаЗаказа.Товары Цикл 
			 
			 	НоваяСтрока = ДокументРеализации.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			 	НоваяСтрока.ЗаказКлиента = СтрокаЗаказа;
			 
			 	Обработки.ДатаМобайл_АРМДиспетчера.ОбработатьНовуюСтрокуТЧ(ПараметрыДокумента, ДокументРеализации, ИмяТЧПодбор, НоваяСтрока);
				
			 КонецЦикла;	
				
		 КонецЦикла;		 
		 
		 Попытка
			 ДокументРеализации.Записать(РежимЗаписиДокумента.Проведение);	
		 Исключение
			 ДокументРеализации.Записать(РежимЗаписиДокумента.Запись);
		 КонецПопытки; 
		 
		 ДокументТСД.НовыйДокумент = ДокументРеализации.Ссылка;
		 
		 МассивДокументов.Очистить();
		 
		 МассивДокументов.Добавить(ДокументРеализации.Ссылка); 
		 
		 Возврат;
		 
	КонецЕсли;
	
	Для каждого СтрокаДокумент Из МассивДокументов Цикл // Раскидываю товары по документам, если есть остатки или нет позиции в документах, тогда всё закидываю в последний документ
		ТЗОтбораПоДокументу = ТЗДляИзменений.Скопировать(Новый Структура("Ссылка", СтрокаДокумент));
		
		ЭтоПоследнийДокумент = МассивДокументов[МассивДокументов.Количество() - 1] = СтрокаДокумент;
		
		Для каждого СтрокаОтбораПоДокументу Из ТЗОтбораПоДокументу Цикл
			
			СтрокиПоиска = ТЗОтбораПоДокументу.НайтиСтроки(Новый Структура("Номенклатура, ХарактеристикаНоменклатуры", СтрокаОтбораПоДокументу.Номенклатура, СтрокаОтбораПоДокументу.ХарактеристикаНоменклатуры));
			
			КоличествоПоДокументу = СтрокаОтбораПоДокументу.КоличествоПоДокументу;
			
			Если СтрокаОтбораПоДокументу.ЦРПТМарка = "" Тогда
				КоличествоПоТСД	= СтрокаОтбораПоДокументу.КоличествоПоТСД;
				КоличествоПоТСД = КоличествоПоТСД - КоличествоПоДокументу;
				
				Если КоличествоПоТСД < 0 Тогда
					КоличествоПоТСД = 0;
					СтрокаОтбораПоДокументу.КоличествоПоДокументу = СтрокаОтбораПоДокументу.КоличествоПоТСД;
				КонецЕсли; 
				
				СтрокиТЗИзменений = ТЗДляИзменений.НайтиСтроки(Новый Структура("Номенклатура, ХарактеристикаНоменклатуры", СтрокаОтбораПоДокументу.Номенклатура, СтрокаОтбораПоДокументу.ХарактеристикаНоменклатуры));
				
				Если СтрокиТЗИзменений.Количество() Тогда
					Для каждого СтрокаДляИзменений Из СтрокиТЗИзменений Цикл
						Если СтрокаДляИзменений.Ссылка = СтрокаДокумент И Не ЭтоПоследнийДокумент И КоличествоПоТСД = 0 Тогда
							ТЗДляИзменений.Удалить(СтрокаДляИзменений);	
						Иначе	
							СтрокаДляИзменений.КоличествоПоТСД = КоличествоПоТСД;
						КонецЕсли; 	
					КонецЦикла; 	
				КонецЕсли;			
			Иначе
				
				КоличествоПоТСД	= СтрокиПоиска.Количество();
				
				Если КоличествоПоТСД > КоличествоПоДокументу Тогда
					Пока КоличествоПоТСД > КоличествоПоДокументу Цикл
						КоличествоПоТСД = КоличествоПоТСД - 1;
						ТЗОтбораПоДокументу.Удалить(СтрокиПоиска[КоличествоПоТСД]);	
					КонецЦикла;		
				КонецЕсли;
				
				ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(СтрокаОтбораПоДокументу.ЦРПТМарка);		
				
				Если ДанныеУпаковки <> Неопределено Тогда
					СтрокаОтбораПоДокументу.КМСсылка = ДанныеУпаковки.Ссылка;		
				КонецЕсли; 
				
				// Удаляем по марке строки по другим документам
				СтрокиТЗИзменений = ТЗДляИзменений.НайтиСтроки(Новый Структура("ЦРПТМарка", СтрокаОтбораПоДокументу.ЦРПТМарка));
				
				Если СтрокиТЗИзменений.Количество() Тогда
					Для каждого СтрокаДляУдаления Из СтрокиТЗИзменений Цикл
						ТЗДляИзменений.Удалить(СтрокаДляУдаления);	
					КонецЦикла; 	
				КонецЕсли;
				
				СтрокаОтбораПоДокументу.КоличествоПоДокументу = 1;
				
			КонецЕсли; 
			
		КонецЦикла;
		
		Если ЭтоПоследнийДокумент И ТЗДляИзменений.Количество() Тогда			
			ТЗДляИзменений.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЦРПТМарка, КМСсылка", "КоличествоПоТСД, КоличествоПоДокументу");
			
			Для каждого СтрокаДобавления Из ТЗДляИзменений Цикл
				НоваяСтрока = Неопределено;
				
				Если СтрокаДобавления.ЦРПТМарка <> "" Тогда					
					НоваяСтрока = ТЗОтбораПоДокументу.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДобавления);
					
					ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(НоваяСтрока.ЦРПТМарка);		
					
					Если ДанныеУпаковки <> Неопределено Тогда
						НоваяСтрока.КМСсылка = ДанныеУпаковки.Ссылка;		
					КонецЕсли;
				Иначе
					НайденнаяСтрока = ТЗОтбораПоДокументу.НайтиСтроки(Новый Структура("Номенклатура, ХарактеристикаНоменклатуры", СтрокаДобавления.Номенклатура, СтрокаДобавления.ХарактеристикаНоменклатуры));
					Если НайденнаяСтрока.Количество() = 0 Тогда
						НоваяСтрока = ТЗОтбораПоДокументу.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДобавления);
						НоваяСтрока.КоличествоПоДокументу = СтрокаДобавления.КоличествоПоТСД;
					Иначе
						НайденнаяСтрока[0].КоличествоПоДокументу = НайденнаяСтрока[0].КоличествоПоТСД;	
					КонецЕсли; 
				КонецЕсли; 
				
				Если НоваяСтрока <> Неопределено И Не ЗначениеЗаполнено(НоваяСтрока.Ссылка) Тогда
					НоваяСтрока.Ссылка = СтрокаДокумент;	
				КонецЕсли; 
			КонецЦикла;  
		КонецЕсли;
		
		ТЗОтбораПоДокументу.Колонки.КоличествоПоДокументу.Имя = "Количество";
		
		Если ТЗОтбораПоДокументу.Количество() = 0 Тогда
			Продолжить;	
		КонецЕсли;
		
		СтрокаДокументОбъект = СтрокаДокумент.ПолучитьОбъект();
		
		ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, СтрокаДокументОбъект, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);
		
		СоздатьСтрокиШтрихкодовУпаковокПоМассиву(ТЗОтбораПоДокументу.ВыгрузитьКолонку("КМСсылка"), СтрокаДокументОбъект);
		
		КопияТЧ = СтрокаДокументОбъект[ИмяТЧПодбор].Выгрузить();
		
		Если ТЧПриЗагрузкеПодбор <> 0 Тогда			
			ТЗОтбораПоДокументу.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения", "Количество");
			
			СтруктураДанных = Новый Структура;
			СтруктураДанных.Вставить("ТЗОтбораПоДокументу"	, ТЗОтбораПоДокументу);
			СтруктураДанных.Вставить("Шаблон"				, Шаблон);
			СтруктураДанных.Вставить("ДокументТСД"			, ДокументТСД);
			
			ОбработатьИзменениеТЧПодбор(СтруктураДанных, СтрокаДокументОбъект, ИмяТЧПодбор, КопияТЧ, Истина);
		КонецЕсли;
		
		Попытка
			ВыполнитьДопОбработкуДокумента(СтрокаДокументОбъект, ДокументТСД, Шаблон, Ложь);
		Исключение 
		КонецПопытки;
		
		СтрокаДокументОбъект.Записать();
		
		ВидМаркируемойПродукцииДокументаМассив = ПолучитьВидПродукцииИСПоМассивуТоваров(ТЗОтбораПоДокументу.ВыгрузитьКолонку("Номенклатура"));
		
		Для каждого ВидМаркируемойПродукции Из ВидМаркируемойПродукцииДокументаМассив Цикл
			
			РезультатПроверки = ПолучитьРезультатПроверкиДокумента(СтрокаДокумент ,Шаблон, ВидМаркируемойПродукции, СтрокаОшибок);
			
			Если РезультатПроверки <> Неопределено Тогда 
				ОбработатьМаркируемыеТовары(РезультатПроверки.ПодобраннаяМаркируемаяПродукция);
				ВнестиДанныеОСобранныхМарках(РезультатПроверки.ДеревоМаркированнойПродукции, РезультатПроверки.ПодобраннаяМаркируемаяПродукция, СтруктураСобранныхМарокИУпаковок);
				СохранитьРезультатПроверкиДокумента(СтрокаДокумент, РезультатПроверки, ВидМаркируемойПродукции, Шаблон, ДокументТСД);
			Иначе
				Если ЗначениеЗаполнено(СтрокаОшибок) Тогда
				КонецЕсли;	
			КонецЕсли;
			
		КонецЦикла; 
			
	КонецЦикла; 
	
КонецПроцедуры

Функция ОбработатьВидДокументаПриобретениеТоваровУслуг(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок)
	
	Шаблон = ДокументТСД.Шаблон;
	
	РеквизитыШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(Шаблон);
	
	СоздаватьЕслиНеНайдена 						= РеквизитыШаблона.МаркировкаСоздаватьСправочникКМЕслиНеНайден;
	ПривязыватьGTIN 							= РеквизитыШаблона.МаркировкаПривязыватьGTINКакШтрихкод;
	ТЧПриЗагрузкеПодбор 						= РеквизитыШаблона.ТабличнуюЧастьПриЗагрузкеПодбор;
	ИмяТЧПодбор 								= РеквизитыШаблона.ИмяТабличнойЧастиПодбор;
	ПроверкаБезСертификата						= РеквизитыШаблона.МаркировкаПроверкаБезСертификатаИС;
	ЭтоПриемка              					= Истина;
	ИгнорироватьНесоответствиеТовараПоЕАNиКМ 	= РеквизитыШаблона.МаркировкаИгнорироватьНесоответствиеТовараПоЕАNиКМ;
	ПерезаписатьХешУпаковок 					= РеквизитыШаблона.МаркировкаПерезаписатьХешУпаковок;
	РежимКомплектации 		 					= РеквизитыШаблона.РежимКомплектации;

	ИмяИсходногоДокумента = ИсходныйДокумент.Метаданные().Имя;
	
	Если ИмяИсходногоДокумента = "ПриемкаТоваровИСМП" Или ИмяИсходногоДокумента = "ПриходныйОрдерНаТовары" Тогда
		ЭтоПриемка = Ложь;	
	КонецЕсли; 
	
	ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);
	
	Если ЭтоНовыйДокумент Тогда
		ЗаполнитьШапкуДокумента(Новый Структура("Об, Док", ДокументТСД, ИсходныйДокумент));
		ПеренестиВДокументНовыеЗначенияРеквизитов(ДокументТСД, ИсходныйДокумент, Шаблон);		
	КонецЕсли;
	
	СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, ПривязыватьGTIN, ИгнорироватьНесоответствиеТовараПоЕАNиКМ);
	
	Если ТЧПриЗагрузкеПодбор <> 1 Тогда	
		ОчиститьСсылкиШтрихкодовУпаковок(ИсходныйДокумент);
	КонецЕсли;	
	
	МассивНеизвестныхДляПриемки = Новый Массив();
	МассивНепроверенныхДляПриемки = Новый Массив();
	
	Если РежимКомплектации = 1 Тогда
		СоздатьСтрокиШтрихкодовУпаковокПоМассиву_Упаковки(СтруктураСобранныхМарокИУпаковок.Наборы, ИсходныйДокумент, МассивНеизвестныхДляПриемки, ПроверкаБезСертификата, , МассивНепроверенныхДляПриемки);
	КонецЕсли;
	
	ТЗУпаковок = Новый ТаблицаЗначений;
	Если СтруктураСобранныхМарокИУпаковок.Марки.Количество() > 0 Тогда
		ТЗУпаковок = ПолучитьУпаковкуПоМарке(СтруктураСобранныхМарокИУпаковок.Марки);	
	КонецЕсли;
	
	СоздатьСтрокиШтрихкодовУпаковокПоМассиву_Упаковки(СтруктураСобранныхМарокИУпаковок.Короба, ИсходныйДокумент, МассивНеизвестныхДляПриемки, ПроверкаБезСертификата, , МассивНепроверенныхДляПриемки);
	СоздатьСтрокиШтрихкодовУпаковокПоМассиву(СтруктураСобранныхМарокИУпаковок.Марки, ИсходныйДокумент, МассивНеизвестныхДляПриемки, ПроверкаБезСертификата, , МассивНепроверенныхДляПриемки, , ТЗУпаковок);
	
	Если ТЧПриЗагрузкеПодбор <> 0 Тогда
		КопияТЧ = ИсходныйДокумент[ИмяТЧПодбор].Выгрузить();
		
		ОбработатьИзменениеТЧПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, КопияТЧ);		
	КонецЕсли;
	
	Попытка
		ИзменитьРеквизитыШапкиИзДополнительныхФорм(ИсходныйДокумент, Шаблон, ДокументТСД);
	Исключение 
	КонецПопытки;
	
	Попытка
		ВыполнитьДопОбработкуДокумента(ИсходныйДокумент, ДокументТСД, Шаблон, ЭтоНовыйДокумент)
	Исключение 
	КонецПопытки;
		
	ИсходныйДокумент.Записать();
	
	ВидМаркируемойПродукцииДокументаМассив = ПолучитьВидПродукцииИСДокумента(ИсходныйДокумент, ИмяТЧПодбор);
	
	Для каждого ВидМаркируемойПродукции Из ВидМаркируемойПродукцииДокументаМассив Цикл
		
		РезультатПроверки = ПолучитьРезультатПроверкиДокумента(ИсходныйДокумент, Шаблон, ВидМаркируемойПродукции, СтрокаОшибок);
		
		МассивВСтатусеНеПроверялась = Новый Массив;
		
		Если РезультатПроверки <> Неопределено Тогда
			ОбработатьМаркируемыеТовары(РезультатПроверки.ПодобраннаяМаркируемаяПродукция);
			ВнестиДанныеОСобранныхМарках(РезультатПроверки.ДеревоМаркированнойПродукции, РезультатПроверки.ПодобраннаяМаркируемаяПродукция, СтруктураСобранныхМарокИУпаковок,
			, ЭтоПриемка, МассивНеизвестныхДляПриемки, МассивНепроверенныхДляПриемки, ТЧПриЗагрузкеПодбор, ИсходныйДокумент, МассивВСтатусеНеПроверялась);
			ОбработатьУпаковкиПриемка(РезультатПроверки.ДеревоМаркированнойПродукции);
			ОбработатьМаркируемыеТоварыПриемка(РезультатПроверки.ПодобраннаяМаркируемаяПродукция);
			СохранитьРезультатПроверкиДокумента(ИсходныйДокумент, РезультатПроверки, ВидМаркируемойПродукции, Шаблон, ДокументТСД);
		Иначе
			Если ЗначениеЗаполнено(СтрокаОшибок) Тогда
				Возврат Неопределено;
			КонецЕсли;		
		КонецЕсли;
		
	КонецЦикла;
	
	Если ПерезаписатьХешУпаковок Тогда
		Попытка ПерезаписатьХешУпаковок(СтруктураСобранныхМарокИУпаковок, Истина); Исключение КонецПопытки;	
	КонецЕсли;
		
	Если РеквизитыШаблона.ВидДокументаНового = "" Тогда
		ДокументТСД.ИсходныйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	Иначе		
		ДокументТСД.НовыйДокумент = ИсходныйДокумент.Ссылка;		
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	КонецЕсли;
		
КонецФункции // ()

Функция ОбработатьВидДокументаПриемкаТоваровИСМП(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок)
	
	Шаблон = ДокументТСД.Шаблон;
	ТЧПриЗагрузкеПодбор 	= Шаблон.ТабличнуюЧастьПриЗагрузкеПодбор;
	ИмяТЧПодбор 			= Шаблон.ИмяТабличнойЧастиПодбор;
	СоздаватьЕслиНеНайдена 	= Шаблон.МаркировкаСоздаватьСправочникКМЕслиНеНайден;	
	ПривязыватьGTIN 		= Шаблон.МаркировкаПривязыватьGTINКакШтрихкод;
	
	УстановитьGTIN(ДокументТСД);
	ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);
	
	СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, ПривязыватьGTIN);
	
	Если ЭтоНовыйДокумент Тогда
		ЗаполнитьШапкуДокумента(Новый Структура("Об, Док", ДокументТСД, ИсходныйДокумент));
		ПеренестиВДокументНовыеЗначенияРеквизитов(ДокументТСД, ИсходныйДокумент, Шаблон);		
	КонецЕсли;
	
	Если ТЧПриЗагрузкеПодбор <> 0 Тогда
		ОбработатьИзменениеТЧПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор);
	КонецЕсли;

	Попытка
		ИзменитьРеквизитыШапкиИзДополнительныхФорм(ИсходныйДокумент, Шаблон, ДокументТСД);
	Исключение 
	КонецПопытки;
	
	Попытка
		ВыполнитьДопОбработкуДокумента(ИсходныйДокумент, ДокументТСД, Шаблон, ЭтоНовыйДокумент)
	Исключение 
	КонецПопытки;
			
	ИсходныйДокумент.Записать();
	
	ВидМаркируемойПродукцииДокументаМассив = ПолучитьВидПродукцииИСДокумента(ИсходныйДокумент,ИмяТЧПодбор);
	
	Для каждого ВидМаркируемойПродукции Из ВидМаркируемойПродукцииДокументаМассив Цикл
		
		РезультатПроверки = ПолучитьРезультатПроверкиДокумента(ИсходныйДокумент, Шаблон, ВидМаркируемойПродукции, СтрокаОшибок);
			
		Если РезультатПроверки <> Неопределено Тогда			
			ДеревоМаркированнойПродукцииДоЗагрузкиДанных = РезультатПроверки.ДеревоМаркированнойПродукции;
			
			СоздатьСтрокиШтрихкодовУпаковокПоМассиву_Упаковки(СтруктураСобранныхМарокИУпаковок.Короба, ИсходныйДокумент);
			СоздатьСтрокиШтрихкодовУпаковокПоМассиву(СтруктураСобранныхМарокИУпаковок.Марки, ИсходныйДокумент);
			
			ИсходныйДокумент.Записать();
			
			РезультатПроверки = ПолучитьРезультатПроверкиДокумента(ИсходныйДокумент, Шаблон, ВидМаркируемойПродукции, СтрокаОшибок);
			
			Если РезультатПроверки <> Неопределено Тогда				
				РезультатПроверки.ДеревоМаркированнойПродукции = ДеревоМаркированнойПродукцииДоЗагрузкиДанных;
				
				ОбработатьМаркируемыеТовары(РезультатПроверки.ПодобраннаяМаркируемаяПродукция);
				ВнестиДанныеОСобранныхМарках(РезультатПроверки.ДеревоМаркированнойПродукции, РезультатПроверки.ПодобраннаяМаркируемаяПродукция, СтруктураСобранныхМарокИУпаковок);
				СохранитьРезультатПроверкиДокумента(ИсходныйДокумент, РезультатПроверки, ВидМаркируемойПродукции, Шаблон, ДокументТСД);			
			КонецЕсли;	
		Иначе
			Если ЗначениеЗаполнено(СтрокаОшибок) Тогда
				Возврат Неопределено;
			КонецЕсли;		
		КонецЕсли;
		
	КонецЦикла;
	
	Если Шаблон.ВидДокументаНового = "" Тогда
		ДокументТСД.ИсходныйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	Иначе
		ДокументТСД.НовыйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	КонецЕсли;		
		
КонецФункции // ()

Функция ОбработатьВидДокументаРеализацияТоваровУслуг(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок, 
	ЭтоВыводИСМПНаОсновании = Ложь, ВыбВидПродукции = Неопределено) Экспорт 
	
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	
	Шаблон = ДокументТСД.Шаблон;
	РеквизитыШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(Шаблон);
	
	ТЧПриЗагрузкеПодбор = РеквизитыШаблона.ТабличнуюЧастьПриЗагрузкеПодбор; 
	ТЧПриЗагрузкеПриемка = РеквизитыШаблона.ТабличнуюЧастьПриЗагрузкеПриемка;

	ПерезаписатьХешУпаковок = РеквизитыШаблона.МаркировкаПерезаписатьХешУпаковок;
	КопияТЧ = Неопределено;
	КопияТЧПриемка = Неопределено; 
	ИмяТЧПодбор = "";
	ИмяТЧПриемка = "";
	
	ТипЗнчДока = ТипЗнч(ИсходныйДокумент);
	УстановитьGTIN(ДокументТСД);
	
	НовыйДокументВВидеТабличнойЧасти = Справочники.ДатаМобайл_ШаблоныДокументов.НовыйДокументКакТабличнаяЧасть(Шаблон);
	
	Если РеквизитыШаблона.ВидДокументаНового = "" Тогда
		Если РеквизитыШаблона.ИспользоватьПодбор Тогда
			ИмяТЧПодбор = РеквизитыШаблона.ИмяТабличнойЧастиПодбор;
		КонецЕсли;
		Если РеквизитыШаблона.ИспользоватьПриемку Тогда
			ИмяТЧПриемка = РеквизитыШаблона.ИмяТабличнойЧастиПриемка;
		КонецЕсли;
	Иначе
		Если РеквизитыШаблона.ИспользоватьПодбор Тогда
			ИмяТЧПодбор = РеквизитыШаблона.ИмяТабличнойЧастиНовойПодбор;
		КонецЕсли;
		Если РеквизитыШаблона.ИспользоватьПриемку Тогда
			ИмяТЧПриемка = РеквизитыШаблона.ИмяТабличнойЧастиНовойПриемка;
		КонецЕсли;
	КонецЕсли;
	
	СоздаватьЕслиНеНайдена 	= РеквизитыШаблона.МаркировкаСоздаватьСправочникКМЕслиНеНайден;	
	ПривязыватьGTIN 		= РеквизитыШаблона.МаркировкаПривязыватьGTINКакШтрихкод;
	ЗаписыватьПолныйКМ      = РеквизитыШаблона.МаркировкаЗаписыватьПолныйКМ;
	
	Если ИмяТЧПодбор <> "" Тогда
		ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);	
	КонецЕсли;

	Если ИмяТЧПриемка <> "" Тогда
		ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПриемка, ТЧПриЗагрузкеПриемка);	
	КонецЕсли;
	
	СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, ПривязыватьGTIN);
	СоздатьСтрокиШтрихкодовУпаковокПоМассиву_Упаковки(СтруктураСобранныхМарокИУпаковок.Короба, ИсходныйДокумент);
	СоздатьСтрокиШтрихкодовУпаковокПоМассиву(СтруктураСобранныхМарокИУпаковок.Марки, ИсходныйДокумент);
	
	Если ЭтоНовыйДокумент Тогда
		ЗаполнитьШапкуДокумента(Новый Структура("Об, Док", ДокументТСД, ИсходныйДокумент));
		ПеренестиВДокументНовыеЗначенияРеквизитов(ДокументТСД, ИсходныйДокумент, Шаблон);
	Иначе
		Если ТипЗнчДока = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда		
			УстановитьСтатусЕслиИспользуютсяСерииДляРеализации(ИсходныйДокумент, Шаблон);	
		КонецЕсли;
	КонецЕсли;
	
	Если РеквизитыШаблона.ВидДокумента = "ЗаказКлиента" И ТипЗнч(ИсходныйДокумент) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		ИсходныйДокумент.РеализацияПоЗаказам = Истина;
		СтруктураПоЗаказу = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументТСД.ИсходныйДокумент, "ДатаОтгрузки,Менеджер,Организация,НалогообложениеНДС,СпособДоставки");
		ЗаполнитьЗначенияСвойств(ИсходныйДокумент, СтруктураПоЗаказу); 		
	КонецЕсли;
	
	Если РеквизитыШаблона.ИспользоватьПодбор И ТЧПриЗагрузкеПодбор <> 0 И ЗначениеЗаполнено(ИмяТЧПодбор) Тогда 
		КопияТЧ = ИсходныйДокумент[ИмяТЧПодбор].Выгрузить();
		
		Если РеквизитыШаблона.СоздаватьДокументИСМП Тогда		
			Если КопияТЧ.Количество() = 0 И ТипЗнч(ИсходныйДокумент) = Тип("ДокументОбъект.ВыводИзОборотаИСМП") Тогда
				КопияТЧ = ДокументТСД.ИсходныйДокумент[ИмяТЧПодбор].Выгрузить();
			КонецЕсли;			
		КонецЕсли;
		
		ОбработатьИзменениеТЧПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, КопияТЧ,, ВыбВидПродукции);
	КонецЕсли;
	
	Если РеквизитыШаблона.ИспользоватьПриемку И ТЧПриЗагрузкеПриемка <> 0 И ЗначениеЗаполнено(ИмяТЧПриемка) Тогда
		КопияТЧПриемка = ИсходныйДокумент[ИмяТЧПриемка].Выгрузить();

		ОбработатьИзменениеТЧПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПриемка, КопияТЧПриемка,, ВыбВидПродукции, Истина);
	КонецЕсли;
	
	Попытка
		ИзменитьРеквизитыШапкиИзДополнительныхФорм(ИсходныйДокумент, Шаблон, ДокументТСД);
	Исключение
		ДатаМобайл_ОбщийМодуль.ОбработатьИсключение(0, "ОбработатьВидДокументаРеализацияТоваровУслуг", ОписаниеОшибки());
	КонецПопытки;
	
	Если ТипЗнчДока = Тип("ДокументОбъект.РасходныйОрдерНаТовары") Тогда
		Если Не ЗначениеЗаполнено(ИсходныйДокумент.ДатаОтгрузки) Тогда
			ИсходныйДокумент.ДатаОтгрузки = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ИсходныйДокумент.Ответственный) Тогда
			ИсходныйДокумент.Ответственный = ПараметрыСеанса.ТекущийПользователь;
		КонецЕсли;		
	КонецЕсли;
	
	Попытка
		ВыполнитьДопОбработкуДокумента(ИсходныйДокумент, ДокументТСД, Шаблон, ЭтоНовыйДокумент);
	Исключение
		ИсходныйДокумент.Записать();
	КонецПопытки;	     
	
	// РАБОТА С УПАКОВОЧНЫМИ ЛИСТАМИ СОЗДАННЫМИ ПРИ ОБРАБОТКЕ ДРУГИХ ДОКУМЕНТОВ 
	СоздаватьДокументыУпаковочныхЛистов = (РеквизитыШаблона.ИспользованиеУпаковочныхЛистовПодбор <> 0
													Или РеквизитыШаблона.ИспользованиеУпаковочныхЛистовПриемка <> 0);
	
	Если СоздаватьДокументыУпаковочныхЛистов Тогда
		Попытка Обработки.ДатаМобайл_АРМДиспетчера.ЗаполнитьУпаковочныеЛисты(ДокументТСД); Исключение КонецПопытки;	
	КонецЕсли;	
	
	Если ЗаписыватьПолныйКМ Тогда
		МассивПолныйКМ = СформироватьМассивПараметровПоПолномуКМ(ИсходныйДокумент, ДокументТСД);
		РучнойВводШтрихкодаЗавершение(МассивПолныйКМ, Неопределено);
	КонецЕсли;             
	
	Если Не РеквизитыШаблона.ВидДокумента = "ЗаказНаЭмиссиюКодовМаркировкиСУЗ" Тогда
		Если Не ВыбВидПродукции = Неопределено Тогда
			РезультатПроверки = ПолучитьРезультатПроверкиДокумента(ИсходныйДокумент, Шаблон, ВыбВидПродукции, СтрокаОшибок);
			
			Если РезультатПроверки <> Неопределено Тогда 
				ОбработатьМаркируемыеТовары(РезультатПроверки.ПодобраннаяМаркируемаяПродукция);
				ВнестиДанныеОСобранныхМарках(РезультатПроверки.ДеревоМаркированнойПродукции, РезультатПроверки.ПодобраннаяМаркируемаяПродукция, СтруктураСобранныхМарокИУпаковок);
				СохранитьРезультатПроверкиДокумента(ИсходныйДокумент, РезультатПроверки, ВыбВидПродукции, Шаблон, ДокументТСД);
			Иначе
				Если ЗначениеЗаполнено(СтрокаОшибок) Тогда
					Возврат Неопределено;
				КонецЕсли;	
			КонецЕсли;
				
		Иначе
			ЗаполнитьПроверкуИПодборПоВидамПродукцииДокумента(ИсходныйДокумент, Шаблон, СтруктураСобранныхМарокИУпаковок, ИмяТЧПодбор, СтрокаОшибок, ДокументТСД);
			
			Если РеквизитыШаблона.ЗаполнятьКодыМаркировкиВПодчиненномДокументе Тогда
				Попытка
					Если ТипЗнчДока = Тип("ДокументОбъект.ОтборРазмещениеТоваров") И ИсходныйДокумент.ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Отбор Тогда
						// берем связанный подчиненный РО и в нем заполняем КМ
						Распоряжение = ИсходныйДокумент.Распоряжение;
						
						Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда
							РаспоряжениеОбъект = Распоряжение.ПолучитьОбъект();																					
							СоздатьСтрокиШтрихкодовУпаковокПоМассиву_Упаковки(СтруктураСобранныхМарокИУпаковок.Короба, РаспоряжениеОбъект);
							СоздатьСтрокиШтрихкодовУпаковокПоМассиву(СтруктураСобранныхМарокИУпаковок.Марки, РаспоряжениеОбъект);							
							РаспоряжениеОбъект.Записать();
							ЗаполнитьПроверкуИПодборПоВидамПродукцииДокумента(РаспоряжениеОбъект, Шаблон, СтруктураСобранныхМарокИУпаковок, ИмяТЧПодбор, СтрокаОшибок, ДокументТСД);
						КонецЕсли;
						
					ИначеЕсли ТипЗнчДока = Тип("ДокументОбъект.ОтборРазмещениеТоваров") И РеквизитыШаблона.ВидДокумента = "ПриходныйОрдерНаТовары" Тогда
						ДокументОбъект = ДокументТСД.ИсходныйДокумент.ПолучитьОбъект();
						СоздатьСтрокиШтрихкодовУпаковокПоМассиву_Упаковки(СтруктураСобранныхМарокИУпаковок.Короба, ДокументОбъект);
						СоздатьСтрокиШтрихкодовУпаковокПоМассиву(СтруктураСобранныхМарокИУпаковок.Марки, ДокументОбъект);
						ДокументОбъект.Записать();
						ЗаполнитьПроверкуИПодборПоВидамПродукцииДокумента(ДокументОбъект, Шаблон, СтруктураСобранныхМарокИУпаковок, "Товары", СтрокаОшибок, ДокументТСД);	
					КонецЕсли;
				Исключение КонецПопытки;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаОшибок) Тогда
				Возврат Неопределено;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;	
	
	Если ПерезаписатьХешУпаковок Тогда
		Попытка ПерезаписатьХешУпаковок(СтруктураСобранныхМарокИУпаковок); Исключение КонецПопытки;	
	КонецЕсли; 
	
	Если РеквизитыШаблона.ВидДокументаНового = "РасходныйОрдерНаТовары" И РеквизитыШаблона.ВидДокумента = "РеализацияТоваровУслуг" Тогда
		Попытка        
			
			НаборЗаписей_РО = РегистрыСведений.СтатусыПроверкиИПодбораДокументовИСМП.СоздатьНаборЗаписей(); 
			НаборЗаписей_РО.Отбор.Документ.Установить(ИсходныйДокумент.Ссылка);
			НаборЗаписей_РО.Прочитать();
			
			НовыйЗаписей_РТУ = РегистрыСведений.СтатусыПроверкиИПодбораДокументовИСМП.СоздатьНаборЗаписей();
			НовыйЗаписей_РТУ.Отбор.Документ.Установить(ДокументТСД.ИсходныйДокумент);
			НовыйЗаписей_РТУ.Прочитать();
			
			Для каждого Строка Из НаборЗаписей_РО Цикл
				НоваяЗапись = НовыйЗаписей_РТУ.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяЗапись, Строка,,"Документ");
				НоваяЗапись.Документ = ДокументТСД.ИсходныйДокумент;
				
				Попытка
					НовыйЗаписей_РТУ.Записать(Истина);		
				Исключение			
				КонецПопытки;
			КонецЦикла;	
			
		Исключение
			
			Попытка  
				НаборЗаписей_РО = РегистрыСведений.СтатусыПроверкиИПодбораДокументовИС.СоздатьНаборЗаписей(); 
				НаборЗаписей_РО.Отбор.Документ.Установить(ИсходныйДокумент.Ссылка);
				НаборЗаписей_РО.Прочитать();
				
				НовыйЗаписей_РТУ = РегистрыСведений.СтатусыПроверкиИПодбораДокументовИС.СоздатьНаборЗаписей();
				НовыйЗаписей_РТУ.Отбор.Документ.Установить(ДокументТСД.ИсходныйДокумент);
				НовыйЗаписей_РТУ.Прочитать();
				
				Для каждого Строка Из НаборЗаписей_РО Цикл
					НоваяЗапись = НовыйЗаписей_РТУ.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяЗапись, Строка,,"Документ");
					НоваяЗапись.Документ = ДокументТСД.ИсходныйДокумент;
					
					Попытка
						НовыйЗаписей_РТУ.Записать(Истина);		
					Исключение			
					КонецПопытки;
				КонецЦикла;
			Исключение
			КонецПопытки;	
			
		КонецПопытки;
	КонецЕсли;	
	
	Если РеквизитыШаблона.ВидДокументаНового = "" Тогда
		ДокументТСД.ИсходныйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
		
	Иначе		
		Если Не ЭтоВыводИСМПНаОсновании Тогда
			Если НовыйДокументВВидеТабличнойЧасти Тогда
				СтрНовогоДокумента = ДокументТСД.НовыеДокументы.Добавить();
				СтрНовогоДокумента.НовыйДокумент = ИсходныйДокумент.Ссылка;
			Иначе
				ДокументТСД.НовыйДокумент = ИсходныйДокумент.Ссылка;
			КонецЕсли;
		КонецЕсли;
		
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	КонецЕсли;		
		
КонецФункции

Функция ОбработатьВидДокументаЧекККМ(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок)

	Шаблон = ДокументТСД.Шаблон;
	ТЧПриЗагрузкеПодбор 	= Шаблон.ТабличнуюЧастьПриЗагрузкеПодбор;
	ИмяТЧПодбор 			= Шаблон.ИмяТабличнойЧастиПодбор;
	СоздаватьЕслиНеНайдена 	= Шаблон.МаркировкаСоздаватьСправочникКМЕслиНеНайден;	
	ПривязыватьGTIN 		= Шаблон.МаркировкаПривязыватьGTINКакШтрихкод;
	ЗаписыватьПолныйКМ      = Шаблон.МаркировкаЗаписыватьПолныйКМ;
	
	ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);
	
	Если ЭтоНовыйДокумент Тогда
		ЗаполнитьШапкуДокумента(Новый Структура("Об, Док", ДокументТСД, ИсходныйДокумент));
		ПеренестиВДокументНовыеЗначенияРеквизитов(ДокументТСД, ИсходныйДокумент, Шаблон);		
	КонецЕсли;
	
	Если ТЧПриЗагрузкеПодбор <> 0 Тогда
		ОбработатьИзменениеТЧПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор);
	КонецЕсли;
	
	СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, ПривязыватьGTIN);
	
	СоздатьСтрокиАкцизныхМарокПоМассиву(СтруктураСобранныхМарокИУпаковок.Короба, ИсходныйДокумент);
	СоздатьСтрокиАкцизныхМарокПоМассиву(СтруктураСобранныхМарокИУпаковок.Марки, ИсходныйДокумент);
	
	Попытка
		ИзменитьРеквизитыШапкиИзДополнительныхФорм(ИсходныйДокумент, Шаблон, ДокументТСД);
	Исключение 
	КонецПопытки;
	
	Попытка
		ВыполнитьДопОбработкуДокумента(ИсходныйДокумент, ДокументТСД, Шаблон, ЭтоНовыйДокумент)
	Исключение 
	КонецПопытки;	
	
	ИсходныйДокумент.Записать();
	
	Если ЗаписыватьПолныйКМ Тогда
		МассивПолныйКМ = СформироватьМассивПараметровПоПолномуКМ(ИсходныйДокумент, ДокументТСД);
		РучнойВводШтрихкодаЗавершение(МассивПолныйКМ, Неопределено);
	КонецЕсли;
	
	Если Шаблон.ВидДокументаНового = "" Тогда
		ДокументТСД.ИсходныйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	Иначе
		ДокументТСД.НовыйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	КонецЕсли;		
		
КонецФункции // ()

Процедура ОбработатьВидДокументаДатаМобайл_УпаковочныйЛист(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, УзелПО, СтрокаОшибок, ИзМаркировки = Ложь)
	
	Шаблон = ДокументТСД.Шаблон;
	СоздаватьЕслиНеНайдена 	= Шаблон.МаркировкаСоздаватьСправочникКМЕслиНеНайден;	
	ЗаписыватьПолныйКМ      = Шаблон.МаркировкаЗаписыватьПолныйКМ;
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура КАК Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры КАК Характеристика,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.СерияСсылка КАК Серия,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМСсылка КАК КМСсылка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка КАК ЦРПТМарка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка_Длина КАК ЦРПТМарка_Длина,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_RawMrc КАК KM_RawMrc,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_TNVED КАК KM_TNVED,
	|	СУММА(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Количество) КАК Количество,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Короб КАК Короб
	|ПОМЕСТИТЬ ДанныеПодбор
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор
	|ГДЕ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка = &Ссылка
	|	И НЕ(ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.Шаблон.ЗагрузкаСтрокПодбораСДокументами
	|				И ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка.Шаблон.ВидДокументаНового <> """"
	|				И ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ПризнакПовторнойВыгрузки)
	|
	|СГРУППИРОВАТЬ ПО
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.СерияСсылка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КМСсылка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЦРПТМарка_Длина,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_RawMrc,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.KM_TNVED,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Короб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеПодбор.УпаковочныйЛист КАК Упаковка,
	|	ДанныеПодбор.Номенклатура КАК Номенклатура,
	|	ДанныеПодбор.Характеристика КАК Характеристика,
	|	ДанныеПодбор.Серия КАК Серия,
	|	ДанныеПодбор.КМСсылка КАК СсылкаМарка,
	|	ДанныеПодбор.ЦРПТМарка КАК Марка,
	|	ДанныеПодбор.ЦРПТМарка_Длина КАК ЦРПТМарка_Длина,
	|	ДанныеПодбор.KM_RawMrc КАК KM_RawMrc,
	|	ДанныеПодбор.KM_TNVED КАК KM_TNVED,
	|	ДанныеПодбор.Короб КАК Короб	
	|ИЗ
	|	ДанныеПодбор КАК ДанныеПодбор
	|ГДЕ
	|	ДанныеПодбор.Количество > 0 
	|ИТОГИ ПО
	|	Упаковка,
	|	Короб";
		
	Запрос.УстановитьПараметр("Ссылка", ДокументТСД.Ссылка);
	
	РезультатЗапрос = Запрос.Выполнить(); 
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Упаковка", "");
	ДанныеДляПроверки = РезультатЗапрос.Выгрузить();
	
	ВыборкаУпаковка = РезультатЗапрос.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ЗапросКМ = Новый Запрос;
	ЗапросКМ.Текст =
	"ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|ГДЕ
	|	НЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка = &Ссылка
	|	И ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод В(&КМ)
	|	И НЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод = ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)
	|	И НЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка.ПометкаУдаления";
	
	Пока ВыборкаУпаковка.Следующий() Цикл 
		
		Если ЗначениеЗаполнено(ВыборкаУпаковка.Упаковка) Тогда
			
			УпакСсылка = ПолучитьСправочникСсылкаУпаковка(ВыборкаУпаковка.Упаковка, Истина, Неопределено);
			
			Если ЗначениеЗаполнено(УпакСсылка) Тогда  
					
				Если УпакСсылка.ПометкаУдаления Тогда
					
					Сообщить("Упаковка " + Строка(УпакСсылка) + "  помечена на удаление. Агрегация по данной упаковке не выполнена!");
					
				Иначе
					
					ЗапросКМ.УстановитьПараметр("Ссылка", УпакСсылка);       
					
					СтруктураПоиска.Упаковка = ВыборкаУпаковка.Упаковка;
					МассивКМ = ДанныеДляПроверки.НайтиСтроки(СтруктураПоиска);
					
					ЗапросКМ.УстановитьПараметр("КМ", МассивКМ);
					
					РезультатПроверки = ЗапросКМ.Выполнить();
					
					Если Не РезультатПроверки.Пустой() Тогда
						
						Сообщить("Вложенный (-ые) КМ (-ы) в упаковку " + Строка(УпакСсылка) + "  уже агрегирован (-ы) в другие упаковки!");
						
						
				    Иначе			
				
						УпакОбъект = УпакСсылка.ПолучитьОбъект();
						
						ВыборкаКороба = ВыборкаУпаковка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						
						Пока ВыборкаКороба.Следующий() Цикл			
							
							Если ЗначениеЗаполнено(ВыборкаКороба.Короб) Тогда
								
								КоробСсылка = ПолучитьСправочникСсылкаУпаковка(ВыборкаКороба.Короб, Истина, Неопределено);										
								КоробОбъект = КоробСсылка.ПолучитьОбъект();
													
								ПроверитьМаркаНаходитсяВДругомКоробе(КоробСсылка, УпакОбъект.Ссылка);
								
								РезультатПоиска = УпакОбъект.ВложенныеШтрихкоды.НайтиСтроки(Новый Структура("Штрихкод", КоробСсылка));
								Если РезультатПоиска.Количество() = 0 Тогда
									НовыйВложенныйШтрихкод = УпакОбъект.ВложенныеШтрихкоды.Добавить();
									НовыйВложенныйШтрихкод.Штрихкод = КоробСсылка;
								КонецЕсли;
								
								КоробОбъект.Записать();			
								ОпределитьУпаковкуМоноМульти(КоробОбъект);
								
							Иначе
								
								ВыборкаМарки = ВыборкаКороба.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
								
								Пока ВыборкаМарки.Следующий() Цикл
									
									Если ЗначениеЗаполнено(ВыборкаМарки.СсылкаМарка) Тогда
										СсылкаМарка = ВыборкаМарки.СсылкаМарка;
									Иначе	
										СтруктураТовара = Новый Структура("Номенклатура, Характеристика", ВыборкаМарки.Номенклатура, ВыборкаМарки.Характеристика);
										СсылкаМарка = ПолучитьСправочникСсылкаМарка(ВыборкаМарки.Марка, ВыборкаМарки.ЦРПТМарка_Длина, ВыборкаМарки.KM_RawMrc, ВыборкаМарки.KM_TNVED, СоздаватьЕслиНеНайдена, СтруктураТовара, ДокументТСД.Шаблон);
									КонецЕсли;
									
									Если ЗначениеЗаполнено(СсылкаМарка) Тогда								
										
										ПроверитьМаркаНаходитсяВДругомКоробе(СсылкаМарка, УпакОбъект.Ссылка);
										
										РезультатПоиска = УпакОбъект.ВложенныеШтрихкоды.НайтиСтроки(Новый Структура("Штрихкод", СсылкаМарка));
										Если РезультатПоиска.Количество() = 0 Тогда
											НовыйВложенныйШтрихкод = УпакОбъект.ВложенныеШтрихкоды.Добавить();
											НовыйВложенныйШтрихкод.Штрихкод = СсылкаМарка;
										КонецЕсли;								
										
									КонецЕсли;
									
								КонецЦикла;
								
							КонецЕсли;	
							
						
						КонецЦикла;  
					
						УпакОбъект.Записать();	
						ОпределитьУпаковкуМоноМульти(УпакОбъект);   
					
					КонецЕсли;
					
				КонецЕсли;	
				
			КонецЕсли;
		Иначе
			// загрузим только КМ в справочник			
			ВыборкаКороба = ВыборкаУпаковка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаКороба.Следующий() Цикл			
				
				ВыборкаМарки = ВыборкаКороба.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаМарки.Следующий() Цикл
					
					Если ЗначениеЗаполнено(ВыборкаМарки.СсылкаМарка) Тогда
						СсылкаМарка = ВыборкаМарки.СсылкаМарка;
					Иначе	
						СтруктураТовара = Новый Структура("Номенклатура, Характеристика", ВыборкаМарки.Номенклатура, ВыборкаМарки.Характеристика);
						СсылкаМарка = ПолучитьСправочникСсылкаМарка(ВыборкаМарки.Марка, ВыборкаМарки.ЦРПТМарка_Длина, ВыборкаМарки.KM_RawMrc, ВыборкаМарки.KM_TNVED, СоздаватьЕслиНеНайдена, СтруктураТовара, ДокументТСД.Шаблон);
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЦикла;			
		КонецЕсли;
		
	КонецЦикла;
	
	Если Не ИзМаркировки Тогда
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
	КонецЕсли;
	
	Если ТипЗнч(ИсходныйДокумент.Ссылка) <> Тип("ДокументСсылка.ДатаМобайл_УпаковочныйЛист") И ЗаписыватьПолныйКМ Тогда
		Если Не ЗначениеЗаполнено(ИсходныйДокумент.Ссылка) Тогда
			ИсходныйДокумент.Записать();	
		КонецЕсли;
		МассивПолныйКМ = СформироватьМассивПараметровПоПолномуКМ(ИсходныйДокумент, ДокументТСД);
		РучнойВводШтрихкодаЗавершение(МассивПолныйКМ, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОпределитьУпаковкуМоноМульти(УпаковкаОбъект)
	
	СсылкаУпаковка = УпаковкаОбъект.Ссылка;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.Номенклатура КАК Номенклатура,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.Характеристика КАК Характеристика,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.Серия КАК Серия
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|ГДЕ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка = &СсылкаУпаковка";
	
	
	Запрос.УстановитьПараметр("СсылкаУпаковка",СсылкаУпаковка);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() = 1 Тогда
		Если Не ЗначениеЗаполнено(УпаковкаОбъект.Номенклатура) тогда 
			УпаковкаОбъект.Номенклатура = Результат[0].Номенклатура; 	
			УпаковкаОбъект.Характеристика = Результат[0].Характеристика;
			УпаковкаОбъект.Серия = Результат[0].Серия;		        
		КонецЕсли;       
		
		УпаковкаОбъект.ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
				
		УпаковкаОбъект.Записать();
	Иначе		
		//УпаковкаОбъект.Номенклатура = Неопределено;
		//УпаковкаОбъект.Характеристика = Неопределено;
		//УпаковкаОбъект.Серия = Неопределено;
		
		Если Результат.Количество() > 1 Тогда
			УпаковкаОбъект.ТипУпаковки = Перечисления.ТипыУпаковок.МультитоварнаяУпаковка;
		Иначе
			УпаковкаОбъект.ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
		КонецЕсли;
			
		УпаковкаОбъект.Записать();		
	КонецЕсли;
			
КонецПроцедуры

Функция ОбработатьВидДокументаМаркировкаТоваровИСМП(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок, ПараметрыДокумента)
	
	ЭтоСозданиеВторогоДокументаМаркировки = Ложь;   
	
	Если ЗначениеЗаполнено(ДокументТСД.Ссылка) Тогда
		
		Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
		РеквизитыДокументаТСД = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументТСД.Ссылка, "НовыйДокумент");
		
		Если ЗначениеЗаполнено(РеквизитыДокументаТСД.НовыйДокумент) Тогда
			
			ЭтоСозданиеВторогоДокументаМаркировки = Истина; 			
			ПараметрыДокумента.Вставить("ЭтоСозданиеВторогоДокументаМаркировки", Истина);
			
		КонецЕсли;
		
	КонецЕсли;   
	
	Шаблон = ДокументТСД.Шаблон;
	ТЧПриЗагрузкеПодбор = Шаблон.ТабличнуюЧастьПриЗагрузкеПодбор;
	
	Если Шаблон.ВидДокументаНового = "" Тогда
		ИмяТЧПодбор = Шаблон.ИмяТабличнойЧастиПодбор;
	Иначе
		ИмяТЧПодбор = Шаблон.ИмяТабличнойЧастиНовойПодбор;
	КонецЕсли;
	
	СоздаватьЕслиНеНайдена 		= Шаблон.МаркировкаСоздаватьСправочникКМЕслиНеНайден;
	ПривязыватьGTIN 			= Шаблон.МаркировкаПривязыватьGTINКакШтрихкод;
	ЗаписыватьПолныйКМ      	= Шаблон.МаркировкаЗаписыватьПолныйКМ;
	РежимКомплектации           = Шаблон.РежимКомплектации;
	
	Если ЭтоНовыйДокумент Тогда
		
		ИсходныйДокумент.Дата = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
		ИсходныйДокумент.Операция = Перечисления.ВидыОперацийИСМП.ВводВОборотМаркировкаОстатков;
		
		Если РежимКомплектации = 1 Тогда
			ИсходныйДокумент.Операция = Перечисления.ВидыОперацийИСМП.ВводВОборотИмпортСФТС;
		КонецЕсли;
		
		ВыборкаНастройкиОбменаСУЗ =	РегистрыСведений.НастройкиОбменаСУЗ.Выбрать();
		Если ВыборкаНастройкиОбменаСУЗ.Следующий() Тогда
			ИсходныйДокумент.Организация = ВыборкаНастройкиОбменаСУЗ.Организация;
		КонецЕсли;
				
	КонецЕсли;
	
	ПеренестиВДокументНовыеЗначенияРеквизитов(ДокументТСД, ИсходныйДокумент, Шаблон); 
	
	Попытка
		ИзменитьРеквизитыШапкиИзДополнительныхФорм(ИсходныйДокумент, Шаблон, ДокументТСД);
	Исключение 
	КонецПопытки;
		
	// Генерация упаковок в документе ввод в оборот 
	Если Не РежимКомплектации = 1 Тогда
		
		Если Шаблон.ИспользованиеУпаковочныхЛистовПодбор > 0 Тогда
			ОбработатьВидДокументаДатаМобайл_УпаковочныйЛист(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, Неопределено, СтрокаОшибок, Истина);
		КонецЕсли;
	
		ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);
		СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, ПривязыватьGTIN);
		
	Иначе   
		
		Если ПараметрыДокумента = Неопределено Тогда
			
			ПараметрыДокумента = Новый Структура; 
			ПараметрыДокумента.Вставить("Об", ДокументТСД);
			
		КонецЕсли;
		
		ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);
		СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок_МаркировкаТоваровИСМП(ПараметрыДокумента, СоздаватьЕслиНеНайдена, ПривязыватьGTIN);
		
		Если Не ЭтоСозданиеВторогоДокументаМаркировки Тогда
			
			Если СтруктураСобранныхМарокИУпаковок.Наборы.Количество() Тогда
				
				АгрегацияКомплектующихВНаборы(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок, Истина, СтруктураСобранныхМарокИУпаковок);
				
			КонецЕсли; 
			
			Если Шаблон.ИспользованиеУпаковочныхЛистовПодбор > 0 Тогда
				АгрегацияНаборовВУпакЛисты(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок, Истина, СтруктураСобранныхМарокИУпаковок);
			КонецЕсли;	
			
		Иначе
			
			Если СтруктураСобранныхМарокИУпаковок.Короба.Количество() = 0 Тогда
				
				Если СтруктураСобранныхМарокИУпаковок.Наборы.Количество() Тогда
					
					Для Каждого КМНабораСсылка Из СтруктураСобранныхМарокИУпаковок.Наборы Цикл
						
						НоваяСтрокаДокумента = ИсходныйДокумент.ШтрихкодыУпаковок.Добавить();
						НоваяСтрокаДокумента.ШтрихкодУпаковки = КМНабораСсылка;
						
					КонецЦикла;
					
				КонецЕсли;
				
								
			КонецЕсли;	
			
		КонецЕсли;   		
		
	КонецЕсли; 
		
	Если ЭтоСозданиеВторогоДокументаМаркировки Тогда
		
		СоздатьСтрокиШтрихкодовУпаковокПоМассиву_Упаковки(СтруктураСобранныхМарокИУпаковок.Короба, ИсходныйДокумент,,, ЭтоНовыйДокумент, ДокументТСД);
			
	Иначе
		
		// Наборы
		Если РежимКомплектации = 1 Тогда
			СоздатьСтрокиШтрихкодовУпаковокПоМассиву(СтруктураСобранныхМарокИУпаковок.Наборы, ИсходныйДокумент,,, ЭтоНовыйДокумент); 	
		Иначе
			СоздатьСтрокиШтрихкодовУпаковокПоМассиву_Упаковки(СтруктураСобранныхМарокИУпаковок.Короба, ИсходныйДокумент,,, ЭтоНовыйДокумент, ДокументТСД);
			СоздатьСтрокиШтрихкодовУпаковокПоМассиву(СтруктураСобранныхМарокИУпаковок.Марки, ИсходныйДокумент, ,, ЭтоНовыйДокумент,, ДокументТСД);
		КонецЕсли;	
		
		Если СтруктураСобранныхМарокИУпаковок.Свойство("ТаблицаМарокВнеНабора") = Истина Тогда
		
			Если СтруктураСобранныхМарокИУпаковок.ТаблицаМарокВнеНабора.Количество() Тогда 
				
				МассивМарокВнеНабора = СтруктураСобранныхМарокИУпаковок.ТаблицаМарокВнеНабора.ВыгрузитьКолонку("КМСсылка");
				СоздатьСтрокиШтрихкодовУпаковокПоМассиву(МассивМарокВнеНабора, ИсходныйДокумент, ,, ЭтоНовыйДокумент,, ДокументТСД);
				
			КонецЕсли;
			
		КонецЕсли;	
		
	КонецЕсли;	
	
	Если ТЧПриЗагрузкеПодбор <> 0 Тогда		
		
		ОбработатьИзменениеТЧПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор);  
		
		Если ЭтоСозданиеВторогоДокументаМаркировки Тогда
			
			Если СтруктураСобранныхМарокИУпаковок.Свойство("ТаблицаМарокВнеНабора") = Истина Тогда
				
				СтруктураПоискаСтрок = Новый Структура;
				СтруктураПоискаСтрок.Вставить("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
				СтруктураПоискаСтрок.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
				
				Для Каждого СтрокаМассива Из СтруктураСобранныхМарокИУпаковок.ТаблицаМарокВнеНабора Цикл 
					
					Если ЗначениеЗаполнено(СтрокаМассива.УпаковочныйЛист) Тогда
						Продолжить;
					КонецЕсли;
					
					Если Не ЗначениеЗаполнено(СтрокаМассива.КМСсылка.Номенклатура) Тогда
						Продолжить;
					КонецЕсли;
					
					СтруктураПоискаСтрок.Номенклатура = СтрокаМассива.КМСсылка.Номенклатура;
					СтруктураПоискаСтрок.Характеристика = СтрокаМассива.КМСсылка.Характеристика;
					
					МассивНайденныхСтрок = ИсходныйДокумент.Товары.НайтиСтроки(СтруктураПоискаСтрок);
					
					Для Каждого СтрокаТоваров Из МассивНайденныхСтрок Цикл
						
						СтрокаТоваров.Количество = СтрокаТоваров.Количество - 1;
						СтрокаТоваров.КоличествоУпаковок = СтрокаТоваров.Количество;
						
						Если СтрокаТоваров.Количество <= 0 Тогда
							ИсходныйДокумент.Товары.Удалить(СтрокаТоваров);
						КонецЕсли;	
						
					КонецЦикла;
					
				КонецЦикла; 

			КонецЕсли;
		
		КонецЕсли;	
				
	КонецЕсли;
	
	Попытка
		ВыполнитьДопОбработкуДокумента(ИсходныйДокумент, ДокументТСД, Шаблон, ЭтоНовыйДокумент)
	Исключение 
	КонецПопытки;  
	
	Если РежимКомплектации = 1 Тогда
		
		Попытка ИсходныйДокумент.ДокументОснование = ПолучитьДокументОснования(ДокументТСД.ИсходныйДокумент); Исключение КонецПопытки;
		Если ЗначениеЗаполнено(ДокументТСД.ИсходныйДокумент.Организация) Тогда
			ИсходныйДокумент.Организация = ДокументТСД.ИсходныйДокумент.Организация;	
		КонецЕсли;
		
	КонецЕсли;
	
	ИсходныйДокумент.Записать();
	
	Если ЭтоНовыйДокумент Тогда
		Если Не ЗначениеЗаполнено(ИсходныйДокумент.ВидПродукции) Тогда
			ВидМаркируемойПродукцииДокументаМассив = ПолучитьВидПродукцииИСДокумента(ИсходныйДокумент, ИмяТЧПодбор);
			ИсходныйДокумент.ВидПродукции = ВидМаркируемойПродукцииДокументаМассив[0];
			ИсходныйДокумент.Записать();
		КонецЕсли;	
	КонецЕсли;
	
	ОтчетПроизводственнойЛинии = ИсходныйДокумент.ОтчетПроизводственнойЛинии;
	
	Если ЗаписатьВТЧДанныеОтчетаПроизводственнойЛинии(ИсходныйДокумент.ВидПродукции) И ОтчетПроизводственнойЛинии Тогда		
		Если ИсходныйДокумент.Товары.Количество() > 0 Тогда
			ИсходныйДокумент.Товары.Очистить();	
		КонецЕсли;
		
		ТЗСобранныеДанныеМарки = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		ТЗСобранныеДанныеМарки.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЦРПТМарка, ЦРПТМарка_Длина, УпаковочныйЛист, KM_RawMrc, КМСсылка, KM_TNVED", "Количество");
		
		ТчДанныеОтчетаПроизводственнойЛинии = ИсходныйДокумент.ДанныеОтчетаПроизводственнойЛинии;
		
		Для каждого СтрокаДока Из ТЗСобранныеДанныеМарки Цикл
			Если СтрокаДока.Количество = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаТЧ = ТчДанныеОтчетаПроизводственнойЛинии.Добавить();
			СтрокаТЧ.ЗначениеШтрихкода        	= СтрокаДока.ЦРПТМарка;
			СтрокаТЧ.ЗначениеШтрихкодаУпаковки  = СтрокаДока.УпаковочныйЛист;			
		КонецЦикла;	
	КонецЕсли;
	
	ИсходныйДокумент.Записать();
	
	Если ЗаписыватьПолныйКМ Тогда
		МассивПолныйКМ = СформироватьМассивПараметровПоПолномуКМ(ИсходныйДокумент, ДокументТСД);
		РучнойВводШтрихкодаЗавершение(МассивПолныйКМ, Неопределено);
	КонецЕсли;
	
	ВидМаркируемойПродукцииДокументаМассив = ПолучитьВидПродукцииИСДокумента(ИсходныйДокумент,ИмяТЧПодбор);
	
	Для каждого ВидМаркируемойПродукции Из ВидМаркируемойПродукцииДокументаМассив Цикл
		
		РезультатПроверки = ПолучитьРезультатПроверкиДокумента(ИсходныйДокумент , Шаблон, ВидМаркируемойПродукции,СтрокаОшибок, ПараметрыДокумента);
		
		Если РезультатПроверки <> Неопределено Тогда
			ОбработатьМаркируемыеТовары(РезультатПроверки.ПодобраннаяМаркируемаяПродукция);
			ВнестиДанныеОСобранныхМарках(РезультатПроверки.ДеревоМаркированнойПродукции, РезультатПроверки.ПодобраннаяМаркируемаяПродукция, СтруктураСобранныхМарокИУпаковок);
			СохранитьРезультатПроверкиДокумента(ИсходныйДокумент, РезультатПроверки, ВидМаркируемойПродукции, Шаблон, ДокументТСД);
		Иначе
			Если ЗначениеЗаполнено(СтрокаОшибок) Тогда
				Возврат Неопределено;
			КонецЕсли;	
		КонецЕсли;
		
	КонецЦикла;
	
	// Для корректного отображения статусов марок в табличной части товаров до окончания работы с формой проверки и подбора их не должно быть в документе, поэтому очистим табличную часть марок.
	// Только когда есть проверка статусов в ИСМП
	Если Шаблон.МаркировкаПроверкаБезСертификатаИС Тогда
	Иначе	
		ОчиститьСтрокиШтрихкодовУпаковокПоМассиву(ИсходныйДокумент);
		ИсходныйДокумент.Записать();
	КонецЕсли;	
	
	Если Шаблон.ВидДокументаНового = "" Тогда
		
		ДокументТСД.ИсходныйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
		
	Иначе
		
		Если Шаблон.ВидДокументаНового = "МаркировкаТоваровИСМП" И Не РежимКомплектации = 0 Тогда	
			ДокументТСД.НовыйДокумент = Документы.МаркировкаТоваровИСМП.ПустаяСсылка();
		Иначе	
			ДокументТСД.НовыйДокумент = ИсходныйДокумент.Ссылка;
		КонецЕсли;	
		
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД); 
		
		Если Не ЭтоСозданиеВторогоДокументаМаркировки И Не РежимКомплектации = 0 Тогда 
			
			СтруктураОтвета = Новый Структура;
			СтруктураОтвета.Вставить("СсылкаНаДокументМаркировки", ИсходныйДокумент.Ссылка);
				
			Если СтруктураСобранныхМарокИУпаковок.Наборы.Количество() Тогда	          
				СтруктураОтвета.Вставить("ТребуетсяСозданиеВторогоДокументаМаркировки", Истина);
			Иначе
				СтруктураОтвета.Вставить("ТребуетсяСозданиеВторогоДокументаМаркировки", Ложь);
			КонецЕсли;
			
			Возврат СтруктураОтвета;
			
		Иначе	
		
			Возврат ИсходныйДокумент.Ссылка;
			
		КонецЕсли;	
		
	КонецЕсли;	
	
КонецФункции 

Процедура ЗаполнитьВСДИСрокГодности(ИсходныйДокумент, лЭлемент, стрИсходныйДокумент, ЭтоНовыйДокумент)
	
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	Модуль_ОбщегоНазначенияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначенияИСКлиентСервер");
	Модуль_ИнтеграцияИСУТКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСУТКлиентСервер");
	
	Попытка   
		РеквизитыНоменклатуры = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(лЭлемент.Номенклатура, "ОсобенностьУчета,ВидНоменклатуры");
		Если Модуль_ОбщегоНазначенияИСКлиентСервер.ЭтоВидПродукцииСоСрокамиГодности(Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(РеквизитыНоменклатуры.ОсобенностьУчета))
			Или Модуль_ОбщегоНазначенияИСКлиентСервер.ЭтоВидПродукцииСоСрокамиГодности(Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(РеквизитыНоменклатуры.ВидНоменклатуры.ОсобенностьУчета)) Тогда
			Если ЗначениеЗаполнено(стрИсходныйДокумент.ШтрихкодУпаковки.Серия) Тогда
				стрИсходныйДокумент.СрокГодности = стрИсходныйДокумент.ШтрихкодУпаковки.Серия.ГоденДо;
				Возврат;
			КонецЕсли;	
		КонецЕсли;
	Исключение КонецПопытки;

	Если ЭтоНовыйДокумент Тогда
		
		ДанныеВСД = ПолучитьВСДПоТовару(лЭлемент.Номенклатура);
		
		Если ДанныеВСД <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(стрИсходныйДокумент, ДанныеВСД);	
		КонецЕсли;
		
	Иначе
		
		Попытка
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Номенклатура", лЭлемент.Номенклатура);
			
			СтрокаПоиска = ИсходныйДокумент.Товары.НайтиСтроки(ПараметрыОтбора);
			
			Если СтрокаПоиска.Количество() = 1 Тогда
				
				Если ЗначениеЗаполнено(СтрокаПоиска[0].ИдентификаторПроисхожденияВЕТИС)
					И ЗначениеЗаполнено(СтрокаПоиска[0].СрокГодности) Тогда
					Попытка стрИсходныйДокумент.ИдентификаторПроисхожденияВЕТИС = СтрокаПоиска[0].ИдентификаторПроисхожденияВЕТИС; Исключение КонецПопытки;
					Попытка стрИсходныйДокумент.СрокГодности = СтрокаПоиска[0].СрокГодности; Исключение КонецПопытки;
				Иначе
					
					ДанныеВСД = ПолучитьВСДПоТовару(лЭлемент.Номенклатура);
					
					Если ДанныеВСД <> Неопределено Тогда
						
						ЗаполнитьЗначенияСвойств(стрИсходныйДокумент, ДанныеВСД);
						
						Для Каждого Строка Из СтрокаПоиска Цикл
							Если Не ЗначениеЗаполнено(Строка.ИдентификаторПроисхожденияВЕТИС) Тогда
								Строка.ИдентификаторПроисхожденияВЕТИС = ДанныеВСД.ИдентификаторПроисхожденияВЕТИС;
								Строка.СрокГодности = ДанныеВСД.СрокГодности;
							КонецЕсли; 
						КонецЦикла;

					КонецЕсли;			
										
				КонецЕсли;
				             						
			ИначеЕсли СтрокаПоиска.Количество() = 0 Тогда	
				
				ДанныеВСД = ПолучитьВСДПоТовару(лЭлемент.Номенклатура);
				
				Если ДанныеВСД <> Неопределено Тогда
					ЗаполнитьЗначенияСвойств(стрИсходныйДокумент, ДанныеВСД);	
				КонецЕсли;
				
			КонецЕсли; 
						
		Исключение
		КонецПопытки;	
	КонецЕсли;
	
	ЗаполнитьСрокГодностиПоДатеПроизводства(лЭлемент, ИсходныйДокумент, стрИсходныйДокумент);
		
КонецПроцедуры

Процедура ЗаполнитьСрокГодностиПоДатеПроизводства(лЭлемент, ИсходныйДокумент, стрИсходныйДокумент)
	
	Попытка
		Если ЗначениеЗаполнено(лЭлемент.Номенклатура.ВидНоменклатуры.ВладелецСерий) Тогда
			ТекущийВладелецСерий = лЭлемент.Номенклатура.ВидНоменклатуры.ВладелецСерий;
		Иначе
			ТекущийВладелецСерий = лЭлемент.Номенклатура.ВидНоменклатуры;
		КонецЕсли;
		
		Если ТекущийВладелецСерий.ИспользоватьСрокГодностиСерии Тогда
			Если ЗначениеЗаполнено(ИсходныйДокумент.ДатаПроизводства) И ЗначениеЗаполнено(лЭлемент.Номенклатура.СрокГодности) Тогда
				
				ДатаОкончанияСрокаГодности17 = ДатаМобайл_HTTP_Логика.РассчитатьГоденДоСерии(лЭлемент.Номенклатура, ИсходныйДокумент.ДатаПроизводства);			
				стрИсходныйДокумент.СрокГодности = ДатаОкончанияСрокаГодности17;
										
			КонецЕсли;
		КонецЕсли;
	Исключение КонецПопытки;
	
КонецПроцедуры

Процедура ОбработатьМаркируемыеТовары(ПодобраннаяМаркируемаяПродукция)
	
	Для каждого строка Из ПодобраннаяМаркируемаяПродукция Цикл
		Если ЗначениеЗаполнено(строка.Характеристика) Тогда
			строка.ХарактеристикиИспользуются = Истина;
		КонецЕсли;	
	КонецЦикла;	
	
КонецПроцедуры

Процедура ОбработатьМаркируемыеТоварыПриемка(ПодобраннаяМаркируемаяПродукция)
	
	ПодобраннаяМаркируемаяПродукцияНовая = ПодобраннаяМаркируемаяПродукция.СкопироватьКолонки();
	
	Для каждого СтрокаПродукции Из ПодобраннаяМаркируемаяПродукция Цикл
		
		Если СтрокаПродукции.Количество = 0 И СтрокаПродукции.КоличествоПодобрано = 0 И СтрокаПродукции.КоличествоИС = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаПродукцииНовая = ПодобраннаяМаркируемаяПродукцияНовая.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПродукцииНовая, СтрокаПродукции);
		
	КонецЦикла;
	
	ПодобраннаяМаркируемаяПродукция = ПодобраннаяМаркируемаяПродукцияНовая;
	
КонецПроцедуры

Процедура ОбработатьУпаковкиПриемка(ДеревоЗначений)

	НеПроверялась 			= Перечисления.СтатусыПроверкиНаличияПродукцииИС.НеПроверялась;
	ВНаличии      			= Перечисления.СтатусыПроверкиНаличияПродукцииИС.ВНаличии;
	МонотоварнаяУпаковка 	= Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;	
	Попытка
		//проверка, что вся вложенность отсканирована в упаковку
		ПерепроверитьВерхнюю = Ложь;
		Для каждого Строка Из ДеревоЗначений.Строки Цикл
			Если Строка.ТипУпаковки = МонотоварнаяУпаковка Тогда	
				Для каждого СтрокаУпаковки Из Строка.Строки Цикл
					Если Строка.СтатусПроверки = НеПроверялась Тогда
						ПараметрыОтбора = Новый Структура;
						ПараметрыОтбора.Вставить("СтатусПроверки", НеПроверялась);
						НайденныеСтроки = Строка.Строки.НайтиСтроки(ПараметрыОтбора);
						Если НайденныеСтроки.Количество() = 0 Тогда
							Строка.СтатусПроверки = ВНаличии;
						ИначеЕсли СтрокаУпаковки.ТипУпаковки = МонотоварнаяУпаковка Тогда							
							Для каждого СтрокаВЛ Из СтрокаУпаковки.Строки Цикл
								Если СтрокаУпаковки.СтатусПроверки = НеПроверялась Тогда
									ПараметрыОтбора = Новый Структура;
									ПараметрыОтбора.Вставить("СтатусПроверки", НеПроверялась);
									НайденныеСтроки = СтрокаУпаковки.Строки.НайтиСтроки(ПараметрыОтбора);
									Если НайденныеСтроки.Количество() = 0 Тогда
										СтрокаУпаковки.СтатусПроверки = ВНаличии;
										ПерепроверитьВерхнюю = Истина;
									КонецЕсли;
								КонецЕсли;
							КонецЦикла;							
						КонецЕсли;						
					КонецЕсли;		
				КонецЦикла;
				
				Если ПерепроверитьВерхнюю Тогда
					Для каждого СтрокаУпаковки Из Строка.Строки Цикл
						Если Строка.СтатусПроверки = НеПроверялась Тогда
							ПараметрыОтбора = Новый Структура;
							ПараметрыОтбора.Вставить("СтатусПроверки", НеПроверялась);
							НайденныеСтроки = Строка.Строки.НайтиСтроки(ПараметрыОтбора);
							Если НайденныеСтроки.Количество() = 0 Тогда
								Строка.СтатусПроверки = ВНаличии;
							КонецЕсли;						
						КонецЕсли;		
					КонецЦикла;	
				КонецЕсли;				
			ИначеЕсли Строка.Представление = "Групповые упаковки и наборы" Тогда
				Для каждого СтрокаУпаковки Из Строка.Строки Цикл
					Если СтрокаУпаковки.СтатусПроверки = НеПроверялась Тогда
						ПараметрыОтбора = Новый Структура;
						ПараметрыОтбора.Вставить("СтатусПроверки", НеПроверялась);
						НайденныеСтроки = СтрокаУпаковки.Строки.НайтиСтроки(ПараметрыОтбора);
						Если НайденныеСтроки.Количество() = 0 Тогда
							СтрокаУпаковки.СтатусПроверки = ВНаличии;	
						КонецЕсли;	
					КонецЕсли;		
				КонецЦикла;
			КонецЕсли;	
		КонецЦикла;
	Исключение КонецПопытки;
	
КонецПроцедуры

Функция ОбработатьВидДокументаВозвратВОборотИСМП(ИсходныйДокумент, ДокументТСД, ЭтоНовыйДокумент, СтрокаОшибок)
	
	Шаблон = ДокументТСД.Шаблон;
	ТЧПриЗагрузкеПодбор = Шаблон.ТабличнуюЧастьПриЗагрузкеПодбор;
	
	Если Шаблон.ВидДокументаНового = "" Тогда
		ИмяТЧПодбор = Шаблон.ИмяТабличнойЧастиПодбор;
	Иначе
		ИмяТЧПодбор = Шаблон.ИмяТабличнойЧастиНовойПодбор;
	КонецЕсли;
	
	СоздаватьЕслиНеНайдена = Шаблон.МаркировкаСоздаватьСправочникКМЕслиНеНайден;	
	ПривязыватьGTIN = Ложь;
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	ОснованиеИсходного = Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументТСД.Ссылка, "ИсходныйДокумент");
	
	ЭтоПеремаркировкаТоваровИСМП = Ложь;	
	Если ТипЗнч(ИсходныйДокумент.Ссылка) = Тип("ДокументСсылка.ПеремаркировкаТоваровИСМП") Тогда
		ЭтоПеремаркировкаТоваровИСМП = Истина;		
	КонецЕсли; 
	
	ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор);
	
	СтруктураСобранныхМарокИУпаковок = ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, ПривязыватьGTIN);
	
	Если ЭтоНовыйДокумент Тогда
		ЗаполнитьШапкуДокумента(Новый Структура("Об, Док", ДокументТСД, ИсходныйДокумент));		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИсходныйДокумент.Организация) Тогда		
		ИсходныйДокумент.Организация = Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОснованиеИсходного, "Организация");		
	КонецЕсли; 
	
	ПеренестиВДокументНовыеЗначенияРеквизитов(ДокументТСД, ИсходныйДокумент, Шаблон);
	
	Для каждого Марка Из СтруктураСобранныхМарокИУпаковок.Марки Цикл
		Если ЗначениеЗаполнено(Марка) Тогда
			
			ПараметрыОтбора = Новый Структура;		
			Если ЭтоПеремаркировкаТоваровИСМП Тогда
				ПараметрыОтбора.Вставить("НовыйКодМаркировки", Марка);
			Иначе
				ПараметрыОтбора.Вставить("КодМаркировки", Марка);
			КонецЕсли;
			
			НайденныеСтроки = ИсходныйДокумент[ИмяТЧПодбор].НайтиСтроки(ПараметрыОтбора);
			
			Если НайденныеСтроки.Количество() > 0 Тогда
				СтрокаТабличнойЧасти = НайденныеСтроки[0];
				ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, Марка);
			Иначе
				СтрокаТабличнойЧасти = ИсходныйДокумент[ИмяТЧПодбор].Добавить();
				Если ЭтоПеремаркировкаТоваровИСМП Тогда
					СтрокаТабличнойЧасти.НовыйКодМаркировки 	= Марка;
					СтрокаТабличнойЧасти.НоваяНоменклатура 		= Марка.Номенклатура;
					СтрокаТабличнойЧасти.КодТНВЭД				= Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТабличнойЧасти.НоваяНоменклатура, "КодТНВЭД");
					СтрокаТабличнойЧасти.НоваяХарактеристика 	= Марка.Характеристика;
					СтрокаТабличнойЧасти.ПричинаПеремаркировки 	= Перечисления.ПричиныПеремаркировкиТоваровИСМП.ИспорченоУтрачено;
				Иначе
					СтрокаТабличнойЧасти.КодМаркировки 	= Марка;
					СтрокаТабличнойЧасти.Номенклатура 	= Марка.Номенклатура;
					СтрокаТабличнойЧасти.Характеристика = Марка.Характеристика;
					СтрокаТабличнойЧасти.Серия 			= Марка.Серия;
				КонецЕсли; 	
			КонецЕсли; 
			
			СтрокаТабличнойЧасти.ВидПервичногоДокумента = Перечисления.ВидыПервичныхДокументовИСМП.Прочее;			
			
			Если Шаблон.ВидДокументаНового = "" Тогда
			Иначе
				Если ЗначениеЗаполнено(ДокументТСД.ИсходныйДокумент) Тогда
					СтрокаТабличнойЧасти.НаименованиеПервичногоДокумента = ДокументТСД.ИсходныйДокумент.Метаданные().Синоним;
					СтрокаТабличнойЧасти.НомерПервичногоДокумента = ДокументТСД.ИсходныйДокумент.Номер;
					СтрокаТабличнойЧасти.ДатаПервичногоДокумента = ДокументТСД.ИсходныйДокумент.Дата;
				КонецЕсли;	
			КонецЕсли;
			
			Обработки.ДатаМобайл_АРМДиспетчера.ОбработатьНовуюСтрокуТЧ(Новый Структура("Об", ДокументТСД), ИсходныйДокумент, ИмяТЧПодбор, СтрокаТабличнойЧасти);
			
		КонецЕсли;
	КонецЦикла;	
	
	Попытка
		ИзменитьРеквизитыШапкиИзДополнительныхФорм(ИсходныйДокумент, Шаблон, ДокументТСД);
	Исключение 
	КонецПопытки;
	
	Попытка
		ВыполнитьДопОбработкуДокумента(ИсходныйДокумент, ДокументТСД, Шаблон, ЭтоНовыйДокумент)
	Исключение 
	КонецПопытки;  
		
	ИсходныйДокумент.Записать();
	
	ВидМаркируемойПродукцииДокументаМассив = ПолучитьВидПродукцииИСДокумента(ИсходныйДокумент, ИмяТЧПодбор);
	ИсходныйДокумент.ВидПродукции = ВидМаркируемойПродукцииДокументаМассив[0]; 
	
	ИсходныйДокумент.Записать();
	
	Если Шаблон.ВидДокументаНового = "" Тогда
		ДокументТСД.ИсходныйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	Иначе
		ДокументТСД.НовыйДокумент = ИсходныйДокумент.Ссылка;
		УстановитьДатуЗавершенияДокументаТСД(ДокументТСД);
		Возврат ИсходныйДокумент.Ссылка;
	КонецЕсли;		
		
КонецФункции // ()

Процедура ВыполнитьДопОбработкуДокумента(ИсходныйДокумент, ДокументТСД, Шаблон, ЭтоНовыйДокумент)
	
	ИмяДока = ИсходныйДокумент.Метаданные().Имя;
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	
	ПараметрыШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(Шаблон);
	
	АвтоматическийКомментарий 					= ПараметрыШаблона.АвтоматическийКомментарий; 
	АвтоматическийКомментарийИспользовать		= ПараметрыШаблона.АвтоматическийКомментарийИспользовать;   
	ЗагружатьКомментарий						= ПараметрыШаблона.ЗагружатьКомментарий; 
	ПроводитьРоботом							= ПараметрыШаблона.ПроводитьРоботом;
	ВидДокумента                                = ПараметрыШаблона.ВидДокумента; 
	ВидДокументаНового                          = ПараметрыШаблона.ВидДокументаНового;
	СоздаватьСчетФактураВыданный				= ПараметрыШаблона.СоздаватьСчетФактураВыданный; 
	ПроверкаОтборРазмещение                 	= ПараметрыШаблона.ПроверкаОтборРазмещение;
	
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("Об"              , ДокументТСД);
	ПараметрыДокумента.Вставить("Шаблон"          , Шаблон);	
	ПараметрыДокумента.Вставить("Док"             , ИсходныйДокумент);
	ПараметрыДокумента.Вставить("ПараметрыШаблона", ПараметрыШаблона);
	
	Если СокрЛП(ВидДокументаНового) = "" Или ПараметрыШаблона.БыстраяПриемка Или ПараметрыШаблона.БыстраяОтгрузка Тогда
		ПараметрыДокумента.Вставить("ИмяТЧПодбор", ПараметрыШаблона.ИмяТабличнойЧастиПодбор);
		ПараметрыДокумента.Вставить("ИмяТЧПриемка", ПараметрыШаблона.ИмяТабличнойЧастиПриемка); 
		
		Если ИмяДока = "РасходныйОрдерНаТовары" И ПараметрыШаблона.ИмяТабличнойЧастиПодбор = "ТоварыПоРаспоряжениям" Тогда
			ПараметрыДокумента.Вставить("ИмяТЧПодбор", "ОтгружаемыеТовары");
		КонецЕсли;
	Иначе
		ПараметрыДокумента.Вставить("ИмяТЧПодбор" , ПараметрыШаблона.ИмяТабличнойЧастиНовойПодбор);
		ПараметрыДокумента.Вставить("ИмяТЧПриемка", ПараметрыШаблона.ИмяТабличнойЧастиНовойПриемка);
	КонецЕсли;
	
	ПараметрыДокументаТСД = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументТСД.Ссылка, "ИсходныйДокумент, Организация"); 
	ПараметрыДокумента.Вставить("ИсходныйДокумент", ПараметрыДокументаТСД.ИсходныйДокумент);
	ПараметрыДокумента.Вставить("Организация"     , ПараметрыДокументаТСД.Организация); 
	
	СтатусОтбораРазмещенияТоваровПослеЗагрузки = Неопределено;
	
	Если СокрЛП(ВидДокумента) = "ОтборРазмещениеТоваров" И ПроверкаОтборРазмещение Тогда
		ДокИсходный = ПараметрыДокумента.ИсходныйДокумент.ПолучитьОбъект();
		СтатусОтбораРазмещенияТоваровПослеЗагрузки = Обработки.ДатаМобайл_АРМДиспетчера.ПолучитьСтатусОтбораРазмещенияТоваровПослеЗагрузки(ДокументТСД, ДокИсходный);
	КонецЕсли; 
	
	ПараметрыДокумента.Вставить("СтатусОтбораРазмещенияТоваровПослеЗагрузки", СтатусОтбораРазмещенияТоваровПослеЗагрузки);
	
	// РАБОТА С КОММЕНТАРИЕМ ДОКУМЕНТА
	КомментарийПараметры = Новый Структура;
	КомментарийПараметры.Вставить("АвтоматическийКомментарийИспользовать", АвтоматическийКомментарийИспользовать);
	КомментарийПараметры.Вставить("АвтоматическийКомментарий", АвтоматическийКомментарий);
	КомментарийПараметры.Вставить("ЗагружатьКомментарий", ЗагружатьКомментарий);  
	
	Обработки.ДатаМобайл_АРМДиспетчера.УстановитьКомментарийДокумента(ДокументТСД, ИсходныйДокумент, КомментарийПараметры);
	
	// НОВЫЕ РЕКВИЗИТЫ АВТОЗАГРУЗКИ
	Попытка Обработки.ДатаМобайл_АРМДиспетчера.ЗаполнитьРеквизитыАвтозагрузки(ДокументТСД, Шаблон, ИсходныйДокумент); Исключение КонецПопытки;
	
	// УСТАНОВКА АВТОРА И СКЛАД/ПОМЕЩЕНИЕ ПО ЯЧЕЙКЕ
	Попытка 
		Если ДокументТСД.СобранныеДанныеПодбор.Количество() > 0 Тогда
			СтрТЧ = ДокументТСД.СобранныеДанныеПодбор[0];
			
			Попытка ПараметрыДокумента.Вставить("Пользователь", СтрТЧ.Пользователь); Исключение КонецПопытки;
			Попытка Обработки.ДатаМобайл_АРМДиспетчера.УстановитьАвтора(ИсходныйДокумент, СтрТЧ.Пользователь, ЭтоНовыйДокумент, Шаблон); Исключение КонецПопытки;
			Попытка Обработки.ДатаМобайл_АРМДиспетчера.УстановитьСкладПоЯчейке(ИсходныйДокумент, СтрТЧ.ЯчейкаСсылка); Исключение КонецПопытки;
		КонецЕсли; 
		
		Если ДокументТСД.СобранныеДанныеПриемка.Количество() > 0 Тогда
			СтрТЧ = ДокументТСД.СобранныеДанныеПриемка[0];
			
			Попытка ПараметрыДокумента.Вставить("Пользователь", СтрТЧ.Пользователь); Исключение КонецПопытки;
			Попытка Обработки.ДатаМобайл_АРМДиспетчера.УстановитьАвтора(ИсходныйДокумент, СтрТЧ.Пользователь, ЭтоНовыйДокумент, Шаблон); Исключение КонецПопытки;
			Попытка Обработки.ДатаМобайл_АРМДиспетчера.УстановитьСкладПоЯчейке(ИсходныйДокумент, СтрТЧ.ЯчейкаСсылка); Исключение КонецПопытки;
		КонецЕсли;
	Исключение 
	КонецПопытки; 

	// ДОПОЛНИТЕЛЬНАЯ ОБРАБОТКА ПО ВИДАМ ДОКУМЕНТОВ 
	ЕстьОшибки = Ложь;
	СтрокаОшибок = "";
	УдалосьПровестиПеремещение = Ложь;
	
	Попытка Обработки.ДатаМобайл_АРМДиспетчера.ВыполнитьДополнительнуюОбработкуДокумента(ИсходныйДокумент, ПараметрыДокумента, ЕстьОшибки, СтрокаОшибок); Исключение КонецПопытки;
	
	Если ЕстьОшибки Тогда
		ДатаМобайл_ОбщийМодуль.СообщитьПользователю(СтрокаОшибок);
	КонецЕсли;
	
	// ПРОВЕРКА ЗАПОЛНЕНИЯ РЕКВИЗИТОВ ДОКУМЕНТА
	
	Если ИмяДока = "РеализацияТоваровУслуг" Тогда
			
		Если Не ЗначениеЗаполнено(ИсходныйДокумент.Ссылка) И Не ЗначениеЗаполнено(ИсходныйДокумент.Склад) Тогда
			ДатаМобайл_ОбщийМодуль.СообщитьПользователю("Не указан склад! Значение склада можно указать в автозагрузке");	
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ИсходныйДокумент.Ссылка) И Не ЗначениеЗаполнено(ИсходныйДокумент.Организация) Тогда
			ДатаМобайл_ОбщийМодуль.СообщитьПользователю("Не указана организация! Значение организации можно указать в автозагрузке");	
		КонецЕсли;
		
	КонецЕсли;
	
	// ЗАПИСЬ-ПРОВЕДЕНИЕ	
	Если ПроводитьРоботом Тогда
		
		// ПРОВЕДЕНИЕ ТЕКУЩЕГО
		Попытка 
			Обработки.ДатаМобайл_АРМДиспетчера.ВыполнитьДополнительноеПроведениеДокумента(ДокументТСД, ИсходныйДокумент, ПараметрыДокумента); 
		Исключение
			Попытка	
				Если ПараметрыШаблона.РежимПроведения = 0 Тогда
					ИсходныйДокумент.Записать(РежимЗаписиДокумента.Проведение);
				Иначе
					ИсходныйДокумент.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Оперативный);	
				КонецЕсли;	
			Исключение
				Если ПараметрыШаблона.ОтменаПроведения = 0 Тогда
					ИсходныйДокумент.Записать(РежимЗаписиДокумента.ОтменаПроведения);	
				Иначе	
					ИсходныйДокумент.Записать();
				КонецЕсли;
			КонецПопытки; 
		КонецПопытки;
		
	Иначе
		ИсходныйДокумент.Записать();
	КонецЕсли;       
	
	Если (ВидДокумента = "ЗаказКлиента" Или ВидДокумента = "РеализацияТоваровУслуг") 
			И ИмяДока = "РеализацияТоваровУслуг"
			И СоздаватьСчетФактураВыданный Тогда
			
			Если Не ИсходныйДокумент.Проведен Тогда
				Попытка ИсходныйДокумент.Записать(РежимЗаписиДокумента.Проведение); Исключение КонецПопытки;
			КонецЕсли;
			
			Попытка Обработки.ДатаМобайл_АРМДиспетчера.СоздатьСчетФактураВыданный(ИсходныйДокумент); Исключение КонецПопытки;
	КонецЕсли;		
	
	Если ВидДокумента = "РеализацияТоваровУслуг" 
		И ИмяДока = "РасходныйОрдерНаТовары" Тогда
		
		ДокументРТУ = ДокументТСД.ИсходныйДокумент.ПолучитьОбъект();
		ДокументРТУ.ШтрихкодыУпаковок.Загрузить(ИсходныйДокумент.ШтрихкодыУпаковок.Выгрузить());
		
		Попытка
			ДокументРТУ.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
		КонецПопытки;		
	КонецЕсли;
	
	Попытка Обработки.ДатаМобайл_АРМДиспетчера.ВыполнитьДополнительнуюОбработкуИсходногоДокумента(ИсходныйДокумент, ПараметрыДокумента, УдалосьПровестиПеремещение); Исключение КонецПопытки;
			
КонецПроцедуры

Функция ЗаполнитьУпаковочныеЛисты_Маркировка(Об, МассивДокументов = Неопределено, Док = "") Экспорт
	
	Шаблон = Об.Шаблон;
	ДобавитьНовыеДокументыВМассив = Ложь;
	ТЧНеИзменять = Ложь;
	
	// Запишем и проведем все упак листы по документу
	ТЗОбщая = ВыгрузитьСобранныеДанныеПодбор(Об);
	ТЗОбщая.Свернуть("УпаковочныйЛист,Пользователь");
	
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");	
	ПараметрыШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(Шаблон, "ВидДокумента, ИспользоватьТиповыеУпаковочныеЛисты, ТабличнаяЧастьПриЗагрузкеУЛ, ИспользованиеУпаковочныхЛистовПодбор, РаспределениеТоваров, ИспользоватьМаркировку");
	ВидДокумента 						= ПараметрыШаблона.ВидДокумента;
	ИспользоватьТиповыеУпаковочныеЛисты = ПараметрыШаблона.ИспользоватьТиповыеУпаковочныеЛисты;
	ТабличнуюЧастьПриЗагрузкеПодбор     = ПараметрыШаблона.ТабличнаяЧастьПриЗагрузкеУЛ;
	СоздаватьДокументыУпаковочныхЛистов = ПараметрыШаблона.ИспользованиеУпаковочныхЛистовПодбор <> 0;
	МножествоДокументовКакЗадание		= ПараметрыШаблона.РаспределениеТоваров = 1;
	ИспользоватьМаркировку 				= ПараметрыШаблона.ИспользоватьМаркировку;
	
	Если МножествоДокументовКакЗадание <> Истина Тогда 		
		Если ИспользоватьТиповыеУпаковочныеЛисты И МассивДокументов <> Неопределено Тогда
			ДобавитьНовыеДокументыВМассив = Истина;
			МассивДокументов.Очистить();		
		КонецЕсли;
	КонецЕсли;
	
	Если ТабличнуюЧастьПриЗагрузкеПодбор = 1 Тогда
		ТЧНеИзменять = Истина;	
	КонецЕсли; 
	
	ДанныеПодбораВРазныеДокументы = Истина;
	
	Для каждого СтрокаОбщей Из ТЗОбщая Цикл
		
		Если СтрокаОбщей.УпаковочныйЛист <> "" Или ВидДокумента = "ДатаМобайл_УпаковочныйЛист" Тогда						
			// ШАПКА УПАКОВОЧНОГО ЛИСТА
			
			НомерУпакЛиста = СтрЗаменить(СтрокаОбщей.УпаковочныйЛист, "/////", "");
			Если Лев(СтрокаОбщей.УпаковочныйЛист, 3) = "UPL" Тогда 
				НомерУпакЛиста = Прав(НомерУпакЛиста, СтрДлина(НомерУпакЛиста) - 3);
			КонецЕсли;	
			
			ДокументУпакЛиста = Документы.ДатаМобайл_УпаковочныйЛист.НайтиПоНомеру(НомерУпакЛиста);	
			
			Если ДокументУпакЛиста.Пустая() Тогда
				
				Если ДанныеПодбораВРазныеДокументы Тогда
					ДокументУпаковочногоЛиста = Документы.ДатаМобайл_УпаковочныйЛист.СоздатьДокумент();
					ДокументУпаковочногоЛиста.Дата = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
					
					Если ЗначениеЗаполнено(Об.ИсходныйДокумент) Тогда
						ДокументУпаковочногоЛиста.Основание = Об.ИсходныйДокумент;
					Иначе
						ДокументУпаковочногоЛиста.Основание = Об.Ссылка;
					КонецЕсли;
					
					ДокументУпаковочногоЛиста.Ответственный = Справочники.Пользователи.НайтиПоНаименованию(СтрокаОбщей.Пользователь, Ложь);
					ДокументУпаковочногоЛиста.ТСД = Об.ТСД;
					ДокументУпаковочногоЛиста.Код = НомерУпакЛиста; 
					ДокументУпаковочногоЛиста.Номер = НомерУпакЛиста;
					ДокументУпаковочногоЛиста.Записать();
					
					ДокументУпакЛиста = ДокументУпаковочногоЛиста.Ссылка;
					
					Если ВидДокумента = "ДатаМобайл_УпаковочныйЛист" И Не СоздаватьДокументыУпаковочныхЛистов Тогда
						ДанныеПодбораВРазныеДокументы = Ложь;						
					КонецЕсли; 					
				Иначе
					ДокументУпакЛиста = Док;
				КонецЕсли; 
				
				Если ИспользоватьТиповыеУпаковочныеЛисты Тогда
					ДокументУпаковочногоЛистаТиповой = Документы.УпаковочныйЛист.СоздатьДокумент();	
					ДокументУпаковочногоЛистаТиповой.Дата = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
					ДокументУпаковочногоЛистаТиповой.Вид = Перечисления.ВидыУпаковочныхЛистов.Исходящий;
					ДокументУпаковочногоЛистаТиповой.Код = НомерУпакЛиста;
					Попытка ДокументУпаковочногоЛиста.Упаковал = ДокументУпаковочногоЛиста.Ответственный; Исключение КонецПопытки;
					Попытка ДокументУпаковочногоЛистаТиповой.СкладУпаковки = Об.Склад; Исключение КонецПопытки;
					
					Если ЗначениеЗаполнено(Об.ИсходныйДокумент) Тогда	
						Если Об.Шаблон.ВидДокумента = "РасходныйОрдерНаТовары" И ЗначениеЗаполнено(Об.ИсходныйДокумент) Тогда 
							Модуль_ПрефиксацияОбъектовКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ПрефиксацияОбъектовКлиентСервер");
							РеквизитыОрдера = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Об.ИсходныйДокумент, "Получатель, Номер");
							Основание = НСтр("ru = '%Получатель% / Ордер %Номер%'");
							Основание = СтрЗаменить(Основание, "%Получатель%", РеквизитыОрдера.Получатель);
							Основание = СтрЗаменить(Основание, "%Номер%", Модуль_ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(РеквизитыОрдера.Номер));	
							ДокументУпаковочногоЛистаТиповой.Основание =  Основание;
						Иначе
							ДокументУпаковочногоЛистаТиповой.Основание =  Об.ИсходныйДокумент;
						КонецЕсли;
					КонецЕсли;	
					
					ДокументУпаковочногоЛистаТиповой.Записать();	
					
					Попытка
						ДокументУпаковочногоЛиста.ТиповойУпаковочныйЛист = ДокументУпаковочногоЛистаТиповой.Ссылка;
						ДокументУпаковочногоЛиста.Записать();
					Исключение
						ДатаМобайл_ОбщийМодуль.СообщитьПользователю(ОписаниеОшибки());
					КонецПопытки;					
				КонецЕсли;	
				
			КонецЕсли;
						
			ДокументУпакЛистаОбъект = ДокументУпакЛиста.ПолучитьОбъект();
			Док = ДокументУпакЛистаОбъект.Ссылка;
			КопияТЧ = ДокументУпакЛистаОбъект.Товары;	
			Если ТабличнуюЧастьПриЗагрузкеПодбор = 2 Тогда
				ДокументУпакЛистаОбъект.Товары.Очистить();
			ИначеЕсли ТабличнуюЧастьПриЗагрузкеПодбор = 3 Тогда
				Для каждого СтрокаТЧКопии Из КопияТЧ Цикл
					СтрокаТЧКопии.Количество 			= 0;
					СтрокаТЧКопии.КоличествоУпаковок    = 0;
				КонецЦикла; 
			КонецЕсли; 
						
			// СТРОКИ УПАКОВОЧНОГО ЛИСТА
			
			ТЗ = ВыгрузитьСобранныеДанныеПодбор(Об);                  
			Если ИспользоватьМаркировку Тогда
				ТЗ.Свернуть("Номенклатура,ХарактеристикаНоменклатуры,СерияСсылка,ЕдиницаИзмерения,УпаковочныйЛист,ШтрихКод,Пользователь, УпаковочныйЛистАтрибуты, ЦРПТМарка","Количество");
			Иначе
				ТЗ.Свернуть("Номенклатура,ХарактеристикаНоменклатуры,СерияСсылка,ЕдиницаИзмерения,УпаковочныйЛист,ШтрихКод,Пользователь, УпаковочныйЛистАтрибуты","Количество");	
				СтруктураПоискаУпЛист = Новый Структура("ЦРПТМарка", "");	
			КонецЕсли;	
			СтруктураПоискаУпЛист = Новый Структура("УпаковочныйЛист", СтрокаОбщей.УпаковочныйЛист);			
			ДанныеУпакЛиста = ТЗ.НайтиСтроки(СтруктураПоискаУпЛист);
			
			Если ДанныеУпакЛиста.Количество() <> 0 Тогда
				Если МножествоДокументовКакЗадание Тогда
					ДокументУпакЛистаОбъект.Основание = Об.Ссылка;
				Иначе
					ДокументУпакЛистаОбъект.Основание = Об.ИсходныйДокумент;
				КонецЕсли;  
				
				ВесУпаковки = 0;
				ДлинаУпаковки = 0;
				ВысотаУпаковки = 0; 
				ШиринаУпаковки = 0;
				КоличествоМестУпаковки = 0;
				
				Для каждого СтрокаТЧ Из ДанныеУпакЛиста Цикл
					
					Если СтрокаТЧ.Количество = 0 Или ТЧНеИзменять Тогда
						Продолжить;
					КонецЕсли;  
					
					// фильтр по не маркир. товарам:
					
					Если Не ИспользоватьМаркировку И ПолучитьТипМаркированнойПродукции(СтрокаТЧ.Номенклатура) <> 0 Тогда
	                 	Продолжить;
                    КонецЕсли;
					
					лСтруктураПоиска = Новый Структура("Номенклатура,Характеристика,Серия,Упаковка,Штрихкод", СтрокаТЧ.Номенклатура, СтрокаТЧ.ХарактеристикаНоменклатуры, СтрокаТЧ.СерияСсылка, СтрокаТЧ.ЕдиницаИзмерения, СтрокаТЧ.ШтрихКод);
					СтрокиПоиска = КопияТЧ.НайтиСтроки(лСтруктураПоиска);
					Если СтрокиПоиска.Количество() = 0 Тогда					
						СтрокаТабличнойЧасти = ДокументУпакЛистаОбъект.Товары.Добавить();
						СтрокаТабличнойЧасти.Штрихкод = СтрокаТЧ.ШтрихКод;
						СтрокаТабличнойЧасти.Номенклатура = СтрокаТЧ.Номенклатура;
						СтрокаТабличнойЧасти.Характеристика = СтрокаТЧ.ХарактеристикаНоменклатуры;
						
						СтрокаТабличнойЧасти.Упаковка = СтрокаТЧ.ЕдиницаИзмерения;
						СтрокаТабличнойЧасти.Серия = СтрокаТЧ.СерияСсылка;
						СтрокаТабличнойЧасти.Коэффициент = Обработки.ДатаМобайл_АРМДиспетчера.ВернутьКоэффициент(СтрокаТЧ.Номенклатура, СтрокаТЧ.ЕдиницаИзмерения);
					Иначе	
						СтрокаТабличнойЧасти = СтрокиПоиска[0];
					КонецЕсли;	
					
					СтрокаТабличнойЧасти.КоличествоУпаковок = СтрокаТабличнойЧасти.КоличествоУпаковок + СтрокаТЧ.Количество;
					СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.КоличествоУпаковок * СтрокаТабличнойЧасти.Коэффициент;
					
					// данные веса и объема:      
					СтруктураДанных = Обработки.ДатаМобайл_АРМДиспетчера.ПолучитьДанныеВесОбъемЕдИзм(СтрокаТабличнойЧасти.Номенклатура);
					СтрокаТабличнойЧасти.Вес = СтрокаТабличнойЧасти.Количество * СтруктураДанных.Вес;
					СтрокаТабличнойЧасти.Объем = СтрокаТабличнойЧасти.Количество * СтруктураДанных.Объем;   					
					
					Попытка
						Если ЗначениеЗаполнено(СтрокаТЧ.УпаковочныйЛистАтрибуты) Тогда
							СтруктураДанныхГабаритов = Обработки.ДатаМобайл_АРМДиспетчера.ПолучитьДанныеГабаритов(СтрокаТЧ.УпаковочныйЛистАтрибуты);
						КонецЕсли;  
						
						Если СтруктураДанныхГабаритов <> Неопределено Тогда
							Если ШиринаУпаковки = 0 Тогда 
								Попытка ШиринаУпаковки = СтруктураДанныхГабаритов.Ширина; Исключение КонецПопытки;
							КонецЕсли;
							
							Если ВысотаУпаковки = 0 Тогда
								Попытка ВысотаУпаковки = СтруктураДанныхГабаритов.Высота; Исключение КонецПопытки;
							КонецЕсли; 
							
							Если ДлинаУпаковки = 0 Тогда 				
								Попытка ДлинаУпаковки = СтруктураДанныхГабаритов.Длина; Исключение КонецПопытки;
							КонецЕсли; 
							
							Если ВесУпаковки = 0 Тогда 				
								Попытка ВесУпаковки = СтруктураДанныхГабаритов.ВесУпаковки; Исключение КонецПопытки;
							КонецЕсли;
							
							Если КоличествоМестУпаковки = 0 Тогда 				
								Попытка КоличествоМестУпаковки = СтруктураДанныхГабаритов.КоличествоМестУпаковки; Исключение КонецПопытки;
							КонецЕсли;
						КонецЕсли;
					Исключение 
					КонецПопытки;
				КонецЦикла;       
				
				ДокументУпакЛистаОбъект.ВесУпаковки = ВесУпаковки;
				ДокументУпакЛистаОбъект.ШиринаУпаковки = ШиринаУпаковки;
				ДокументУпакЛистаОбъект.ВысотаУпаковки = ВысотаУпаковки; 
				ДокументУпакЛистаОбъект.ГлубинаУпаковки = ДлинаУпаковки;
				ДокументУпакЛистаОбъект.КоличествоМестУпаковки = КоличествоМестУпаковки;

				ДокументУпакЛистаОбъект.Ответственный = Справочники.Пользователи.НайтиПоНаименованию(СтрокаТЧ.Пользователь, Ложь);
				ДокументУпакЛистаОбъект.Записать();
				Попытка ДокументУпакЛистаОбъект.Записать(РежимЗаписиДокумента.Проведение); Исключение ДатаМобайл_ОбщийМодуль.СообщитьПользователю(ОписаниеОшибки()) КонецПопытки;
								
				// ТИПОВЫЕ УПАК ЛИСТЫ
								
				Если ИспользоватьТиповыеУпаковочныеЛисты Тогда
					ДокументУпаковочногоЛистаТиповой = ДокументУпакЛистаОбъект.ТиповойУпаковочныйЛист.ПолучитьОбъект();
					
					// Всегда перезаполняем типовой упак лист актуальными данными из упак лиcта DataMobile
					ДокументУпаковочногоЛистаТиповой.Товары.Очистить();
					Для каждого СтрТЧ Из ДокументУпакЛистаОбъект.Товары Цикл
						СтрокаТабличнойЧастиТиповойЛист = ДокументУпаковочногоЛистаТиповой.Товары.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧастиТиповойЛист, СтрТЧ); 
					КонецЦикла;
					ДокументУпаковочногоЛистаТиповой.Упаковал = ДокументУпакЛистаОбъект.Ответственный;
										
					// При внесении в базу 1С результатов подбора и создании типовых упаковочных листов 1С 
					// необходимо заполнять вкладку «Комментарий» документа «Упаковочный лист» номерами всех участвующих в задании исходных документов, 
					// а также, если в качестве исходного документа используется «Расходный ордер на товары», данными поля «Получатель».
					Если МножествоДокументовКакЗадание Тогда	
						Для каждого ТекущийИсходныйДокумент Из МассивДокументов Цикл
							ТекущийКомментарий = "";
							Попытка
								Если ТипЗнч(ТекущийИсходныйДокумент) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда	
									Модуль_ПрефиксацияОбъектовКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ПрефиксацияОбъектовКлиентСервер");
									РеквизитыОрдера = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТекущийИсходныйДокумент, "Получатель, Номер");
									ТекущийКомментарий = НСтр("ru = '%Получатель% / Ордер %Номер%'");
									ТекущийКомментарий = СтрЗаменить(ТекущийКомментарий, "%Получатель%", РеквизитыОрдера.Получатель);
									ТекущийКомментарий = СтрЗаменить(ТекущийКомментарий, "%Номер%", Модуль_ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(РеквизитыОрдера.Номер));	
								Иначе
									ТекущийКомментарий = "" + ТекущийИсходныйДокумент;
								КонецЕсли;			
							Исключение
							КонецПопытки;
							ДокументУпаковочногоЛистаТиповой.Комментарий = ДокументУпаковочногоЛистаТиповой.Комментарий + Символы.ПС + ТекущийКомментарий;
						КонецЦикла;
					КонецЕсли;	
					
					ДокументУпаковочногоЛистаТиповой.Записать();
					Обработки.ДатаМобайл_АРМДиспетчера.УстановитьСерииВдокументе(ДокументУпаковочногоЛистаТиповой);
					ДокументУпаковочногоЛистаТиповой.Записать();
					Попытка ДокументУпаковочногоЛистаТиповой.Записать(РежимЗаписиДокумента.Проведение); Исключение ДатаМобайл_ОбщийМодуль.СообщитьПользователю(ОписаниеОшибки()); КонецПопытки;
					
					Если ДобавитьНовыеДокументыВМассив Тогда
						МассивДокументов.Добавить(ДокументУпаковочногоЛистаТиповой.Ссылка);		
					КонецЕсли;					
				КонецЕсли;			
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;	
	
	Если ТЗОбщая.Количество() > 1 И ВидДокумента = "ДатаМобайл_УпаковочныйЛист" И ДанныеПодбораВРазныеДокументы Тогда
		Док = "";		
	КонецЕсли; 
	
КонецФункции

Функция ЗаполнитьПроверкуИПодборПоВидамПродукцииДокумента(ИсходныйДокумент, Шаблон, СтруктураСобранныхМарокИУпаковок, ИмяТЧПодбор, СтрокаОшибок, ДокументТСД)
	
	ВидМаркируемойПродукцииДокументаМассив = ПолучитьВидПродукцииИСДокумента(ИсходныйДокумент, ИмяТЧПодбор);
	
	Для каждого ВидМаркируемойПродукции Из ВидМаркируемойПродукцииДокументаМассив Цикл
		
		Если Не ЗначениеЗаполнено(ВидМаркируемойПродукции) Тогда
			Продолжить;	
		КонецЕсли;
		
		РезультатПроверки = ПолучитьРезультатПроверкиДокумента(ИсходныйДокумент, Шаблон, ВидМаркируемойПродукции, СтрокаОшибок);
		
		Если РезультатПроверки <> Неопределено Тогда 
			
			ОбработатьМаркируемыеТовары(РезультатПроверки.ПодобраннаяМаркируемаяПродукция);
			ВнестиДанныеОСобранныхМарках(РезультатПроверки.ДеревоМаркированнойПродукции, РезультатПроверки.ПодобраннаяМаркируемаяПродукция, СтруктураСобранныхМарокИУпаковок);
			СохранитьРезультатПроверкиДокумента(ИсходныйДокумент, РезультатПроверки, ВидМаркируемойПродукции, Шаблон, ДокументТСД);
			
		Иначе
			
			Если ЗначениеЗаполнено(СтрокаОшибок) Тогда
				Возврат Неопределено;
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецФункции

#КонецОбласти

Процедура ИзменитьРеквизитыШапкиИзДополнительныхФорм(Док, Шаблон, СсылкаНаДокТСД)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДатаМобайл_СвязиДополнительныхФормИШаблонов.ЗаполняемыйРеквизит КАК ЗаполняемыйРеквизит,
	|	ДатаМобайл_СвязиДополнительныхФормИШаблонов.ДополнительнаяФорма КАК ДополнительнаяФорма
	|ИЗ
	|	РегистрСведений.ДатаМобайл_СвязиДополнительныхФормИШаблонов КАК ДатаМобайл_СвязиДополнительныхФормИШаблонов
	|ГДЕ
	|	ДатаМобайл_СвязиДополнительныхФормИШаблонов.Шаблон = &Шаблон
	|	И НЕ ЕСТЬNULL(ДатаМобайл_СвязиДополнительныхФормИШаблонов.ЗаполняемыйРеквизит, """") = """"
	|	И ДатаМобайл_СвязиДополнительныхФормИШаблонов.РеквизитИзШапки = 1";
	
	Запрос.УстановитьПараметр("Шаблон", Шаблон);
	
	МетаданныеСправочники = Метаданные.Справочники;
	МетаданныеПеречисления = Метаданные.Перечисления;
	
	ЗаполняемыеРеквизиты = Запрос.Выполнить().Выгрузить();
	Для каждого реквизитПоиска Из ЗаполняемыеРеквизиты Цикл
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДатаМобайл_ЗначенияДополнительныхФорм.Значение КАК Значение,
		|	МАКСИМУМ(ДатаМобайл_ЗначенияДополнительныхФорм.ИдентификаторСтроки) КАК ИдентификаторСтроки,
		|	ДатаМобайл_ЗначенияДополнительныхФорм.ДополнительнаяФорма.ТипДанных КАК ТипДанных
		|ИЗ
		|	РегистрСведений.ДатаМобайл_ЗначенияДополнительныхФорм КАК ДатаМобайл_ЗначенияДополнительныхФорм
		|ГДЕ
		|	ДатаМобайл_ЗначенияДополнительныхФорм.ДополнительнаяФорма = &ДополнительнаяФорма
		|	И ДатаМобайл_ЗначенияДополнительныхФорм.Документ = &СсылкаНаДокТСД
		|	И ДатаМобайл_ЗначенияДополнительныхФорм.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)		
		|
		|СГРУППИРОВАТЬ ПО
		|	ДатаМобайл_ЗначенияДополнительныхФорм.Значение,
		|	ДатаМобайл_ЗначенияДополнительныхФорм.ДополнительнаяФорма.ТипДанных
		|
		|УПОРЯДОЧИТЬ ПО
		|	ИдентификаторСтроки УБЫВ";
		
		Запрос.УстановитьПараметр("СсылкаНаДокТСД", СсылкаНаДокТСД.Ссылка);
		Запрос.УстановитьПараметр("ДополнительнаяФорма", реквизитПоиска.ДополнительнаяФорма); 
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ЗначениеПодстановки = Выборка.Значение;
			Если Не (Выборка.ТипДанных = "Текст" Или Выборка.ТипДанных = "Число" Или Выборка.ТипДанных = "Дата") Тогда
				Попытка
					Если Не МетаданныеСправочники.Найти(Выборка.ТипДанных) = Неопределено Тогда
						ЗначениеПодстановки = Справочники[Выборка.ТипДанных].ПолучитьСсылку(Новый УникальныйИдентификатор(Выборка.Значение));
					ИначеЕсли Не МетаданныеПеречисления.Найти(Выборка.ТипДанных) = Неопределено Тогда
						Попытка
							ИндексПеречисления = Число(Сред(Выборка.Значение, СтрНайти(Выборка.Значение, ".") + 1));
							ЗначениеПодстановки = Перечисления[Выборка.ТипДанных][ИндексПеречисления];
						Исключение
							ЗначениеПодстановки = Перечисления[Выборка.ТипДанных][Выборка.Значение];	
						КонецПопытки;
					КонецЕсли;
				Исключение
				КонецПопытки;
			КонецЕсли;
			Если Выборка.ТипДанных = "Дата" Тогда
				ФорматированнаяДата = ДатаМобайл_ОбщийМодуль.ПолучитьДатуИзСтрокиПоФормату(Выборка.Значение, Шаблон);
				Если Не ФорматированнаяДата = Неопределено Тогда
					ЗначениеПодстановки = ФорматированнаяДата;
				Иначе
					Если Не ТипЗнч(реквизитПоиска.ЗаполняемыйРеквизит) = Тип("Строка") Тогда
						Продолжить;
					КонецЕсли;						  
				КонецЕсли;
			КонецЕсли;
			
			Попытка
				Док[реквизитПоиска.ЗаполняемыйРеквизит] = ЗначениеПодстановки;
			Исключение
			КонецПопытки;			
		КонецЕсли;		
	КонецЦикла;
	
	Док.Записать();
	
КонецПроцедуры

#Область ФункцииДляОбработкиДокументов

Процедура ЗаполнитьШапкуДокумента(ПараметрыДокумента)

	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	Модуль_ИнтеграцияИСУТКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСУТКлиентСервер");
	
	РеквизитыДокументаТСД = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрыДокумента.Об.Ссылка, "Шаблон,Клиент,ТСД,Склад,ИсходныйДокумент");
	РеквизитыШаблона = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(РеквизитыДокументаТСД.Шаблон, "ВидДокументаНового,ВидДокумента,ИмяТабличнойЧастиПодбор,ИспользоватьПодбор,ИспользоватьПриемку"); 
	
	Шаблон 		= РеквизитыДокументаТСД.Шаблон;	
	Док 		= ПараметрыДокумента.Док;
	Док.Дата 	= ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
	Клиент 		= РеквизитыДокументаТСД.Клиент;
	ТСД 		= РеквизитыДокументаТСД.ТСД; 
	Склад 		= РеквизитыДокументаТСД.Склад;
	
	ВидДокументаНового 	= РеквизитыШаблона.ВидДокументаНового;
	ВидДокумента		= РеквизитыШаблона.ВидДокумента;
	
	ТипЗнчДока = ТипЗнч(Док.Ссылка);
	МетаданныеДок = Док.Метаданные();
	
	Модуль_ПартнерыИКонтрагенты = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ПартнерыИКонтрагенты");
	Модуль_ЗакупкиСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ЗакупкиСервер");
	
	Если ВидДокументаНового = "РеализацияТоваровУслуг" И ВидДокумента = "ЗаказКлиента" Тогда
		Док.АдресДоставки = РеквизитыДокументаТСД.ИсходныйДокумент.АдресДоставки;
	КонецЕсли;
	
	Если ВидДокументаНового = "ВыводИзОборотаИСМП" И ВидДокумента  = "РеализацияТоваровУслуг" Тогда
		Док.ВидПервичногоДокумента = Перечисления.ВидыПервичныхДокументовИСМП.ТоварнаяНакладная;
		Док.НомерПервичногоДокумента = РеквизитыДокументаТСД.ИсходныйДокумент.Номер;
		Док.ДатаПервичногоДокумента = РеквизитыДокументаТСД.ИсходныйДокумент.Дата;
	КонецЕсли;
	
	Попытка
		Если ЗначениеЗаполнено(Клиент) Тогда
			Док.Партнер = Клиент;
			Модуль_ПартнерыИКонтрагенты.ЗаполнитьКонтрагентаПартнераПоУмолчанию(Док.Партнер, Док.Контрагент);
			Если ТипЗнчДока = Тип("ДокументСсылка.РеализацияТоваровУслуг") Или ТипЗнчДока = Тип("ДокументСсылка.ЗаказКлиента") Тогда
				
				Если ВидДокументаНового = "РеализацияТоваровУслуг" И ВидДокумента = "ЗаказКлиента" И Не ЗначениеЗаполнено(Док.Соглашение) Тогда
					Док.ЗаполнитьУсловияПродажПоУмолчанию();
				КонецЕсли;				
				
				Если Не ЗначениеЗаполнено(Док.ХозяйственнаяОперация) Тогда
					Док.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияКлиенту;	
				КонецЕсли;
				
			ИначеЕсли ТипЗнчДока = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Или ТипЗнчДока = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
				Док.ЗаполнитьУсловияЗакупокПоУмолчанию();
				Док.ВариантПриемкиТоваров = Модуль_ЗакупкиСервер.ПолучитьВариантПриемкиТоваров(Неопределено, Док.Договор);
			ИначеЕсли ТипЗнчДока = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
				Док.ЗаполнитьУсловияПродажПоУмолчанию();
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Если ТипЗнчДока = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда		
		УстановитьСтатусЕслиИспользуютсяСерииДляРеализации(Док, Шаблон);	
	КонецЕсли;
	
	СкладЗаписан = Ложь;
	Если ЗначениеЗаполнено(Склад) Тогда
		Если Не СкладЗаписан Тогда
			Попытка
				Док.Склад = Склад;
				СкладЗаписан = Истина;
			Исключение
			КонецПопытки;
		КонецЕсли;
		Если Не СкладЗаписан Тогда
			Попытка
				Док.СкладОтправитель = Склад;
				СкладЗаписан = Истина;
			Исключение
			КонецПопытки;
		КонецЕсли;
		Если Не СкладЗаписан Тогда
			Попытка
				Док.ТорговыйОбъект = Склад;
				СкладЗаписан = Истина;
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	Попытка
		ТЗСобранныеДанныеПодбор = ВыгрузитьСобранныеДанныеПодбор(ПараметрыДокумента.Об);	
		Для каждого СтрокаПодбора Из ТЗСобранныеДанныеПодбор Цикл
			РеквизитыНоменклатура = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаПодбора.Номенклатура, "ОсобенностьУчета");
			Док.ВидПродукции = Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(РеквизитыНоменклатура.ОсобенностьУчета);
			Прервать;		
		КонецЦикла;	
	Исключение 
	КонецПопытки;
	
	Если ТипЗнчДока = Тип("ДокументСсылка.ОтборРазмещениеТоваров") Тогда
		Если РеквизитыШаблона.ИспользоватьПриемку И Не РеквизитыШаблона.ИспользоватьПодбор Тогда
			Док.ВидОперации = Перечисления.ВидыОперацийОтбораРазмещенияТоваров.Размещение;	
		КонецЕсли; 	
	КонецЕсли;
	
	Если МетаданныеДок.Имя = ВидДокументаНового И (ВидДокументаНового = "ПоступлениеТоваров" Или ВидДокументаНового = "ПоступлениеТоваровОтХранителя") Тогда
		Попытка
			Док.Распоряжение = РеквизитыДокументаТСД.ИсходныйДокумент;
			Док.ПоРаспоряжениям = Истина;
			
			РеквизитыРаспоряжения = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(РеквизитыДокументаТСД.ИсходныйДокумент, "Организация,ХозяйственнаяОперация,Соглашение");
			
			Док.Организация = РеквизитыРаспоряжения.Организация;
			Док.ХозяйственнаяОперация = РеквизитыРаспоряжения.ХозяйственнаяОперация;
			Док.Соглашение = РеквизитыРаспоряжения.Соглашение;
		Исключение КонецПопытки;	
	КонецЕсли; 
	
	Если ВидДокумента = "ЗаказНаПеремещение" И ВидДокументаНового = "РасходныйОрдерНаТовары" Тогда
		Док.Получатель = РеквизитыДокументаТСД.ИсходныйДокумент.СкладПолучатель; 
		Док.СкладскаяОперация = Перечисления.СкладскиеОперации.ОтгрузкаПоПеремещению;
		
		Попытка
			Док.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен;
			Док.Приоритет = Справочники.Приоритеты.ПолучитьПриоритетПоУмолчанию();
		Исключение
			ДатаМобайл_ОбщийМодуль.ОбработатьИсключение(0, "ДатаМобайл_Маркировка.ЗаполнитьШапкуДокумента", ОписаниеОшибки());
		КонецПопытки;		
	КонецЕсли;
	
	Если ВидДокументаНового = "ПриобретениеТоваровУслуг" И ВидДокумента = "ЗаказПоставщику" Тогда
		Модуль_СозданиеНаОснованииУТВызовСервера = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("СозданиеНаОснованииУТВызовСервера");
		Модуль_ЗакупкиСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ЗакупкиСервер");
		Модуль_ЗакупкиВызовСервера = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ЗакупкиВызовСервера");
		
		Док.ЗаказПоставщику = РеквизитыДокументаТСД.ИсходныйДокумент;
		
		МассивСсылок = Новый Массив;
		МассивСсылок.Добавить(РеквизитыДокументаТСД.ИсходныйДокумент);
		
		ДанныеЗаполнения = Модуль_СозданиеНаОснованииУТВызовСервера.ПриобретениеТоваровУслугПараметрыОткрытияФормы(МассивСсылок);
		
		Док.Заполнить(ДанныеЗаполнения);
		
		ХозяйственнаяОперацияОтбора = Модуль_ЗакупкиСервер.ХозяйственныеОперацииПоОсновной(Док.ХозяйственнаяОперация);
	
		Если Док.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов Тогда
			
			ДопПараметры = Модуль_ЗакупкиСервер.ДополнительныеПараметрыОтбораДоговоров();
			ДопПараметры.ВалютаВзаиморасчетов		= Док.ВалютаВзаиморасчетов;
			ДопПараметры.НаправлениеДеятельности	= Док.НаправлениеДеятельности;
			ДопПараметры.ДоговорССамозанятым		= Док.ОперацияССамозанятым;
			ДоговорПоУмолчанию = Модуль_ЗакупкиСервер.ПолучитьДоговорПоУмолчанию(Док, ХозяйственнаяОперацияОтбора, ДопПараметры);
			
		Иначе
			
			ДопПараметры = Модуль_ЗакупкиСервер.ДополнительныеПараметрыОтбораДоговоров();
			ДопПараметры.ВалютаВзаиморасчетов = Док.ВалютаВзаиморасчетов;
			ДопПараметры.ДоговорССамозанятым = Док.ОперацияССамозанятым;
			ДоговорПоУмолчанию = Модуль_ЗакупкиСервер.ПолучитьДоговорПоУмолчанию(Док, ХозяйственнаяОперацияОтбора, ДопПараметры);
			
		КонецЕсли;
		
		ИспользуютсяДоговорыПоСоглашению = Не ЗначениеЗаполнено(Док.Соглашение)
		Или Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док.Соглашение, "ИспользуютсяДоговорыКонтрагентов");
		Если (Док.Договор <> ДоговорПоУмолчанию
			Или Не ЗначениеЗаполнено(Док.Договор))
			И ИспользуютсяДоговорыПоСоглашению Тогда
			
			Док.Договор = ДоговорПоУмолчанию;
			
			Модуль_ЗакупкиВызовСервера.ЗаполнитьБанковскиеСчетаПоДоговору(Док.Договор, Док.БанковскийСчетОрганизации, Док.БанковскийСчетКонтрагента);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьСтатусЕслиИспользуютсяСерииДляРеализации(Док, Шаблон)
	
	СерииВОтдельнойТЧ = Шаблон.СерииВОтдельнойТЧ;
	лЕстьСерия = (Шаблон.ИспользованиеСерийниковПодбор > 0 И (Док.Метаданные().ТабличныеЧасти.Товары.Реквизиты.Найти("Серия") <> Неопределено)) И СерииВОтдельнойТЧ;
	
	Если лЕстьСерия Тогда
		Док.Статус = Перечисления.СтатусыРеализацийТоваровУслуг.Отгружено; //влияет на статус указания серий, было КПредоплате
	КонецЕсли;
	
КонецПроцедуры

Процедура ПеренестиВДокументНовыеЗначенияРеквизитов(Об, Док, Шаблон)
	
	Если СокрЛП(Шаблон.ВидДокументаНового) = ""
		Или (Шаблон.ВидДокумента = "ПриобретениеТоваровУслуг" И Шаблон.ВидДокументаНового = "ПриходныйОрдерНаТовары") Тогда//старая схема
				
		Для каждого НовЗнач Из Шаблон.НовыеЗначенияРеквизитов Цикл
			Попытка Док[НовЗнач.ИмяРеквизита] = НовЗнач.ЗначениеРеквизита; Исключение КонецПопытки;
		КонецЦикла;
						
	Иначе	
		Попытка
			Если Шаблон.НовыеЗначенияРеквизитов.Количество() > 0 Тогда
				ИсходныйДок = Об.ИсходныйДокумент.ПолучитьОбъект();
				Для каждого НовЗнач Из Шаблон.НовыеЗначенияРеквизитов Цикл
					Попытка ИсходныйДок[НовЗнач.ИмяРеквизита] = НовЗнач.ЗначениеРеквизита; Исключение КонецПопытки;	
				КонецЦикла;	
				ИсходныйДок.Записать();
			КонецЕсли;
		Исключение
		КонецПопытки;	
			
		Для каждого НовЗнач Из Шаблон.НовыеЗначенияРеквизитовНового Цикл
			Попытка Док[НовЗнач.ИмяРеквизита] = НовЗнач.ЗначениеРеквизита; Исключение КонецПопытки;	
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьНастройкуТЧПриЗагрузкеПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, ТЧПриЗагрузкеПодбор)
	
	МетаданныеДокумента = ИсходныйДокумент.Метаданные().Имя; 
	Шаблон = ДокументТСД.Шаблон; 
	
	СтруктураРеквизитовШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(Шаблон, 
	"ПроверкаОтборРазмещение");
	
	ПроверкаОтборРазмещение = СтруктураРеквизитовШаблона.ПроверкаОтборРазмещение; 
		
	Если ТЧПриЗагрузкеПодбор = 0 Тогда
		
		Если МетаданныеДокумента <> "ПриобретениеТоваровУслуг" И МетаданныеДокумента <> "ПриемкаТоваровИСМП" Тогда
			Попытка ИсходныйДокумент.ШтрихкодыУпаковок.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.АкцизныеМарки.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.Марки.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.ДанныеОтчетаПроизводственнойЛинии.Очистить(); Исключение КонецПопытки;
		КонецЕсли;
		
	ИначеЕсли ТЧПриЗагрузкеПодбор = 2 Тогда
		
		Если МетаданныеДокумента <> "ПриобретениеТоваровУслуг" И МетаданныеДокумента <> "ПриемкаТоваровИСМП" Тогда
			Попытка ИсходныйДокумент.ШтрихкодыУпаковок.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.АкцизныеМарки.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.Марки.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.ДанныеОтчетаПроизводственнойЛинии.Очистить(); Исключение КонецПопытки;
		КонецЕсли;
		
		ИсходныйДокумент[ИмяТЧПодбор].Очистить();
		
	ИначеЕсли ТЧПриЗагрузкеПодбор = 3 Тогда
		
		Если МетаданныеДокумента <> "ПриобретениеТоваровУслуг" И МетаданныеДокумента <> "ПриемкаТоваровИСМП" Тогда
			Попытка ИсходныйДокумент.ШтрихкодыУпаковок.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.АкцизныеМарки.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.Марки.Очистить(); Исключение КонецПопытки;
			Попытка ИсходныйДокумент.ДанныеОтчетаПроизводственнойЛинии.Очистить(); Исключение КонецПопытки;
		КонецЕсли;
		
		Для каждого Стр Из ИсходныйДокумент[ИмяТЧПодбор] Цикл
			
			// БЫЛО:
			//Попытка Стр.Количество = 0; Исключение КонецПопытки;
			//Попытка Стр.КоличествоУпаковок = 0; Исключение КонецПопытки;
			
			// СТАЛО:
			Если МетаданныеДокумента = "ПересчетТоваров" Тогда
				Попытка Стр.КоличествоФакт = 0; Исключение КонецПопытки;
				Попытка Стр.КоличествоУпаковокФакт = 0; Исключение КонецПопытки;
			Иначе 
				СтатусБезОшибок = Ложь;
				
				Если МетаданныеДокумента = "ОтборРазмещениеТоваров" Тогда
					Попытка Стр.КоличествоУпаковокОтобрано = 0; Исключение КонецПопытки;
					Попытка Стр.КоличествоОтобрано = 0; Исключение КонецПопытки; 
					
					СтатусБезОшибок = (ИсходныйДокумент.Статус = Перечисления.СтатусыОтборовРазмещенийТоваров.ВыполненоБезОшибок);
				КонецЕсли;				
				
				Если Не ПроверкаОтборРазмещение Или СтатусБезОшибок Тогда
					Попытка Стр.Количество = 0; Исключение КонецПопытки;
					Попытка Стр.КоличествоУпаковок = 0; Исключение КонецПопытки;
					Попытка Стр.Ячейка = Справочники.СкладскиеЯчейки.ПустаяСсылка(); Исключение КонецПопытки;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла; 
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьИзменениеТЧПодбор(ДокументТСД, ИсходныйДокумент, ИмяТЧПодбор, КопияТЧ = Неопределено, 
									   ЭтоГрупповойДокумент = Ложь, ВыбВидПродукции = Неопределено, ЭтоПриемка = Ложь)
									   
	// Тип ДокументТСД:
	
	// 1. ДокументОбъект.ДатаМобайл_ДокументыТСД
	// 2. Структура
	
	Если ЭтоГрупповойДокумент И ТипЗнч(ДокументТСД) = Тип("Структура") Тогда
		
		// Получим данные из структуры
		ТЗОтбораПоДокументу = ДокументТСД.ТЗОтбораПоДокументу;
		
		// Переопределим переменную
		ДокументТСД = ДокументТСД.ДокументТСД; 
		
	КонецЕсли;	
	
	МетаданныеДокумента = ИсходныйДокумент.Метаданные();
	ИмяДока = МетаданныеДокумента.Имя;    
	
	Модуль_ИнтеграцияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСКлиентСервер");
	Модуль_ИнтеграцияИСУТКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСУТКлиентСервер");
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	Модуль_ОбщегоНазначенияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначенияИСКлиентСервер");
			
	Шаблон = ДокументТСД.Шаблон;
		
	СтруктураРеквизитовШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(Шаблон, 
	"БазовыеЕдиницыПриЗагрузке, ТабличнуюЧастьПриЗагрузкеПодбор, СерииВОтдельнойТЧ, ИспользованиеСерийниковПодбор,
	|ИспользованиеСерийниковПриемка, ИсточникСерии, ИспользованиеЯчеекПодбор, БазовыеУпаковкиПриЗагрузке, 
	|ИспользованиеЯчеекПриемка, ТабличнуюЧастьПриЗагрузкеПриемка, ПроверкаОтборРазмещение, РежимКомплектации,
	|ИспользоватьДопФормы, НаборыВариантыЗаполнения, ВидДокументаНового, ИмяТабличнойЧастиПодбор, ЗаполнениеGTINВТЧДокумента"); 
	
	РежимКомплектации					= СтруктураРеквизитовШаблона.РежимКомплектации;
	БазовыеЕдиницыПриЗагрузке 			= СтруктураРеквизитовШаблона.БазовыеЕдиницыПриЗагрузке;
	СерииВОтдельнойТЧ 					= СтруктураРеквизитовШаблона.СерииВОтдельнойТЧ;
	ИсточникСерии						= СтруктураРеквизитовШаблона.ИсточникСерии;
	БазовыеУпаковкиПриЗагрузке          = СтруктураРеквизитовШаблона.БазовыеУпаковкиПриЗагрузке;
	ПроверкаОтборРазмещение             = СтруктураРеквизитовШаблона.ПроверкаОтборРазмещение;
	ИспользоватьДопФормы    			= СтруктураРеквизитовШаблона.ИспользоватьДопФормы; 
	НаборыВариантыЗаполнения			= СтруктураРеквизитовШаблона.НаборыВариантыЗаполнения;
    ВидДокументаНового					= СтруктураРеквизитовШаблона.ВидДокументаНового;
    ИмяТЧПодборИсходногоДокумента		= СтруктураРеквизитовШаблона.ИмяТабличнойЧастиПодбор;
	
	ПараметрыДокумента = Новый Структура;
	
	Попытка
		ПараметрыДокумента.Вставить("ИсхДокумент", ДокументТСД.ПолучитьОбъект());
		ПараметрыДокумента.Вставить("ИсхДокументЗаписать", Ложь);
	Исключение
		ПараметрыДокумента.Вставить("ИсхДокумент", Неопределено);
		ПараметрыДокумента.Вставить("ИсхДокументЗаписать", Ложь);
	КонецПопытки;
	
	Если ЭтоПриемка Тогда
		СобранныеДанные = ВыгрузитьСобранныеДанныеПриемка(ДокументТСД);
		
		ТабличнуюЧастьПриЗагрузке       = СтруктураРеквизитовШаблона.ТабличнуюЧастьПриЗагрузкеПриемка;
		ИспользованиеСерийников			= СтруктураРеквизитовШаблона.ИспользованиеСерийниковПриемка;
		ИспользованиеЯчеек				= СтруктураРеквизитовШаблона.ИспользованиеЯчеекПриемка;
	Иначе
		СобранныеДанные = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		
		ТабличнуюЧастьПриЗагрузке		= СтруктураРеквизитовШаблона.ТабличнуюЧастьПриЗагрузкеПодбор;
		ИспользованиеСерийников			= СтруктураРеквизитовШаблона.ИспользованиеСерийниковПодбор;
		ИспользованиеЯчеек				= СтруктураРеквизитовШаблона.ИспользованиеЯчеекПодбор;
	КонецЕсли;
	
	Попытка 
		ДатаСозданияДокаТСД = ДокументТСД.ДатаСоздания;
	Исключение
		ДатаСозданияДокаТСД = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
		ДатаМобайл_ОбщийМодуль.ОбработатьИсключение(0, "ОбработатьИзменениеТЧПодбор", ОписаниеОшибки());	
	КонецПопытки;
	
	лЕстьСерия = ((ИспользованиеСерийников > 0 Или ИсточникСерии = 2) И (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("Серия") <> Неопределено)) И Не ЭтоГрупповойДокумент;
	лЕстьСерияВОтдельнойТЧ = МетаданныеДокумента.ТабличныеЧасти.Найти("Серии") <> Неопределено;
	//В задании в отдельной ТЧ, в подчиненном в основной ТЧ
	Если лЕстьСерия тогда 
		Если лЕстьСерияВОтдельнойТЧ И СерииВОтдельнойТЧ тогда
			лЕстьСерия = Ложь;
		КонецЕсли;	
	КонецЕсли;
	
	Если ЭтоГрупповойДокумент Тогда
		ТЗСобранныеДанные = ТЗОтбораПоДокументу;
	Иначе
	 
		//Если ИмяДока = "МаркировкаТоваровИСМП" Тогда
		//	ТЗСобранныеДанные = ПолучитьВложенныеТоварыВУпаковку(ДокументТСД);  DMX-12728
		//Иначе
			ТЗСобранныеДанные = СобранныеДанные; 
		//КонецЕсли;    
			
		Если БазовыеЕдиницыПриЗагрузке Тогда
			ТЗСобранныеДанные = ПересчитатьКоличествоЕдиницуИзмерения(ДокументТСД.Ссылка, ЭтоПриемка);		
		КонецЕсли;  
		
		Если лЕстьСерия Тогда
			ТЗСобранныеДанные.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, ЯчейкаСсылка, СерияСсылка", "Количество");
		Иначе                                                                                                                                          
			
			Если РежимКомплектации = 1 И НаборыВариантыЗаполнения = 0 Тогда
				
				Запрос = Новый Запрос;
				Запрос.Текст = 
				"ВЫБРАТЬ        
				|	ВТ.ВариантКомплектацииНабора,
				|	ВТ.ЕдиницаИзмерения,
				|	ВТ.KM_GTIN,
				|	ВТ.ЯчейкаСсылка,
				|	ВТ.СерияСсылка,
				|	ВТ.КоличествоНаборов
				|ПОМЕСТИТЬ ВТ
				|ИЗ
				|	&ВТ КАК ВТ
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ВТ.ВариантКомплектацииНабора.Владелец КАК Номенклатура,
				|	ВТ.ВариантКомплектацииНабора.Характеристика КАК ХарактеристикаНоменклатуры,
				|	ВТ.ЕдиницаИзмерения,
				|	ВТ.KM_GTIN,
				|	ВТ.ЯчейкаСсылка,
				|	ВТ.СерияСсылка,
				|	ВТ.КоличествоНаборов КАК Количество
				|ИЗ
				|	ВТ КАК ВТ"; 
				Запрос.УстановитьПараметр("ВТ", ТЗСобранныеДанные);
				Результат = Запрос.Выполнить();
				ТЗСобранныеДанные = Результат.Выгрузить();
				
			КонецЕсли;		
			
			ТЗСобранныеДанные.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, ЯчейкаСсылка", "Количество");		
			
		КонецЕсли;
					
	КонецЕсли; 
	
	лЕстьGTIN = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("GTIN") <> Неопределено);
	
	Если ИмяДока = "МаркировкаТоваровИСМП" Тогда 
		
		Если Не ИсходныйДокумент.Операция = ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.ВводВОборотМаркировкаОстатков") Тогда
			лЕстьGTIN = Ложь;	
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не лЕстьGTIN Тогда
		
		Если ЭтоГрупповойДокумент Тогда
			ТЗСобранныеДанные.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения", "Количество");	
		Иначе	
			ТЗСобранныеДанные.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЯчейкаСсылка", "Количество");		
		КонецЕсли;	
		
	КонецЕсли; 
	
	Если ТабличнуюЧастьПриЗагрузке = 5 Тогда
		КопияТЧ = Неопределено;		
	КонецЕсли; 
	
	ЭтоВыводИзОборотаИСМП = ИмяДока = "ВыводИзОборотаИСМП";
	
	Если ЭтоВыводИзОборотаИСМП Тогда
		
		Если Не ВыбВидПродукции = Неопределено Тогда
			ОсобенностьУчетаМассив = Новый Массив; 
			ОсобенностьУчетаМассив.Добавить(Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(ВыбВидПродукции));
			
		Иначе // все
			
			Попытка
				ФильтрВидПродукции = Модуль_ИнтеграцияИСКлиентСервер.ВидыПродукцииИСМП(Истина);
			Исключение
				ФильтрВидПродукции = Модуль_ОбщегоНазначенияИСКлиентСервер.ВидыПродукцииИСМП(Истина);
			КонецПопытки;
		
			ОсобенностьУчетаМассив = Новый Массив;  
			
			Для каждого ВидПродукции Из ФильтрВидПродукции Цикл
				ОсобенностьУчетаМассив.Добавить(Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(ВидПродукции));
			КонецЦикла;
			
		КонецЕсли; 
		
	КонецЕсли; 
							
	лЕстьЯчейка = (ИспользованиеЯчеек > 0 И (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("Ячейка") <> Неопределено));
	лЕстьЕдиницаИзмерения = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("ЕдиницаИзмерения") <> Неопределено);
	лЕстьУпаковка = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("Упаковка") <> Неопределено);
	лЕстьИдентификаторСтроки = (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("ИдентификаторСтроки") <> Неопределено);
	лЕстьНазначение = МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("Назначение") <> Неопределено;
		
	Если лЕстьСерия Тогда		
		ТЗСобранныеДанные = ?(ЭтоПриемка, ВыгрузитьСобранныеДанныеПриемка(ДокументТСД), ВыгрузитьСобранныеДанныеПодбор(ДокументТСД));
		ТЗСобранныеДанные.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, СерияСсылка, ЯчейкаСсылка", "Количество");			
	КонецЕсли;
	
	Если ИмяДока = "ОтборРазмещениеТоваров" И ЭтоПриемка Тогда 
		лЕстьЯчейка = (СтруктураРеквизитовШаблона.ИспользованиеЯчеекПриемка > 0 И (МетаданныеДокумента.ТабличныеЧасти[ИмяТЧПодбор].Реквизиты.Найти("Ячейка") <> Неопределено));	
	КонецЕсли;
	
	ПустаяУпаковка = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
	
	НазначениеЗаполненоВТЧПодбор = Ложь;
	ИсходныйДокТЧПодбор = Неопределено;
	Если Не ЭтоПриемка И лЕстьНазначение Тогда
		Если ВидДокументаНового <> "" Тогда
			Попытка
				ИсходныйДокТЧПодбор = ДокументТСД.ИсходныйДокумент[ИмяТЧПодборИсходногоДокумента].Выгрузить();
				НазначениеЗаполненоВТЧПодбор = Обработки.ДатаМобайл_АРМДиспетчера.ПолучитьНазначениеЗаполненоВТЧ(ИсходныйДокТЧПодбор);
			Исключение
				НазначениеЗаполненоВТЧПодбор = Ложь;
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	ТаблицаДопФорм = Новый ТаблицаЗначений;
	ЕстьДополнительныеФормыДляПоискаСтрок = Обработки.ДатаМобайл_АРМДиспетчера.ЕстьДополнительныеФормыДляПоискаСтрок(Шаблон, 0, ТаблицаДопФорм) И ИспользоватьДопФормы;
	
	Если ЕстьДополнительныеФормыДляПоискаСтрок Тогда
		ТЗСобранныеДанные = Обработки.ДатаМобайл_АРМДиспетчера.ПолучитьТабТСДСУчетомДополнительныхФорм(ДокументТСД.Ссылка, 0, ТаблицаДопФорм, Истина);
		НазначениеЗаполненоВТЧПодбор = Ложь;
	КонецЕсли;
	
	Если НазначениеЗаполненоВТЧПодбор Тогда
		ТЗСобранныеДанные = Обработки.ДатаМобайл_АРМДиспетчера.ДополнитьНазначениемТабТСД(ТЗСобранныеДанные, ИсходныйДокТЧПодбор, лЕстьСерия);	
	КонецЕсли;
	
	Для каждого СтрТЧ Из ТЗСобранныеДанные Цикл
		
		Если СтрТЧ.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если ИмяДока = "МаркировкаТоваровИСМП" Тогда
			Если ПолучитьТипМаркированнойПродукции(СтрТЧ.Номенклатура) = 0 Тогда
				Продолжить;
			КонецЕсли;			
		КонецЕсли;
		
		ОсобенностьУчета = СтрТЧ.Номенклатура.ОсобенностьУчета;
		
		Если ЭтоВыводИзОборотаИСМП И (ОсобенностьУчета.Пустая() Или ОсобенностьУчетаМассив.Найти(ОсобенностьУчета) = Неопределено) Тогда	
			Продолжить;	
		КонецЕсли;       
				
		Попытка 
			
			Если СтрТЧ.ЕдиницаИзмерения.ТипУпаковки = Перечисления.ТипыУпаковокНоменклатуры.Разупаковка Тогда
				
				КоэффициентУпаковки = ?(СтрТЧ.ЕдиницаИзмерения.Числитель = 0, 1, СтрТЧ.ЕдиницаИзмерения.Знаменатель) / ?(СтрТЧ.ЕдиницаИзмерения.Числитель = 0, 1, СтрТЧ.ЕдиницаИзмерения.Знаменатель);

			Иначе	
				
				КоэффициентУпаковки = СтрТЧ.ЕдиницаИзмерения.Числитель / СтрТЧ.ЕдиницаИзмерения.Знаменатель;
				
			КонецЕсли; 
			
			КоэффициентУпаковки = ?(КоэффициентУпаковки = 0, 1, КоэффициентУпаковки);
			
		Исключение
			КоэффициентУпаковки = ?(СтрТЧ.ЕдиницаИзмерения.Числитель = 0, 1, СтрТЧ.ЕдиницаИзмерения.Числитель);
		Конецпопытки;
		
		Если БазовыеЕдиницыПриЗагрузке Тогда					
			//ТекущаяЕдиницаИзмерения = СтрТЧ.Номенклатура.ЕдиницаИзмерения;
			СтрТЧ.Количество = СтрТЧ.Количество * КоэффициентУпаковки;
			ТекущаяЕдиницаИзмерения = Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
			КоэффициентУпаковки = 1;
		Иначе
			ТекущаяЕдиницаИзмерения = СтрТЧ.ЕдиницаИзмерения;
		КонецЕсли;	
						
		лСтруктураПоиска = Новый Структура("Номенклатура, Характеристика", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры);
		
		Если лЕстьУпаковка Тогда
			// Проверка на заполненность упаковок
			//Если БазовыеУпаковкиПриЗагрузке И СтрТЧ.Номенклатура.ИспользоватьУпаковки И Не СтрТЧ.Номенклатура.ВесИспользовать И Не ЗначениеЗаполнено(СтрТЧ.ЕдиницаИзмерения) Тогда
			Если БазовыеУпаковкиПриЗагрузке И СтрТЧ.Номенклатура.ИспользоватьУпаковки Тогда
				ТекущаяЕдиницаИзмерения = Обработки.ДатаМобайл_АРМДиспетчера.ПолучитьБазовуюУпаковкуНоменклатуры(СтрТЧ.Номенклатура);	
				
				Если Не ЗначениеЗаполнено(ТекущаяЕдиницаИзмерения) И ИмяДока = "ОтборРазмещениеТоваров" Тогда
					СтрокаОшибок = "Не выбрана упаковка, для документа обязательно указание упаковок!!!";
					Возврат; 
				КонецЕсли;	
			КонецЕсли;
			
			лСтруктураПоиска.Вставить("Упаковка", ТекущаяЕдиницаИзмерения);												
		КонецЕсли; 
		
		Если лЕстьЕдиницаИзмерения Тогда
			лСтруктураПоиска.Вставить("ЕдиницаИзмерения", ТекущаяЕдиницаИзмерения);
		КонецЕсли; 
		
		Если лЕстьGTIN Тогда
			лСтруктураПоиска.Вставить("GTIN", СтрТЧ.KM_GTIN);
		КонецЕсли;
		
		Если лЕстьСерия Тогда
			лСтруктураПоиска.Вставить("Серия", СтрТЧ.СерияСсылка);
		КонецЕсли;
		
		Если лЕстьЯчейка Тогда
			лСтруктураПоиска.Вставить("Ячейка", СтрТЧ.ЯчейкаСсылка);
		КонецЕсли;
		              	
		СтрокиПоискаКопияТЧ = Неопределено;
		лСтруктураПоискаКопия = Новый Структура;
		
		Для каждого СтрокаСтрПоиска Из лСтруктураПоиска Цикл
			лСтруктураПоискаКопия.Вставить(СтрокаСтрПоиска.Ключ, СтрокаСтрПоиска.Значение);
		КонецЦикла;
		
		Если КопияТЧ <> Неопределено И (ИмяДока = "РеализацияТоваровУслуг" Или ИмяДока = "ПриобретениеТоваровУслуг" Или ИмяДока = "ВозвратТоваровОтКлиента" Или ЭтоВыводИзОборотаИСМП) Тогда
			
			Если ЭтоВыводИзОборотаИСМП И лЕстьGTIN Тогда				
				лСтруктураПоискаКопия.Удалить("GTIN");
				СтрокиПоискаКопияТЧ = КопияТЧ.НайтиСтроки(лСтруктураПоискаКопия);						
			Иначе	
				СтрокиПоискаКопияТЧ = КопияТЧ.НайтиСтроки(лСтруктураПоискаКопия);	
			КонецЕсли;
			
			Если СтрокиПоискаКопияТЧ.Количество() = 0 И КоэффициентУпаковки = 1 Тогда				
				Попытка лСтруктураПоискаКопия.Упаковка = ПустаяУпаковка; Исключение Конецпопытки;	
				СтрокиПоискаКопияТЧ = КопияТЧ.НайтиСтроки(лСтруктураПоискаКопия);				
			КонецЕсли;
			
			Если СтрокиПоискаКопияТЧ.Количество() = 0 И лЕстьСерия Тогда				
				лСтруктураПоискаКопия.Удалить("Серия");
				СтрокиПоискаКопияТЧ = КопияТЧ.НайтиСтроки(лСтруктураПоискаКопия);				
			КонецЕсли;
			
		КонецЕсли; 
		
		Если ЕстьДополнительныеФормыДляПоискаСтрок Тогда
			Обработки.ДатаМобайл_АРМДиспетчера.ОбработатьСтруктуруПоискаСУчетомДополнительныхФорм(лСтруктураПоиска, ТаблицаДопФорм, СтрТЧ, Шаблон, МетаданныеДокумента);
		КонецЕсли;
		
		СтрокиПоиска = ИсходныйДокумент[ИмяТЧПодбор].НайтиСтроки(лСтруктураПоиска);			
		Если КоэффициентУпаковки = 1 И СтрокиПоиска.Количество() = 0 Тогда
			Попытка лСтруктураПоиска.Упаковка = ПустаяУпаковка; Исключение Конецпопытки;
			СтрокиПоиска = ИсходныйДокумент[ИмяТЧПодбор].НайтиСтроки(лСтруктураПоиска);
		КонецЕсли;
						
		Если СтрокиПоиска.Количество() <> 0 Тогда		
			СтрокаТабличнойЧасти = СтрокиПоиска[0];  
			
			Если КопияТЧ <> Неопределено И СтрокиПоискаКопияТЧ <> Неопределено Тогда
				Если СтрокиПоискаКопияТЧ.Количество() <> 0 Тогда
					Если СтрТЧ.Количество > 0 Тогда
						//ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаКопияТЧ[0]);
						Попытка			
							ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаКопияТЧ[0], , "КоличествоУпаковок, Количество");
						Исключение
							Попытка
								ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаКопияТЧ[0], , "Количество");
							Исключение
								ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаКопияТЧ[0]);
							КонецПопытки;
						КонецПопытки;					
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;			
			
		Иначе
			
			СтрокаТабличнойЧасти = ИсходныйДокумент[ИмяТЧПодбор].Добавить();
			
			СтрокаТабличнойЧасти.Номенклатура = СтрТЧ.Номенклатура;
			СтрокаТабличнойЧасти.Характеристика = СтрТЧ.ХарактеристикаНоменклатуры;
			
			Если ИмяДока = "МаркировкаТоваровИСМП" Тогда
				
				ДанныеВСД = ПолучитьВСДПоТовару(СтрокаТабличнойЧасти.Номенклатура);
				
				Если ДанныеВСД <> Неопределено Тогда
					ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, ДанныеВСД);	
				КонецЕсли; 
				
			КонецЕсли;
			
			Если лЕстьУпаковка Тогда				
				СтрокаТабличнойЧасти.Упаковка = ТекущаяЕдиницаИзмерения;				
			КонецЕсли; 
			
			Если лЕстьЕдиницаИзмерения Тогда				
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = ТекущаяЕдиницаИзмерения;				
			КонецЕсли;
			
			Если лЕстьGTIN И СтруктураРеквизитовШаблона.ЗаполнениеGTINВТЧДокумента Тогда
				СтрокаТабличнойЧасти.GTIN = СтрТЧ.KM_GTIN;
			КонецЕсли;
						
			Если лЕстьСерия Тогда				
				СтрокаТабличнойЧасти.Серия = СтрТЧ.СерияСсылка;				
				Если ИмяДока = "МаркировкаТоваровИСМП" И 
					(Модуль_ОбщегоНазначенияИСКлиентСервер.ЭтоВидПродукцииСоСрокамиГодности(Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(ОсобенностьУчета))) Тогда				
					Попытка СтрокаТабличнойЧасти.СрокГодности = Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрТЧ.СерияСсылка, "ГоденДо"); Исключение КонецПопытки;
					Если ЗначениеЗаполнено(СтрТЧ.СерияСсылка) Тогда
						СтрокаТабличнойЧасти.СтатусУказанияСерий = 2;
					КонецЕсли;
				КонецЕсли;				
			КонецЕсли;
				
			Если лЕстьЯчейка Тогда
				СтрокаТабличнойЧасти.Ячейка = СтрТЧ.ЯчейкаСсылка;
			КонецЕсли;
			
			Если лЕстьИдентификаторСтроки Тогда
				СтрокаТабличнойЧасти.ИдентификаторСтроки = Новый УникальныйИдентификатор();
			КонецЕсли;		
						
			Обработки.ДатаМобайл_АРМДиспетчера.ОбработатьНовуюСтрокуТЧ(Новый Структура("Об", ДокументТСД), ИсходныйДокумент, ИмяТЧПодбор, СтрокаТабличнойЧасти); 
			
			Если ИмяДока = "МаркировкаТоваровИСМП" Тогда				
				
				Если ОсобенностьУчета = Перечисления.ОсобенностиУчетаНоменклатуры.УпакованнаяВода Тогда
					Попытка СтрокаТабличнойЧасти.КодТНВЭД = ПолучитьКодТНВЭДПоВидуПродукции(ОсобенностьУчета); Исключение КонецПопытки;
				КонецЕсли;	
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ИмяДока = "МаркировкаТоваровИСМП" Тогда
			ЗаполнитьСрокГодностиПоДатеПроизводства(СтрТЧ, ИсходныйДокумент, СтрокаТабличнойЧасти);
			
			Попытка
				Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СрокГодности) Тогда
					
					СрокГодностиЧасы = ДопРеквизитСрокГодности(СтрокаТабличнойЧасти.Номенклатура); 
					
					Если ЗначениеЗаполнено(ИсходныйДокумент.ДатаПроизводства) Тогда
						ИсхДата = ИсходныйДокумент.ДатаПроизводства;
					Иначе
						ИсхДата = ДатаСозданияДокаТСД;
					КонецЕсли;
					
					Если СрокГодностиЧасы <> Неопределено Тогда
						СтрокаТабличнойЧасти.СрокГодности = ИсхДата + СрокГодностиЧасы;	
					КонецЕсли;
					
				КонецЕсли; 
				
			Исключение   
				ДатаМобайл_ОбщийМодуль.ОбработатьИсключение(0, "ОбработатьИзменениеТЧПодбор", ОписаниеОшибки());	
			КонецПопытки;
		КонецЕсли;
		
		Если НазначениеЗаполненоВТЧПодбор Тогда
			Попытка
				Обработки.ДатаМобайл_АРМДиспетчера.ЗаполнитьНазначениеВСтрокеТЧ(Новый Структура("ИсходныйДокумент, БазовыеЕдиницыПриЗагрузке", ДокументТСД.ИсходныйДокумент, БазовыеЕдиницыПриЗагрузке), лСтруктураПоиска, СтрокаТабличнойЧасти); 
			Исключение 
			КонецПопытки;
		КонецЕсли;
		
		Если ТабличнуюЧастьПриЗагрузке = 5 Тогда
				
			Попытка				
				СтрокаТабличнойЧасти.КоличествоУпаковок = СтрТЧ.Количество;  
				СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.КоличествоУпаковок * КоэффициентУпаковки;				
			Исключение
				СтрокаТабличнойЧасти.Количество = СтрТЧ.Количество;
			КонецПопытки;
			
		Иначе			
			
			Если ИмяДока = "ПересчетТоваров" Тогда
				
				СтрокаТабличнойЧасти.КоличествоУпаковокФакт = СтрокаТабличнойЧасти.КоличествоУпаковокФакт + СтрТЧ.Количество;
				СтрокаТабличнойЧасти.КоличествоФакт = СтрокаТабличнойЧасти.КоличествоУпаковокФакт * КоэффициентУпаковки;
				
			ИначеЕсли ИмяДока = "ОтборРазмещениеТоваров" И ПроверкаОтборРазмещение Тогда
				
				Если ИсходныйДокумент.Статус = Перечисления.СтатусыОтборовРазмещенийТоваров.ВыполненоСОшибками Тогда
					
					Попытка
						СтрокаТабличнойЧасти.КоличествоУпаковокОтобрано = СтрокаТабличнойЧасти.КоличествоУпаковокОтобрано + СтрТЧ.Количество;
					Исключение
						СтрокаТабличнойЧасти.КоличествоУпаковокРазмещено = СтрокаТабличнойЧасти.КоличествоУпаковокРазмещено + СтрТЧ.Количество;
					КонецПопытки;
					
					Попытка
						СтрокаТабличнойЧасти.КоличествоОтобрано = СтрокаТабличнойЧасти.КоличествоУпаковокОтобрано * КоэффициентУпаковки;
					Исключение
						СтрокаТабличнойЧасти.КоличествоРазмещено = СтрокаТабличнойЧасти.КоличествоУпаковокРазмещено * КоэффициентУпаковки;
					КонецПопытки;	
									
				Иначе	
						
					СтрокаТабличнойЧасти.КоличествоУпаковок = СтрокаТабличнойЧасти.КоличествоУпаковок + СтрТЧ.Количество;
					СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.КоличествоУпаковок * КоэффициентУпаковки;
					
					Попытка
						СтрокаТабличнойЧасти.КоличествоУпаковокОтобрано = СтрокаТабличнойЧасти.КоличествоУпаковок;
					Исключение
						СтрокаТабличнойЧасти.КоличествоУпаковокРазмещено = СтрокаТабличнойЧасти.КоличествоУпаковок;
					КонецПопытки;
					
					Попытка
						СтрокаТабличнойЧасти.КоличествоОтобрано = СтрокаТабличнойЧасти.Количество; 
					Исключение
						СтрокаТабличнойЧасти.КоличествоРазмещено = СтрокаТабличнойЧасти.Количество;	
					КонецПопытки;
					
				КонецЕсли;
				
			Иначе
				
				Попытка			
					СтрокаТабличнойЧасти.КоличествоУпаковок = СтрокаТабличнойЧасти.КоличествоУпаковок + СтрТЧ.Количество;  
					СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.КоличествоУпаковок * КоэффициентУпаковки;					
				Исключение
					СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.Количество + СтрТЧ.Количество * КоэффициентУпаковки;
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЕстьДополнительныеФормыДляПоискаСтрок Тогда
			Обработки.ДатаМобайл_АРМДиспетчера.ОбработатьСтрокуСУчетомДополнительныхФорм(СтрокаТабличнойЧасти, ТаблицаДопФорм, СтрТЧ, Шаблон, МетаданныеДокумента);
		КонецЕсли;
		
		// доп формы без поиска
		Обработки.ДатаМобайл_АРМДиспетчера.ИзменитьРеквизитыТабличнойЧастиИзДополнительныхФорм(ИсходныйДокумент, ИмяТЧПодбор, "", Шаблон, ДокументТСД.Ссылка, ПараметрыДокумента);

		Обработки.ДатаМобайл_АРМДиспетчера.ОбработатьСтрокуТЧ(ИсходныйДокумент, ИмяТЧПодбор, СтрокаТабличнойЧасти, Шаблон);
		
	КонецЦикла;
	
	// Серии в отдельной ТЧ
	Если МетаданныеДокумента.ТабличныеЧасти.Найти("Серии") <> Неопределено И СерииВОтдельнойТЧ И Не ЭтоГрупповойДокумент Тогда
		
		Если ТабличнуюЧастьПриЗагрузке > 1 И ТабличнуюЧастьПриЗагрузке < 5 Тогда
			Попытка ИсходныйДокумент.Серии.Очистить(); Исключение КонецПопытки;	
		КонецЕсли; 
		
		ТЗСобранныеДанные = ?(ЭтоПриемка, ВыгрузитьСобранныеДанныеПриемка(ДокументТСД), ВыгрузитьСобранныеДанныеПодбор(ДокументТСД));
		ТЗСобранныеДанные.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, KM_GTIN, СерияСсылка, УпаковочныйЛистСсылка", "Количество");
		
		Для каждого СтрТЧ Из ТЗСобранныеДанные Цикл
			
			СерияПоУпаковке = Неопределено;
			
			Если СтрТЧ.СерияСсылка.Пустая() Или СтрТЧ.Количество = 0 Тогда				
				Если ЗначениеЗаполнено(СтрТЧ.УпаковочныйЛистСсылка) Тогда
					СерияПоУпаковке = СтрТЧ.УпаковочныйЛистСсылка.Серия;
				КонецЕсли;
				 
				Если Не ЗначениеЗаполнено(СерияПоУпаковке) Тогда
					Продолжить;	
				КонецЕсли;		
			КонецЕсли; 
			
			Если ЗначениеЗаполнено(СерияПоУпаковке) Тогда
				Серия = СерияПоУпаковке;	
			Иначе	
				Серия = СтрТЧ.СерияСсылка;
			КонецЕсли;	
			
			Попытка 
				
				КоэффициентУпаковки = СтрТЧ.ЕдиницаИзмерения.Числитель/СтрТЧ.ЕдиницаИзмерения.Знаменатель;
				КоэффициентУпаковки = ?(КоэффициентУпаковки = 0, 1, КоэффициентУпаковки);
				
			Исключение
				КоэффициентУпаковки = ?(СтрТЧ.ЕдиницаИзмерения.Числитель = 0, 1, СтрТЧ.ЕдиницаИзмерения.Числитель);
			Конецпопытки;	
			
			лСтруктураПоискаСерий = Новый Структура("Номенклатура,Характеристика,Серия", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры, Серия);
			СтрокиПоискаСерий = ИсходныйДокумент["Серии"].НайтиСтроки(лСтруктураПоискаСерий);
			
			Если СтрокиПоискаСерий.Количество() = 0 Тогда
				
				СтрокаТабличнойЧастиСерии = ИсходныйДокумент["Серии"].Добавить();
				
				СтрокаТабличнойЧастиСерии.Номенклатура = СтрТЧ.Номенклатура;
				СтрокаТабличнойЧастиСерии.Характеристика = СтрТЧ.ХарактеристикаНоменклатуры;
				СтрокаТабличнойЧастиСерии.Серия = Серия;
				
				СтрокиПоискаПоТоварам = ИсходныйДокумент[ИмяТЧПодбор].НайтиСтроки(Новый Структура("Номенклатура,Характеристика", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры));
				
				Если СтрокиПоискаПоТоварам.Количество() = 1 Или СтрокиПоискаПоТоварам.Количество() > 1 Тогда
					
					Попытка СтрокаТабличнойЧастиСерии.Склад = СтрокиПоискаПоТоварам[0].Склад; Исключение КонецПопытки;
					Попытка СтрокаТабличнойЧастиСерии.Назначение = СтрокиПоискаПоТоварам[0].Назначение; Исключение КонецПопытки;					
					
				КонецЕсли;
				
			Иначе	
				СтрокаТабличнойЧастиСерии = СтрокиПоискаСерий[0];
			КонецЕсли;
			
			СтрокаТабличнойЧастиСерии.Количество = СтрокаТабличнойЧастиСерии.Количество + СтрТЧ.Количество * КоэффициентУпаковки;			
			
		КонецЦикла; 
				
	КонецЕсли;	
	// Серии в отдельной ТЧ
	
	Если ИспользованиеСерийников <> 0 Тогда
		Обработки.ДатаМобайл_АРМДиспетчера.УстановитьСерииВдокументе(ИсходныйДокумент);
	КонецЕсли; 
	
	Если ТабличнуюЧастьПриЗагрузке = 3 Тогда
		ПроверкаНаНулевоеКоличество(ИсходныйДокумент, ИмяТЧПодбор);	
	КонецЕсли;
			
КонецПроцедуры

Процедура УстановитьДатуЗавершенияДокументаТСД(ДокументТСД)
	
	ДокументТСД.ДатаЗавершения = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
	ДокументТСД.ДополнительныеСвойства.Вставить("НеобращатьсяВСервисЧЗ", Истина);
	ДокументТСД.Записать();
	
	// УДАЛЕНИЕ РЕГИСТРАЦИИ ДАННОГО ДОКУМЕНТА НА ДАННОМ УЗЛЕ 
	ДатаМобайл_ОбщийМодуль.УдалитьРегистрациюОбъекта(ДокументТСД, Истина);
	
КонецПроцедуры

Процедура УстановитьGTIN(ДокументТСД)
		
	Для каждого СтруктураСтроки Из ДокументТСД.СобранныеДанныеПодбор Цикл
		Если ЗначениеЗаполнено(СтруктураСтроки.ЦРПТМарка) Тогда
			
			// Пачка табака:
			// GTIN+SN = 21
			// Блок табака:
			// 01+GTIN+21+SN = 25
			// Обувь:
			// 01+GTIN+21+SN = 31
			// Лекарства:
			// 01+GTIN+21+SN = 31
			// Фото:
			// 01+GTIN+21+SN = 38
			// Молочка:
			// 01+GTIN+21+SN = 24 или 32
			
			Если СтруктураСтроки.ЦРПТМарка_Длина = 21 Тогда
				KM_GTIN = Сред(СтруктураСтроки.ЦРПТМарка, 1, 14);
			ИначеЕсли СтруктураСтроки.ЦРПТМарка_Длина = 25 Тогда
				KM_GTIN = Сред(СтруктураСтроки.ЦРПТМарка, 3, 14);
			ИначеЕсли СтруктураСтроки.ЦРПТМарка_Длина = 31 Или СтруктураСтроки.ЦРПТМарка_Длина = 38 Или СтруктураСтроки.ЦРПТМарка_Длина = 24 Или СтруктураСтроки.ЦРПТМарка_Длина = 32 Тогда
				KM_GTIN = Сред(СтруктураСтроки.ЦРПТМарка, 3, 14);
			Иначе
				KM_GTIN = "";
			КонецЕсли;	
			
			СтруктураСтроки.KM_GTIN = KM_GTIN;
			
		КонецЕсли;	
	КонецЦикла;
		
КонецПроцедуры	

Функция ПривязатьGTINкТовару(ЦРПТМарка, ЦРПТМарка_Длина, Параметры = Неопределено)
		
	// Пачка табака:
	// GTIN+SN = 21
	// Блок табака:
	// 01+GTIN+21+SN = 25
	// Обувь:
	// 01+GTIN+21+SN = 31
	// Лекарства:
	// 01+GTIN+21+SN = 31
	// Фото:
	// 01+GTIN+21+SN = 38
	// Молочка:
	// 01+GTIN+21+SN = 24 или 32
	
	Если ЦРПТМарка_Длина = 21 Тогда
		GTIN_КМ = Сред(ЦРПТМарка, 1, 14);
	ИначеЕсли ЦРПТМарка_Длина = 25 Тогда
		GTIN_КМ = Сред(ЦРПТМарка, 3, 14);
	ИначеЕсли ЦРПТМарка_Длина = 31 Или ЦРПТМарка_Длина = 38 Или ЦРПТМарка_Длина = 24 Или ЦРПТМарка_Длина = 32 Тогда
		GTIN_КМ = Сред(ЦРПТМарка, 3, 14);
	Иначе
		GTIN_КМ = "";
	КонецЕсли;	
	
	Штрихкод = УдалитьЛидирующиеНули(GTIN_КМ);	
	
	Если Штрихкод <> "" И Лев(Штрихкод, 1) <> "2" И Параметры <> Неопределено Тогда
		
		Попытка ЗаписатьШтрихкодВрегистр(Штрихкод, Параметры); Исключение КонецПопытки;	
		
	КонецЕсли;	
		
КонецФункции // ()

Функция УдалитьЛидирующиеНули(Строка)
	
	СтрокаБезНулей = Строка;
	Пока Лев(СтрокаБезНулей, 1) = "0" Цикл
		СтрокаБезНулей = Прав(СтрокаБезНулей, СтрДлина(СтрокаБезНулей) - 1);	
	КонецЦикла;	
	
	Возврат СтрокаБезНулей; 
КонецФункции	

Функция ЗаписатьШтрихкодВРегистр(ШК, Параметры)
		
	лТовар = Параметры.Номенклатура;
	лХарактеристикаНоменклатуры = Параметры.Характеристика;
	лУпак = Параметры.Упаковка;
		
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихкодыНоменклатуры.Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод");
	Запрос.УстановитьПараметр("ШтрихКод", ШК);
	
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда // уже есть в списке шк  
		Возврат Истина;	
	КонецЕсли;	
	
	ЗаписьШК = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьМенеджерЗаписи();
	ЗаписьШК.Номенклатура = лТовар;
	ЗаписьШК.Упаковка = лУпак;
	ЗаписьШК.Штрихкод = ШК;	
	ЗаписьШК.Характеристика = лХарактеристикаНоменклатуры; 
	
	ЗаписьШК.Записать(Истина);	
	
КонецФункции	

Функция НайтиУпаковкуПоGTIN(GTIN_KM, Параметры) Экспорт
	
	лУпак = Параметры.Номенклатура.ЕдиницаИзмерения;
	
	лТовар = Параметры.Номенклатура;
	лХарактеристикаНоменклатуры = Параметры.Характеристика;
			
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихкодыНоменклатуры.Упаковка
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
	|	И ШтрихкодыНоменклатуры.Номенклатура = &Номенклатура
	|");
	
	Если СтрДлина(GTIN_KM) = 14 И Лев(GTIN_KM, 1) = "0" Тогда
		ШК = Сред(GTIN_KM, 2);
	Иначе
		ШК = GTIN_KM;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Штрихкод", GTIN_KM);
	Запрос.УстановитьПараметр("Номенклатура", лТовар);
	
	Рез = Запрос.Выполнить(); 
	
	Если Рез.Пустой() И Не ШК = GTIN_KM Тогда
		Запрос.УстановитьПараметр("Штрихкод", ШК);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Если ЗначениеЗаполнено(Выборка.Упаковка) Тогда
				лУпак = Выборка.Упаковка;
			КонецЕсли;
		КонецЕсли;
		
	Иначе 
		Выборка = Рез.Выбрать();
		
		Если Выборка.Следующий() Тогда
			Если ЗначениеЗаполнено(Выборка.Упаковка) Тогда
				лУпак = Выборка.Упаковка;
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;		
	
	Возврат лУпак;
		
КонецФункции	

Процедура ПроверитьМаркаНаходитсяВДругомКоробе(СсылкаМарка, СсылкаУпаковка)
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|ГДЕ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод = &Штрихкод
	|	И ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка<>&Упаковка");
	
	Запрос.УстановитьПараметр("Штрихкод", СсылкаМарка);
	Запрос.УстановитьПараметр("Упаковка", СсылкаУпаковка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ОбъектКороб = Выборка.Ссылка.ПолучитьОбъект();
		РезультатПоиска = ОбъектКороб.ВложенныеШтрихкоды.НайтиСтроки(Новый Структура("Штрихкод", СсылкаМарка));
		
		Для каждого Строка Из РезультатПоиска Цикл
			ОбъектКороб.ВложенныеШтрихкоды.Удалить(Строка);
		КонецЦикла;
		
		ОбъектКороб.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

Функция НужноЗаполнитьОбъектКороб(ОбъектКороб)
	
	Если ОбъектКороб.Номенклатура = Справочники.Номенклатура.ПустаяСсылка() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции // ()

Функция ЗаполнитьОбъектКороб(ОбъектКороб, СсылкаМарка)
	
	ОбъектКороб.Номенклатура = СсылкаМарка.Номенклатура;
	ОбъектКороб.Характеристика = СсылкаМарка.Характеристика;
	ОбъектКороб.Серия = СсылкаМарка.Серия;
	ОбъектКороб.Упаковка = СсылкаМарка.Упаковка;
	
	ОбъектКороб.Записать();
	
КонецФункции // ()

Функция ПолучитьСтруктуруСобранныхМарокИУпаковок(ДокументТСД, СоздаватьЕслиНеНайдена, ПривязыватьGTIN = Ложь, ИгнорироватьНесоответствиеТовараПоЕАNиКМ = Ложь)
	
	Шаблон = ДокументТСД.Шаблон;

	СтруктураРеквизитовШаблона = Справочники.ДатаМобайл_ШаблоныДокументов.ПолучитьПараметрыШаблона(Шаблон, 
	"РежимКомплектации, МаркировкаРежимОСУ"); 
	
	РежимКомплектации					= СтруктураРеквизитовШаблона.РежимКомплектации;
	       	
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	
	МаркированныйТовар = Перечисления.ТипыУпаковок.МаркированныйТовар;
	
	// массив марок
	МассивМарок = Новый Массив;
	
	Если Не РежимКомплектации = 1 Тогда
		
		ТЗСобранныеДанныеМарки = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		ТЗСобранныеДанныеМарки.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЦРПТМарка, ЦРПТМарка_Длина, УпаковочныйЛист, KM_RawMrc, КМСсылка, KM_TNVED, СерияСсылка", "Количество, КоличествоВУпаковке");
		
		Если ТЗСобранныеДанныеМарки.Количество() = 0 Тогда
			ТЗСобранныеДанныеМарки = ВыгрузитьСобранныеДанныеПриемка(ДокументТСД);
			ТЗСобранныеДанныеМарки.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЦРПТМарка, ЦРПТМарка_Длина, УпаковочныйЛист, KM_RawMrc, КМСсылка, KM_TNVED, СерияСсылка", "Количество, КоличествоВУпаковке");	
		КонецЕсли;
		
		Для каждого СтрокаДока Из ТЗСобранныеДанныеМарки Цикл
			
			Если СтрокаДока.Количество = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			// фильтр на не маркир. товары:		
			Если ПолучитьТипМаркированнойПродукции(СтрокаДока.Номенклатура) = 0 Тогда
				Продолжить;
			КонецЕсли;     
			
			ВесМожноУказывать = СтрокаДока.Номенклатура.ВесМожноУказыватьВДокументах;
			
			СтруктураТовара = Новый Структура("Номенклатура, Характеристика, Упаковка, Серия, Количество", СтрокаДока.Номенклатура, СтрокаДока.ХарактеристикаНоменклатуры, СтрокаДока.ЕдиницаИзмерения, СтрокаДока.СерияСсылка, СтрокаДока.Количество);
			
			Если ЗначениеЗаполнено(СтрокаДока.ЦРПТМарка) 
				И 
				(Не ЗначениеЗаполнено(СтрокаДока.УпаковочныйЛист)    
				//предполагаем выполнение агрегации только в двух видах документов, в остальных будет не агрегация, а просто запись в упаковочный лист в основном модуле
				//но сами КМ надо записать в документ (без упак листов)
				или (Шаблон.ИспользованиеУпаковочныхЛистовПодбор<>0 
				и Шаблон.ВидДокумента<>"ДатаМобайл_УпаковочныйЛист" и Шаблон.ВидДокументаНового<>"ДатаМобайл_УпаковочныйЛист" 
				и Шаблон.ВидДокумента<>"МаркировкаТоваровИСМП" и Шаблон.ВидДокументаНового<>"МаркировкаТоваровИСМП")) Тогда
				
				Если ЗначениеЗаполнено(СтрокаДока.КМСсылка) И СтрокаДока.КМСсылка.ТипУпаковки = МаркированныйТовар Тогда
					МассивМарок.Добавить(СтрокаДока.КМСсылка);
				ИначеЕсли ЗначениеЗаполнено(СтрокаДока.КМСсылка) И СтрокаДока.КМСсылка.ВложенныеШтрихкоды.Количество() <> 0 Тогда
					МассивМарок.Добавить(СтрокаДока.КМСсылка);
				Иначе	
					СтрокаДока.КМСсылка = ПолучитьСправочникСсылкаМарка(СтрокаДока.ЦРПТМарка, СтрокаДока.ЦРПТМарка_Длина, СтрокаДока.KM_RawMrc, СтрокаДока.KM_TNVED, СоздаватьЕслиНеНайдена, СтруктураТовара,Шаблон);
					МассивМарок.Добавить(СтрокаДока.КМСсылка);
				КонецЕсли;
				
				Если СтрокаДока.СерияСсылка <> Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаДока.КМСсылка, "Серия") И ЗначениеЗаполнено(СтрокаДока.КМСсылка) 
					 Или СтрокаДока.КМСсылка.ТипУпаковки <> МаркированныйТовар Тогда
					ОбновитьСериюШтрихкодыУпаковокТоваров(СтрокаДока.КМСсылка, СтрокаДока.СерияСсылка);	
				КонецЕсли;
				
				Если ПривязыватьGTIN Тогда
					ПривязатьGTINкТовару(СтрокаДока.ЦРПТМарка, СтрокаДока.ЦРПТМарка_Длина, СтруктураТовара);	
				КонецЕсли;
				
				Если ЗначениеЗаполнено(СтрокаДока.КМСсылка) И ИгнорироватьНесоответствиеТовараПоЕАNиКМ Тогда
					Если СтрокаДока.Номенклатура <> СтрокаДока.КМСсылка.Номенклатура Или СтрокаДока.ХарактеристикаНоменклатуры <> СтрокаДока.КМСсылка.Характеристика Тогда
						КМОбъект = СтрокаДока.КМСсылка.ПолучитьОбъект();
						КМОбъект.Номенклатура 	= СтрокаДока.Номенклатура;
						КМОбъект.Характеристика = СтрокаДока.ХарактеристикаНоменклатуры;
						КМОбъект.Записать();	
					КонецЕсли; 
				КонецЕсли;
				
				ЗаполнитьВесУпаковки(СтрокаДока, ВесМожноУказывать);
				
			ИначеЕсли ЗначениеЗаполнено(СтрокаДока.ЦРПТМарка) И ВесМожноУказывать Тогда
				
				Если ЗначениеЗаполнено(СтрокаДока.КМСсылка) И СтрокаДока.КМСсылка.ТипУпаковки = МаркированныйТовар Тогда
				ИначеЕсли ЗначениеЗаполнено(СтрокаДока.КМСсылка) И СтрокаДока.КМСсылка.ВложенныеШтрихкоды.Количество() <> 0 Тогда
				Иначе	
					СтрокаДока.КМСсылка = ПолучитьСправочникСсылкаМарка(СтрокаДока.ЦРПТМарка, СтрокаДока.ЦРПТМарка_Длина, СтрокаДока.KM_RawMrc, СтрокаДока.KM_TNVED, СоздаватьЕслиНеНайдена, СтруктураТовара,ДокументТСД.Шаблон);
				КонецЕсли;
				
				ЗаполнитьВесУпаковки(СтрокаДока, ВесМожноУказывать);	
				
			КонецЕсли;
			
		КонецЦикла; 
		
	КонецЕсли;
	
	// массив коробов
	МассивКоробов = Новый Массив;
	
	// массив наборов
	МассивНаборов = Новый Массив;
	
	Если Не РежимКомплектации = 1 Тогда
		
		ТЗУпаковочныхЛистов = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		ТЗУпаковочныхЛистов.Свернуть("УпаковочныйЛист, УпаковочныйЛистСсылка, СерияСсылка","Количество");
		
		Для каждого СтрТЗ Из ТЗУпаковочныхЛистов Цикл
			
			Если СтрТЗ.Количество = 0 Тогда
				Продолжить;
			КонецЕсли;	
			
			Если ЗначениеЗаполнено(СтрТЗ.УпаковочныйЛистСсылка) Тогда
				МассивКоробов.Добавить(СтрТЗ.УпаковочныйЛистСсылка);
				ОбновитьСериюШтрихкодыУпаковокТоваров(СтрТЗ.УпаковочныйЛистСсылка, СтрТЗ.СерияСсылка);
				Продолжить;
			КонецЕсли;	
			
			Если ЗначениеЗаполнено(СтрТЗ.УпаковочныйЛист) Тогда  
				//предполагаем выполнение агрегации только в двух видах документов, в остальных будет не агрегация, а просто запись в упаковочный лист в основном модуле
				//но сами КМ надо записать в документ (без упак листов)
				Если Шаблон.ИспользованиеУпаковочныхЛистовПодбор<>0 
					и Шаблон.ВидДокумента<>"ДатаМобайл_УпаковочныйЛист" и Шаблон.ВидДокументаНового<>"ДатаМобайл_УпаковочныйЛист" 
					и Шаблон.ВидДокумента<>"МаркировкаТоваровИСМП" и Шаблон.ВидДокументаНового<>"МаркировкаТоваровИСМП" Тогда
				Иначе
					УпаковкаСсылка = ПолучитьСправочникСсылкаУпаковка(СтрТЗ.УпаковочныйЛист, Ложь, Неопределено);
					МассивКоробов.Добавить(УпаковкаСсылка);
					ОбновитьСериюШтрихкодыУпаковокТоваров(УпаковкаСсылка, СтрТЗ.СерияСсылка);
				КонецЕсли;	
			КонецЕсли;
			
		КонецЦикла; 
	
	Иначе     
		
		ТЗНаборов = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		ТЗНаборов.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ВариантКомплектацииНабора, КМНабора, КМНабораСсылка");
		
		Для каждого СтрТЗ Из ТЗНаборов Цикл			
			
			Если ЗначениеЗаполнено(СтрТЗ.КМНабораСсылка) Тогда                   
				
				Если МассивНаборов.Найти(СтрТЗ.КМНабораСсылка) = Неопределено Тогда
					МассивНаборов.Добавить(СтрТЗ.КМНабораСсылка);
				КонецЕсли;
				
				Продолжить;
				
			ИначеЕсли Не ЗначениеЗаполнено(СтрТЗ.КМНабораСсылка) И ЗначениеЗаполнено(СтрТЗ.КМНабора) И ЗначениеЗаполнено(СтрТЗ.ВариантКомплектацииНабора) Тогда
				
				ПараметрыТовара = Новый Структура("Номенклатура, Характеристика, Количество", СтрТЗ.Номенклатура, СтрТЗ.ХарактеристикаНоменклатуры, 1);
				Попытка 
					ТекущийНаборСсылка = ДатаМобайл_Маркировка.ПолучитьСправочникСсылкаУпаковка(СтрТЗ.КМНабора, Истина, ПараметрыТовара); 
				Исключение 
				КонецПопытки; 
				
				Если Не ТекущийНаборСсылка = Неопределено Тогда
					
					Если МассивНаборов.Найти(ТекущийНаборСсылка) = Неопределено Тогда
						МассивНаборов.Добавить(ТекущийНаборСсылка);
					КонецЕсли;	
					
				КонецЕсли;	
					
			КонецЕсли;				
			
		КонецЦикла; 
		
	КонецЕсли;	
		
	// ОСУ
	Если СтруктураРеквизитовШаблона.МаркировкаРежимОСУ = 1 Тогда
		ТЗОСУ = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
		ТЗОСУ.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЦРПТМарка, ЦРПТМарка_Длина, УпаковочныйЛист, KM_RawMrc, КМСсылка, KM_TNVED, СерияСсылка, ШтрихКод", "Количество, КоличествоВУпаковке");
		
		ПродукцияИСМП_МолочкаВода = Новый Массив;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.МолочнаяПродукцияБезВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.МолочнаяПродукцияПодконтрольнаяВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.УпакованнаяВода); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.БАДы); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.БАДы2025); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.ДезинфицирующиеСредства); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.БезалкогольныеНапитки); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.СоковаяПродукция); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.МорепродуктыПодконтрольныеВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.КонсервированнаяПродукцияБезВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.КонсервированнаяПродукцияПодконтрольнаяВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.КормаДляЖивотныхБезВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.КормаДляЖивотныхПодконтрольныеВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.КормаДляЖивотныхВлажныеБезВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.КормаДляЖивотныхВлажныеПодконтрольныеВЕТИС); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.ПарфюмерныеИКосметическиеСредстваИБытоваяХимия); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.РастительныеМасла); Исключение КонецПопытки;
		
		Для каждого СтрОСУ Из ТЗОСУ Цикл
			
			Если СтрОСУ.Количество = 0 Или ЗначениеЗаполнено(СтрОСУ.УпаковочныйЛист) Или ЗначениеЗаполнено(СтрОСУ.ЦРПТМарка) Тогда
				Продолжить;
			КонецЕсли;	
			
			Если ПродукцияИСМП_МолочкаВода.Найти(СтрОСУ.Номенклатура.ОсобенностьУчета) = Неопределено Тогда 
				Продолжить;
				//ИначеЕсли ПродукцияИСМП_МолочкаВода.Найти(СтрОСУ.Номенклатура.ВидНоменклатуры.ОсобенностьУчета) = Неопределено Тогда
				//	Продолжить;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрОСУ.ШтрихКод) Тогда
				КоличествоПУ = ?(СтрОСУ.Номенклатура.ВесМожноУказыватьВДокументах, СтрОСУ.КоличествоВУпаковке, СтрОСУ.Количество);
				GTIN = ?(СтрДлина(СтрОСУ.ШтрихКод) = 13, "0" + СтрОСУ.ШтрихКод, СтрОСУ.ШтрихКод); 
				ЗначениеУпаковки = "(02)" + GTIN + "(37)" + КоличествоПУ;
				УпаковкаСсылка = ПолучитьСправочникСсылкаУпаковка(ЗначениеУпаковки, СоздаватьЕслиНеНайдена, Новый Структура("Номенклатура, Характеристика, Серия, КоличествоПУ, Количество, ЭтоОСУ", СтрОСУ.Номенклатура, СтрОСУ.ХарактеристикаНоменклатуры, СтрОСУ.СерияСсылка, КоличествоПУ, СтрОСУ.Количество, Истина));
				
				Если Не ЗначениеЗаполнено(УпаковкаСсылка) И Не СоздаватьЕслиНеНайдена Тогда
					ДатаМобайл_ОбщийМодуль.СообщитьПользователю("Не найдена упаковка. В шаблоне не установлено ""Создание новых КМ в 1С"".");
					Продолжить;
				КонецЕсли;
				
				Если СтрОСУ.СерияСсылка <> Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УпаковкаСсылка, "Серия") И ЗначениеЗаполнено(УпаковкаСсылка) Тогда
					ОбновитьСериюШтрихкодыУпаковокТоваров(УпаковкаСсылка, СтрОСУ.СерияСсылка);	
				КонецЕсли;
				
				Если СтрОСУ.Номенклатура.ВесМожноУказыватьВДокументах И (СтрОСУ.Количество <> УпаковкаСсылка.Количество Или КоличествоПУ <> УпаковкаСсылка.КоличествоПотребительскихУпаковок) Тогда
					УпаковкаОбъект = УпаковкаСсылка.ПолучитьОбъект();
					УпаковкаОбъект.Количество = СтрОСУ.Количество;
					УпаковкаОбъект.КоличествоПотребительскихУпаковок = КоличествоПУ;
					УпаковкаОбъект.Записать();
				КонецЕсли; 
				МассивКоробов.Добавить(УпаковкаСсылка);
			КонецЕсли;	
			
		КонецЦикла;
	КонецЕсли;

	Возврат Новый Структура("Марки, Короба, Наборы", МассивМарок, МассивКоробов, МассивНаборов);
	
КонецФункции

Функция ПолучитьУпаковкуПоМарке(СписокМарок)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка) КАК Палета,
	|	"""" КАК ЗначениеПалеты,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка КАК Короб,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка.ЗначениеШтрихкода КАК ЗначениеКороба,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.Ссылка КАК Марка,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.ЗначениеШтрихкода КАК ЗначениеМарки
	|ПОМЕСТИТЬ ВТ_1
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|ГДЕ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод В(&СписокМарок)
	|	И НЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка КАК Палета,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка.ЗначениеШтрихкода КАК ЗначениеПалеты,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.Ссылка КАК Короб,
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод.ЗначениеШтрихкода КАК ЗначениеКороба
	|ПОМЕСТИТЬ ВТ_Палета
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковокТоваровВложенныеШтрихкоды
	|ГДЕ
	|	ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Штрихкод В
	|			(ВЫБРАТЬ
	|				ВТ_1.Короб КАК Короб
	|			ИЗ
	|				ВТ_1 КАК ВТ_1)
	|	И НЕ ШтрихкодыУпаковокТоваровВложенныеШтрихкоды.Ссылка.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ВТ_Палета.Палета, ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.ПустаяСсылка)) КАК Палета,
	|	ЕСТЬNULL(ВТ_Палета.ЗначениеПалеты, """") КАК ЗначениеПалеты,
	|	ЕСТЬNULL(ВТ_Палета.Короб, ВТ_1.Короб) КАК Короб,
	|	ЕСТЬNULL(ВТ_Палета.ЗначениеКороба, ВТ_1.ЗначениеКороба) КАК ЗначениеКороба,
	|	ВТ_1.Марка КАК Марка,
	|	ВТ_1.ЗначениеМарки КАК ЗначениеМарки
	|ИЗ
	|	ВТ_1 КАК ВТ_1
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Палета КАК ВТ_Палета
	|		ПО ВТ_1.Короб = ВТ_Палета.Короб";
	
	Запрос.УстановитьПараметр("СписокМарок", СписокМарок);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ПолучитьСтруктуруСобранныхМарокИУпаковок_МаркировкаТоваровИСМП(ПараметрыДокумента, СоздаватьЕслиНеНайдена, ПривязыватьGTIN = Ложь, ИгнорироватьНесоответствиеТовараПоЕАNиКМ = Ложь)
	
	ДокументТСД = ПараметрыДокумента.Об;
	
	ЭтоСозданиеВторогоДокументаМаркировки = Ложь;     
	
	Если ПараметрыДокумента.Свойство("ЭтоСозданиеВторогоДокументаМаркировки") Тогда		
		ЭтоСозданиеВторогоДокументаМаркировки = ПараметрыДокумента.ЭтоСозданиеВторогоДокументаМаркировки;
	КонецЕсли;
		
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	
	МассивМарок = Новый Массив;
	
	ТаблицаМарокВнеНабора = Новый ТаблицаЗначений;
	ТаблицаМарокВнеНабора.Колонки.Добавить("КМСсылка", Новый ОписаниеТипов("СправочникСсылка.ШтрихкодыУпаковокТоваров"));
	ТаблицаМарокВнеНабора.Колонки.Добавить("УпаковочныйЛист", Новый ОписаниеТипов("Строка"));
	
	ТЗСобранныеДанныеМарки = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
	ТЗСобранныеДанныеМарки.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЦРПТМарка, ЦРПТМарка_Длина, УпаковочныйЛист, KM_RawMrc, КМСсылка, KM_TNVED, СерияСсылка, КМНабора, КМНабораСсылка", "Количество, КоличествоВУпаковке, КоличествоНаборов");
	
	Для каждого СтрокаДока Из ТЗСобранныеДанныеМарки Цикл
		
		Если СтрокаДока.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;	
		
		ВесМожноУказывать = СтрокаДока.Номенклатура.ВесМожноУказыватьВДокументах;
		
		СтруктураТовара = Новый Структура("Номенклатура, Характеристика, Упаковка, Серия, Количество", СтрокаДока.Номенклатура, СтрокаДока.ХарактеристикаНоменклатуры, СтрокаДока.ЕдиницаИзмерения, СтрокаДока.СерияСсылка, СтрокаДока.Количество);
		
		Если Не ЭтоСозданиеВторогоДокументаМаркировки Тогда	
			
			Если ЗначениеЗаполнено(СтрокаДока.ЦРПТМарка) Тогда
				
				Если ЗначениеЗаполнено(СтрокаДока.КМСсылка) И СтрокаДока.КМСсылка.ТипУпаковки = Перечисления.ТипыУпаковок.МаркированныйТовар Тогда
					МассивМарок.Добавить(СтрокаДока.КМСсылка);
				ИначеЕсли ЗначениеЗаполнено(СтрокаДока.КМСсылка) И СтрокаДока.КМСсылка.ВложенныеШтрихкоды.Количество() <> 0 Тогда
					МассивМарок.Добавить(СтрокаДока.КМСсылка);
				Иначе	
					СтрокаДока.КМСсылка = ПолучитьСправочникСсылкаМарка(СтрокаДока.ЦРПТМарка, СтрокаДока.ЦРПТМарка_Длина, СтрокаДока.KM_RawMrc, СтрокаДока.KM_TNVED, СоздаватьЕслиНеНайдена, СтруктураТовара,ДокументТСД.Шаблон);
					МассивМарок.Добавить(СтрокаДока.КМСсылка);
					МассивСтрокДокументаТСД = ДокументТСД.СобранныеДанныеПодбор.НайтиСтроки(Новый Структура("ЦРПТМарка", СтрокаДока.ЦРПТМарка));
					
					Если МассивСтрокДокументаТСД.Количество() Тогда
						МассивСтрокДокументаТСД[0].КМСсылка = СтрокаДока.КМСсылка;	
					КонецЕсли;
						
				КонецЕсли;
				
				Если СтрокаДока.СерияСсылка <> Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаДока.КМСсылка, "Серия") И ЗначениеЗаполнено(СтрокаДока.КМСсылка) Тогда
					ОбновитьСериюШтрихкодыУпаковокТоваров(СтрокаДока.КМСсылка, СтрокаДока.СерияСсылка);	
				КонецЕсли;
				
				Если ПривязыватьGTIN Тогда
					ПривязатьGTINкТовару(СтрокаДока.ЦРПТМарка, СтрокаДока.ЦРПТМарка_Длина, СтруктураТовара);	
				КонецЕсли;
				
				Если ЗначениеЗаполнено(СтрокаДока.КМСсылка) И ИгнорироватьНесоответствиеТовараПоЕАNиКМ Тогда
					Если СтрокаДока.Номенклатура <> СтрокаДока.КМСсылка.Номенклатура Или СтрокаДока.ХарактеристикаНоменклатуры <> СтрокаДока.КМСсылка.Характеристика Тогда
						КМОбъект = СтрокаДока.КМСсылка.ПолучитьОбъект();
						КМОбъект.Номенклатура 	= СтрокаДока.Номенклатура;
						КМОбъект.Характеристика = СтрокаДока.ХарактеристикаНоменклатуры;
						КМОбъект.Записать();	
					КонецЕсли; 
				КонецЕсли;
				
				ЗаполнитьВесУпаковки(СтрокаДока, ВесМожноУказывать);
								
			КонецЕсли;
			
		КонецЕсли;
	
		Если ЗначениеЗаполнено(СтрокаДока.ЦРПТМарка) И Не ЗначениеЗаполнено(СтрокаДока.КМНабора) Тогда
			
			КМСсылка = ПолучитьСправочникСсылкаМарка(СтрокаДока.ЦРПТМарка, СтрокаДока.ЦРПТМарка_Длина, СтрокаДока.KM_RawMrc, СтрокаДока.KM_TNVED, СоздаватьЕслиНеНайдена, СтруктураТовара,ДокументТСД.Шаблон);
			
			НоваяСтрока = ТаблицаМарокВнеНабора.Добавить();	
			НоваяСтрока.КМСсылка = КМСсылка;
			НоваяСтрока.УпаковочныйЛист = СтрокаДока.УпаковочныйЛист;
			
		КонецЕсли;
				
	КонецЦикла;   
	
	 
	МассивНаборов = Новый Массив;
		
	ТЗНаборов = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
	ТЗНаборов.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ВариантКомплектацииНабора, КМНабора, КМНабораСсылка");
	
	Для каждого СтрТЗ Из ТЗНаборов Цикл			
		
		Если ЗначениеЗаполнено(СтрТЗ.КМНабораСсылка) Тогда                   
			
			Если МассивНаборов.Найти(СтрТЗ.КМНабораСсылка) = Неопределено Тогда
				МассивНаборов.Добавить(СтрТЗ.КМНабораСсылка);
			КонецЕсли;
			
			Продолжить;
			
		ИначеЕсли Не ЗначениеЗаполнено(СтрТЗ.КМНабораСсылка) И ЗначениеЗаполнено(СтрТЗ.КМНабора) И ЗначениеЗаполнено(СтрТЗ.ВариантКомплектацииНабора) Тогда
			
			ПараметрыТовара = Новый Структура("Номенклатура, Характеристика, Количество", СтрТЗ.Номенклатура, СтрТЗ.ХарактеристикаНоменклатуры, 1);
			Попытка 
				ТекущийНаборСсылка = ДатаМобайл_Маркировка.ПолучитьСправочникСсылкаУпаковка(СтрТЗ.КМНабора, Истина, ПараметрыТовара); 
			Исключение 
			КонецПопытки; 
			
			Если Не ТекущийНаборСсылка = Неопределено Тогда
				
				Если МассивНаборов.Найти(ТекущийНаборСсылка) = Неопределено Тогда
					МассивНаборов.Добавить(ТекущийНаборСсылка);
				КонецЕсли;	
				
			КонецЕсли;	
				
		КонецЕсли;				
		
	КонецЦикла; 
 		
	МассивКоробов = Новый Массив;
	
	ТЗУпаковочныхЛистов = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
	ТЗУпаковочныхЛистов.Свернуть("УпаковочныйЛист, УпаковочныйЛистСсылка","Количество");
	
	Для каждого СтрТЗ Из ТЗУпаковочныхЛистов Цикл	
		
		Если СтрТЗ.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;		
		
		Если ЗначениеЗаполнено(СтрТЗ.УпаковочныйЛистСсылка) Тогда                   
			МассивКоробов.Добавить(СтрТЗ.УпаковочныйЛистСсылка);
			Продолжить;
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(СтрТЗ.УпаковочныйЛист) Тогда
			МассивКоробов.Добавить(ПолучитьСправочникСсылкаУпаковка(СтрТЗ.УпаковочныйЛист, Ложь, Неопределено));
		КонецЕсли;						
		
	КонецЦикла; 
	
	ТЗОСУ = ВыгрузитьСобранныеДанныеПодбор(ДокументТСД);
	ТЗОСУ.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, ЦРПТМарка, ЦРПТМарка_Длина, УпаковочныйЛист, KM_RawMrc, КМСсылка, KM_TNVED, СерияСсылка, ШтрихКод", "Количество, КоличествоВУпаковке");
	
	ПродукцияИСМП_МолочкаВода = Новый Массив;
	Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.МолочнаяПродукцияБезВЕТИС); Исключение КонецПопытки;
	Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.МолочнаяПродукцияПодконтрольнаяВЕТИС); Исключение КонецПопытки;
	Попытка ПродукцияИСМП_МолочкаВода.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.УпакованнаяВода); Исключение КонецПопытки;
	
	Для каждого СтрОСУ Из ТЗОСУ Цикл
		
		Если СтрОСУ.Количество = 0 Или ЗначениеЗаполнено(СтрОСУ.УпаковочныйЛист) Или ЗначениеЗаполнено(СтрОСУ.ЦРПТМарка) Тогда
			Продолжить;
		КонецЕсли;	
		
		Если ПродукцияИСМП_МолочкаВода.Найти(СтрОСУ.Номенклатура.ОсобенностьУчета) = Неопределено Тогда 
			Продолжить;
		//ИначеЕсли ПродукцияИСМП_МолочкаВода.Найти(СтрОСУ.Номенклатура.ВидНоменклатуры.ОсобенностьУчета) = Неопределено Тогда
		//	Продолжить;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрОСУ.ШтрихКод) Тогда
			КоличествоПУ = ?(СтрОСУ.Номенклатура.ВесМожноУказыватьВДокументах, СтрОСУ.КоличествоВУпаковке, СтрОСУ.Количество);
			GTIN = ?(СтрДлина(СтрОСУ.ШтрихКод) = 13, "0" + СтрОСУ.ШтрихКод, СтрОСУ.ШтрихКод); 
			ЗначениеУпаковки = "(02)" + GTIN + "(37)" + КоличествоПУ;
			УпаковкаСсылка = ПолучитьСправочникСсылкаУпаковка(ЗначениеУпаковки, СоздаватьЕслиНеНайдена, Новый Структура("Номенклатура, Характеристика, Серия, КоличествоПУ, Количество, ЭтоОСУ", СтрОСУ.Номенклатура, СтрОСУ.ХарактеристикаНоменклатуры, СтрОСУ.СерияСсылка, КоличествоПУ, СтрОСУ.Количество, Истина));
			
			Если Не ЗначениеЗаполнено(УпаковкаСсылка) И Не СоздаватьЕслиНеНайдена Тогда
				Сообщить("Не найдена упаковка. В шаблоне не установлено ""Создание новых КМ в 1С"".");
				Продолжить;
			КонецЕсли;
			
			Если СтрОСУ.СерияСсылка <> Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УпаковкаСсылка, "Серия") И ЗначениеЗаполнено(УпаковкаСсылка) Тогда
				ОбновитьСериюШтрихкодыУпаковокТоваров(УпаковкаСсылка, СтрОСУ.СерияСсылка);	
			КонецЕсли;
			
			Если СтрОСУ.Номенклатура.ВесМожноУказыватьВДокументах И (СтрОСУ.Количество <> УпаковкаСсылка.Количество Или КоличествоПУ <> УпаковкаСсылка.КоличествоПотребительскихУпаковок) Тогда
				УпаковкаОбъект = УпаковкаСсылка.ПолучитьОбъект();
				УпаковкаОбъект.Количество = СтрОСУ.Количество;
				УпаковкаОбъект.КоличествоПотребительскихУпаковок = КоличествоПУ;
				УпаковкаОбъект.Записать();
			КонецЕсли; 
			МассивКоробов.Добавить(УпаковкаСсылка);
		КонецЕсли;	
		
	КонецЦикла;
	
	Возврат Новый Структура("Марки, Короба, Наборы, ТаблицаМарокВнеНабора", МассивМарок, МассивКоробов, МассивНаборов, ТаблицаМарокВнеНабора);
	
КонецФункции

Функция ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(ЗначениеШтрихкода)
	
	Модуль_ШтрихкодированиеИС = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИС");
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	
	ЗначенияШтрихкодов = Новый Массив;
	ЗначенияШтрихкодов.Добавить(ЗначениеШтрихкода);
	
	ЭтоКАДляКазахстана = ДатаМобайл_ОбщийМодуль.ПроверкаИмениКонфигурации("КомплекснаяАвтоматизацияДляКазахстана");
	ЭтоУТДляКазахстана = ДатаМобайл_ОбщийМодуль.ПроверкаИмениКонфигурации("УправлениеТорговлейДляКазахстана");
	
	Если ЭтоКАДляКазахстана или ЭтоУТДляКазахстана Тогда //в КА 2.4.5.7 отсутствует данный поиск
		ШтрихкодыУпаковок = Новый Массив;
	Иначе
		ШтрихкодыУпаковок = Модуль_ШтрихкодированиеИС.ШтрихкодыУпаковок(ЗначенияШтрихкодов);	
	КонецЕсли;
	
	Если ШтрихкодыУпаковок.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Модуль_ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ШтрихкодыУпаковок[0]);
	
КонецФункции

Функция ПолучитьСправочникСсылкаМарка(КМ, ЦРПТМарка_Длина, KM_RawMrc, KM_TNVED, СоздаватьЕслиНеНайден = Ложь, Параметры = Неопределено, Шаблон) Экспорт
	
	Если Не ЗначениеЗаполнено(КМ) Тогда
		Возврат Неопределено;
	КонецЕсли;	
	
	ЗапросВЦРПТ = Шаблон.МаркировкаЗапросВЦРПТ;
	ЗаписыватьНулевойМРЦ = Не Шаблон.МаркировкаНеЗаписыватьНулевойМРЦ;
	
	ЭтоПриемка = Ложь;
	
	Если Шаблон.ВидДокумента = "ПриобретениеТоваровУслуг" Или Шаблон.ВидДокумента = "ПриемкаТоваровИСМП" Тогда
		ЭтоПриемка = Истина;	
	КонецЕсли;
	
	RawMrc = KM_RawMrc;
	Если Не ЗаписыватьНулевойМРЦ И KM_RawMrc = "AAAA" Тогда
		RawMrc = "";	
	КонецЕсли;
	
	Модуль_ИнтеграцияИСУТКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСУТКлиентСервер");
	
	ЭтоТабак = Ложь;
	ВызовHTTP = Ложь;
	
	Если Параметры <> Неопределено Тогда
		
		Попытка
			Номенклатура = Параметры.Номенклатура;
		Исключение
		    Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
		КонецПопытки;
		
		ПродукцияИСМП_Табак = Новый Массив;
		Попытка ПродукцияИСМП_Табак.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.ТабачнаяПродукция); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_Табак.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.АльтернативныйТабак); Исключение КонецПопытки;
		Попытка ПродукцияИСМП_Табак.Добавить(Перечисления.ОсобенностиУчетаНоменклатуры.НикотиносодержащаяПродукция); Исключение КонецПопытки;
		
		Если ПродукцияИСМП_Табак.Найти(Номенклатура.ОсобенностьУчета) <> Неопределено Тогда 
			ЭтоТабак = Истина;	
			ОсобенностьУчета = Номенклатура.ОсобенностьУчета;
		ИначеЕсли ПродукцияИСМП_Табак.Найти(Номенклатура.ВидНоменклатуры.ОсобенностьУчета) <> Неопределено Тогда
			ЭтоТабак = Истина;
			ОсобенностьУчета = Номенклатура.ОсобенностьУчета;	
		КонецЕсли;			
		
		Если ОсобенностьУчета = Неопределено Тогда
			ОсобенностьУчета = Номенклатура.ОсобенностьУчета;
		КонецЕсли;	
		
		Если ОсобенностьУчета = Неопределено Тогда 
			ОсобенностьУчета = Номенклатура.ВидНоменклатуры.ОсобенностьУчета;
		КонецЕсли;
		
		Попытка ВидМаркируемойПродукции = Модуль_ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(ОсобенностьУчета); Исключение КонецПопытки;
		
		Параметры.Вставить("ЗаписыватьНулевойМРЦ", ЗаписыватьНулевойМРЦ);
		
		Попытка ВызовHTTP = Параметры.ВызовHTTP Исключение КонецПопытки;
		
	КонецЕсли;
	
	Если Не ЭтоТабак Тогда
		ШаблонДляЧЗ = Неопределено;
	Иначе	
		ШаблонДляЧЗ = Шаблон;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ШтрихкодыУпаковокТоваров.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	|ГДЕ
	|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода ПОДОБНО &ЗначениеШтрихкодаДляЗапроса СПЕЦСИМВОЛ ""$""
	|	И НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления";
	
	// Пачка табака:
	// GTIN+SN = 21
	// Блок табака:
	// 01+GTIN+21+SN = 25
	// Обувь:
	// 01+GTIN+21+SN = 31
	// Лекарства:
	// 01+GTIN+21+SN = 31
	// Фото:
	// 01+GTIN+21+SN = 38
	// Молочка:
	// 01+GTIN+21+SN = 24 или 32
	
	Если СтрДлина(КМ) = 21 Тогда
		ЗначениеШтрихкода = КМ;
	ИначеЕсли СтрДлина(КМ) = 25 Тогда
		ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 7);
	ИначеЕсли СтрДлина(КМ) = 26 Тогда
		ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 8);	
	ИначеЕсли СтрДлина(КМ) = 31 Тогда
		ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 13);
	ИначеЕсли СтрДлина(КМ) = 32 Тогда
		ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 14);
	ИначеЕсли СтрДлина(КМ) = 38 Тогда
		ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 20);
	ИначеЕсли СтрДлина(КМ) = 24 Тогда
		ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 6);	
	Иначе		
		ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(КМ);
		
		Если ДанныеУпаковки <> Неопределено Тогда
			Возврат ДанныеУпаковки.Ссылка;
		КонецЕсли;
		
		Попытка
			Если Не ВызовHTTP И ЗапросВЦРПТ И Не ЭтоПриемка И СоздаватьЕслиНеНайден Тогда
				Возврат СформироватьЗапросКСервисуМОТПилиИСМПиСоздатьСправочникСсылкаМарка(КМ, KM_RawMrc,, Истина, ЭтоТабак,, ВидМаркируемойПродукции, Параметры, ШаблонДляЧЗ);	                      
			КонецЕсли;   
		Исключение
		КонецПопытки;
		
		// упаковка
		Возврат ПолучитьСправочникСсылкаУпаковка(КМ, СоздаватьЕслиНеНайден, Параметры);
	КонецЕсли;
	
	// Символы _ и % присутствуют в алфавите маркировки, поэтому требуется экранирование через спецсимвол, символ $ не присутствует в алфавите маркировки
	ЗначениеШтрихкодаДляЗапроса = "" + ЗначениеШтрихкода;
	ЗначениеШтрихкодаДляЗапроса = СтрЗаменить(ЗначениеШтрихкодаДляЗапроса, "_", "$_");
	ЗначениеШтрихкодаДляЗапроса = СтрЗаменить(ЗначениеШтрихкодаДляЗапроса, "%", "$%");
	ЗначениеШтрихкодаДляЗапроса = ЗначениеШтрихкодаДляЗапроса + "%";
	
	Запрос.УстановитьПараметр("ЗначениеШтрихкодаДляЗапроса", ЗначениеШтрихкодаДляЗапроса);
	
	КодМаркировкиНеНайден = Истина;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл		
		ТекущийКМ = Выборка.Ссылка;
		
		// Запрос подобно не учитывает регистр, поэтому в выборке может оказаться несколько результатов или неоказаться нужного, надо проверить что нужный КМ выбран.
		Если СтрНайти(ТекущийКМ.ЗначениеШтрихкода,ЗначениеШтрихкода) = 0 Или СтрНайти(ТекущийКМ.ЗначениеШтрихкода, "                         ") > 0 Тогда
			Продолжить;
		Иначе
			КодМаркировкиНеНайден = Ложь;	
		КонецЕсли;	
		
		Если Не ЗначениеЗаполнено(ТекущийКМ.Номенклатура) И Параметры <> Неопределено Тогда
			ДополнитьИнформациюНоменклатураХарактеристика(ТекущийКМ,Параметры.Номенклатура,Параметры.Характеристика);	
		КонецЕсли;	
		
		Если ПолучитьТипМаркированнойПродукции(ТекущийКМ.Номенклатура) = 1 Тогда	
			ДополнитьИнформациюТабачнойПродукцииМРЦ(ТекущийКМ, RawMrc, ЗаписыватьНулевойМРЦ);
		КонецЕсли;
		
		Попытка
			Если Не ВызовHTTP И ЗапросВЦРПТ И Не ЭтоПриемка И ТекущийКМ.ТипУпаковки <> Перечисления.ТипыУпаковок.МаркированныйТовар И ТекущийКМ.ВложенныеШтрихкоды.Количество() = 0 Тогда
				
				КМПоЗапросу = СформироватьЗапросКСервисуМОТПилиИСМПиСоздатьСправочникСсылкаМарка(КМ, KM_RawMrc,,, ЭтоТабак,, ВидМаркируемойПродукции, Параметры, ШаблонДляЧЗ);
				
				Если КМПоЗапросу = Неопределено И ТекущийКМ.ТипУпаковки <> Перечисления.ТипыУпаковок.МаркированныйТовар Тогда					
					Возврат ТекущийКМ;
				Иначе
					Возврат КМПоЗапросу;
				КонецЕсли;
			КонецЕсли;    
		Исключение
		КонецПопытки;
		
		Возврат ТекущийКМ;
	КонецЦикла;
	
	Если КодМаркировкиНеНайден Тогда
		Если СоздаватьЕслиНеНайден И Параметры <> Неопределено Тогда
			Если Не ВызовHTTP И ЗапросВЦРПТ Тогда
				Попытка
					Если СтрДлина(КМ) <> 21 Тогда
						КМУпаковки = СформироватьЗапросКСервисуМОТПилиИСМПиСоздатьСправочникСсылкаМарка(КМ, KM_RawMrc,,, ЭтоТабак,, ВидМаркируемойПродукции, Параметры, ШаблонДляЧЗ);
						Если КМУпаковки = Неопределено Тогда
							СоздатьСправочникСсылкаМарка(ЗначениеШтрихкода, Параметры, RawMrc, KM_TNVED, ЦРПТМарка_Длина);	
						Иначе							
							Возврат КМУпаковки;
						КонецЕсли;
					КонецЕсли;   
				Исключение
				КонецПопытки;	
			КонецЕсли;
			
			Возврат СоздатьСправочникСсылкаМарка(ЗначениеШтрихкода, Параметры, RawMrc, KM_TNVED, ЦРПТМарка_Длина);
		Иначе		
			Возврат Неопределено;
		КонецЕсли;		
	КонецЕсли;
	
КонецФункции // ()

Функция ПолучитьСправочникСсылкаУпаковка(КМ, СоздаватьЕслиНеНайден = Ложь, Параметры = Неопределено) Экспорт
	
	Если Параметры = Неопределено Тогда
		Параметры = Новый Структура;		
	КонецЕсли; 
	
	Параметры.Вставить("ЕстьТег93", Ложь);
	
	ЗначениеШтрихкода1 = "";
	ЗначениеШтрихкода2 = "";
	
	Если Лев(КМ, 2) = "00" И (СтрДлина(КМ) = 20 Или Найти(КМ, "/") = 21) Тогда
		ЗначениеШтрихкода = "(00)" + Сред(КМ, 3, 18);
		ЗначениеШтрихкода1 = Сред(КМ, 3, 18);
		ЗначениеШтрихкода2 = "00" + Сред(КМ, 3, 18);
	ИначеЕсли СтрДлина(КМ) = 18 Тогда
		ЗначениеШтрихкода = КМ;
		ЗначениеШтрихкода1 = Сред(КМ, 3, 16);
	ИначеЕсли Лев(КМ, 4) = "(00)" И (СтрДлина(КМ) = 22 Или Найти(КМ, "/") = 23) Тогда
		ЗначениеШтрихкода = "(00)" + Сред(КМ, 5, 18);
		ЗначениеШтрихкода1 = Сред(КМ, 5, 18);
		ЗначениеШтрихкода2 = "00" + Сред(КМ, 5, 18);;
	Иначе
		ЗначениеШтрихкода = СтрЗаменить(КМ,"/////","");
		ЗначениеШтрихкода = СтрЗаменить(ЗначениеШтрихкода,"[","(");
		ЗначениеШтрихкода = СтрЗаменить(ЗначениеШтрихкода,"]",")");
		
		ПоискТега = Найти(ЗначениеШтрихкода, "(93)");
		
		Если ПоискТега > 0 Тогда
			ЗначениеШтрихкода = Лев(ЗначениеШтрихкода, ПоискТега - 1);
			Параметры.ЕстьТег93 = Истина;
		КонецЕсли; 
	КонецЕсли;      

	// Наборы
	
	Если Параметры.Свойство("РежимКомплектации") И Параметры.РежимКомплектации = 1 Тогда 
	
		Если СтрДлина(КМ) = 21 Тогда
			ЗначениеШтрихкода = КМ;
		ИначеЕсли СтрДлина(КМ) = 25 Тогда
			ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 7);
		ИначеЕсли СтрДлина(КМ) = 26 Тогда
			ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 8);	
		ИначеЕсли СтрДлина(КМ) = 31 Тогда
			ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 13);
		ИначеЕсли СтрДлина(КМ) = 32 Тогда
			ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 14);
		ИначеЕсли СтрДлина(КМ) = 38 Тогда
			ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 20);
		ИначеЕсли СтрДлина(КМ) = 24 Тогда
			ЗначениеШтрихкода = "(01)" + Сред(КМ, 3, 14) + "(21)" + Сред(КМ, 19, 6);	
		КонецЕсли;		
		
	КонецЕсли; 
	
	//
	
	Если СтрНайти(ЗначениеШтрихкода, "(91)") > 0 Тогда
		ЗначениеШтрихкода = Лев(ЗначениеШтрихкода, СтрНайти(ЗначениеШтрихкода, "(91)") - 1);	
	КонецЕсли;
	
	Если СтрНайти(ЗначениеШтрихкода, "(92)") > 0 Тогда
		ЗначениеШтрихкода = Лев(ЗначениеШтрихкода, СтрНайти(ЗначениеШтрихкода, "(92)") - 1);	
	КонецЕсли;
	
	Если СтрНайти(ЗначениеШтрихкода, "(93)") > 0 Тогда
		ЗначениеШтрихкода = Лев(ЗначениеШтрихкода, СтрНайти(ЗначениеШтрихкода, "(93)") - 1);	
	КонецЕсли;
	
	// Старый вариант:
	
	//Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ
	//|	ШтрихкодыУпаковокТоваров.Ссылка КАК Ссылка
	//|ИЗ
	//|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	//|ГДЕ
	//|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода ПОДОБНО &ЗначениеШтрихкодаДляЗапроса  СПЕЦСИМВОЛ ""$""
	//|	И 1=1
	//|	И НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления";
	//
	//Если ЗначениеЗаполнено(ЗначениеШтрихкода1) Тогда
	//	Запрос.Текст = Запрос.Текст +
	//	"
	//	|
	//	|ОБЪЕДИНИТЬ
	//	|
	//	|ВЫБРАТЬ
	//	|	ШтрихкодыУпаковокТоваров.Ссылка КАК Ссылка
	//	|ИЗ
	//	|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
	//	|ГДЕ
	//	|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода ПОДОБНО ""%"" + &ЗначениеШтрихкода1
	//	|	И 1=1
	//	|	И НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления
	//	|";	
	//КонецЕсли;	
	//	
	//// Символы _ и % присутствуют в алфавите маркировки, поэтому требуется экранирование через спецсимвол, символ $ не присутствует в алфавите маркировки
	//ЗначениеШтрихкодаДляЗапроса = ЗначениеШтрихкода;
	//ЗначениеШтрихкодаДляЗапроса = СтрЗаменить(ЗначениеШтрихкодаДляЗапроса, "_", "$_");
	//ЗначениеШтрихкодаДляЗапроса = СтрЗаменить(ЗначениеШтрихкодаДляЗапроса, "%", "$%");
	//
	//Если Лев(КМ, 4) <> "(02)" Тогда
	//	ЗначениеШтрихкодаДляЗапроса = ЗначениеШтрихкодаДляЗапроса + "%";	
	//КонецЕсли; 
	//
	//Запрос.УстановитьПараметр("ЗначениеШтрихкодаДляЗапроса", ЗначениеШтрихкодаДляЗапроса);
	//Запрос.УстановитьПараметр("ЗначениеШтрихкода1", ЗначениеШтрихкода1);
	
	//{Новый вариант
	Запрос = Новый Запрос; 
	ДлинаШК = СтрДлина(КМ);

	Если ДлинаШК = 18
		 Или ДлинаШК = 20 
		 Или ДлинаШК = 22 Тогда
		 
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыУпаковокТоваров.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода В (&ЗначенияШтрихкодаДляЗапроса)
		|	И 1=1
		|	И НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления";   
		
		МассивЗначенийШК = Новый Массив;
						
		МассивЗначенийШК.Добавить(ЗначениеШтрихкода);
		МассивЗначенийШК.Добавить(ЗначениеШтрихкода1);
       	МассивЗначенийШК.Добавить(ЗначениеШтрихкода2);
		
		Запрос.УстановитьПараметр("ЗначенияШтрихкодаДляЗапроса", МассивЗначенийШК);
		 
	Иначе
		 

		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыУпаковокТоваров.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.ЗначениеШтрихкода ПОДОБНО &ЗначениеШтрихкодаДляЗапроса  СПЕЦСИМВОЛ ""$""
		|	И 1=1
		|	И НЕ ШтрихкодыУпаковокТоваров.ПометкаУдаления";   
		
		// Символы _ и % присутствуют в алфавите маркировки, поэтому требуется экранирование через спецсимвол, символ $ не присутствует в алфавите маркировки
		ЗначениеШтрихкодаДляЗапроса = ЗначениеШтрихкода;
		ЗначениеШтрихкодаДляЗапроса = СтрЗаменить(ЗначениеШтрихкодаДляЗапроса, "_", "$_");
		ЗначениеШтрихкодаДляЗапроса = СтрЗаменить(ЗначениеШтрихкодаДляЗапроса, "%", "$%");
		
		Если Лев(КМ, 4) <> "(02)" Тогда
			ЗначениеШтрихкодаДляЗапроса = ЗначениеШтрихкодаДляЗапроса + "%";	
		КонецЕсли; 
		
		Запрос.УстановитьПараметр("ЗначениеШтрихкодаДляЗапроса", ЗначениеШтрихкодаДляЗапроса);
			
	КонецЕсли;
	//}
	
	// поиск по серии для ОСУ
	Попытка
		Если Параметры.Свойство("ЭтоОСУ") И Параметры.Свойство("Серия") Тогда
			Если Параметры.ЭтоОСУ И ЗначениеЗаполнено(Параметры.Серия) Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "1=1", "ШтрихкодыУпаковокТоваров.Серия = &Серия");
				
				Запрос.УстановитьПараметр("Серия", Параметры.Серия);
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда		
		ТекущийКМ = Выборка.Ссылка;
		
		Возврат ТекущийКМ;
	Иначе		
		Если СоздаватьЕслиНеНайден Тогда			
			Возврат СоздатьСправочникСсылкаУпаковка(ЗначениеШтрихкода, Параметры);
		Иначе		
			Возврат Неопределено;
		КонецЕсли;		
	КонецЕсли;
	
КонецФункции // ()

Процедура ДополнитьИнформациюТабачнойПродукцииМРЦ(ТекущийКМ, KM_RawMrc, ЗаписыватьНулевойМРЦ)
	
	Если СтрДлина(ТекущийКМ.ЗначениеШтрихкода) = 21 И ТекущийКМ.ТипШтрихкода = Перечисления.ТипыШтрихкодов.DataMatrix Тогда 
				
		ТекущийКМОбъект = ТекущийКМ.ПолучитьОбъект();
		Если KM_RawMrc = "" И ЗаписыватьНулевойМРЦ Тогда
			ТекущийКМОбъект.ЗначениеШтрихкода = ТекущийКМОбъект.ЗначениеШтрихкода + "AAAA";
		Иначе		
			ТекущийКМОбъект.ЗначениеШтрихкода = ТекущийКМОбъект.ЗначениеШтрихкода + KM_RawMrc;
		КонецЕсли;	
		ТекущийКМОбъект.Записать();
		
	ИначеЕсли СтрДлина(ТекущийКМ.ЗначениеШтрихкода) = 29 И ТекущийКМ.ТипШтрихкода = Перечисления.ТипыШтрихкодов.GS1_DataMatrix И KM_RawMrc <> "" Тогда 
		
		ТекущийКМОбъект = ТекущийКМ.ПолучитьОбъект();		
		ТекущийКМОбъект.ЗначениеШтрихкода = ТекущийКМОбъект.ЗначениеШтрихкода + "(8005)" + KM_RawMrc;
		ТекущийКМОбъект.Записать();
		
	КонецЕсли;
		
КонецПроцедуры

Процедура ДополнитьИнформациюНоменклатураХарактеристика(ТекущийКМ, Номенклатура, Характеристика)
	
	ТекущийКМОбъект = ТекущийКМ.ПолучитьОбъект();
	
	ТекущийКМОбъект.Номенклатура = Номенклатура;
	ТекущийКМОбъект.Характеристика = Характеристика;
	ТекущийКМОбъект.Упаковка = Номенклатура.ЕдиницаИзмерения;
	
	ТекущийКМОбъект.Записать();
	
КонецПроцедуры

Функция СоздатьСправочникСсылкаМарка(КодМаркировки, Параметры, KM_RawMrc, KM_TNVED, ЦРПТМарка_Длина)
	
	// Пачка табака:
	// GTIN+SN = 21
	// Блок табака:
	// 01+GTIN+21+SN = 25
	// Обувь:
	// 01+GTIN+21+SN = 31
	// Лекарства:
	// 01+GTIN+21+SN = 31
	// Фото:
	// 01+GTIN+21+SN = 38
	// Молочка:
	// 01+GTIN+21+SN = 24 или 32
			
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	ОсобенностьУчета = Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.Номенклатура, "ОсобенностьУчета");
	
	ЭтоПиво = Ложь;
	ЭтоНапиток = Ложь;
	ЭтоНабор = Ложь;
	ЭтоУпаковка = Ложь;
	
	Попытка ЭтоПиво = ОсобенностьУчета = Перечисления.ОсобенностиУчетаНоменклатуры.БезалкогольноеПиво; Исключение КонецПопытки;
	
	Если Не ЭтоПиво Тогда
		Попытка ЭтоПиво = ОсобенностьУчета = Перечисления.ОсобенностиУчетаНоменклатуры.Пиво; Исключение КонецПопытки;	
	КонецЕсли;
	
	Если Не ЭтоПиво Тогда
		Попытка ЭтоПиво = ОсобенностьУчета = Перечисления.ОсобенностиУчетаНоменклатуры.ПивоВПотребительскихУпаковках; Исключение КонецПопытки;	
	КонецЕсли;
	
	Попытка ЭтоНапиток = ОсобенностьУчета = Перечисления.ОсобенностиУчетаНоменклатуры.БезалкогольныеНапитки; Исключение КонецПопытки;
		
	Попытка
		ЭтоАльтернативныйТабак = ОсобенностьУчета = Перечисления.ОсобенностиУчетаНоменклатуры.АльтернативныйТабак;	
	Исключение
		ЭтоАльтернативныйТабак = Ложь;
	КонецПопытки; 
	
	КоэффициентУпаковки = Неопределено;
	
	Если ЭтоАльтернативныйТабак И СтрДлина(КодМаркировки) = 29 Тогда
		
		Упаковка = НайтиУпаковкуПоGTIN(Сред(КодМаркировки, 5, 14), Параметры);
		
		Попытка 
			КоэффициентУпаковки = Упаковка.Числитель / Упаковка.Знаменатель;
			КоэффициентУпаковки = ?(КоэффициентУпаковки = 0, 1, КоэффициентУпаковки);
		Исключение
			КоэффициентУпаковки = ?(Упаковка.Числитель = 0, 1, Упаковка.Числитель);
		Конецпопытки;
		
	КонецЕсли; 
	
	НовЭлемент = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();
	
	Если ЦРПТМарка_Длина = 21 Тогда
		НовЭлемент.ТипШтрихкода = Перечисления.ТипыШтрихкодов.DataMatrix;
	Иначе	
		НовЭлемент.ТипШтрихкода = Перечисления.ТипыШтрихкодов.GS1_DataMatrix;
	КонецЕсли;	
	
	Если ЦРПТМарка_Длина = 21 Тогда
		Если KM_RawMrc = "" И Параметры.ЗаписыватьНулевойМРЦ Тогда
			НовЭлемент.ЗначениеШтрихкода = КодМаркировки + "AAAA";		
		Иначе
			НовЭлемент.ЗначениеШтрихкода = КодМаркировки + KM_RawMrc;	
		КонецЕсли;
	ИначеЕсли ЦРПТМарка_Длина = 25 Тогда
		Если KM_RawMrc = "" Тогда
			НовЭлемент.ЗначениеШтрихкода = КодМаркировки;		
		Иначе
			НовЭлемент.ЗначениеШтрихкода = КодМаркировки + "(8005)" + KM_RawMrc;	
		КонецЕсли;	
	ИначеЕсли ЦРПТМарка_Длина = 31 Тогда 
		Если KM_TNVED = "" Тогда
			НовЭлемент.ЗначениеШтрихкода = КодМаркировки;		
		Иначе
			НовЭлемент.ЗначениеШтрихкода = КодМаркировки + "(240)" + KM_TNVED;	
		КонецЕсли;
	ИначеЕсли ЦРПТМарка_Длина = 32 Тогда
		НовЭлемент.ЗначениеШтрихкода = КодМаркировки;	
	ИначеЕсли ЦРПТМарка_Длина = 24 Тогда 
		НовЭлемент.ЗначениеШтрихкода = КодМаркировки;			
	ИначеЕсли ЦРПТМарка_Длина = 38 Тогда 
		НовЭлемент.ЗначениеШтрихкода = КодМаркировки;		
	Иначе 
		НовЭлемент.ЗначениеШтрихкода = КодМаркировки;
	КонецЕсли;
	
	Если КоэффициентУпаковки <> Неопределено Тогда // ЭтоАльтернативныйТабак
		Если КоэффициентУпаковки = 1 Тогда
			НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МаркированныйТовар;
		Иначе
			НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
		КонецЕсли;
	ИначеЕсли (ЭтоПиво Или ЭтоНапиток) И ЦРПТМарка_Длина = 25 Тогда
		НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МаркированныйТовар;	
	Иначе
		Если ЦРПТМарка_Длина = 25 Тогда
			НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
		Иначе	
			НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МаркированныйТовар;
		КонецЕсли;
	КонецЕсли; 
	
	Если ЦРПТМарка_Длина = 21 Тогда
		GTIN_KM = Сред(КодМаркировки, 1, 14);
	ИначеЕсли ЦРПТМарка_Длина = 25 Тогда	
		GTIN_KM = Сред(КодМаркировки, 5, 14);
	ИначеЕсли ЦРПТМарка_Длина = 31 Тогда	
		GTIN_KM = Сред(КодМаркировки, 5, 14);
	Иначе
		GTIN_KM = Сред(КодМаркировки, 5, 14);	
	КонецЕсли;
	
	GTIN_KM = УдалитьЛидирующиеНули(GTIN_KM);
	Попытка 
		ТЗПоGTIN = ОписаниеGTINИСЭтоНаборИлиУпаковка(GTIN_KM);	
		Если ТЗПоGTIN.Количество() > 0 Тогда
			ЭтоНабор = ТЗПоGTIN[0].ЭтоНабор;
			ЭтоУпаковка = ТЗПоGTIN[0].ЭтоУпаковка;
			НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;		
		КонецЕсли;	
	Исключение КонецПопытки;
	Попытка ТекущаяУпаковка = НайтиУпаковкуПоGTIN(GTIN_KM, Параметры); Исключение ТекущаяУпаковка = Параметры.Номенклатура.ЕдиницаИзмерения; КонецПопытки;
		
	Если Параметры.Свойство("Серия") Тогда
		НовЭлемент.Серия = Параметры.Серия;		
	КонецЕсли;
	
	НовЭлемент.Номенклатура = Параметры.Номенклатура;
	НовЭлемент.Характеристика = Параметры.Характеристика;	
	НовЭлемент.Упаковка = ТекущаяУпаковка;
	
	Если НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МаркированныйТовар Тогда
		НовЭлемент.Количество = 1;
		
		ЧислительУпаковки = НовЭлемент.Упаковка.Числитель;
		ЗнаменательУпаковки = НовЭлемент.Упаковка.Знаменатель; 
		
		Если ЗнаменательУпаковки <> 0 И ЧислительУпаковки <> 0 Тогда
			
			КоличествоСогласноУпаковке = ЧислительУпаковки/ЗнаменательУпаковки;
			Если КоличествоСогласноУпаковке > 1 Тогда
				НовЭлемент.Количество = КоличествоСогласноУпаковке;
				НовЭлемент.КоличествоПотребительскихУпаковок = 1;
			КонецЕсли;	
			
		КонецЕсли;
		
		Если НовЭлемент.Номенклатура.ВесМожноУказыватьВДокументах Тогда
			Попытка НовЭлемент.Количество = Параметры.Количество; Исключение КонецПопытки;	
		КонецЕсли;		
	КонецЕсли; 
		
	Если ЭтоНабор Тогда
		НовЭлемент.Количество = 1;
		НовЭлемент.КоличествоПотребительскихУпаковок = 1;
	КонецЕсли;
	
	Если ЭтоУпаковка Тогда
		Попытка НовЭлемент.Количество = ТекущаяУпаковка.Числитель / ТекущаяУпаковка.Знаменатель; Исключение КонецПопытки;
	КонецЕсли;
	                             
	ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(НовЭлемент.ЗначениеШтрихкода);
	
	Если ДанныеУпаковки <> Неопределено Тогда
		Возврат ДанныеУпаковки.Ссылка;
	КонецЕсли;
	
	НовЭлемент.Записать();
	
	Возврат НовЭлемент.Ссылка;
	
КонецФункции

Функция СоздатьСправочникСсылкаУпаковка(КодМаркировки, Параметры = Неопределено) Экспорт
	
	Попытка
		ЕстьТег93 = Параметры.ЕстьТег93;
	Исключение
		ЕстьТег93 = Ложь;
	КонецПопытки;
	
	НовЭлемент = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();
	
	Если Лев(КодМаркировки, 4) = "(00)" Тогда
		НовЭлемент.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC;
	ИначеЕсли Лев(КодМаркировки, 4) = "(01)" Или Лев(КодМаркировки, 4) = "(02)" Тогда  
		НовЭлемент.ТипШтрихкода = Перечисления.ТипыШтрихкодов.GS1_DataMatrix;
	Иначе 
		НовЭлемент.ТипШтрихкода = Перечисления.ТипыШтрихкодов.Code128; // В ЕГАИС используем просто Code 128
	КонецЕсли;
	
	Если Параметры <> Неопределено Тогда
		Попытка НовЭлемент.Номенклатура = Параметры.Номенклатура; Исключение КонецПопытки;
		Попытка НовЭлемент.Характеристика = Параметры.Характеристика; Исключение КонецПопытки;
		Попытка НовЭлемент.Количество = Параметры.Количество; Исключение КонецПопытки;
		Попытка НовЭлемент.КоличествоПотребительскихУпаковок = Параметры.КоличествоПУ; Исключение КонецПопытки;
		Попытка НовЭлемент.Серия = Параметры.Серия; Исключение КонецПопытки;
	КонецЕсли;
	
	НовЭлемент.ЗначениеШтрихкода = КодМаркировки;	
	НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МонотоварнаяУпаковка;
	
	ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(НовЭлемент.ЗначениеШтрихкода);
	
	Если Параметры <> Неопределено Тогда
		Если Параметры.Свойство("Серия") Тогда
			Если ДанныеУпаковки <> Неопределено И ДанныеУпаковки.Серия = Параметры.Серия Тогда
				Возврат ДанныеУпаковки.Ссылка;
			КонецЕсли;
		Иначе
			Если ДанныеУпаковки <> Неопределено Тогда
				Возврат ДанныеУпаковки.Ссылка;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если ДанныеУпаковки <> Неопределено Тогда
			Возврат ДанныеУпаковки.Ссылка;
		КонецЕсли;		
	КонецЕсли;
	
	НовЭлемент.Записать();
	
	Возврат НовЭлемент.Ссылка;
	
КонецФункции

Процедура ОбновитьСериюШтрихкодыУпаковокТоваров(ШХСсылка, СерияСсылка)
	
	Если Не ЗначениеЗаполнено(ШХСсылка) Или Не ЗначениеЗаполнено(СерияСсылка) Тогда
		Возврат;	
	КонецЕсли; 
	
	Если ШХСсылка.ТипУпаковки = Перечисления.ТипыУпаковок.МаркированныйТовар Тогда
		ШХОбъект = ШХСсылка.ПолучитьОбъект();
		ШХОбъект.Серия = СерияСсылка;
		ШХОбъект.Записать();
	Иначе
		Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
		
		УпаковкаОбъект = ШХСсылка.ПолучитьОбъект();
		
		Для каждого СтрокаШК Из УпаковкаОбъект.ВложенныеШтрихкоды Цикл
			ШКОбъект = СтрокаШК.Штрихкод.ПолучитьОбъект();
			Если СерияСсылка <> Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаШК.Штрихкод, "Серия") Тогда
				ШКОбъект.Серия = СерияСсылка;					
			КонецЕсли;
			ШКОбъект.Записать();
			
			ОбновитьСериюШтрихкодыУпаковокТоваров(ШКОбъект.Ссылка, СерияСсылка);
		КонецЦикла;
		
		Если СерияСсылка <> Модуль_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ШХСсылка, "Серия") Тогда
			УпаковкаОбъект.Серия = СерияСсылка;	
		КонецЕсли;
		
		УпаковкаОбъект.Записать();	
	КонецЕсли;
	
КонецПроцедуры

Функция СформироватьЗапросКСервисуМОТПилиИСМПиСоздатьСправочникСсылкаМарка(КодМаркировки, KM_RawMrc, ТекущийКМ = Неопределено, ЭтоУпаковка = Ложь, 
	ЭтоТабак = Истина, СсылкаНаДок = Неопределено, ВидМаркируемойПродукцииДокумента = Неопределено, Параметры = Неопределено, Шаблон = Неопределено, ВызовИзАРМ = Ложь, ОшибкаПриОбращении = "",
	ДанныеНоменклатурыПоДаннымУПД = Неопределено) Экспорт
	
	Если Шаблон = Неопределено Тогда
		Шаблон = Справочники.ДатаМобайл_ШаблоныДокументов.ПустаяСсылка();
	КонецЕсли;
	
	Контекст 			= Новый Структура("Объект,Ссылка", "", ""); // Контекст = ЭтотОбъект;
	ФормаВыбора 		= Неопределено;
	
	Если ЭтоТабак Тогда
		ВидПродукцииИС = ?(ВидМаркируемойПродукцииДокумента <> Неопределено, ВидМаркируемойПродукцииДокумента, Перечисления.ВидыПродукцииИС.Табак);
	Иначе
		ВидПродукцииИС = ?(ВидМаркируемойПродукцииДокумента <> Неопределено, ВидМаркируемойПродукцииДокумента, Перечисления.ВидыПродукцииИС.Обувь)
	КонецЕсли;
	
	СсылкаНаШтрихкод	= Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка();
		
	Модуль_ШтрихкодированиеИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИСКлиентСервер");
	Модуль_ШтрихкодированиеИСКлиентСерверПереопределяемый = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИСКлиентСерверПереопределяемый");
	Модуль_ШтрихкодированиеИС = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИС");
	МодульШтрихкодированиеМОТП = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеМОТП");
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	Модуль_ШтрихкодированиеОбщегоНазначенияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеОбщегоНазначенияИСКлиентСервер");
	Модуль_ШтрихкодированиеОбщегоНазначенияИС = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеОбщегоНазначенияИС");
	
	Попытка
		ПараметрыСканирования = Модуль_ШтрихкодированиеИСКлиентСервер.БазовыеПараметрыСканирования();
	Исключение
		ПараметрыСканирования = Модуль_ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.БазовыеПараметрыСканирования();
	КонецПопытки;

	ЗаполнитьПараметрыСканированияДляАлкогольнойПродукции(ПараметрыСканирования, Контекст, ВидПродукцииИС, ФормаВыбора);
	ЗаполнитьПараметрыСканированияДляТабачнойПродукции(ПараметрыСканирования, Контекст, ВидПродукцииИС, ФормаВыбора);
	ЗаполнитьПараметрыСканированияДляПродукцииИСМП(ПараметрыСканирования, Контекст, ФормаВыбора, ВидПродукцииИС);
	Модуль_ШтрихкодированиеИСКлиентСерверПереопределяемый.ПриЗаполненииПараметровСканирования(ПараметрыСканирования, Контекст, ВидПродукцииИС);
	
	Если ЭтоТабак Тогда
		ПараметрыСканирования = ПолучитьПараметрыСканированияМОТП(СсылкаНаДок, ВидПродукцииИС, Шаблон, ПараметрыСканирования, Истина);
	Иначе
		ПараметрыСканирования = ПолучитьПараметрыСканированияИСПМ(СсылкаНаДок, ВидПродукцииИС, Шаблон, ПараметрыСканирования, Истина, ВызовИзАРМ);
	КонецЕсли; 
	
	ПараметрыСканирования.ЭтоПроверкаКодовМаркировкиИСМП = Истина;
	
	Структура = Новый Структура();
	Структура.Вставить("Штрихкод"		, ?(ТекущийКМ = Неопределено, КодМаркировки, ТекущийКМ.ЗначениеШтрихкода));
	Структура.Вставить("Количество"		, "");
	Структура.Вставить("ФорматBase64"	, Ложь);
	
	ДанныеШтрихкодаСписок = Новый Массив;
	ДанныеШтрихкодаСписок.Добавить(Структура); 
	Попытка
		ДанныеПоШтрихкодам    = Модуль_ШтрихкодированиеИС.ИнициализацияДанныхПоШтрихкодам();
	Исключение
		Модуль_ШтрихкодированиеИС = Модуль_ШтрихкодированиеОбщегоНазначенияИС;
		ДанныеПоШтрихкодам    = Модуль_ШтрихкодированиеИС.ИнициализацияДанныхПоШтрихкодам();
	КонецПопытки;
	ДанныеПоШтрихкодам.ВидыПродукции.Добавить(ВидПродукцииИС);
	ДанныеКодовМаркировки = ДанныеПоШтрихкодам.ДанныеКодовМаркировки;
	
	Попытка ПараметрыСканирования.ДопустимыеВидыПродукции.Добавить(ВидПродукцииИС); Исключение КонецПопытки; 
	
	Попытка
		Модуль_ШтрихкодированиеИС.ПодготовитьДанныеКодовМаркировкиДляОбработки(ДанныеКодовМаркировки, ДанныеШтрихкодаСписок, ПараметрыСканирования, Неопределено);	
	Исключение
		Модуль_ШтрихкодированиеИС.ПодготовитьДанныеКодовМаркировкиДляОбработки(ДанныеПоШтрихкодам, ДанныеШтрихкодаСписок, ПараметрыСканирования, Неопределено);	
	КонецПопытки;
	
	Если ТекущийКМ = Неопределено Тогда
		
		ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(КодМаркировки);
		
		Если ДанныеУпаковки = Неопределено Тогда
			Модуль_ШтрихкодированиеИС.ЗаполнитьДанныеПоШтрихкодам(ДанныеПоШтрихкодам, ПараметрыСканирования, Неопределено);
		ИначеЕсли ДанныеУпаковки.Ссылка.ВложенныеШтрихкоды.Количество() = 0 Тогда //создание вложенности
			ЗаполнитьДанныеПоШтрихкодам(ДанныеПоШтрихкодам, ПараметрыСканирования, Неопределено, Модуль_ШтрихкодированиеИС);
		Иначе
			Возврат ДанныеУпаковки.Ссылка;	
		КонецЕсли;
		
	Иначе
		
		МодульШтрихкодированиеМОТП.ЗаполнитьДанныеНеизвестныхУпаковок(ДанныеПоШтрихкодам, ПараметрыСканирования);
		
		Если ДанныеПоШтрихкодам.ВложенныеШтрихкоды <> Неопределено Тогда			
			Попытка
				Модуль_ШтрихкодированиеИС.ДополнитьТаблицуДанныеКодовМаркировкиПоСтрокамДереваУпаковок(
				ДанныеПоШтрихкодам.ДанныеКодовМаркировки, ДанныеПоШтрихкодам.ВложенныеШтрихкоды.ДеревоУпаковок,, ПараметрыСканирования);
			Исключение
				Модуль_ШтрихкодированиеИС.ДополнитьТаблицуДанныеКодовМаркировкиПоСтрокамДереваУпаковок(
				ДанныеПоШтрихкодам, ДанныеПоШтрихкодам.ВложенныеШтрихкоды.ДеревоУпаковок,, ПараметрыСканирования);	
			КонецПопытки;	
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДанныеПоШтрихкодам.ТекстОшибки <> "" Тогда
		ОшибкаПриОбращении = ДанныеПоШтрихкодам.ТекстОшибки;
		Возврат Неопределено;
	КонецЕсли;
	
	Если ДанныеПоШтрихкодам.ВложенныеШтрихкоды = Неопределено Тогда
		Возврат Неопределено;	
	КонецЕсли;
	
	Если ДанныеПоШтрихкодам.Свойство("ВложенныеШтрихкоды") И ДанныеПоШтрихкодам.ВложенныеШтрихкоды.Свойство("ДеревоУпаковок") Тогда
		
		ДеревоУпаковок = ДанныеПоШтрихкодам.ВложенныеШтрихкоды.ДеревоУпаковок;
		
		Попытка
			
			СтрокаДерева = ДеревоУпаковок.Строки[0];
			
			СоздатьНеизвестныеШтрихкодыУпаковокТоваров(СтрокаДерева, СсылкаНаШтрихкод, KM_RawMrc, ДанныеНоменклатурыПоДаннымУПД, ЭтоТабак, Параметры, СсылкаНаДок);
			
			Если СтрокаДерева.Строки.Количество() = 0 Тогда
				Возврат СсылкаНаШтрихкод;	
			КонецЕсли; 
			
			Для каждого СтрокаВложенности Из СтрокаДерева.Строки Цикл
				СоздатьНеизвестныеШтрихкодыУпаковокТоваров(СтрокаВложенности, СсылкаНаШтрихкод, KM_RawMrc, ДанныеНоменклатурыПоДаннымУПД, ЭтоТабак, Параметры, СсылкаНаДок);
				
				Если СтрокаВложенности.Строки.Количество() = 0 Тогда
					Продолжить;	
				КонецЕсли;
							
				Для каждого СтрокаВложенностиВторогоУровня Из СтрокаВложенности.Строки Цикл 
					Если ЗначениеЗаполнено(СтрокаВложенностиВторогоУровня.Упаковка) Тогда
						СтрокаВложенностиВторогоУровня.Упаковка = Неопределено;	
					КонецЕсли;
					
					СоздатьНеизвестныеШтрихкодыУпаковокТоваров(СтрокаВложенностиВторогоУровня, СсылкаНаШтрихкод, KM_RawMrc, ДанныеНоменклатурыПоДаннымУПД, ЭтоТабак, Параметры, СсылкаНаДок);	
				КонецЦикла; 
				
			КонецЦикла;				
			
		Исключение
			
			ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ИмяСобытияЖурналРегистрации = НСтр("ru = 'Создание элементов справочника штрихкоды упаковок.'", Модуль_ОбщегоНазначения.КодОсновногоЯзыка());
			ЗаписьЖурналаРегистрации(ИмяСобытияЖурналРегистрации, УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
			
			ВызватьИсключение ПодробноеПредставлениеОшибки;
			
		КонецПопытки;
		
	КонецЕсли; 
	
	Возврат СсылкаНаШтрихкод;
	
КонецФункции

Функция СформироватьЗапросКСервису(МассивКМ, СсылкаНаДок, Шаблон, МассивПродукцийПоДокументу, ОшибкаПриОбращении, ВызовИзАРМ = Ложь) Экспорт
	
	Если Шаблон = Неопределено Тогда
		Шаблон = Справочники.ДатаМобайл_ШаблоныДокументов.ПустаяСсылка();
	КонецЕсли;
	
	Контекст 			= Новый Структура("Объект,Ссылка", "", ""); // Контекст = ЭтотОбъект;
	ВидПродукцииИС	    = Неопределено;
		
	Модуль_ШтрихкодированиеИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИСКлиентСервер");
	Модуль_ШтрихкодированиеИСКлиентСерверПереопределяемый = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИСКлиентСерверПереопределяемый");
	Модуль_ШтрихкодированиеОбщегоНазначенияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеОбщегоНазначенияИСКлиентСервер");
	Модуль_ОбщегоНазначенияИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначенияИСКлиентСервер");
	Модуль_ШтрихкодированиеИСМП = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИСМП");
	
	Попытка
		ПараметрыСканирования = Модуль_ШтрихкодированиеИСКлиентСервер.БазовыеПараметрыСканирования();
	Исключение
		ПараметрыСканирования = Модуль_ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.БазовыеПараметрыСканирования();
	КонецПопытки;

	Модуль_ШтрихкодированиеИСКлиентСерверПереопределяемый.ПриЗаполненииПараметровСканирования(ПараметрыСканирования, Контекст, ВидПродукцииИС);
	
	ПараметрыСканирования = ПолучитьПараметрыСканированияИСПМ(СсылкаНаДок, ВидПродукцииИС, Шаблон, ПараметрыСканирования, Истина);
 			
	ПараметрыСканирования.ДопустимыеВидыПродукции.Очистить();
	ПараметрыСканирования.ОпределениеВидаПродукцииИСМП = Истина;
	ПараметрыСканирования.ДопустимыеВидыПродукции = Модуль_ОбщегоНазначенияИСКлиентСервер.ВидыПродукцииИСМП(Истина);
	ПараметрыСканирования.СсылкаНаОбъект = СсылкаНаДок;
	ПараметрыСканирования.ДетализацияСтруктурыХранения = Перечисления.ДетализацияСтруктурыХраненияИС.Полная;
	ПараметрыСканирования.ЭтоПроверкаКодовМаркировкиИСМП = Истина;
	
	РезультатПолученияДанных = Модуль_ШтрихкодированиеИСМП.ВложенныеШтрихкодыУпаковокПоДокументу(
					СсылкаНаДок,
					ПараметрыСканирования, Истина);
		
	Если РезультатПолученияДанных.ЕстьОшибки Тогда
		ОшибкаПриОбращении = РезультатПолученияДанных.ТекстОшибки;
		Возврат Неопределено;
	КонецЕсли;

	Если РезультатПолученияДанных.ВложенныеШтрихкоды = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если РезультатПолученияДанных.Свойство("ВложенныеШтрихкоды") И РезультатПолученияДанных.ВложенныеШтрихкоды.Свойство("ДеревоУпаковок") Тогда
		
		РезультатПолученияДанных.ВложенныеШтрихкоды.ДеревоУпаковок.Колонки.Удалить("ШтрихкодУпаковки");
		РезультатПолученияДанных.ВложенныеШтрихкоды.ДеревоУпаковок.Колонки.Добавить("КоличествоПодчиненныхПотребительскихУпаковок", Новый ОписаниеТипов("Число"));
		РезультатПолученияДанных.ВложенныеШтрихкоды.ДеревоУпаковок.Колонки.Добавить("КоличествоПодчиненныхВсего", Новый ОписаниеТипов("Число"));
		РезультатПолученияДанных.ВложенныеШтрихкоды.ДеревоУпаковок.Колонки.Добавить("СтатусПроверки",                      Новый ОписаниеТипов("ПеречислениеСсылка.СтатусыПроверкиНаличияПродукцииИС"));
		РезультатПолученияДанных.ВложенныеШтрихкоды.ДеревоУпаковок.Колонки.Добавить("КоличествоПодчиненныхОтсутствует", Новый ОписаниеТипов("Число"));
			
		ПараметрыПроцедуры = Новый Структура;
		ПараметрыПроцедуры.Вставить("СоздаватьАктОРасхождениях",    Ложь);
		ПараметрыПроцедуры.Вставить("ПроверяемыйДокумент",          СсылкаНаДок);
		ПараметрыПроцедуры.Вставить("ПроверкаНеПоДокументу",        Истина);
		ПараметрыПроцедуры.Вставить("ДанныеПроверкиИПодбора",       Неопределено);
		ПараметрыПроцедуры.Вставить("ВидМаркируемойПродукции",      ВидПродукцииИС);
		ПараметрыПроцедуры.Вставить("ДеревоМаркированнойПродукции",    РезультатПолученияДанных.ВложенныеШтрихкоды.ДеревоУпаковок);
		ПараметрыПроцедуры.Вставить("ПодобраннаяМаркируемаяПродукция", Новый Массив);
		ПараметрыПроцедуры.Вставить("СохранятьОписаниеGTIN",        Ложь);
		ПараметрыПроцедуры.Вставить("ПараметрыСканирования",        ПараметрыСканирования);
		ПараметрыПроцедуры.Вставить("ДетализацияСтруктурыХранения", Перечисления.ДетализацияСтруктурыХраненияИС.Полная);
		ПараметрыПроцедуры.Вставить("РежимИсправленияОшибокПослеПередачиКодов", Ложь);
		ПараметрыПроцедуры.Вставить("Сценарий",                     0);
		ПараметрыПроцедуры.Вставить(
		"ВозможностьЗагрузкиДанныхБезПодключенияМОТП",
		Ложь);
		
		Модуль_ДлительныеОперации 			= ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ДлительныеОперации");
		Модуль_ИнтеграцияИСПереопределяемый = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСПереопределяемый");
		
		ПараметрыВыполнения = Модуль_ДлительныеОперации.ПараметрыВыполненияВФоне(Неопределено);
		ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Перенос результатов проверки и подбора в документ.'");
		ПараметрыВыполнения.ЗапуститьВФоне = Истина;
		
		Модуль_ИнтеграцияИСПереопределяемый.НастроитьДлительнуюОперацию(ПараметрыПроцедуры, ПараметрыВыполнения);
		
		Возврат Модуль_ДлительныеОперации.ВыполнитьВФоне("Обработки.ПроверкаИПодборПродукцииИСМП.ЗафиксироватьРезультатПроверкиИПодбора",
		ПараметрыПроцедуры, ПараметрыВыполнения);
		
	КонецЕсли; 
		
КонецФункции

// Включает поддержку алкогольной продукции и заполняет параметры сканирования с учетом ее специфики.
// 
// Параметры:
//  ПараметрыСканирования - (См. ШтрихкодированиеИСКлиент.ПараметрыСканирования).
//  Контекст - Неопределено, ФормаКлиентскогоПриложения, ДокументСсылка - Описание
//  ФормаВыбора - ФормаКлиентскогоПриложения - форма выбора.
//  ВидПродукции - ПеречислениеСсылка.ВидыПродукцииИС - Вид продукции, по которому будут инициализированы параметры сканирования.
Процедура ЗаполнитьПараметрыСканированияДляАлкогольнойПродукции(ПараметрыСканирования, Контекст, ВидПродукции, ФормаВыбора)
	
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	
	Если Модуль_ОбщегоНазначения.ПодсистемаСуществует("ГосИС.ЕГАИС")
		И (ВидПродукции = ПредопределенноеЗначение("Перечисление.ВидыПродукцииИС.Алкогольная")
		Или ВидПродукции = Неопределено) Тогда
		
		МодульШтрихкодированиеЕГАИСКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеЕГАИСКлиентСервер");
		МодульШтрихкодированиеЕГАИСКлиентСервер.ЗаполнитьПараметрыСканирования(
		ПараметрыСканирования, Контекст, ВидПродукции, ФормаВыбора);
		
	КонецЕсли;
	
КонецПроцедуры

// Включает поддержку табачной продукции и заполняет параметры сканирования с учетом ее специфики.
// 
// Параметры:
//  ПараметрыСканирования - (См. ШтрихкодированиеИСКлиент.ПараметрыСканирования).
//  Контекст - Неопределено, ФормаКлиентскогоПриложения, ДокументСсылка - Описание
//  ФормаВыбора - ФормаКлиентскогоПриложения - форма выбора.
//  ВидПродукции - ПеречислениеСсылка.ВидыПродукцииИС - Вид продукции, по которому будут инициализированы параметры сканирования.
Процедура ЗаполнитьПараметрыСканированияДляТабачнойПродукции(ПараметрыСканирования, Контекст, ВидПродукции, ФормаВыбора, ПараметрыРежимаИсправленияОшибок = Неопределено)
	
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	
	Если Модуль_ОбщегоНазначения.ПодсистемаСуществует("ГосИС.ИСМП")
		И (ЭтоТабакПоВидыПродукцииИС(ВидПродукции)
		Или ВидПродукции = Неопределено) Тогда
		
		Попытка
			Модуль_ШтрихкодированиеМОТПКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеМОТПКлиентСервер");
			Модуль_ШтрихкодированиеМОТПКлиентСервер.ЗаполнитьПараметрыСканирования(ПараметрыСканирования, Контекст, ВидПродукции, ФормаВыбора);
		Исключение
			Модуль_ШтрихкодированиеОбщегоНазначенияМОТПКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеОбщегоНазначенияМОТПКлиентСервер");
			Модуль_ШтрихкодированиеОбщегоНазначенияМОТПКлиентСервер.ЗаполнитьПараметрыСканирования(ПараметрыСканирования, Контекст, ВидПродукции, ФормаВыбора, ПараметрыРежимаИсправленияОшибок);
		КонецПопытки;
			
	КонецЕсли;
	
КонецПроцедуры

// Включает поддержку обувной продукции и заполняет параметры сканирования с учетом ее специфики.
//
// Параметры:
//  ПараметрыСканирования - (См. ШтрихкодированиеИСКлиент.ПараметрыСканирования).
//  Контекст - Неопределено, ФормаКлиентскогоПриложения, ДокументСсылка - Описание
//  ФормаВыбора - ФормаКлиентскогоПриложения - форма выбора.
//  ВидПродукции - ПеречислениеСсылка.ВидыПродукцииИС - Вид продукции, по которому будут инициализированы параметры сканирования.
Процедура ЗаполнитьПараметрыСканированияДляПродукцииИСМП(ПараметрыСканирования, Контекст, ФормаВыбора, ВидПродукции)
	
	Модуль_ИнтеграцияИСПовтИсп = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ИнтеграцияИСПовтИсп");
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	Модуль_ОбщегоНазначенияИСПовтИсп = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначенияИСПовтИсп");
	Модуль_ШтрихкодированиеОбщегоНазначенияИСМПКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеОбщегоНазначенияИСМПКлиентСервер");
	
	Если Модуль_ОбщегоНазначения.ПодсистемаСуществует("ГосИС.ИСМП") Тогда
		
		Попытка
			Если Модуль_ИнтеграцияИСПовтИсп.ЭтоПродукцияИСМП(ВидПродукции)
				Или Не ЗначениеЗаполнено(ВидПродукции) Тогда
				
				МодульШтрихкодированиеМОТПКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИСМПКлиентСервер");
				
				Попытка
					МодульШтрихкодированиеМОТПКлиентСервер.ЗаполнитьПараметрыСканирования(Контекст, ФормаВыбора, ВидПродукции, ПараметрыСканирования);	
				Исключение
					МодульШтрихкодированиеМОТПКлиентСервер.ЗаполнитьПараметрыСканирования(Контекст, ВидПродукции, ПараметрыСканирования);
				КонецПопытки; 
				
			КонецЕсли;
		Исключение
			Если Модуль_ОбщегоНазначенияИСПовтИсп.ЭтоПродукцияИСМП(ВидПродукции)
				Или Не ЗначениеЗаполнено(ВидПродукции) Тогда
				
				МодульШтрихкодированиеМОТПКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ШтрихкодированиеИСМПКлиентСервер");
				
				Попытка
					МодульШтрихкодированиеМОТПКлиентСервер.ЗаполнитьПараметрыСканирования(Контекст, ФормаВыбора, ВидПродукции, ПараметрыСканирования);	
				Исключение
					Попытка
						МодульШтрихкодированиеМОТПКлиентСервер.ЗаполнитьПараметрыСканирования(Контекст, ВидПродукции, ПараметрыСканирования);	
					Исключение
					    Модуль_ШтрихкодированиеОбщегоНазначенияИСМПКлиентСервер.ЗаполнитьПараметрыСканирования(Контекст, ВидПродукции, ПараметрыСканирования);
					КонецПопытки;					
				КонецПопытки; 
				
			КонецЕсли;		
		КонецПопытки;
	
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьНеизвестныеШтрихкодыУпаковокТоваров(СтрокаДерева, СсылкаНаШтрихкод, KM_RawMrc, ДанныеНоменклатурыПоДаннымУПД = Неопределено, ЭтоТабак, Параметры, СсылкаНаДок)
	
	Марка = СтрокаДерева.Штрихкод;
	
	ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(Марка);
	
	Если ДанныеУпаковки = Неопределено Тогда
		НовЭлемент = Справочники.ШтрихкодыУпаковокТоваров.СоздатьЭлемент();
		
		Попытка
			ЗаполнитьЗначенияСвойств(НовЭлемент, СтрокаДерева,,"Родитель,Владелец,ХешСумма");
		Исключение
			ЗаполнитьЗначенияСвойств(НовЭлемент, СтрокаДерева,,"Родитель,ХешСумма");
		КонецПопытки;
		
		Если СтрДлина(Марка) = 29 И СтрокаДерева.ТипШтрихкода = Перечисления.ТипыШтрихкодов.GS1_DataMatrix Тогда	
			Марка = Марка + ?(СокрЛП(KM_RawMrc) = "", "", "(8005)" + KM_RawMrc);	
		КонецЕсли;
		
		// Переопределю Номенклатуру и характеристику на подобранную из документа ПТУ или на ТСД
		Если СсылкаНаДок <> Неопределено И ТипЗнч(СсылкаНаДок) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Номенклатура", НовЭлемент.Номенклатура);
			
			СтрокаПоиска = СсылкаНаДок.Товары.НайтиСтроки(ПараметрыОтбора);
			
			Если СтрокаПоиска.Количество() = 1 Тогда		
				НовЭлемент.Характеристика = СтрокаПоиска[0].Характеристика;
			КонецЕсли;
						
		ИначеЕсли Параметры <> Неопределено Тогда
			
			Номенклатура 	= Параметры.Номенклатура;
			Характеристика 	= Параметры.Характеристика;
			
			Если Номенклатура <> Справочники.Номенклатура.ПустаяСсылка() И Номенклатура <> НовЭлемент.Номенклатура Тогда
				НовЭлемент.Номенклатура = Номенклатура;	
			КонецЕсли;
			
			Если Характеристика <> Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка() И Характеристика <> НовЭлемент.Характеристика Тогда
				НовЭлемент.Характеристика = Характеристика;	
			КонецЕсли;
			
		КонецЕсли;
		
		НовЭлемент.ЗначениеШтрихкода = СокрЛП(Марка);
		
		Если Не ЭтоТабак И (СтрокаДерева.ТипШтрихкода = Перечисления.ТипыШтрихкодов.GS1_DataMatrix Или СтрокаДерева.ТипШтрихкода = Перечисления.ТипыШтрихкодов.SSCC) И НовЭлемент.Номенклатура = Справочники.Номенклатура.ПустаяСсылка() Тогда
			
			МаркаБезНулей = СтрЗаменить(Марка, "(00)", "");
			
			Если ДанныеНоменклатурыПоДаннымУПД <> Неопределено Тогда
				
				СведенияПоEAN = ДанныеНоменклатурыПоДаннымУПД.Получить(МаркаБезНулей);
				
				Если СведенияПоEAN <> Неопределено Тогда			
					Если ЗначениеЗаполнено(СведенияПоEAN.Номенклатура) Тогда					
						НовЭлемент.Номенклатура = СведенияПоEAN.Номенклатура;
						НовЭлемент.Характеристика = СведенияПоEAN.Характеристика;
					Иначе
						ЗаполнитьНоменклатуру(СтрокаДерева, НовЭлемент);				
					КонецЕсли;
				Иначе
					ЗаполнитьНоменклатуру(СтрокаДерева, НовЭлемент);
				КонецЕсли;
				
			КонецЕсли; 
			
		КонецЕсли;
		
		Если НовЭлемент.Номенклатура = Справочники.Номенклатура.ПустаяСсылка() И НовЭлемент.ТипУпаковки <> Перечисления.ТипыУпаковок.МультитоварнаяУпаковка Тогда
			ЗаполнитьНоменклатуру(СтрокаДерева, НовЭлемент, Истина);
		КонецЕсли;
		
		Если НовЭлемент.Номенклатура <> Справочники.Номенклатура.ПустаяСсылка() Или НовЭлемент.ТипУпаковки = Перечисления.ТипыУпаковок.МультитоварнаяУпаковка Тогда			
			ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(НовЭлемент.ЗначениеШтрихкода);
			
			Если ДанныеУпаковки <> Неопределено Тогда //данный штрихкод есть базе
				СсылкаНаШтрихкод = ДанныеУпаковки.Ссылка;
				Возврат;
			КонецЕсли;
			
			НовЭлемент.Записать();
		Иначе
			ДатаМобайл_ОбщийМодуль.СообщитьПользователю("Не заполнена номенклатура для: " + Марка);
		КонецЕсли;	
		
	Иначе
		
		НовЭлемент = ДанныеУпаковки.Ссылка;
		
	КонецЕсли; 
	
	Если СтрокаДерева.Родитель <> Неопределено Тогда
		ЗначениеШтрихкодаРодителя 					= СтрокаДерева.Родитель.Штрихкод;
		ЗначениеШтрихкодаРодителяНормализованный 	= СтрокаДерева.Родитель.НормализованныйШтрихкод;
		
		ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(ЗначениеШтрихкодаРодителя);
		
		Если ДанныеУпаковки = Неопределено Тогда
			ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(ЗначениеШтрихкодаРодителяНормализованный);		
		КонецЕсли; 
		
		Если ДанныеУпаковки = Неопределено И Не СсылкаНаШтрихкод.Пустая() Тогда // 2 верхних поиска перестали отрабатывать, добавил подстановку по родителю
			ДанныеУпаковки = СсылкаНаШтрихкод;		
		КонецЕсли;
		
		Если ДанныеУпаковки <> Неопределено Тогда // данный штрихкод есть базе	
			НайденныйОбъект = ДанныеУпаковки.Ссылка.ПолучитьОбъект();
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Штрихкод", НовЭлемент.Ссылка);
			НайденныеСтроки = НайденныйОбъект.ВложенныеШтрихкоды.НайтиСтроки(ПараметрыОтбора);
			
			Если НайденныеСтроки.Количество() = 0 Тогда
				НовСтрокаВложенности = НайденныйОбъект.ВложенныеШтрихкоды.Добавить();
				НовСтрокаВложенности.Штрихкод = НовЭлемент.Ссылка;
				НайденныйОбъект.Записать();
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли; 
	
	Если СсылкаНаШтрихкод.Пустая() Тогда
		СсылкаНаШтрихкод = НовЭлемент.Ссылка;		
	КонецЕсли; 
	
КонецПроцедуры

Процедура ЗаполнитьНоменклатуру(СтрокаДерева, НовЭлемент, ИскатьПоEAN = Ложь)
	
	Если ИскатьПоEAN Тогда
		
		EAN = "";
		
		Если СтрокаДерева.Строки.Количество() = 0 Тогда
			EAN = СтрокаДерева.EAN;	
		КонецЕсли; 
		
		Попытка
			Если СтрокаДерева.Строки[0].Строки.Количество() = 0 Тогда
				EAN = СтрокаДерева.Строки[0].EAN;	
			КонецЕсли;
		Исключение
		КонецПопытки;
		
		Попытка
			Если СтрокаДерева.Строки[0].Строки[0].Количество() = 0 Тогда
				EAN = СтрокаДерева.Строки[0].Строки[0].EAN;	
			КонецЕсли;
		Исключение
		КонецПопытки;
		
		Если Не ПустаяСтрока(EAN) Тогда
			ЗаполнитьНоменклатуруВСтрокаДерева(СтрокаДерева, НовЭлемент, EAN);
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	Если СтрокаДерева.Родитель <> Неопределено Тогда
		
		ЗначениеШтрихкодаРодителя 					= СтрокаДерева.Родитель.Штрихкод;
		ЗначениеШтрихкодаРодителяНормализованный 	= СтрокаДерева.Родитель.НормализованныйШтрихкод;
		
		ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(ЗначениеШтрихкодаРодителя);
		
		Если ДанныеУпаковки = Неопределено Тогда
			ДанныеУпаковки = ПолучитьДанныеУпаковкиПоЗначениюШтрихкода(ЗначениеШтрихкодаРодителяНормализованный);		
		КонецЕсли;
		
		Если ДанныеУпаковки <> Неопределено Тогда // данный штрихкод есть базе
			НовЭлемент.Номенклатура = ДанныеУпаковки.Номенклатура;
			НовЭлемент.Характеристика = ДанныеУпаковки.Характеристика;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьНоменклатуруВСтрокаДерева(СтрокаДерева, НовЭлемент, EAN)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод ПОДОБНО ""%"" + &Штрихкод
	|	И ШтрихкодыНоменклатуры.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.)";
	
	Запрос.УстановитьПараметр("Штрихкод", EAN);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		Номенклатура = Выборка.Номенклатура;
		ПустаяНоменклатура = Справочники.Номенклатура.ПустаяСсылка();
		
		СтрокаДерева.Номенклатура 	= Номенклатура;
		НовЭлемент.Номенклатура 	= Номенклатура;
		
		Если СтрокаДерева.Строки.Количество() = 0 Тогда
			Возврат;	
		КонецЕсли; 
		
		Для каждого СтрокаВложенности Из СтрокаДерева.Строки Цикл
			
			Если СтрокаВложенности.Номенклатура = ПустаяНоменклатура Тогда
				СтрокаВложенности.Номенклатура = Номенклатура;	
			КонецЕсли;	
			
			Если СтрокаВложенности.Строки.Количество() = 0 Тогда
				Продолжить;	
			КонецЕсли;
			
			Для каждого СтрокаВложенностиВторогоУровня Из СтрокаВложенности.Строки Цикл
				Если СтрокаВложенностиВторогоУровня.Номенклатура = ПустаяНоменклатура Тогда
					СтрокаВложенностиВторогоУровня.Номенклатура = Номенклатура;	
				КонецЕсли;		
			КонецЦикла; 
			
		КонецЦикла;	
	КонецЕсли;	
	
КонецПроцедуры

Процедура ОчиститьСтрокиШтрихкодовУпаковокПоМассиву(ИсходныйДокумент)
	
	Попытка ИсходныйДокумент.ШтрихкодыУпаковок.Очистить(); Исключение КонецПопытки;
	
КонецПроцедуры

Процедура СоздатьСтрокиШтрихкодовУпаковокПоМассиву(лМассив, ИсходныйДокумент, МассивНеизвестныхДляПриемки = Неопределено, ПроверкаБезСертификата = Ложь, ЭтоНовыйДокумент = Ложь, 
	МассивНепроверенныхДляПриемки = Неопределено, ДокументТСД = Неопределено, ТЗУпаковок = Неопределено)
	
	Если МассивНеизвестныхДляПриемки = Неопределено Тогда
		МассивНеизвестныхДляПриемки = Новый Массив;	
	КонецЕсли;	
	
	Если МассивНепроверенныхДляПриемки = Неопределено Тогда
		МассивНепроверенныхДляПриемки = Новый Массив;	
	КонецЕсли; 
	
	Попытка 
		ДатаСозданияДокаТСД = ДокументТСД.ДатаСоздания 
	Исключение
		ДатаСозданияДокаТСД = ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату();
		ДатаМобайл_ОбщийМодуль.ОбработатьИсключение(0, "СоздатьСтрокиШтрихкодовУпаковокПоМассиву", ОписаниеОшибки());
	КонецПопытки;
	
	ВидДокумента = ИсходныйДокумент.Метаданные().Имя;
	Если Метаданные.Документы[ВидДокумента].ТабличныеЧасти.Найти("ШтрихкодыУпаковок") = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	Для каждого лЭлемент Из лМассив Цикл
		
		Если лЭлемент = Неопределено Или лЭлемент = Справочники.ШтрихкодыУпаковокТоваров.ПустаяСсылка() Тогда
			Продолжить;
		КонецЕсли;
		
		лСтруктураПоиска = Новый Структура("ШтрихкодУпаковки", лЭлемент);	
		СтрокиПоиска = ИсходныйДокумент.ШтрихкодыУпаковок.НайтиСтроки(лСтруктураПоиска);
		Если СтрокиПоиска.Количество() <> 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если ВидДокумента = "ПриобретениеТоваровУслуг" Или ВидДокумента = "ПриемкаТоваровИСМП" Тогда
			Попытка
				ЗначениеШтрихкода = УбратьСкобкиТеговМарка(лЭлемент.ЗначениеШтрихкода,ПолучитьТипМаркированнойПродукции(лЭлемент.Номенклатура));
				лСтруктураПоиска = Новый Структура("ЗначениеШтрихкода", ЗначениеШтрихкода);	
				СтрокиПоиска = ИсходныйДокумент.ШтрихкодыУпаковок.НайтиСтроки(лСтруктураПоиска);
				
				Если СтрокиПоиска.Количество() = 0 И (СтрДлина(лЭлемент.ЗначениеШтрихкода) = 22 Или лЭлемент.ЗначениеШтрихкода = 20) Тогда
					лСтруктураПоиска = Новый Структура("ЗначениеШтрихкода", Прав(лЭлемент.ЗначениеШтрихкода, 18));	
					СтрокиПоиска = ИсходныйДокумент.ШтрихкодыУпаковок.НайтиСтроки(лСтруктураПоиска);		
				КонецЕсли;
				
				Если СтрокиПоиска.Количество() = 0 Тогда
					НайденноеЗначениеШтрихкода = ПоискЗначениеШтрихкодаВДокументеПриемка(ИсходныйДокумент.Ссылка, ЗначениеШтрихкода);
					Если НайденноеЗначениеШтрихкода <> "" Тогда
						Продолжить;
					КонецЕсли;	
				КонецЕсли;
				
				Если СтрокиПоиска.Количество() <> 0 Тогда
					Для каждого НайденнаяСтрока Из СтрокиПоиска Цикл
						Если ПроверкаБезСертификата Тогда
							НайденнаяСтрока.ШтрихкодУпаковки = лЭлемент;	
						КонецЕсли; 
					КонецЦикла;
					Продолжить;
				КонецЕсли;
				
				Если ТЗУпаковок <> Неопределено Тогда
					Если ТЗУпаковок.Количество() > 0 Тогда
						Отбор = Новый Структура();
						Отбор.Вставить("Марка", лЭлемент);
						Строки = ТЗУпаковок.НайтиСтроки(Отбор);
						Если Строки.Количество() > 0 Тогда
							НайденнаяСтрокаТЗ = Строки[0];
							Если ЗначениеЗаполнено(НайденнаяСтрокаТЗ.Палета) Тогда
								ТекущееЗначениеШтрихкода = НайденнаяСтрокаТЗ.ЗначениеПалеты;
							Иначе
								ТекущееЗначениеШтрихкода = НайденнаяСтрокаТЗ.ЗначениеКороба;	
							КонецЕсли;
							
							лСтруктураПоиска = Новый Структура("ЗначениеШтрихкода",ТекущееЗначениеШтрихкода);	
							СтрокиПоиска = ИсходныйДокумент.ШтрихкодыУпаковок.НайтиСтроки(лСтруктураПоиска);
							
							Если СтрокиПоиска.Количество() = 0 И (Лев(ТекущееЗначениеШтрихкода, 2) = "00" И СтрДлина(ТекущееЗначениеШтрихкода) = 20
								Или СтрокиПоиска.Количество() = 0 И Лев(ТекущееЗначениеШтрихкода, 4) = "(00)" И СтрДлина(ТекущееЗначениеШтрихкода) = 22) Тогда
								ТекущееЗначениеШтрихкода = Прав(ТекущееЗначениеШтрихкода, 18);
								лСтруктураПоиска = Новый Структура("ЗначениеШтрихкода", ТекущееЗначениеШтрихкода);	
								СтрокиПоиска = ИсходныйДокумент.ШтрихкодыУпаковок.НайтиСтроки(лСтруктураПоиска);											
							КонецЕсли;				
							
