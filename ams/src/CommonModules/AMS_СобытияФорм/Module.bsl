	КонецЕсли;
КонецПроцедуры

Процедура ДобавитьРеквизитыДоставкиAMS(Форма, ТипДокумента)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;

	ДобавляемыеРеквизиты = Новый Массив;
	
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_ТранспортноеСредство", Новый ОписаниеТипов("СправочникСсылка.ТранспортныеСредства")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_Водитель", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_ТелефонВодителя", Новый ОписаниеТипов("Строка")));
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

	ДанныеДоставки = ПолучитьТранспортДоставки(Объект.Ссылка);
	Если Не ДанныеДоставки = Неопределено Тогда
		Форма.AMS_ТранспортноеСредство = ДанныеДоставки.ТранспортноеСредство;
		Форма.AMS_Водитель             = ДанныеДоставки.Водитель;
		Форма.AMS_ТелефонВодителя      = AMS_ВызовСервера.ПолучитьТелефонМобильныйФизическиеЛица(ДанныеДоставки.Водитель);
	КонецЕсли;
	
	СписокВыбора = Элементы.СпособДоставки.СписокВыбора;
	СписокВыбора.Очистить();
	
	Если ТипДокумента = "ЗаказКлиента" 
		Или ТипДокумента = "ОтгрузкаТоваровКлиенту" 
		Или ТипДокумента = "ПередачаТоваровХранителю" 
		Или ТипДокумента = "РеализацияТоваровУслуг" Тогда
			
		СписокВыбора.Добавить(Перечисления.СпособыДоставки.Самовывоз, "Самовывоз (с нашего склада)");
		СписокВыбора.Добавить(Перечисления.СпособыДоставки.ДоКлиента, "Наша транспортная служба до клиента");
		СписокВыбора.Добавить(Перечисления.СпособыДоставки.СиламиПеревозчикаПоАдресу, "Наша транспортная служба до перевозчика");
		СписокВыбора.Добавить(Перечисления.СпособыДоставки.КПолучателюОпределяетСлужбаДоставки,	"Перегрузка в транспорт клиента");
	
	ИначеЕсли ТипДокумента = "ЗаказПоставщику" Тогда
		СписокВыбора.Добавить(Перечисления.СпособыДоставки.СиламиПоставщикаДоНашегоСклада, "Поставщик (на наш склад)");
		СписокВыбора.Добавить(Перечисления.СпособыДоставки.НашимиСиламиСАдресаОтправителя, "Наша транспортная служба от поставщика");
	
	ИначеЕсли ТипДокумента = "ЗаявкаНаВозвратТоваровОтКлиента" Тогда
		СписокВыбора.Добавить(Перечисления.СпособыДоставки.ДоКлиента, "Наша транспортная служба до склада");
	КонецЕсли;

	Группа = Элементы.Добавить("AMS_ГруппаДоставка", Тип("ГруппаФормы"), Элементы.СтраницаДоставка);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительная информация";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Группа = Элементы.Добавить("AMS_ГруппаТранспорт", Тип("ГруппаФормы"), Элементы.AMS_ГруппаДоставка);
	Группа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Отображение         = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("AMS_ТранспортноеСредство", Тип("ПолеФормы"), Элементы.AMS_ГруппаТранспорт);
	Элемент.ПутьКДанным    = "AMS_ТранспортноеСредство";
	Элемент.Вид            = ВидПоляФормы.ПолеВвода;
	Элемент.ТолькоПросмотр = Истина;
	Элемент.Заголовок      = "Транспортное средство";
	Элемент.Ширина         = 15;
	Элемент.РастягиватьПоГоризонтали = Ложь;
	
	Элемент = Элементы.Добавить("AMS_Водитель", Тип("ПолеФормы"), Элементы.AMS_ГруппаТранспорт);
	Элемент.ПутьКДанным    = "AMS_Водитель";
	Элемент.Вид            = ВидПоляФормы.ПолеВвода;
	Элемент.ТолькоПросмотр = Истина;
	Элемент.Заголовок      = "Водитель";
	Элемент.Ширина         = 20;
	Элемент.РастягиватьПоГоризонтали = Ложь;

	Элемент = Элементы.Добавить("AMS_ТелефонВодителя", Тип("ПолеФормы"), Элементы.AMS_ГруппаТранспорт);
	Элемент.ПутьКДанным    = "AMS_ТелефонВодителя";
	Элемент.Вид            = ВидПоляФормы.ПолеВвода;
	Элемент.ТолькоПросмотр = Истина;
	Элемент.Заголовок      = "Мобильные телефон";
	Элемент.Ширина         = 15;
	Элемент.РастягиватьПоГоризонтали = Ложь;
	
	Если ТипДокумента = "ЗаказКлиента" 
		Или ТипДокумента = "ОтгрузкаТоваровКлиенту" 
		Или ТипДокумента = "ПередачаТоваровХранителю" 
		Или ТипДокумента = "РеализацияТоваровУслуг" Тогда

		Элемент = Элементы.Добавить("AMS_ДоверенностьКлиента", Тип("ПолеФормы"), Элементы.AMS_ГруппаДоставка);
		Элемент.ПутьКДанным = "Объект.AMS_ДоверенностьКлиента";
		Элемент.Вид         = ВидПоляФормы.ПолеПереключателя;
		Группа.Заголовок    = "Доверенность клиента";
		Элемент.СписокВыбора.Добавить(1, "Оригинал");
		Элемент.СписокВыбора.Добавить(2, "Копия");

		Группа = Элементы.Добавить("AMS_ГруппаДоПеревозчика", Тип("ГруппаФормы"), Элементы.AMS_ГруппаДоставка);
		Группа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.ОтображатьЗаголовок = Ложь;
		Группа.Отображение         = ОтображениеОбычнойГруппы.Нет;
		Группа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		
		Элемент = Элементы.Добавить("AMS_ВидТранспортаПеревозчика", Тип("ПолеФормы"), Элементы.AMS_ГруппаДоПеревозчика);
		Элемент.ПутьКДанным              = "Объект.AMS_ВидТранспортаПеревозчика";
		Элемент.Вид                      = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок                = "Вид транспорта перевозчика";
		Элемент.Ширина                   = 35;
		Элемент.РастягиватьПоГоризонтали = Ложь;
		Элемент.РежимВыбораИзСписка      = Истина;
		Элемент.СписокВыбора.Добавить("Авто", "АВТО");
		Элемент.СписокВыбора.Добавить("Жд", "Ж/Д");
		
		Элемент = Элементы.Добавить("AMS_НомерЗаявкиПеревозчика", Тип("ПолеФормы"), Элементы.AMS_ГруппаДоПеревозчика);
		Элемент.ПутьКДанным              = "Объект.AMS_НомерЗаявкиПеревозчика";
		Элемент.Вид                      = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок                = "Номер заявки";
		Элемент.Ширина                   = 35;
		Элемент.РастягиватьПоГоризонтали = Ложь;

