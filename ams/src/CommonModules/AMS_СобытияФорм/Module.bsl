#Область ПрограммныйИнтерфейс

// Процедура, вызываемая из одноименного обработчика события формы.
//
// Параметры:
//  Форма					 - ФормаКлиентскогоПриложения	 - форма, из обработчика события которой происходит вызов процедуры.
//  Отказ					 - Булево			 - признак отказа от создания формы.
//  СтандартнаяОбработка	 - Булево			 - признак выполнения стандартной (системной) обработки события
//  ДополнительныеПараметры	 - Структура		 - дополнительные параметры.
//
Процедура ПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры = Неопределено) Экспорт
	ИмяФормы = Форма.ИмяФормы;
	
	ЛеваяЧастьИмя = Лев(ИмяФормы, СтрНайти(ИмяФормы, ".")-1);
	
	Если ЛеваяЧастьИмя = "Справочник" Тогда
	
		Если ИмяФормы = "Справочник.ДоговорыКонтрагентов.Форма.ФормаЭлемента" Тогда
			НастройкаФормыДоговорыКонтрагентов(Форма);
		
		ИначеЕсли ИмяФормы = "Справочник.ДоговорыКонтрагентов.Форма.ФормаСписка" Тогда
			НастройкаФормыСпискаДоговорыКонтрагентов(Форма);

		ИначеЕсли ИмяФормы = "Справочник.ДоговорыКонтрагентов.Форма.ФормаСпискаЗакупки" Тогда
			НастройкаФормыСпискаЗакупкиДоговорыКонтрагентов(Форма);

		ИначеЕсли ИмяФормы = "Справочник.ДоговорыКонтрагентов.Форма.ФормаСпискаПродажи" Тогда
			НастройкаФормыСпискаПродажиДоговорыКонтрагентов(Форма);

		ИначеЕсли ИмяФормы = "Справочник.ЗоныДоставки.Форма.ФормаЭлемента" Тогда
			НастройкаФормыЗоныДоставки(Форма);

		ИначеЕсли ИмяФормы = "Справочник.Контрагенты.Форма.ФормаЭлемента" Тогда
			НастройкаФормаЭлементаКонтрагенты(Форма);

		ИначеЕсли ИмяФормы = "Справочник.Контрагенты.Форма.ФормаВыбора" Тогда
			НастройкаФормаВыбораКонтрагенты(Форма);

		ИначеЕсли ИмяФормы = "Справочник.Контрагенты.Форма.ФормаСпискаПараметрическая" Тогда
			НастройкаФормаСпискаПараметрическаяКонтрагенты(Форма);

		ИначеЕсли ИмяФормы = "Справочник.НаборыУпаковок.Форма.ФормаВыбора" Тогда
			Форма.ТолькоПросмотр = Не AMS_ВызовСервера.ЭтоKhors();
		
		ИначеЕсли ИмяФормы = "Справочник.НаборыУпаковок.Форма.ФормаЭлемента" Тогда
			Форма.ТолькоПросмотр = Не (AMS_ВызовСервера.ЭтоKhors() Или Пользователи.РолиДоступны("AMS_БухгалтерПроизводства"));
		
		ИначеЕсли ИмяФормы = "Справочник.Номенклатура.Форма.ФормаЭлемента" Тогда
			НастройкаФормаЭлементаНоменклатура(Форма);
			УправлениеФормаЭлементаНоменклатура(Форма);
		
		ИначеЕсли ИмяФормы = "Справочник.Организации.Форма.ФормаЭлемента" Тогда
			НастройкаФормаЭлементаОрганизации(Форма);

		ИначеЕсли ИмяФормы = "Справочник.Партнеры.Форма.ФормаЭлемента" Тогда
			НастройкаФормаЭлементаПартнеры(Форма);
			УправлениеФормаЭлементаПартнеры(Форма);

		ИначеЕсли ИмяФормы = "Справочник.Партнеры.Форма.ФормаСписка" Тогда
			НастройкаФормаСпискаПартнеры(Форма);

		ИначеЕсли ИмяФормы = "Справочник.СоглашенияСКлиентами.Форма.ФормаЭлемента" Тогда
			НастройкаФормаЭлементаСоглашенияСКлиентами(Форма);

		ИначеЕсли ИмяФормы = "Справочник.ТранспортныеСредства.Форма.ФормаЭлемента" Тогда
			НастройкаФормаЭлементаТранспортныеСредства(Форма);

		ИначеЕсли ИмяФормы = "Справочник.ТранспортныеСредства.Форма.ФормаСписка" Тогда
			НастройкаФормаСпискаТранспортныеСредства(Форма);

		ИначеЕсли ИмяФормы = "Справочник.УпаковкиЕдиницыИзмерения.Форма.ФормаСпискаУпаковок" Тогда
//			Форма.ТолькоПросмотр = Не AMS_ВызовСервера.ЭтоKhors();
		
		ИначеЕсли ИмяФормы = "Справочник.УпаковкиЕдиницыИзмерения.Форма.РазблокированиеРеквизитовЕдиницыИзмерения" Тогда
//			Форма.ТолькоПросмотр = Не AMS_ВызовСервера.ЭтоKhors();
		КонецЕсли;
	
	ИначеЕсли ЛеваяЧастьИмя = "Документ" Тогда
		Если ИмяФормы = "Документ.ВнутреннееПотребление.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаВнутреннееПотребление(Форма);
			
		ИначеЕсли ИмяФормы = "Документ.ЗаказКлиента.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокумента_ЗаказКлиента_ОтгрузкаТоваров_РеализацияТоваров(Форма, "ЗаказКлиента");
			УправлениеФормойЗаказКлиента(Форма);
			
			ОбеспечениеВДокументахСервер.ОбновитьКолонкуДоступно(Форма);

		ИначеЕсли ИмяФормы = "Документ.ЗаказПоставщику.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаЗаказПоставщику(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.ЗаказНаПеремещение.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаЗаказНаПеремещение(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.ЗаявкаНаВозвратТоваровОтКлиента.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаЗаявкаНаВозвратТоваровОтКлиента(Форма);

		ИначеЕсли ИмяФормы = "Документ.КорректировкаРеализации.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаКорректировкаРеализации(Форма);

		ИначеЕсли ИмяФормы = "Документ.КорректировкаРеализации.Форма.ФормаСписка" Тогда
			НастройкаФормаСпискаКорректировкаРеализации(Форма);

		ИначеЕсли ИмяФормы = "Документ.ОприходованиеИзлишковТоваров.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаОприходованиеИзлишковТоваров(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.ОрдерНаОтражениеИзлишковТоваров.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаОрдерНаОтражениеИзлишковТоваров(Форма);

		ИначеЕсли ИмяФормы = "Документ.ОрдерНаОтражениеНедостачТоваров.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаОрдерНаОтражениеНедостачТоваров(Форма);

		ИначеЕсли ИмяФормы = "Документ.ОтгрузкаТоваровКлиенту.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокумента_ЗаказКлиента_ОтгрузкаТоваров_РеализацияТоваров(Форма, "ОтгрузкаТоваровКлиенту");
		
		ИначеЕсли ИмяФормы = "Документ.ОтчетКомиссионера.Форма.ФормаДокумента" Тогда
			СформироватьДокументаОтчетКомиссионера(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.ОтчетОСписанииТоваровУХранителя.Форма.ФормаДокумента" Тогда
			СформироватьДокументаОтчетОСписанииТоваровУХранителя(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.ПередачаТоваровМеждуОрганизациями.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаПередачаТоваровМеждуОрганизациями(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.ПередачаТоваровХранителю.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаПередачаТоваровХранителю(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.ПеремещениеТоваров.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаПеремещениеТоваров(Форма);

		ИначеЕсли ИмяФормы = "Документ.ПересчетТоваров.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаПересчетТоваров(Форма);

		ИначеЕсли ИмяФормы = "Документ.ПриобретениеТоваровУслуг.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаПриобретениеТоваровУслуг(Форма);

		ИначеЕсли ИмяФормы = "Документ.ПрочееОприходованиеТоваров.Форма.ФормаДокумента" Тогда
			НастройкаФормыДокументаПрочееОприходованиеТоваров(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.РасходныйОрдерНаТовары.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаРасходныйОрдерНаТовары(Форма);

		ИначеЕсли ИмяФормы = "Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокумента_ЗаказКлиента_ОтгрузкаТоваров_РеализацияТоваров(Форма, "РеализацияТоваровУслуг");
						
		ИначеЕсли ИмяФормы = "Документ.СборкаТоваров.Форма.ФормаДокумента" Тогда
			НастройкаФормыДокументаСборкаТоваров(Форма);
		
		ИначеЕсли ИмяФормы = "Документ.СписаниеНедостачТоваров.Форма.ФормаДокумента" Тогда
			НастройкаФормаДокументаСписаниеНедостачТоваров(Форма);
		КонецЕсли;	
	
	ИначеЕсли ЛеваяЧастьИмя = "Обработка" Тогда
		Если ИмяФормы = "Обработка.РабочееМестоМенеджераПоДоставке.Форма.ФормаВыбораТранспорта" Тогда
			НастройкаФормаОбработкаРабочееМестоМенеджераПоДоставкеФормаВыбораТранспорта(Форма);
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область НастройкаФормыСправочники

Процедура НастройкаФормыДоговорыКонтрагентов(Форма) 
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;

	Элементы.Номер.УстановитьДействие("ПриИзменении", "Подключаемый_амсПриИзменении_Номер");
	Элементы.Дата.УстановитьДействие("ПриИзменении", "Подключаемый_амсПриИзменении_Дата");

	Если AMS_ВызовСервера.ЭтоKhors() Тогда
		Возврат;
	КонецЕсли; 

	Элементы.Статус.Доступность = Ложь;

	Если Пользователи.РолиДоступны("_Юрист") Тогда
		Возврат;
	КонецЕсли; 

	Форма.КоманднаяПанель.ПодчиненныеЭлементы[10].Видимость = Ложь; // Меню: Все действия - Разрешить редактирование реквизитов

	НеСогласован = Объект.Статус = Перечисления.СтатусыДоговоровКонтрагентов.НеСогласован;

	Элементы.ГруппаШапкаДоговора.Доступность        = НеСогласован;
	Элементы.ГруппаОрганизация.Доступность          = НеСогласован;
	Элементы.Партнер.Доступность                    = НеСогласован;
	Элементы.Контрагент.Доступность                 = НеСогласован;
	Элементы.ИдентификаторГосКонтракта.Доступность  = НеСогласован;

	Элементы.СтраницаРасчетыИОформление.ТолькоПросмотр = Не НеСогласован;
	Элементы.СтраницаУчетнаяИнформация.ТолькоПросмотр  = Не НеСогласован;
КонецПроцедуры

Процедура НастройкаФормыСпискаДоговорыКонтрагентов(Форма) 
	Элементы = Форма.Элементы;
	Элементы.ГруппаУстановитьСтатус.Видимость = Ложь;
КонецПроцедуры

Процедура НастройкаФормыСпискаЗакупкиДоговорыКонтрагентов(Форма) 
	Элементы = Форма.Элементы;
	Элементы.ГруппаУстановитьСтатус.Видимость = Ложь;
КонецПроцедуры

Процедура НастройкаФормыСпискаПродажиДоговорыКонтрагентов(Форма) 
	Элементы = Форма.Элементы;
	Элементы.ГруппаУстановитьСтатус.Видимость = Ложь;
КонецПроцедуры

Процедура НастройкаФормыЗоныДоставки(Форма)
	Элементы = Форма.Элементы;

	Группа  = Элементы.Добавить("_ГруппаАМС", Тип("ГруппаФормы"));
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительные информация";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("_Статус", Тип("ПолеФормы"), Элементы._ГруппаАМС);
	Элемент.ПутьКДанным = "Объект._Км";
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Расстояние";
КонецПроцедуры

Процедура НастройкаФормаЭлементаКонтрагенты(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;

	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;

	Группа  = Элементы.Добавить("AMS_ГруппаАМС", Тип("ГруппаФормы"), Элементы.СтраницаОсновное);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительные реквизиты";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Элемент = Элементы.Добавить("AMS_ЧЗ_МаслоСмазочное", Тип("ПолеФормы"), Элементы.AMS_ГруппаАМС);
	Элемент.Вид                = ВидПоляФормы.ПолеФлажка;
	Элемент.Заголовок          = "Честный знак (Масло смазочное)";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	Элемент.ПутьКДанным = "Объект.AMS_ЧЗ_МаслоСмазочное";

	Элемент = Элементы.Добавить("AMS_ЧЗ_БытоваяХимия", Тип("ПолеФормы"), Элементы.AMS_ГруппаАМС);
	Элемент.Вид                = ВидПоляФормы.ПолеФлажка;
	Элемент.Заголовок          = "Честный знак (Бытовая химия)";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	Элемент.ПутьКДанным        = "Объект.AMS_ЧЗ_БытоваяХимия";

	Элемент = Элементы.Добавить("AMS_Закрыт", Тип("ПолеФормы"), Элементы.AMS_ГруппаАМС);
	Элемент.Вид                = ВидПоляФормы.ПолеФлажка;
	Элемент.Заголовок          = "Контрагент закрыт";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	Элемент.ПутьКДанным        = "Объект._Закрыт";

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Контрагент", Объект.Ссылка);
	Запрос.УстановитьПараметр("Партнер", Объект.Партнер);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.Ссылка КАК Ссылка,
	|	т.Статус КАК Статус
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК т
	|ГДЕ
	|	т.Партнер = &Партнер
	|	И т.Контрагент = &Контрагент
	|	И т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Действует)";
	
	Если Не Запрос.Выполнить().Пустой() И Не (Пользователи.РолиДоступны("_ГлавныйБухгалтер,_Юрист")) Тогда
		Форма.ТолькоПросмотр = Истина;

		Элементы.ПереходКИсторииКПП.Видимость                               = Ложь;
		Элементы.ПереходКИсторииНаименования.Видимость                      = Ложь;
		Элементы.ЗаполнитьПоНаименованиюПоДаннымЕдиныхГосРеестров.Видимость = Ложь;
		Элементы.ГруппаКонтактнаяИнформацияПолеd4a42634x1e3bx4184xb364x51ec78c918a51.Доступность = Ложь; // Юр. адрес
	КонецЕсли;
КонецПроцедуры

Процедура НастройкаФормаВыбораКонтрагенты(Форма)
	Элементы = Форма.Элементы;

	Элемент = Элементы.Добавить("ДополнительнаяИнформация", Тип("ПолеФормы"), Элементы.Список);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Список.ДополнительнаяИнформация";

	Элемент = Элементы.Добавить("КонтрагентЗакрыт", Тип("ПолеФормы"), Элементы.Список);
	Элемент.Вид         = ВидПоляФормы.ПолеФлажка;
	Элемент.ПутьКДанным = "Список.КонтрагентЗакрыт";
КонецПроцедуры

Процедура НастройкаФормаСпискаПараметрическаяКонтрагенты(Форма)
	Элементы = Форма.Элементы;

	Элемент = Элементы.Добавить("ДополнительнаяИнформация", Тип("ПолеФормы"), Элементы.Список);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Список.ДополнительнаяИнформация";

	Элемент = Элементы.Добавить("КонтрагентЗакрыт", Тип("ПолеФормы"), Элементы.Список);
	Элемент.Вид         = ВидПоляФормы.ПолеФлажка;
	Элемент.ПутьКДанным = "Список.КонтрагентЗакрыт";
КонецПроцедуры

Процедура НастройкаФормаЭлементаНоменклатура(Форма)
	Элементы = Форма.Элементы;

	Группа  = Элементы.Добавить("AMS_ГруппаАМС", Тип("ГруппаФормы"), Элементы.ГруппаРеквизиты);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительные реквизиты";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Элемент = Элементы.Добавить("AMS_СтатьяРасходов", Тип("ПолеФормы"), Элементы.AMS_ГруппаАМС);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Статья расходов";
	Элемент.ПутьКДанным = "Объект._СтатьяРасходов";

	Элемент = Элементы.Добавить("AMS_Упаковка", Тип("ПолеФормы"), Элементы.AMS_ГруппаАМС);
	Элемент.Вид                      = ВидПоляФормы.ПолеВвода;
	Элемент.Ширина		             = 10;
	Элемент.РастягиватьПоГоризонтали = Ложь;
	Элемент.РежимВыбораИзСписка      = Истина;
	Элемент.Заголовок                = "Упаковка";
	Элемент.ПутьКДанным              = "Объект._Упаковка";

	Элемент = Элементы.Добавить("AMS_ИспользуетФабрикат", Тип("ПолеФормы"), Элементы.AMS_ГруппаАМС);
	Элемент.Вид         = ВидПоляФормы.ПолеФлажка;
	Элемент.ПутьКДанным = "Объект._ИспользуетФабрикат";
	Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_AMS_ПриИзменении_ИспользуетФабрикат");

	Группа  = Элементы.Добавить("AMS_ГруппаФабрикат", Тип("ГруппаФормы"), Элементы.AMS_ГруппаАМС);
	Группа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Отображение         = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("AMS_Фабрикат", Тип("ПолеФормы"), Элементы.AMS_ГруппаФабрикат);
	Элемент.Вид                = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным        = "Объект._Фабрикат";

	Элемент = Элементы.Добавить("AMS_КоличествоФабрикатаВУпаковке", Тип("ПолеФормы"), Элементы.AMS_ГруппаФабрикат);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._КоличествоФабрикатаВУпаковке";
КонецПроцедуры

Процедура УправлениеФормаЭлементаНоменклатура(Форма) Экспорт
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	Если Объект.НаборУпаковок = Справочники.НаборыУпаковок.ИндивидуальныйДляНоменклатуры Тогда
		НаборУпаковокВладелец = Объект.Ссылка;
	Иначе
		НаборУпаковокВладелец = Объект.НаборУпаковок;
	КонецЕсли;
	
	Табл = AMS_Сервер.ПолучитьУпаковкиПродукции(НаборУпаковокВладелец);
	
	Элементы.AMS_Упаковка.СписокВыбора.ЗагрузитьЗначения(Табл.ВыгрузитьКолонку("Упаковка"));

	ЭтоПродукцияAMS = AMS_ВызовСервера.ЭтоПродукцияAMS(Объект);
	ЭтоУслуга    = Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга;
	ИмМожно      = Пользователи.РолиДоступны("ДобавлениеИзменениеНоменклатуры");

	Форма.ТолькоПросмотр = Не ИмМожно;

	Элементы.AMS_ГруппаАМС.Видимость = ИмМожно;
	
	Элементы.ИспользоватьУпаковки.Доступность    = ИмМожно;
	Элементы.НаборУпаковок.Доступность           = ИмМожно;
	Элементы.ЕдиницаИзмерения.Доступность        = ИмМожно;
	Элементы.ГруппаЕдиницаДляОтчетов.Доступность = ИмМожно;

	Элементы.AMS_СтатьяРасходов.Видимость  = ЭтоУслуга;
	Элементы.AMS_Упаковка.Видимость        = Не ЭтоУслуга;
	
	Элементы.AMS_ИспользуетФабрикат.Видимость = ЭтоПродукцияAMS;

	Элементы.AMS_Фабрикат.Видимость                     = Объект._ИспользуетФабрикат;
	Элементы.AMS_КоличествоФабрикатаВУпаковке.Видимость = Объект._ИспользуетФабрикат;
КонецПроцедуры

Процедура НастройкаФормаЭлементаОрганизации(Форма)
	Элементы = Форма.Элементы;

	Если AMS_ВызовСервера.ЭтоKhors() Или Пользователи.РолиДоступны("_ГлавныйБухгалтер") Тогда
		Группа  = Элементы.Добавить("_ГруппаАМС", Тип("ГруппаФормы"), Элементы.ГруппаОбщаяИнформация);
		Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок   = "Дополнительные реквизиты";
		Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		
		//
		Группа  = Элементы.Добавить("_ГруппаАМС1", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
		Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок   = "Должность";
		Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

		Элемент = Элементы.Добавить("_ДолжностьРуководителя", Тип("ПолеФормы"), Элементы._ГруппаАМС1);
		Элемент.Вид         = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок   = "Руководителя";
		Элемент.ПутьКДанным = "Объект._ДолжностьРуководителя";

		Массив = Новый Массив;
		Массив.Добавить(Тип("Строка"));
		ПараметрыСтроки = Новый КвалификаторыСтроки(20);
		ТипСтрока = Новый ОписаниеТипов(Массив, , , , ПараметрыСтроки);
		Реквизит = Новый РеквизитФормы("_ДолжностьГлавБуха", ТипСтрока, , "Должность главного бухгалтера");

		ДобавляемыеРеквизиты = Новый Массив;
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
		Форма._ДолжностьГлавБуха = "Главный бухгалтер";

		Элемент = Элементы.Добавить("_ДолжностьГлавБуха", Тип("ПолеФормы"), Элементы._ГруппаАМС1);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Главного бухгалтера";
		Элемент.ПутьКДанным    = "_ДолжностьГлавБуха";
		Элемент.Доступность    = Ложь;

		Элемент = Элементы.Добавить("_ДолжностьКладовщика", Тип("ПолеФормы"), Элементы._ГруппаАМС1);
		Элемент.Вид         = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок   = "Кладовщика";
		Элемент.ПутьКДанным = "Объект._ДолжностьКладовщика";
		
		//
		Группа  = Элементы.Добавить("_ГруппаАМС2", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
		Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок   = "ФИО";
		Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

		Элемент = Элементы.Добавить("_Руководитель", Тип("ПолеФормы"), Элементы._ГруппаАМС2);
		Элемент.Вид                = ВидПоляФормы.ПолеВвода;
		Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
		Элемент.ПутьКДанным        = "Объект._Руководитель";

		Элемент = Элементы.Добавить("_ГлавныйБухгалтер", Тип("ПолеФормы"), Элементы._ГруппаАМС2);
		Элемент.Вид = ВидПоляФормы.ПолеВвода;
		Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
		Элемент.ПутьКДанным = "Объект._ГлавныйБухгалтер";

		Элемент = Элементы.Добавить("_Кладовщик", Тип("ПолеФормы"), Элементы._ГруппаАМС2);
		Элемент.Вид                = ВидПоляФормы.ПолеВвода;
		Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
		Элемент.ПутьКДанным        = "Объект._Кладовщик";
	КонецЕсли;
КонецПроцедуры

Процедура НастройкаФормаЭлементаПартнеры(Форма)
	Элементы = Форма.Элементы;

	Группа  = Элементы.Добавить("_ГруппаАМС", Тип("ГруппаФормы"), Элементы.ГруппаОбщаяИнформация);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительные реквизиты";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Группа  = Элементы.Добавить("_ГруппаЛимит", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Отображение         = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("_Закрыт", Тип("ПолеФормы"), Элементы._ГруппаЛимит);
	Элемент.Вид                = ВидПоляФормы.ПолеФлажка;
	Элемент.Заголовок          = "Партнёр закрыт";
	Элемент.ПутьКДанным        = "Объект._Закрыт";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;

	Элемент = Элементы.Добавить("_Стикерование", Тип("ПолеФормы"), Элементы._ГруппаЛимит);
	Элемент.Вид                = ВидПоляФормы.ПолеФлажка;
	Элемент.Заголовок          = "Стикеровать товар";
	Элемент.ПутьКДанным        = "Объект._Стикерование";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;

	Элемент = Элементы.Добавить("AMS_Лимит", Тип("ПолеФормы"), Элементы._ГруппаЛимит);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Лимит кредита";
	Элемент.ПутьКДанным = "Объект.AMS_Лимит";

	Элемент = Элементы.Добавить("AMS_СегментРынка", Тип("ПолеФормы"), Элементы._ГруппаЛимит);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Ширина      = 20;
	Элемент.Заголовок   = "Сегмент рынка";
	Элемент.ПутьКДанным = "Объект.AMS_СегментРынка";

	Группа  = Элементы.Добавить("_ГруппаТУ", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Транпортная услуга";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Элемент = Элементы.Добавить("_ТранпортнаяУслуга", Тип("ПолеФормы"), Элементы._ГруппаТУ);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Наименование транпортной услуги";
	Элемент.ПутьКДанным = "Объект._ТранпортнаяУслуга";

	Группа  = Элементы.Добавить("_ГруппаТУ1", Тип("ГруппаФормы"), Элементы._ГруппаТУ);
	Группа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Отображение         = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("_ТранпортнаяУслугаСпособ", Тип("ПолеФормы"), Элементы._ГруппаТУ1);
	Элемент.ПутьКДанным = "Объект._ТранпортнаяУслугаСпособ";
	Элемент.Вид         = ВидПоляФормы.ПолеПереключателя;
	Элемент.Заголовок   = "Способ начисления транспортой услуги";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	Элемент.СписокВыбора.Добавить(0, "Процент от суммы накладной");
	Элемент.СписокВыбора.Добавить(1, "Фиксированная сумма");
	Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_амсПриИзмененииТранпортнаяУслугаСпособ");

	Элемент = Элементы.Добавить("_ТранпортнаяУслугаПроцент", Тип("ПолеФормы"), Элементы._ГруппаТУ1);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Процент, %";
	Элемент.ПутьКДанным = "Объект._ТранпортнаяУслугаПроцент";

	Элемент = Элементы.Добавить("_ТранпортнаяУслугаСумма", Тип("ПолеФормы"), Элементы._ГруппаТУ1);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Сумма без НДС, руб.";
	Элемент.ПутьКДанным = "Объект._ТранпортнаяУслугаСумма";

	Группа  = Элементы.Добавить("_ГруппаПарамПечати", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Параметры печати";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Группа  = Элементы.Добавить("_ГруппаПарамПечати1", Тип("ГруппаФормы"), Элементы._ГруппаПарамПечати);
	Группа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Отображение         = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Элемент = Элементы.Добавить("_АртикулКлиента", Тип("ПолеФормы"), Элементы._ГруппаПарамПечати1);
	Элемент.Вид         = ВидПоляФормы.ПолеФлажка;
	Элемент.Заголовок   = "Артикул клиента";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	Элемент.ПутьКДанным = "Объект._АртикулКлиента";
	Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_амсПриИзмененииАртикулКлиента");

	Элемент = Элементы.Добавить("_АртикулКлиентаПлюс", Тип("ПолеФормы"), Элементы._ГруппаПарамПечати1);
	Элемент.Вид         = ВидПоляФормы.ПолеФлажка;
	Элемент.Заголовок   = "Артикул клиента и организации";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	Элемент.ПутьКДанным = "Объект._АртикулКлиентаПлюс";
