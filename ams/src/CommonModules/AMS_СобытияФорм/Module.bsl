#Область УправлениеФормойДокументов

Процедура УправлениеРеквизитамиДоставкиAMS(Форма, ТипДокумента) Экспорт
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	НашАвто = Истина;
	Если ТипДокумента = "ЗаказПоставщику" Тогда
		НашАвто = Объект.СпособДоставки = Перечисления.СпособыДоставки.НашимиСиламиСАдресаОтправителя;
	Иначе
		НашАвто = Не Объект.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз; 
	КонецЕсли;
	
	ВключенВЛогитическийЛист =  AMS_ВызовСервера.ВключенВЛогитическийЛист(Объект.Ссылка);
	
	Элементы.ПеревозчикПартнер.КнопкаОткрытия = Истина;
	
	Элементы.ГруппаСпособДоставкиПеревозчик.ТолькоПросмотр = ВключенВЛогитическийЛист;

	Если ТипДокумента = "ЗаказПоставщику" Тогда
		Элементы.ГруппаАдрес.ТолькоПросмотр     = ВключенВЛогитическийЛист;
	
	Иначе	
		Элементы.АдресДоставкиПолучателя.ТолькоПросмотр  = ВключенВЛогитическийЛист;
		Элементы.ГруппаЗонаВремя.ТолькоПросмотр          = ВключенВЛогитическийЛист;
		Элементы.АдресДоставкиПеревозчика.ТолькоПросмотр = ВключенВЛогитическийЛист;
		Элементы.ГруппаЗонаВремя1.ТолькоПросмотр         = ВключенВЛогитическийЛист;
		Элементы.АдресДоставкиПолучателя2.ТолькоПросмотр = ВключенВЛогитическийЛист;
	    
	    Если Не (ТипДокумента = "ЗаявкаНаВозвратТоваровОтКлиента" Или ТипДокумента = "ПередачаТоваровХранителю") Тогда
			Элементы.АдресДоставкиПолучателя3.ТолькоПросмотр = ВключенВЛогитическийЛист;
	    КонецЕсли;
			
	    Если Не ТипДокумента = "ЗаявкаНаВозвратТоваровОтКлиента" Тогда
			ДоПеревозчика = Объект.СпособДоставки = Перечисления.СпособыДоставки.СиламиПеревозчикаПоАдресу;
			Перегрузка    = Объект.СпособДоставки = Перечисления.СпособыДоставки.КПолучателюОпределяетСлужбаДоставки;
			
			Элементы.AMS_ГруппаДоПеревозчика.Видимость = ДоПеревозчика;
			Элементы.AMS_ГруппаПерегрузка.Видимость    = Перегрузка;
	    КонецЕсли;
	КонецЕсли;
		
	Элементы.ГруппаЗонаВремя.ТолькоПросмотр = ВключенВЛогитическийЛист;
	
	Элементы.AMS_ТранспортноеСредство.Видимость = НашАвто;
	Элементы.AMS_Водитель.Видимость             = НашАвто;
	Элементы.AMS_ТелефонВодителя.Видимость      = НашАвто;
КонецПроцедуры

Процедура УправлениеФормойЗаказКлиента(Форма) Экспорт
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	Элементы.Номер.ТолькоПросмотр = Не AMS_ВызовСервера.ЭтоKhors();
	Элементы.Дата.ТолькоПросмотр  = Не AMS_ВызовСервера.ЭтоKhors();
	
	Стр = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Партнер, "_ТранпортнаяУслуга, _ТранпортнаяУслугаПроцент, _ТранпортнаяУслугаСумма");

	Элементы.AMS_ТранспортныеУслуги.Доступность = (ЗначениеЗаполнено(Стр._ТранпортнаяУслуга) И (Стр._ТранпортнаяУслугаПроцент > 0 Или Стр._ТранпортнаяУслугаСумма > 0));

	Если ЗначениеЗаполнено(Объект.Партнер) Тогда
		Форма.AMS_ПартнерДопИнфо = Объект.Партнер.ДополнительнаяИнформация;
	Иначе
		Форма.AMS_ПартнерДопИнфо = "";
	КонецЕсли;

	// Контроль фиксированной суммы договора
	//@skip-check bsl-legacy-check-string-literal
	СуммаДоговора  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "Сумма");
	Если Не СуммаДоговора = Неопределено И СуммаДоговора > 0  Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Договор", Объект.Договор);
		Запрос.УстановитьПараметр("ТекущийДокумент", Объект.Ссылка);
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(д.СуммаДокумента) КАК СуммаИсполнено
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК д
		|ГДЕ
		|	д.Договор = &Договор
		|	И НЕ д.Ссылка = &ТекущийДокумент
		|
		|СГРУППИРОВАТЬ ПО
		|	д.Договор";
	
		СуммаИсполнено = 0;
		Рез = Запрос.Выполнить();
		Если Не Рез.Пустой() Тогда
			Выб = Рез.Выбрать(); Выб.Следующий();
			СуммаИсполнено = Выб.СуммаИсполнено;
		КонецЕсли;

		Остаток = СуммаДоговора - СуммаИсполнено - Объект.СуммаДокумента;

		Форма.AMS_ИнфоСуммаКонтракта = "Сумма контракта: " + СуммаДоговора + ". Исполнено: " + СуммаИсполнено
			+ ". Сумма документа: " + Объект.СуммаДокумента + ". Остаток: " + Остаток + " руб.";

		Элементы.AMS_ИнфоСуммаКонтракта.Видимость = Истина;

		Если Остаток < 0 Тогда
			Элементы.AMS_ИнфоСуммаКонтракта.ЦветТекста = ЦветаСтиля.ЦветОтрицательногоЧисла;
		Иначе
			Элементы.AMS_ИнфоСуммаКонтракта.ЦветТекста = ЦветаСтиля.ЦветТекстаПоля;
		КонецЕсли;
	
	Иначе
		Элементы.AMS_ИнфоСуммаКонтракта.Видимость = Ложь;
	КонецЕсли;
	// Контроль фиксированной суммы договора
	
	УправлениеРеквизитамиДоставкиAMS(Форма, "ЗаказКлиента")
КонецПроцедуры

Процедура УправлениеФормойРеализацияТоваровУслуг(Форма) Экспорт
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	Элементы.Номер.Доступность = AMS_ВызовСервера.ЭтоKhors();
	
	// Закрыть изменение даты
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжение", Объект.Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары КАК д
	|		ПО т.Ссылка = д.Ссылка
	|ГДЕ
	|	т.Распоряжение = &Распоряжение
	|	И НЕ д.ПометкаУдаления";
	ЕстьРасходныйОрдерНаТовары = Не Запрос.Выполнить().Пустой();
	Если ЕстьРасходныйОрдерНаТовары
		И Не (AMS_ВызовСервера.ЭтоKhors() Или AMS_ВызовСервера.ЭтоГлавбух()) Тогда
		Элементы.Дата.Доступность = Ложь;
	КонецЕсли;
	// Закрыть изменение даты

	Если ЗначениеЗаполнено(Объект.Партнер) Тогда
		Форма.AMS_ПартнерДопИнфо = Объект.Партнер.ДополнительнаяИнформация;
	Иначе
		Форма.AMS_ПартнерДопИнфо = "";
	КонецЕсли;
	
	Если Объект.РеализацияПоЗаказам Тогда //Закрыть всё, кроме проведения
		Элементы.ГруппаСтатус.ТолькоПросмотр        = Истина;
		Элементы.ГруппаОсновное.ТолькоПросмотр      = Истина;
		Элементы.ГруппаТовары.ТолькоПросмотр        = Истина;
		Элементы.СтраницаДоставка.ТолькоПросмотр    = Истина;
		Элементы.ГруппаДополнительно.ТолькоПросмотр = Истина;
		
		Элементы.Товары.КоманднаяПанель.Видимость = Ложь;
		Элементы.ГруппаЦеныСкидки.Видимость       = Ложь;
		Элементы.AMS_ГруппаКнопки.Видимость       = Ложь;
		
		Возврат;
	КонецЕсли;
	
	Бухгалтер  = Пользователи.РолиДоступны("_ГлавныйБухгалтер, _Бухгалтер");
	Менеджер   = Пользователи.РолиДоступны("_СтаршийМенеджер, AMS_МенеджерПродаж, _БухгалтерСклада, AMS_Аналитик");
	ЕстьПечать = AMS_ВызовСервера.ЕстьОперацияПечатьПоследняя(Объект.Ссылка);

	БухСклада   = Пользователи.РолиДоступны("_БухгалтерСклада");
	РолиСклада  = Пользователи.РолиДоступны("_НачальникСклада,_КладовщикСклада");
	ЭтоЗаказ    = Объект.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.Заказ 
				  Или Объект.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.Стикерование 
				  Или Объект.AMS_СтатусРеализации = Перечисления.AMS_СтатусыРеализаций.КОтгрузке;
				
	Форма.ТолькоПросмотр = Не (Бухгалтер Или Менеджер);

	ШапкаРазрешить = Бухгалтер Или (Менеджер И ЭтоЗаказ И Не ЕстьПечать);
	Элементы.ГруппаСтатус.Доступность          = ШапкаРазрешить;
	Элементы.ГруппаШапка.ТолькоПросмотр        = Не ШапкаРазрешить;
	Элементы.AMS_ПравилоПродажи.ТолькоПросмотр = Не ШапкаРазрешить;
	Элементы.ГруппаПараметры.Доступность       = ШапкаРазрешить;
	Элементы.ГруппаПечать.Доступность          = ШапкаРазрешить;

	Элементы.AMS_ЭДО.Доступность                    = Бухгалтер;
	Элементы.ГруппаТребуетсяЗалогЗаТару.Доступность = Бухгалтер;
	
	Если Бухгалтер Тогда
		ТоварыРазрешить = Истина;
	ИначеЕсли ЕстьПечать Тогда
		ТоварыРазрешить = Ложь;
	ИначеЕсли Менеджер И ЭтоЗаказ Тогда
		ТоварыРазрешить = Истина;
	Иначе
		ТоварыРазрешить = Ложь;
	КонецЕсли;

	Элементы.Товары.ТолькоПросмотр            = Не ТоварыРазрешить;
	Элементы.Товары.КоманднаяПанель.Видимость = ТоварыРазрешить;
	Элементы.ГруппаЦеныСкидки.Видимость       = ТоварыРазрешить;
	Элементы.AMS_ГруппаКнопки.Видимость       = ТоварыРазрешить;

	Элементы.AMS_УтвержденаОтгрузка.Доступность = Не ЕстьПечать;
	Элементы.AMS_ИнфоЗапретИзменений.Видимость  = ЕстьПечать;

	Если Не Бухгалтер Тогда
		Элементы.Товары.ТолькоПросмотр = Истина;

		Элементы.Товары.КонтекстноеМеню.Видимость                 = Ложь;
		Элементы.ТоварыДобавить.Видимость                         = Ложь;
		Элементы.ТоварыСкопировать.Видимость                      = Ложь;
		Элементы.ТоварыИзменить.Видимость                         = Ложь;
		Элементы.ТоварыУдалить.Видимость                          = Ложь;
		Элементы.ТоварыПереместить.Видимость                      = Ложь;
		Элементы.ТоварыСкопироватьСтроки.Видимость                = Ложь;
		Элементы.ТоварыВставитьСтроки.Видимость                   = Ложь;
		Элементы.ТоварыРазбитьСтроку.Видимость                    = Ложь;
		Элементы.ТоварыСоставНабора.Видимость                     = Ложь;
		Элементы.ГруппаТоварыПодобратьТовары.Видимость            = Ложь;
		Элементы.ТоварыЗаполнитьСкладВВыделенныхСтроках.Видимость = Ложь;
		Элементы.ТоварыВыделитьВсе.Видимость                      = Ложь;

		Элементы._Печать.Видимость                = Не РолиСклада;
		Элементы.Товары.КоманднаяПанель.Видимость = Не (РолиСклада Или БухСклада);
	КонецЕсли;
	
	УправлениеРеквизитамиДоставкиAMS(Форма, "РеализацияТоваровУслуг");

	#Область КонтрольФиксированнойСуммыДоговора
	
	//@skip-check bsl-legacy-check-string-literal
	СуммаДоговора  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "Сумма");
	Если Не СуммаДоговора = Неопределено И СуммаДоговора > 0  Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Договор", Объект.Договор);
		Запрос.УстановитьПараметр("ТекущийДокумент", Объект.Ссылка);
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(д.СуммаДокумента) КАК СуммаИсполнено
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК д
		|ГДЕ
		|	д.Договор = &Договор
		|	И НЕ д.Ссылка = &ТекущийДокумент
		|
		|СГРУППИРОВАТЬ ПО
		|	д.Договор";
	
		СуммаИсполнено = 0;
		Рез = Запрос.Выполнить();
		Если Не Рез.Пустой() Тогда
			Выб = Рез.Выбрать(); Выб.Следующий();
			СуммаИсполнено = Выб.СуммаИсполнено;
		КонецЕсли;

		Остаток = СуммаДоговора - СуммаИсполнено - Объект.СуммаДокумента;

		Форма.AMS_ИнфоСуммаКонтракта = "Сумма контракта: " + СуммаДоговора + ". Исполнено: " + СуммаИсполнено
			+ ". Сумма документа: " + Объект.СуммаДокумента + ". Остаток: " + Остаток + " руб.";

		Элементы.AMS_ИнфоСуммаКонтракта.Видимость = Истина;

		Если Остаток < 0 Тогда
			Элементы.AMS_ИнфоСуммаКонтракта.ЦветТекста = ЦветаСтиля.ЦветОтрицательногоЧисла;
		Иначе
			Элементы.AMS_ИнфоСуммаКонтракта.ЦветТекста = ЦветаСтиля.ЦветТекстаПоля;
		КонецЕсли;
	
		Элементы.AMS_ЭкспортЗУ.Видимость = Истина;
	Иначе
		Элементы.AMS_ЭкспортЗУ.Видимость = Ложь;
		Элементы.AMS_ИнфоСуммаКонтракта.Видимость = Ложь;
	КонецЕсли;
	
	#КонецОбласти // Контроль фиксированной суммы договора

	Таб = Объект.Товары.Выгрузить(, "Номенклатура,Количество");
	Стр = AMS_Сервер.ПолучитьВесОбъемТоваров(Таб, Объект.AMS_СпособПередачиТоваров);
	Элементы.AMS_КоличествоПалет.Заголовок = "Количество палет (" + Формат(Стр.КоличествоПалет, "ЧДЦ=3") + ")";
КонецПроцедуры

#КонецОбласти

#Область ОтчетКомиссионера

Процедура СформироватьДокументаОтчетКомиссионера(Форма)
	Перем Маркетплейс;
	
	Если Не Форма.Параметры.Свойство("Маркетплейс", Маркетплейс) Тогда
		Возврат;
	КонецЕсли;
	
	Комиссионер = Маркетплейс.Комиссионер;
	Данные      = Маркетплейс.Данные;
	
	//@skip-check bsl-legacy-check-string-literal
	Код = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Комиссионер, "Код");

	Объект = Форма.Объект;
	
	Если Код = "01-01002250" Тогда Фирма = "OZON";
	ИначеЕсли Код = "01-01002442" Тогда Фирма = "ДетскийМир"
	ИначеЕсли Код = "01-01002441" Тогда Фирма = "МАГНИТ_МАРКЕТ"
	ИначеЕсли Код = "01-01002247" Тогда Фирма = "WB";
	ИначеЕсли Код = "01-01002322" Тогда Фирма = "Летуаль";
	ИначеЕсли Код = "01-01002235" Тогда Фирма = "ЯндексМаркет"; 
	КонецЕсли;

	Док = Документы.ОтчетКомиссионера.СоздатьДокумент();

	Док.Дата                        = ТекущаяДатаСеанса();
	Док.Организация                 = AMS_ВызовСервера.ОрганизацияТрейд();
	Док.Партнер                     = Комиссионер;
	Док.Валюта                      = Константы.ВалютаРегламентированногоУчета.Получить();
	Док.Менеджер                    = Пользователи.АвторизованныйПользователь();
	Док.НалогообложениеНДС          = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
	Док.ХозяйственнаяОперация       = Перечисления.ХозяйственныеОперации.РеализацияЧерезКомиссионера;
	Док.ПорядокРасчетов             = Перечисления.ПорядокРасчетов.ПоНакладным;
	Док.СпособРасчетаВознаграждения = Перечисления.СпособыРасчетаКомиссионногоВознаграждения.НеРассчитывается;
	
	Если Фирма = "OZON" Тогда
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Маркетплейс", Истина);
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1027739244741");
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Договор № ИР-564449/24 от 11.11.2024 г. (передача на комиссию)", Истина);
	
	ИначеЕсли Фирма = "ДетскийМир" Тогда
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Маркетплейс", Истина);
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1237770205232");
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Договор № Договор-оферта от 11.02.2026 г.", Истина);

	ИначеЕсли Фирма = "МАГНИТ_МАРКЕТ" Тогда
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Маркетплейс", Истина);
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1211600048791");
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Договор № Договор-оферта от 28.01.2026 г.", Истина);

	ИначеЕсли Фирма = "WB" Тогда
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Маркетплейс", Истина);
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1247700471919");
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Договор № S08170158 от 11.11.2024 г.", Истина);

	ИначеЕсли Фирма = "Летуаль" Тогда
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Летуаль", Истина);
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1027739498324");
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Контракт № MPL-005264 от 26.06.2025 г.", Истина);
		
	ИначеЕсли Фирма = "ЯндексМаркет" Тогда
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Маркетплейс Кемикал", Истина);
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1247700776850");
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Договор № 48337928/25 от  09.12.2025 г.", Истина);
	КонецЕсли;
	
	Док.УстановитьНовыйНомер();
	
	Если Фирма = "OZON" Тогда
		ЗагрузитьТоварыОтчетКомиссионера_OZON(Док, Данные);
	Иначе
		ЗагрузитьТоварыОтчетКомиссионера(Док, Данные);
	КонецЕсли;
	
	ЗначениеВДанныеФормы(Док, Объект);
КонецПроцедуры

Процедура ЗагрузитьТоварыОтчетКомиссионера_OZON(Док, Данные)
	Табл = ПолучитьСтруктуруДанныхОтчета();
	
	Для Каждого Элемент Из Данные Цикл
		Стр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Элемент);
	КонецЦикла;
	
	РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Док.Договор, "ВидЦенУчетный, СтавкаНДС");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Табл", Табл);
	Запрос.УстановитьПараметр("ВидЦены", РеквизитыДоговора.ВидЦенУчетный);
	Запрос.УстановитьПараметр("СтавкаНДС", РеквизитыДоговора.СтавкаНДС);
	Запрос.УстановитьПараметр("Ставка", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыДоговора.СтавкаНДС, "Ставка"));
	Запрос.УстановитьПараметр("Дата", Док.Дата);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Табл.НомерСтроки КАК НомерСтроки,
	|	ВЫРАЗИТЬ(Табл.Артикул КАК СТРОКА(20)) КАК Артикул,
	|	Табл.Количество КАК Количество,
	|	Табл.Цена КАК ЦенаПродажи,
	|	Табл.Сумма КАК СуммаПродажи
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Табл КАК Табл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.НомерСтроки КАК НомерСтроки,
	|	Ном.Артикул КАК Артикул,
	|	Ном.Ссылка КАК Номенклатура,
	|	вт.Количество КАК Количество,
	|	вт.ЦенаПродажи КАК ЦенаПродажи,
	|	вт.СуммаПродажи КАК СуммаПродажи
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО вт.Артикул = Ном.Артикул
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	тов.Номенклатура КАК Номенклатура,
	|	Цен.ВидЦены КАК ВидЦены,
	|	Цен.Цена КАК Цена
	|ПОМЕСТИТЬ Цен
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, ВидЦены = &ВидЦены) КАК Цен
	|		ПО тов.Номенклатура = Цен.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.НомерСтроки КАК НомерСтроки,
	|	тов.Артикул КАК Артикул,
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Количество КАК КоличествоУпаковокФакт,
	|	тов.Количество КАК КоличествоУпаковок,
	|	тов.Количество КАК Количество,
	|	Цен.ВидЦены КАК ВидЦены,
	|	ЕСТЬNULL(Цен.Цена, 0) КАК Цена,
	|	тов.Количество * ЕСТЬNULL(Цен.Цена, 0) КАК Сумма,
	|	&СтавкаНДС КАК СтавкаНДС,
	|	&Ставка * тов.Количество * ЕСТЬNULL(Цен.Цена, 0) / 100 КАК СуммаНДС,
	|	(&Ставка + 100) * тов.Количество * ЕСТЬNULL(Цен.Цена, 0) / 100 КАК СуммаСНДС,
	|	тов.СуммаПродажи / тов.Количество КАК ЦенаПродажи,
	|	тов.Количество * ЕСТЬNULL(тов.ЦенаПродажи, 0) / (&Ставка + 100) * &Ставка КАК СуммаПродажиНДС,
	|	тов.СуммаПродажи КАК СуммаПродажи
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Цен КАК Цен
	|		ПО тов.Номенклатура = Цен.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Док.Товары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

Процедура ЗагрузитьТоварыОтчетКомиссионера(Док, Данные)
	Табл = ПолучитьСтруктуруДанныхОтчета();
	
	Для Каждого Элемент Из Данные Цикл
		Стр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Элемент);
	КонецЦикла;
	
	РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Док.Договор, "ВидЦенУчетный, СтавкаНДС");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Табл", Табл);
	Запрос.УстановитьПараметр("ВидЦены", РеквизитыДоговора.ВидЦенУчетный);
	Запрос.УстановитьПараметр("СтавкаНДС", РеквизитыДоговора.СтавкаНДС);
	Запрос.УстановитьПараметр("Ставка", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РеквизитыДоговора.СтавкаНДС, "Ставка"));
	Запрос.УстановитьПараметр("Дата", Док.Дата);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Табл.НомерСтроки КАК НомерСтроки,
	|	ВЫРАЗИТЬ(Табл.Артикул КАК СТРОКА(20)) КАК Артикул,
	|	Табл.Количество КАК Количество,
	|	Табл.Цена КАК ЦенаПродажи
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Табл КАК Табл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.НомерСтроки КАК НомерСтроки,
	|	Ном.Артикул КАК Артикул,
	|	Ном.Ссылка КАК Номенклатура,
	|	вт.Количество КАК Количество,
	|	вт.ЦенаПродажи КАК ЦенаПродажи
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО вт.Артикул = Ном.Артикул
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	тов.Номенклатура КАК Номенклатура,
	|	Цен.ВидЦены КАК ВидЦены,
	|	Цен.Цена КАК Цена
	|ПОМЕСТИТЬ Цен
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, ВидЦены = &ВидЦены) КАК Цен
	|		ПО тов.Номенклатура = Цен.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.НомерСтроки КАК НомерСтроки,
	|	тов.Артикул КАК Артикул,
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Количество КАК КоличествоУпаковокФакт,
	|	тов.Количество КАК КоличествоУпаковок,
	|	тов.Количество КАК Количество,
	|	Цен.ВидЦены КАК ВидЦены,
	|	ЕСТЬNULL(Цен.Цена, 0) КАК Цена,
	|	тов.Количество * ЕСТЬNULL(Цен.Цена, 0) КАК Сумма,
	|	&СтавкаНДС КАК СтавкаНДС,
	|	&Ставка * тов.Количество * ЕСТЬNULL(Цен.Цена, 0) / 100 КАК СуммаНДС,
	|	(&Ставка + 100) * тов.Количество * ЕСТЬNULL(Цен.Цена, 0) / 100 КАК СуммаСНДС,
	|	тов.ЦенаПродажи КАК ЦенаПродажи,
	|	тов.Количество * ЕСТЬNULL(тов.ЦенаПродажи, 0) / (&Ставка + 100) * &Ставка КАК СуммаПродажиНДС,
	|	тов.Количество * тов.ЦенаПродажи КАК СуммаПродажи
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Цен КАК Цен
	|		ПО тов.Номенклатура = Цен.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Док.Товары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

Функция ПолучитьСтруктуруДанныхОтчета()
	Табл = Новый ТаблицаЗначений();
	
	Табл.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число"));
	Табл.Колонки.Добавить("Артикул",     Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(20)));
	Табл.Колонки.Добавить("Количество",  Новый ОписаниеТипов("Число"));
	Табл.Колонки.Добавить("Цена",        Новый ОписаниеТипов("Число"));
	Табл.Колонки.Добавить("Сумма",       Новый ОписаниеТипов("Число"));
	
	Возврат Табл;
КонецФункции

#КонецОбласти

#Область ОтчетОСписанииТоваровУХранителя

Процедура СформироватьДокументаОтчетОСписанииТоваровУХранителя(Форма)
	Перем Маркетплейс;
	
	Если Не Форма.Параметры.Свойство("Маркетплейс", Маркетплейс) Тогда
		Возврат;
	КонецЕсли;	
	
	Комиссионер = Маркетплейс.Комиссионер;
	Данные      = Маркетплейс.Данные;
	
	//@skip-check bsl-legacy-check-string-literal
	Код = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Комиссионер, "Код");
	
	Объект = Форма.Объект;
	
	Док = Документы.ОтчетОСписанииТоваровСХранения.СоздатьДокумент();

	Док.Дата                        = ТекущаяДатаСеанса();
	Док.Организация                 = AMS_ВызовСервера.ОрганизацияТрейд();
	Док.Партнер                     = Комиссионер;
	Док.Валюта                      = Константы.ВалютаРегламентированногоУчета.Получить();
	Док.Менеджер                    = Пользователи.АвторизованныйПользователь();
	Док.ХозяйственнаяОперация       = Перечисления.ХозяйственныеОперации.СписаниеНедостачЗаСчетКомитента;
	Док.СтатьяРасходов	            = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("01-000092");
	
	Если Код = "01-01002250" Тогда // //Интернет Решения (OZON)
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Маркетплейс", Истина);	
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1027739244741");		
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Договор № ИР-564449/24 от 11.11.2024 г.", Истина);		
	
	ИначеЕсли  Код = "01-01002247" Тогда //РВБ (Валберис) 
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Маркетплейс", Истина);	
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1247700471919");		
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Договор № S08170158 от 11.11.2024 г.", Истина);		

	ИначеЕсли Код = "01-01002322" Тогда //Алькор и Ко (Летуаль) Тогда
		Док.Соглашение = Справочники.СоглашенияСКлиентами.НайтиПоНаименованию("Летуаль", Истина);	
		Док.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("РегистрационныйНомер", "1027739498324");		
		Док.Договор    = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("Контракт № MPL-005264 от 26.06.2025 г.", Истина);		
	КонецЕсли;
	
	Док.УстановитьНовыйНомер();
	
	ЗагрузитьТоварыОтчетОСписанииТоваровУХранителя(Док, Данные);
	
	ЗначениеВДанныеФормы(Док, Объект);
КонецПроцедуры

Процедура ЗагрузитьТоварыОтчетОСписанииТоваровУХранителя(Док, Данные)
	Табл = ПолучитьСтруктуруДанныхОтчета();
	
	Для Каждого Элемент Из Данные Цикл
		Стр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Элемент);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Табл", Табл);
	Запрос.УстановитьПараметр("Дата", Док.Дата);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Табл.НомерСтроки КАК НомерСтроки,
	|	ВЫРАЗИТЬ(Табл.Артикул КАК СТРОКА(20)) КАК Артикул,
	|	Табл.Количество КАК Количество,
	|	Табл.Цена КАК Цена
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Табл КАК Табл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.НомерСтроки КАК НомерСтроки,
	|	Ном.Артикул КАК Артикул,
	|	Ном.Ссылка КАК Номенклатура,
	|	вт.Количество КАК Количество,
	|	вт.Цена КАК Цена,
	|	вт.Количество * вт.Цена КАК Сумма
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО вт.Артикул = Ном.Артикул
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Док.Товары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

#КонецОбласти

#Область Прочие

Функция ПолучитьТранспортДоставки(Распоряжение) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);

	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Распоряжения.Ссылка КАК ЛогистическийЛист,
	|	Распоряжения.ТранспортноеСредство КАК ТранспортноеСредство,
	|	Рейсы.Водитель КАК Водитель,
	|	ТранспортныеСредства._Перевозчик КАК Перевозчик
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК Распоряжения
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТранспортныеСредства КАК ТранспортныеСредства
	|		ПО Распоряжения.ТранспортноеСредство = ТранспортныеСредства.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист.Рейсы КАК Рейсы
	|		ПО Распоряжения.Ссылка = Рейсы.Ссылка
	|		И Распоряжения.ТранспортноеСредство = Рейсы.ТранспортноеСредство
	|ГДЕ
	|	Распоряжения.Распоряжение = &Распоряжение";

	Табл = Запрос.Выполнить().Выгрузить();

	Стр = Новый Структура("ЛогистическийЛист,ТранспортноеСредство,Водитель");
	Стр.Вставить("Перевозчик");

	Если Табл.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Табл[0]);
	КонецЕсли;
КонецФункции

#КонецОбласти

