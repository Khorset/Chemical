	//Элемент.ПутьКДанным          = "Объект.Расхождения._Брак";
	//Элемент.Вид                  = ВидПоляФормы.ПолеФлажка;
	//Элемент.ОтображениеПодсказки = ОтображениеПодсказки.Всплывающая;
	//Элемент.Подсказка            = "Оформить передачу на склад бракованной продукции";

	Элемент = Элементы.Добавить("Расхождения_Причина", Тип("ПолеФормы"), Элементы.Расхождения);
	Элемент.ПутьКДанным = "Объект.Расхождения._Причина";
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;

	ЭтоБух = Пользователи.РолиДоступны("_Бухгалтер");

	Элементы.Номер.Доступность = AMS_ВызовСервера.ЭтоKhors();
	Элементы._ЭДО.Доступность  = AMS_ВызовСервера.ЭтоKhors() Или ЭтоБух;

