Процедура УправлениеФормаЭлементаПартнеры(Форма) Экспорт
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	ЭтоКлиент = Объект.Клиент;
	
	Элементы._Стикерование.Видимость         = ЭтоКлиент;
	Элементы.AMS_Лимит.Видимость             = ЭтоКлиент;
	Элементы._ГруппаТУ.Видимость             = ЭтоКлиент;
	Элементы._ГруппаПарамПечати.Видимость    = ЭтоКлиент;
	Элементы._ГруппаКолЭкземпляров.Видимость = ЭтоКлиент;

	БезОграничений = AMS_ВызовСервера.ЕстьПравоАМС(Перечисления.AMS_Права.ПроведениеРеализацииБезОграничений);

	Элементы._Стикерование.Доступность = БезОграничений;
	Элементы.AMS_Лимит.Доступность     = БезОграничений;

	Элементы._ТранпортнаяУслугаПроцент.Видимость = (Объект._ТранпортнаяУслугаСпособ = 0);
	Элементы._ТранпортнаяУслугаСумма.Видимость   = (Объект._ТранпортнаяУслугаСпособ = 1);
КонецПроцедуры

Процедура НастройкаФормаСпискаПартнеры(Форма)
	Список   = Форма.Список;
	Элементы = Форма.Элементы;

	ДобавляемыеРеквизиты = Новый Массив;
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("_СкрытьЗакрытые", Новый ОписаниеТипов("Булево")));
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

	Элемент = Элементы.Добавить("_СкрытьЗакрытые", Тип("ПолеФормы"), Элементы.ГруппаФильтрыЗначимые);
	Элемент.ПутьКДанным = "_СкрытьЗакрытые";
	Элемент.Вид         = ВидПоляФормы.ПолеФлажка;
	Элемент.Заголовок   = "Скрыть закрытые";
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_амсПриИзменении_СкрытьЗакрытые");
	
	ТекстСправа = Сред(Список.ТекстЗапроса, 9);
	Список.ТекстЗапроса = "ВЫБРАТЬ" + "
						|	СправочникПартнеры._Закрыт КАК Закрыт," + ТекстСправа;
КонецПроцедуры

Процедура НастройкаФормаЭлементаСоглашенияСКлиентами(Форма)
	Форма.ТолькоПросмотр = Форма.Объект.Типовое И Не Пользователи.РолиДоступны("AMS_Аналитик");
КонецПроцедуры

