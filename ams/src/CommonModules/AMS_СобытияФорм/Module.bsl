	|ИЗ
	|	Документ.КорректировкаРеализации КАК ДокументКорректировкаРеализации
	|		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияПоОбъектамУчетаЭДО КАК СостоянияЭД
	|		ПО (СостоянияЭД.СсылкаНаОбъект = ДокументКорректировкаРеализации.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыСОшибкамиПроверкиКонтрагентов КАК ДокументыСОшибкамиПроверкиКонтрагентов
	|		ПО ДокументКорректировкаРеализации.Ссылка = ДокументыСОшибкамиПроверкиКонтрагентов.Документ
	|			И (&ИспользованиеПроверкиВозможно)}";

	Элемент = Элементы.Добавить("_Основание", Тип("ПолеФормы"), Элементы.СписокКорректировкиРеализации);
	Элемент.Вид         = ВидПоляФормы.ПолеНадписи;
	Элемент.Заголовок   = "Основание";
	Элемент.ПутьКДанным = "СписокКорректировкиРеализации.ДокументОснование";

	Элемент = Элементы.Вставить("_Статус", Тип("ПолеФормы"), Элементы.СписокКорректировкиРеализации,
		Элементы.СписокКорректировкиРеализацииДата);
	Элемент.Вид         = ВидПоляФормы.ПолеНадписи;
	Элемент.Заголовок   = "Статус";
	Элемент.ПутьКДанным = "СписокКорректировкиРеализации.Статус";
	
	// выполнить условное оформление
	ЭлементОформления = Форма.СписокКорректировкиРеализации.УсловноеОформление.Элементы.Добавить();

	ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Ссылка._ПеремещениеТоваров");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеРавно;
	ЭлементОтбора.ПравоеЗначение = ОбщегоНазначения.ПредопределенныйЭлемент("Документ.ПеремещениеТоваров.ПустаяСсылка");
	ЭлементОтбора.Использование  = Истина;

	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.Хаки);
	ЭлементОформления.Использование = Истина;
КонецПроцедуры

Процедура НастройкаФормаДокументаОприходованиеИзлишковТоваров(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;

	Если AMS_ВызовСервера.ЭтоKhors() Или Пользователи.РолиДоступны("_Бухгалтер") Тогда
		Команда = Форма.Команды.Добавить("_КомандаЗаполнитьЦены");
