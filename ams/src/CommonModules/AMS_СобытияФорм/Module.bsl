		Элемент = Элементы.Добавить("AMS_ТелефонВодителяКлиента", Тип("ПолеФормы"), Элементы.AMS_ГруппаПерегрузка);
		Элемент.ПутьКДанным              = "Объект.AMS_ТелефонВодителяКлиента";
