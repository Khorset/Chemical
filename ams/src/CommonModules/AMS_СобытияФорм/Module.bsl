	Элемент.КнопкаОткрытия     = Истина;
	Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_AMS_ПриИзменении_ПартнерДопИнфо");
	
	// Табличная часть Товары
	Группа  = Элементы.Добавить("AMS_ГруппаКнопки", Тип("ГруппаФормы"), Элементы.Товары.КоманднаяПанель);
	Группа.Вид = ВидГруппыФормы.ГруппаКнопок;

	Команда = Форма.Команды.Добавить("AMS_КомандаПодборТоваров");
