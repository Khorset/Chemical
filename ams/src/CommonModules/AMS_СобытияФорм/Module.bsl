	Команда = Форма.Команды.Добавить("AMS_КомандаЗагрузитьИзДокументаРеализации");
	Команда.Действие  = "Подключаемый_AMS_Команда_ЗагрузитьИзДокументаРеализации";
	Команда.Заголовок = "Загрузить из реализаций";

	Кнопка = Элементы.Добавить("AMS_КнопкаЗагрузитьИзДокументаРеализации", Тип("КнопкаФормы"), Элементы.AMS_ГруппаКнопки);
