		Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
		Кнопка.ИмяКоманды = "_КомандаЗаполнитьЦены";
		
		Команда = Форма.Команды.Добавить("_КомандаЗаполнитьМатериалы");
		Команда.Действие  = "Подключаемый_амсКоманда_ЗаполнитьМатериалы";
		Команда.Заголовок = "Заполнить материалы";

		Кнопка = Элементы.Добавить("_КнопкаЗаполнитьМатериалы", Тип("КнопкаФормы"), Элементы.Товары.КоманднаяПанель);
		Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
		Кнопка.ИмяКоманды = "_КомандаЗаполнитьМатериалы";

		Команда = Форма.Команды.Добавить("_КомандаЗаполнитьФабрикаты");
		Команда.Действие  = "Подключаемый_амсКоманда_ЗаполнитьФабрикаты";
		Команда.Заголовок = "Заполнить фабрикаты";

		Кнопка = Элементы.Добавить("_КнопкаЗаполнитьФабрикаты", Тип("КнопкаФормы"), Элементы.Товары.КоманднаяПанель);
		Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
		Кнопка.ИмяКоманды = "_КомандаЗаполнитьФабрикаты";
	КонецЕсли;

	Элементы.Номер.Доступность = AMS_ВызовСервера.ЭтоKhors();

	Если AMS_ВызовСервера.ЭтоKhors() Или Пользователи.РолиДоступны("_Бухгалтер") Тогда
		//Форма.ТолькоПросмотр = Ложь;
	ИначеЕсли Объект._СформированАвтоматически Или ЗначениеЗаполнено(Объект.ПересчетТоваров) Тогда 
		Форма.ТолькоПросмотр = Истина;
	КонецЕсли;
КонецПроцедуры

