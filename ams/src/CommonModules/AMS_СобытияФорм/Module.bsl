Процедура НастройкаФормаДокументаВнутреннееПотребление(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
		
	ЭтоKhors = AMS_ВызовСервера.ЭтоKhors();
	
	Элементы.Номер.Доступность = ЭтоKhors;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Или Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПередачаВЭксплуатацию Тогда
		Возврат;
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Объект._Основание) Тогда
		Элементы.Дата.Доступность = Ложь; 
		
		ЭтоБухПроизвод  = Пользователи.РолиДоступны("AMS_БухгалтерПроизводства") Или AMS_ВызовСервера.ЭтоГлавбух(); 
		ЭтоНачЦеха      = Пользователи.РолиДоступны("_НачальникЦеха"); 
		МенеджерЗакупок = Пользователи.РолиДоступны("_МенеджерЗакупок"); 
		
		Если ЭтоБухПроизвод Тогда
			//Ничего не делать
		ИначеЕсли ЭтоНачЦеха Или МенеджерЗакупок Тогда
			Элементы.ТоварыНоменклатура.ТолькоПросмотр             = Истина;
			Элементы.ТоварыКоличествоУпаковок.ТолькоПросмотр       = Истина;
			Элементы.ТоварыУпаковкаЕдиницаИзмерения.ТолькоПросмотр = Истина;
			Элементы.ТоварыЦена.ТолькоПросмотр                     = Истина;
			Элементы.ТоварыСумма.ТолькоПросмотр                    = Истина;
			Элементы.ТоварыСтатьяРасходов.ТолькоПросмотр           = Истина;
			Элементы.ТоварыГруппаАналитика.ТолькоПросмотр          = Истина;
			
		Иначе
			Форма.ТолькоПросмотр = Истина;
			Элементы.Товары.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
		КонецЕсли;
		
		Группа  = Элементы.Добавить("AMS_ГруппаДопРеквизиты", Тип("ГруппаФормы"), Элементы.ГруппаОсновное);
		Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок   = "Дополнительные реквизиты (AMS)";
		Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
		Элемент = Элементы.Добавить("AMS_ОперацияПроизводства", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Операция";
		Элемент.ПутьКДанным    = "Объект._ОперацияПроизводства";
		Элемент.КнопкаВыбора   = Ложь;
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
	
		Элемент = Элементы.Добавить("AMS_Основание", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
