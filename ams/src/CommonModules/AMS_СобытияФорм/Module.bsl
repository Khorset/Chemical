	Элемент.РастягиватьПоГоризонтали = Ложь;
	Элемент.Ширина = 15;
	Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_амсПриИзмененииСтатус");

	Элемент = Элементы.Добавить("Партнер", Тип("ПолеФормы"), Элементы.ГруппаОтбор);
