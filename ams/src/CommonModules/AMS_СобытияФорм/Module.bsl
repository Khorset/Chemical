Процедура НастройкаФормаДокументаЗаказПоставщику(Форма)
	Элементы = Форма.Элементы;

	//Дополнительная информация
	Группа  = Элементы.Добавить("_ГруппаАМС", Тип("ГруппаФормы"), Элементы.ГруппаОсновное);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительная информация";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Команда = Форма.Команды.Добавить("_КомандаВыборПоставщика");
	Команда.Действие  = "Подключаемый_амсКоманда_ВыборПоставщика";
	Команда.Заголовок = "Выбор поставщика и подбор товаров";

	Кнопка = Элементы.Добавить("_Кнопка_КомандаВыборПоставщика", Тип("КнопкаФормы"), Элементы._ГруппаАМС);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаВыборПоставщика";

	Группа  = Элементы.Добавить("_КоличествоПалетВес", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Отображение = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("AMS_КоличествоПалет", Тип("ПолеФормы"), Элементы._КоличествоПалетВес);
	Элемент.ПутьКДанным = "Объект.AMS_КоличествоПалет";
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Количество палет";

	Элемент = Элементы.Добавить("_Шт", Тип("ДекорацияФормы"), Элементы._КоличествоПалетВес);
	Элемент.Заголовок   = "шт.";

	Элемент = Элементы.Добавить("AMS_Вес", Тип("ПолеФормы"), Элементы._КоличествоПалетВес);
	Элемент.ПутьКДанным = "Объект.AMS_Вес";
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Вес";

	Элемент = Элементы.Добавить("_т", Тип("ДекорацияФормы"), Элементы._КоличествоПалетВес);
	Элемент.Заголовок   = "т.";
	
	//Товары
	Элемент = Элементы.Вставить("_Остаток", Тип("ПолеФормы"), Элементы.Товары, Элементы.ТоварыКоличествоУпаковок);
	Элемент.ПутьКДанным    = "Объект.Товары._Остаток";
	Элемент.Вид            = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок      = "Остаток";
	Элемент.ТолькоПросмотр = Истина;

	Элемент = Элементы.Вставить("_КоличествоЗаказано", Тип("ПолеФормы"), Элементы.Товары,
		Элементы.ТоварыКоличествоУпаковок);
	Элемент.ПутьКДанным    = "Объект.Товары._КоличествоЗаказано";
	Элемент.Вид            = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок      = "Заказано";

	Элементы.ТоварыКоличествоУпаковок.Заголовок = "Количество (Согласовано)";

	Элементы.ПоступлениеОднойДатой.Видимость = Ложь;
	Элементы.ДлительностьДоставки.Видимость  = Ложь;
	Элементы.ДатаОтгрузки.Заголовок          = "Дата отгрузки";
	Элементы.ДатаОтгрузки.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
			
	ДобавитьРеквизитыДоставкиAMS(Форма, "ЗаказПоставщику");
КонецПроцедуры

