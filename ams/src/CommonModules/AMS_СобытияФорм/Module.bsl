Процедура НастройкаФормаДокументаПеремещениеТоваров(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	ЭтоKhors = AMS_ВызовСервера.ЭтоKhors();
	
	Элементы.Номер.Доступность = ЭтоKhors;

	Группа  = Элементы.Добавить("_ГруппаАМС", Тип("ГруппаФормы"), Элементы.СтраницаОсновное);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительные реквизиты";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Группа  = Элементы.Добавить("_ГруппаОтгрузил", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Отображение         = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("_Отгрузил", Тип("ПолеФормы"), Элементы._ГруппаОтгрузил);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Отгрузил";
	Элемент.ПутьКДанным = "Объект._Отгрузил";

	Элемент = Элементы.Добавить("_ВремяОтгрузки", Тип("ПолеФормы"), Элементы._ГруппаОтгрузил);
	Элемент.Вид         = ВидПоляФормы.ПолеНадписи;
	Элемент.Заголовок   = "Время отгрузки";
	Элемент.ПутьКДанным = "Объект._ВремяОтгрузки";

	Группа  = Элементы.Добавить("_ГруппаПринял", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид                 = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Отображение         = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка         = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("_Принял", Тип("ПолеФормы"), Элементы._ГруппаПринял);
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Принял";
	Элемент.ПутьКДанным = "Объект._Принял";

	Элемент = Элементы.Добавить("_ВремяПоступления", Тип("ПолеФормы"), Элементы._ГруппаПринял);
	Элемент.Вид         = ВидПоляФормы.ПолеНадписи;
	Элемент.Заголовок   = "Время поступления";
	Элемент.ПутьКДанным = "Объект._ВремяПоступления";

	Если ЗначениеЗаполнено(Объект._Основание) Тогда
		Элемент = Элементы.Добавить("_ОперацияПроизводства", Тип("ПолеФормы"), Элементы._ГруппаАМС);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Операция";
		Элемент.ПутьКДанным    = "Объект._ОперацияПроизводства";
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
		
		Элемент = Элементы.Добавить("_Основание", Тип("ПолеФормы"), Элементы._ГруппаАМС);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Основание";
		Элемент.ПутьКДанным    = "Объект._Основание";
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
	КонецЕсли; 

	Команда = Форма.Команды.Добавить("_КомандаЗаполнитьПродукцию");
	Команда.Действие  = "Подключаемый_AMS_Команда_ЗаполнитьПродукцию";
	Команда.Заголовок = "Заполнить продукцию";

	Кнопка = Элементы.Добавить("_КнопкаЗаполнитьПродукцию", Тип("КнопкаФормы"), Элементы.Товары.КоманднаяПанель);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаЗаполнитьПродукцию";

	Если Пользователи.РолиДоступны("_КладовщикСклада") И Не ЭтоKhors Тогда
		Элементы.Статус.Доступность               = Истина;
		
		Элементы.ГруппаНакладнаяПоЗаказам.Доступность = Ложь;
		Элементы.Шапка.Доступность                    = Ложь;
		Элементы._Отгрузил.Доступность                = Ложь;
		
		Элементы.СтраницаТовары.ТолькоПросмотр            = Истина;
		Элементы.СтраницаДоставка.ТолькоПросмотр          = Истина;
		Элементы.ГруппаДополнительно.ТолькоПросмотр       = Истина;
		Элементы.ТекстДокументыНаОсновании.ТолькоПросмотр = Истина;
		Элементы.ГруппаСостояниеЭДО.ТолькоПросмотр        = Истина;
		
		Элементы.Товары.КоманднаяПанель.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

Процедура УправлениеФормаДокументаПеремещениеТоваров(Форма) Экспорт
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;

	Элементы._КнопкаЗаполнитьПродукцию.Видимость = Не Объект.Проведен И ЗначениеЗаполнено(Объект._Основание) 
		И Объект._ОперацияПроизводства = Перечисления.AMS_ОперацииПроизводства.ПеремещениеПроизведеннойПродукции; 
КонецПроцедуры

Процедура НастройкаФормаДокументаПересчетТоваров(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	// Добавляемые реквизиты формы                                            
	ДобавляемыеРеквизиты = Новый Массив;
	
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("_мСтатус",
		Новый ОписаниеТипов("ПеречислениеСсылка.СтатусыПересчетовТоваров")));
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

	Элементы.Статус.УстановитьДействие("НачалоВыбора", "Подключаемый_амсНачалоВыбора_Статус");

	Команда = Форма.Команды.Добавить("_КомандаВнесениеРезультатов");
	Команда.Действие  = "Подключаемый_амсКоманда_ВнесениеРезультатов";
	Команда.Заголовок = "Внесение результатов";

	Кнопка = Элементы.Добавить("_КнопкаВнесениеРезультатов", Тип("КнопкаФормы"), Элементы.ГруппаТоварыШапка);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаВнесениеРезультатов";

	Если Не (AMS_ВызовСервера.ЭтоKhors() Или Пользователи.РолиДоступны("_Бухгалтер")) Тогда
		Форма.ТолькоПросмотр = (Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Выполнено);
	КонецЕсли;
КонецПроцедуры

Процедура НастройкаФормаДокументаПриобретениеТоваровУслуг(Форма)
	Элементы = Форма.Элементы;

	Команда = Форма.Команды.Добавить("_КомандаПечатьАктПереводаНаименований");
	Команда.Действие  = "Подключаемый_амсПечать_АктПереводаНаименований";
	Команда.Заголовок = "Акт перевода наименований";

	Кнопка = Элементы.Добавить("_КнопкаПечать_АктПереводаНаименований", Тип("КнопкаФормы"),
		Элементы.ПодменюПечать.ПодчиненныеЭлементы[1]);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаПечатьАктПереводаНаименований";
	
	//Дополнительная информация
	Группа  = Элементы.Добавить("_ГруппаАМС", Тип("ГруппаФормы"), Элементы.ГруппаОсновное);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительная информация";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Команда = Форма.Команды.Добавить("_КомандаВыборПоставщика");
	Команда.Действие  = "Подключаемый_амсКоманда_ВыборПоставщика";
	Команда.Заголовок = "Выбор поставщика и подбор товаров";

	Кнопка = Элементы.Добавить("_Кнопка_КомандаВыборПоставщика", Тип("КнопкаФормы"), Элементы._ГруппаАМС);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаВыборПоставщика";
КонецПроцедуры

Процедура НастройкаФормыДокументаПрочееОприходованиеТоваров(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
		
	ЭтоKhors = AMS_ВызовСервера.ЭтоKhors();
	
	Элементы.Номер.Доступность = ЭтоKhors;
	
	Если ЗначениеЗаполнено(Объект._Основание) Тогда
		Элементы.Дата.Доступность = Ложь; 
		
		ЭтоБухПроизвод  = Пользователи.РолиДоступны("AMS_БухгалтерПроизводства") Или AMS_ВызовСервера.ЭтоГлавбух(); 
		ЭтоНачЦеха      = Пользователи.РолиДоступны("_НачальникЦеха"); 
		МенеджерЗакупок = Пользователи.РолиДоступны("_МенеджерЗакупок"); 
		
		Если ЭтоБухПроизвод Тогда
			//Ничего не делать
		ИначеЕсли ЭтоНачЦеха Или МенеджерЗакупок Тогда
			Элементы.ТоварыНоменклатура.ТолькоПросмотр             = Истина;
			Элементы.ТоварыКоличествоУпаковок.ТолькоПросмотр       = Истина;
			Элементы.ТоварыУпаковкаЕдиницаИзмерения.ТолькоПросмотр = Истина;
			Элементы.ТоварыЦена.ТолькоПросмотр                     = Истина;
			Элементы.ТоварыСумма.ТолькоПросмотр                    = Истина;
			Элементы.ТоварыСтатьяРасходовДоходов.ТолькоПросмотр    = Истина;
			Элементы.ТоварыГруппаАналитика.ТолькоПросмотр          = Истина;
			
		Иначе
			Форма.ТолькоПросмотр = Истина;
			Элементы.Товары.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
		КонецЕсли;
		
		Группа  = Элементы.Добавить("AMS_ГруппаДопРеквизиты", Тип("ГруппаФормы"), Элементы.ГруппаОсновное);
		Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок   = "Дополнительные реквизиты (AMS)";
		Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
		Элемент = Элементы.Добавить("AMS_ОперацияПроизводства", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Операция";
		Элемент.ПутьКДанным    = "Объект._ОперацияПроизводства";
		Элемент.КнопкаВыбора   = Ложь;
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
	
		Элемент = Элементы.Добавить("AMS_Основание", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Основание";
		Элемент.ПутьКДанным    = "Объект._Основание";
		Элемент.КнопкаВыбора   = Ложь;
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
КонецЕсли;
КонецПроцедуры

Процедура НастройкаФормаДокументаРасходныйОрдерНаТовары(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РасходныйОрдерНаТовары", Объект.Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т.Распоряжение КАК Распоряжение
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК т
	|ГДЕ
	|	т.Ссылка = &РасходныйОрдерНаТовары";

	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	Выб.Следующий();

	Распоряжение = Выб.Распоряжение;

	ЭтоПродажа = ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг");

	Если Объект._ВесОсновной = 0 Тогда
		Если ЭтоПродажа Тогда
			//@skip-check bsl-legacy-check-string-literal
			Объект._ВесОсновной = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Распоряжение, "AMS_Вес");

		Иначе //Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			Стр = AMS_Сервер.ПолучитьВесОбъемТоваров(Распоряжение.Товары.Выгрузить( , "Номенклатура,Количество"), 1);
			Объект._ВесОсновной = Стр.Вес;
		КонецЕсли;
	КонецЕсли;
	
	// ВЫВОД НА ФОРМУ РЕКВИЗИТОВ ФОРМЫ
	
	// Группа Дополнительные реквизиты
	Группа  = Элементы.Добавить("_ГруппаАМС", Тип("ГруппаФормы"), Элементы.ГруппаИнформацияИКомментарий);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительные информация";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Группа.РастягиватьПоГоризонтали = Ложь;
	Группа.Ширина = 90;
	
	// Таблица Товары
	Группа  = Элементы.Добавить("_ГруппаТовары", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Отгруженные товары с Верхнего склада";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Группа.РастягиватьПоГоризонтали = Ложь;
	Группа.Ширина = 88;

	Таблица = Элементы.Добавить("_Товары", Тип("ТаблицаФормы"), Элементы._ГруппаТовары);
	Таблица.ПутьКДанным = "Объект._Товары";
	Таблица.Отображение = ОтображениеТаблицы.Список;
	Таблица.АвтоМаксимальнаяШирина = Ложь;
	Таблица.Ширина = 80;

	Элемент = Элементы.Добавить("_ТоварыНомерСтроки", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "№";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Товары.НомерСтроки";
	Элемент.ТолькоПросмотр = Истина;
	Элемент.Ширина = 2;

	Элемент = Элементы.Добавить("_ТоварыНоменклатура", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "Номенклатура";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Товары.Номенклатура";
	Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_амсПриИзменении_ТоварыНоменклатура");
	Элемент.РежимВыбораИзСписка = Истина;
	СписокВыбора = Элемент.СписокВыбора;
	Табл = Объект.ТоварыПоРаспоряжениям;
	Для Каждого Стр Из Табл Цикл
		СписокВыбора.Добавить(Стр.Номенклатура);
	КонецЦикла;

	Элемент = Элементы.Добавить("_ТоварыУпаковка", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "Упаковка";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Товары.Номенклатура._Упаковка";

	Элемент = Элементы.Добавить("_ТоварыКоличество", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "Количество";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Товары.Количество";
	Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_амсПриИзменении_ТоварыКоличество");

	Элемент = Элементы.Добавить("_ТоварыВес", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "Вес, кг";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Товары.Вес";
	Элемент.ТолькоПросмотр = Истина;
	
	// Вес огруженного товары
	Группа  = Элементы.Добавить("_ГруппаВес", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид  = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Отображение = ОтображениеОбычнойГруппы.Нет;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	Элемент = Элементы.Добавить("AMS_Вес", Тип("ПолеФормы"), Элементы._ГруппаВес);
	Элемент.ПутьКДанным = "Объект._ВесОсновной";
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Отгружено, т:  Основной склад";
	Элемент.ТолькоПросмотр = Истина;

	Элемент = Элементы.Добавить("AMS_Объем", Тип("ПолеФормы"), Элементы._ГруппаВес);
	Элемент.ПутьКДанным = "Объект._ВесВерхний";
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Верхний склад";
	Элемент.ТолькоПросмотр = Истина;
	
	// Таблица Работы
	Группа  = Элементы.Добавить("_ГруппаРаботы", Тип("ГруппаФормы"), Элементы._ГруппаАМС);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Выполненные работы по отгрузке продукции";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Группа.РастягиватьПоГоризонтали = Ложь;
	Группа.Ширина = 88;

	Таблица = Элементы.Добавить("_Работы", Тип("ТаблицаФормы"), Элементы._ГруппаРаботы);
	Таблица.ПутьКДанным = "Объект._Работы";
	Таблица.Отображение = ОтображениеТаблицы.Список;
	Таблица.АвтоМаксимальнаяШирина = Ложь;
	Таблица.Ширина = 85;

	Элемент = Элементы.Добавить("_РаботыНомерСтроки", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "№";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Работы.НомерСтроки";
	Элемент.ТолькоПросмотр = Истина;
	Элемент.Ширина = 2;

	Элемент = Элементы.Добавить("_РаботыМестоПогрузки", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "Место";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Работы.МестоПогрузки";

	Элемент = Элементы.Добавить("_РаботыРабота", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "Работа";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Работы.Работа";
	Элемент.РежимВыбораИзСписка = Истина;
	Элемент.УстановитьДействие("НачалоВыбора", "Подключаемый_амсНачалоВыбора_Работа");

	Элемент = Элементы.Добавить("_РаботыСотрудник", Тип("ПолеФормы"), Таблица);
	Элемент.Заголовок = "Сотрудник";
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = "Объект._Работы.Сотрудник";
	Элемент.РежимВыбораИзСписка = Истина;
	Элемент.СписокВыбора.ЗагрузитьЗначения(AMS_Сервер.ПолучитьСотрудниковСкладаПродукции());
	
	//Заполнить предварительно Работы
	Если ЭтоПродажа 
		И Объект.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен 
		И Объект._Работы.Количество() = 0 Тогда

		МестоПогрузки = Перечисления._МестаПогрузки.Основной;

		Стр = Объект._Работы.Добавить();
		Стр.МестоПогрузки = МестоПогрузки;
		Стр.Работа = Справочники._Работы.СкладКладовщик;

		Стр = Объект._Работы.Добавить();
		Стр.МестоПогрузки = МестоПогрузки;
		Стр.Работа = Справочники._Работы.СкладОбмотчик;

		Стр = Объект._Работы.Добавить();
		Стр.МестоПогрузки = МестоПогрузки;
		Стр.Работа = Справочники._Работы.СкладГрузчикВМашине;

		Стр = Объект._Работы.Добавить();
		Стр.МестоПогрузки = МестоПогрузки;
		Стр.Работа = Справочники._Работы.СкладВодитель;

		Стр = Объект._Работы.Добавить();
		Стр.МестоПогрузки = МестоПогрузки;
		Стр.Работа = Справочники._Работы.СкладКомплектовщик;

		Стр = Объект._Работы.Добавить();
		Стр.МестоПогрузки = МестоПогрузки;
		Стр.Работа = Справочники._Работы.СкладКомплектовщик;
	КонецЕсли;

	// Управление элементами формы
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РасходныйОрдерНаТовары", Объект.Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т.Распоряжение КАК Распоряжение
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК т
	|ГДЕ
	|	т.Ссылка = &РасходныйОрдерНаТовары";

	Рез = Запрос.Выполнить();
	Если Рез.Пустой() Тогда
		Возврат;
	КонецЕсли;

	Элементы.Контролер.Доступность = Истина;
	Элементы.Номер.Доступность = AMS_ВызовСервера.ЭтоKhors();

	Бух     = Пользователи.РолиДоступны("_Директор,_Бухгалтер");
	ГлавБух = Пользователи.РолиДоступны("_ГлавныйБухгалтер");

	Элементы.Дата.Доступность         = ГлавБух;
	Элементы.ДатаОтгрузки.Доступность = ГлавБух;

	Если Не (ГлавБух Или Бух) 
		И Объект.Статус = Перечисления.СтатусыРасходныхОрдеров.Отгружен Тогда
		Элементы.ГруппаСтатусПроверитьИсправить.Доступность = Ложь;
		Элементы.ГруппаИнформация.Доступность = Ложь;

		Элементы.ТоварыПоРаспоряжениям.ТолькоПросмотр = Истина;
		Элементы.ТоварыПоРаспоряжениям.КоманднаяПанель.Видимость = Ложь;

		Элементы.ОтгружаемыеТовары.ТолькоПросмотр = Истина;
		Элементы.ОтгружаемыеТовары.КоманднаяПанель.Видимость = Ложь;
		Элементы.ГруппаРежимПросмотраНавигация.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

Процедура НастройкаФормыДокументаСборкаТоваров(Форма)
	Элементы = Форма.Элементы;

	Группа  = Элементы.Добавить("AMS_ГруппаДопРеквизиты", Тип("ГруппаФормы"), Элементы.ГруппаОсновное);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Заголовок   = "Дополнительные реквизиты (AMS)";
	Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Элемент = Элементы.Добавить("AMS_Операция", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
	Элемент.ПутьКДанным = "Объект.AMS_Операция";
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок   = "Операция";

	Элемент = Элементы.Добавить("AMS_Основание", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
	Элемент.Вид          = ВидПоляФормы.ПолеВвода;
	Элемент.Заголовок    = "Основание";
	Элемент.ПутьКДанным  = "Объект.AMS_Основание";
КонецПроцедуры

Процедура НастройкаФормаДокументаСписаниеНедостачТоваров(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
		
	ЭтоKhors = AMS_ВызовСервера.ЭтоKhors();
	
	Элементы.Номер.Доступность = ЭтоKhors;
	
	Если ЗначениеЗаполнено(Объект._Основание) Тогда
		Группа  = Элементы.Добавить("AMS_ГруппаДопРеквизиты", Тип("ГруппаФормы"), Элементы.ГруппаИнформация);
		Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок   = "Дополнительные реквизиты (AMS)";
		Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
		Элемент = Элементы.Добавить("AMS_ОперацияПроизводства", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Операция";
		Элемент.ПутьКДанным    = "Объект._ОперацияПроизводства";
		Элемент.КнопкаВыбора   = Ложь;
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
	
		Элемент = Элементы.Добавить("AMS_Основание", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Основание";
		Элемент.ПутьКДанным    = "Объект._Основание";
		Элемент.КнопкаВыбора   = Ложь;
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
	КонецЕсли;

	Если Пользователи.РолиДоступны("_Бухгалтер") Тогда
		Элементы = Форма.Элементы;

		Команда = Форма.Команды.Добавить("_КомандаЗаполнитьМатериалы");
		Команда.Действие  = "Подключаемый_амсКоманда_ЗаполнитьМатериалы";
		Команда.Заголовок = "Заполнить материалы";

		Кнопка = Элементы.Добавить("_КнопкаЗаполнитьМатериалы", Тип("КнопкаФормы"), Элементы.Товары.КоманднаяПанель);
		Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
		Кнопка.ИмяКоманды = "_КомандаЗаполнитьМатериалы";

		Команда = Форма.Команды.Добавить("_КомандаЗаполнитьФабрикаты");
		Команда.Действие  = "Подключаемый_амсКоманда_ЗаполнитьФабрикаты";
		Команда.Заголовок = "Заполнить фабрикаты";

		Кнопка = Элементы.Добавить("_КнопкаЗаполнитьФабрикаты", Тип("КнопкаФормы"), Элементы.Товары.КоманднаяПанель);
		Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
		Кнопка.ИмяКоманды = "_КомандаЗаполнитьФабрикаты";
	КонецЕсли;

	Если Не AMS_ВызовСервера.ЭтоKhors() Тогда
		Форма.ТолькоПросмотр = Объект._СформированАвтоматически Или Не Пользователи.РолиДоступны("_Бухгалтер") И ЗначениеЗаполнено(Объект.ПересчетТоваров);
	КонецЕсли;
КонецПроцедуры

Процедура НастройкаФормаДокументаОрдерНаОтражениеИзлишковТоваров(Форма)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
		
	ЭтоKhors = AMS_ВызовСервера.ЭтоKhors();
	
	Элементы.Номер.Доступность = ЭтоKhors;
	
	Если ЗначениеЗаполнено(Объект._Основание) Тогда
		Элементы.Дата.Доступность = Ложь; 
		
		ЭтоБухПроизвод  = Пользователи.РолиДоступны("AMS_БухгалтерПроизводства") Или AMS_ВызовСервера.ЭтоГлавбух(); 
		ЭтоНачЦеха      = Пользователи.РолиДоступны("_НачальникЦеха"); 
		МенеджерЗакупок = Пользователи.РолиДоступны("_МенеджерЗакупок"); 
		
		Если ЭтоБухПроизвод Тогда
			//Ничего не делать
		ИначеЕсли ЭтоНачЦеха Или МенеджерЗакупок Тогда
			Элементы.ТоварыНоменклатура.ТолькоПросмотр             = Истина;
			Элементы.ТоварыКоличествоУпаковок.ТолькоПросмотр       = Истина;
			Элементы.ТоварыГруппаУпаковкаЕдиницаИзмерения.ТолькоПросмотр = Истина;
			
		Иначе
			Форма.ТолькоПросмотр = Истина;
			Элементы.Товары.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
		КонецЕсли;
		
		Группа  = Элементы.Добавить("AMS_ГруппаДопРеквизиты", Тип("ГруппаФормы"), Элементы.ГруппаИнформация);
		Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок   = "Дополнительные реквизиты (AMS)";
		Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
		Элемент = Элементы.Добавить("AMS_ОперацияПроизводства", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Операция";
		Элемент.ПутьКДанным    = "Объект._ОперацияПроизводства";
		Элемент.КнопкаВыбора   = Ложь;
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
	
		Элемент = Элементы.Добавить("AMS_Основание", Тип("ПолеФормы"), Элементы.AMS_ГруппаДопРеквизиты);
		Элемент.Вид            = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок      = "Основание";
		Элемент.ПутьКДанным    = "Объект._Основание";
		Элемент.КнопкаВыбора   = Ложь;
		Элемент.ТолькоПросмотр = Не ЭтоKhors;
	КонецЕсли;

	Команда = Форма.Команды.Добавить("AMS_Команда_ЗаполнитьОстатки");
	Команда.Действие  = "Подключаемый_AMS_Команда_ЗаполнитьОстатки";
	Команда.Заголовок = "Заполнить остатки (МАСТ)";

	Кнопка = Элементы.Добавить("AMS_Кнопка_ЗаполнитьОстатки", Тип("КнопкаФормы"), Элементы.Товары.КоманднаяПанель);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "AMS_Команда_ЗаполнитьОстатки";
КонецПроцедуры

