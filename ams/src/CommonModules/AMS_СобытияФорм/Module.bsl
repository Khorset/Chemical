	Элемент.РежимВыбораИзСписка = Истина;
	Элемент.СписокВыбора.Добавить(AMS_ВызовСервера.СкладПродукции());
	Элемент.СписокВыбора.Добавить(AMS_ВызовСервера.Цех1());
	Элемент.СписокВыбора.Добавить(AMS_ВызовСервера.Цех2());
	Элемент.СписокВыбора.Добавить(AMS_ВызовСервера.Цех3());
	Элемент.СписокВыбора.Добавить(AMS_ВызовСервера.Цех4());

	Элемент = Элементы.Добавить("AMS_Дожность", Тип("ПолеФормы"), Элементы._ГруппаАМС);
	Элемент.ПутьКДанным = "Объект.AMS_Должность";
	Элемент.Заголовок   = "Дожность";
	Элемент.Вид         = ВидПоляФормы.ПолеВвода;
КонецПроцедуры

#КонецОбласти

#Область НастройкаФормыДокументы

Процедура НастройкаФормаДокумента_ЗаказКлиента_ОтгрузкаТоваров_РеализацияТоваров(Форма, ТипДокумента)
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	#Область ДобавитьРеквизитыФормы

	ДобавляемыеРеквизиты = Новый Массив;
	
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_ПартнерДопИнфо", Новый ОписаниеТипов("Строка")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_ИнфоСуммаКонтракта", Новый ОписаниеТипов("Строка",,	Новый КвалификаторыСтроки(200))));

	Если ТипДокумента = "ЗаказКлиента" Тогда
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_мСтатусВ2В", Новый ОписаниеТипов("ПеречислениеСсылка.AMS_СтатусыВ2В")));
		
		Если Объект.Автор.Наименование = "<Не указан>" Тогда
			Объект.Автор = Пользователи.АвторизованныйПользователь();
		КонецЕсли;
		
	ИначеЕсли ТипДокумента = "РеализацияТоваровУслуг" Тогда
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_мСтатусРеализации", Новый ОписаниеТипов("ПеречислениеСсылка.AMS_СтатусыРеализаций")));
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_ВремяНачалаОбработкиДокумента", Новый ОписаниеТипов("Дата")));
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_ИнфоЗапретИзменений", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(200))));
//		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("AMS_ПередачаТоваровМеждуОрганизациями", Новый ОписаниеТипов("ДокументСсылка.ПередачаТоваровМеждуОрганизациями")));
	КонецЕсли;
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

	#КонецОбласти

	#Область ЗаполнитьДобавленныеРеквизиты

	Если ТипДокумента = "ЗаказКлиента" Тогда
	
	ИначеЕсли ТипДокумента = "РеализацияТоваровУслуг" Тогда
		Форма.AMS_мСтатусРеализации             = Объект.AMS_СтатусРеализации;
		Форма.AMS_ВремяНачалаОбработкиДокумента = ТекущаяДатаСеанса();
		Форма.AMS_ИнфоЗапретИзменений           = "На складе выполнена печать документов!" ;
		
//		Если Не Объект.Организация = AMS_ВызовСервера.ОрганизацияСобственникПродукции() Тогда
//			Форма.AMS_ПередачаТоваровМеждуОрганизациями = AMS_Сервер.ПолучитьПередачаТоваровМеждуОрганизациями(Объект.Ссылка);	
//		КонецЕсли;
	КонецЕсли;

	#КонецОбласти
	
	ДобавитьКомандыПечатиAMS(Форма, Элементы, ТипДокумента);
	
	ДобавитьРеквизитыAMS(Форма, Элементы, ТипДокумента);
	
	ДобавитьРеквизитыДоставкиAMS(Форма, ТипДокумента);
КонецПроцедуры

Процедура ДобавитьКомандыПечатиAMS(Форма, Элементы, ТипДокумента)
	Если ТипДокумента = "AMS_ПередачаВПереработку" Тогда
		Возврат;
	КонецЕсли;
	
	Группа  = Элементы.Добавить("_Печать", Тип("ГруппаФормы"), Форма.КоманднаяПанель);
	Группа.Вид       = ВидГруппыФормы.Подменю;
	Группа.Заголовок = "Печать (AMS)";

	Команда = Форма.Команды.Добавить("AMS_КомандаПечатьЗаказКлиента");
	Команда.Заголовок = "Заказ клиента";
	Команда.Действие  = "Подключаемый_AMS_КомандаПечатьЗаказКлиента";

	Кнопка = Элементы.Добавить("AMS_КнопкаПечатьЗаказКлиента", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "AMS_КомандаПечатьЗаказКлиента";

	Команда = Форма.Команды.Добавить("_КомандаСчет");
	Команда.Заголовок = "Счёт на оплату";
	Команда.Действие  = "Подключаемый_AMS_Команда_ПечатьСчетНаОплату";

	Кнопка = Элементы.Добавить("_КнопкаСчет", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаСчет";

	Если ТипДокумента = "ЗаказКлиента" Тогда
		Возврат;
	
	ИначеЕсли ТипДокумента = "ОтгрузкаТоваровКлиенту" Тогда
		Возврат;
	
	ИначеЕсли ТипДокумента = "РеализацияТоваровУслуг" Тогда

	КонецЕсли;

	Команда = Форма.Команды.Добавить("_КомандаПечатьУПД");
	Команда.Заголовок = "УПД";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьУПД";

	Кнопка = Элементы.Добавить("_КнопкаПечатьУПД", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаПечатьУПД";

	Команда = Форма.Команды.Добавить("_КомандаПечатьСН");
	Команда.Заголовок = "Складская накладная";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьСкладскаяНакладная";

	Кнопка = Элементы.Добавить("_КнопкаПечатьСН", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаПечатьСН";

	Команда = Форма.Команды.Добавить("_КомандаДоверенность");
	Команда.Заголовок = "Доверенность";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьДоверенность";

	Кнопка = Элементы.Добавить("_КнопкаДоверенность", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаДоверенность";

	Если AMS_ВызовСервера.ЭтоЧугункова() Или AMS_ВызовСервера.ЭтоKhors() Тогда
		Команда           = Форма.Команды.Добавить("_КомандаТН");
		Команда.Заголовок = "Транспортная накладная";
		Команда.Действие  = "Подключаемый_амсКоманда_ПечатьТН";

		Кнопка            = Элементы.Добавить("_КнопкаТН", Тип("КнопкаФормы"), Элементы._Печать);
		Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
		Кнопка.ИмяКоманды = "_КомандаТН";
	КонецЕсли;

	Команда = Форма.Команды.Добавить("_КомандаТТН");
	Команда.Заголовок = "Товарно-транспортная накладная (1-Т)";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьТТН";

	Кнопка = Элементы.Добавить("_КнопкаТТН", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаТТН";

	Команда = Форма.Команды.Добавить("_КомандаТОРГ12");
	Команда.Заголовок = "Товарная накладная (ТОРГ-12)";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьТОРГ12";

	Кнопка = Элементы.Добавить("_КнопкаТОРГ12", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаТОРГ12";

	Команда = Форма.Команды.Добавить("_КомандаСчетФактура");
	Команда.Заголовок = "Счет фактура";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьСчетФактура";

	Кнопка = Элементы.Добавить("_КнопкаСчетФактура", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаСчетФактура";

	Команда = Форма.Команды.Добавить("_КомандаАктаОРасхождениях");
	Команда.Заголовок = "Акта о расхождениях товаров";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьАктаОРасхождениях";

	Кнопка = Элементы.Добавить("_КнопкаАктаОРасхождениях", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаАктаОРасхождениях";

	Команда = Форма.Команды.Добавить("_КомандаПалетнаяЭтикетка");
	Команда.Заголовок = "Палетная этикетка";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьПалетнаяЭтикетка";

	Кнопка = Элементы.Добавить("_КнопкаПалетнаяЭтикетка", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаПалетнаяЭтикетка";

	Команда = Форма.Команды.Добавить("_КомандаЗаявкаПеревозчику");
	Команда.Заголовок = "Заявка перевозчику";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьЗаявкаПеревозчику";

	Кнопка = Элементы.Добавить("_КнопкаЗаявкаПеревозчику", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаЗаявкаПеревозчику";

	Команда = Форма.Команды.Добавить("_КомандаСертификатыНоменклатурыРеестр");
	Команда.Заголовок = "Сертификаты (реестр)";
	Команда.Действие  = "Подключаемый_амс_ПечатьСертификатыНоменклатурыРеестр";

	Кнопка = Элементы.Добавить("_КнопкаСертификатыНоменклатурыРеестр", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаСертификатыНоменклатурыРеестр";

	Команда = Форма.Команды.Добавить("_КомандаСертификатыНоменклатурыБезДублей");
	Команда.Заголовок = "Сертификаты (по одному на сертификат)";
	Команда.Действие  = "Подключаемый_амс_ПечатьСертификатыНоменклатурыБезДублей";

	Кнопка = Элементы.Добавить("_КнопкаСертификатыНоменклатурыБезДублей", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаСертификатыНоменклатурыБезДублей";
	
	Команда = Форма.Команды.Добавить("_КомандаНакладнаяНаПалеты");
	Команда.Заголовок = "Накладная на палеты";
	Команда.Действие  = "Подключаемый_амс_ПечатьНакладнаяНаПалеты";

	Кнопка = Элементы.Добавить("_КнопкаНакладнаяНаПалеты", Тип("КнопкаФормы"), Элементы._Печать);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаНакладнаяНаПалеты";
	
	ГруппаКоманд = Элементы.Добавить("_ГруппаКнопокЭкспорт", Тип("ГруппаФормы"), Элементы._Печать);
	ГруппаКоманд.Вид = ВидГруппыФормы.ГруппаКнопок;

	Команда = Форма.Команды.Добавить("_КомандаПечатьУпаковочныйЛист");
	Команда.Заголовок = "Упаковочный лист";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьУпаковочныйЛист";

	Кнопка = Элементы.Добавить("_КнопкаПечатьУпаковочныйЛист", Тип("КнопкаФормы"), Элементы._ГруппаКнопокЭкспорт);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаПечатьУпаковочныйЛист";

	Команда = Форма.Команды.Добавить("_КомандаСпецификация");
	Команда.Заголовок = "Спецификация товаров";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьСпецификация";

	Кнопка = Элементы.Добавить("_КнопкаСпецификация", Тип("КнопкаФормы"), Элементы._ГруппаКнопокЭкспорт);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаСпецификация";

	Команда = Форма.Команды.Добавить("_КомандаСпецификацияЭкспотр");
	Команда.Заголовок = "Спецификация товаров (экспорт)";
	Команда.Действие  = "Подключаемый_амсКоманда_ПечатьСпецификацияЭкспорт";

	Кнопка = Элементы.Добавить("_КнопкаСпецификацияЭкспорт", Тип("КнопкаФормы"), Элементы._ГруппаКнопокЭкспорт);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = "_КомандаСпецификацияЭкспотр";
КонецПроцедуры

Процедура ДобавитьРеквизитыAMS(Форма, Элементы, ТипДокумента)
	Если ТипДокумента = "РеализацияТоваровУслуг" Тогда
		Элемент = Элементы.Добавить("AMS_СтатусРеализации", Тип("ПолеФормы"), Элементы.ГруппаСтатус);
		Элемент.ПутьКДанным              = "Объект.AMS_СтатусРеализации";
		Элемент.Заголовок                = "Статус (AMS)";
		Элемент.Вид                      = ВидПоляФормы.ПолеВвода;
		Элемент.Ширина                   = 15;
		Элемент.РастягиватьПоГоризонтали = Ложь;
		Элемент.РежимВыбораИзСписка      = Истина;
		МассивЗначенией = Новый Массив;
		МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.Заказ);
		МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.Стикерование);
		МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.КОтгрузке);
		Если Пользователи.РолиДоступны("_Бухгалтер") Тогда
			МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.Отгружено);
			МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.ОтгруженоПоРаспискеЭкспедитора);
			МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.ОтгруженоПоСканДов_УПД);
			МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.ОтгруженоПоСканДов);
			МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.ОтгруженоПоДов);
			МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.ОтгруженоПоУПД);
			МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.Закрыта);
			МассивЗначенией.Добавить(Перечисления.AMS_СтатусыРеализаций.ЗакрытаБезДоверенности);
		КонецЕсли;
		Элемент.СписокВыбора.ЗагрузитьЗначения(МассивЗначенией);
		Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_AMS_ПриИзменении_СтатусРеализации");

		Элемент = Элементы.Добавить("AMS_ДатаОтгрузки", Тип("ПолеФормы"), Элементы.ГруппаСтатус);
		Элемент.ПутьКДанным = "Объект.AMS_ДатаОтгрузки";
		Элемент.Вид         = ВидПоляФормы.ПолеВвода;
		Элемент.Заголовок   = "Дата получения (приемки)";

		Элемент = Элементы.Добавить("AMS_ЭДО", Тип("ПолеФормы"), Элементы.ГруппаСтатус);
		Элемент.ПутьКДанным        = "Объект.AMS_ЭДО";
		Элемент.Вид                = ВидПоляФормы.ПолеФлажка;
		Элемент.Заголовок          = "ЭДО подписан";
		Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
	КонецЕсли;
	
	Если ТипДокумента = "ЗаказКлиента" Тогда
		Элемент = Элементы.Вставить("AMS_ДатаОтгрузки", Тип("ПолеФормы"), Элементы.ГруппаСтатусПриоритет, Элементы.Приоритет);
