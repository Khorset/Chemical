		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

		Если Объект.Дата > '20260318' Тогда
			Элемент = Элементы.Добавить("AMS_ДокументРеализации", Тип("ПолеФормы"), Элементы.AMS_ГруппаСвязанныеДокументы);
			Элемент.ПутьКДанным        = "Объект.AMS_ДокументРеализации";
			Элемент.Вид                = ВидПоляФормы.ПолеВвода;
			Элемент.Заголовок          = "Продажа себе";
			Элемент.Ширина             = 20;
			Если Не Пользователи.РолиДоступны("_ГлавныйБухгалтер") И Объект.AMS_УтвержденаОтгрузка Тогда
				Элемент.ТолькоПросмотр = Истина;
				Элемент.КнопкаВыбора   = Ложь;
			КонецЕсли;

			Элемент = Элементы.Добавить("AMS_ДокументПриобретение", Тип("ПолеФормы"), Элементы.AMS_ГруппаСвязанныеДокументы);
			Элемент.ПутьКДанным        = "Объект.AMS_ДокументПриобретение";
			Элемент.Вид                = ВидПоляФормы.ПолеВвода;
			Элемент.Заголовок          = "Закупка у себя";
			Элемент.Ширина             = 20;
			Если Не Пользователи.РолиДоступны("_ГлавныйБухгалтер") И Объект.AMS_УтвержденаОтгрузка Тогда
				Элемент.ТолькоПросмотр = Истина;
				Элемент.КнопкаВыбора   = Ложь;
			КонецЕсли;
		КонецЕсли;
		
//		Элемент = Элементы.Добавить("AMS_ПередачаТоваровМеждуОрганизациями", Тип("ПолеФормы"), Элементы.AMS_ГруппаДополнительнаяИнформация);
//		Элемент.ПутьКДанным        = "AMS_ПередачаТоваровМеждуОрганизациями";
//		Элемент.Вид                = ВидПоляФормы.ПолеВвода;
//		Элемент.Заголовок          = "Передача товаров";
//		Элемент.Ширина             = 55;
//		Если Не AMS_ВызовСервера.ЭтоKhors() Тогда
//			Элемент.ТолькоПросмотр = Истина;
//			Элемент.КнопкаВыбора   = Ложь;
//		КонецЕсли;
	КонецЕсли;

	Элемент = Элементы.Добавить("AMS_ПартнерДопИнфо", Тип("ПолеФормы"), Элементы.AMS_ГруппаДополнительнаяИнформация);
	Элемент.ПутьКДанным        = "AMS_ПартнерДопИнфо";
	Элемент.Вид                = ВидПоляФормы.ПолеВвода;
	Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	Элемент.Ширина             = 86;
