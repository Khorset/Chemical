Процедура ПередЗаписьюНаСервереПоступлениеБезналичныхДенежныхСредств(Отказ, ТекущийОбъект, ПараметрыЗаписи) Экспорт
	Если ТекущийОбъект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПрочееПоступлениеДенежныхСредств Тогда
		Возврат;
	КонецЕсли;
	
	//Если Контрагент платит за несколько Партнеров, то Возврат
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Родитель", ТекущийОбъект.Контрагент.Партнер);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Партнеры.Ссылка
	|ИЗ
	|	Справочник.Партнеры КАК Партнеры
	|ГДЕ
	|	Партнеры.Родитель = &Родитель";
	Если Не Запрос.Выполнить().Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	//Выполнить проверку заполнения Основания платежа
	Табл = ТекущийОбъект.РасшифровкаПлатежа;

	КолСтр = Табл.Количество();

	Если КолСтр = 1 Тогда
		Если ЗначениеЗаполнено(ТекущийОбъект.Договор) Или ЗначениеЗаполнено(Табл[0].ОснованиеПлатежа) Тогда
			//это хорошо - продолжаем запись
		Иначе
			Текст = "Не заполнено ""Основание платежа"" или ""Договор"".";
			ОбщегоНазначения.СообщитьПользователю(Текст, , , , Отказ);
		КонецЕсли;

	Иначе
		Для Каждого Стр Из Табл Цикл
			Если Не ЗначениеЗаполнено(Стр.ОснованиеПлатежа) Тогда
				Текст = "В строке №" + Стр.НомерСтроки + " не заполнено ""Основание платежа"".";
				ОбщегоНазначения.СообщитьПользователю(Текст, , , , Отказ);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ПодпискиНаСобытия

Процедура ОбработкаЗаполненияСправочников(Источник, ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка) Экспорт
	ИмяДок = Источник.Метаданные().Имя;

	Если ИмяДок = "ДоговорыКонтрагентов" Тогда
		Если ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
			ОбработкаЗаполненияДоговорыКонтрагентов(Источник, ДанныеЗаполнения);
		КонецЕсли;

	ИначеЕсли ИмяДок = "СоглашенияСКлиентами" Тогда
		ОбработкаЗаполненияСоглашенияСКлиентами(Источник);

	ИначеЕсли ИмяДок = "СоглашенияСПоставщиками" Тогда
		ОбработкаЗаполненияСоглашенияСПоставщиками(Источник);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура НастройкаФормыПечатьДокументов(Форма, ИмяМакета) Экспорт
	ДобавляемыеРеквизиты = Новый Массив;
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИмяМакета", Новый ОписаниеТипов("Строка")));

	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

	Форма.ИмяМакета = ИмяМакета;
КонецПроцедуры

Процедура ПолучитьДанныеНаОснованииСКД(СКД, Таб, Настройки, Парам, Расшифровка = Неопределено,
	МакетКомпоновки = Неопределено, ВнешниеНаборыДанных = Неопределено) Экспорт
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Если ТипЗнч(Таб) = Тип("ТабличныйДокумент") Тогда
		ТипГенератора = Тип("ГенераторМакетаКомпоновкиДанных");
	Иначе
		ТипГенератора = Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений");
	КонецЕсли;

	Если Настройки = Неопределено Тогда
		Настройки = СКД.НастройкиПоУмолчанию;
	КонецЕсли;

	Если Парам <> Неопределено Тогда
		КоллекцияЗначенийПараметров = Настройки.ПараметрыДанных.Элементы;
		Для Каждого Параметр Из Парам Цикл
			НайденноеЗначениеПараметра = КоллекцияЗначенийПараметров.Найти(Параметр.Ключ);
			Если НайденноеЗначениеПараметра <> Неопределено Тогда
				НайденноеЗначениеПараметра.Использование = Истина;
				НайденноеЗначениеПараметра.Значение = Параметр.Значение;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	МакетКомпоновкиСКД = КомпоновщикМакета.Выполнить(СКД, Настройки, Расшифровка, МакетКомпоновки, ТипГенератора);

	ПроцессорКомпановки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпановки.Инициализировать(МакетКомпоновкиСКД, ВнешниеНаборыДанных, Расшифровка);

	Если ТипЗнч(Таб) = Тип("ТабличныйДокумент") Тогда
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
		ПроцессорВывода.УстановитьДокумент(Таб);
	Иначе
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		ПроцессорВывода.УстановитьОбъект(Таб);
	КонецЕсли;

	ПроцессорВывода.ОтображатьПроцентВывода = Истина;
	ПроцессорВывода.Вывести(ПроцессорКомпановки, Истина);
КонецПроцедуры

Процедура ЗаписатьДокумент(Документ, РежимЗаписи, Отказ = Ложь, СообщитьОбОшибке = Истина, СообщитьОВыполнении = Ложь) Экспорт
	Если СтрНайти(Строка(ТипЗнч(Документ)), "Документ объект") = 0 Тогда //это ссылка 
		//@skip-check unknown-method-property
		ДокументОбъект = Документ.ПолучитьОбъект();
	Иначе
		ДокументОбъект = Документ;
	КонецЕсли;

	СинонимДок = ДокументОбъект.Метаданные().Синоним;
	НоменДок   = ДокументОбъект.Номер;
	СтрокаДок  = СинонимДок + " № " + ?(ПустаяСтрока(НоменДок), " ... ", НоменДок) + " от " + Формат(
		ДокументОбъект.Дата, "ДФ=dd.MM.yyyy") + " г.";

	Попытка
		ДокументОбъект.Записать(РежимЗаписи);

		Если СообщитьОВыполнении Тогда
			Если РежимЗаписи = РежимЗаписиДокумента.Запись Тогда
				Вариант = "Документа " + СтрокаДок + " записан!";
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
				Вариант = "Документ " + СтрокаДок + " проведен!";
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				Вариант = "У документа " + СтрокаДок + " отменено проведение!";
			КонецЕсли;
			ОбщегоНазначения.СообщитьПользователю(Вариант, ДокументОбъект);
		КонецЕсли;

	Исключение
		Отказ = Истина;

		Если СообщитьОбОшибке Тогда
			Если РежимЗаписи = РежимЗаписиДокумента.Запись Тогда
				Вариант = "Документа " + СтрокаДок + " не удалось записать!";
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
				Вариант = "Документ " + СтрокаДок + " не проведен!";
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				Вариант = "У документа " + СтрокаДок + " не удалось отменить проведение!";
			КонецЕсли;

			ОбщегоНазначения.СообщитьПользователю(Вариант + " Ошибка: " + ОписаниеОшибки(), ДокументОбъект);
		КонецЕсли;
	КонецПопытки;
КонецПроцедуры

Процедура УстановитьПометкуУдаленияДокументу(Документ, Пометка, Отказ = Ложь, СообщитьОбОшибке = Истина,
	СообщитьОВыполении = Ложь) Экспорт
	Если СтрНайти(Строка(ТипЗнч(Документ)), "Документ объект") = 0 Тогда //это ссылка 
		ДокументОбъект = Документ.ПолучитьОбъект();
	Иначе
		ДокументОбъект = Документ;
	КонецЕсли;

	СинонимДок = ДокументОбъект.Метаданные().Синоним;
	НоменДок   = ДокументОбъект.Номер;
	СтрокаДок  = "«" + СинонимДок + " № " + ?(ПустаяСтрока(НоменДок), " ... ", НоменДок) + " от " + Формат(
		ДокументОбъект.Дата, "ДФ=dd.MM.yyyy") + " г.»";

	Попытка
		Если ДокументОбъект.Модифицированность() Тогда
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;

		ДокументОбъект.УстановитьПометкуУдаления(Пометка);

		Если СообщитьОВыполении Тогда
			Если Пометка = Истина Тогда
				Вариант = "Документ " + СтрокаДок + " помечен на удаление!";
			Иначе
				Вариант = "У документа " + СтрокаДок + " снята пометка на удаление!";
			КонецЕсли;
			ОбщегоНазначения.СообщитьПользователю(Вариант);
		КонецЕсли;

	Исключение
		Если СообщитьОбОшибке Тогда
			Если Пометка = Истина Тогда
				Вариант = "У документ " + СтрокаДок + " не удалось установить пометку на удаление!";
			Иначе
				Вариант = "У документа " + СтрокаДок + " не удалось снять пометку на удаление!";
			КонецЕсли;
			ОбщегоНазначения.СообщитьПользователю(Вариант + " Ошибка: " + ОписаниеОшибки(), , , , Отказ);
		КонецЕсли;
	КонецПопытки;
КонецПроцедуры

#Область ПроцедурыОбработкиЗаполненияСправочников

Процедура ОбработкаЗаполненияДоговорыКонтрагентов(Источник, ДанныеЗаполнения)
	УстановитьПривилегированныйРежим(Истина);

	ЗаполнитьЗначенияСвойств(Источник, ДанныеЗаполнения);

	Источник.Статус                = Перечисления.СтатусыДоговоровКонтрагентов.НеСогласован;
	Источник.Организация           = AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию();
	Стр = AMS_ВызовСервера.ПолучитьНаименованиеДоговора(Источник.Номер, Источник.Дата, Источник.Организация,
		Источник.Партнер, Источник.Контрагент, Источник.ТипДоговора, Источник.Наименование);
	Источник.Наименование          = Стр.Наименование;
	Источник.НаименованиеДляПечати = Стр.НаименованиеДляПечати;
	Источник.Подразделение         = AMS_ВызовСервера.ПодразделениеПроизводство();
	Источник.ПорядокРасчетов       = Перечисления.ПорядокРасчетов.ПоНакладным;
	Источник.СтавкаНДС             = Перечисления.СтавкиНДС.НДС20;

	Если Источник.ТипДоговора = Перечисления.ТипыДоговоров.СПокупателем Тогда
		Источник.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ПоступлениеОплатыОтКлиента;
	ИначеЕсли Источник.ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
		Источник.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ОплатаПоставщику;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполненияСоглашенияСКлиентами(Источник)
	Если Источник.Типовое Тогда
		Возврат;
	КонецЕсли;

	УстановитьПривилегированныйРежим(Истина);

	Партнер = Источник.Партнер;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(т.Ссылка) КАК Количество
	|ИЗ
	|	Справочник.СоглашенияСКлиентами КАК т
	|ГДЕ
	|	т.Партнер = &Партнер
	|	И НЕ т.Типовое";
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Номер = "1";
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Номер = Строка(Выборка.Количество + 1);
	КонецЕсли;

	Дата = ТекущаяДатаСеанса();

	ПартнерНаименование     = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Партнер, "Наименование");
	ОрганизацияНаименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Организация, "Наименование");
	
	Источник.Статус = ПредопределенноеЗначение("Перечисление.СтатусыСоглашенийСКлиентами.НеСогласовано");
	
	Источник.Организация                      = AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию();
	Источник.Наименование                     = СокрЛП(ПартнерНаименование) + " с " + СокрЛП(ОрганизацияНаименование);
	Источник.Номер                            = Номер;
	Источник.Дата                             = Дата;
	Источник.ДатаНачалаДействия               = Дата;
	Источник.ИспользуютсяДоговорыКонтрагентов = Истина;
	Источник.СтатьяДвиженияДенежныхСредств    = Справочники.СтатьиДвиженияДенежныхСредств.ПоступлениеОплатыОтКлиента;
КонецПроцедуры

Процедура ОбработкаЗаполненияСоглашенияСПоставщиками(Источник)
	УстановитьПривилегированныйРежим(Истина);

	Партнер = Источник.Партнер;

	Если Не ЗначениеЗаполнено(Партнер) Тогда
		Возврат;
	КонецЕсли;

	Валюта                  = Константы.ВалютаРегламентированногоУчета.Получить();
	ПартнерНаименование     = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Партнер, "Наименование");
	ОрганизацияНаименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Организация, "Наименование");

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(СоглашенияСПоставщиками.Ссылка) КАК Количество
	|ИЗ
	|	Справочник.СоглашенияСПоставщиками КАК СоглашенияСПоставщиками
	|ГДЕ
	|	СоглашенияСПоставщиками.Партнер = &Партнер";
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Источник.Номер = "1";
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Источник.Номер = Строка(Выборка.Количество + 1);
	КонецЕсли;

	Источник.Дата                             = ТекущаяДатаСеанса();
	Источник.Наименование                     = СокрЛП(ПартнерНаименование) + " с " + СокрЛП(ОрганизацияНаименование);
	Источник.ДатаНачалаДействия               = ТекущаяДатаСеанса();
	Источник.Валюта                           = Валюта;
	Источник.ЦенаВключаетНДС                  = Истина;
	Источник.ФормаОплаты                      = Перечисления.ФормыОплаты.Безналичная;
	Источник.РегистрироватьЦеныПоставщика     = Истина;
	Источник.ИспользуютсяДоговорыКонтрагентов = Истина;
	Источник.ПорядокРасчетов                  = Перечисления.ПорядокРасчетов.ПоНакладным;
	Источник.СтатьяДвиженияДенежныхСредств    = Справочники.СтатьиДвиженияДенежныхСредств.ОплатаПоставщику;
	
	//ВидЦеныПоставщика
	ВидЦеныПоставщикаНаименование = ПартнерНаименование;
	ВидЦеныПоставщика = Справочники.ВидыЦенПоставщиков.НайтиПоНаименованию(ВидЦеныПоставщикаНаименование, Истина);
	Если ЗначениеЗаполнено(ВидЦеныПоставщика) Тогда
		Источник.ВидЦеныПоставщика = ВидЦеныПоставщика;

	Иначе
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Владелец", Партнер);
		Запрос.Текст =
		"ВЫБРАТЬ
