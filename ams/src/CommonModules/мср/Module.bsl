Функция ПолучитьРабочийДень(ПорядковыйНомер, ДатаНачала = Неопределено) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Если ДатаНачала = Неопределено Тогда
		ДатаНачала = НачалоДня(ТекущаяДатаСеанса());
	КонецЕсли;

	ПроизводственныйКалендарь = Справочники.Календари.НайтиПоНаименованию("Производственный календарь", Истина);

	Если ПорядковыйНомер = 0 Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Календарь", ПроизводственныйКалендарь);
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);

		Запрос.Текст =
		"ВЫБРАТЬ
		|	таб.ДатаГрафика КАК Дата
		|ИЗ
		|	РегистрСведений.КалендарныеГрафики КАК таб
		|ГДЕ
		|	таб.Календарь = &Календарь
		|	И таб.ДеньВключенВГрафик
		|	И таб.ДатаГрафика = &ДатаНачала";

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Неопределено;  //Это выходной день
		Иначе
			Выборка = Результат.Выбрать();
			Выборка.Следующий();
			Возврат Выборка.Дата;
		КонецЕсли;

	ИначеЕсли ПорядковыйНомер > 0 Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Календарь", ПроизводственныйКалендарь);
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);

		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ " + Строка(ПорядковыйНомер) +
		"
		|   таб.ДатаГрафика КАК Дата
		|ПОМЕСТИТЬ втРабДни
		|ИЗ
		|   РегистрСведений.КалендарныеГрафики КАК таб
		|ГДЕ
		|   таб.Календарь = &Календарь
		|   И таб.ДеньВключенВГрафик
		|   И таб.ДатаГрафика > &ДатаНачала
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|   МАКСИМУМ(Табл.Дата) КАК Дата
		|ИЗ
		|   втРабДни КАК Табл";

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Неопределено;
		Иначе
			Выборка = Результат.Выбрать();
			Выборка.Следующий();
			Возврат Выборка.Дата;
		КонецЕсли;

	ИначеЕсли ПорядковыйНомер < 0 Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Календарь", ПроизводственныйКалендарь);
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);

		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ " + Строка(-ПорядковыйНомер) +
		"
		|   таб.ДатаГрафика КАК Дата
		|ИЗ
		|   РегистрСведений.КалендарныеГрафики КАК таб
		|ГДЕ
		|   таб.Календарь = &Календарь
		|   И таб.ДеньВключенВГрафик
		|   И таб.ДатаГрафика < &ДатаНачала
		|
		|УПОРЯДОЧИТЬ ПО
		|   Дата УБЫВ";

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Возврат Неопределено;
		Иначе
			МассивДат = Результат.Выгрузить().ВыгрузитьКолонку("Дата");
			Возврат МассивДат[МассивДат.Количество() - 1];
		КонецЕсли;
	КонецЕсли;
КонецФункции

