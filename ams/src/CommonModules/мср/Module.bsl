	|ПОМЕСТИТЬ ЦенМ
	|ИЗ
	|	ПриходМесяц КАК ПриходМесяц
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПрочееОприходованиеТоваров.Товары КАК Приход
	|		ПО ПриходМесяц.Номенклатура = Приход.Номенклатура
	|			И ПриходМесяц.Период = Приход.Ссылка.Дата
	|ГДЕ
	|	Приход.Ссылка._ЭтапПроизводства = 2
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриходМесяц.КонецМесяца,
	|	ПриходМесяц.Номенклатура,
	|	ПриходМесяц.ПриходИзЦеха
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ост.ВидПродукции КАК ВидПродукции,
	|	Ост.ТипПродукции КАК ТипПродукции,
	|	Ост.Категория КАК Категория,
	|	Ост.Назначение КАК Назначение,
	|	Ост.Бренд КАК Бренд,
	|	Ост.СтатусТовара КАК СтатусТовара,
	|	Ост.Штрихкод КАК Штрихкод,
	|	Ост.Артикул КАК Артикул,
	|	Ост.Номенклатура КАК Номенклатура,
	|	Ост.КонецМесяца КАК КонецМесяца,
	|	ВЫРАЗИТЬ(ЦенМ.Стоимость КАК ЧИСЛО(10, 2)) КАК Стоимость,
	|	Ост.ОстатокШт КАК ОстатокШт,
	|	ВЫБОР
	|		КОГДА ЦенМ.Стоимость = 0
	|				ИЛИ Ост.ОстатокШт = 0
	|			ТОГДА 0
	|		ИНАЧЕ ЦенМ.Стоимость * Ост.ОстатокШт
	|	КОНЕЦ КАК ОстатокРуб,
	|	Ост.Склад КАК Склад,
	|	Ост.ДатаПроизводства КАК ДатаПроизводства,
	|	Ост.Серия КАК Серия,
	|	Ост.СкладНаименование КАК СкладНаименование,
	|	Ост.Наименование КАК Наименование
	|ПОМЕСТИТЬ ТоварМ
	|ИЗ
	|	Ост КАК Ост
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенМ КАК ЦенМ
	|		ПО Ост.Номенклатура = ЦенМ.Номенклатура
	|			И Ост.КонецМесяца = ЦенМ.КонецМесяца
	|ГДЕ
	|	Ост.ОстатокШт > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварМ.ВидПродукции КАК ВидПродукции,
	|	ТоварМ.ТипПродукции КАК ТипПродукции,
	|	ТоварМ.Категория КАК Категория,
	|	ТоварМ.Назначение КАК Назначение,
	|	ТоварМ.Бренд КАК Бренд,
	|	ТоварМ.СтатусТовара КАК СтатусТовара,
	|	ТоварМ.Штрихкод КАК Штрихкод,
	|	ТоварМ.Артикул КАК Артикул,
	|	ТоварМ.Номенклатура КАК Номенклатура,
	|	ТоварМ.КонецМесяца КАК КонецМесяца,
	|	ТоварМ.Стоимость КАК Стоимость,
	|	ТоварМ.ОстатокШт КАК ОстатокШт,
	|	ТоварМ.ОстатокРуб КАК ОстатокРуб,
	|	ТоварМ.Склад КАК Склад,
	|	ТоварМ.ДатаПроизводства КАК ДатаПроизводства,
	|	ТоварМ.Серия КАК Серия,
	|	ТоварМ.СкладНаименование КАК СкладНаименование,
	|	ТоварМ.Наименование КАК Наименование
	|ИЗ
	|	ТоварМ КАК ТоварМ
	|
	|УПОРЯДОЧИТЬ ПО
	|	СкладНаименование,
	|	Наименование,
	|	КонецМесяца
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Партнер КАК ГоловнойПартнер,
	|	т.СегментРынка КАК СегментРынка,
	|	т.ГруппаДоступа КАК ГруппаДоступа,
	|	т.Менеджер КАК ОсновнойМенеджер,
	|	т.Дата КАК ДатаРеализации,
	|	т.Сумма КАК ПланПродажРуб
	|ИЗ
	|	РегистрСведений.AMS_ПланыПродаж КАК т
	|ГДЕ
	|	т.Дата МЕЖДУ &ДатаНачала И КОНЕЦПЕРИОДА(&ДатаОкончания, МЕСЯЦ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Менеджер.Наименование,
	|	ДатаРеализации,
	|	т.Партнер.Наименование";
	
	Пакет = Запрос.ВыполнитьПакет();
	
	Возврат Новый Структура("ПродажиЗаПериод, ИтогиПоМесяцам, ПланыПродаж", Пакет[6], Пакет[15], Пакет[16]); 
КонецФункции

Функция РезультатЗапросаВыгрузкаОплат()
	СКД = Обработки.AMS_Продажи.ПолучитьМакет("скдВыгрузкаОплат");

	Табл = Новый ТаблицаЗначений();

	Организации = Новый Массив();
	Организации.Добавить(AMS_ВызовСервера.ОрганизацияКемикал());
	Организации.Добавить(AMS_ВызовСервера.ОрганизацияТрейд());
	Организации.Добавить(AMS_ВызовСервера.ОрганизацияТД());

	Парам = Новый Структура;
	Парам.Вставить("Организации", Организации);

	Данные = Новый Структура;
	Данные.Вставить("СКД", СКД);
	Данные.Вставить("Результат", Табл);
	Данные.Вставить("Параметры", Парам);

	AMS_ВызовСервера.ВыполнитьСКД(Данные);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Табл", Табл);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Табл.Дата КАК Дата,
		|	Табл.Заказ КАК Заказ,
		|	Табл.ГоловнойПартнер КАК ГоловнойПартнер,
		|	Табл.ДолгУвеличение КАК ДолгУвеличение,
		|	Табл.ДолгУменьшение КАК ДолгУменьшение,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(Табл.Заказ) В (ТИП(Документ.РеализацияТоваровУслуг), ТИП(Документ.ОтчетКомиссионера),
		|			ТИП(Документ.АктВыполненныхРабот))
		|			ТОГДА 1
		|		ИНАЧЕ 2
		|	КОНЕЦ КАК ТипДок
		|ПОМЕСТИТЬ Таб
		|ИЗ
		|	&Табл КАК Табл
		|ГДЕ
		|	ТИПЗНАЧЕНИЯ(Табл.Заказ) В (ТИП(Документ.РеализацияТоваровУслуг), ТИП(Документ.ОтчетКомиссионера),
		|		ТИП(Документ.АктВыполненныхРабот), ТИП(Документ.ПоступлениеБезналичныхДенежныхСредств),
		|		ТИП(Документ.ПриходныйКассовыйОрдер))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Таб.Заказ КАК Заказ,
		|	МАКСИМУМ(ЕСТЬNULL(ЭтапыРеал.ДатаПлатежа, ЕСТЬNULL(ЭтапыОтчет.ДатаПлатежа, ЭтапыАкт.ДатаПлатежа))) КАК ДатаПлатежа
		|ПОМЕСТИТЬ Оплаты
		|ИЗ
		|	Таб КАК Таб
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АктВыполненныхРабот.ЭтапыГрафикаОплаты КАК ЭтапыАкт
		|		ПО Таб.Заказ = ЭтапыАкт.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтчетКомиссионера.ЭтапыГрафикаОплаты КАК ЭтапыОтчет
		|		ПО Таб.Заказ = ЭтапыОтчет.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.ЭтапыГрафикаОплаты КАК ЭтапыРеал
		|		ПО Таб.Заказ = ЭтапыРеал.Ссылка
		|ГДЕ
		|	Таб.Заказ В
		|		(ВЫБРАТЬ
		|			т.Заказ КАК Заказ
		|		ИЗ
		|			Таб КАК т
		|		ГДЕ
		|			т.ТипДок = 1)
		|СГРУППИРОВАТЬ ПО
		|	Таб.Заказ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Таб.Дата КАК Дата,
		|	Таб.Заказ КАК Заказ,
		|	Таб.ГоловнойПартнер КАК ГоловнойПартнер,
		|	Партнеры.ОсновнойМенеджер КАК ОсновнойМенеджер,
		|	ВЫБОР
		|		КОГДА Оплаты.ДатаПлатежа ЕСТЬ NULL
		|		ИЛИ Оплаты.ДатаПлатежа = ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА Таб.Дата
		|		ИНАЧЕ Оплаты.ДатаПлатежа
		|	КОНЕЦ КАК ДатаПлатежа,
		|	ВЫБОР
		|		КОГДА Таб.ТипДок = 1
		|			ТОГДА Таб.ДолгУвеличение
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Всего,
		|	ВЫБОР
		|		КОГДА Таб.ТипДок = 1
		|			ТОГДА Таб.ДолгУменьшение
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Оплачено,
		|	ВЫБОР
		|		КОГДА Таб.ТипДок = 2
		|			ТОГДА Таб.ДолгУменьшение
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ПриходДС,
		|	Партнеры.Наименование КАК Наименование,
		|	Таб.ТипДок КАК ТипДок,
		|	Партнеры.ГруппаДоступа КАК ГруппаДоступа,
		|	Партнеры.AMS_СегментРынка КАК СегментРынка
		|ИЗ
		|	Таб КАК Таб
		|		ЛЕВОЕ СОЕДИНЕНИЕ Оплаты КАК Оплаты
		|		ПО Таб.Заказ = Оплаты.Заказ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
		|		ПО Таб.ГоловнойПартнер = Партнеры.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТипДок,
		|	Наименование,
		|	Дата";
	
	Возврат Запрос.Выполнить(); 
КонецФункции

#КонецОбласти

#Область ЗакрытиеСтарыхПартнеров

Процедура ЗакрытьСтарыхПартнеров() Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Ссылка КАК Партнер,
		|	т.Клиент КАК Клиент,
		|	т.Поставщик КАК Поставщик,
		|	т.ПрочиеОтношения КАК ПрочиеОтношения,
		|	т.Перевозчик КАК Перевозчик,
		|	т._Закрыт КАК Закрыт,
		|	т.ДатаРегистрации КАК ДатаРегистрации
		|ПОМЕСТИТЬ ВсеПарт
		|ИЗ
		|	Справочник.Партнеры КАК т
		|ГДЕ
		|	НЕ т.Предопределенный
		|	И т.ДатаРегистрации < ДОБАВИТЬКДАТЕ(&Дата, ГОД, -1)
		|	И НЕ т._Закрыт
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	т.Партнер КАК Партнер,
		|	МАКСИМУМ(т.ДатаДокументаИБ) КАК ДатаПоследнегоДокумента
		|ПОМЕСТИТЬ ДокПарт
		|ИЗ
		|	РегистрСведений.РеестрДокументов КАК т
		|ГДЕ
		|	т.ДатаДокументаИБ > ДОБАВИТЬКДАТЕ(&Дата, ГОД, -1)
		|	И т.Партнер В
		|		(ВЫБРАТЬ
		|			т.Партнер КАК Партнер
		|		ИЗ
		|			ВсеПарт КАК т)
		|СГРУППИРОВАТЬ ПО
		|	т.Партнер
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВсеПарт.Партнер КАК Партнер,
		|	ВсеПарт.Клиент КАК Клиент,
		|	ВсеПарт.Поставщик КАК Поставщик,
		|	ВсеПарт.ПрочиеОтношения КАК ПрочиеОтношения,
		|	ВсеПарт.Перевозчик КАК Перевозчик,
		|	ВсеПарт.Закрыт КАК Закрыт,
		|	ВсеПарт.ДатаРегистрации КАК ДатаРегистрации
		|ИЗ
		|	ВсеПарт КАК ВсеПарт
		|ГДЕ
		|	НЕ ВсеПарт.Партнер В
		|		(ВЫБРАТЬ
		|			ДокПарт.Партнер КАК Партнер
		|		ИЗ
		|			ДокПарт КАК ДокПарт)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаРегистрации";
	
	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	
	Пока Выб.Следующий() Цикл
		Партнер = Выб.Партнер.ПолучитьОбъект();
		Партнер._Закрыт = Истина;
		Партнер.Записать();
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

