
#Область СлужебныйПрограммныйИнтерфейс

#Область ПередЗаписьюНаСервере

Процедура ПередЗаписьюНаСервереДоговорыКонтрагентов(Объект, Отказ) Экспорт
	Договор = Объект;

	Если Договор.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;

	Если Договор.ТипДоговора = ОбщегоНазначения.ПредопределенныйЭлемент(
		"Перечисление.ТипыДоговоров.РеализацияЧерезКомиссионера") Тогда
		Возврат;
	КонецЕсли;
	
	//Номер
	Если ПустаяСтрока(Договор.Номер) Тогда
		ТекстОшибки = НСтр("ru='Поле ""Номер"" не заполнено.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.Номер", , Отказ);
	КонецЕсли; 
		
	//Дата
	Если Договор.Дата = Дата(1, 1, 1) Тогда
		ТекстОшибки = НСтр("ru='Поле ""Дата"" не заполнено.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.Дата", , Отказ);
	КонецЕсли; 
		
	//Наименование и Наименование для печати
	Если ПустаяСтрока(Объект.Наименование) Тогда
		Стр = AMS_ВызовСервера.ПолучитьНаименованиеДоговора(Объект.Номер, Объект.Дата, Объект.Организация, Объект.Партнер,
			Объект.Контрагент, Объект.ТипДоговора, Объект.Наименование);
		Объект.Наименование          = Стр.Наименование;
		Объект.НаименованиеДляПечати = Стр.НаименованиеДляПечати;
	КонецЕсли; 
	
	//Подразделение
	Если Не Договор.Подразделение = AMS_ВызовСервера.ПодразделениеПроизводство() Тогда
		Договор.Подразделение = AMS_ВызовСервера.ПодразделениеПроизводство();
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Договор.Менеджер) Тогда
		ТекстОшибки = НСтр("ru='Поле ""Менеджер"" не заполнено.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.Менеджер", , Отказ);
	КонецЕсли; 
		
	//Банковский счета
	Если Не Договор.Организация = Справочники.Организации.УправленческаяОрганизация Тогда
		//счёт организации
		Счёт = Договор.БанковскийСчет;
		Если ЗначениеЗаполнено(Счёт) Тогда
			Если Счёт.НомерСчета = "40901810100005171489" Или Счёт.НомерСчета = "40702810200000052602"
				Или Счёт.НомерСчета = "40702810700010510483" Тогда
				ТекстОшибки = НСтр("ru='В договоре указан запрещённый к использованию счёт организации.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.БанковскийСчет", , Отказ);
			КонецЕсли;
		Иначе
			ТекстОшибки = НСтр("ru='В договоре поле ""Счет организации"" не заполнено.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.БанковскийСчет", , Отказ);
		КонецЕсли;
		
		//счёт покупателя
		Счёт = Договор.БанковскийСчетКонтрагента;
		Если ЗначениеЗаполнено(Счёт) Тогда
			ИмяСчёта = Лев(Прав(СокрЛП(Счёт.НомерСчета), 4) + ?(ЗначениеЗаполнено(Счёт.Банк), " в " + Строка(
				Счёт.Банк), "") + " (" + Строка(Счёт.ВалютаДенежныхСредств) + ")", 150);
			Если СтрНайти(Счёт.Наименование, ИмяСчёта) = 0 Тогда
				СчётОбъект = Счёт.ПолучитьОбъект();
				СчётОбъект.Наименование = ИмяСчёта;
				СчётОбъект.Записать();
			КонецЕсли;

		Иначе
			Если Не (Договор.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо
				Или Договор.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицоНеРезидент) Тогда
				ТекстОшибки = НСтр("ru='В договоре поле ""Счет покупателя"" не заполнено.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.БанковскийСчетКонтрагента", , Отказ);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли; 
	
	//Проверка соответствия контрагента покупателю
	ПартнерДоговора                        = Договор.Партнер;
	ГоловноеПредприятиеПартнераДоговора    = ПартнерДоговора.Родитель;

	КонтрагентДоговора                     = Договор.Контрагент;
	ПартнерКонтрагента                     = КонтрагентДоговора.Партнер;
	ГоловноеПредприятиеПартнераКонтрагента = ПартнерКонтрагента.Родитель;

	Если Не (ПартнерДоговора = ПартнерКонтрагента Или ПартнерКонтрагента = ГоловноеПредприятиеПартнераДоговора
		Или ПартнерДоговора = ГоловноеПредприятиеПартнераКонтрагента) Тогда
		Если Договор.ТипДоговора = Перечисления.ТипыДоговоров.СПокупателем Тогда
			Клиент = "Покупатель";
		ИначеЕсли Договор.ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
			Клиент = "Поставщик";
		КонецЕсли;

		ТекстОшибки = НСтр(
			"ru='В договоре в поле ""%Клиент%"" должен быть указан партнёр контрагента ""%ПартнерКонтрагента%"".'");
		ТекстОшибки =  СтрЗаменить(ТекстОшибки, "%Клиент%", Клиент);
		ТекстОшибки =  СтрЗаменить(ТекстОшибки, "%ПартнерКонтрагента%", ПартнерКонтрагента);

		Если ЗначениеЗаполнено(ГоловноеПредприятиеПартнераКонтрагента) Тогда
			ТекстОшибки = ТекстОшибки + НСтр("ru=' Или головное предприятие партнёра - ""%ГоловноеПредприятие%"".'");
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ГоловноеПредприятие%", ГоловноеПредприятиеПартнераКонтрагента);
		КонецЕсли;

		ТекстОшибки = ТекстОшибки + НСтр("ru=' Или неправильно выбран контрагент (не имеет отношений с партнёром).'");

		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.Контрагент", , Отказ);
	КонецЕсли;
	
	//Детализация расчетов
	Если Не Договор.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоНакладным Тогда
		Договор.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоНакладным;
	КонецЕсли;
	
	//Статья ДДС
	ТипДоговора = Договор.ТипДоговора;
	Если Не ЗначениеЗаполнено(Договор.СтатьяДвиженияДенежныхСредств) Тогда
		Если ТипДоговора = Перечисления.ТипыДоговоров.СПокупателем Тогда
			Договор.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ПоступлениеОплатыОтКлиента;

		ИначеЕсли ТипДоговора = Перечисления.ТипыДоговоров.СПоставщиком Тогда
			Договор.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ОплатаПоставщику;
		КонецЕсли;
	КонецЕсли;
	
	//Ставка НДС для платежей
	Если Не ЗначениеЗаполнено(Договор.СтавкаНДС) Тогда
		Договор.СтавкаНДС = Перечисления.СтавкиНДС.НДС20;
	КонецЕсли;
КонецПроцедуры
Процедура ПередЗаписьюНаСервереНоменклатура(Объект, Отказ) Экспорт
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат;
	КонецЕсли;

	Номенклатура = Объект;

	Если AMS_ВызовСервера.ЭтоПродукцияAMS(Номенклатура) Тогда
		Если Не ЗначениеЗаполнено(Номенклатура.Производитель) Тогда
			ОбщегоНазначения.СообщитьПользователю("Не заполнено поле ""Производитель (бренд)"".", ,
				"Объект.Производитель", , Отказ);
		КонецЕсли;

		Если Не ЗначениеЗаполнено(Номенклатура.ЦеноваяГруппа) Тогда
			ОбщегоНазначения.СообщитьПользователю("Не заполнено поле ""Ценовая группа"".", , "Объект.ЦеноваяГруппа", ,
				Отказ);
		КонецЕсли;

		Если Не Номенклатура.ВидНоменклатуры = AMS_ВызовСервера.ВидНоменклатурыПродукцияНаборы()
			И Не ЗначениеЗаполнено(Номенклатура._Упаковка) И Не AMS_ВызовСервера.ЭтоKhors() Тогда
			ОбщегоНазначения.СообщитьПользователю("Не заполнено поле ""Упаковка"".", , "Объект._Упаковка", , Отказ);
		КонецЕсли;

		Если Номенклатура._ИспользуетФабрикат Тогда
			Если Не ЗначениеЗаполнено(Номенклатура._Фабрикат) Тогда
				ОбщегоНазначения.СообщитьПользователю("Не заполнено поле ""Фабрикат"".", , "Объект._Фабрикат", , Отказ);
			КонецЕсли;

			Если Не Номенклатура._КоличествоФабрикатаВУпаковке > 0 Тогда
				ОбщегоНазначения.СообщитьПользователю("Не заполнено поле ""Количество в упаковке"".", ,
					"Объект._КоличествоФабрикатаВУпаковке", , Отказ);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
Процедура ПередЗаписьюНаСервереСоглашенияСКлиентами(Объект, Отказ) Экспорт
	Соглашение = Объект;

	Если Соглашение.Типовое Тогда
		Возврат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Соглашение.Организация) Тогда
		ТекстОшибки = НСтр("ru='Не заполнено поле ""Организация"".'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.Организация", , Отказ);
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Соглашение.ГрафикОплаты) Тогда
		ТекстОшибки = НСтр("ru='В условиях продажи не заполнено поле ""График оплаты"".'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.ГрафикОплаты", , Отказ);
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Соглашение.ВидЦен) Тогда
		ТекстОшибки = НСтр("ru='В условиях продажи не заполнено поле ""Вид цен"".'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.ВидЦен", , Отказ);
	КонецЕсли;

	Наименование = СокрЛП(Соглашение.Партнер.Наименование) + " с " + СокрЛП(Соглашение.Организация.Наименование);
	Если СтрНайти(Соглашение.Наименование, Наименование) = 0 Тогда
		Соглашение.Наименование = Наименование;
	КонецЕсли;

	Если Не Пользователи.РолиДоступны("_Бухгалтер") И Не Соглашение.Склад = AMS_ВызовСервера.СкладПродукции() Тогда
		Соглашение.Склад = AMS_ВызовСервера.СкладПродукции();
	КонецЕсли;

	Если Не Соглашение.СтатьяДвиженияДенежныхСредств
		= Справочники.СтатьиДвиженияДенежныхСредств.ПоступлениеОплатыОтКлиента Тогда
		Соглашение.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ПоступлениеОплатыОтКлиента;
	КонецЕсли; 
		
	//Проверка соответствия контрагента клиенту
	Если ЗначениеЗаполнено(Соглашение.Партнер) И ЗначениеЗаполнено(Соглашение.Контрагент) Тогда
		ПартнерДоговора                        = Соглашение.Партнер;
		ГоловноеПредприятиеПартнераДоговора    = ПартнерДоговора.Родитель;

		КонтрагентДоговора                     = Соглашение.Контрагент;
		ПартнерКонтрагента                     = КонтрагентДоговора.Партнер;
		ГоловноеПредприятиеПартнераКонтрагента = ПартнерКонтрагента.Родитель;

		Если Не (ПартнерДоговора = ПартнерКонтрагента Или ПартнерКонтрагента = ГоловноеПредприятиеПартнераДоговора
			Или ПартнерДоговора = ГоловноеПредприятиеПартнераКонтрагента) Тогда

			ТекстОшибки = НСтр(
				"ru='В договоре поле ""Клиент"" должен быть указан партнёр контрагента ""%ПартнерКонтрагента%"".'");
			ТекстОшибки =  СтрЗаменить(ТекстОшибки, "%ПартнерКонтрагента%", ПартнерКонтрагента);

			Если ЗначениеЗаполнено(ГоловноеПредприятиеПартнераКонтрагента) Тогда
				ТекстОшибки = ТекстОшибки + НСтр("ru=' или головное предприятие партнёра - ""%ГоловноеПредприятие%"".'");
				ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ГоловноеПредприятие%", ГоловноеПредприятиеПартнераКонтрагента);
			КонецЕсли;

			ТекстОшибки = ТекстОшибки + НСтр(
				"ru=' или неправильно выбран контрагент (не имеет отношений с партнёром).'");

			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ПередЗаписьюНаСервереЗаявкаНаВозвратТоваровОтКлиента(Отказ, ТекущийОбъект, ПараметрыЗаписи) Экспорт
	РазрешеноПроведение = Пользователи.РолиДоступны("_Директор,_СтаршийМенеджер,_СтаршийМенеджерМЕГА")
		Или AMS_ВызовСервера.ЭтоKhors();

	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение И Не ТекущийОбъект.Проведен
		И Не РазрешеноПроведение Тогда

		ТекстСообщения = НСтр("ru = 'Проведение документа разрешено старшему менеджеру продаж.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Отказ);
	КонецЕсли;
КонецПроцедуры
