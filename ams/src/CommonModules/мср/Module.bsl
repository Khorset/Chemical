Процедура ДобавитьКомандыПечати(КомандыПечати, ИмяМакета) Экспорт
	Если ИмяМакета = "СличительнаяВедомость" Тогда
		КомандаПечати = КомандыПечати.Добавить();
		КомандаПечати.МенеджерПечати = "Обработка.AMS_Продажи";
		КомандаПечати.Идентификатор = ИмяМакета;
		КомандаПечати.Представление = НСтр("ru = 'Сличительная ведомость (АМС)'");
		КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункцииПереопределяемый

//@skip-check method-too-many-params
//@skip-check doc-comment-parameter-section
Процедура AMSУстановитьДействиеФормы(Форма, ИмяСобытия = "", ИмяЭлементаФормы = "", ЛиИсключительное = Ложь, ПсевдонимЭлементаФормы = "") Экспорт
    
    Если ИмяЭлементаФормы <> "" Тогда
        МассивФрагментов = AMSПолучитьМассивИзСтрокиСРазделителем(ИмяЭлементаФормы);
        ИмяЭлементаФормы = МассивФрагментов[0];
        Объект = Форма.ЭлементыФормы[ИмяЭлементаФормы];
        
        Если МассивФрагментов.Количество() > 1 Тогда 
            ИмяЭлементаФормы = ИмяЭлементаФормы + МассивФрагментов[1];
            
            Если ТипЗнч(Объект) = Тип("ТабличноеПоле") Тогда 
                //@skip-check bsl-legacy-check-dynamic-feature-access
                Объект = Объект.Колонки[МассивФрагментов[1]].ЭлементУправления;
            ИначеЕсли ТипЗнч(Объект) = Тип("КоманднаяПанель") Тогда 
                //@skip-check bsl-legacy-check-dynamic-feature-access
                Объект = Объект.Кнопки[МассивФрагментов[1]];                
            КонецЕсли;
        КонецЕсли;
    Иначе
        Объект = Форма;
        ИмяЭлементаФормы = "";
    КонецЕсли;
    
    ТекстМаркера = "рСтарыеОбработчики";
    Если Форма.ЭлементыФормы.Найти(ТекстМаркера) = Неопределено Тогда
        Форма.ЭлементыФормы.Добавить(Тип("ПолеВвода"), ТекстМаркера, Ложь);
    КонецЕсли;
    
    Если ПсевдонимЭлементаФормы <> "" Тогда 
        ПолноеИмяСобытия = ПсевдонимЭлементаФормы + ИмяСобытия;
    Иначе
        ПолноеИмяСобытия = ИмяЭлементаФормы       + ИмяСобытия;
    КонецЕсли;
    
    Если ТипЗнч(Объект) = Тип("КнопкаКоманднойПанели") Тогда
        //@skip-check bsl-legacy-check-dynamic-feature-access
        СтароеДействие = Объект.Действие;
    Иначе
        СтароеДействие = Объект.ПолучитьДействие(ИмяСобытия);
    КонецЕсли;
    
    Если ЛиИсключительное и СтароеДействие <> Неопределено Тогда 
        //@skip-check use-non-recommended-method
        Сообщить("Конфликт обработчиков события """ + ИмяСобытия + """ объекта """ + Строка(Объект) + """",
                 СтатусСообщения.Важное);
    КонецЕсли;
	
	НовоеДействие = "AMS" + ПолноеИмяСобытия;
	
	 //Для отладки здесь следует отключать попытку. Она используется для назначения унифицированных обработчиков,
	 //наличие которых не является обязательным.
	Попытка
	    Если ТипЗнч(Объект) = Тип("КнопкаКоманднойПанели") Тогда
	        Объект.Действие = НовоеДействие;
	    Иначе
	        Объект.УстановитьДействие(ИмяСобытия, НовоеДействие);
	    КонецЕсли;
	Исключение
	    Возврат;
	КонецПопытки;
    
    СписокСоответствияОбработчиков = Форма.ЭлементыФормы.рСтарыеОбработчики.СписокВыбора;
    СписокСоответствияОбработчиков.Добавить(ИмяЭлементаФормы + "." + ИмяСобытия, СтароеДействие);
КонецПроцедуры

Функция AMSПолучитьАргументыДействияФормы(Объект, ИмяСобытия = "")

    Аргументы = "";
    Если ТипЗнч(Объект) = Тип("КнопкаКоманднойПанели") Тогда
        // Это действие кнопки командной панели формы
        Аргументы = "(Кнопка)";        
    
    ИначеЕсли ТипЗнч(Объект) = Тип("Форма") Тогда
        // Это событие формы
        Попытка
            ОбъектОсновнойРеквизитФормы = Объект.ЭтотОбъект;
        Исключение
            ОбъектОсновнойРеквизитФормы = Неопределено;
        КонецПопытки;
        
        Если Аргументы = "" Тогда 
            Если      ИмяСобытия = "ВнешнееСобытие" Тогда 
                Аргументы = "(Источник, Событие, Данные)";
            ИначеЕсли ИмяСобытия = "ОбработкаАктивизацииОбъекта" Тогда 
                Аргументы = "(АктивныйОбъект, Источник)";
            ИначеЕсли ИмяСобытия = "ОбработкаВыбора" Тогда 
                Аргументы = "(ЗначениеВыбора, Источник)";
            ИначеЕсли ИмяСобытия = "ОбработкаЗаписиНовогоОбъекта" Тогда 
                Аргументы = "(Объект, Источник)";
            ИначеЕсли ИмяСобытия = "ОбработкаОповещения" Тогда 
                Аргументы = "(ИмяСобытия, Параметр, Источник)";
            ИначеЕсли ИмяСобытия = "ПередЗакрытием" Тогда 
                Аргументы = "(Отказ, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "ПередЗаписью" Тогда 
                Если AMSПолучитьКорневойТипКонфигурации(ОбъектОсновнойРеквизитФормы) = "Документ" Тогда
                    Аргументы = "(Отказ, РежимЗаписи, РежимПроведения)";
                Иначе
                    Аргументы = "(Отказ)";
                КонецЕсли;
            ИначеЕсли ИмяСобытия = "ПередОткрытием" Тогда 
                Аргументы = "(Отказ, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "ПриЗаписи" Тогда 
                Аргументы = "(Отказ)";
            ИначеЕсли ИмяСобытия = "ПриПовторномОткрытии" Тогда 
                Аргументы = "(СтандартнаяОбработка)";
            Иначе
                Аргументы = "()";
            КонецЕсли;
        КонецЕсли;        
    

    Иначе
        // Это событие элемента формы
        Если ТипЗнч(Объект) = Тип("ТабличноеПоле") Тогда
            Если      ИмяСобытия = "Выбор" Тогда 
                Аргументы = "(Элемент, ВыбраннаяСтрока, Колонка, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "Перетаскивание" Тогда 
                Аргументы = "(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Колонка)";
            ИначеЕсли ИмяСобытия = "ПроверкаПеретаскивания" Тогда 
                Аргументы = "(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Колонка)";
            КонецЕсли;
        
        ИначеЕсли ТипЗнч(Объект) = Тип("ТабличныйДокумент") Тогда
            Если      ИмяСобытия = "Выбор" Тогда 
                Аргументы = "(Элемент, Область, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "Перетаскивание" Тогда 
                Аргументы = "(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Область)";
            ИначеЕсли ИмяСобытия = "ПроверкаПеретаскивания" Тогда 
                Аргументы = "(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Область)";
            КонецЕсли;
        КонецЕсли;
        Если Аргументы = "" Тогда 
            Если      ИмяСобытия = "АвтоПодборТекста" Тогда 
                Аргументы = "(Элемент, Текст, ТекстАвтоПодбора, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "НачалоВыбора" Тогда 
                Аргументы = "(Элемент, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "НачалоПеретаскивания" Тогда 
                Аргументы = "(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "ОбработкаВыбора" Тогда 
                Аргументы = "(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "ОбработкаЗаписиНовогоОбъекта" Тогда 
                Аргументы = "(Элемент, Объект, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "ОбработкаРасшифровки" Тогда 
                Аргументы = "(Элемент, Расшифровка, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "ОкончаниеВводаТекста" Тогда 
                Аргументы = "(Элемент, Текст, Значение, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "ОкончаниеПеретаскивания" Тогда 
                Аргументы = "(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "Открытие" Тогда 
                Аргументы = "(Элемент, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "Очистка" Тогда 
                Аргументы = "(Элемент, СтандартнаяОбработка)";
            ИначеЕсли ИмяСобытия = "ПередНачаломДобавления" Тогда 
                Аргументы = "(Элемент, Отказ, Копирование)";
            ИначеЕсли ИмяСобытия = "ПередНачаломИзменения" Тогда 
                Аргументы = "(Элемент, Отказ)";
            ИначеЕсли ИмяСобытия = "ПередОкончаниемРедактирования" Тогда 
                Аргументы = "(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)";
            ИначеЕсли ИмяСобытия = "ПередУдалением" Тогда 
                Аргументы = "(Элемент, Отказ)";
            ИначеЕсли ИмяСобытия = "ПриВыводеСтроки" Тогда 
                Аргументы = "(Элемент, ОформлениеСтроки, ДанныеСтроки)";
            ИначеЕсли ИмяСобытия = "ПриИзмененииСодержимогоОбласти" Тогда 
                Аргументы = "(Элемент, Область)";
            ИначеЕсли ИмяСобытия = "ПриНачалеРедактирования" Тогда 
                Аргументы = "(Элемент, НоваяСтрока, Копирование)";
            ИначеЕсли ИмяСобытия = "ПриОкончанииРедактирования" Тогда 
                Аргументы = "(Элемент, НоваяСтрока, ОтменаРедактирования)";
            ИначеЕсли ИмяСобытия = "ПриОкончанииРедактированияИнтервала" Тогда 
                Аргументы = "(Элемент, Интервал, Отмена)";
            ИначеЕсли ИмяСобытия = "ПриПолученииДанных" Тогда 
                Аргументы = "(Элемент, ОформленияСтрок)";
            ИначеЕсли ИмяСобытия = "ПриСменеСтраницы" Тогда 
                Аргументы = "(Элемент, ТекущаяСтраница)";
            ИначеЕсли ИмяСобытия = "Регулирование" Тогда 
                Аргументы = "(Элемент, Направление, СтандартнаяОбработка)";
            Иначе
                Аргументы = "(Элемент)";
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;
	
	Возврат Аргументы + ";";
КонецФункции

Функция AMSПолучитьСтароеДействиеФормы(Форма, ИмяСобытия = "", ИмяЭлементаФормы = "") Экспорт
    Если ИмяЭлементаФормы <> "" Тогда 
        МассивФрагментов = AMSПолучитьМассивИзСтрокиСРазделителем(ИмяЭлементаФормы);
        ИмяЭлементаФормы = МассивФрагментов[0];
        Объект = Форма.ЭлементыФормы[ИмяЭлементаФормы];
        
        Если МассивФрагментов.Количество() > 1 Тогда 
            ИмяЭлементаФормы = ИмяЭлементаФормы + МассивФрагментов[1];
            Если ТипЗнч(Объект) = Тип("ТабличноеПоле") Тогда 
                //@skip-check bsl-legacy-check-dynamic-feature-access
                Объект = Объект.Колонки[МассивФрагментов[1]].ЭлементУправления;
            ИначеЕсли ТипЗнч(Объект) = Тип("КоманднаяПанель") Тогда 
                //@skip-check bsl-legacy-check-dynamic-feature-access
                Объект = Объект.Кнопки[МассивФрагментов[1]];                
            КонецЕсли;
        КонецЕсли;
    Иначе
        ИмяЭлементаФормы = "";
        Объект = Форма;
    КонецЕсли;
    
    СтарыйОбработчик = "";
    СписокСоответствияОбработчиков = Форма.ЭлементыФормы.рСтарыеОбработчики.СписокВыбора;
    ЭлементСписка = СписокСоответствияОбработчиков.НайтиПоЗначению(ИмяЭлементаФормы + "." + ИмяСобытия);
    
	Если ЭлементСписка <> Неопределено Тогда 
        СтарыйОбработчик = ЭлементСписка.Представление;
	КонецЕсли;
	
    Если СтарыйОбработчик <> "" Тогда 
        СтарыйОбработчик = СтарыйОбработчик + AMSПолучитьАргументыДействияФормы(Объект, ИмяСобытия);
    КонецЕсли;
    
    Возврат СтарыйОбработчик;
КонецФункции

Функция AMSПолучитьДействиеФормы(Форма, ИмяСобытия = "", ИмяЭлементаФормы = "") Экспорт

    Если ИмяЭлементаФормы <> "" Тогда 
        МассивФрагментов = AMSПолучитьМассивИзСтрокиСРазделителем(ИмяЭлементаФормы);
        Объект = Форма.ЭлементыФормы[МассивФрагментов[0]];
        
        Если МассивФрагментов.Количество() > 1 Тогда
            ИмяСубэлемента = МассивФрагментов[1];
            ИмяЭлементаФормы = ИмяЭлементаФормы + ИмяСубэлемента;
            
            Если ТипЗнч(Объект) = Тип("ТабличноеПоле") Тогда 
                //@skip-check bsl-legacy-check-dynamic-feature-access
                Объект = Объект.Колонки[ИмяСубэлемента].ЭлементУправления;
                УстановкаПараметров = "Элемент = ЭлементыФормы." + ИмяЭлементаФормы + "Колонки[" 
                           + ИмяСубэлемента + "].ЭлементУправления;" + Символы.ПС;
            ИначеЕсли ТипЗнч(Объект) = Тип("КоманднаяПанель") Тогда 
                //@skip-check bsl-legacy-check-dynamic-feature-access
                Объект = Объект.Кнопки[ИмяСубэлемента];                
                УстановкаПараметров = "Кнопка = ЭлементыФормы." + ИмяЭлементаФормы + "Кнопки[" 
                           + ИмяСубэлемента + "];" + Символы.ПС;
            Иначе
                //@skip-check use-non-recommended-method
                Сообщить("Неизвестный тип элемента """ + ТипЗнч(Объект) + """ с  субэлементом """ 
                       + ИмяСубэлемента + """ при получении действия формы");
            КонецЕсли;
        Иначе
            УстановкаПараметров = "Элемент = ЭлементыФормы." + ИмяЭлементаФормы + ";" + Символы.ПС;
        КонецЕсли;
    Иначе
        Объект = Форма;
    КонецЕсли;
    
    Обработчик = Строка(Объект.ПолучитьДействие(ИмяСобытия));
    Если Обработчик <> "" Тогда 
        Обработчик = УстановкаПараметров + Обработчик + AMSПолучитьАргументыДействияФормы(Объект,                   ИмяСобытия)
                   + Символы.ПС;
    КонецЕсли;
    Возврат Обработчик;

КонецФункции // AMSПолучитьДействиеФормы()

Функция AMSПолучитьМассивИзСтрокиСРазделителем(Строка, Разделитель = ".") Экспорт
    Массив = Новый Массив;
   	
   	Строка = СтрЗаменить(Строка, Разделитель, Символы.ПС);
    
    Для Счетчик = 1 По СтрЧислоСтрок(Строка) Цикл 
        Массив.Добавить(СтрПолучитьСтроку(Строка, Счетчик));
    КонецЦикла;
   
    Возврат Массив;
КонецФункции

Функция AMSПолучитьКорневойТипКонфигурации(Значение) Экспорт
    ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипЗнч(Значение));
    
    Если ОбъектМетаданных <> Неопределено Тогда 
        МассивФрагментов = AMSПолучитьМассивИзСтрокиСРазделителем(ОбъектМетаданных.ПолноеИмя());
        Если МассивФрагментов.Количество() = 2 Тогда 
            Возврат МассивФрагментов[0];
        Иначе
            // Ссылка на субобъект
        КонецЕсли;
    КонецЕсли;
    
    Возврат Неопределено;
КонецФункции

