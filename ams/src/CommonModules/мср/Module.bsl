Процедура УстановитьСкладПолученияТовара(Объект) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Если ЗначениеЗаполнено(Объект.Партнер) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Партнер", Объект.Партнер);
		Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Закупки.Склад
		|ИЗ
		|	РегистрНакопления.Закупки КАК Закупки
		|ГДЕ
		|	Закупки.Партнер = &Партнер";
		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			Объект.Склад = Справочники.Склады.ПустаяСсылка();

		Иначе
			Выборка = Результат.Выбрать();

			Если Выборка.Количество() = 1 Тогда
				Выборка.Следующий();
				Объект.Склад = Выборка.Склад;
			Иначе
				Объект.Склад = Справочники.Склады.ПолучитьСсылку(
					Новый УникальныйИдентификатор("1fe241fb-1785-11e2-8e90-001e67078c9d")); //Цеха
			КонецЕсли;
		КонецЕсли;

	Иначе
		Объект.Склад = Справочники.Склады.ПустаяСсылка();
	КонецЕсли;
КонецПроцедуры

