	КодыИзExcel.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));

	Для Каждого Стр Из Данные Цикл
		НовСтр = КодыИзExcel.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
	КонецЦикла;

	Партнер = Объект.Партнер;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("ТоварыИзДок", Объект.Товары.Выгрузить( , "Номенклатура,КоличествоУпаковок"));
	Запрос.УстановитьПараметр("КодыИзExcel", КодыИзExcel);
	Запрос.УстановитьПараметр("ВидЦен", Объект.Соглашение.ВидЦен);
	Запрос.УстановитьПараметр("Партнер", ?(ЗначениеЗаполнено(Партнер.Родитель), Партнер.Родитель, Партнер));
	Запрос.УстановитьПараметр("Соглашение", Объект.Соглашение);
	Запрос.УстановитьПараметр("ПорядокКлиента", Партнер._ПорядокКлиента);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.КоличествоУпаковок КАК Количество
	|ПОМЕСТИТЬ ТоварыИзДок
	|ИЗ
	|	&ТоварыИзДок КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.КодТовара КАК КодТовара,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ коды
	|ИЗ
	|	&КодыИзExcel КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ном.Ссылка КАК Номенклатура,
	|	коды.Количество КАК Количество
	|ПОМЕСТИТЬ ТоварыИзExcel
	|ИЗ
	|	коды КАК коды
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|		ПО коды.КодТовара = ном.Код
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	ТоварыИзДок КАК т
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т.Номенклатура,
	|	т.Количество
	|ИЗ
	|	ТоварыИзExcel КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	СУММА(т.Количество) КАК Количество
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	вт КАК т
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	СпрНом._Упаковка КАК Упаковка,
	|	СпрНом.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	тов.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА &ПорядокКлиента
	|			ТОГДА НомКлиентов.ПорядковыйНомер
	|		ИНАЧЕ СпрНом.Наименование
	|	КОНЕЦ КАК Порядок,
	|	СпрНом.КоэффициентЕдиницыДляОтчетов КАК Кфц
	|ПОМЕСТИТЬ ном
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНом
	|		ПО тов.Номенклатура = СпрНом.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений._НоменклатураКлиентов КАК НомКлиентов
	|		ПО тов.Номенклатура = НомКлиентов.Номенклатура
	|			И (НомКлиентов.Партнер = &Партнер)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ном.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА СогТов.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА СогТов.Цена
	|		ИНАЧЕ СогТов.Цена / СогТов.Упаковка.Числитель
	|	КОНЕЦ КАК Цена,
	|	СогТов.ВидЦены КАК ВидЦены
	|ПОМЕСТИТЬ ЦенДоп
	|ИЗ
	|	ном КАК ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СогТов
	|		ПО ном.Номенклатура = СогТов.Номенклатура
	|ГДЕ
	|	СогТов.Ссылка = &Соглашение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ном.Номенклатура КАК Номенклатура,
	|	СогЦенГр.ВидЦен КАК ВидЦены
	|ПОМЕСТИТЬ ЦенГр
	|ИЗ
	|	ном КАК ном
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СогЦенГр
	|		ПО ном.ЦеноваяГруппа = СогЦенГр.ЦеноваяГруппа
	|ГДЕ
	|	СогЦенГр.Ссылка = &Соглашение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ном.Номенклатура КАК Номенклатура,
	|	ЦенДоп.Цена КАК Цена,
	|	ВЫБОР
	|		КОГДА ЦенДоп.ВидЦены ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|					КОГДА ЦенГр.ВидЦены ЕСТЬ NULL
	|						ТОГДА &ВидЦен
	|					ИНАЧЕ ЦенГр.ВидЦены
	|				КОНЕЦ
	|		ИНАЧЕ ЦенДоп.ВидЦены
	|	КОНЕЦ КАК ВидЦены
	|ПОМЕСТИТЬ Цен
	|ИЗ
	|	ном КАК ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенДоп КАК ЦенДоп
	|		ПО ном.Номенклатура = ЦенДоп.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенГр КАК ЦенГр
	|		ПО ном.Номенклатура = ЦенГр.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Цен.Номенклатура КАК Номенклатура,
	|	Цен.ВидЦены КАК ВидЦены,
	|	ВЫБОР
	|		КОГДА Цен.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|			ТОГДА Цен.Цена
	|		ИНАЧЕ ВЫБОР
	|				КОГДА СрезПоследних.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|					ТОГДА СрезПоследних.Цена
	|				ИНАЧЕ СрезПоследних.Цена / СрезПоследних.Упаковка.Числитель
	|			КОНЕЦ
	|	КОНЕЦ КАК Цена
	|ПОМЕСТИТЬ цены
	|ИЗ
	|	Цен КАК Цен
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, ) КАК СрезПоследних
	|		ПО Цен.Номенклатура = СрезПоследних.Номенклатура
	|			И Цен.ВидЦены = СрезПоследних.ВидЦены
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ном.Номенклатура КАК Номенклатура,
	|	ном.Упаковка КАК Упаковка,
	|	цены.ВидЦены КАК ВидЦены,
	|	цены.Цена * ном.Кфц КАК Цена,
	|	ном.Количество КАК КоличествоУпаковок,
	|	ном.Порядок КАК Порядок
	|ИЗ
	|	ном КАК ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ цены КАК цены
	|		ПО ном.Номенклатура = цены.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Неопределено;

	Иначе
		Массив = Новый Массив;

		Табл = Рез.Выгрузить();
		Для Каждого Стр Из Табл Цикл
			Массив.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
		КонецЦикла;

		Возврат Массив;
	КонецЕсли;
КонецФункции

Функция ПолучитьРеализацияТовары(Док) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура,
	|	СУММА(т.Количество) КАК Количество
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Док
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура";
	Запрос.УстановитьПараметр("Док", Док);

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

#КонецОбласти

#Область РегламентныеЗадания

#Область ВыгрузкаПродаж

Процедура ВыгрузкаПродаж() Экспорт
	ДанныеБазы = AMS_ВызовСервера.ПолучитьИмяБазы();
	
	Если Не (ДанныеБазы.ИмяБазы = "Trade_work" Или ДанныеБазы.ИмяБазы = "ams" Или ДанныеБазы.ИмяБазы = "ams1") Тогда 
		Возврат;
	КонецЕсли;

	ИмяКаталога = "H:\disk_z\unloading";
	Каталог = Новый Файл(ИмяКаталога);
	Если Не Каталог.Существует() Тогда
		ИмяКаталога = "H:\work";
		Каталог = Новый Файл(ИмяКаталога);
	КонецЕсли;
	
	ДатаВыгрузки = НачалоДня(ТекущаяДатаСеанса());
	
	ИмяФайла = ИмяКаталога + "\Выгрузка.xlsx";
	
	Макет = Обработки.AMS_Продажи.ПолучитьМакет("ВыгрузкаДанныхПродаж");

	Результат = ПолучитьРезультатВыгрузкиПродаж(Макет, ДатаВыгрузки);
	
	Поток = ФайловыеПотоки.ОткрытьДляЗаписи(ИмяФайла);
	Результат.Записать(Поток, ТипФайлаТабличногоДокумента.XLSX);
	Поток.Закрыть();
КонецПроцедуры

Функция ПолучитьРезультатВыгрузкиПродаж(Макет, ДатаОкончания)
	Результат = Новый ТабличныйДокумент;
	
	Пакет = ПолучитьПакетДанныхВыгрузкаПродаж(ДатаОкончания);
	
	ОблШапка   = Макет.ПолучитьОбласть("Шапка");
	ОблСтрока  = Макет.ПолучитьОбласть("Строка");
	ОблОстатки = Макет.ПолучитьОбласть("Остатки");
	ОблПланы   = Макет.ПолучитьОбласть("Планы");
	ОблОплата  = Макет.ПолучитьОбласть("Оплата");
	
	Результат.Вывести(ОблШапка); 
	
	Выб = Пакет.ПродажиЗаПериод.Выбрать();
	Пока Выб.Следующий() Цикл
		ОблСтрока.Параметры.Заполнить(Выб);
		Результат.Вывести(ОблСтрока); 
	КонецЦикла;
	
	Выб = Пакет.ИтогиПоМесяцам.Выбрать();
	Пока Выб.Следующий() Цикл
		ОблОстатки.Параметры.Заполнить(Выб);
		Результат.Вывести(ОблОстатки); 
	КонецЦикла;
	
	Выб = Пакет.ПланыПродаж.Выбрать();
	Пока Выб.Следующий() Цикл
		ОблПланы.Параметры.Заполнить(Выб);
		Результат.Вывести(ОблПланы); 
	КонецЦикла; 
	
	Рез = РезультатЗапросаВыгрузкаОплат();
	Выб = Рез.Выбрать();
	Пока Выб.Следующий() Цикл
		ОблОплата.Параметры.Заполнить(Выб);
		Результат.Вывести(ОблОплата); 
	КонецЦикла; 

	Возврат Результат;
КонецФункции

Функция ПолучитьПакетДанныхВыгрузкаПродаж(ДатаОкончания)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНачала", Дата(2024,1,1));
	Запрос.УстановитьПараметр("ДатаОкончания", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ВидыНоменклатурыПродукции", AMS_ВызовСервера.ВидыНоменклатурыПродукции());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(РегВыручка.Период, ДЕНЬ) КАК ДатаРеализации,
	|	РегВыручка.Регистратор КАК Регистратор,
	|	РегВыручка.АналитикаУчетаПоПартнерам.Партнер КАК Партнер,
	|	РегВыручка.АналитикаУчетаПоПартнерам.Контрагент КАК Контрагент,
	|	СпрНом.Ссылка КАК Номенклатура,
	|	РегВыручка.Склад КАК Склад,
	|	РегВыручка.Соглашение.ГрафикОплаты КАК ГрафикОплаты,
	|	РегВыручка.КоличествоОборот КАК Количество,
	|	РегВыручка.СуммаВыручкиОборот КАК Сумма,
	|	РегВыручка.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
	|	ВЫБОР
	|		КОГДА РегВыручка.Регистратор ССЫЛКА Документ.ОтчетКомиссионера
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Маркетплейс
	|ПОМЕСТИТЬ Рег
	|ИЗ
	|	РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(
	|			&ДатаНачала,
	|			,
	|			Регистратор,
	|			НЕ ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияТоваровВДругуюОрганизацию)
	|				И ТипЗапасов = ЗНАЧЕНИЕ(Перечисление.ТипыЗапасов.Товар)) КАК РегВыручка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНом
	|		ПО РегВыручка.АналитикаУчетаНоменклатуры.Номенклатура = СпрНом.Ссылка
	|ГДЕ
	|	СпрНом.ВидНоменклатуры В(&ВидыНоменклатурыПродукции)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ГрафикОплаты,
	|	Партнер,
	|	Контрагент,
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫБОР
	|		КОГДА Партн.Родитель = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|			ТОГДА Партн.Ссылка
	|		ИНАЧЕ Партн.Родитель
	|	КОНЕЦ КАК ГоловнойПартнер,
	|	ВЫБОР
	|		КОГДА Партн.Родитель = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|			ТОГДА Партн.Наименование
	|		ИНАЧЕ Партн.Родитель.Наименование
	|	КОНЕЦ КАК НаименованиеГП,
	|	Партн.Ссылка КАК Партнер,
	|	Партн.ГруппаДоступа КАК ГруппаДоступа,
	|	Партн.Наименование КАК НаименованиеП,
	|	Партн.AMS_СегментРынка КАК СегментРынка,
	|	Партн.ОсновнойМенеджер КАК ОсновнойМенеджер,
	|	МАКСИМУМ(Этапы.Сдвиг) КАК Отсрочка,
	|	Контр.Ссылка КАК Контрагент,
	|	Контр.ИНН КАК ИНН,
	|	Контр.Наименование КАК НаименованиеК
	|ПОМЕСТИТЬ Клиент
	|ИЗ
	|	Рег КАК Рег
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГрафикиОплаты.Этапы КАК Этапы
	|		ПО Рег.ГрафикОплаты = Этапы.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партн
	|		ПО Рег.Партнер = Партн.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контр
	|		ПО Рег.Контрагент = Контр.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Партн.Ссылка,
	|	ВЫБОР
	|		КОГДА Партн.Родитель = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|			ТОГДА Партн.Ссылка
	|		ИНАЧЕ Партн.Родитель
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА Партн.Родитель = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|			ТОГДА Партн.Наименование
	|		ИНАЧЕ Партн.Родитель.Наименование
	|	КОНЕЦ,
	|	Партн.Наименование,
	|	Партн.ОсновнойМенеджер,
	|	Контр.Ссылка,
	|	Контр.ИНН,
	|	Контр.Наименование,
	|	Партн.ГруппаДоступа,
	|	Партн.AMS_СегментРынка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НомДоп.Вид КАК ВидПродукции,
	|	НомДоп.Тип КАК ТипПродукции,
	|	НомДоп.Категория КАК Категория,
