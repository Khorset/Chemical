Функция ЭтоПервыйЛогистическийЛист(Дата, Ссылка) Экспорт
	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("Дата", Дата);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист КАК т
	|ГДЕ
	|	т.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.МоментВремени";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Истина;
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		ПерваяСсылка = Выб.Ссылка;

		Если ПерваяСсылка = Ссылка Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
КонецФункции

