	Соглашения = ПолучитьДействующиеСоглашенияПартнера(Дата, Партнер);

	Если Соглашения.Найти(Соглаше, "Ссылка") = Неопределено Тогда
		ТекстОшибки = НСтр("ru='Правило продаж имеет не разрешённое к применению Соглашение.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , "Объект.AMS_ПравилоПродажи");
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
КонецФункции
Функция ПолучитьДействующиеСоглашенияПартнера(Дата, Партнер) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ДатаДокумента", Дата);
	Запрос.УстановитьПараметр("Действует", "Действует");
	Запрос.УстановитьПараметр("Индивидуальное", "Индивидуальное");
	Запрос.УстановитьПараметр("Типовое", "Типовое");
	Запрос.УстановитьПараметр("ТолькоИндивидуальные", Ложь);
	Запрос.УстановитьПараметр("ТолькоИспользуемыеВРаботеТП", Ложь);
	Запрос.УстановитьПараметр("ТолькоТиповые", Ложь);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.Ссылка КАК Ссылка,
	|	т.ПометкаУдаления КАК ПометкаУдаления,
	|	т.Номер КАК Номер,
	|	т.Дата КАК Дата,
	|	т.Валюта КАК Валюта,
	|	т.ГрафикОплаты КАК ГрафикОплаты,
	|	т.СуммаДокумента КАК СуммаДокумента,
	|	т.Типовое КАК Типовое,
	|	т.ВидЦен КАК ВидЦен,
	|	т.Статус КАК Статус,
	|	т.Регулярное КАК Регулярное,
	|	т.СегментНоменклатуры КАК СегментНоменклатуры,
	|	т.ДатаНачалаДействия КАК ДатаНачалаДействия,
	|	т.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
	|	т.Менеджер КАК Менеджер,
	|	т.Наименование КАК Наименование,
	|	т.Комментарий КАК Комментарий,
	|	т.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	т.Организация КАК Организация,
	|	т.Контрагент КАК Контрагент,
	|	ВЫРАЗИТЬ(&Партнер КАК Справочник.Партнеры) КАК ПартнерОтбор,
	|	ВЫБОР
	|		КОГДА т.Типовое
	|			ТОГДА &Типовое
	|		ИНАЧЕ &Индивидуальное
	|	КОНЕЦ КАК ТипСоглашения,
	|	ВЫБОР
	|		КОГДА т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
	|			ТОГДА &Действует
	|	КОНЕЦ КАК Состояние,
	|	ВЫБОР
	|		КОГДА т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.НеСогласовано)
	|				И (т.ДатаНачалаДействия <> ДАТАВРЕМЯ(1, 1, 1)
	|						И т.ДатаНачалаДействия < &ДатаДокумента
	|					ИЛИ т.ДатаОкончанияДействия <> ДАТАВРЕМЯ(1, 1, 1)
	|						И т.ДатаОкончанияДействия < &ДатаДокумента)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СогласованиеПросрочено,
	|	ВЫБОР
	|		КОГДА т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
	|				И (т.ДатаОкончанияДействия <> ДАТАВРЕМЯ(1, 1, 1)
	|					И т.ДатаОкончанияДействия < &ДатаДокумента)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СрокДействияИстек,
	|	ВЫБОР
	|		КОГДА т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
	|				И (т.ДатаНачалаДействия <> ДАТАВРЕМЯ(1, 1, 1)
	|					И т.ДатаНачалаДействия > &ДатаДокумента)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СрокДействияНеНаступил,
	|	ВЫБОР
	|		КОГДА т.Типовое
	|				И т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
	|			ТОГДА 0
	|		КОГДА НЕ т.Типовое
	|				И т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
	|			ТОГДА 3
	|	КОНЕЦ КАК КартинкаСостояния,
	|	т.ДоступноВнешнимПользователям КАК ДоступноВнешнимПользователям,
	|	т.СегментПартнеров КАК СегментПартнеров
	|ИЗ
	|	Справочник.СоглашенияСКлиентами КАК т
	|ГДЕ
	|	т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
	|	И НЕ т.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА &ТолькоТиповые = ИСТИНА
	|					И &ТолькоИндивидуальные = ЛОЖЬ
	|					И (т.Типовое
	|						И (т.СегментПартнеров = ЗНАЧЕНИЕ(Справочник.СегментыПартнеров.ПустаяСсылка)
	|							ИЛИ т.СегментПартнеров В
	|								(ВЫБРАТЬ
	|									ПартнерыСегмента.Сегмент
	|								ИЗ
	|									РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента
	|								ГДЕ
	|									ПартнерыСегмента.Партнер = &Партнер)))
	|				ТОГДА ИСТИНА
	|			КОГДА &ТолькоИндивидуальные = ИСТИНА
	|					И НЕ &ТолькоТиповые = ИСТИНА
	|					И (НЕ т.Типовое
	|						И (т.СегментПартнеров = ЗНАЧЕНИЕ(Справочник.СегментыПартнеров.ПустаяСсылка)
	|							ИЛИ т.СегментПартнеров В
	|								(ВЫБРАТЬ
	|									ПартнерыСегмента.Сегмент
	|								ИЗ
	|									РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента
	|								ГДЕ
	|									ПартнерыСегмента.Партнер = &Партнер)))
	|					И (&Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|						ИЛИ т.Партнер = &Партнер)
	|				ТОГДА ИСТИНА
	|			КОГДА &ТолькоТиповые = ЛОЖЬ
	|					И &ТолькоИндивидуальные = ЛОЖЬ
	|					И (т.СегментПартнеров = ЗНАЧЕНИЕ(Справочник.СегментыПартнеров.ПустаяСсылка)
	|						ИЛИ т.СегментПартнеров В
	|							(ВЫБРАТЬ
	|								ПартнерыСегмента.Сегмент
	|							ИЗ
	|								РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента
	|							ГДЕ
	|								ПартнерыСегмента.Партнер = &Партнер)
	|						ИЛИ &Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка))
	|					И (&Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|						ИЛИ т.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|						ИЛИ т.Партнер = &Партнер)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ТолькоИспользуемыеВРаботеТП = ИСТИНА
	|					И т.ИспользуетсяВРаботеТорговыхПредставителей
	|				ТОГДА ИСТИНА
	|			КОГДА &ТолькоИспользуемыеВРаботеТП = ЛОЖЬ
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции
Функция ПолучитьДополнительнаяИнформация(Объект) Экспорт
	Возврат Объект.ДополнительнаяИнформация;
КонецФункции

#КонецОбласти

#Область СрокГодности

Функция ПолучитьСрокГодности(ДатаПроизводства, ГоденДо, ВидНоменклатуры) Экспорт
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
	Запрос.УстановитьПараметр("ГоденДо", ГоденДо);
	Запрос.УстановитьПараметр("ДатаПроизводства", ДатаПроизводства);
	
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СерииНоменклатуры.Ссылка КАК Серия
	|ИЗ
	|	Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|ГДЕ
	|	СерииНоменклатуры.ВидНоменклатуры = &ВидНоменклатуры
	|	И СерииНоменклатуры.ГоденДо = &ГоденДо
	|	И СерииНоменклатуры.ДатаПроизводства = &ДатаПроизводства";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Серия;
	
	Иначе
		СерияОбъект = Справочники.СерииНоменклатуры.СоздатьЭлемент();
		
		СерияОбъект.ВидНоменклатуры = ВидНоменклатуры;
		СерияОбъект.ГоденДо = ГоденДо;
		СерияОбъект.ДатаПроизводства = ДатаПроизводства;
		
		СерияОбъект.Записать();
		
		Возврат СерияОбъект.Ссылка;
	КонецЕсли;
КонецФункции

#КонецОбласти

#Область ПЕЧАТЬ

Процедура ЗаписатьСобытиеДокумента(Реализация, Событие) Экспорт
	Если Не (Пользователи.РолиДоступны("_БухгалтерСклада, _КладовщикСклада, _НачальникСклада") Или ЭтоKhors()) Тогда
		Возврат;
	КонецЕсли;

	Если Событие = Перечисления.AMS_СобытияРеализации.ПечатьУПД Тогда
		Если ТипЗнч(Реализация) = Тип("ДокументСсылка.СчетФактураВыданный") Тогда
			Реализация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Реализация, "ДокументОснование");
		КонецЕсли;

		Если Не ЕстьОперацияПечатьПоследняяУПД(Реализация) Тогда
			РегистрыСведений.AMS_ИсторияРеализации.ЗаписатьСобытиеДокумента(Реализация, Событие);
		КонецЕсли;

	ИначеЕсли Событие = Перечисления.AMS_СобытияРеализации.ПечатьТОРГ12 И Не ЕстьОперацияПечатьПоследняяУПД(Реализация) Тогда
		РегистрыСведений.AMS_ИсторияРеализации.ЗаписатьСобытиеДокумента(Реализация, Событие);

	ИначеЕсли Событие = Перечисления.AMS_СобытияРеализации.ОтменаПечати Тогда
		РегистрыСведений.AMS_ИсторияРеализации.ЗаписатьСобытиеДокумента(Реализация, Событие);
		
	ИначеЕсли Событие = Перечисления.AMS_СобытияРеализации.ПечатьСН Тогда
		Если Не ЕстьОперацияПечатьПоследняяСН(Реализация) Тогда
			РегистрыСведений.AMS_ИсторияРеализации.ЗаписатьСобытиеДокумента(Реализация, Событие);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ЕстьТранспортДоставки(Распоряжение) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Распоряжение КАК Распоряжение
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист КАК д
	|		ПО т.Ссылка = д.Ссылка
	|ГДЕ
	|	д.Проведен
	|	И (т.Распоряжение = &Распоряжение
	|			ИЛИ т.ОбъединеннаяЗагрузка = &Распоряжение)";

	Рез = Запрос.Выполнить();

	Возврат Не Рез.Пустой();
КонецФункции
Функция ПечатьРазрешена(ПараметрКоманды, ИмяМакета) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Если ИмяМакета = "СчетНаОплату" Или ИмяМакета = "Спецификация" Или ИмяМакета = "СертификатыНоменклатурыРеестр"
		Или ИмяМакета = "СертификатыНоменклатурыИзображенияИзДокументов" Или ИмяМакета = "СертификатыНоменклатурыИзображенияИзДокументовБезДублей"
		Или Пользователи.РолиДоступны("_ГлавныйБухгалтер,_Директор,_Бухгалтер") Или ЭтоKhors() Тогда

		Возврат Истина;
	КонецЕсли;

	Если (Пользователи.РолиДоступны("_НачальникСклада,_КладовщикСклада")) И (ИмяМакета = "СН" Или ИмяМакета
		= "ПалетнаяЭтикетка") Тогда
		Возврат Истина;
	КонецЕсли;

	Распоряжение = ПараметрКоманды[0];

	Если Не ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Возврат Истина;
	КонецЕсли;
		
	//@skip-check bsl-legacy-check-string-literal
	Статус = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Распоряжение, "AMS_СтатусРеализации");
	Если Статус = Перечисления.AMS_СтатусыРеализаций.Заказ Или Статус = Перечисления.AMS_СтатусыРеализаций.Стикерование Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Пользователи.РолиДоступны("_СтаршийМенеджер, AMS_МенеджерПродаж") Тогда
		ИмяГруппыДоступа = ПолучитьИмяГруппыДоступаРеализации(Распоряжение);
		Если СтрНайти(ИмяГруппыДоступа, "Сети") > 0 Или СтрНайти(ИмяГруппыДоступа, "Ашан") > 0 Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Возврат Истина;
КонецФункции
Функция ЕстьОперацияПечатьПоследняя(Реализация) Экспорт
	Если Не ЗначениеЗаполнено(Реализация) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Реализация", Реализация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Реал.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ Док
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реал
	|ГДЕ
	|	Реал.Ссылка = &Реализация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ист.Документ КАК Реализация,
	|	МАКСИМУМ(Ист.Период) КАК ДатаСН
	|ПОМЕСТИТЬ СН
	|ИЗ
	|	Док КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.AMS_ИсторияРеализации КАК Ист
	|		ПО Док.Ссылка = Ист.Документ
	|ГДЕ
	|	Ист.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ПечатьСН)
	|СГРУППИРОВАТЬ ПО
	|	Ист.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ист.Документ КАК Реализация,
	|	МАКСИМУМ(Ист.Период) КАК ДатаУПД
	|ПОМЕСТИТЬ УПД
	|ИЗ
	|	Док КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.AMS_ИсторияРеализации КАК Ист
	|		ПО Док.Ссылка = Ист.Документ
	|ГДЕ
	|	Ист.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ПечатьУПД)
	|	ИЛИ Ист.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ПечатьТОРГ12)
	|СГРУППИРОВАТЬ ПО
	|	Ист.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ист.Документ КАК Реализация,
	|	МАКСИМУМ(Ист.Период) КАК ДатаОтмены
	|ПОМЕСТИТЬ Отмена
	|ИЗ
	|	Док КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.AMS_ИсторияРеализации КАК Ист
	|		ПО Док.Ссылка = Ист.Документ
	|ГДЕ
	|	Ист.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ОтменаПечати)
	|СГРУППИРОВАТЬ ПО
	|	Ист.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА Отмена.ДатаОтмены ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|				КОГДА СН.ДатаСН ЕСТЬ NULL
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|			КОГДА СН.ДатаСН > Отмена.ДатаОтмены
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	КОНЕЦ КАК ЕстьСН,
	|	ВЫБОР
	|		КОГДА Отмена.ДатаОтмены ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|				КОГДА УПД.ДатаУПД ЕСТЬ NULL
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|			КОГДА УПД.ДатаУПД > Отмена.ДатаОтмены
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	КОНЕЦ КАК ЕстьУПД
	|ПОМЕСТИТЬ Печать
	|ИЗ
	|	Док КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ СН КАК СН
	|		ПО Док.Ссылка = СН.Реализация
	|		ЛЕВОЕ СОЕДИНЕНИЕ УПД КАК УПД
	|		ПО Док.Ссылка = УПД.Реализация
	|		ЛЕВОЕ СОЕДИНЕНИЕ Отмена КАК Отмена
	|		ПО Док.Ссылка = Отмена.Реализация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Печать.Ссылка КАК Ссылка
	|ИЗ
	|	Печать КАК Печать
	|ГДЕ
