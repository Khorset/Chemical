	|	Ном.Номенклатура КАК Номенклатура,
	|	Ном.Наименование КАК Наименование,
	|	Ном.НаименованиеПолное КАК НаименованиеПолное,
	|	Ном.Маркер КАК Маркер,
	|	Ном.СрокГодности КАК СрокГодности,
	|	Ном.УпаковкаСтрока КАК УпаковкаСтрока,
	|	Ном.Упаковка КАК Упаковка,
	|	Ном.ВесУпаковка КАК ВесУпаковка,
	|	Ном.ОбъемСтрока КАК ОбъемСтрока,
	|	Ном.ОбъемУпаковка КАК ОбъемУпаковка,
	|	Ном.Код КАК Код,
	|	Ном.Артикул КАК Артикул,
	|	Ном.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	Ном.ВидНоменклатуры КАК ВидНоменклатуры,
	|	Ном.Склад КАК Склад,
	|	Ном.КоличествоУпаковка КАК КоличествоУпаковка,
	|	Ном.Кфц КАК Кфц,
	|	Палет.КоличествоПалета КАК КоличествоПалета,
	|	Ном.Фабрикат КАК Фабрикат,
	|	Ном.КоличествоФабрикатаВУпаковке КАК КоличествоФабрикатаВУпаковке,
	|	Ном.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	ЦенаСогл.ВидЦены КАК ВидЦеныСоглашение,
	|	ЦенаСогл.ЦенаСоглашение КАК ЦенаСоглашение,
	|	НомКлиента.ПорядковыйНомерКлиента КАК ПорядковыйНомерКлиента,
	|	НомКлиента.АртикулКлиента КАК АртикулКлиента,
	|	ШтрифКоды.ШтрихкодЕд КАК ШтрихкодЕд,
	|	ШтрифКоды.ШтрихкодУпак КАК ШтрихкодУпак,
	|	Ном.КодТНВЭД КАК КодТНВЭД,
	|	Ном.КфцРРЦ КАК КфцРРЦ,
	|	Ном.СтавкаНДС КАК СтавкаНДС,
	|	Ном.СтавкаНДССтавка КАК СтавкаНДССтавка,
	|	Ном.Прайс КАК Прайс,
	|	ЕСТЬNULL(ТовКонтракт.ВнеПрайса, ЛОЖЬ) КАК ВнеПрайса,
	|	Ном.Заказ КАК Заказ,
	|	Ном.Подбор КАК Подбор,
	|	Ном.В2В КАК В2В,
	|	Ном.ЧестныйЗнак КАК ЧестныйЗнак
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	Ном КАК Ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенаСогл КАК ЦенаСогл
	|		ПО Ном.Номенклатура = ЦенаСогл.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ НомКлиента КАК НомКлиента
	|		ПО Ном.Номенклатура = НомКлиента.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ШтрифКоды КАК ШтрифКоды
	|		ПО Ном.Номенклатура = ШтрифКоды.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТовКонтракт КАК ТовКонтракт
	|		ПО Ном.Номенклатура = ТовКонтракт.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТовКлиента КАК ТовКлиента
	|		ПО Ном.Номенклатура = ТовКлиента.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Палет КАК Палет
	|		ПО Ном.Номенклатура = Палет.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура";

	Запрос.Выполнить();
КонецПроцедуры

Процедура ПолучитьСтоимостьТовара(МВТ, Парам) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = МВТ;

	Запрос.УстановитьПараметр("Номенклатура", Парам.Номенклатура);
	Запрос.УстановитьПараметр("Дата", Парам.Дата);
	Запрос.УстановитьПараметр("ВидНоменклатурыМатериал", ВидНоменклатурыМатериал());

	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Ном.Ссылка КАК Номенклатура
	|ПОМЕСТИТЬ Тов1
	|ИЗ
	|	Справочник.Номенклатура КАК Ном
	|ГДЕ
	|	Ном.Ссылка В (&Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СборкаД.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(СборкаД.Дата) КАК Дата
	|ПОМЕСТИТЬ Давал1
	|ИЗ
	|	Тов1 КАК Тов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СборкаТоваров КАК СборкаД
	|		ПО Тов.Номенклатура = СборкаД.Номенклатура
	|ГДЕ
	|	Тов.Номенклатура.ВидНоменклатуры = &ВидНоменклатурыМатериал
	|СГРУППИРОВАТЬ ПО
	|	СборкаД.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сборка.Ссылка КАК Ссылка,
	|	Давал1.Номенклатура КАК Номенклатура,
	|	Сборка.Количество КАК Количество,
	|	СборкаТовары.Номенклатура КАК НоменклатураПереработки,
	|	СборкаТовары.Количество КАК КоличествоПереработки
	|ПОМЕСТИТЬ Давал2
	|ИЗ
	|	Давал1 КАК Давал1
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СборкаТоваров КАК Сборка
	|			ПРАВОЕ СОЕДИНЕНИЕ Документ.СборкаТоваров.Товары КАК СборкаТовары
	|			ПО (СборкаТовары.Ссылка = Сборка.Ссылка)
	|		ПО Давал1.Номенклатура = Сборка.Номенклатура
	|		И Давал1.Дата = Сборка.Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Тов1.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ Тов2
	|ИЗ
	|	Тов1 КАК Тов1
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Давал2.НоменклатураПереработки
	|ИЗ
	|	Давал2 КАК Давал2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Тов2.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	Тов2 КАК Тов2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(Себест.Период) КАК Период
	|ПОМЕСТИТЬ Закупка1
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК Себест
	|		ПО Товары.Номенклатура = Себест.АналитикаУчетаНоменклатуры.Номенклатура
	|ГДЕ
	|	Себест.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщика)
	|	И Себест.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И Себест.Период <= &Дата
	|	И Себест.Стоимость > 0
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Закупка1.Номенклатура КАК Номенклатура,
	|	Закупка1.Период КАК Период,
	|	Себест.Стоимость / Себест.Количество КАК Цена
	|ПОМЕСТИТЬ Закупка2
	|ИЗ
	|	Закупка1 КАК Закупка1
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК Себест
	|		ПО Закупка1.Номенклатура = Себест.АналитикаУчетаНоменклатуры.Номенклатура
	|		И Закупка1.Период = Себест.Период
	|ГДЕ
	|	Себест.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщика)
	|	И Себест.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И Себест.Период <= &Дата
	|	И Себест.Стоимость > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(Себест.Период) КАК Период
	|ПОМЕСТИТЬ Оприход1
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК Себест
	|		ПО Товары.Номенклатура = Себест.АналитикаУчетаНоменклатуры.Номенклатура
	|ГДЕ
	|	Себест.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ОприходованиеТоваров)
	|	И Себест.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И Себест.Период <= &Дата
	|	И Себест.Стоимость > 0
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Оприход1.Номенклатура КАК Номенклатура,
	|	Оприход1.Период КАК Период,
	|	Себест.Стоимость / Себест.Количество КАК Цена
	|ПОМЕСТИТЬ Оприход2
	|ИЗ
	|	Оприход1 КАК Оприход1
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК Себест
	|		ПО Оприход1.Номенклатура = Себест.АналитикаУчетаНоменклатуры.Номенклатура
	|		И Оприход1.Период = Себест.Период
	|ГДЕ
	|	Себест.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ОприходованиеТоваров)
	|	И Себест.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	И Себест.Период <= &Дата
	|	И Себест.Стоимость > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА Закупка2.Цена ЕСТЬ NULL
	|			ТОГДА ЕСТЬNULL(Оприход2.Цена, 0)
	|		ИНАЧЕ Закупка2.Цена
	|	КОНЕЦ КАК Цена
	|ПОМЕСТИТЬ ЦеныВсе
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Закупка2 КАК Закупка2
	|		ПО Товары.Номенклатура = Закупка2.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Оприход2 КАК Оприход2
	|		ПО Товары.Номенклатура = Оприход2.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Давал2.Номенклатура КАК Номенклатура,
	|	Давал2.Количество КАК Количество,
	|	Давал2.НоменклатураПереработки КАК НоменклатураПереработки,
	|	Давал2.КоличествоПереработки КАК КоличествоПереработки,
	|	ЦеныВсе.Цена КАК ЦенаСырья,
	|	Давал2.КоличествоПереработки * ЦеныВсе.Цена КАК СуммаСырья,
	|	Давал2.КоличествоПереработки * ЦеныВсе.Цена / Давал2.Количество КАК СуммаСырьяЕд
	|ПОМЕСТИТЬ Давал3
	|ИЗ
	|	Давал2 КАК Давал2
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныВсе КАК ЦеныВсе
	|		ПО Давал2.НоменклатураПереработки = ЦеныВсе.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Давал3.Номенклатура КАК Номенклатура,
	|	СУММА(Давал3.СуммаСырьяЕд) КАК Цена
	|ПОМЕСТИТЬ Давал4
	|ИЗ
	|	Давал3 КАК Давал3
	|СГРУППИРОВАТЬ ПО
	|	Давал3.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Давал2.Номенклатура КАК Номенклатура,
	|	Цены.Цена КАК Цена
	|ПОМЕСТИТЬ ЦеныПреформ
	|ИЗ
	|	ЦеныВсе КАК Цены
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Давал2 КАК Давал2
	|		ПО Цены.Номенклатура = Давал2.НоменклатураПереработки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЦеныВсе.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Давал4.Цена, ЦеныВсе.Цена) КАК Цена
	|ПОМЕСТИТЬ ЦенаТовара
	|ИЗ
	|	ЦеныВсе КАК ЦеныВсе
	|		ЛЕВОЕ СОЕДИНЕНИЕ Давал4 КАК Давал4
	|		ПО ЦеныВсе.Номенклатура = Давал4.Номенклатура
	|ГДЕ
	|	НЕ ЦеныВсе.Номенклатура В
	|		(ВЫБРАТЬ
	|			т.НоменклатураПереработки КАК Номенклатура
	|		ИЗ
	|			Давал2 КАК т)";

	Запрос.Выполнить();
КонецПроцедуры

#КонецОбласти

#Область Служебные_НеобходимоОпределитьКудаПоместить

Функция СформироватьМаршрутныйЛист(Парам) Экспорт
	ТабДок = Новый ТабличныйДокумент;
	
	ТабДок.АвтоМасштаб          = Истина;
	ТабДок.ОриентацияСтраницы   = ОриентацияСтраницы.Ландшафт;
	ТабДок.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_МаршрутныйЛист";

	Макет = Документы.AMS_ЛогистическийЛист.ПолучитьМакет("МаршрутныйЛист");

	ОблЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОблДоставка  = Макет.ПолучитьОбласть("Доставка");
	ОблВозврат   = Макет.ПолучитьОбласть("Возврат");
	ОблПодвоз    = Макет.ПолучитьОбласть("Подвоз");
	ОблПодвал    = Макет.ПолучитьОбласть("Подвал");

	Рез = ПолучитьРезультатЗапросаЛогистика(Парам);

	Если Рез.Пустой() Тогда
		Возврат ТабДок;
	КонецЕсли;

	Номер = 0;
	Выб1 = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выб1.Следующий() Цикл
		Направление = 0;
		Номер = Номер + 1;
		
		//Заголовок
		ЗаполнитьЗначенияСвойств(ОблЗаголовок.Параметры, Выб1);
		ОблЗаголовок.Параметры.Заголовок = "Маршрутный лист № " + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(
			Парам.Номер, Ложь, Истина) + "/" + Номер + " от " + Формат(Парам.Дата, "ДЛФ=ДД");
		ОблЗаголовок.Параметры.ДатаПогрузки	 = Формат(Выб1.ВремяЗагрузки, "ДФ=""дд ММММ гггг 'г.'""");
		ОблЗаголовок.Параметры.ВремяПогрузки = Формат(Выб1.ВремяЗагрузки, "ДФ=""ЧЧ:мм""");
		ТабДок.Вывести(ОблЗаголовок);
		
		//Шапка
		Если Выб1.ТК Тогда
			ОблШапка  = Макет.ПолучитьОбласть("ШапкаТК");
			ОблСтрока = Макет.ПолучитьОбласть("СтрокаТК");
		Иначе
			ОблШапка  = Макет.ПолучитьОбласть("Шапка");
			ОблСтрока = Макет.ПолучитьОбласть("Строка");
		КонецЕсли;
		ТабДок.Вывести(ОблШапка);

		Выб = Выб1.Выбрать();
		Пока Выб.Следующий() Цикл
			//Направление
			Если Не (Направление = Выб.Направление) Тогда
				Счет = 0;
				Направление = Выб.Направление;

				Если Направление = 1 Тогда
					ТабДок.Вывести(ОблДоставка);
				ИначеЕсли Направление = 2 Тогда
					ТабДок.Вывести(ОблПодвоз);
				ИначеЕсли Направление = 3 Тогда
					ТабДок.Вывести(ОблВозврат);
				КонецЕсли;
			КонецЕсли;
			Счет = Счет + 1;

			ЗаполнитьЗначенияСвойств(ОблСтрока.Параметры, Выб);

			ОблСтрока.Параметры.Сч = Счет;

			Если Выб.СпособДоставки = Перечисления.СпособыДоставки.КПолучателюОпределяетСлужбаДоставки Тогда
				ОблСтрока.Параметры.Партнер = ОблСтрока.Параметры.Партнер.НаименованиеПолное 
				+ ?(ПустаяСтрока(Выб.ТранспортКлиента), "", Символы.ПС + "Транспорт: " + Выб.ТранспортКлиента) 
				+ ?(ПустаяСтрока(Выб.ДоверенностьКлиента), "", Символы.ПС + "Доверенность: " + Выб.ДоверенностьКлиента) 
				+ ?(ПустаяСтрока(Выб.ТелефонВодителяКлиента), "", Символы.ПС + "Телефон: " + Выб.ТелефонВодителяКлиента);
			КонецЕсли;

			ОблСтрока.Параметры.ВремяС	 = Формат(Выб.ВремяС, "ДФ=""ЧЧ:мм""");
			ОблСтрока.Параметры.ВремяПо	 = Формат(Выб.ВремяПо, "ДФ=""ЧЧ:мм""");

			ОблСтрока.Параметры.ДополнительнаяИнформация = ?(ПустаяСтрока(Выб.ДополнительнаяИнформация), "",
				Выб.ДополнительнаяИнформация + Символы.ПС) + "Менеджер: " + Выб.Менеджер + ?(Направление = 2,
				Символы.ПС + "Доставка в " + Выб.Склад, "");

			ОблСтрока.Параметры.Распоряжение = ?(ТипЗнч(Выб.Распоряжение) = Тип(
				"ДокументСсылка.AMS_ПередачаВПереработку"), "Передача в переработку № ", "УПД № ")
				+ ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Выб.Номер, Ложь, Истина) + Символы.ПС + " от " + Формат(
				Выб.Дата, "ДЛФ=ДД");

			Если Выб.Направление = 1 Тогда
				Если Выб.СпособПередачиТоваров = 0 Тогда
					ОблСтрока.Параметры.Способ1 = "П";
					ОблСтрока.Параметры.Способ2 = "палетами";
				Иначе
					ОблСтрока.Параметры.Способ1 = "К";
					ОблСтрока.Параметры.Способ2 = "коробками";
				КонецЕсли;

				Если Выб.Обрешетка Тогда
					ОблСтрока.Параметры.Способ3 = "С ОБРЕШЕТКОЙ";
				Иначе
					ОблСтрока.Параметры.Способ3 = "БЕЗ ОБРЕШЕТКИ";
				КонецЕсли;
			КонецЕсли;

			ТабДок.Вывести(ОблСтрока);
		КонецЦикла;

		ОблПодвал.Параметры.Палет = "Итого количество палет: " + Выб1.Палет;
		ТабДок.Вывести(ОблПодвал);

		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЦикла;

	Возврат ТабДок;
КонецФункции

Функция ЕстьОперацияПечатьПоследняяСН(Документ)
	Если Не ЗначениеЗаполнено(Документ) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Документ", Документ);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Реализация
	|ПОМЕСТИТЬ док
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК т
	|ГДЕ
	|	т.Ссылка = &Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Документ КАК Документ,
	|	МАКСИМУМ(т.Период) КАК ДатаОтмены
	|ПОМЕСТИТЬ вт1
	|ИЗ
	|	РегистрСведений.AMS_ИсторияРеализации КАК т
	|ГДЕ
	|	т.Документ = &Документ
	|	И т.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ОтменаПечати)
	|СГРУППИРОВАТЬ ПО
	|	т.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Документ КАК Документ,
	|	МАКСИМУМ(т.Период) КАК ДатаПечати
	|ПОМЕСТИТЬ вт2
	|ИЗ
	|	РегистрСведений.AMS_ИсторияРеализации КАК т
	|ГДЕ
	|	т.Документ = &Документ
	|	И т.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ПечатьСН)
	|СГРУППИРОВАТЬ ПО
	|	т.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	док.Реализация КАК Реализация,
	|	ВЫБОР
	|		КОГДА вт1.ДатаОтмены ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|				КОГДА вт2.ДатаПечати ЕСТЬ NULL
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|			КОГДА вт2.ДатаПечати > вт1.ДатаОтмены
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	КОНЕЦ КАК ЕстьПечать
	|ИЗ
	|	док КАК док
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт1 КАК вт1
	|		ПО док.Реализация = вт1.Документ
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт2 КАК вт2
	|		ПО док.Реализация = вт2.Документ";

	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	Выб.Следующий();

	Возврат Выб.ЕстьПечать;
КонецФункции

