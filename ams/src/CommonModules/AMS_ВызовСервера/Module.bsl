Функция ПоместитьВоВременноеХранилищеТовары(Знач Объект) Экспорт
	Отбор = Новый Структура("Номенклатура", ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка"));
	МассивПустыхСтрок = Объект.Товары.НайтиСтроки(Отбор);
	Для Каждого Стр Из МассивПустыхСтрок Цикл
		Объект.Товары.Удалить(Стр);
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить( , "Номенклатура, Упаковка, Количество, ВидЦены, Сумма, ПроцентРучнойСкидки"));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Упаковка КАК Упаковка,
	|	т.Количество КАК Количество,
	|	т.ВидЦены КАК ВидЦены,
	|	т.Сумма КАК Сумма,
	|	т.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Товары КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	вт.Упаковка КАК Упаковка,
	|	вт.Количество КАК Количество,
	|	вт.ВидЦены КАК ВидЦены,
	|	вт.Сумма КАК Сумма,
	|	вт.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки
	|ИЗ
	|	вт КАК вт
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|		ПО вт.Номенклатура = ном.Ссылка
	|			И (ном.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар))";
	
	// Доставка
	//@skip-check bsl-legacy-check-string-literal
	Массив   = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Партнер, "_ТранпортнаяУслуга")));
	Доставка = Массив.Количество() > 0;
	
	// ЦеныПоСоглашению
	Товары = Запрос.Выполнить().Выгрузить();
	Табл = Товары.Скопировать(, "ВидЦены");
	Табл.Свернуть("ВидЦены");
	
	ЦеныПоСоглашению = Ложь;
	
	Для Каждого Стр Из Табл Цикл
		Если ЗначениеЗаполнено(Стр.ВидЦены) Тогда
			ЦеныПоСоглашению = Истина;
		КонецЕсли;	
	КонецЦикла;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "ДатаОтгрузки") Тогда //это заказ клиента
		ДатаДокумента = Объект.ДатаОтгрузки;
	Иначе
		ДатаДокумента = Объект.Дата;
	КонецЕсли;

	Данные = Новый Структура;
	Данные.Вставить("ДатаДокумента", ДатаДокумента);
	Данные.Вставить("Товары", Товары);
	Данные.Вставить("Ссылка", Объект.Ссылка);
	Данные.Вставить("Проведен", Объект.Проведен);
	Данные.Вставить("Соглашение", Объект.Соглашение);
	Данные.Вставить("Партнер", Объект.Партнер);
	Данные.Вставить("Склад", Объект.Склад);
	Данные.Вставить("Доставка", Доставка);
	Данные.Вставить("ЦеныПоСоглашению", ЦеныПоСоглашению);
	
	
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ПередачаТоваровХранителю") Тогда
		Данные.Вставить("ПравилоПродажи", Справочники.AMS_ПравилаПродаж.ПустаяСсылка());
	Иначе
		Данные.Вставить("ПравилоПродажи", Объект.AMS_ПравилоПродажи);
	КонецЕсли;	

	Возврат ПоместитьВоВременноеХранилище(Данные);
КонецФункции

Функция ПолучитьПравилоПродажи(Дата, Партнер, Контрагент = Неопределено) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);

	Если Контрагент = Неопределено Тогда
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	т.Ссылка КАК ПравилоПродажи
		|ИЗ
		|	Справочник.AMS_ПравилаПродаж КАК т
		|ГДЕ
		|	НЕ т.ПометкаУдаления
		|	И т.Владелец = &Партнер
		|	И т.СтатусПравилаПродажи = ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыПравилПродаж.Действует)
		|	И т.Основное";
	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	т.Ссылка КАК ПравилоПродажи
		|ИЗ
		|	Справочник.AMS_ПравилаПродаж КАК т
		|ГДЕ
		|	НЕ т.ПометкаУдаления
		|	И т.Владелец = &Партнер
		|	И т.СтатусПравилаПродажи = ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыПравилПродаж.Действует)
		|	И т.Контрагент = &Контрагент";
	КонецЕсли;

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Справочники.AMS_ПравилаПродаж.ПустаяСсылка();
	Иначе
		Выб = Рез.Выбрать(); 
		Выб.Следующий(); 
		Возврат Выб.ПравилоПродажи;
	КонецЕсли;
КонецФункции
