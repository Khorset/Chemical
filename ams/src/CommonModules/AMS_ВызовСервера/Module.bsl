Процедура AMS_ПроверитьВозможностьПодбора(Знач Объект, Отказ) Экспорт
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "ДатаОтгрузки") Тогда //это заказ клиента
		Если Не ЗначениеЗаполнено(Объект.ДатаОтгрузки) Тогда
			ТекстСообщения = НСтр("ru='Не заполнено поле ""Дата отгрузки""'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "Объект.ДатаОтгрузки",,Отказ);
			Возврат;
		КонецЕсли;
	Иначе
		Если Не ЗначениеЗаполнено(Объект.Дата) Тогда
			ТекстСообщения = НСтр("ru='Не заполнено поле ""Дата""'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "Объект.Дата",,Отказ);
			Возврат;
		КонецЕсли;
	КонецЕсли;
		
	Если Не ЗначениеЗаполнено(Объект.Партнер) Тогда
		ТекстСообщения = НСтр("ru='Не заполнено поле ""Клиент""'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, Объект.Ссылка, "Объект.Партнер",,Отказ);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить(,"НомерСтроки, Номенклатура, Упаковка"));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.НомерСтроки КАК НомерСтроки,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Упаковка КАК Упаковка
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	&Товары КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.НомерСтроки КАК НомерСтроки,
	|	тов.Номенклатура КАК Номенклатура
	|ИЗ
	|	тов КАК тов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНом
	|		ПО тов.Номенклатура = СпрНом.Ссылка
	|		И (СпрНом.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар))
	|ГДЕ
	|	тов.Упаковка <> СпрНом._Упаковка
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.НомерСтроки КАК НомерСтроки,
	|	тов.Номенклатура КАК Номенклатура
	|ИЗ
	|	тов КАК тов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНом
	|		ПО тов.Номенклатура = СпрНом.Ссылка
	|		И (СпрНом.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция.Товары КАК Продукция
	|		ПО тов.Номенклатура = Продукция.Номенклатура
	|ГДЕ
	|	Продукция.Ссылка ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";

	Пакет = Запрос.ВыполнитьПакет();

	Если Не Пакет[1].Пустой() Тогда
		Выб = Пакет[1].Выбрать();
		Пока Выб.Следующий() Цикл
			ОбщегоНазначения.СообщитьПользователю("В строке № " + Выб.НомерСтроки + " указана упаковка не установленная к продажи.", , , , Отказ);
		КонецЦикла;
	КонецЕсли;

	Если Не Пакет[2].Пустой() Тогда
		Выб = Пакет[2].Выбрать();
		Пока Выб.Следующий() Цикл
			ОбщегоНазначения.СообщитьПользователю("В строке № " + Выб.НомерСтроки + " указана номенклатура не установленная к продажи.", , , , Отказ);
		КонецЦикла;
	КонецЕсли;

	Если Отказ Тогда
		ОбщегоНазначения.СообщитьПользователю("Для изменения документа обратитесь к бухгалтеру.");
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьПараметрыДляПрайса(ТипПрайса, ВариантПрайса, Соглашение = Неопределено, ВидЦеныБытХим = Неопределено,
	ВидЦеныМега = Неопределено) Экспорт
	МассивЦеноваяГруппа   = Новый Массив;
	МассивЦенИзСоглашения = Новый Массив;
	МассивВидЦены1        = Новый Массив;
	МассивВидЦены2        = Новый Массив;
	МассивВидЦены3        = Новый Массив;
	МассивВидЦены4        = Новый Массив;
	МассивВидЦены5        = Новый Массив;
	МассивВидЦены6        = Новый Массив;

	Если ВариантПрайса = 1 Тогда
		ВидЦеныБытХим = Соглашение.ВидЦен;
		МассивВидЦены1.Добавить(ВидЦеныБытХим);

		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаБытоваяХимия());
		Стр = Соглашение.ЦеновыеГруппы.Найти(ЦеноваяГруппаМЕГА(), "ЦеноваяГруппа");
		Если ЗначениеЗаполнено(Стр) Тогда
			МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаМЕГА());
			ВидЦеныМега = Стр.ВидЦен;
			МассивВидЦены1.Добавить(ВидЦеныМега);
		КонецЕсли;

		Табл = Соглашение.Товары.Выгрузить( , "Номенклатура,Цена");
		Для Каждого Стр Из Табл Цикл
			МассивЦенИзСоглашения.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
		КонецЦикла;

	ИначеЕсли ВариантПрайса = 2 Тогда
		МассивВидЦены1.Добавить(ВидЦеныБытХим);
		МассивВидЦены1.Добавить(ВидЦеныМега);

		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаМЕГА());
		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаБытоваяХимия());

	ИначеЕсли ВариантПрайса = 3 Тогда
		МассивВидЦены1.Добавить(ВидЦеныБытХим);

		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаБытоваяХимия());

	ИначеЕсли ВариантПрайса = 4 Тогда
		МассивВидЦены1.Добавить(ВидЦеныМега);

		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаМЕГА());

	ИначеЕсли ВариантПрайса = 5 Тогда
		МассивВидЦены1.Добавить(ВидЦены020000());
		МассивВидЦены2.Добавить(ВидЦены050000());
		МассивВидЦены3.Добавить(ВидЦены100000());
		МассивВидЦены4.Добавить(ВидЦены250000());
		МассивВидЦены5.Добавить(ВидЦены500000());
		МассивВидЦены6.Добавить(ВидЦены900000());

		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаБытоваяХимия());

	ИначеЕсли ВариантПрайса = 6 Тогда
		МассивВидЦены1.Добавить(ВидЦены2());
		МассивВидЦены2.Добавить(ВидЦеныМ3());
		МассивВидЦены3.Добавить(ВидЦены3());
		МассивВидЦены4.Добавить(ВидЦеныМ4());
		МассивВидЦены5.Добавить(ВидЦены4());
		МассивВидЦены6.Добавить(Справочники.ВидыЦен.ПустаяСсылка());

		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаБытоваяХимия());

	ИначеЕсли ВариантПрайса = 7 Тогда
		МассивВидЦены1.Добавить(ВидЦеныМЕГА20());
		МассивВидЦены2.Добавить(ВидЦеныМЕГА50());
		МассивВидЦены3.Добавить(ВидЦеныМЕГА75());
		МассивВидЦены4.Добавить(ВидЦеныМЕГА100());
		МассивВидЦены5.Добавить(Справочники.ВидыЦен.ПустаяСсылка());
		МассивВидЦены6.Добавить(Справочники.ВидыЦен.ПустаяСсылка());

		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаМЕГА());

	ИначеЕсли ВариантПрайса = 8 Тогда
		МассивВидЦены1.Добавить(ВидЦеныМЕГА250());
		МассивВидЦены2.Добавить(ВидЦеныМЕГА500());
		МассивВидЦены3.Добавить(Справочники.ВидыЦен.ПустаяСсылка());
		МассивВидЦены4.Добавить(Справочники.ВидыЦен.ПустаяСсылка());
		МассивВидЦены5.Добавить(Справочники.ВидыЦен.ПустаяСсылка());
		МассивВидЦены6.Добавить(Справочники.ВидыЦен.ПустаяСсылка());

		МассивЦеноваяГруппа.Добавить(ЦеноваяГруппаМЕГА());

	КонецЕсли;

	Парам = Новый Структура;
	Парам.Вставить("ТипПрайса", ТипПрайса);
	Парам.Вставить("ВариантПрайса", ВариантПрайса);
	Парам.Вставить("ЦеноваяГруппа", МассивЦеноваяГруппа);
	Парам.Вставить("ЦеныСоглашения", МассивЦенИзСоглашения);
	Парам.Вставить("ВидЦены1", МассивВидЦены1);
	Парам.Вставить("ВидЦены2", МассивВидЦены2);
	Парам.Вставить("ВидЦены3", МассивВидЦены3);
	Парам.Вставить("ВидЦены4", МассивВидЦены4);
	Парам.Вставить("ВидЦены5", МассивВидЦены5);
	Парам.Вставить("ВидЦены6", МассивВидЦены6);

	Возврат Парам;
КонецФункции

