Функция ЭтоПодчинённыйСклад(Склад) Экспорт
	Если Пользователи.РолиДоступны("_НачальникСклада") 
		И (Склад = СкладПродукции() 
			Или Склад = СкладМО() 
			Или Склад = СкладБракованнойПродукции()) Тогда

		Возврат Истина;

	ИначеЕсли Пользователи.РолиДоступны("_Цех1") И Склад = Цех1() Тогда
		Возврат Истина;

	ИначеЕсли Пользователи.РолиДоступны("_Цех2") И Склад = Цех2() Тогда
		Возврат Истина;

	ИначеЕсли Пользователи.РолиДоступны("_Цех3") И Склад = Цех3() Тогда
		Возврат Истина;

	ИначеЕсли Пользователи.РолиДоступны("_Цех4") И Склад = Цех4() Тогда
		Возврат Истина;

	ИначеЕсли Пользователи.РолиДоступны("_Бухгалтер") Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;
КонецФункции

