	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.Договор КАК Договор
	|ИЗ
	|	Документ.ЗаказКлиента КАК т
	|ГДЕ
	|	т.Ссылка = &ЗаказКлиента
	|	И т.Договор.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаНаЭкспорт)";
	
	Возврат Не Запрос.Выполнить().Пустой();
