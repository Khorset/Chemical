Процедура ЗаписатьРегистрТоварныеОграничения(ПараметрыЗаписи) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	МенеджерЗаписи = РегистрыСведений.ТоварныеОграничения.СоздатьМенеджерЗаписи();
    
    МенеджерЗаписи.Склад        = ПараметрыЗаписи.Склад;
	МенеджерЗаписи.Номенклатура = ПараметрыЗаписи.Номенклатура;
	
	МенеджерЗаписи.Прочитать();
    
	Если Не МенеджерЗаписи.Выбран() Тогда 
        МенеджерЗаписи.Склад        = ПараметрыЗаписи.Склад;
    	МенеджерЗаписи.Номенклатура = ПараметрыЗаписи.Номенклатура;
	КонецЕсли;		
    
    МенеджерЗаписи[ПараметрыЗаписи.Ресурс] = ПараметрыЗаписи.Значение;
    
    МенеджерЗаписи.Записать(Истина);
КонецПроцедуры

