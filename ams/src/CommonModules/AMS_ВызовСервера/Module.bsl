Процедура ПолучитьПродукциюДляВ2В(МВТ) Экспорт
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = МВТ;

	Запрос.УстановитьПараметр("ВидНомЦех1",  ВидНоменклатурыПродукцияЦеха1());
	Запрос.УстановитьПараметр("ВидНомЦех2",  ВидНоменклатурыПродукцияЦеха2());
	Запрос.УстановитьПараметр("ВидНомЦех3",  ВидНоменклатурыПродукцияЦеха3());
	Запрос.УстановитьПараметр("ВидНомНабор", ВидНоменклатурыПродукцияНаборы());
	Запрос.УстановитьПараметр("ВидНомТовар", ВидНоменклатурыТовар());
	
	Запрос.УстановитьПараметр("Цех1",           Цех1());
	Запрос.УстановитьПараметр("Цех2",           Цех2());
	Запрос.УстановитьПараметр("Цех3",           Цех3());
	Запрос.УстановитьПараметр("СкладНаборов",   СкладСборкиНаборов());
	Запрос.УстановитьПараметр("СкладПродукции", СкладПродукции());

	Запрос.Текст =
	"ВЫБРАТЬ
	|	Прод.Родитель КАК ВидПродукции,
