Процедура ЗаписатьДокумент(Документ, РежимЗаписи, Отказ = Ложь, СообщитьОбОшибке = Истина, СообщитьОВыполнении = Ложь) Экспорт
	Если СтрНайти(Строка(ТипЗнч(Документ)), "Документ объект") = 0 Тогда //это ссылка 
		//@skip-check unknown-method-property
		ДокументОбъект = Документ.ПолучитьОбъект();
	Иначе
		ДокументОбъект = Документ;
	КонецЕсли;

	СинонимДок = ДокументОбъект.Метаданные().Синоним;
	НоменДок   = ДокументОбъект.Номер;
	СтрокаДок  = СинонимДок + " № " + ?(ПустаяСтрока(НоменДок), " ... ", НоменДок) + " от " + Формат(
		ДокументОбъект.Дата, "ДФ=dd.MM.yyyy") + " г.";

	Попытка
		ДокументОбъект.Записать(РежимЗаписи);

		Если СообщитьОВыполнении Тогда
			Если РежимЗаписи = РежимЗаписиДокумента.Запись Тогда
				Вариант = "Документа " + СтрокаДок + " записан!";
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
				Вариант = "Документ " + СтрокаДок + " проведен!";
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				Вариант = "У документа " + СтрокаДок + " отменено проведение!";
			КонецЕсли;
			ОбщегоНазначения.СообщитьПользователю(Вариант, ДокументОбъект);
		КонецЕсли;

	Исключение
		Отказ = Истина;

		Если СообщитьОбОшибке Тогда
			Если РежимЗаписи = РежимЗаписиДокумента.Запись Тогда
				Вариант = "Документа " + СтрокаДок + " не удалось записать!";
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
				Вариант = "Документ " + СтрокаДок + " не проведен!";
			ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
				Вариант = "У документа " + СтрокаДок + " не удалось отменить проведение!";
			КонецЕсли;

			ОбщегоНазначения.СообщитьПользователю(Вариант + " Ошибка: " + ОписаниеОшибки(), ДокументОбъект);
		КонецЕсли;
	КонецПопытки;
КонецПроцедуры

Процедура УстановитьПометкуУдаленияДокументу(Документ, Пометка, Отказ = Ложь, СообщитьОбОшибке = Истина,
	СообщитьОВыполении = Ложь) Экспорт
	Если СтрНайти(Строка(ТипЗнч(Документ)), "Документ объект") = 0 Тогда //это ссылка 
		ДокументОбъект = Документ.ПолучитьОбъект();
	Иначе
		ДокументОбъект = Документ;
	КонецЕсли;

	СинонимДок = ДокументОбъект.Метаданные().Синоним;
	НоменДок   = ДокументОбъект.Номер;
	СтрокаДок  = "«" + СинонимДок + " № " + ?(ПустаяСтрока(НоменДок), " ... ", НоменДок) + " от " + Формат(
		ДокументОбъект.Дата, "ДФ=dd.MM.yyyy") + " г.»";

	Попытка
		Если ДокументОбъект.Модифицированность() Тогда
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли;

		ДокументОбъект.УстановитьПометкуУдаления(Пометка);

		Если СообщитьОВыполении Тогда
			Если Пометка = Истина Тогда
				Вариант = "Документ " + СтрокаДок + " помечен на удаление!";
			Иначе
				Вариант = "У документа " + СтрокаДок + " снята пометка на удаление!";
			КонецЕсли;
			ОбщегоНазначения.СообщитьПользователю(Вариант);
		КонецЕсли;

	Исключение
		Если СообщитьОбОшибке Тогда
			Если Пометка = Истина Тогда
				Вариант = "У документ " + СтрокаДок + " не удалось установить пометку на удаление!";
			Иначе
				Вариант = "У документа " + СтрокаДок + " не удалось снять пометку на удаление!";
			КонецЕсли;
			ОбщегоНазначения.СообщитьПользователю(Вариант + " Ошибка: " + ОписаниеОшибки(), , , , Отказ);
		КонецЕсли;
	КонецПопытки;
КонецПроцедуры

