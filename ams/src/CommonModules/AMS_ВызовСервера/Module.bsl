Функция ПолучитьТранспортныеУслуги(Партнер, Сумма, ЦенаВключаетНДС) Экспорт
	Стр = Новый Структура();
	
	ДанныеТранспортныхУслуг = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(Партнер,
		 "_ТранпортнаяУслугаСпособ, _ТранпортнаяУслуга, _ТранпортнаяУслугаПроцент, _ТранпортнаяУслугаСумма");
	
	Если ДанныеТранспортныхУслуг._ТранпортнаяУслугаСпособ = 0 Тогда 
		Цена = Сумма * ДанныеТранспортныхУслуг._ТранпортнаяУслугаПроцент / 100;
	Иначе
		Цена = ДанныеТранспортныхУслуг._ТранпортнаяУслугаСумма;
	КонецЕсли;
	
	Номенклатура = ДанныеТранспортныхУслуг._ТранпортнаяУслуга;
	СтавкаНДС    = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Номенклатура, "СтавкаНДС");
	Ставка       = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(СтавкаНДС, "Ставка");
	
	Если ЦенаВключаетНДС Тогда
		Цена  = Цена * (100 + Ставка) / 100;
	КонецЕсли;
	
	Стр.Вставить("Номенклатура", Номенклатура);
	Стр.Вставить("КоличествоУпаковок",         1);
	Стр.Вставить("Количество",                 1);
	Стр.Вставить("Цена",                       Цена);
	Стр.Вставить("СтавкаНДС",                  СтавкаНДС);
	Стр.Вставить("Сумма",                      Цена);
	Стр.Вставить("СуммаНДС",                   Цена * Ставка / 100);
	Стр.Вставить("СуммаСНДС",                  Стр.Сумма + Стр.СуммаНДС);
	Стр.Вставить("ТипНоменклатуры",            ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));
	Стр.Вставить("БезВозвратнойТары",          Истина);
	Стр.Вставить("СуммаБезВозвратнойТары",     Стр.Сумма);
	Стр.Вставить("СуммаНДСБезВозвратнойТары",  Стр.СуммаНДС);
	Стр.Вставить("СуммаСНДСБезВозвратнойТары", Стр.СуммаСНДС);
	
	Возврат Стр;	
КонецФункции
