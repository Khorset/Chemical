Функция ПолучитьСоставОсновнойСпецификации(Номенклатура) Экспорт 
	МассивДанных = Новый Массив();
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК КоличествоМатериал,
	|	д.Количество КАК КоличествоФабрикат
	|ИЗ
	|	Справочник._ВариантыСпецификацийНоменклатуры.Товары КАК т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник._ВариантыСпецификацийНоменклатуры КАК д
	|		ПО т.Ссылка = д.Ссылка
	|ГДЕ
	|	д.Владелец = &Номенклатура
	|	И д.Основной
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Номенклатура.Наименование";
	Табл = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Стр Из Табл Цикл
		МассивДанных.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;
	
	Возврат МассивДанных;
КонецФункции

Функция ПолучитьСтоимостьФабриката(Спецификация, Дата) Экспорт 
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Спецификация", Спецификация);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СпецТ.Номенклатура КАК Номенклатура,
	|	СпецД.Количество КАК Замес,
	|	СпецТ.Количество КАК Норма
	|ИЗ
	|	Справочник._ВариантыСпецификацийНоменклатуры КАК СпецД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник._ВариантыСпецификацийНоменклатуры.Товары КАК СпецТ
	|		ПО СпецД.Ссылка = СпецТ.Ссылка
	|ГДЕ
	|	СпецД.Ссылка = &Спецификация
	|	И НЕ СпецТ.Номенклатура.Код = ""01-00000017""";
	
	Табл = Запрос.Выполнить().Выгрузить();
	
	МВТ = Новый МенеджерВременныхТаблиц;
	
	Парам = Новый Структура;
	Парам.Вставить("Дата", Дата);
	Парам.Вставить("Номенклатура", Табл.ВыгрузитьКолонку("Номенклатура"));

	ПолучитьСтоимостьТовара(МВТ, Парам);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Табл", Табл);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Замес КАК Замес,
	|	т.Норма КАК Норма
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Табл КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт.Номенклатура КАК Номенклатура,
	|	ЦенаТовара.Цена * вт.Норма КАК Сумма,
	|	вт.Замес КАК Замес
	|ПОМЕСТИТЬ вт1
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенаТовара КАК ЦенаТовара
	|		ПО вт.Номенклатура = ЦенаТовара.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(т.Сумма) / МАКСИМУМ(т.Замес) КАК Стоимость
	|ИЗ
	|	вт1 КАК т";
	
	Рез = Запрос.Выполнить();
	
	Если Рез.Пустой() Тогда
		Возврат 0;		
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		
		Возврат Выб.Стоимость;
	КонецЕсли;
КонецФункции

Функция ПолучитьСтоимостьПродукции(Спецификация, СтоимостьФабриката, Дата) Экспорт 
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Спецификация", Спецификация);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СпецТ.Номенклатура КАК Номенклатура,
	|	СпецТ.Количество КАК Количество
	|ИЗ
	|	Справочник._ВариантыСпецификацийНоменклатуры КАК СпецД
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник._ВариантыСпецификацийНоменклатуры.Товары КАК СпецТ
	|		ПО СпецД.Ссылка = СпецТ.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО СпецТ.Номенклатура = Ном.Ссылка
	|ГДЕ
	|	СпецД.Ссылка = &Спецификация";
	
	Табл = Запрос.Выполнить().Выгрузить();
	
	Если СтоимостьФабриката = 0 Тогда
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("Табл", Табл);
		Запрос.УстановитьПараметр("ВидыНоменклатуры", ВидыНоменклатурыФабрикаты());
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Табл.Номенклатура КАК Номенклатура,
		|	Табл.Количество КАК Количество
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	&Табл КАК Табл
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт.Номенклатура КАК Номенклатура
		|ИЗ
		|	вт КАК вт
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
		|		ПО вт.Номенклатура = Ном.Ссылка
		|ГДЕ
		|	Ном.ВидНоменклатуры В (&ВидыНоменклатуры)";
		
		Рез = Запрос.Выполнить();
		
		Если Не Рез.Пустой() Тогда
			Выб = Рез.Выбрать();
			Выб.Следующий();
			Фабрикат = Выб.Номенклатура;
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Дата", Дата);
			Запрос.УстановитьПараметр("Номенклатура", Фабрикат);
			
			Запрос.Текст =
				"ВЫБРАТЬ
				|	д.Дата КАК Дата,
				|	ф.Спецификация КАК Спецификация
				|ПОМЕСТИТЬ вт
				|ИЗ
				|	Документ.AMS_ПроизводствоЗаСмену.Фабрикаты КАК ф
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ПроизводствоЗаСмену КАК д
				|		ПО ф.Ссылка = д.Ссылка
				|ГДЕ
				|	д.Дата < &Дата
				|	И ф.Номенклатура = &Номенклатура
				|	И НЕ ф.Спецификация = ЗНАЧЕНИЕ(Справочник._ВариантыСпецификацийНоменклатуры.ПустаяСсылка)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ ПЕРВЫЕ 1
				|	вт.Дата КАК Дата,
				|	вт.Спецификация КАК Спецификация
				|ИЗ
				|	вт КАК вт
				|
				|УПОРЯДОЧИТЬ ПО
				|	Дата УБЫВ";
			
			Рез = Запрос.Выполнить();
			Если Не Рез.Пустой() Тогда
				Выб = Рез.Выбрать();
				Выб.Следующий();
				СпецификацияФабриката = Выб.Спецификация;
				СтоимостьФабриката = ПолучитьСтоимостьФабриката(СпецификацияФабриката, Дата)
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	МВТ = Новый МенеджерВременныхТаблиц;
	
	Парам = Новый Структура;
	Парам.Вставить("Дата", Дата);
	Парам.Вставить("Номенклатура", Табл.ВыгрузитьКолонку("Номенклатура"));

	ПолучитьСтоимостьТовара(МВТ, Парам);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Табл", Табл);
	Запрос.УстановитьПараметр("СтоимостьФабриката", СтоимостьФабриката);
	Запрос.УстановитьПараметр("ВидыНоменклатуры", ВидыНоменклатурыФабрикаты());
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Табл.Номенклатура КАК Номенклатура,
	|	Табл.Количество КАК Количество
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Табл КАК Табл
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	вт.Номенклатура КАК Номенклатура,
	|	вт.Количество КАК Количество,
	|	ЦенаТовара.Цена КАК Цена,
	|	ВЫБОР
	|		КОГДА Ном.ВидНоменклатуры В (&ВидыНоменклатуры)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоФабрикат
	|ПОМЕСТИТЬ вт1
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенаТовара КАК ЦенаТовара
	|		ПО вт.Номенклатура = ЦенаТовара.Номенклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО вт.Номенклатура = Ном.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА т.ЭтоФабрикат
	|			ТОГДА &СтоимостьФабриката
	|		ИНАЧЕ т.Цена
	|	КОНЕЦ * т.Количество КАК Сумма
	|ПОМЕСТИТЬ вт2
	|ИЗ
	|	вт1 КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(т.Сумма) КАК Сумма
	|ИЗ
	|	вт2 КАК т";
	
	Рез = Запрос.Выполнить();
	
	Если Рез.Пустой() Тогда
		Возврат 0;		
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		
		Возврат Выб.Сумма;
	КонецЕсли;
КонецФункции

Функция ПолучитьИмяБазы() Экспорт
	ДанныеБазы = Новый Структура();
	
    СтрокаИБ = СтрокаСоединенияИнформационнойБазы(); //File="D:\Base".
    //Возвращает Строка соединения информационной базы, которую, например,
    //можно использовать для запуска 1С:Предприятия средствами встроенного языка
    ПутьИБ = СтрНайти(Врег(СтрокаИБ), "FILE=");

    Если ПутьИБ = 1 тогда // Файловая информационная база 1С:Предприятия 8 (.1CD)

        Возврат Сред(СтрокаИБ,7,СтрДлина(СтрокаИБ)-8)+"\"; // Получим D:\Base

    Иначе
        ПозицияПоиска = СтрНайти(Врег(СтрокаИБ), "SRVR=");
        Если ПозицияПоиска <> 1 Тогда
            Возврат Неопределено;
        КонецЕсли;

        ПозицияТЧК_ЗПТ = СтрНайти(СтрокаИБ, ";");
        ПозСтарт = 6 + 1;
        ПозФиниш = ПозицияТЧК_ЗПТ - 2; //

        ИмяСервера = Сред(СтрокаИБ, ПозСтарт, ПозФиниш - ПозСтарт + 1);
        
        СтрокаИБ = Сред(СтрокаИБ, ПозицияТЧК_ЗПТ + 1);
        ПутьИБ = СтрНайти(Врег(СтрокаИБ), "REF=");// позиция имени сервера
        Если ПутьИБ <> 1 Тогда
            Возврат Неопределено;
        КонецЕсли;

        ПозСтарт = 6;
        ПозицияТЧК_ЗПТ = СтрНайти(СтрокаИБ, ";");
        ПозФиниш = ПозицияТЧК_ЗПТ - 2;

        ИмяИБНаСервере = Сред(СтрокаИБ, ПозСтарт, ПозФиниш - ПозСтарт + 1);
        
        ДанныеБазы.Вставить("ИмяСервера", ИмяСервера);
        ДанныеБазы.Вставить("ИмяБазы", ИмяИБНаСервере);
        ДанныеБазы.Вставить("КаталогВременныхФайлов", КаталогВременныхФайлов());
        
        Возврат ДанныеБазы;
    КонецЕсли;
КонецФункции

#Область СКД

Процедура ВыполнитьСКД(Данные) Экспорт
	СКД       = Данные.СКД;
	Результат = Данные.Результат;
	
	Настройки = Неопределено;
	Данные.Свойство("Настройки", Настройки);

	Вариант = Неопределено;
	Данные.Свойство("Вариант", Вариант);
	
	Параметры = Неопределено;
	Данные.Свойство("Параметры", Параметры);
	
	Расшифровка = Неопределено;
	Данные.Свойство("Расшифровка", Расшифровка);
	
	МакетКомпоновки = Неопределено;
	Данные.Свойство("МакетКомпоновки", МакетКомпоновки);
	
	ВнешниеНаборыДанных = Неопределено;
	Данные.Свойство("ВнешниеНаборыДанных", ВнешниеНаборыДанных);

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;

	Если ТипЗнч(Результат) = Тип("ТабличныйДокумент") Тогда
		ТипГенератора = Тип("ГенераторМакетаКомпоновкиДанных");
	Иначе
		ТипГенератора = Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений");
	КонецЕсли;

	Если Настройки = Неопределено Тогда
		Если Вариант = Неопределено Тогда
			Настройки = СКД.НастройкиПоУмолчанию;
		Иначе
			Настройки = СКД.ВариантыНастроек.Найти(Вариант).Настройки;
		КонецЕсли;
	КонецЕсли;

	Если Параметры <> Неопределено Тогда
		КоллекцияЗначенийПараметров = Настройки.ПараметрыДанных.Элементы;
		Для Каждого Параметр Из Параметры Цикл
			НайденноеЗначениеПараметра = КоллекцияЗначенийПараметров.Найти(Параметр.Ключ);
			Если НайденноеЗначениеПараметра <> Неопределено Тогда
				НайденноеЗначениеПараметра.Использование = Истина;
				НайденноеЗначениеПараметра.Значение = Параметр.Значение;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	МакетКомпоновкиСКД = КомпоновщикМакета.Выполнить(СКД, Настройки, Расшифровка, МакетКомпоновки, ТипГенератора);

	ПроцессорКомпановки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпановки.Инициализировать(МакетКомпоновкиСКД, ВнешниеНаборыДанных, Расшифровка);

	Если ТипЗнч(Результат) = Тип("ТабличныйДокумент") Тогда
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
		ПроцессорВывода.УстановитьДокумент(Результат);
	Иначе
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		ПроцессорВывода.УстановитьОбъект(Результат);
	КонецЕсли;

	ПроцессорВывода.ОтображатьПроцентВывода = Истина;
	ПроцессорВывода.Вывести(ПроцессорКомпановки, Истина);
КонецПроцедуры

