Функция ЕстьПравоАМС(Право) Экспорт
	Если ЭтоKhors() Тогда
		Возврат Истина;	
	
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Право КАК Право,
		|	т.Пользователь КАК Пользователь
		|ИЗ
		|	РегистрСведений.AMS_ПраваПользователей КАК т
		|ГДЕ
		|	т.Право = &Право
		|	И т.Пользователь = &Пользователь";
	
		Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
		Запрос.УстановитьПараметр("Право", Право);
	
		Возврат Не Запрос.Выполнить().Пустой();
	КонецЕсли;
КонецФункции

