Функция ПолучитьАдресаДоставки(Партнер) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер", Партнер);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.АдресДоставки КАК АдресДоставки,
	|	т.АдресДоставкиЗначение КАК АдресДоставкиЗначение,
	|	т.АдресДоставкиЗначенияПолей КАК АдресДоставкиЗначенияПолей,
	|	т.ВремяДоставкиПо КАК ВремяДоставкиПо,
	|	т.ВремяДоставкиС КАК ВремяДоставкиС,
	|	т.ДополнительнаяИнформацияПоДоставке КАК ДополнительнаяИнформацияПоДоставке,
	|	т.ЗонаДоставки КАК ЗонаДоставки
	|ИЗ
	|	Справочник.AMS_АдресаДоставки КАК т
	|ГДЕ
	|	т.Владелец = &Партнер
	|	И НЕ т.ПометкаУдаления";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ПолучитьАдресДоставки(Партнер) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Вид,
	|	т.Представление
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК т
	|ГДЕ
	|	т.Ссылка = &Партнер
	|	И т.Вид = &АдресДоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Вид,
	|	т.Представление
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК т
	|ГДЕ
	|	т.Ссылка = &Партнер
	|	И т.Вид = &АдресФактический
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Вид,
	|	т.Представление
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК т
	|ГДЕ
	|	т.Ссылка = &Партнер
	|	И т.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресПартнера)";

	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("АдресДоставки", Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию(
		"Адрес доставки", Истина));
	Запрос.УстановитьПараметр("АдресФактический", Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию(
		"Фактический адрес", Истина));

	УстановитьПривилегированныйРежим(Истина);

	Рез  = Запрос.ВыполнитьПакет();
	Рез1 = Рез[0];
	Рез2 = Рез[1];
	Рез3 = Рез[2];

	Если Не Рез1.Пустой() Тогда
		Возврат Рез1.Выгрузить().ВыгрузитьКолонку("Представление")[0];

	ИначеЕсли Не Рез2.Пустой() Тогда
		Возврат Рез2.Выгрузить().ВыгрузитьКолонку("Представление")[0];

	ИначеЕсли Не Рез3.Пустой() Тогда
		Возврат Рез3.Выгрузить().ВыгрузитьКолонку("Представление")[0];

	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции

Функция ПолучитьЗонаДоставки(Партнер, АдресДоставки) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("АдресДоставки", АдресДоставки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.ЗонаДоставки КАК ЗонаДоставки
	|ИЗ
	|	Справочник.AMS_АдресаДоставки КАК т
	|ГДЕ
	|	т.Владелец = &Партнер
	|	И т.Наименование = &АдресДоставки";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Справочники.ЗоныДоставки.ПустаяСсылка();
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		
		Возврат Выб.ЗонаДоставки;
	КонецЕсли;
КонецФункции

Функция ПолучитьДанныеАдресаДоставки(Партнер, Адрес) Экспорт
	ДанныеАдреса = Новый Структура("АдресДоставки, ЗонаДоставки, Расстояние");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("Адрес", Адрес);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Наименование КАК АдресДоставки,
	|	т.ЗонаДоставки КАК ЗонаДоставки,
	|	т.Расстояние КАК Расстояние
	|ИЗ
	|	Справочник.AMS_АдресаДоставки КАК т
	|ГДЕ
	|	т.Владелец = &Партнер
	|	И т.Наименование = &Адрес";

	Рез = Запрос.Выполнить();
	
	Если Рез.Пустой() Тогда
		ДанныеАдреса.АдресДоставки = "";
		ДанныеАдреса.ЗонаДоставки  = Справочники.ЗоныДоставки.ПустаяСсылка();
		ДанныеАдреса.Расстояние    = 0;	
	Иначе
		
		ДанныеАдреса.АдресДоставки = "";
		ДанныеАдреса.ЗонаДоставки  = Справочники.ЗоныДоставки.ПустаяСсылка();
		ДанныеАдреса.Расстояние    = 0;	
	КонецЕсли;
	
	Возврат ДанныеАдреса;
КонецФункции

Процедура ЗаписатьРасстояние(Партнер, АдресДоставки, Расстояние) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Владелец", Партнер);
	Запрос.УстановитьПараметр("АдресДоставки", АдресДоставки);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.AMS_АдресаДоставки КАК т
	|ГДЕ
	|	т.Владелец = &Владелец
	|	И т.АдресДоставки = &АдресДоставки";
	
	Рез = Запрос.Выполнить();
	
	Если Не Рез.Пустой() Тогда
		Выб = Рез.Выбрать(); Выб.Следующий();
		
		АдресДоставки = Выб.Ссылка.ПолучитьОбъект();
		
		АдресДоставки.Расстояние = Расстояние;
		
		АдресДоставки.Записать();
	КонецЕсли;
КонецПроцедуры

