Функция ПолучитьНаименованиеДоговора(Номер, Дата, Организация, Партнер, Контрагент, ТипДоговора, СтароеНаименование) Экспорт
	Стр = Новый Структура("Наименование,НаименованиеДляПечати");

	НомерДата = СокрЛП(Номер) + " от " + Формат(Дата, "ДЛФ=Д") + " г.";
	
	//Наименование
	Если Организация = ОрганизацияКемикал() Тогда
		Если ТипДоговора = ПредопределенноеЗначение("Перечисление.ТипыДоговоров.СПокупателем") Тогда
			Наименование = "Договор № " + НомерДата;
		ИначеЕсли ТипДоговора = ПредопределенноеЗначение("Перечисление.ТипыДоговоров.СПоставщиком") Тогда
			Наименование = "Договор закупки № " + НомерДата;
		КонецЕсли;

	ИначеЕсли Организация = ОрганизацияТрейд() Тогда
		Если ТипДоговора = ПредопределенноеЗначение("Перечисление.ТипыДоговоров.СПокупателем") Тогда
			Наименование = "Контракт № " + НомерДата;
		ИначеЕсли ТипДоговора = ПредопределенноеЗначение("Перечисление.ТипыДоговоров.СПоставщиком") Тогда
			Наименование = "Договор закупки № " + НомерДата;
		КонецЕсли;

	Иначе
		ОрганизацияДоговора = Организация;
		КонтрагентДоговора  = Контрагент;
		ПартнерДоговора     = Партнер;
		ПартнерКонтрагента  = КонтрагентДоговора.Партнер;
		ГоловноеПредприятие = ПартнерДоговора.Родитель;

		Если ПартнерКонтрагента = ПартнерДоговора Тогда
			Наименование = СокрЛП(КонтрагентДоговора.Наименование) + " с " + СокрЛП(ОрганизацияДоговора.Наименование);

		ИначеЕсли ПартнерКонтрагента = ГоловноеПредприятие Тогда
			Наименование = СокрЛП(КонтрагентДоговора.Наименование) + " с " + СокрЛП(ОрганизацияДоговора.Наименование)
				+ ?(ЗначениеЗаполнено(КонтрагентДоговора), " для " + СокрЛП(ПартнерДоговора.Наименование), "");

		КонецЕсли;
	КонецЕсли;

	Если СтрНайти(СтароеНаименование, Наименование) = 0 Тогда
		Стр.Наименование = Наименование;
	Иначе
		Стр.Наименование = СтароеНаименование;
	КонецЕсли;
	//Наименование
	
	//НаименованиеДляПечати
	Если Организация = ОрганизацияТрейд() Тогда
		Стр.НаименованиеДляПечати = "Контракт № " + НомерДата;
	Иначе
		Стр.НаименованиеДляПечати = "Договор № " + НомерДата;
	КонецЕсли;
	//НаименованиеДляПечати

	Возврат Стр;
КонецФункции
Функция ПолучитьНаименованиеПравила(Знач Правило) Экспорт
	Договор = Правило.Договор;

	Если ЗначениеЗаполнено(Договор) Тогда
		ОрганизацияДоговора = Договор.Организация;
		КонтрагентДоговора  = Договор.Контрагент;
		ПартнерДоговора     = Договор.Партнер;
		ПартнерКонтрагента  = КонтрагентДоговора.Партнер;
		ГоловноеПредприятие = ПартнерДоговора.Родитель;

		Если ПартнерКонтрагента = ПартнерДоговора Тогда
			Возврат СокрЛП(КонтрагентДоговора.Наименование) + " с " + СокрЛП(ОрганизацияДоговора.Наименование);

		ИначеЕсли ПартнерКонтрагента = ГоловноеПредприятие Тогда
			Возврат СокрЛП(КонтрагентДоговора.Наименование) + " с " + СокрЛП(ОрганизацияДоговора.Наименование) + ?(
				ЗначениеЗаполнено(КонтрагентДоговора), " для " + СокрЛП(ПартнерДоговора.Наименование), "");

		КонецЕсли;

	Иначе
		Возврат Правило.Контрагент.Наименование + " с " + Правило.Организация.Наименование;
	КонецЕсли;
