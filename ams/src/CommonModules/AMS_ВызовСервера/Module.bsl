	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Спр, "Значение");
КонецФункции

Функция ПолучитьАдресПользовательскиеНастройки(ИмяОтчета, ПараметрыПользователя, ИмяВарианта = Неопределено) Экспорт
	ОтчетОбъект = Отчеты[ИмяОтчета].Создать();
	КомпоновщикНастроек = ОтчетОбъект.КомпоновщикНастроек;
	Если ИмяВарианта = Неопределено Тогда
		Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	
	Иначе
		Варианты = ОтчетОбъект.СхемаКомпоновкиДанных.ВариантыНастроек;
		НайденныйВариант = Варианты.Найти(ИмяВарианта);

		Если НайденныйВариант <> Неопределено Тогда
			Настройки = НайденныйВариант.Настройки;
			Для Каждого ПараметрПользователя Из ПараметрыПользователя Цикл
				Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(ПараметрПользователя.Ключ,
					ПараметрПользователя.Значение);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

	КомпоновщикНастроек.ЗагрузитьНастройки(Настройки);

	Возврат ПоместитьВоВременноеХранилище(КомпоновщикНастроек.ПользовательскиеНастройки, Новый УникальныйИдентификатор);
КонецФункции

Функция ПолучитьВозможностиСклада(Дата) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	т.Дата КАК Дата,
	|	т.Количество КАК Количество
	|ИЗ
	|	РегистрСведений._ВозможностиСклада КАК т
	|ГДЕ
	|	т.Дата <= КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат 25000;
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();

		Возврат Выб.Количество;
	КонецЕсли;
КонецФункции
Функция ПолучитьДатуUNIX(Дата) Экспорт
	Возврат Дата - Дата(1970,1,1);
КонецФункции

Функция ПолучитьТекущуюДатуИУстановленноеВремя(Час, Мин) Экспорт
	Возврат НачалоДня(ТекущаяДатаСеанса()) + ПолучитьВремя(7,0);
КонецФункции
Функция ПолучитьВремя(Час, Мин) Экспорт
	Возврат 3600 * Час + 60 * Мин;
КонецФункции
Функция ПолучитьВремяСтрока(Время) Экспорт
	Если ЗначениеЗаполнено(Время) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Время", Время);
		Запрос.Текст = "ВЫБРАТЬ ПОДСТРОКА(""0123456789"", ЧАС(&Время) / 10 + 1, 1) + ПОДСТРОКА(""0123456789"", СЕКУНДА(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), СЕКУНДА, 6 * ЧАС(&Время))) / 6 + 1, 1) + "":"" + ПОДСТРОКА(""0123456789"", МИНУТА(&Время) / 10 + 1, 1) + ПОДСТРОКА(""0123456789"", СЕКУНДА(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), СЕКУНДА, 6 * МИНУТА(&Время))) / 6 + 1, 1) КАК Время";
		Рез = Запрос.Выполнить();
		Выб = Рез.Выбрать();
		Выб.Следующий();
		Возврат Выб.Время;
	Иначе
		Возврат "00:00";
	КонецЕсли;
КонецФункции
Функция ПолучитьДатуПрайса(ВидЦены) Экспорт
	Если Не ЗначениеЗаполнено(ВидЦены) Тогда
		Возврат '00010101';
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	МАКСИМУМ(т.Период) КАК Период
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры КАК т
	|ГДЕ
	|	т.ВидЦены В(&ВидЦены)";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат '00010101';
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		Возврат Выб.Период;
	КонецЕсли;
КонецФункции
Функция ПолучитьРабочийДень(ПорядковыйНомер, ДатаНачала = Неопределено, ТекущееВремя = Ложь, КалендарьРФ = Ложь) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Если ДатаНачала = Неопределено Тогда
		ДатаНачала = НачалоДня(ТекущаяДатаСеанса());
	КонецЕсли;

	Если КалендарьРФ Тогда
		ПроизводственныйКалендарь = Справочники.Календари.НайтиПоНаименованию("Календарь РФ", Истина);
	Иначе
		ПроизводственныйКалендарь = Справочники.Календари.НайтиПоНаименованию("Производственный календарь", Истина);
	КонецЕсли; 

	Если ПорядковыйНомер = 0 Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Календарь", ПроизводственныйКалендарь);
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);

		Запрос.Текст =
		"ВЫБРАТЬ
		|	таб.ДатаГрафика КАК Дата
		|ИЗ
		|	РегистрСведений.КалендарныеГрафики КАК таб
		|ГДЕ
		|	таб.Календарь = &Календарь
		|	И таб.ДеньВключенВГрафик
		|	И таб.ДатаГрафика = &ДатаНачала";

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			РабочийДень = Неопределено;  //Это выходной день
		Иначе
			Выборка = Результат.Выбрать();
			Выборка.Следующий();
			РабочийДень = Выборка.Дата;
		КонецЕсли;

	ИначеЕсли ПорядковыйНомер > 0 Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Календарь", ПроизводственныйКалендарь);
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);

		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ " + Строка(ПорядковыйНомер) +
		"
		|   таб.ДатаГрафика КАК Дата
		|ПОМЕСТИТЬ втРабДни
		|ИЗ
		|   РегистрСведений.КалендарныеГрафики КАК таб
		|ГДЕ
		|   таб.Календарь = &Календарь
		|   И таб.ДеньВключенВГрафик
		|   И таб.ДатаГрафика > &ДатаНачала
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|   МАКСИМУМ(Табл.Дата) КАК Дата
		|ИЗ
		|   втРабДни КАК Табл";

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			РабочийДень = Неопределено;
		Иначе
			Выборка = Результат.Выбрать();
			Выборка.Следующий();
			РабочийДень = Выборка.Дата;
		КонецЕсли;

	ИначеЕсли ПорядковыйНомер < 0 Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Календарь", ПроизводственныйКалендарь);
		Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);

		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ " + Строка(-ПорядковыйНомер) +
		"
		|   таб.ДатаГрафика КАК Дата
		|ИЗ
		|   РегистрСведений.КалендарныеГрафики КАК таб
		|ГДЕ
		|   таб.Календарь = &Календарь
		|   И таб.ДеньВключенВГрафик
		|   И таб.ДатаГрафика < &ДатаНачала
		|
		|УПОРЯДОЧИТЬ ПО
		|   Дата УБЫВ";

		Результат = Запрос.Выполнить();

		Если Результат.Пустой() Тогда
			РабочийДень = Неопределено;
		Иначе
			МассивДат = Результат.Выгрузить().ВыгрузитьКолонку("Дата");
			РабочийДень = МассивДат[МассивДат.Количество() - 1];
		КонецЕсли;
	КонецЕсли;
	
	Если ТекущееВремя Тогда
		РабочийДень = РабочийДень + (ТекущаяДатаСеанса() - НачалоДня(ТекущаяДатаСеанса()));
	КонецЕсли;
		
	Возврат РабочийДень;	
КонецФункции

Функция ПолучитьКонтрагентаПартнёра(Партнер, ИНН = Неопределено, КПП = Неопределено) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ИНН",     ИНН);
	Запрос.УстановитьПараметр("КПП",     КПП);
		
	Если ИНН = Неопределено Или КПП = Неопределено Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		|	таб.Ссылка КАК Контрагент
		|ИЗ
		|	Справочник.Контрагенты КАК таб
		|ГДЕ
		|	таб.Партнер = &Партнер
		|	И НЕ таб._Закрыт
		|	И НЕ таб.ПометкаУдаления";
		
	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ
		|	таб.Ссылка КАК Контрагент
		|ИЗ
		|	Справочник.Контрагенты КАК таб
		|ГДЕ
		|	НЕ таб.ПометкаУдаления
		|	И НЕ таб._Закрыт
		|	И таб.Партнер = &Партнер
		|	И таб.ИНН = &ИНН
		|	И таб.КПП = &КПП
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	таб.Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК таб
		|ГДЕ
		|	НЕ таб.ПометкаУдаления
		|	И НЕ таб._Закрыт
		|	И таб.Партнер = &Партнер
		|	И таб.НалоговыйНомер = &КПП";
	КонецЕсли;

	Табл = Запрос.Выполнить().Выгрузить();
	Если Табл.Количество() = 1 Тогда
		Возврат Табл[0].Контрагент;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

#Область Логистика

Функция ВключенВЛогитическийЛист(Распоряжения) Экспорт
	Если Не ЗначениеЗаполнено(Распоряжения) Тогда
		Возврат Ложь;
	КонецЕсли;

	ЛогистическийЛист = ПолучитьЛогистическийЛист(Распоряжения);
	
	Возврат ЗначениеЗаполнено(ЛогистическийЛист);
КонецФункции

Функция ПолучитьЛогистическийЛист(Распоряжения) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжения", Распоряжения);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т.Ссылка КАК ЛогистическийЛист
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
	|ГДЕ
	|	т.Распоряжение В (&Распоряжения)
	|	И НЕ т.Ссылка.ПометкаУдаления";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Выб = Рез.Выбрать(); Выб.Следующий();
		Возврат Выб.ЛогистическийЛист;
	КонецЕсли;
КонецФункции

Функция ПолучитьЛогистическийЛистРасходныйОрдер(Распоряжение) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
	|ГДЕ
	|	т.Распоряжение = &Распоряжение
	|	И НЕ т.Ссылка.ПометкаУдаления
	|
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК т
	|ГДЕ
	|	т.Распоряжение = &Распоряжение
	|	И НЕ т.Ссылка.ПометкаУдаления";

	Рез = Запрос.ВыполнитьПакет();

	Стр = Новый Структура("ЛогистическийЛист,РасходныйОрдерНаТовары");

	Если Рез[0].Пустой() Тогда
		Стр.ЛогистическийЛист = Неопределено;
	Иначе
		Выб = Рез[0].Выбрать();
		Выб.Следующий();
		Стр.ЛогистическийЛист = Выб.Ссылка;
	КонецЕсли;

	Если Рез[1].Пустой() Тогда
		Стр.РасходныйОрдерНаТовары = Неопределено;
	Иначе
		Выб = Рез[1].Выбрать();
		Выб.Следующий();
		Стр.РасходныйОрдерНаТовары = Выб.Ссылка;
	КонецЕсли;

	Возврат Стр;
КонецФункции

