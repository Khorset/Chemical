Функция ПолучитьГруппуДоступаМенеджера(Пользователь) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Пользователь", Пользователь);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	ГруппыДоступа.Ссылка КАК Ссылка,
	|	ГруппыПользователейСостав.Пользователь КАК Пользователь
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Справочник.ГруппыДоступа КАК ГруппыДоступа
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав
	|			ПО ГруппыДоступаПользователи.Пользователь = ГруппыПользователейСостав.Ссылка
	|		ПО ГруппыДоступа.Ссылка = ГруппыДоступаПользователи.Ссылка
	|ГДЕ
	|	ГруппыПользователейСостав.Пользователь = &Пользователь
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ГруппыДоступаЗначенияДоступа.ЗначениеДоступа КАК ГруппаДоступа
	|ИЗ
	|	Справочник.ГруппыДоступа.ЗначенияДоступа КАК ГруппыДоступаЗначенияДоступа
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт КАК вт
	|		ПО (вт.Ссылка = ГруппыДоступаЗначенияДоступа.Ссылка)
	|ГДЕ
	|	НЕ(ГруппыДоступаЗначенияДоступа.ЗначениеДоступа.Наименование ПОДОБНО ""%умолчанию%""
	|				ИЛИ ГруппыДоступаЗначенияДоступа.ЗначениеДоступа.Наименование ПОДОБНО ""%Поставщики%""
	|				ИЛИ ГруппыДоступаЗначенияДоступа.ЗначениеДоступа.Наименование ПОДОБНО ""%Перевозчики%"")";

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ГруппаДоступа");
КонецФункции
Функция ПолучитьИмяГруппыДоступаРеализации(Реализация) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Реализация", Реализация);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	ГруппыДоступа.Наименование КАК ГруппаДоступаНаименование
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реал
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Парт
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступаПартнеров КАК ГруппыДоступа
	|			ПО Парт.ГруппаДоступа = ГруппыДоступа.Ссылка
	|		ПО Реал.Партнер = Парт.Ссылка
	|ГДЕ
	|	Реал.Ссылка = &Реализация";

	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	Выб.Следующий();

	Возврат Выб.ГруппаДоступаНаименование;
КонецФункции

