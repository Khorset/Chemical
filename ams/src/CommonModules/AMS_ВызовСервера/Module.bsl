Функция ПолучитьТоварыНеУказанныеКОтгрузке(ЗаказКлиента)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.НомерСтроки КАК НомерСтроки,
	|	т.Номенклатура.Наименование КАК Номенклатура
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &ЗаказКлиента
	|	И НЕ т.ВариантОбеспечения = ЗНАЧЕНИЕ(Перечисление.ВариантыОбеспечения.Отгрузить)";
	
	
	Табл = Запрос.Выполнить().Выгрузить();
	
	МассивСтрок = Новый Массив();
	
	Для Каждого Стр Из Табл Цикл
		МассивСтрок.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;
	
	Возврат МассивСтрок;
КонецФункции

