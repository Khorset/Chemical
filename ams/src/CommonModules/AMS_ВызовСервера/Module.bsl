	|		ЛЕВОЕ СОЕДИНЕНИЕ ШтрихКор КАК ШтрихКор
	|		ПО Тов.Номенклатура = ШтрихКор.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ШтрихПал КАК ШтрихПал
	|		ПО Тов.Номенклатура = ШтрихПал.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЕдШт КАК ЕдШт
	|		ПО Тов.Номенклатура = ЕдШт.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЕдКор КАК ЕдКор
	|		ПО Тов.Номенклатура = ЕдКор.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЕдПал КАК ЕдПал
	|		ПО Тов.Номенклатура = ЕдПал.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ШтрихЕд КАК ШтрихЕд
	|		ПО Тов.Номенклатура = ШтрихЕд.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура";

	Запрос.Выполнить();
КонецПроцедуры

Процедура ПолучитьПродукцию(МВТ, ПараметрыМВТ) Экспорт
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = МВТ;

	//@skip-check bsl-legacy-check-string-literal
	РодительПартнера = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыМВТ.Партнер, "Родитель", Истина);

	Запрос.УстановитьПараметр("ВидНомЦех1",  ВидНоменклатурыПродукцияЦеха1());
	Запрос.УстановитьПараметр("ВидНомЦех2",  ВидНоменклатурыПродукцияЦеха2());
	Запрос.УстановитьПараметр("ВидНомЦех3",  ВидНоменклатурыПродукцияЦеха3());
	Запрос.УстановитьПараметр("ВидНомНабор", ВидНоменклатурыПродукцияНаборы());
	Запрос.УстановитьПараметр("ВидНомТовар", ВидНоменклатурыТовар());
	
	Запрос.УстановитьПараметр("Цех1", Цех1());
	Запрос.УстановитьПараметр("Цех2", Цех2());
	Запрос.УстановитьПараметр("Цех3", Цех3());
	Запрос.УстановитьПараметр("СкладНаборов",   СкладСборкиНаборов());
	Запрос.УстановитьПараметр("СкладПродукции", СкладПродукции());
	
	Запрос.УстановитьПараметр("ДатаЦены",           ПараметрыМВТ.ДатаЦены);
	Запрос.УстановитьПараметр("МЕГА",               ПараметрыМВТ.МЕГА);
	Запрос.УстановитьПараметр("Соглашение",         ПараметрыМВТ.Соглашение);
	Запрос.УстановитьПараметр("ВидЦены",            ПараметрыМВТ.ВидЦены);
	Запрос.УстановитьПараметр("РодительИлиПартнер", ?(ЗначениеЗаполнено(РодительПартнера), РодительПартнера, ПараметрыМВТ.Партнер));
	Запрос.УстановитьПараметр("Партнер",            ПараметрыМВТ.Партнер);
	Запрос.УстановитьПараметр("ПравилоПродажи",     ПараметрыМВТ.ПравилоПродажи);
	Запрос.УстановитьПараметр("Дефис",              "-");

	Запрос.Текст =
	"ВЫБРАТЬ
	|	Прод.Родитель КАК ТипПродукции,
	|	Прод.Родитель.Наименование КАК ТипПродукцииНаименование,
	|	Прод.Ссылка КАК НазначениеПродукции,
	|	Прод.Наименование КАК НазначениеПродукцииНаименование,
	|	ПродТов.ТоварныйЗнак КАК ТоварныйЗнак,
	|	ПродТов.ТоварныйЗнак.Порядок КАК ТоварныйЗнакПорядок,
	|	ПродТов.НомерСтроки КАК НомерСтроки,
	|	ПродТов.Номенклатура КАК Номенклатура,
	|	Ном.Наименование КАК Наименование,
	|	Ном.НаименованиеПолное КАК НаименованиеПолное,
	|	ПродТов.Маркер КАК Маркер,
	|	ПродТов.Объем КАК ОбъемСтрока,
	|	ПродТов.СрокГодности КАК СрокГодности,
	|	ПродТов.Упаковка КАК УпаковкаСтрока,
	|	Ном._Упаковка КАК Упаковка,
	|	Ном._Упаковка.Вес КАК ВесУпаковка,
	|	Ном._Упаковка.Объем КАК ОбъемУпаковка,
	|	Ном.Код КАК Код,
	|	Ном.Артикул КАК Артикул,
	|	Ном.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	Ном.ВидНоменклатуры КАК ВидНоменклатуры,
	|	ВЫБОР
	|		КОГДА Ном.ВидНоменклатуры = &ВидНомЦех1
	|			ТОГДА &Цех1
	|		КОГДА Ном.ВидНоменклатуры = &ВидНомЦех2
	|			ТОГДА &Цех2
	|		КОГДА Ном.ВидНоменклатуры = &ВидНомЦех3
	|			ТОГДА &Цех3
	|		КОГДА Ном.ВидНоменклатуры = &ВидНомНабор
	|			ТОГДА &СкладНаборов
	|		КОГДА Ном.ВидНоменклатуры = &ВидНомТовар
	|			ТОГДА &СкладПродукции
	|	КОНЕЦ КАК Склад,
	|	Ном.КоэффициентЕдиницыДляОтчетов КАК КоличествоУпаковка,
	|	Ном.КоэффициентЕдиницыДляОтчетов КАК Кфц,
	|	Ном._Фабрикат КАК Фабрикат,
	|	Ном._КоличествоФабрикатаВУпаковке КАК КоличествоФабрикатаВУпаковке,
	|	Ном.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	ВЫБОР
	|		КОГДА Ном.НаборУпаковок = ЗНАЧЕНИЕ(Справочник.НаборыУпаковок.ИндивидуальныйДляНоменклатуры)
	|			ТОГДА Ном.Ссылка
	|		ИНАЧЕ Ном.НаборУпаковок
	|	КОНЕЦ КАК ВладелецНабораУпаковок,
	|	Ном.КодТНВЭД КАК КодТНВЭД,
	|	ПродТов.КфцРРЦ КАК КфцРРЦ,
	|	Ном.СтавкаНДС КАК СтавкаНДС,
	|	Ном.СтавкаНДС.Ставка КАК СтавкаНДССтавка,
	|	ПродТов.Прайс КАК Прайс,
	|	ПродТов.Заказ КАК Заказ,
	|	ПродТов.Подбор КАК Подбор,
	|	ПродТов.В2В КАК В2В,
	|	ПродТов.ЧестныйЗнак КАК ЧестныйЗнак
	|ПОМЕСТИТЬ Ном
	|ИЗ
	|	Справочник.AMS_Продукция КАК Прод
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция.Товары КАК ПродТов
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|			ПО ПродТов.Номенклатура = Ном.Ссылка
	|		ПО Прод.Ссылка = ПродТов.Ссылка
	|ГДЕ
	|	НЕ Прод.ЭтоГруппа
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ном.Номенклатура КАК Номенклатура,
	|	СогТов.ВидЦены КАК ВидЦены,
	|	СогТов.Цена КАК Цена
	|ПОМЕСТИТЬ ЦенДоп
	|ИЗ
	|	Ном КАК Ном
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СогТов
	|		ПО Ном.Номенклатура = СогТов.Номенклатура
	|ГДЕ
	|	СогТов.Ссылка = &Соглашение
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ном.Номенклатура КАК Номенклатура,
	|	СогЦенГр.ВидЦен КАК ВидЦены
	|ПОМЕСТИТЬ ВидЦенЦГ
	|ИЗ
	|	Ном КАК Ном
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СогЦенГр
	|		ПО Ном.ЦеноваяГруппа = СогЦенГр.ЦеноваяГруппа
	|ГДЕ
	|	СогЦенГр.Ссылка = &Соглашение
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
