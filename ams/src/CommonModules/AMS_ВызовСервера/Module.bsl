#Область СлужебныйПрограммныйИнтерфейс

// Функция, проверка вхождения в сегмент
//
// Параметры:
// ОбъектСсылка  - СправочникСсылка - номенклатура или партнер.
// СегментСсылка - СправочникСсылка - сегмент.
//
// Возвращаемое значение:
//  Булево - Признак, наличия документа в Логистическом листе
//

#Область Сегменты

// Входит в сегмент.
// 
// Параметры:
//  НоменклатураПартнер - СправочникСсылка.Номенклатура, СправочникСсылка.Партнеры - ссылка на справочник "Номенклатура" или "Партнеры"
//  Сегмент - СправочникСсылка.СегментыНоменклатуры, СправочникСсылка.СегментыПартнеров - ссылка на справочник "Сегменты номенклатуры" или "Сегменты партнеров", СправочникСсылка.ПартнерыСегмента 
// 
// Возвращаемое значение:
//  Неопределено, Булево - Входит в сегмент
Функция ВходитВСегмент(НоменклатураПартнер, Сегмент) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НоменклатураПартнер", НоменклатураПартнер);
	Запрос.УстановитьПараметр("Сегмент", Сегмент);

	Если ТипЗнч(НоменклатураПартнер) = Тип("СправочникСсылка.Номенклатура") Тогда
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	НоменклатураСегмента.Номенклатура
		|ИЗ
		|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
		|ГДЕ
		|	НоменклатураСегмента.Сегмент = &Сегмент
		|	И НоменклатураСегмента.Номенклатура = &НоменклатураПартнер";

	ИначеЕсли ТипЗнч(НоменклатураПартнер) = Тип("СправочникСсылка.Партнеры") Тогда
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ПартнерыСегмента.Партнер
		|ИЗ
		|	РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента
		|ГДЕ
		|	ПартнерыСегмента.Сегмент = &Сегмент
		|	И ПартнерыСегмента.Партнер = &НоменклатураПартнер";

	Иначе
		Возврат Неопределено;
	КонецЕсли;

	Возврат Не Запрос.Выполнить().Пустой();
КонецФункции

Функция ПолучитьТоварыЗапрещенныеКПродажиЧестныйЗнакМасло(Контрагент, Дата, Товары) Экспорт
	//@skip-check bsl-legacy-check-string-literal
	ЕстьРегистрация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Контрагент, "AMS_ЧЗ_МаслоСмазочное");
	
	Если Дата < '20260401' Или ЕстьРегистрация Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Товары);
	Запрос.УстановитьПараметр("ВидНоменклатуры", ВидыНоменклатуры_ЧЗ_Масло());

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Номенклатура,
	|	т.ВидНоменклатуры КАК ВидНоменклатуры
	|ИЗ
	|	Справочник.Номенклатура КАК т
	|ГДЕ
	|	т.Ссылка В (&Товары)
	|	И т.ВидНоменклатуры В (&ВидНоменклатуры)";

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");
КонецФункции

