Функция УдалитьПовторяющиесяЭлементыМассива(Массив) Экспорт
	ТекущийИндекс = 0;
	ВсегоЭлементов = Массив.Количество();
	Пока ТекущийИндекс < ВсегоЭлементов Цикл
		Индекс2 = ТекущийИндекс + 1;
		Пока Индекс2 < ВсегоЭлементов Цикл
			Если Массив[Индекс2] = Массив[ТекущийИндекс] Тогда
				Массив.Удалить(Индекс2);
				ВсегоЭлементов = ВсегоЭлементов - 1;
			Иначе
				Индекс2 = Индекс2 + 1;
			КонецЕсли;
		КонецЦикла;
		ТекущийИндекс = ТекущийИндекс + 1;
	КонецЦикла;
	Возврат Массив;
КонецФункции

Функция ЭтоКонтрагентПартнера(Партнер, Контрагент) Экспорт
	ПартнерКонтрагента  = Контрагент.Партнер;
	ГоловноеПредприятие = Партнер.Родитель;

	Если Партнер = ПартнерКонтрагента Тогда
		Возврат Истина;
	ИначеЕсли ПартнерКонтрагента = ГоловноеПредприятие Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

#Область РеализацияТоваровУслуг

Процедура ПроверитьВозможностьСозданияРеализацииНаОснованииЗаказаКлиента(ЗаказКлиента, Отказ) Экспорт
	Если Пользователи.РолиДоступны("_ГлавныйБухгалтер, _Бухгалтер") Тогда
		Возврат;
	КонецЕсли;
	
	МассивСтрок = ПолучитьТоварыНеУказанныеКОтгрузке(ЗаказКлиента);
	Для Каждого Стр Из МассивСтрок Цикл
		Текст = "В строке %1 списка ""Товары"" для номенклатуры ""%2"" не указано действие ""Отгрузить""";
		Текст = СтрШаблон(Текст, Стр.НомерСтроки, Стр.Номенклатура);
		ОбщегоНазначения.СообщитьПользователю(Текст,,,, Отказ);
		Возврат;
	КонецЦикла;
		
	//@skip-check bsl-legacy-check-string-literal
	ДатаОтгрузки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗаказКлиента, "ДатаОтгрузки");
	Если ДатаОтгрузки = Дата(1,1,1) Тогда
		Текст = "Не заполнено поле ""Дата отгрузки""";
		ОбщегоНазначения.СообщитьПользователю(Текст,, "Объект.ДатаОтгрузки",, Отказ);
	КонецЕсли;
	
	Если ЭтоПродажаНаЭкспорт(ЗаказКлиента) Тогда
		Возврат;
	КонецЕсли;
	
	ДатаСегодня    = НачалоДня(ПолучитьРабочийДень(0,,,Истина));
	ДатаРеализации = КонецДня(ПолучитьРабочийДень(1,,,Истина));
	
	Если ДатаОтгрузки < ДатаСегодня Тогда //вчера
		Текст = "Дата отгрузки не может быть меньше %1";
		Текст = СтрШаблон(Текст, Формат(ДатаРеализации, "ДЛФ=ДД"));
		ОбщегоНазначения.СообщитьПользователю(Текст,, "Объект.ДатаОтгрузки",, Отказ);
		
	ИначеЕсли ДатаОтгрузки > ДатаРеализации Тогда //послезавтра
		Текст = "Дата отгрузки не может превышать  %1";
		Текст = СтрШаблон(Текст, Формат(ДатаРеализации, "ДЛФ=ДД"));
		ОбщегоНазначения.СообщитьПользователю(Текст,, "Объект.ДатаОтгрузки",, Отказ);
	КонецЕсли;
КонецПроцедуры

Процедура ИзменитьПартнерДопИнфо(Партнер, Значение) Экспорт
	Объект = Партнер.ПолучитьОбъект();
