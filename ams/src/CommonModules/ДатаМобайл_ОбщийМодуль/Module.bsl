// Функция удаляет регистрацию документа ТСД в текущем плане обмена/на всех планах обмена
//
// Параметры:
//	ДокументТСД - ДокументОбъект.ДатаМобайл_ДокументыТСД - элемент спр-ка ДатаМобайл_ДокументыТСД
//	ТолькоЗакрытые - Булево - признак удаления регистрации только у закрытых документов
//	ВсеУстройства - Булево - признак очищения регистрации на всех узлах
// 
// Возвращаемое значение:
//   Булево
//
Функция УдалитьРегистрациюОбъекта(ДокументТСД, ТолькоЗакрытые = Ложь, ВсеУстройства = Ложь) Экспорт
	
	Если Не ЗначениеЗаполнено(ДокументТСД.Ссылка) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ТолькоЗакрытые И Не ЗначениеЗаполнено(ДокументТСД.ДатаЗавершения) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ВсеУстройства Тогда
		ВыборкаПлановОбмена = ПланыОбмена.ДатаМобайл_СписокТСД.Выбрать();
		
		Результат = Истина;
		
		Пока ВыборкаПлановОбмена.Следующий() Цикл 
			Если ВыборкаПлановОбмена.ЭтотУзел Тогда Продолжить; КонецЕсли;
			
			Попытка
				ДокументТСД.ОбменДанными.Получатели.Удалить(ВыборкаПлановОбмена.Ссылка);
				ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаПлановОбмена.Ссылка, ДокументТСД.Ссылка);
			Исключение
				Результат = Ложь;
			КонецПопытки;
		КонецЦикла;
		
		Возврат Результат;
	Иначе
		Попытка
			ДокументТСД.ОбменДанными.Получатели.Удалить(ДокументТСД.ТСД);
			ПланыОбмена.УдалитьРегистрациюИзменений(ДокументТСД.ТСД, ДокументТСД.Ссылка);
			Возврат Истина;
		Исключение
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;
	
КонецФункции

// ПЕЧАТЬ
Функция ШтрихкодОперацииПечати(УзелПО, ШК) Экспорт
	
	СтруктураНастроек = Новый Структура;
	Ответ = Неопределено;
	
	СтруктураНастроек.Вставить("Печать", "");
	СтруктураНастроекТСД = ПланыОбмена.ДатаМобайл_СписокТСД.ПолучитьНастройкиТабличныхЧастейТСД(УзелПО, СтруктураНастроек);
	
	Если СтруктураНастроекТСД.ШтрихкодыОперации.Количество() Тогда

		НаборЗаписейРегистраШК = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
		НаборЗаписейРегистраШК.Отбор.Штрихкод.Установить(ШК);
		НаборЗаписейРегистраШК.Прочитать(); 
	
		Если НаборЗаписейРегистраШК.Количество() = 0 Тогда
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("ШтрихкодОперации", ШК);
			
			МассивСтрок = СтруктураНастроекТСД.ШтрихкодыОперации.НайтиСтроки(СтруктураПоиска);
			
			Если МассивСтрок.Количество() Тогда
				
				ДанныеСтроки = МассивСтрок[0];
				
				НаборЗаписейРегистра = РегистрыСведений.ДатаМобайл_ВыборОперацииПечати.СоздатьНаборЗаписей();
				НаборЗаписейРегистра.Отбор.ТСД.Установить(УзелПО); 
				НаборЗаписейРегистра.Отбор.ОперацияПечати.Установить(ДанныеСтроки.ТипОперации);
				НаборЗаписейРегистра.Прочитать(); 
				НаборЗаписейРегистра.Очистить();
				
				НоваяЗаписьРегистра = НаборЗаписейРегистра.Добавить();
				НоваяЗаписьРегистра.ТСД = УзелПО;
				НоваяЗаписьРегистра.ОперацияПечати = ДанныеСтроки.ТипОперации;
				НоваяЗаписьРегистра.Штрихкод = ШК;  
				
				НаборЗаписейРегистра.Записать(Истина);  
				
				СтруктураОтвета = Новый Структура;
				СтруктураОтвета.Вставить("description", "");
				СтруктураОтвета.Вставить("title", "Операция """ + ДанныеСтроки.ТипОперации + """ была применена.");
				Ответ = ДатаМобайл_HTTP_Логика.ПодготовитьОтветJSON(СтруктураОтвета);  
				
			КонецЕсли;	
		
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

// ЕГАИС
Функция ПолучитьНоменклатуруПоЕГАИС(НоменклатураЕГАИС) Экспорт    	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция КАК АлкогольнаяПродукция,
	|	МАКСИМУМ(СоответствиеНоменклатурыЕГАИС.Номенклатура) КАК Номенклатура
	|ИЗ
	|	РегистрСведений.СоответствиеНоменклатурыЕГАИС КАК СоответствиеНоменклатурыЕГАИС
	|ГДЕ
	|	СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция = &НоменклатураЕГАИС
	|
	|СГРУППИРОВАТЬ ПО
	|	СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция";
	
	// аст 
	Если ЕстьАСТ() Тогда
		астЗаменитьРегистрНоменклатурыЕГАИС(Запрос.Текст);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НоменклатураЕГАИС", НоменклатураЕГАИС);
	ТаблицаСоответствий = Запрос.Выполнить().Выгрузить();
	
	Если ТаблицаСоответствий.Количество() > 0 Тогда
		Возврат ТаблицаСоответствий[0].Номенклатура;
	Иначе
		алкЗаменитьРегистрНоменклатурыЕГАИС(Запрос.Текст);
		
		Запрос.УстановитьПараметр("НоменклатураЕГАИС", НоменклатураЕГАИС);
		ТаблицаСоответствий = Запрос.Выполнить().Выгрузить();
		Если ТаблицаСоответствий.Количество() > 0 Тогда
			Возврат ТаблицаСоответствий[0].Номенклатура;
		Иначе
			Возврат Справочники.Номенклатура.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;			
	
