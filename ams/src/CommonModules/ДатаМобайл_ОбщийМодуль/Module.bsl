#КонецОбласти

#Область ЕГАИС_ОПТ 

Функция ЕстьЕГАИСОпт() Экспорт
	
	Попытка
		СтруктураНастройки = НастройкиПолучить();
		РезультатФункции = СтруктураНастройки.ЕГАИС_ОПТ;
	Исключение
		РезультатФункции = Ложь;
	КонецПопытки;
	
	Возврат РезультатФункции;
	
КонецФункции
Процедура ДатаМобайл_Автообработка_ЕГАИС_ОПТ()
	
	Если Не ЕстьЕГАИСОпт() Тогда
		Возврат;
	КонецЕсли;
	
	// АВТОЗАГРУЗКА ЕГАИС документы	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСД.Ссылка КАК ДМСсылка,
	|	ДатаМобайл_ДокументыТСД.Шаблон.ПроводитьРоботом
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС КАК ДатаМобайл_ДокументыТСД
	|ГДЕ
	|	ДатаМобайл_ДокументыТСД.ДатаЗавершенияСбора <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ДатаМобайл_ДокументыТСД.Шаблон.ОбрабатыватьРоботом
	|	И ДатаМобайл_ДокументыТСД.ДатаЗавершения = ДАТАВРЕМЯ(1, 1, 1)");
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока Рез.Следующий() Цикл
		Попытка
			СтрокаОшибок = "";
			
			Об = Рез.ДМссылка.ПолучитьОбъект();
			Об.ДатаПриемкиОператором = ТекущаяДата();
			Об.Записать();
			
			Док = Обработки.ДатаМобайл_АРМДиспетчера.ВнестиДокументВБазу_ЕГАИС(Об,СтрокаОшибок);
			
			Если Док = Неопределено тогда
			Иначе	
				Если Об.Шаблон.ПроводитьРоботом тогда
					ДокОбъект = Док.ПолучитьОбъект();
					ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
				КонецЕсли;	
			КонецЕсли;
		Исключение
			ИмяСобытия = НСтр("ru = 'Документ DataMobile ЕГАИС'");
			
			ТекстСообщения = НСтр("ru = 'Не удалось загрузить документ DataMobile ЕГАИС: %Справочник% по причине: %Причина%'");
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Справочник%", Рез.ДМссылка);
			ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Причина%", ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())+" "+СтрокаОшибок);
			ЗаписьЖурналаРегистрации(ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка,
			Справочники.ДатаМобайл_ДокументыТСД_ЕГАИС,
			Рез.ДМссылка,
			ТекстСообщения);
		КонецПопытки;
	КонецЦикла;
	
	// АВТОВЫГРУЗКА ЕГАИС документы
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСД.Ссылка КАК ДМСсылка,
	|	ДатаМобайл_ДокументыТСД.Шаблон.ПроводитьРоботом
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС КАК ДатаМобайл_ДокументыТСД
	|ГДЕ
	|	ДатаМобайл_ДокументыТСД.ДатаЗавершенияСбора <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ДатаМобайл_ДокументыТСД.Шаблон.ОбрабатыватьРоботом
	|	И ДатаМобайл_ДокументыТСД.ДатаЗавершения = ДАТАВРЕМЯ(1, 1, 1)");
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока Рез.Следующий() Цикл
		Об = Рез.ДМссылка.ПолучитьОбъект();
		Об.ДатаПриемкиОператором = ТекущаяДата();
		Об.Записать();
		СтрокаОшибок = "";
		Док = Обработки.ДатаМобайл_АРМДиспетчера.ВнестиДокументВБазу_ЕГАИС(Об, СтрокаОшибок);	
	КонецЦикла;
	
	ЗапросНужныхШаблонов = Новый Запрос("ВЫБРАТЬ
	|	ДатаМобайл_ШаблоныДокументов.УсловиеВыгрузки,
	|	ДатаМобайл_ШаблоныДокументов.ВидДокумента,
	|	ДатаМобайл_ШаблоныДокументов.Ссылка,
	|	ДатаМобайл_ШаблоныДокументов.УдалениеСтарыхДокументов КАК УдалениеСтарыхДокументов,
	|	ДатаМобайл_ШаблоныДокументов.ВыгружатьТолькоПроведенныеДокументы КАК ВыгружатьТолькоПроведенныеДокументы
	|ИЗ
	|	Справочник.ДатаМобайл_ШаблоныДокументов_ЕГАИС КАК ДатаМобайл_ШаблоныДокументов
	|ГДЕ
	|	ДатаМобайл_ШаблоныДокументов.ВыгружатьРоботом");
	Шаблоны = ЗапросНужныхШаблонов.Выполнить().Выгрузить();
	
	Для каждого Шаблон Из Шаблоны Цикл
		ТекстЗапросаПоДокументам = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Документ1С.Ссылка КАК ИсходныйДокумент,
		|	Документ1С.Дата КАК Дата,
		|	Документ1С.Номер КАК Номер,
		|	Документ1С.Комментарий КАК Комментарий
		|ИЗ
		|	Документ.ПриобретениеТоваровУслуг КАК Документ1С
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС КАК ДатаМобайл_ДокументыТСД
		|		ПО Документ1С.Ссылка = ДатаМобайл_ДокументыТСД.ИсходныйДокумент
		|ГДЕ
		|	НЕ Документ1С.ПометкаУдаления
		|   И 1=1
		|   И 2=2
		|	И &УсловиеВключения
		|	И ДатаМобайл_ДокументыТСД.Ссылка ЕСТЬ NULL ";
		
		ТекстЗапросаПоДокументам = СтрЗаменить(ТекстЗапросаПоДокументам,"ПриобретениеТоваровУслуг", Шаблон.ВидДокумента);
		ТекстЗапросаПоДокументам = СтрЗаменить(ТекстЗапросаПоДокументам,"&УсловиеВключения", ?(СокрЛП(Шаблон.УсловиеВыгрузки) = "", "1=1", Шаблон.УсловиеВыгрузки));
		
		Если Шаблон.ВыгружатьТолькоПроведенныеДокументы Тогда
			ТекстЗапросаПоДокументам = СтрЗаменить(ТекстЗапросаПоДокументам, "1=1", "Документ1С.Проведен");	
		КонецЕсли; 
		
		ЗапросДокументов = Новый Запрос(); 
		
		Если Шаблон.УдалениеСтарыхДокументов <> 0 Тогда
			ТекстЗапросаПоДокументам = СтрЗаменить(ТекстЗапросаПоДокументам,"2=2", "Документ1С.Дата > &ДатаУдаления");
			ЗапросДокументов.УстановитьПараметр("ДатаУдаления",ТекущаяДата() - Шаблон.УдалениеСтарыхДокументов * 86400);				
		КонецЕсли;  
		
		ЗапросДокументов.УстановитьПараметр("Шаблон", Шаблон.Ссылка);
		
		Для каждого СтрПараметра Из Шаблон.Ссылка.ПараметрыУсловияВыгрузки Цикл
			ЗапросДокументов.УстановитьПараметр(СтрПараметра.ИмяПараметра, СтрПараметра.ЗначениеПараметра);
		КонецЦикла;	 
		
		ЗапросДокументов.Текст = ТекстЗапросаПоДокументам;
		СписокДоков = ЗапросДокументов.Выполнить().Выбрать();
		
		Пока СписокДоков.Следующий() Цикл
			ДокТСД = Справочники.ДатаМобайл_ДокументыТСД_ЕГАИС.СоздатьЭлемент();
			ЗаполнитьЗначенияСвойств(ДокТСД,СписокДоков);
			ДокТСД.Шаблон = Шаблон.Ссылка;
			ДокТСД.Записать();
		КонецЦикла;	
	КонецЦикла;
	
	// ФИКСАЦИЯ ПЛАН-ФАКТ ЕГАИС
	ЗапросПланФакт = Новый Запрос;
	ЗапросПланФакт.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 200
	|	ДокументыТСД.Ссылка,
	|	ДокументыТСД.ПланРавноФакт КАК ПланРавноФакт
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС КАК ДокументыТСД
	|ГДЕ
	|	НЕ ДокументыТСД.ПометкаУдаления
	|	И ДокументыТСД.ДатаЗавершения = ДАТАВРЕМЯ(1, 1, 1)
	|	И НЕ ДокументыТСД.ДатаЗавершенияСбора = ДАТАВРЕМЯ(1, 1, 1)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументыТСД.ДатаЗавершенияСбора УБЫВ";
	
	ВыборкаПланФакт = ЗапросПланФакт.Выполнить().Выбрать();
	
	Пока ВыборкаПланФакт.Следующий() Цикл
		ПланРавноФакт = ПланРавноФактЕГАИС(ВыборкаПланФакт.Ссылка); 
		
		Если Не ПланРавноФакт = ВыборкаПланФакт.ПланРавноФакт Тогда
			докОб = ВыборкаПланФакт.Ссылка.ПолучитьОбъект();
			докОб.ПланРавноФакт = ПланРавноФакт;
			
			Попытка
				докОб.Записать();
			Исключение КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
Функция ПолучитьКодУпаковкиРАР(УзелПО, ТипУпаковки, ПроверятьИспользованные = Ложь) Экспорт
	
	НовыйКодУпаковкиРАР = ЗаписатьНовыйКодУпаковкиРАР(УзелПО, ТипУпаковки, ПроверятьИспользованные);		
	Возврат НовыйКодУпаковкиРАР;
	
КонецФункции
Функция ЗаписатьНовыйКодУпаковкиРАР(УзелПО, ТипУпаковки, ПроверятьИспользованные) 
	
	Если Не ЗначениеЗаполнено(ТипУпаковки) Тогда
		Возврат Неопределено;
	Иначе
		ТекущийТипУпаковки = ТипУпаковки; //ТипУпаковки 1-короб, 2 - палета
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(УзелПО.Организация) Тогда
		Возврат Неопределено;
	Иначе
		// Получим код организации РАР
		ЗапросКодЕГАИС = Новый Запрос;
		ЗапросКодЕГАИС.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЕстьNull(алкКодыОбъектовАИС.ЗначениеРеквизитаАИС,"""") КАК ЗначениеРеквизитаАИС
		|ИЗ
		|	РегистрСведений.алкКодыОбъектовАИС КАК алкКодыОбъектовАИС
		|ГДЕ
		//|	алкКодыОбъектовАИС.Объект = &Ссылка
		|	алкКодыОбъектовАИС.Объект.Владелец = &Ссылка
		|	И алкКодыОбъектовАИС.РеквизитАИС = ЗНАЧЕНИЕ(ПланВидовХарактеристик.алкРеквизитыОбъектовАИС.КодЕГАИС)";
		ЗапросКодЕГАИС.УстановитьПараметр("Ссылка",УзелПО.Организация);
		РезультатЗапроса = ЗапросКодЕГАИС.Выполнить();
		
		Если Не РезультатЗапроса.Пустой() Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			ТекущийИдентификаторОрганизации = Выборка.ЗначениеРеквизитаАИС;
			
			Если СтрДлина(ТекущийИдентификаторОрганизации) <> 12 Тогда    
				Возврат Неопределено;
			КонецЕсли;
		Иначе    
			Сообщить("В регистре сведений ""Коды объектов АИС"" не обнаружено записи с заполненным в поле объект ссылкой на карточку организации!");
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(УзелПО.ЛинияРозливаЕГАИС) Тогда
		Возврат Неопределено;
	Иначе
		ТекущаяЛинияРозлива = УзелПО.ЛинияРозливаЕГАИС;
	КонецЕсли;
	
	Если ПроверятьИспользованные тогда
		ПоследнийКодУпаковкиРАР = Неопределено;
		Если ПроверкаНеИспользуетсяПоследнийКодУпаковкиРАР(ТекущийТипУпаковки,ТекущийИдентификаторОрганизации,ТекущаяЛинияРозлива, ПоследнийКодУпаковкиРАР) Тогда
			Возврат ПоследнийКодУпаковкиРАР.КодУпаковки;
		КонецЕсли;
	КонецЕсли;
	
	НачатьТранзакцию();
	НовыйКодУпаковки = ПолучитьНовыйКодУпаковкиРАР(ТекущийТипУпаковки,ТекущийИдентификаторОрганизации,ТекущаяЛинияРозлива);
	
	Если НовыйКодУпаковки  = Неопределено Тогда	
		ОтменитьТранзакцию();
		Возврат Неопределено;
	КонецЕсли; 
	
	НоваяЗаписьРегистра = РегистрыСведений.ДатаМобайл_КодыУпаковок_ЕГАИС.СоздатьМенеджерЗаписи();
	НоваяЗаписьРегистра.ИдентификаторОрганизации = ТекущийИдентификаторОрганизации;
	НоваяЗаписьРегистра.ТипУпаковки = ТекущийТипУпаковки;
	НоваяЗаписьРегистра.ЛинияРозлива = ТекущаяЛинияРозлива;
	НоваяЗаписьРегистра.Счетчик = НовыйКодУпаковки.Счетчик;
	НоваяЗаписьРегистра.Дата = ТекущаяДата();
	НоваяЗаписьРегистра.ТСД = УзелПО;
	НоваяЗаписьРегистра.КодУпаковки = НовыйКодУпаковки.КодУпаковки;
	НоваяЗаписьРегистра.Активность = Истина;
	
	Попытка
		НоваяЗаписьРегистра.Записать();
	Исключение
		ОтменитьТранзакцию();
		Возврат Неопределено;
	КонецПопытки; 
	
	ЗафиксироватьТранзакцию();
	
	Возврат НовыйКодУпаковки.КодУпаковки;
	
КонецФункции 
Функция ПолучитьНовыйКодУпаковкиРАР(ТекущийТипУпаковки,ТекущийИдентификаторОрганизации,ТекущаяЛинияРозлива, ПолучитьНовый = Истина) 
	
	//Штриховой код формата Code-128.  26 символов.
	//
	//Где:
	// 010039994654 – идентификатор организации в ЕГАИС, осуществляющей маркировку групповой тары (FSRAR_ID). (12 знаков) 
	// 1 – тип логистической единицы (1- короб, 2- паллет, 3-сборный короб, 4-сборный паллет). (1 знак)
	// 01 – номер линии розлива. (2 знака). Номер должен настраиваться на каждом устройстве, генерирующем код. 
	// 18 – год, в который производится генерация групповой маркировки. (2 знака) 
	// 000000001 – логистический идентификатор, счетчик, обнуляемый в начале каждого года. (9 знаков).
	
	ЧислНовыйНомер = МаксимальныйКодУпаковки(ТекущийТипУпаковки,ТекущийИдентификаторОрганизации,ТекущаяЛинияРозлива) + ?(ПолучитьНовый, 1, 0);
	Если ЧислНовыйНомер < 1 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		ЧислТекущийТипУпаковки = Число(ТекущийТипУпаковки);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Попытка
		ЧислТекущаяЛинияРозлива = Число(ТекущаяЛинияРозлива);
	Исключение
		Возврат Неопределено;
	КонецПопытки; 
	
	СтрТекущийТипУпаковки = Формат(ЧислТекущийТипУпаковки,"ЧЦ=1; ЧДЦ=; ЧВН=; ЧГ=0");
	СтрТекущаяЛинияРозлива = Формат(ЧислТекущаяЛинияРозлива,"ЧЦ=2; ЧДЦ=; ЧВН=; ЧГ=0");
	СтрГод = Формат(ТекущаяДата(),"ДФ=гг");
	СтрНовыйНомер = Формат(ЧислНовыйНомер,"ЧЦ=9; ЧДЦ=; ЧВН=; ЧГ=0");
	
	Результат = Новый Структура("Счетчик,КодУпаковки");
	Результат.Счетчик = ЧислНовыйНомер;
	Результат.КодУпаковки = "" + ТекущийИдентификаторОрганизации + СтрТекущийТипУпаковки + СтрТекущаяЛинияРозлива + СтрГод + СтрНовыйНомер;
	
	Возврат Результат; 
	
КонецФункции
Функция МаксимальныйКодУпаковки(ТекущийТипУпаковки,ТекущийИдентификаторОрганизации,ТекущаяЛинияРозлива) 
	
	Запрос = Новый Запрос;	
	ТекстЗапроса = "ВЫБРАТЬ   
	| ЕстьNULL(Максимум(КодыУпаковок.Счетчик),0) Как ID
	|ИЗ
	| РегистрСведений.ДатаМобайл_КодыУпаковок_ЕГАИС Как КодыУпаковок
	|ГДЕ
	| КодыУпаковок.ИдентификаторОрганизации = &ТекущийИдентификаторОрганизации
	| И КодыУпаковок.ТипУпаковки = &ТекущийТипУпаковки
	| И КодыУпаковок.ЛинияРозлива = &ТекущаяЛинияРозлива
	| И КодыУпаковок.Дата МЕЖДУ &НачалоГода и &КонецГода
	|";
	
	Запрос.УстановитьПараметр("ТекущийИдентификаторОрганизации", ТекущийИдентификаторОрганизации);
	Запрос.УстановитьПараметр("ТекущийТипУпаковки",  ТекущийТипУпаковки);
	Запрос.УстановитьПараметр("ТекущаяЛинияРозлива", ТекущаяЛинияРозлива);
	
	Запрос.УстановитьПараметр("НачалоГода", НачалоГода(ТекущаяДата()));
	Запрос.УстановитьПараметр("КонецГода",  КонецГода(ТекущаяДата()));
	
	Запрос.Текст = ТекстЗапроса;
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат  0;
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.ID;
	КонецЕсли; 	
	
КонецФункции
Функция ПроверкаНеИспользуетсяПоследнийКодУпаковкиРАР(ТекущийТипУпаковки, ТекущийИдентификаторОрганизации, ТекущаяЛинияРозлива, ПоследнийСгенерированныйКод)
	
	ПоследнийСгенерированныйКод = ПолучитьНовыйКодУпаковкиРАР(ТекущийТипУпаковки, ТекущийИдентификаторОрганизации, ТекущаяЛинияРозлива, Ложь);
	
	//++ Романов 09012020
	Если ПоследнийСгенерированныйКод = Неопределено тогда
		Возврат Ложь;
	КонецЕсли;
	//--
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСД_ЕГАИССобранныеДанныеПодбор.УпаковочныйЛист
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСД_ЕГАИССобранныеДанныеПодбор
	|ГДЕ
	|	ДатаМобайл_ДокументыТСД_ЕГАИССобранныеДанныеПодбор.УпаковочныйЛист = &УпаковочныйЛист");
	Запрос.УстановитьПараметр("УпаковочныйЛист", ПоследнийСгенерированныйКод.КодУпаковки);
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Количество() = 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции // ()
Функция ПечатьУпаковкиРАР(НастройкаПечати, КаталогСохранения, АдресПринтсервера, ПортПринтсервера, ОнлайнСвязьСПринтсервером, КодУпаковки, ВводУпакЛистов, ТЗДанныхПечати) Экспорт
	
	//--------------------------------------------------------------------------------------------------------------
	// Печать упаковки РАР
	//--------------------------------------------------------------------------------------------------------------
	
	ТипУпаковки = ВводУпакЛистов;
	
	//ТипУпаковки - 1 - короб, 2 - палета
	ТипУпаковки = ?(ТипУпаковки = 3,1,ТипУпаковки);
	ТипУпаковки = ?(ТипУпаковки = 4,2,ТипУпаковки);
	ТипУпаковки = ?(ТипУпаковки = 5,1,ТипУпаковки);
	ТипУпаковки = ?(ТипУпаковки = 6,2,ТипУпаковки);
	
	Если НастройкаПечати<>Неопределено Тогда
		
		
		Если КодУпаковки = Неопределено Тогда
			Сообщить("Не удалось сформировать код упаковки");
			Возврат ЛОЖЬ;
		КонецЕсли;
		
		ЗаписьXML = Новый ЗаписьXML;
		
		Если НЕ ОнлайнСвязьСПринтсервером Тогда
			ИмяФайла = ПолучитьНовоеИмяФайла();	
			Попытка
				ЗаписьXML.ОткрытьФайл(КаталогСохранения+ИмяФайла+".xml", "UTF-8");
			Исключение
				Сообщить("Не удалось сохранить файл печати в каталоге: " + КаталогСохранения + " по причине: " + ОписаниеОшибки());	
			КонецПопытки;
		Иначе
			ЗаписьXML.УстановитьСтроку("UTF-8");
		КонецЕсли;	
		
		ЗаписьXML.ЗаписатьОбъявлениеXML();	
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("PrintData");
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("PrinterName");
		ЗаписьXML.ЗаписатьТекст(НастройкаПечати.ИмяПринтера);
		ЗаписьXML.ЗаписатьКонецЭлемента();		
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("TemplateName");
		ЗаписьXML.ЗаписатьТекст(НастройкаПечати.ИмяШаблона);
		ЗаписьXML.ЗаписатьКонецЭлемента();		
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Count");
		ЗаписьXML.ЗаписатьТекст(ЧистаяСтрока(Формат(?(НастройкаПечати.КоличествоКопий = 0,1,НастройкаПечати.КоличествоКопий),"ЧГ = ")));
		ЗаписьXML.ЗаписатьКонецЭлемента();	
		
		
		ТекущееНазваниеТовара = "";
		ТекущаяДатаРозлива = "";
		ТекущаяЕмкость = "";
		ТекущееКоличество = "";
		ТекущийНомерПартии = "";
		ТекущийEANКороба = "";
		
		Если ТЗДанныхПечати.Количество() > 0 И ТипУпаковки = 1 Тогда
			Если не ТЗДанныхПечати[0].Номенклатура.Пустая() Тогда
				ТекущееНазваниеТовара = "" + Лев(ТЗДанныхПечати[0].Номенклатура.Наименование, 150);
				ТекущаяЕмкость = "" + ТЗДанныхПечати[0].Номенклатура.алкЕмкость + " л.";
			КонецЕсли;
			
			Если ТЗДанныхПечати[0].Штрихкод <> "" Тогда
				ТекущийEANКороба = ТЗДанныхПечати[0].Штрихкод;
				КоэффициентКороба = ПолучитьКоэффициентУпаковки(ТЗДанныхПечати[0].Штрихкод);
				
				Если КоэффициентКороба <> 0 Тогда
					ТекущееКоличество = "" + КоэффициентКороба + " шт.";
				КонецЕсли;
			КонецЕсли;
			
			Если Не ТЗДанныхПечати[0].СерияСсылка.Пустая() Тогда
				ТекущаяДатаРозлива = "" + Формат(ТЗДанныхПечати[0].СерияСсылка.алкДатаНачалаРозлива,"ДФ=dd.MM.yyyy"); //из серии
				//ТекущийНомерПартии = "" + ТЗДанныхПечати[0].СерияСсылка.СерийныйНомер; //из серии
				ТекущийНомерПартии = "" + ТЗДанныхПечати[0].СерияСсылка.Наименование; //из серии 
			КонецЕсли;
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Head");
		
		//--- Название товара
		СтрЗначение = ТекущееНазваниеТовара;
		ЗаписьXML.ЗаписатьНачалоЭлемента("ArtName");
		ЗаписьXML.ЗаписатьТекст(СтрЗначение);
		ЗаписьXML.ЗаписатьКонецЭлемента();	
		
		//--- КодУпаковки
		СтрЗначение = КодУпаковки;
		ЗаписьXML.ЗаписатьНачалоЭлемента("UPL");
		ЗаписьXML.ЗаписатьТекст(СтрЗначение);
		ЗаписьXML.ЗаписатьКонецЭлемента();				
		
		//--- ДатаРозлива
		СтрЗначение = ТекущаяДатаРозлива;
		ЗаписьXML.ЗаписатьНачалоЭлемента("DateBottling");
		ЗаписьXML.ЗаписатьТекст(СтрЗначение);
		ЗаписьXML.ЗаписатьКонецЭлемента();	
		
		//--- Емкость
		СтрЗначение = ТекущаяЕмкость;
		ЗаписьXML.ЗаписатьНачалоЭлемента("Size");
		ЗаписьXML.ЗаписатьТекст(СтрЗначение);
		ЗаписьXML.ЗаписатьКонецЭлемента();	
		
		//--- Количество штук
		СтрЗначение = ТекущееКоличество;
		ЗаписьXML.ЗаписатьНачалоЭлемента("BoxQty");
		ЗаписьXML.ЗаписатьТекст(СтрЗначение);
		ЗаписьXML.ЗаписатьКонецЭлемента();	
		
		//--- Номерпартии
		СтрЗначение = ТекущийНомерПартии;
		ЗаписьXML.ЗаписатьНачалоЭлемента("Part");
		ЗаписьXML.ЗаписатьТекст(СтрЗначение);
		ЗаписьXML.ЗаписатьКонецЭлемента();	
		
		//--- EAN короба
		СтрЗначение = ТекущийEANКороба;
		ЗаписьXML.ЗаписатьНачалоЭлемента("BoxEAN");
		ЗаписьXML.ЗаписатьТекст(СтрЗначение);
		ЗаписьXML.ЗаписатьКонецЭлемента();	
		
		ЗаписьXML.ЗаписатьКонецЭлемента();//Head
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Detail");
		ЗаписьXML.ЗаписатьНачалоЭлемента("Item");
		ЗаписьXML.ЗаписатьКонецЭлемента();//Item
		ЗаписьXML.ЗаписатьКонецЭлемента();//Detail
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Footer");
		Год = Строка(Формат(Год(ТекущаяДата()),"ЧГ="));
		Месяц = Строка(Месяц(ТекущаяДата()));
		День = Строка(День(ТекущаяДата()));
		ДатаСтрока = Год + Строка(Месяц) + Строка(День);
		ЗаписьXML.ЗаписатьНачалоЭлемента("Date");	
		ЗаписьXML.ЗаписатьТекст(ЧистаяСтрока(Год + Месяц + День));
		ЗаписьXML.ЗаписатьКонецЭлемента();//Date
		ЗаписьXML.ЗаписатьКонецЭлемента();//Footer
		
		ЗаписьXML.ЗаписатьКонецЭлемента();//PrintData
		
		Если Не ОнлайнСвязьСПринтсервером Тогда
			ЗаписьXML.Закрыть();
			Сообщить("Данные отправлены на печать");
		Иначе
			СтрокаДляЗапроса = ЗаписьXML.Закрыть();
			ЕстьОшибка = Ложь;
			ОтправитьДанныеНаПринтсервер(АдресПринтсервера, ПортПринтсервера, СтрокаДляЗапроса, ЕстьОшибка);
			
			Если ЕстьОшибка Тогда
				Возврат Ложь;
			Иначе
				Сообщить("Данные отправлены на печать");
			КонецЕсли;	
		КонецЕсли;		
	Иначе
		Возврат Ложь;
	КонецЕсли;	
	
	Возврат Истина;
	
КонецФункции // ()
Процедура ОтправитьДанныеНаПринтсервер(АдресПринтсервера, ПортПринтсервера, СтрокаДляЗапроса, ЕстьОшибка);
	
	Соединение = Новый HTTPСоединение(АдресПринтсервера,ПортПринтсервера,,,,1,);
	
	РесурсНаСервере = "/printFile/";
	HTTPЗапрос = Новый HTTPЗапрос(РесурсНаСервере);
	HTTPЗапрос.Заголовки.Вставить("Content-type", "application/xml");
	HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаДляЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	ЕстьОшибка = Ложь;
	
	Попытка 
		Результат = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
	Исключение
		ЕстьОшибка = Истина;
		//ТекстОшибки = ОписаниеОшибки();	
		ТекстОшибки = "SendArtToPrint. Ошибка онлайн соединения c сервером печати, проверьте настройки.";
	КонецПопытки;
	
	Соединение = Неопределено;
	
	Если ЕстьОшибка тогда
		Сообщить(ТекстОшибки);
	Иначе
		ТекстСообщения  = "" + Результат.КодСостояния +  " " + Результат.ПолучитьТелоКакСтроку();
		Если СтрНайти(Результат.ПолучитьТелоКакСтроку(),"File Uploaded") > 0 Тогда
			//Успешная отправка данных
		Иначе
			ЕстьОшибка = Истина;
			ТекстОшибки = "SendArtToPrint. Ошибка отправки данных на печать: " + ТекстСообщения + ", проверьте настройки.";
			Сообщить(ТекстОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
Функция ПолучитьНовоеИмяФайла(ПорядковыйНомер = 0)
	
	ИмяФайла = СтрЗаменить(ТекущаяДата(),":","");
	ИмяФайла = СтрЗаменить(ИмяФайла, ".","");
	ИмяФайла = СтрЗаменить(ИмяФайла, " ","");
	ИмяФайла = СтрЗаменить(ИмяФайла, "/","");
	ИмяФайла = СтрЗаменить(ИмяФайла, "\","");
	
	Генератор = Новый ГенераторСлучайныхЧисел(1);
	ИдентификаторФайла = Генератор.СлучайноеЧисло(1, 1000);
	
	ИмяФайла = ИмяФайла + ИдентификаторФайла + ПорядковыйНомер;
	
	Возврат ИмяФайла;
	
КонецФункции // ()
Функция ПолучитьКоэффициентУпаковки(BarcodeBox) Экспорт
	
	ТекущийКоэффициент = 0;
	
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	|	Штрихкоды.Упаковка.Числитель КАК Коэффициент
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
	|ГДЕ
	|	Штрихкоды.Штрихкод = &код");
	
	Запрос.УстановитьПараметр("Код",BarcodeBox);
	Рез = Запрос.Выполнить().Выгрузить();
	
	Если Рез.Количество() > 0 И BarcodeBox <> "" Тогда
		ТекущийКоэффициент = Рез[0].Коэффициент;
	КонецЕсли;
	
	Возврат ТекущийКоэффициент; 
	
КонецФункции
Функция ПолучитьСправкиПоСерии(Серия) Экспорт
	
	ДанныеСправок = Новый Структура("СправкаА,СправкаБ");
	ДанныеСправок.СправкаА = Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	ДанныеСправок.СправкаБ = Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ Первые 1 
	|	СоответствиеСерийЕГАИС.СправкаА КАК СправкаА,
	|	СоответствиеСерийЕГАИС.СправкаБ КАК СправкаБ
	|ИЗ
	|	РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК СоответствиеСерийЕГАИС
	|ГДЕ
	|	СоответствиеСерийЕГАИС.СерияНоменклатуры = &Серия";
	Запрос.УстановитьПараметр("Серия", Серия);
	
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока Рез.Следующий() Цикл
		ДанныеСправок.СправкаА = Рез.СправкаА;
		ДанныеСправок.СправкаБ = Рез.СправкаБ;
	КонецЦикла;		
	
	Возврат  ДанныеСправок;
	
КонецФункции
Функция ПолучитьСериюПоСправкам(СправкаБ, ВсеСерииПоСправкеБ = Ложь) Экспорт
	
	СерияНоменклатурыВБазе = Справочники.СерииНоменклатуры.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	СоответствиеСерийЕГАИС.СерияНоменклатуры КАК Серия
	|ИЗ
	|	РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК СоответствиеСерийЕГАИС
	|ГДЕ
	|	СоответствиеСерийЕГАИС.СправкаБ = &СправкаБ И НЕ СоответствиеСерийЕГАИС.СерияНоменклатуры ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("СправкаБ",СправкаБ);
	
	Если ВсеСерииПоСправкеБ Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫБРАТЬ ПЕРВЫЕ 1", "ВЫБРАТЬ");
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе
		Рез = Запрос.Выполнить().Выбрать();
		
		Пока Рез.Следующий() Цикл
			СерияНоменклатурыВБазе = Рез.Серия;
		КонецЦикла;		
		
		Возврат  СерияНоменклатурыВБазе;
	КонецЕсли;
	
КонецФункции
Функция ПолучитьСвободнуюСериюПоСправкамFIFO(СправкаА,СправкаБ,Номенклатура,ДокументЕГАИС) Экспорт
	
	СерияНоменклатурыВБазе = Справочники.СерииНоменклатуры.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ 
	|	СоответствиеСерийЕГАИС.СерияНоменклатуры КАК Серия,
	|	ЕстьNULL(Сумма(ЕстьNULL(ОстаткиТоваров.ВНаличииОстаток,0)),0) КАК КоличествоОстаток
	|ИЗ
	|	РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК СоответствиеСерийЕГАИС
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки КАК ОстаткиТоваров
	|		ПО ОстаткиТоваров.Серия = СоответствиеСерийЕГАИС.СерияНоменклатуры
	|		И  ОстаткиТоваров.Номенклатура = &Номенклатура 
	|		И  (ОстаткиТоваров.Склад = &Склад ИЛИ &ВсеСклады)
	|		
	|ГДЕ
	|	СоответствиеСерийЕГАИС.СправкаА = &СправкаА 
	|	И СоответствиеСерийЕГАИС.СправкаБ = &СправкаБ
	|
	|СГРУППИРОВАТЬ ПО
	|	СоответствиеСерийЕГАИС.СерияНоменклатуры	
	|	
	|ИМЕЮЩИЕ
	|	ЕстьNULL(Сумма(ЕстьNULL(ОстаткиТоваров.ВНаличииОстаток,0)),0)>0
	|
	|УПОРЯДОЧИТЬ ПО 
	|	СоответствиеСерийЕГАИС.СерияНоменклатуры.Наименование ВОЗР";
	
	
	Запрос.УстановитьПараметр("СправкаА", СправкаА);
	Запрос.УстановитьПараметр("СправкаБ", СправкаБ);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Склад", ДокументЕГАИС.Склад);
	
	Если ДокументЕГАИС.Склад.Пустая() Тогда
		Запрос.УстановитьПараметр("ВсеСклады", Истина);
	Иначе
		Запрос.УстановитьПараметр("ВсеСклады", Ложь);
	КонецЕсли;
	
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока Рез.Следующий() Цикл
		СерияНоменклатурыВБазе = Рез.Серия;
		КоличествоВДокументе = 0;
		
		Для каждого стр из ДокументЕГАИС.Товары Цикл
			Если стр.Серия = СерияНоменклатурыВБазе Тогда
				КоличествоВДокументе = КоличествоВДокументе + стр.Количество;
			КонецЕсли;	
		КонецЦикла;	
		
		Если Рез.КоличествоОстаток>КоличествоВДокументе Тогда
			Прервать;
		Иначе
			СерияНоменклатурыВБазе = Справочники.СерииНоменклатуры.ПустаяСсылка();
			Продолжить;
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат  СерияНоменклатурыВБазе;
	
КонецФункции
Функция ПолучитьПартиюПоСправкамТТН(СправкаА, СправкаБ, Номенклатура, ДокументЕГАИС, ДокументРеализации) Экспорт
	
	СерияНоменклатурыВБазе = Справочники.СерииНоменклатуры.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ 
	|	СоответствиеСерийЕГАИС.СерияНоменклатуры КАК Серия
	|ИЗ
	|	РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК СоответствиеСерийЕГАИС
	|		
	|ГДЕ
	|	СоответствиеСерийЕГАИС.СправкаА = &СправкаА 
	|	И СоответствиеСерийЕГАИС.СправкаБ = &СправкаБ
	|
	|СГРУППИРОВАТЬ ПО
	|	СоответствиеСерийЕГАИС.СерияНоменклатуры	
	|
	|УПОРЯДОЧИТЬ ПО 
	|	СоответствиеСерийЕГАИС.СерияНоменклатуры ВОЗР";
	
	Запрос.УстановитьПараметр("СправкаА",СправкаА);
	Запрос.УстановитьПараметр("СправкаБ",СправкаБ);
	
	Рез = Запрос.Выполнить().Выбрать();
	
	Пока Рез.Следующий() Цикл
		СерияНоменклатурыВБазе = Рез.Серия;
		КоличествоВДокументе = 0;
		
		Для каждого стр Из ДокументЕГАИС.Товары Цикл
			Если стр.НомерПартии = Строка(СерияНоменклатурыВБазе) Тогда
				КоличествоВДокументе = КоличествоВДокументе + стр.Количество;
			КонецЕсли;	
		КонецЦикла; 
		
		КоличествоВДокументеРеализации = 0;
		
		Для каждого стр Из ДокументРеализации.Товары Цикл
			Если стр.Серия = СерияНоменклатурыВБазе Тогда
				КоличествоВДокументеРеализации = КоличествоВДокументеРеализации + стр.Количество;
			КонецЕсли;	
		КонецЦикла;
		
		Для каждого стр Из ДокументРеализации.Серии Цикл
			Если стр.Серия = СерияНоменклатурыВБазе Тогда
				КоличествоВДокументеРеализации = КоличествоВДокументеРеализации + стр.Количество;
			КонецЕсли;	
		КонецЦикла;
		
		Если КоличествоВДокументеРеализации = 0 Или КоличествоВДокументе = КоличествоВДокументеРеализации Тогда
			Продолжить;
		Иначе
			Прервать;
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат  СерияНоменклатурыВБазе;
	
КонецФункции
Функция ПолучитьСериюПоМарке(Номенклатура, DataMatrix) Экспорт
	
	СерияНоменклатурыВБазе = Справочники.СерииНоменклатуры.ПустаяСсылка();
	
	Если Номенклатура.Пустая() Или DataMatrix = "" Тогда
		Возврат СерияНоменклатурыВБазе;
	КонецЕсли;	
	
	// Определим данные DataMatrix
	ПерваяЦифраМарки = Число(ЛЕВ(DataMatrix,1));
	МаркаСерия = СокрЛП(Сред(DataMatrix, 5, 3));		
	КорректнаяМарка = Истина;
	
	Если ПерваяЦифраМарки = 1 Тогда
		ДлинаНомераМарки = 9;
		МаркаНомер = СокрЛП(Сред(DataMatrix, 8, 9));
	ИначеЕсли ПерваяЦифраМарки = 2 Тогда
		ДлинаНомераМарки = 8;
		МаркаНомер = СокрЛП(Сред(DataMatrix, 8, 8));
	Иначе
		КорректнаяМарка = Ложь;
		Возврат СерияНоменклатурыВБазе;
	КонецЕсли;
	
	Если КорректнаяМарка Тогда
		ТекущаяСерияМарки = МаркаСерия;
		ТекущийНомерМарки = Число(МаркаНомер);
		ТекущаяДлинаНомераМарки = ДлинаНомераМарки;
	КонецЕсли;
	
	// Найдем подходящие серии из регистра
	Запрос = Новый Запрос;
	Запрос.Текст = 	 "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СерииНоменклатуры.Ссылка КАК Серия
	|ИЗ
	|	Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|  ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.алкСоответствияАлкогольнойПродукцииЕГАИСИНоменклатуры КАК РегистрСоответсвия
	|  ПО СерииНоменклатуры.ВидНоменклатуры = РегистрСоответсвия.Номенклатура.ВидНоменклатуры
	|ГДЕ
	|  РегистрСоответсвия.АлкогольнаяПродукция = &АлкогольнаяПродукция";	 
	Запрос.УстановитьПараметр("АлкогольнаяПродукция", Номенклатура);
	
	////Найдем подходящие серии по артикулу
	//Запрос = Новый Запрос;
	//Запрос.Текст = 	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	//               	 |	СерииНоменклатуры.Ссылка КАК Серия
	//               	 |ИЗ
	//               	 |	Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	//				 |ГДЕ
	//				 |  СерииНоменклатуры.Владелец.Артикул = &АлкогольнаяПродукцияКод";
	
	//Запрос.УстановитьПараметр("АлкогольнаяПродукцияКод",Строка(Номенклатура.Код));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	// Перебором найдем вхождение в серию
	Пока Выборка.Следующий() Цикл
		СерияПодходит = Ложь;
		
		// Поиск по первому полю
		СтрокаМарок = Выборка.Серия.алкПредставлениеМарокАкцизных;
		
		Если СтрокаМарок = "" Тогда
			Продолжить;
		КонецЕсли;
		
		Если Сред(СтрокаМарок, 4, 1) <> " " Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаСерия = Лев(СтрокаМарок, 3);
		
		Если СтрокаСерия <> ТекущаяСерияМарки Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаДиапазоны = Сред(СтрокаМарок, 5);
		МассивДапазоны = СтрЗаменить(СтрокаДиапазоны, ",", Символы.ПС);
		
		ПоискМарок = Истина;
		i = 0;
		Пока ПоискМарок Цикл
			i = i + 1;
			ТекущийДиапазон = СокрЛП(СтрПолучитьСтроку(МассивДапазоны, i));
			Если ТекущийДиапазон = "" Тогда
				ПоискМарок = Ложь;
				Прервать;
			КонецЕсли;
			
			ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, ".", "");
			ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "/", "");
			ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "\", "");
			ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "?", "");
			ПозицияСимвола = Найти(ТекущийДиапазон, "-");
			
			Если ПозицияСимвола = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если ПозицияСимвола = 9 Тогда
				Если ТекущаяДлинаНомераМарки <> 8 Тогда
					Продолжить;
				КонецЕсли; 
				
				МинимальныйНомер = Число(Лев(ТекущийДиапазон, 8));
				МаксимальныйНомер = Число(Сред(ТекущийДиапазон, 10, 8));
			ИначеЕсли ПозицияСимвола = 10 Тогда
				Если ТекущаяДлинаНомераМарки <> 9 Тогда
					Продолжить;
				КонецЕсли;    
				
				МинимальныйНомер = Число(Лев(ТекущийДиапазон, 9));
				МаксимальныйНомер = Число(Сред(ТекущийДиапазон, 11, 9));
			Иначе
				Продолжить;
			КонецЕсли;	 
			
			Если ТекущийНомерМарки >= МинимальныйНомер И ТекущийНомерМарки <= МаксимальныйНомер Тогда
				СерияПодходит = Истина;
				Прервать;
			КонецЕсли;					
		КонецЦикла;	
		
		// Поиск по второму полю
		Если не СерияПодходит Тогда
			
			СтрокаМарок = Выборка.Серия.алкПредставлениеМарокРСМ;
			
			Если СтрокаМарок="" Тогда
				Продолжить;
			КонецЕсли;
			
			Если Сред(СтрокаМарок, 4, 1) <> " " Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаСерия = Лев(СтрокаМарок, 3);
			
			Если СтрокаСерия <> ТекущаяСерияМарки Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаДиапазоны = Сред(СтрокаМарок, 5);
			МассивДапазоны = СтрЗаменить(СтрокаДиапазоны, ",", Символы.ПС);
			
			ПоискМарок = Истина;
			i = 0;
			Пока ПоискМарок Цикл
				i = i + 1;
				ТекущийДиапазон = СокрЛП(СтрПолучитьСтроку(МассивДапазоны, i));
				
				Если ТекущийДиапазон = "" Тогда
					ПоискМарок = Ложь;
					Прервать;
				КонецЕсли;
				
				ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, ".", "");
				ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "/", "");
				ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "\", "");
				ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "?", "");
				ПозицияСимвола = Найти(ТекущийДиапазон, "-");
				
				Если ПозицияСимвола = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				Если ПозицияСимвола = 9 Тогда
					Если ТекущаяДлинаНомераМарки <> 8 Тогда
						Продолжить;
					КонецЕсли;
					МинимальныйНомер = Число(Лев(ТекущийДиапазон, 8));
					МаксимальныйНомер = Число(Сред(ТекущийДиапазон, 10, 8));
				ИначеЕсли ПозицияСимвола = 10 Тогда
					Если ТекущаяДлинаНомераМарки <> 9 Тогда
						Продолжить;
					КонецЕсли;
					МинимальныйНомер = Число(Лев(ТекущийДиапазон, 9));
					МаксимальныйНомер = Число(Сред(ТекущийДиапазон, 11, 9));
				Иначе
					Продолжить;
				КонецЕсли;	 
				
				Если ТекущийНомерМарки >= МинимальныйНомер И ТекущийНомерМарки <= МаксимальныйНомер Тогда
					СерияПодходит = Истина;
					Прервать;
				КонецЕсли;					
			КонецЦикла;	
			
		КонецЕсли;
		
		
		// Поиск по третьему полю		
		Если Не СерияПодходит Тогда		
			СтрокаМарок = Выборка.Серия.алкПредставлениеМарокФСМ;
			
			Если СтрокаМарок = "" Тогда
				Продолжить;
			КонецЕсли;
			
			Если Сред(СтрокаМарок, 4, 1) <> " " Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаСерия = Лев(СтрокаМарок, 3);
			
			Если СтрокаСерия <> ТекущаяСерияМарки Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаДиапазоны = Сред(СтрокаМарок, 5);
			МассивДапазоны = СтрЗаменить(СтрокаДиапазоны, ",", Символы.ПС);
			
			ПоискМарок = Истина;
			i = 0; 
			
			Пока ПоискМарок Цикл
				i = i + 1;
				ТекущийДиапазон = СокрЛП(СтрПолучитьСтроку(МассивДапазоны, i));
				Если ТекущийДиапазон = "" Тогда
					ПоискМарок = Ложь;
					Прервать;
				КонецЕсли;
				
				ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, ".", "");
				ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "/", "");
				ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "\", "");
				ТекущийДиапазон = СтрЗаменить(ТекущийДиапазон, "?", "");
				ПозицияСимвола = Найти(ТекущийДиапазон, "-");
				
				Если ПозицияСимвола = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				Если ПозицияСимвола = 9 Тогда
					Если ТекущаяДлинаНомераМарки <> 8 Тогда
						Продолжить;
					КонецЕсли;
					
					МинимальныйНомер = Число(Лев(ТекущийДиапазон, 8));
					МаксимальныйНомер = Число(Сред(ТекущийДиапазон, 10, 8));
				ИначеЕсли ПозицияСимвола = 10 Тогда
					Если ТекущаяДлинаНомераМарки <> 9 Тогда
						Продолжить;
					КонецЕсли;   
					
					МинимальныйНомер = Число(Лев(ТекущийДиапазон, 9));
					МаксимальныйНомер = Число(Сред(ТекущийДиапазон, 11, 9));
				Иначе
					Продолжить;
				КонецЕсли;	 
				
				Если ТекущийНомерМарки >= МинимальныйНомер И ТекущийНомерМарки <= МаксимальныйНомер Тогда
					СерияПодходит = Истина;
					Прервать;
				КонецЕсли;					
			КонецЦикла;	
			
		КонецЕсли;
		
		Если СерияПодходит Тогда
			СерияНоменклатурыВБазе = Выборка.Серия;
			Возврат СерияНоменклатурыВБазе;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;	
	
	Возврат СерияНоменклатурыВБазе;
	
КонецФункции
Функция ПолучитьНоменклатуруАкцизнойМарки(ИдентификаторМарки = "", Период = Неопределено) Экспорт
	
	МассивМарок = Новый Массив;
	
	Если ТипЗнч(ИдентификаторМарки) = Тип("Строка") Тогда
		МассивМарок.Добавить(ИдентификаторМарки);
	Иначе
		МассивМарок = ИдентификаторМарки;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивМарок", МассивМарок);
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Период), Период, Неопределено));
	Запрос.Текст = "ВЫБРАТЬ
	|	алкХранилищеАкцизныхМарокСрезПоследних.Период,
	|	алкХранилищеАкцизныхМарокСрезПоследних.Регистратор,
	|	алкХранилищеАкцизныхМарокСрезПоследних.Марка,
	|	алкХранилищеАкцизныхМарокСрезПоследних.Упаковка,
	|	алкХранилищеАкцизныхМарокСрезПоследних.СправкаБ,
	|	алкХранилищеАкцизныхМарокСрезПоследних.АлкогольнаяПродукция,
	|	алкХранилищеАкцизныхМарокСрезПоследних.Организация,
	|	алкХранилищеАкцизныхМарокСрезПоследних.ПунктРазгрузки,
	|	алкХранилищеАкцизныхМарокСрезПоследних.ОтметкаВыбытия
	|ПОМЕСТИТЬ ТаблицаМарок
	|ИЗ
	|	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(
	|			&Период,
	|			Марка В (&МассивМарок)
	|				И ОтметкаВыбытия = ЛОЖЬ) КАК алкХранилищеАкцизныхМарокСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаМарок.АлкогольнаяПродукция,
	|	ТаблицаМарок.СправкаБ,
	| 	ЕстьNULL(алкСоответствияСправокАиБЕГАИСИСерий.СерияНоменклатуры,ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК СерияНоменклатуры,
	| 	ЕстьNULL(алкСоответствияСправокАиБЕГАИСИСерий.СправкаА,ЗНАЧЕНИЕ(Справочник.алкКлассификаторСправокАиБ.ПустаяСсылка)) КАК СправкаА,
	|	ТаблицаМарок.Марка
	|ПОМЕСТИТЬ ВТ_СправкиАИБ
	|ИЗ
	|	ТаблицаМарок КАК ТаблицаМарок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК алкСоответствияСправокАиБЕГАИСИСерий
	|		ПО ТаблицаМарок.СправкаБ = алкСоответствияСправокАиБЕГАИСИСерий.СправкаБ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаМарок.Период,
	|	ТаблицаМарок.Регистратор,
	|	ТаблицаМарок.Марка КАК Марка,
	|	ТаблицаМарок.Упаковка,
	|	ТаблицаМарок.СправкаБ КАК СправкаБ,
	|	ТаблицаМарок.АлкогольнаяПродукция КАК АлкогольнаяПродукция,
	|	ТаблицаМарок.Организация,
	|	ТаблицаМарок.ПунктРазгрузки,
	|	ТаблицаМарок.ОтметкаВыбытия,
	|	ЕСТЬNULL(ВТ_СправкиАИБ.СправкаА, ЗНАЧЕНИЕ(Справочник.алкКлассификаторСправокАиБ.ПустаяСсылка)) КАК СправкаА,
	|	ЕСТЬNULL(ВТ_СправкиАИБ.СерияНоменклатуры, ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК СерияНоменклатуры,
	|	ЕСТЬNULL(ВТ_СправкиАИБ.СерияНоменклатуры.алкВладелец, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК Номенклатура	
	|ИЗ
	|	ТаблицаМарок КАК ТаблицаМарок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СправкиАИБ КАК ВТ_СправкиАИБ
	|		ПО ТаблицаМарок.Марка = ВТ_СправкиАИБ.Марка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Марка,
	|	АлкогольнаяПродукция,
	|	Номенклатура,
	|	СправкаА,
	|	СправкаБ,
	|	СерияНоменклатуры";
	
	Возврат Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.Прямой);
	
КонецФункции
Функция ПолучитьНоменклатуруАкцизнойМарки_Приемка(ИдентификаторМарки = "", СсылкаНаДок) Экспорт
	
	НоменклатураЕГАИС = Справочники.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяСсылка();
	
	ЗапросЕГАИС = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЕстьNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция,ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяСсылка)) КАК Ссылка,
	|	ЕстьNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Код, """")  КАК Алкокод,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Наименование, """") КАК ArtName,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Производитель.Наименование, """") КАК Manufacturer,
	//|	ЕСТЬNULL(ЕГАИС_Номенклатура.Импортер.Наименование, """") КАК Importer,
	|	"""" КАК Importer,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Объем, 0) КАК Capacity,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Крепость, 0) КАК PercentAlco,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.ВидПродукции.Наименование, """") КАК TypeAlco			
	|ИЗ
	|	Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.АкцизныеМарки КАК ЕГАИС_Марки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ЕГАИС_Номенклатура
	|		ПО ЕГАИС_Марки.КлючСвязи = ЕГАИС_Номенклатура.КлючСвязи
	|		И ЕГАИС_Марки.Ссылка = ЕГАИС_Номенклатура.Ссылка
	|ГДЕ
	|   ЕГАИС_Марки.Ссылка = &СсылкаНаТТН И ЕГАИС_Номенклатура.Ссылка = &СсылкаНаТТН 
	|   И ЕГАИС_Марки.КодАкцизнойМарки = &Код
	|   И НЕ ЕГАИС_Номенклатура.АлкогольнаяПродукция ЕСТЬ NULL");
	
	ЗапросЕГАИС.УстановитьПараметр("Код", ИдентификаторМарки);
	ЗапросЕГАИС.УстановитьПараметр("СсылкаНаТТН", СсылкаНаДок.ИсходныйДокумент); 
	
	
	ВыборкаЕГАИС = ЗапросЕГАИС.Выполнить().Выбрать();
	
	Если ВыборкаЕГАИС.Следующий() Тогда		
		НоменклатураЕГАИС = ВыборкаЕГАИС.Ссылка;
	КонецЕсли;	
	
	Возврат НоменклатураЕГАИС;
	
КонецФункции
Функция ПроверитьУпаковочныйлистЭтоКороб(УпаковочныйЛист, Период=Неопределено) Экспорт
	
	Если ПустаяСтрока(УпаковочныйЛист) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Упаковка", УпаковочныйЛист);
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Период), Период, Неопределено));
	Запрос.Текст = "ВЫБРАТЬ
	|	алкХранилищеУпаковокСрезПоследних.Упаковка,
	|	алкХранилищеУпаковокСрезПоследних.ИерархияУпаковки
	|ИЗ
	|	РегистрСведений.алкХранилищеУпаковок.СрезПоследних(&Период, ИерархияУпаковки = &Упаковка) КАК алкХранилищеУпаковокСрезПоследних";
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции
Функция НайтиПалетуКороба(ИдентификаторУпаковки, Период=Неопределено) Экспорт
	
	ЗапросУпаковок = Новый Запрос;
	ЗапросУпаковок.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Период), Период, Неопределено));
	ЗапросУпаковок.УстановитьПараметр("Упаковка", ИдентификаторУпаковки);
	ЗапросУпаковок.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	алкХранилищеУпаковокСрезПоследних.Регистратор,
	|	алкХранилищеУпаковокСрезПоследних.Упаковка
	|ПОМЕСТИТЬ ДанныеУпаковки	
	|ИЗ
	|	РегистрСведений.алкХранилищеУпаковок.СрезПоследних(&Период, Упаковка = &Упаковка) КАК алкХранилищеУпаковокСрезПоследних
	|ГДЕ
	|	алкХранилищеУпаковокСрезПоследних.ИерархияУпаковки <> """"
	|;
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	алкХранилищеУпаковокСрезПоследних.Регистратор,
	|	алкХранилищеУпаковокСрезПоследних.ИерархияУпаковки,
	|	ДанныеУпаковки.Регистратор,
	|	ДанныеУпаковки.Упаковка
	|ИЗ
	|	РегистрСведений.алкХранилищеУпаковок.СрезПоследних(&Период, Упаковка = &Упаковка) КАК алкХранилищеУпаковокСрезПоследних
	|	ЛЕВОЕ СОЕДИНЕНИЕ ДанныеУпаковки КАК ДанныеУпаковки
	|	ПО ДанныеУпаковки.Регистратор = алкХранилищеУпаковокСрезПоследних.Регистратор
	|ГДЕ
	|	алкХранилищеУпаковокСрезПоследних.Упаковка <> """"
	|	И ДанныеУпаковки.Регистратор=алкХранилищеУпаковокСрезПоследних.Регистратор
	|	И НЕ ДанныеУпаковки.Регистратор ЕСТЬ NULL И НЕ ДанныеУпаковки.Регистратор ЕСТЬ NULL"; 
	
	Выборка = ЗапросУпаковок.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ИерархияУпаковки;
	Иначе
		Возврат "";
	КонецЕсли;	
	
КонецФункции
