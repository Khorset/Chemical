Функция ВерсияЧислом(Знач ВерсияПО) Экспорт
	
	МаскаВерсии = "##.##.###"; // маска	
	ВерсияПОЧислом = "";
	
	СтрокаПоВерсии = СтрЗаменить(ВерсияПО, ".", Символы.ПС);; 
	СтрокаПоМаске  = СтрЗаменить(МаскаВерсии, ".", Символы.ПС);
	
	// разбор по маске
	Для Сч = 1 По СтрЧислоСтрок(СтрокаПоМаске) Цикл
		ЧастьБлокаМаски  = СтрПолучитьСтроку(СтрокаПоМаске, Сч);
		ЧастьБлокаВерсии = "";
		КолСимволовБлока = СтрДлина(ЧастьБлокаМаски);
		
		Попытка
			ЧастьБлокаВерсии = СтрПолучитьСтроку(СтрокаПоВерсии, Сч);
			
			РазницаПоДлине = КолСимволовБлока - СтрДлина(ЧастьБлокаВерсии);
			РазницаПоДлине = ?(РазницаПоДлине <=0, 0, РазницаПоДлине);
			
			ЧастьБлокаВерсии = ДобавитьНули(ЧастьБлокаВерсии, РазницаПоДлине, Истина);  
		Исключение
			ЧастьБлокаВерсии = ДобавитьНули(ЧастьБлокаВерсии, КолСимволовБлока, Истина);
		КонецПопытки;
		
		ВерсияПОЧислом = ВерсияПОЧислом + ЧастьБлокаВерсии;
	КонецЦикла;
	
	// в числовой формат
	Попытка
		ВерсияПОЧислом = Число(ВерсияПОЧислом);
	Исключение
		ВерсияПОЧислом = 0;
	КонецПопытки;
	
	Возврат ВерсияПОЧислом;
	
КонецФункции

