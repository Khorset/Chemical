			Запрос.УстановитьПараметр("Упаковка", ИдентификаторУпаковки);
			Запрос.Текст = "ВЫБРАТЬ
			|	алкХранилищеАкцизныхМарокСрезПоследних.АлкогольнаяПродукция,
			|	алкХранилищеАкцизныхМарокСрезПоследних.СправкаБ
			|ПОМЕСТИТЬ ТаблицаМарок
			|ИЗ
			|	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(&Период, Упаковка = &Упаковка) КАК алкХранилищеАкцизныхМарокСрезПоследних
			|ГДЕ
			|	алкХранилищеАкцизныхМарокСрезПоследних.ОтметкаВыбытия = ЛОЖЬ
			|	И алкХранилищеАкцизныхМарокСрезПоследних.АлкогольнаяПродукция <> ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяСсылка)
			|;
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТаблицаМарок.АлкогольнаяПродукция,
			|	ТаблицаМарок.СправкаБ,
			//|	ЕСТЬNULL(алкСоответствияСправокАиБЕГАИСИСерий.СерияНоменклатуры,ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК СерияНоменклатуры,
			//|	ЕСТЬNULL(алкСоответствияСправокАиБЕГАИСИСерий.СправкаА,ЗНАЧЕНИЕ(Справочник.алкКлассификаторСправокАиБ.ПустаяСсылка)) КАК СправкаА,
			|	1 КАК Количество
			|ПОМЕСТИТЬ ВТ_СправкиАИБ
			|ИЗ
			|	ТаблицаМарок КАК ТаблицаМарок
			//|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК алкСоответствияСправокАиБЕГАИСИСерий
			//|		ПО ТаблицаМарок.СправкаБ = алкСоответствияСправокАиБЕГАИСИСерий.СправкаБ
			|;				
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТ_СправкиАИБ.АлкогольнаяПродукция,
			|	ВТ_СправкиАИБ.СправкаБ,
			//|	ВТ_СправкиАИБ.СерияНоменклатуры,
			//|	ВТ_СправкиАИБ.СправкаА,
			|	СУММА(ВТ_СправкиАИБ.Количество) КАК Количество
			|ПОМЕСТИТЬ ОбщиеДанные
			|ИЗ
			|	ВТ_СправкиАИБ КАК ВТ_СправкиАИБ
			|СГРУППИРОВАТЬ ПО
			|	ВТ_СправкиАИБ.АлкогольнаяПродукция,
			//|	ВТ_СправкиАИБ.СерияНоменклатуры,
			//|	ВТ_СправкиАИБ.СправкаА,
			|	ВТ_СправкиАИБ.СправкаБ
			|;
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	ОбщиеДанные.АлкогольнаяПродукция,
			|	ОбщиеДанные.СправкаБ,
			//|	ОбщиеДанные.СерияНоменклатуры,
			//|	ОбщиеДанные.СправкаА,
			|	ОбщиеДанные.Количество КАК Количество
			|ИЗ
			|	ОбщиеДанные КАК ОбщиеДанные";
			
			Если ПроверкаЗадания <> 2 И ПроверкаЗадания <> 6 Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"ТаблицаМарок.СправкаБ","0 КАК СправкаБ");	
			КонецЕсли;
			
			ТЗМарок = Запрос.Выполнить().Выгрузить();	
		КонецЕсли;	
	КонецЕсли;
	
	Возврат ТЗМарок;
	
КонецФункции
Функция ПолучитьТаблицуКоличестваМарок(ИдентификаторУпаковки, ВыводитьУпаковкуВРезультат = Истина, ЭтоКороб = Ложь) Экспорт 
	
	ТЗМарок = Новый Массив;
	
	Если ИдентификаторУпаковки = "" Тогда
		Возврат ТЗМарок;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Если ЭтоКороб Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ алкХранилищеАкцизныхМарок.Марка) КАК Количество,
		|	алкХранилищеАкцизныхМарок.АлкогольнаяПродукция,
		|	алкХранилищеАкцизныхМарок.СправкаБ
		|ИЗ
		|	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(
		|			&ДатаЗапроса,
		|			Упаковка = &Упаковка) КАК алкХранилищеАкцизныхМарок
		|
		//	|ГДЕ
		//	|	алкХранилищеАкцизныхМарок.ОтметкаВыбытия = ЛОЖЬ
		|СГРУППИРОВАТЬ ПО
		|	алкХранилищеАкцизныхМарок.СправкаБ,
		|	алкХранилищеАкцизныхМарок.АлкогольнаяПродукция";
		
	Иначе
		
		Запрос.Текст =
		//ВЫБИРАЕМ ПОСЛЕДНИЙ РЕГИСТРАТОР СФОРМИРОВАВШИЙ ПАЛЕТУ
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	алкХранилищеУпаковок.Регистратор КАК Регистратор,
		|	алкХранилищеУпаковок.Период КАК Период
		|ПОМЕСТИТЬ ТабРегистраторы
		|ИЗ
		|	РегистрСведений.алкХранилищеУпаковок.СрезПоследних(
		|			&ДатаЗапроса, 
		|			Упаковка = &Упаковка) КАК алкХранилищеУпаковок
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ
		|;
		|
		//ВЫБИРАЕМ УПАКОВКИ ПО ПОСЛЕДНЕМУ РЕГИСТРАТОРУ
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	алкХранилищеУпаковок.Упаковка КАК Упаковка
		|ПОМЕСТИТЬ ТабУпаковок
		|ИЗ
		|	РегистрСведений.алкХранилищеУпаковок.СрезПоследних(
		|			&ДатаЗапроса,
		|			ИерархияУпаковки = &Упаковка
		|				И Регистратор В
		|					(ВЫБРАТЬ
		|						ТабРегистраторы.Регистратор
		|					ИЗ
		|						ТабРегистраторы КАК ТабРегистраторы)) КАК алкХранилищеУпаковок
		|;
		|
		//ВЫБИРАЕМ МАРКИ УПАКОВОК ПОСЛЕДНЕГО РЕГИСТРАТОРА
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	алкХранилищеАкцизныхМарок.Марка КАК Марка,
		|	алкХранилищеАкцизныхМарок.Упаковка КАК Упаковка,
		|	алкХранилищеАкцизныхМарок.АлкогольнаяПродукция КАК АлкогольнаяПродукция,
		|	алкХранилищеАкцизныхМарок.СправкаБ КАК СправкаБ
		|ПОМЕСТИТЬ ДанныеУпаковок
		|ИЗ
		|	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(
		|			&ДатаЗапроса,
		|			Упаковка В
		|				(ВЫБРАТЬ
		|					ТабУпаковок.Упаковка
		|				ИЗ
		|					ТабУпаковок КАК ТабУпаковок)) КАК алкХранилищеАкцизныхМарок
		|ГДЕ
		|	алкХранилищеАкцизныхМарок.ОтметкаВыбытия = ЛОЖЬ
		|;
		|
		//ВЫБИРАЕМ КОЛИЧЕСТВО МАРОК УПАКОВОК ПОСЛЕДНЕГО РЕГИСТРАТОРА
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДанныеУпаковок.Марка) КАК Количество,
		|	ДанныеУпаковок.Упаковка КАК Упаковка,
		|	ДанныеУпаковок.АлкогольнаяПродукция КАК АлкогольнаяПродукция,
		|	ДанныеУпаковок.СправкаБ КАК СправкаБ
		|ИЗ
		|	ДанныеУпаковок КАК ДанныеУпаковок
		|СГРУППИРОВАТЬ ПО
		|	ДанныеУпаковок.Упаковка,
		|	ДанныеУпаковок.СправкаБ,
		|	ДанныеУпаковок.АлкогольнаяПродукция";
		
	КонецЕсли;
	
	Если Не ВыводитьУпаковкуВРезультат И Не ЭтоКороб Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "алкХранилищеАкцизныхМарок.Упаковка", """""");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Упаковка", ИдентификаторУпаковки);
	Запрос.УстановитьПараметр("ДатаЗапроса", ТекущаяДата());
	
	ТЗМарок = Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗМарок;
	
КонецФункции
Функция ПолучитьТаблицуУпакованногоТовара_УпаковочногоЛиста(ИдентификаторУпаковки = "") Экспорт 
	
	Если Лев(ИдентификаторУпаковки,3) = "UPL" Тогда 
		КодУпакЛиста = Прав(ИдентификаторУпаковки,СтрДлина(ИдентификаторУпаковки)-3); 
	Иначе     
		КодУпакЛиста = ИдентификаторУпаковки; 
	КонецЕсли; 
	
	Запрос = Новый Запрос; 
	Запрос.Текст = "ВЫБРАТЬ 
	|     ДатаМобайл_УпаковочныйЛистТовары.ЕГАИС_Номенклатура КАК АлкогольнаяПродукция,
	|     ДатаМобайл_УпаковочныйЛистТовары.Номенклатура КАК Номенклатура,
	|     ДатаМобайл_УпаковочныйЛистТовары.СправкаБ КАК СправкаБ, 
	|     СУММА(ДатаМобайл_УпаковочныйЛистТовары.Количество) КАК Количество 
	|ИЗ 
	|     Документ.ДатаМобайл_УпаковочныйЛист.Товары КАК ДатаМобайл_УпаковочныйЛистТовары 
	|ГДЕ 
	|     ДатаМобайл_УпаковочныйЛистТовары.Количество > 0 
	|     И (ДатаМобайл_УпаковочныйЛистТовары.Ссылка.Код = &КодУпакЛиста)
	| 
	|СГРУППИРОВАТЬ ПО 
	|     ДатаМобайл_УпаковочныйЛистТовары.ЕГАИС_Номенклатура,
	|     ДатаМобайл_УпаковочныйЛистТовары.Номенклатура,
	|     ДатаМобайл_УпаковочныйЛистТовары.СправкаБ"; 
	
	// искать по коду, если по коду нет - искать по номеру, где код не пустой
	
	Запрос.УстановитьПараметр("КодУпакЛиста", КодУпакЛиста); 		
	Рез = Запрос.Выполнить().Выгрузить(); 
	
	Если Рез.Количество() = 0 Тогда
		Рез = "";
		Запрос.Текст = "ВЫБРАТЬ 
		|     ДатаМобайл_УпаковочныйЛистТовары.ЕГАИС_Номенклатура КАК АлкогольнаяПродукция,
		|     ДатаМобайл_УпаковочныйЛистТовары.Номенклатура КАК Номенклатура,
		|     ДатаМобайл_УпаковочныйЛистТовары.СправкаБ КАК СправкаБ, 
		|     СУММА(ДатаМобайл_УпаковочныйЛистТовары.Количество) КАК Количество 
		|ИЗ 
		|     Документ.ДатаМобайл_УпаковочныйЛист.Товары КАК ДатаМобайл_УпаковочныйЛистТовары 
		|ГДЕ 
		|     ДатаМобайл_УпаковочныйЛистТовары.Количество > 0 
		|     И (ДатаМобайл_УпаковочныйЛистТовары.Ссылка.Номер = &КодУпакЛиста)
		|	   И  ДатаМобайл_УпаковочныйЛистТовары.Ссылка.Код = """"
		| 
		|СГРУППИРОВАТЬ ПО 
		|     ДатаМобайл_УпаковочныйЛистТовары.ЕГАИС_Номенклатура,
		|     ДатаМобайл_УпаковочныйЛистТовары.Номенклатура,
		|     ДатаМобайл_УпаковочныйЛистТовары.СправкаБ"; 
		
		Запрос.УстановитьПараметр("КодУпакЛиста", КодУпакЛиста); 		
		Рез = Запрос.Выполнить().Выгрузить(); 	
	КонецЕсли;
	
	Возврат  Рез;
	
КонецФункции
Функция ПланРавноФактЕГАИС(Док)
	
	ДокТЧ = ПолучитьТЧДокументаЕГАИС(Док);
	
	Если ДокТЧ.Количество() > 0 Тогда
		Для каждого Стр Из ДокТЧ Цикл
			Если Стр.План <> Стр.Факт Тогда
				Возврат Ложь;
			КонецЕсли;			
		КонецЦикла;				
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции
Функция ПолучитьТЧДокументаЕГАИС(Док)
	
	Если ТипЗнч(Док) = Тип("СправочникСсылка.ДатаМобайл_ДокументыТСД_ЕГАИС")
		Или ТипЗнч(Док) = Тип("СправочникОбъект.ДатаМобайл_ДокументыТСД_ЕГАИС") Тогда
		#Область ДокументТСД_ЕГАИС
		Если Док.Шаблон.ЕГАИС Тогда
			Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
			|	СУММА(ВложенныйЗапрос.План) КАК План,
			|	СУММА(ВложенныйЗапрос.Факт) КАК Факт,
			|	СУММА(-ВложенныйЗапрос.План + ВложенныйЗапрос.Факт) КАК Расхождения,
			|	ВложенныйЗапрос.ТипСтроки
			|ПОМЕСТИТЬ ВременнаяТаблица
			|ИЗ
			|	(ВЫБРАТЬ
			|		СобранныеДанныеПодбор.НоменклатураЕГАИС КАК Номенклатура,
			|		0 КАК План,
			|		СобранныеДанныеПодбор.Количество КАК Факт,
			|		""Подбор"" КАК ТипСтроки,
			|		"""" КАК Название
			|	ИЗ
			|		Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК СобранныеДанныеПодбор
			|	ГДЕ
			|		СобранныеДанныеПодбор.Ссылка = &Ссылка
			|	
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		ТаблицаДокумента1СПодбор.АлкогольнаяПродукция,
			|		ТаблицаДокумента1СПодбор.Количество,
			|		0,
			|		""Подбор"",
			|		""""
			|	ИЗ
			|		Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ТаблицаДокумента1СПодбор 
			|			
			|	ГДЕ
			|		ТаблицаДокумента1СПодбор.Ссылка = &ИсходныйДокумент) КАК ВложенныйЗапрос
			|
			|СГРУППИРОВАТЬ ПО
			|	ВложенныйЗапрос.ТипСтроки,
			|	ВложенныйЗапрос.Номенклатура
			|
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВременнаяТаблица.ТипСтроки,
			|	ВременнаяТаблица.Номенклатура КАК Номенклатура,
			|	ВременнаяТаблица.План,
			|	ВременнаяТаблица.Факт,
			|	ВременнаяТаблица.Расхождения
			|ИЗ
			|	ВременнаяТаблица КАК ВременнаяТаблица
			|ГДЕ
			|	ВременнаяТаблица.План-ВременнаяТаблица.Факт<>0
			|	И 1=1
			|"); 	
			
			Запрос.Текст=СтрЗаменить(Запрос.Текст,"Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ТаблицаДокумента1СПодбор","Документ."+Док.Шаблон.ВидДокумента+"."+Док.Шаблон.ИмяТабличнойЧастиПодбор+" КАК ТаблицаДокумента1СПодбор");							
			
			Если Док.Шаблон.ГрупповаяРабота И Док.ДатаЗавершения=Дата(1,1,1)  Тогда
				Запрос.Текст=СтрЗаменить(Запрос.Текст,"Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор","РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов");
				Запрос.Текст=СтрЗаменить(Запрос.Текст,"СобранныеДанныеПодбор.Ссылка = &Ссылка","СобранныеДанныеПодбор.ДокументТСД = &Ссылка И НЕ СобранныеДанныеПодбор.ДляОбмена И  СобранныеДанныеПодбор.ИмяТаблицы = ""Select""");
			КонецЕсли;			
			
			Если Док.Шаблон.ВидДокумента = "ДатаМобайл_УпаковочныйЛист" Или Док.Шаблон.ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад" Тогда	
				Запрос.Текст=СтрЗаменить(Запрос.Текст,"ТаблицаДокумента1СПодбор.АлкогольнаяПродукция","ТаблицаДокумента1СПодбор.ЕГАИС_Номенклатура");
			ИначеЕсли Док.Шаблон.ВидДокумента = "алкАктФиксацииШтрихкодовНаБалансеОрганизацииЕГАИС" Тогда	
				Запрос.Текст=СтрЗаменить(Запрос.Текст,"ТаблицаДокумента1СПодбор.Количество","999");
			КонецЕсли;
			
			Если Док.Шаблон.ВидДокумента = "РеализацияТоваровУслуг" 
				Или Док.Шаблон.ВидДокумента = "ЗаказКлиента" 
				Или Док.Шаблон.ВидДокумента = "ПеремещениеТоваров"
				Или Док.Шаблон.ВидДокумента = "ПересчетТоваров"
				Или Док.Шаблон.ВидДокумента = "СписаниеНедостачТоваров" 
				Или Док.Шаблон.ВидДокумента = "ОрдерНаОтражениеНедостачТоваров"
				Или Док.Шаблон.ВидДокумента = "ВозвратТоваровПоставщику"
				Или Док.Шаблон.ПроверкаЗадания = 3 Или Док.Шаблон.ПроверкаЗадания = 6 Тогда				
				
				Запрос.Текст = "ВЫБРАТЬ
				|	ВложенныйЗапрос.ТипСтроки КАК ТипСтроки,
