			|	ИтоговаяТаблица.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
			|	СУММА(ИтоговаяТаблица.План) КАК План,
			|	СУММА(ИтоговаяТаблица.Факт) КАК Факт,
			|	СУММА(ИтоговаяТаблица.Расхождения) КАК Расхождения,
			|	ИтоговаяТаблица.ТипСтроки
			|ПОМЕСТИТЬ ВременнаяТаблица
			|ИЗ
			|	(ВЫБРАТЬ
			|		ВложенныйЗапрос.Номенклатура КАК Номенклатура,
			|		ЕСТЬNULL(ВложенныйЗапрос.ХарактеристикаНоменклатуры, """") КАК ХарактеристикаНоменклатуры,
			|		СУММА(ВложенныйЗапрос.План) КАК План,
			|		СУММА(ВложенныйЗапрос.Факт) КАК Факт,
			|		СУММА(-ВложенныйЗапрос.План + ВложенныйЗапрос.Факт) КАК Расхождения,
			|		ВложенныйЗапрос.ТипСтроки КАК ТипСтроки,
			|		ВложенныйЗапрос.Название КАК Название
			|	ИЗ
			|		(ВЫБРАТЬ
			|			СобранныеДанныеПодбор.Номенклатура КАК Номенклатура,
			|			ЕСТЬNULL(СобранныеДанныеПодбор.ХарактеристикаНоменклатуры, """") КАК ХарактеристикаНоменклатуры,
			|			0 КАК План,
			|			СобранныеДанныеПодбор.Количество * ЕСТЬNULL(ВЫБОР КОГДА ЕСТЬNULL(СобранныеДанныеПодбор.ЕдиницаИзмерения.Числитель,1) = 0 ТОГДА 1 ИНАЧЕ ЕСТЬNULL(СобранныеДанныеПодбор.ЕдиницаИзмерения.Числитель,1) КОНЕЦ/ 
			|	         		   									ВЫБОР КОГДА ЕСТЬNULL(СобранныеДанныеПодбор.ЕдиницаИзмерения.Знаменатель,1) = 0 ТОГДА 1 ИНАЧЕ ЕСТЬNULL(СобранныеДанныеПодбор.ЕдиницаИзмерения.Знаменатель,1) КОНЕЦ, 1) КАК Факт,
			|			""Подбор"" КАК ТипСтроки,
			|			"""" КАК Название
			|		ИЗ
			|			Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК СобранныеДанныеПодбор
			|		ГДЕ
			|			СобранныеДанныеПодбор.Ссылка = &Ссылка
			|			И &УсловиеЕстьПодбор
			|		
			|		ОБЪЕДИНИТЬ ВСЕ
			|		
			|		ВЫБРАТЬ
			|			СобранныеДанныеПриемка.Номенклатура,
			|			ЕСТЬNULL(СобранныеДанныеПриемка.ХарактеристикаНоменклатуры, """"),
			|			0,
			|			СобранныеДанныеПриемка.Количество*СобранныеДанныеПриемка.ЕдиницаИзмерения.Числитель,
			|			""Размещение"",
			|			""""
			|		ИЗ
			|			Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПриемка КАК СобранныеДанныеПриемка
			|		ГДЕ
			|			СобранныеДанныеПриемка.Ссылка = &Ссылка
			|			И &УсловиеЕстьПриемка
			|		
			|		ОБЪЕДИНИТЬ ВСЕ
			|		
			|		ВЫБРАТЬ
			|			ТаблицаДокумента1СПодбор.Номенклатура,
			|			ЕСТЬNULL(ТаблицаДокумента1СПодбор.Характеристика, """"),
			|			ВЫБОР КОГДА ЕстьNULL(ТаблицаДокумента1СПодбор.Количество,0) = 0 
			|				ТОГДА ТаблицаДокумента1СПодбор.КоличествоУпаковок	
			|				ИНАЧЕ ЕстьNULL(ТаблицаДокумента1СПодбор.Количество,0) 
			|			КОНЕЦ,
			|			0,
			|			""Подбор"",
			|			""""
			|		ИЗ
			|			Документ.ПриходныйОрдерНаТовары.Товары КАК ТаблицаДокумента1СПодбор
			|		ГДЕ
			|			&УсловиеЕстьПодбор
			|			И ТаблицаДокумента1СПодбор.Ссылка = &ИсходныйДокумент
			|		
			|		ОБЪЕДИНИТЬ ВСЕ
			|		
			|		ВЫБРАТЬ
			|			ТаблицаДокумента1СПриемка.Номенклатура,
			|			ТаблицаДокумента1СПриемка.Характеристика,
			|			ВЫБОР КОГДА ЕстьNULL(ТаблицаДокумента1СПриемка.Количество,0) = 0 
			|				ТОГДА ТаблицаДокумента1СПриемка.КоличествоУпаковок	
			|				ИНАЧЕ ЕстьNULL(ТаблицаДокумента1СПриемка.Количество,0) 
			|			КОНЕЦ,
			|			0,
			|			""Размещение"",
			|			""""
			|		ИЗ
			|			Документ.ПриходныйОрдерНаТовары.Товары КАК ТаблицаДокумента1СПриемка
			|		ГДЕ
			|			&УсловиеЕстьПриемка
			|			И ТаблицаДокумента1СПриемка.Ссылка = &ИсходныйДокумент) КАК ВложенныйЗапрос
			|	
			|	СГРУППИРОВАТЬ ПО
			|		ВложенныйЗапрос.ТипСтроки,
			|		ВложенныйЗапрос.ХарактеристикаНоменклатуры,
			|		ВложенныйЗапрос.Номенклатура,
			|		ВложенныйЗапрос.Название) КАК ИтоговаяТаблица
			|
			|СГРУППИРОВАТЬ ПО
			|	ИтоговаяТаблица.ТипСтроки,
			|	ИтоговаяТаблица.ХарактеристикаНоменклатуры,
			|	ИтоговаяТаблица.Номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВременнаяТаблица.Номенклатура КАК Номенклатура,
			|	ВременнаяТаблица.План КАК План,
			|	ВременнаяТаблица.Факт КАК Факт,
			|	ВременнаяТаблица.Расхождения КАК Расхождения,
			|	ВременнаяТаблица.ТипСтроки КАК ТипСтроки
			|ИЗ
			|	ВременнаяТаблица КАК ВременнаяТаблица
			|ГДЕ
			|	ВременнаяТаблица.План-ВременнаяТаблица.Факт<>0
			|";
			
			Если Док.Шаблон.ИспользоватьПодбор Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ПриходныйОрдерНаТовары.Товары КАК ТаблицаДокумента1СПодбор","Документ."+Док.Шаблон.ВидДокумента+"."+Док.Шаблон.ИмяТабличнойЧастиПодбор+" КАК ТаблицаДокумента1СПодбор");
			КонецЕсли;
			
			Если Док.Шаблон.ИспользоватьПриемку Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"Документ.ПриходныйОрдерНаТовары.Товары КАК ТаблицаДокумента1СПриемка","Документ."+Док.Шаблон.ВидДокумента+"."+Док.Шаблон.ИмяТабличнойЧастиПриемка+" КАК ТаблицаДокумента1СПриемка");
			КонецЕсли;		
			
			Если Док.Шаблон.ВидДокумента ="УстановкаЦенНоменклатуры" Или Док.Шаблон.ВидДокумента ="ПрименениеЦенНоменклатуры" Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"ТаблицаДокумента1СПодбор.КоличествоУпаковок",999);
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"ТаблицаДокумента1СПриемка.КоличествоУпаковок",999);
				
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"ТаблицаДокумента1СПодбор.Количество",999);
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"ТаблицаДокумента1СПриемка.Количество",999);
			КонецЕсли;
			
			Если Док.Шаблон.ГрупповаяРабота И Док.ДатаЗавершения=Дата(1,1,1) Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор","РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов");
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"СобранныеДанныеПодбор.Ссылка = &Ссылка","СобранныеДанныеПодбор.ДокументТСД = &Ссылка И НЕ СобранныеДанныеПодбор.ДляОбмена И  СобранныеДанныеПодбор.ИмяТаблицы = ""Select""");
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПриемка","РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов");
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"СобранныеДанныеПриемка.Ссылка = &Ссылка","СобранныеДанныеПриемка.ДокументТСД = &Ссылка И НЕ СобранныеДанныеПриемка.ДляОбмена И  СобранныеДанныеПриемка.ИмяТаблицы = ""Insert""");
			КонецЕсли;
		КонецЕсли; 
		
		Запрос.УстановитьПараметр("УсловиеЕстьПодбор" , Док.Шаблон.ИспользоватьПодбор);
		Запрос.УстановитьПараметр("УсловиеЕстьПриемка", Док.Шаблон.ИспользоватьПриемку);
		#КонецОбласти
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ИсходныйДокумент"  , Док.ИсходныйДокумент);
	Запрос.УстановитьПараметр("Ссылка"            , Док.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	
	Возврат РезультатЗапроса;  
	
КонецФункции
Функция ПолучитьНоменклатуруПоЕГАИС_ОПТ(НоменклатураЕГАИС, PDFBarcode = "", ВернутьМассив = Ложь) Экспорт    	
	
	ТекТовар = Справочники.Номенклатура.ПустаяСсылка();
	
	Если ЗначениеЗаполнено(PDFBarcode) Тогда 
		ДанныеНоменклатурыПоМарке = ПолучитьНоменклатуруАкцизнойМарки(PDFBarcode);
		
		Если ДанныеНоменклатурыПоМарке.Количество() > 0 Тогда
			Возврат ДанныеНоменклатурыПоМарке[0].Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекТовар) Тогда
		Запрос = Новый Запрос;		
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СоответствиеНоменклатурыЕГАИС.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ СписокНоменклатуры	
		|ИЗ
		|	РегистрСведений.алкСоответствияАлкогольнойПродукцииЕГАИСИНоменклатуры КАК СоответствиеНоменклатурыЕГАИС
		|ГДЕ
		|	СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция = &НоменклатураЕГАИС
		|;
		|ВЫБРАТЬ
		|	СписокНоменклатуры.Номенклатура КАК Номенклатура,
		|	ЕстьNULL(Сумма(ЕстьNULL(ОстаткиТоваров.ВНаличииОстаток,0)),0) КАК КоличествоОстаток
		|ПОМЕСТИТЬ СписокНоменклатурыОстатки
		|ИЗ
		|	СписокНоменклатуры КАК СписокНоменклатуры
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки КАК ОстаткиТоваров
		|		ПО ОстаткиТоваров.Номенклатура = СписокНоменклатуры.Номенклатура 
		//|		И  (ОстаткиТоваров.Склад = &Склад ИЛИ &ВсеСклады)
		|СГРУППИРОВАТЬ ПО
		|	СписокНоменклатуры.Номенклатура
		|;
		|ВЫБРАТЬ
		|	СписокНоменклатурыОстатки.Номенклатура КАК Номенклатура
		|ИЗ
		|	СписокНоменклатурыОстатки КАК СписокНоменклатурыОстатки
		|УПОРЯДОЧИТЬ ПО 
		|	СписокНоменклатурыОстатки.КоличествоОстаток УБЫВ";
		
		Запрос.УстановитьПараметр("НоменклатураЕГАИС",НоменклатураЕГАИС);
	
		Если ВернутьМассив Тогда
			Возврат Запрос.Выполнить().Выгрузить();
		Иначе
			Рез = Запрос.Выполнить().Выбрать();
			Если Рез.Следующий() Тогда
				Возврат	Рез.Номенклатура;
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;
	
	Возврат  ТекТовар;
	
КонецФункции
Функция ПолучитьЕГАИСПоНоменклатуреОПТ(Номенклатура, Серия = Неопределено) Экспорт    	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1 
	|	СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция КАК АлкогольнаяПродукция
	|ИЗ
	|	РегистрСведений.алкСоответствияАлкогольнойПродукцииЕГАИСИНоменклатуры КАК СоответствиеНоменклатурыЕГАИС
	|ГДЕ
	|	СоответствиеНоменклатурыЕГАИС.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	
	Если Серия <> Неопределено Тогда
		Запрос.Текст = Запрос.Текст + " И СоответствиеНоменклатурыЕГАИС.СерияНоменклатуры = &Серия"; 
		Запрос.УстановитьПараметр("Серия",Серия);		
	КонецЕсли;
		
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() тогда
		ТекТовар = Рез.АлкогольнаяПродукция;
		Возврат ТекТовар; 
	КонецЕсли;
	
	ТекТовар = Справочники.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяСсылка();
	Возврат ТекТовар;
	
КонецФункции
Функция ПолучитьНоменклатуруПоУпаковкеЕГАИС_ОПТ(НоменклатураЕГАИС, ИдентификаторУпаковки="") Экспорт
	ТекТовар = Справочники.Номенклатура.ПустаяСсылка();

	МассивМарок = Новый Массив;
	Если ТипЗнч(ИдентификаторУпаковки) = Тип("Строка") Тогда
		МассивМарок.Добавить(ИдентификаторУпаковки);
	Иначе
		МассивМарок = ИдентификаторУпаковки;
	КонецЕсли;
	
	//Информация об упаковках в регистре марок	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", Неопределено);
	Запрос.УстановитьПараметр("СписокМарок", МассивМарок);
	Запрос.Текст = "ВЫБРАТЬ
				   |	алкХранилищеАкцизныхМарокСрезПоследних.АлкогольнаяПродукция,
				   |	алкХранилищеАкцизныхМарокСрезПоследних.СправкаБ
				   |ПОМЕСТИТЬ ТаблицаМарок
				   |ИЗ
				   |	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(&Период, Упаковка В (&СписокМарок)) КАК алкХранилищеАкцизныхМарокСрезПоследних
				   |ГДЕ
				   |	алкХранилищеАкцизныхМарокСрезПоследних.ОтметкаВыбытия = ЛОЖЬ
				   |	И алкХранилищеАкцизныхМарокСрезПоследних.АлкогольнаяПродукция <> ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяСсылка)
				   |;
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |	ТаблицаМарок.АлкогольнаяПродукция,
				   |	ТаблицаМарок.СправкаБ,
				   |	ЕСТЬNULL(алкСоответствияСправокАиБЕГАИСИСерий.СерияНоменклатуры,ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК СерияНоменклатуры,
				   |	ЕСТЬNULL(алкСоответствияСправокАиБЕГАИСИСерий.СправкаА,ЗНАЧЕНИЕ(Справочник.алкКлассификаторСправокАиБ.ПустаяСсылка)) КАК СправкаА,
				   |	1 КАК Количество
				   |ПОМЕСТИТЬ ВТ_СправкиАИБ
				   |ИЗ
				   |	ТаблицаМарок КАК ТаблицаМарок
				   |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК алкСоответствияСправокАиБЕГАИСИСерий
				   |		ПО ТаблицаМарок.СправкаБ = алкСоответствияСправокАиБЕГАИСИСерий.СправкаБ
				   |;				
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |	ВТ_СправкиАИБ.АлкогольнаяПродукция,
				   |	ВТ_СправкиАИБ.СправкаБ,
				   |	ВТ_СправкиАИБ.СерияНоменклатуры,
				   |	ВТ_СправкиАИБ.СправкаА,
				   |	СУММА(ВТ_СправкиАИБ.Количество) КАК Количество
				   |ПОМЕСТИТЬ ОбщиеДанные
				   |ИЗ
				   |	ВТ_СправкиАИБ КАК ВТ_СправкиАИБ
				   |СГРУППИРОВАТЬ ПО
				   |	ВТ_СправкиАИБ.АлкогольнаяПродукция,
				   |	ВТ_СправкиАИБ.СправкаБ,
				   |	ВТ_СправкиАИБ.СерияНоменклатуры,
				   |	ВТ_СправкиАИБ.СправкаА
				   |;
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ ПЕРВЫЕ 1
				   |	ОбщиеДанные.АлкогольнаяПродукция,
				   |	ОбщиеДанные.СправкаБ,
				   |	ОбщиеДанные.СерияНоменклатуры,
				   |	ОбщиеДанные.СерияНоменклатуры.алкВладелец КАК Номенклатура,
				   |	ОбщиеДанные.СправкаА,
				   |	ОбщиеДанные.Количество КАК Количество
				   |ИЗ
				   |	ОбщиеДанные КАК ОбщиеДанные";
	
	
	ТЗМарок = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.Прямой);	
	Если ТЗМарок.Количество() > 0 тогда
		ТекущийТовар = ТЗМарок[0].Номенклатура;
		Если ЗначениеЗаполнено(ТекущийТовар) тогда
			  ТекТовар=ТекущийТовар;
		КонецЕсли;
	КонецЕсли;	
	
	Возврат  ТекТовар;
КонецФункции
Процедура ОчиститьЗаписиТСДГрупповогоДокумента_ОПТ(ДокументТСД, ТСД = Неопределено) Экспорт
	
	СтруктураОтбора = Новый Структура("ДокументТСД", ДокументТСД);

	ВыборкаЗаписейТСД = РегистрыСведений.ДатаМобайл_ТСДГрупповыхДокументов.Выбрать(СтруктураОтбора);
	Пока ВыборкаЗаписейТСД.Следующий() Цикл
		Если ТСД = Неопределено Тогда
		ВыборкаЗаписейТСД.ПолучитьМенеджерЗаписи().Удалить();
		Иначе
			Если ВыборкаЗаписейТСД.ПолучитьМенеджерЗаписи().ТСД = ТСД Тогда
				ВыборкаЗаписейТСД.ПолучитьМенеджерЗаписи().Удалить();
			КонецЕсли;            
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

