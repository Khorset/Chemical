Процедура ПриИзмененииРеквизитаДоговорыКонтрагентов(Объект, Элемент) Экспорт
	Стр = AMS_ВызовСервера.ПолучитьНаименованиеДоговора(Объект.Номер, Объект.Дата, Объект.Организация, Объект.Партнер,
		Объект.Контрагент, Объект.ТипДоговора, Объект.Наименование);

	Объект.Наименование          = Стр.Наименование;
	Объект.НаименованиеДляПечати = Стр.НаименованиеДляПечати;

	Если Элемент = "Контрагент" И Не AMS_ВызовСервера.ЭтоКонтрагентПартнера(Объект.Партнер, Объект.Контрагент) Тогда
		ПоказатьПредупреждение( , """" + Объект.Контрагент + """ не является контрагентом партнёра """ + Объект.Партнер	+ """.");
		Объект.Контрагент = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Справочник.Контрагенты.ПустаяСсылка");

	ИначеЕсли Элемент = "Статус" И Объект.Статус = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент(
		"Перечисление.СтатусыДоговоровКонтрагентов.Действует") Тогда
	КонецЕсли;
КонецПроцедуры

