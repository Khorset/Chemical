	ПолучениеШапкиУпаковки = Ложь; 
	
	// Наборы
	Если РаботаСМаркируемымиНаборами Тогда 
		МассивНоменклатуры = ТаблицаТоваров.ВыгрузитьКолонку("Номенклатура");
		МассивХарактеристик = ТаблицаТоваров.ВыгрузитьКолонку("Характеристика");

