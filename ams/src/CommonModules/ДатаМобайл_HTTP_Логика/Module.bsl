	Исключение			
		СтруктураОтвета.Вставить("Описание", "Не смогли записать документ. " );		
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
	КонецПопытки;	
	
	СтруктураОтвета.Вставить("is_success", Истина);
	
	Возврат ПодготовитьОтветJSON(СтруктураОтвета);
	
КонецФункции

