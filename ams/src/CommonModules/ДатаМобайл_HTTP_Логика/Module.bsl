	ВерсияПО32ИлиВыше = Ложь;
	
	Попытка 
		ВерсияЧислом = ДатаМобайл_ОбщийМодуль.ВерсияЧислом(AppVersion);
		
		Если ВерсияЧислом >= ДатаМобайл_ОбщийМодуль.ВерсияЧислом("3.1") Тогда
