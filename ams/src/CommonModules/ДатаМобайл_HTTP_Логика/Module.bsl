//
Процедура УстановитьЗначениеДопРевизитаИзСтроки(СтрокаДопРеквизитов, ДопРеквизит, ИмяРеквизита, НовоеЗначениеРеквизитаСтрокой, ТекстОшибки = "") Экспорт
	
	ТипРеквизита = ДопРеквизит.ТипЗначения;	
	
	Если ТипРеквизита = Новый ОписаниеТипов("Строка") Или ТипРеквизита.СодержитТип(Тип("Строка")) Тогда
		СтрокаДопРеквизитов.Значение = НовоеЗначениеРеквизитаСтрокой;
	ИначеЕсли ТипРеквизита = Новый ОписаниеТипов("Булево") Или ТипРеквизита.СодержитТип(Тип("Булево")) Тогда
		Если НРег(НовоеЗначениеРеквизитаСтрокой) = "да" Или НРег(НовоеЗначениеРеквизитаСтрокой) = "нет" Тогда
			СтрокаДопРеквизитов.Значение = Булево(НовоеЗначениеРеквизитаСтрокой);
