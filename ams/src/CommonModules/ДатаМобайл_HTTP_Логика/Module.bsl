				Если СсылкаНаДок.ИсходныйДокумент.Серии.Количество()>0 тогда
					СерииВОтдельнойТЧ = Истина;
					Запрос.Текст=СтрЗаменить(Запрос.Текст,"ТаблицаТоваровВДокументе.Серия","ЕСТЬNULL(ТаблицаТоваровВДокументе.Серия, ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка))");
					Запрос.Текст=СтрЗаменить(Запрос.Текст,"СУММА(ТаблицаТоваровВДокументе.Количество)","СУММА(ЕСТЬNULL(ТаблицаТоваровВДокументе.Количество, ТаблицаТоваровВДокументе.Количество))");
					Запрос.Текст=СтрЗаменить(Запрос.Текст,"ТЧ_Товары КАК ТаблицаТоваровВДокументеПред","ТЧ_Товары КАК ТаблицаТоваровВДокументеПред
					|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Серии КАК ТаблицаСерийВДокументе
