		или ВидДокумента = "ВозвратТоваровПоставщику"
		или (ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад" И (Шаблон.ПроверкаЗадания =3 или Шаблон.ПроверкаЗадания = 6)) 
		или (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания =3 или Шаблон.ПроверкаЗадания = 6)) тогда 
		
		Запрос.Текст =         
		
		"ВЫБРАТЬ
		|	ТЧ_Товары.Номенклатура КАК Номенклатура, 
		|	ТЧ_Товары.Ссылка КАК Ссылка,
		|	&УсловиеЦенаПред КАК Цена,
		|	СУММА(ТЧ_Товары.Количество) КАК Количество,
		|	МИНИМУМ(ТЧ_Товары.НомерСтроки) КАК НомерСтроки,
		|	ТЧ_Товары.Серия КАК Серия
		|ПОМЕСТИТЬ ТЧ_Товары
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК ТЧ_Товары 
		|ГДЕ
		|	ТЧ_Товары.Ссылка = &ИсходноеЗадание
		|СГРУППИРОВАТЬ ПО 
		|	ТЧ_Товары.Номенклатура,
		|  	&УсловиеЦенаПред,
		|   ТЧ_Товары.Серия,
		|   ТЧ_Товары.Ссылка
		|
		|;
		|/////////////////////////////////////////////////////////////////////////////////						
		|ВЫБРАТЬ
		|	ТаблицаТоваровВДокументеПред.Номенклатура КАК Номенклатура,
		|	ТаблицаТоваровВДокументеПред.Цена КАК Цена,
		|	СУММА(ТаблицаТоваровВДокументеПред.Количество) КАК Количество,
		|	МИНИМУМ(ТаблицаТоваровВДокументеПред.НомерСтроки) КАК НомерСтроки,
		|	ТаблицаТоваровВДокументеПред.Серия КАК Серия
		|ПОМЕСТИТЬ ТаблицаТоваровВДокументеПред
		|ИЗ
		|	ТЧ_Товары КАК ТаблицаТоваровВДокументеПред 
		|СГРУППИРОВАТЬ ПО 
		|	ТаблицаТоваровВДокументеПред.Номенклатура,
		|  	ТаблицаТоваровВДокументеПред.Цена,
		|   ТаблицаТоваровВДокументеПред.Серия
		|
		|;
		|/////////////////////////////////////////////////////////////////////////////////						
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапросСЛимитами.Номенклатура,
		|	ЗапросСЛимитами.НоменклатураУчетная,
		|	ЗапросСЛимитами.Цена,
		|	ЗапросСЛимитами.Количество КАК Количество,
		|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0)) КАК Лимит,
		|	ЗапросСЛимитами.НомерСтроки КАК НомерСтроки,
		|	ЗапросСЛимитами.ИдентификаторСтроки КАК ИдентификаторСтроки,
		|	ЗапросСЛимитами.Серия КАК Серия
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ЕСТЬNULL(ЕГАИСТоварыСправок.АлкогольнаяПродукция,ЕСТЬNULL(ЕГАИСТовары.АлкогольнаяПродукция,ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяССылка)))) КАК Номенклатура,
		|		ТаблицаТоваровВДокументе.Номенклатура КАК НоменклатураУчетная,
		|		&УсловиеЦенаПост КАК Цена,
		|		СУММА(ТаблицаТоваровВДокументе.Количество) КАК Количество,
		|		МИНИМУМ(ТаблицаТоваровВДокументе.НомерСтроки) КАК НомерСтроки,
		|		0 КАК ИдентификаторСтроки,
		|		ТаблицаТоваровВДокументе.Серия КАК Серия
		|	ИЗ
		|		ТаблицаТоваровВДокументеПред КАК ТаблицаТоваровВДокументе
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			СоответствиеНоменклатурыЕГАИС.Номенклатура КАК Номенклатура,
		|			МАКСИМУМ(СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция) КАК АлкогольнаяПродукция
		|			ИЗ
		|			РегистрСведений.алкСоответствияАлкогольнойПродукцииЕГАИСИНоменклатуры КАК СоответствиеНоменклатурыЕГАИС
		|			СГРУППИРОВАТЬ ПО
		|			СоответствиеНоменклатурыЕГАИС.Номенклатура) КАК ЕГАИСТовары
		|			ПО ЕГАИСТовары.Номенклатура = ТаблицаТоваровВДокументе.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			СоответствиеСправокСерийЕГАИС.СерияНоменклатуры КАК Серия,
		|			МАКСИМУМ(СоответствиеСправокСерийЕГАИС.СправкаБ.Владелец) КАК АлкогольнаяПродукция
		|			ИЗ
		|			РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК СоответствиеСправокСерийЕГАИС
		|			СГРУППИРОВАТЬ ПО
		|			СоответствиеСправокСерийЕГАИС.СерияНоменклатуры) КАК ЕГАИСТоварыСправок
		|			ПО ЕГАИСТоварыСправок.Серия = ТаблицаТоваровВДокументе.Серия
		|	СГРУППИРОВАТЬ ПО
		|		ТаблицаТоваровВДокументе.Номенклатура,
		|		&УсловиеЦенаПост,
		|		0,
		|		ТаблицаТоваровВДокументе.Серия
		|	
		|	) КАК ЗапросСЛимитами
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(
		|				,
		|				&ВсеСклады
		|					ИЛИ Склад В (&Склады)) КАК ТоварыНаСкладахОстатки
		|		ПО ЗапросСЛимитами.НоменклатураУчетная = ТоварыНаСкладахОстатки.Номенклатура						
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапросСЛимитами.Номенклатура,
		|	ЗапросСЛимитами.НоменклатураУчетная,
		|	ЗапросСЛимитами.Цена,
		|	ЗапросСЛимитами.Количество,
		|	ЗапросСЛимитами.НомерСтроки,
		|	ЗапросСЛимитами.ИдентификаторСтроки,
		|	ЗапросСЛимитами.Серия
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
		
		Если (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания = 2 или Шаблон.ПроверкаЗадания = 6)) тогда
			СерииВОтдельнойТЧ = Ложь;
