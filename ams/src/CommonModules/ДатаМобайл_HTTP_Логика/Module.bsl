	Запрос.УстановитьПараметр("ВсеСклады",СписокСкладов.Количество()=0);
	
	
	ЕстьЦены = Ложь;
	Попытка
		Для Каждого МетаРеквизитТЧ из Метаданные.Документы[ВидДокумента].ТабличныеЧасти[Шаблон.ИмяТабличнойЧастиПодбор].Реквизиты цикл
			Если МетаРеквизитТЧ.Имя = "Цена" Тогда
				ЕстьЦены = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Исключение
	КонецПопытки;
	
	Если ЕстьЦены тогда
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"&УсловиеЦенаПост","ТаблицаТоваровВДокументе.Цена");
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"&УсловиеЦенаПред","ТЧ_Товары.Цена");
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"&УсловиеЦена","ТаблицаТоваровВДокументе.Цена");
	Иначе
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"&УсловиеЦенаПост","0"); 
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"&УсловиеЦенаПред","0");
		Запрос.Текст=СтрЗаменить(Запрос.Текст,"&УсловиеЦена","0");
		
	КонецЕсли;
	
	Рез=Запрос.Выполнить().Выгрузить();
	
	Попытка
		ЕстьТЧМарок = СсылкаНаДок.ИсходныйДокумент.метаданные().ТабличныеЧасти.Найти("АкцизныеМарки") <> Неопределено;
		ЕстьРеквизитИдентификаторСтроки = СсылкаНаДок.ИсходныйДокумент.метаданные().ТабличныеЧасти[Шаблон.ИмяТабличнойЧастиПодбор].Реквизиты.Найти("КлючСвязи") <> Неопределено;
	Исключение
		ЕстьТЧМарок = Ложь;
		ЕстьРеквизитИдентификаторСтроки = Ложь;
	КонецПопытки;
	
	Для Каждого СтрокаДока из Рез цикл
		
		СтруктураТекущейСтроки = Новый Структура;			
		ОбъектТовара = ПолучитьСтруктуруОбъектаДляHttp("art","id");
		
		
		СписокМарок = ДатаМобайл_ОбщийМодуль.СформироватьСписокНепроверяемыхМарокЕГАИС(); 
		Если (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания = 3 или Шаблон.ПроверкаЗадания = 6)) тогда
			
			DMArtID = "8a-"+Строка(СтрокаДока.НоменклатураУчетная.УникальныйИдентификатор());	
			
		Иначе	
			НоменклатураЕГАИС = СтрокаДока.Номенклатура;
			Если НоменклатураЕГАИС.Пустая() и 
				(ВидДокумента = "РеализацияТоваровУслуг" 
				или ВидДокумента = "ЗаказКлиента" 
				или ВидДокумента = "ПеремещениеТоваров"
				или ВидДокумента = "ПересчетТоваров"
				или ВидДокумента = "СписаниеНедостачТоваров" 
				или ВидДокумента = "ОрдерНаОтражениеНедостачТоваров"
				или ВидДокумента = "ВозвратТоваровПоставщику"
				или ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад") тогда
				НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьЕГАИСПоНоменклатуре_ОПТ(СтрокаДока.НоменклатураУчетная);
			КонецЕсли;
			
			Если СписокМарок.НайтиПоЗначению(НоменклатураЕГАИС.ВидПродукции)<>Неопределено И НЕ НоменклатураЕГАИС.ВидПродукции.Пустая()  тогда
				лТекущаяНоменклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(НоменклатураЕГАИС);
				DMArtID = "8a-"+Строка(лТекущаяНоменклатура.УникальныйИдентификатор());
			Иначе	 
				DMArtID = "8e-"+Строка(НоменклатураЕГАИС.УникальныйИдентификатор());	
			КонецЕсли;
		КонецЕсли;
		
		ОбъектТовара.id = DMArtID;
		СтруктураТекущейСтроки.Вставить("art", ОбъектТовара);
		
		
		DMPrice=СтрокаДока.Цена;
		СтруктураТекущейСтроки.Вставить("price", DMPrice); 
		
		
		ТекущийИдентификаторСтроки = СтрокаДока.ИдентификаторСтроки;
		
		DMSN="";
		Если Шаблон.ПроверкаЗадания = 2 или Шаблон.ПроверкаЗадания = 6 или Шаблон.ПриПревышенииЗаданияПодбор=0 тогда //использование серий
			Если ВидДокумента = "РеализацияТоваровУслуг" 
				или ВидДокумента = "ЗаказКлиента" 
				или ВидДокумента = "ПеремещениеТоваров"
				или ВидДокумента = "ПересчетТоваров"
				или ВидДокумента = "СписаниеНедостачТоваров" 
				или ВидДокумента = "ОрдерНаОтражениеНедостачТоваров"
				или ВидДокумента = "ВозвратТоваровПоставщику"
				или ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад" 
				или (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания = 3 или Шаблон.ПроверкаЗадания = 6)) тогда
				
				Попытка Серия = СтрокаДока.Серия; Исключение Серия=""; КонецПопытки;   
				
			Иначе
				Серия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(СтрокаДока.СправкаБ);
			КонецЕсли;	
			Попытка DMSN = СокрЛП(ЧистаяСтрока(""+ Серия.Наименование)); Исключение DMSN=""; КонецПопытки;    
			
			Попытка
				Если ЗначениеЗаполнено(DMSN) Тогда
					sn = ПолучитьЗначениеСерии_EGAIS_ОПТ(УзелПО, СтрокаДока.Номенклатура, DMSN);
					СтруктураТекущейСтроки.Вставить("sn", sn);
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЕсли;
		
		Если УзелПО.НеОтображатьОстатки тогда
			limit_qty=0;
		Иначе	
			Итог = СтрокаДока.Лимит;
			limit_qty=Формат(Число(Итог),"ЧДЦ=2; ЧРД=.; ЧН=0; ЧГ=0");
		КонецЕсли; 
		СтруктураТекущейСтроки.Вставить("limit_qty", limit_qty);
		
		//Марки формат 3.0
		ВыгрузкаНовыйФормат = Ложь; 
		Если  ВидДокумента ="алкТоварноТранспортнаяНакладнаяЕГАИС" и ЕстьРеквизитИдентификаторСтроки и ЕстьТЧМарок тогда
			ВыгрузкаНовыйФормат = Истина; 
		КонецЕсли;	
		
		Если ВыгрузкаНовыйФормат тогда
			КоличествоБезМарок = СтрокаДока.Количество;
			
			ЗапросМарок = Новый Запрос;
			ЗапросМарок.Текст = "ВЫБРАТЬ
			|	ЕГАИС_ТТНДанныеМарок.КодАкцизнойМарки КАК Марка,
			|	1 КАК КоличествоМарок,
			|	ЕГАИС_ТТНДанныеМарок.НомерКоробки КАК Короб,
			|	ЕСТЬNULL(ЕГАИС_ТТНДанныеУпаковок.ИерархияУпаковки,"""") КАК Палета
			|ИЗ
			|	Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.АкцизныеМарки КАК ЕГАИС_ТТНДанныеМарок
			|	ЛЕВОЕ СОЕДИНЕНИЕ  Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Упаковки КАК ЕГАИС_ТТНДанныеУпаковок
			|	ПО ЕГАИС_ТТНДанныеМарок.Ссылка = ЕГАИС_ТТНДанныеУпаковок.Ссылка
			|	И ЕГАИС_ТТНДанныеУпаковок.Упаковка = ЕГАИС_ТТНДанныеМарок.НомерКоробки
			|ГДЕ
			|   ЕГАИС_ТТНДанныеМарок.Ссылка = &СсылкаТТН
			|	И ЕГАИС_ТТНДанныеМарок.КлючСвязи = &ТекущийИдентификаторСтроки
			|	И ЕстьNull(ЕГАИС_ТТНДанныеУпаковок.Упаковка, 0) <> ЕстьNull(ЕГАИС_ТТНДанныеУпаковок.ИерархияУпаковки, 1)
			|СГРУППИРОВАТЬ ПО
			|   ЕГАИС_ТТНДанныеМарок.КодАкцизнойМарки,
			|   ЕГАИС_ТТНДанныеМарок.НомерКоробки ,
			|   ЕСТЬNULL(ЕГАИС_ТТНДанныеУпаковок.ИерархияУпаковки,"""")";
			
			ЗапросМарок.Текст=СтрЗаменить(ЗапросМарок.Текст,".алкТоварноТранспортнаяНакладнаяЕГАИС.","."+ВидДокумента+".");
			Если ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") тогда
				Если Шаблон.ПроверкаЗадания = 5 тогда //выгрузка документа на ТСД без марок, только упаковки
					ЗапросМарок.Текст=СтрЗаменить(ЗапросМарок.Текст,"ЕГАИС_ТТНДанныеМарок.КодАкцизнойМарки КАК Марка,",""""" КАК Марка,");
					ЗапросМарок.Текст=СтрЗаменить(ЗапросМарок.Текст,"ЕГАИС_ТТНДанныеМарок.КодАкцизнойМарки,","");
					ЗапросМарок.Текст=СтрЗаменить(ЗапросМарок.Текст,"1 КАК КоличествоМарок","Количество(ЕГАИС_ТТНДанныеМарок.КодАкцизнойМарки) КАК КоличествоМарок");		
				КонецЕсли;
			КонецЕсли;
			
			ЗапросМарок.УстановитьПараметр("СсылкаТТН",СсылкаНаДок.ИсходныйДокумент);
			ЗапросМарок.УстановитьПараметр("ТекущийИдентификаторСтроки",ТекущийИдентификаторСтроки);
			
			РезМарок=ЗапросМарок.Выполнить().Выгрузить();
			Для Каждого СтрокаМарок из РезМарок цикл
				
				Если КоличествоБезМарок > 0 тогда    
					СтруктураТекущейСтрокиМарки = Новый Структура;
					
					
					Если ЗначениеЗаполнено(ОбъектТовара) Тогда
						СтруктураТекущейСтрокиМарки.Вставить("art", ОбъектТовара);
					КонецЕсли;
					
					qty = СтрокаМарок.КоличествоМарок;
					
					СтруктураТекущейСтрокиМарки.Вставить("limit_qty", limit_qty);
					СтруктураТекущейСтрокиМарки.Вставить("qty", qty);
					
					Если ЗначениеЗаполнено(DMSN) Тогда
						sn = ПолучитьЗначениеСерии_EGAIS_ОПТ(УзелПО, СтрокаДока.Номенклатура, DMSN);
						СтруктураТекущейСтрокиМарки.Вставить("sn", sn);
					КонецЕсли;
					
					ОбъектМаркировка = ПолучитьСтруктуруОбъектаДляHttp("marking");
					ОбъектМаркировка.mark = СтрокаМарок.Марка;
					
					Если ЗначениеЗаполнено(ОбъектМаркировка.mark) Тогда
						СтруктураТекущейСтрокиМарки.Вставить("marking", ОбъектМаркировка);
					КонецЕсли;
					
					Если ЗначениеЗаполнено(СтрокаМарок.Короб) Тогда 
						СтруктураТекущейСтрокиМарки.Вставить("box_pack", СтрокаМарок.Короб);
					КонецЕсли; 
					
					Если ЗначениеЗаполнено(СтрокаМарок.Палета) Тогда
						СтруктураТекущейСтрокиМарки.Вставить("pack", СтрокаМарок.Палета);
					КонецЕсли; 
					
					ОбъектСписка.Добавить(СтруктураТекущейСтрокиМарки);
					
					КоличествоБезМарок = КоличествоБезМарок-СтрокаМарок.КоличествоМарок;
				Иначе
					Продолжить;
				КонецЕсли;  
			КонецЦикла;
		КонецЕсли;
		
		Если ВыгрузкаНовыйФормат тогда
			Если КоличествоБезМарок>0 тогда
				qty = КоличествоБезМарок;      
				СтруктураТекущейСтроки.Вставить("qty", qty);
				ОбъектСписка.Добавить(СтруктураТекущейСтроки);
			КонецЕсли;	
		Иначе
			qty = СтрокаДока.Количество;
			СтруктураТекущейСтроки.Вставить("qty", qty);	
			ОбъектСписка.Добавить(СтруктураТекущейСтроки);
		КонецЕсли;
		
	КонецЦикла;   
	
	
	
	Возврат ПодготовитьОтветJSON(ОбъектСписка);	
	
КонецФункции 
Функция GetDocArts_EGAIS_ОПТ(SN, UserName, DocOutID, НомерПакета = "") Экспорт 
	
	ОбъектСписка = Новый Массив();		
	СтруктураОтвета = Новый Структура;
	
	УзелПО = НайтиУзел(SN);	
	Если УзелПО = Неопределено Тогда
		УзелПО = NewTSD(SN, UserName);
	КонецЕсли;  
	
	Попытка 
		СсылкаНаДок=ПолучитьДокументПоИдентификатору(DocOutID);
	Исключение	
		СтруктураОтвета.Вставить("Описание", "Не найден документ. ");	
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
	КонецПопытки;
	
	Если СсылкаНаДок.ПолучитьОбъект() = Неопределено Тогда		
		СтруктураОтвета.Вставить("Описание", "Не найден документ. ");		
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
	КонецЕсли;	  
	
	Шаблон = СсылкаНаДок.Шаблон;
	
	
	СписокМарок = Новый Массив();
	
	ЗапросТоваров = Новый Запрос;
	ЗапросТоваров.УстановитьПараметр("ТТН", СсылкаНаДок.ИсходныйДокумент);
	ЗапросТоваров.УстановитьПараметр("СписокНепроверяемыхМарок", СписокМарок); 
	
	ЗапросТоваров.Текст = "ВЫБРАТЬ
	|	ЕГАИС_ТТНТовары.АлкогольнаяПродукция КАК Номенклатура,
	|	СУММА(ЕГАИС_ТТНТовары.Количество) КАК Количество
	|ПОМЕСТИТЬ ТоварыВОсновании
	|ИЗ
	|	Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ЕГАИС_ТТНТовары
	|ГДЕ
	|	ЕГАИС_ТТНТовары.Ссылка = &ТТН
	|	И НЕ ЕГАИС_ТТНТовары.АлкогольнаяПродукция.ВидПродукции В (&СписокНепроверяемыхМарок)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕГАИС_ТТНТовары.АлкогольнаяПродукция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.Код, """") КАК Barcode,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.Производитель.Наименование, """") КАК Manufacturer,
	//|	ЕСТЬNULL(ЕГАИС_Номенклатура.Импортер.Наименование, """") КАК Importer,
	|	"""" КАК Importer,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.Объем, 0) КАК Capacity,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.Крепость, 0) КАК PercentAlco,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.ВидПродукции.Наименование, """") КАК TypeAlco,
	|	ЕСТЬNULL(ТоварыВОсновании.Количество, 0) КАК Quant,
	|	ЕСТЬNULL(ЕГАИС_Номенклатура.Наименование, """") КАК ArtName,
	|	ЕСТЬNULL(ТоварыВОсновании.Номенклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяССылка)) КАК ССылка
	|ИЗ
	|	ТоварыВОсновании КАК ТоварыВОсновании
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС КАК ЕГАИС_Номенклатура
	|		ПО ТоварыВОсновании.Номенклатура = ЕГАИС_Номенклатура.Ссылка";
	
	
	
	Если Шаблон.ВидДокумента = "ДатаМобайл_УпаковочныйЛист" или Шаблон.ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад" тогда 
		ЗапросТоваров.Текст=СтрЗаменить(ЗапросТоваров.Текст,"ТТНТовары.АлкогольнаяПродукция","ТТНТовары.ЕГАИС_Номенклатура");
	ИначеЕсли Шаблон.ВидДокумента = "алкАктФиксацииШтрихкодовНаБалансеОрганизацииЕГАИС" тогда 
		ЗапросТоваров.Текст=СтрЗаменить(ЗапросТоваров.Текст,"ЕГАИС_ТТНТовары.Количество","0");
	КонецЕсли;
	
	Если Шаблон.ВидДокумента = "РеализацияТоваровУслуг" 
		или Шаблон.ВидДокумента = "ЗаказКлиента" 
		или Шаблон.ВидДокумента = "ПеремещениеТоваров"
		или Шаблон.ВидДокумента = "ПересчетТоваров"
		или Шаблон.ВидДокумента = "СписаниеНедостачТоваров" 
		или Шаблон.ВидДокумента = "ОрдерНаОтражениеНедостачТоваров"
		или Шаблон.ВидДокумента = "ВозвратТоваровПоставщику"
		или (Шаблон.ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад" И (Шаблон.ПроверкаЗадания =3 или Шаблон.ПроверкаЗадания = 6)) 
		или (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания = 3 или Шаблон.ПроверкаЗадания = 6)) тогда 				  		
		ЗапросТоваров.Текст = "ВЫБРАТЬ
		|ЕСТЬNULL(СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция,ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяССылка)) КАК Номенклатура,
		|ЕГАИС_ТТНТовары.Номенклатура КАК НоменклатураУчетная
		|ПОМЕСТИТЬ ТоварыВОсновании
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК ЕГАИС_ТТНТовары
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.алкСоответствияАлкогольнойПродукцииЕГАИСИНоменклатуры КАК СоответствиеНоменклатурыЕГАИС
		|	ПО СоответствиеНоменклатурыЕГАИС.Номенклатура = ЕГАИС_ТТНТовары.Номенклатура И СоответствиеНоменклатурыЕГАИС.СерияНоменклатуры = ЕГАИС_ТТНТовары.Серия
		|	И НЕ СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция.ВидПродукции В (&СписокНепроверяемыхМарок)
		|ГДЕ
		|	ЕГАИС_ТТНТовары.Ссылка = &ТТН
		|
		|СГРУППИРОВАТЬ ПО
		|	ЕСТЬNULL(СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция,ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяССылка)),
		|	ЕГАИС_ТТНТовары.Номенклатура
		|	
		|ОБЪЕДИНИТЬ
		|	
		|	ВЫБРАТЬ
		|ЕСТЬNULL(СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция,ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяССылка)) КАК Номенклатура,
		|ЕГАИС_ТТНТовары.Номенклатура КАК НоменклатураУчетная
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК ЕГАИС_ТТНТовары
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.алкСоответствияАлкогольнойПродукцииЕГАИСИНоменклатуры КАК СоответствиеНоменклатурыЕГАИС
		|	ПО СоответствиеНоменклатурыЕГАИС.Номенклатура = ЕГАИС_ТТНТовары.Номенклатура
		|	И НЕ СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция.ВидПродукции В (&СписокНепроверяемыхМарок)
		|ГДЕ
		|	ЕГАИС_ТТНТовары.Ссылка = &ТТН
		|
		|СГРУППИРОВАТЬ ПО
		|	ЕСТЬNULL(СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция,ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяССылка)),
		|	ЕГАИС_ТТНТовары.Номенклатура 
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Код, """") КАК Barcode,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Производитель.Наименование, """") КАК Manufacturer,
		|	"""" КАК Importer,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Объем, 0) КАК Capacity,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Крепость, 0) КАК PercentAlco,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.ВидПродукции.Наименование, """") КАК TypeAlco,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Наименование, """") КАК ArtName,
		|	ТоварыВОсновании.Номенклатура КАК Ссылка,
		|	ТоварыВОсновании.НоменклатураУчетная КАК НоменклатураУчетная
		|ИЗ
		|	ТоварыВОсновании КАК ТоварыВОсновании
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС КАК ЕГАИС_Номенклатура
		|		ПО ТоварыВОсновании.Номенклатура = ЕГАИС_Номенклатура.Ссылка
		|ГДЕ НЕ ТоварыВОсновании.Номенклатура = ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяССылка)";						  
	КонецЕсли;		
	
	ЗапросТоваров.Текст=СтрЗаменить(ЗапросТоваров.Текст,".ЕГАИС_ТТН.","."+Шаблон.ВидДокумента+".");
	ЗапросТоваров.Текст=СтрЗаменить(ЗапросТоваров.Текст,".Товары КАК ","."+Шаблон.ИмяТабличнойЧастиПодбор+" КАК ");
	
	ЗапросТоваров.Текст=СтрЗаменить(ЗапросТоваров.Текст,".алкТоварноТранспортнаяНакладнаяЕГАИС.","."+Шаблон.ВидДокумента+".");
	ЗапросТоваров.Текст=СтрЗаменить(ЗапросТоваров.Текст,".Товары КАК ","."+Шаблон.ИмяТабличнойЧастиПодбор+" КАК ");
	
	ЗапросТоваров.Текст=СтрЗаменить(ЗапросТоваров.Текст,".РеализацияТоваровУслуг.","."+Шаблон.ВидДокумента+".");
	
	ВыборкаЕГАИС = ЗапросТоваров.Выполнить().Выбрать();
	Пока ВыборкаЕГАИС.Следующий() Цикл
		
		
		Если (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания = 3 или Шаблон.ПроверкаЗадания = 6)) тогда
			ArtID = "8a-"+Строка(ВыборкаЕГАИС.НоменклатураУчетная.УникальныйИдентификатор());	
			ArtName = ЧистаяСтрока(Лев(ВыборкаЕГАИС.НоменклатураУчетная.Наименование,100));
			
			ОбычнаяНоменклатура = ВыборкаЕГАИС.НоменклатураУчетная;
			Если УзелПО.ДобавлятьАртикулВНаименование и ЗначениеЗаполнено(ОбычнаяНоменклатура) тогда
				ArtName = ""+УдалитьЛидирующиеНули(ЧистаяСтрока(ОбычнаяНоменклатура.Артикул))+" "+ArtName;
			КонецЕсли;	
			
		Иначе
			НоменклатураЕГАИС = ВыборкаЕГАИС.Ссылка;
			Если НЕ ЗначениеЗаполнено(НоменклатураЕГАИС) и 
				(Шаблон.ВидДокумента = "РеализацияТоваровУслуг" 
				или Шаблон.ВидДокумента = "ЗаказКлиента" 
				или Шаблон.ВидДокумента = "ПеремещениеТоваров"
				или Шаблон.ВидДокумента = "ПересчетТоваров"
				или Шаблон.ВидДокумента = "СписаниеНедостачТоваров" 
				или Шаблон.ВидДокумента = "ОрдерНаОтражениеНедостачТоваров"
				или Шаблон.ВидДокумента = "ВозвратТоваровПоставщику"
				или Шаблон.ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад") тогда
				НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьЕГАИСПоНоменклатуре_ОПТ(ВыборкаЕГАИС.НоменклатураУчетная);
			КонецЕсли;	
			
			ArtID = "8e-"+Строка(НоменклатураЕГАИС.УникальныйИдентификатор());			
			ArtName = ЧистаяСтрока(Лев(НоменклатураЕГАИС.Наименование,100))   +" "+НоменклатураЕГАИС.Объем +"л. "+НоменклатураЕГАИС.Крепость+"%";
			
			ОбычнаяНоменклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(НоменклатураЕГАИС);				
			Если УзелПО.НаименованиеЕГАИС и ЗначениеЗаполнено(ОбычнаяНоменклатура) тогда
				ArtName = ЧистаяСтрока(ОбычнаяНоменклатура);
			КонецЕсли;
			
			Если УзелПО.ДобавлятьАртикулВНаименование и ЗначениеЗаполнено(ОбычнаяНоменклатура) тогда
				ArtName = ""+УдалитьЛидирующиеНули(ЧистаяСтрока(ОбычнаяНоменклатура.Артикул))+" "+ArtName;
			КонецЕсли;			
		КонецЕсли; 
		
		
		ОбъектТовара = ПолучитьСтруктуруОбъектаДляHttp("art");
		
		ОбъектТовара.id = ArtID;	
		ОбъектТовара.name = ArtName;	
		
		СформироватьЗаголовкиJSONParamsТовара_EGAIS_ОПТ(УзелПО,ОбъектТовара,ОбычнаяНоменклатура,Истина,Шаблон);
		
		ОбъектТовара.price = 0;
		ОбъектТовара.rest = 0;
		
		Если Не ЗначениеЗаполнено(ОбъектТовара.name) Или Не ЗначениеЗаполнено(ОбъектТовара.id) Тогда
			Продолжить;
		КонецЕсли;
		
		ОбъектСписка.Добавить(ОбъектТовара);
		
	КонецЦикла;
	
	
	Возврат ПодготовитьОтветJSON(ОбъектСписка);
	
КонецФункции
Функция OnArtMarkScan_EGAIS_ОПТ(Params, kiz = Неопределено, ТипОперации)
	
	ОбъектСписка = Новый Массив;
	СтруктураОтвета = Новый Структура;
	
	deviceId 		=  Params.device_id;
	UserName 		=  Params.username;
	KM_Barcode 		=  kiz.mark;
	KM_GTIN 		=  kiz.gtin;
	DocOutID 		=  Params.doc_id;
	Ячейка 			=  Params.cell_barcode;
	KM_SN 			=  kiz.sn;
	EAN 			=  kiz.ean;
	KM_RawBarcode 	=  kiz.raw_barcode;
	GS1 			=  Params.gs1;
	
	
	УзелПО = НайтиУзел(deviceId);
	Если УзелПО = Неопределено Тогда
		УзелПО = NewTSD(deviceId, UserName);
	КонецЕсли;
	
	Попытка
		СсылкаНаДок=ПолучитьДокументПоИдентификатору(DocOutID);
	Исключение		
		СтруктураОтвета.Вставить("Описание", "Не нашли документ. ");	
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
	КонецПопытки;
	
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	
	ЗначенияРеквизитовСсылкаНаДок = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДок, "ТСД, ДатаНачалаСбора, ДатаЗавершенияСбора, Шаблон, ИсходныйДокумент, Склад");
	
	ДокТСД 						= ЗначенияРеквизитовСсылкаНаДок.ТСД;
	ДокДатаНачалаСбора 			= ЗначенияРеквизитовСсылкаНаДок.ДатаНачалаСбора;
	ДокДатаЗавершенияСбора 		= ЗначенияРеквизитовСсылкаНаДок.ДатаЗавершенияСбора;
	Шаблон 						= ЗначенияРеквизитовСсылкаНаДок.Шаблон;
	ИсходныйДокумент 			= ЗначенияРеквизитовСсылкаНаДок.ИсходныйДокумент;
	Склад  						= ЗначенияРеквизитовСсылкаНаДок.Склад;
	
	Если ЗначениеЗаполнено(Ячейка) Тогда
		ТекущаяЯчейкаСсылка = ДатаМобайл_ОбщийМодуль.ПолучитьЯчейкуПоКодуИлиШтрихкоду(Ячейка, СсылкаНаДок);
	Иначе
		ТекущаяЯчейкаСсылка = Неопределено;
	КонецЕсли; 	
	
	Если Шаблон = Неопределено Тогда	
		СтруктураОтвета.Вставить("Описание", "Не нашли запись документа. ");	
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокТСД) Тогда
		Если ДокТСД <> УзелПО Тогда		
			СтруктураОтвета.Вставить("Описание", "Чужой документ. ");		
			Возврат ПодготовитьОтветJSON(, СтруктураОтвета);		
		КонецЕсли;	
	КонецЕсли;
	
	Если ДокДатаЗавершенияСбора <> Дата(1,1,1) Тогда		
		СтруктураОтвета.Вставить("Описание", "Закрытый документ. ");	
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
	КонецЕсли;
	
	
	Если НЕ (СтрДлина(KM_Barcode) = 68 или СтрДлина(KM_Barcode) = 150) тогда  // формат марки
		Возврат ПодготовитьОтветJSON(ОбъектСписка);
	КонецЕсли;
	
	
	Если Шаблон.ПроверкаЗадания = 5 тогда // проверка отсканирован ли короб с такой маркой 
		Если БылоСканированиеКоробаСТакойМаркой_EGAIS_ОПТ(СсылкаНаДок, KM_Barcode, Шаблон) Тогда
			СтруктураОтвета.Вставить("Описание", "Марка была ранее отсканирована в коробе. ");
			Возврат ПодготовитьОтветJSON(, СтруктураОтвета);	
		КонецЕсли;
		
		//Если ЗначениеЗаполнено(BarcodeBox) Тогда
		//	Если БылоСканированиеКоробаКоторыйНеСоответстввуетМарке_EGAIS_ОПТ(СсылкаНаДок, PDFBarcode, Шаблон, BarcodeBox) Тогда
		//		СтруктураОтвета.Вставить("Описание", "Марка числится в другом коробе. ");
		//		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
		//	КонецЕсли;	
		//КонецЕсли;
	КонецЕсли; 
	
	Если Шаблон.ПроверкаМарки = 1 тогда // уникальность марки в базе			
		Если ПолучитьСостояниеАкцизнойМарки_EGAIS_ОПТ(KM_Barcode)<>Неопределено  тогда
			СтруктураОтвета.Вставить("Описание", "В регистре уже зарегистрирована данная марка, запись невозможна. ");
			Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
		Иначе 
			Если БылоСканированиеМаркиВЭтомДокументе_EGAIS_ОПТ(KM_Barcode, СсылкаНаДок, Шаблон) тогда
				СтруктураОтвета.Вставить("Описание", "В базе уже зарегистрирована данная марка, запись невозможна. ");
				Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
			КонецЕсли;	
		КонецЕсли;
	ИначеЕсли Шаблон.ПроверкаМарки = 2 тогда // ОтметкаВыбытия
		ТекущууСостояниеМарки=ПолучитьСостояниеАкцизнойМарки_EGAIS_ОПТ(KM_Barcode);
		Если ТекущууСостояниеМарки<>Неопределено  тогда
			Если ТекущууСостояниеМарки.ОтметкаВыбытия Тогда                                                    
				СтруктураОтвета.Вставить("Описание", "Марка числится как выбывшая, запись невозможна. ");
				Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
			КонецЕсли;	
		Иначе 
			Если БылоСканированиеМаркиВЭтомТипеДокумента_EGAIS_ОПТ(KM_Barcode,СсылкаНаДок,Шаблон) тогда
				СтруктураОтвета.Вставить("Описание", "Марка уже отсканирована в другом документе, запись невозможна. ");
				Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
			КонецЕсли;	
		КонецЕсли;
	ИначеЕсли Шаблон.ПроверкаМарки = 3 Тогда //проверка выбытия при возврате от клиента
		
		ТекущееСостояниеМарки = ПолучитьСостояниеАкцизнойМарки_EGAIS_ОПТ(KM_Barcode);
		
		Если ТекущееСостояниеМарки = Неопределено Тогда
			СтруктураОтвета.Вставить("Описание", "Марка не числится как выбывшая. Возврат не возможен");
			Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
		КонецЕсли;
		
		Если НЕ ТекущееСостояниеМарки.ОтметкаВыбытия Тогда
			СтруктураОтвета.Вставить("Описание", "Марка не числится как выбывшая. Возврат не возможен");
			Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
		КонецЕсли;
	КонецЕсли;
	
	
	
	Если стрДлина(KM_Barcode)=68 Тогда	
		Алкокод=КодНоменклатурыЕГАИСПоPDF417(KM_Barcode);
		
		ЗапросЕГАИС = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЕГАИС_Номенклатура.Ссылка,
		|	ЕГАИС_Номенклатура.Код КАК Алкокод,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Наименование, """") КАК ArtName,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Производитель.Наименование, """") КАК Manufacturer,
		//|	ЕСТЬNULL(ЕГАИС_Номенклатура.Импортер.Наименование, """") КАК Importer,
		|	"""" КАК Importer,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Объем, 0) КАК Capacity,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.Крепость, 0) КАК PercentAlco,
		|	ЕСТЬNULL(ЕГАИС_Номенклатура.ВидПродукции.Наименование, """") КАК TypeAlco
		|ИЗ
		|	Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС КАК ЕГАИС_Номенклатура
		|ГДЕ
		|	ЕГАИС_Номенклатура.Код = &Код
		|	И НЕ ЕГАИС_Номенклатура.ПометкаУдаления");
		ЗапросЕГАИС.УстановитьПараметр("Код", Алкокод);
		
	ИначеЕсли стрДлина(KM_Barcode) = 150 Тогда	  //Новые марки
		
		//во входящей ттн упаковки смотрим в самом доке
		ЭтоВходящаяТТН = Ложь;
		Если  Шаблон.ВидДокумента = "алкТоварноТранспортнаяНакладнаяЕГАИС" тогда
			Если СсылкаНаДок.ИсходныйДокумент.ВидДокумента = Перечисления.алкВидыДокументовЕГАИС.Входящий тогда
				ЭтоВходящаяТТН = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если ЭтоВходящаяТТН тогда
			
			ЗапросЕГАИС = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЕстьNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция,ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяСсылка)) КАК Ссылка,
			|	ЕстьNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Код, """")  КАК Алкокод,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Наименование, """") КАК ArtName,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Производитель.Наименование, """") КАК Manufacturer,
			//|	ЕСТЬNULL(ЕГАИС_Номенклатура.Импортер.Наименование, """") КАК Importer,
			|	"""" КАК Importer,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Объем, 0) КАК Capacity,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Крепость, 0) КАК PercentAlco,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.ВидПродукции.Наименование, """") КАК TypeAlco			
			|ИЗ
			|	Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.АкцизныеМарки КАК ЕГАИС_Марки
			|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ЕГАИС_Номенклатура
			|		ПО ЕГАИС_Марки.КлючСвязи = ЕГАИС_Номенклатура.КлючСвязи
			|		И ЕГАИС_Марки.Ссылка = ЕГАИС_Номенклатура.Ссылка
			|ГДЕ
			|   ЕГАИС_Марки.Ссылка = &СсылкаНаТТН И ЕГАИС_Номенклатура.Ссылка = &СсылкаНаТТН 
			|   И ЕГАИС_Марки.КодАкцизнойМарки = &Код
			|   И НЕ ЕГАИС_Номенклатура.АлкогольнаяПродукция ЕСТЬ NULL");
			
			ЗапросЕГАИС.УстановитьПараметр("Код", KM_Barcode);
			ЗапросЕГАИС.УстановитьПараметр("СсылкаНаТТН", СсылкаНаДок.ИсходныйДокумент);
			
			
		Иначе	
			ЗапросЕГАИС = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
			|	ЕГАИС_Номенклатура.АлкогольнаяПродукция.Ссылка КАК Ссылка,
			|	ЕГАИС_Номенклатура.АлкогольнаяПродукция.Код КАК Алкокод,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Наименование, """") КАК ArtName,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Производитель.Наименование, """") КАК Manufacturer,
			//|	ЕСТЬNULL(ЕГАИС_Номенклатура.Импортер.Наименование, """") КАК Importer,
			|	"""" КАК Importer,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Объем, 0) КАК Capacity,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.Крепость, 0) КАК PercentAlco,
			|	ЕСТЬNULL(ЕГАИС_Номенклатура.АлкогольнаяПродукция.ВидПродукции.Наименование, """") КАК TypeAlco
			|ИЗ
			|	РегистрСведений.алкХранилищеАкцизныхМарок КАК ЕГАИС_Номенклатура
			|ГДЕ
			|	ЕГАИС_Номенклатура.Марка = &Код
			|	И НЕ ЕГАИС_Номенклатура.АлкогольнаяПродукция.ПометкаУдаления");
			ЗапросЕГАИС.УстановитьПараметр("Код", KM_Barcode);
		КонецЕсли;
		
	КонецЕсли;
	
	ВыборкаЕГАИС = ЗапросЕГАИС.Выполнить().Выбрать();
	
	Пока ВыборкаЕГАИС.Следующий() Цикл
		
		СтруктураТекущейСтроки = Новый Структура;
		ОбъектТовара = ПолучитьСтруктуруОбъектаДляHttp("art","scan");
		
		Если (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания = 3 или Шаблон.ПроверкаЗадания = 6)) тогда
			УчетнаяНоменклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(ВыборкаЕГАИС.Ссылка,KM_Barcode);
			ARtID = "8a-"+Строка(УчетнаяНоменклатура.УникальныйИдентификатор());
			ArtName = ЧистаяСтрока(Лев(УчетнаяНоменклатура.Наименование,100));
			
			ОбычнаяНоменклатура = УчетнаяНоменклатура;
			Если УзелПО.ДобавлятьАртикулВНаименование и ЗначениеЗаполнено(ОбычнаяНоменклатура)  тогда
				ArtName = ""+УдалитьЛидирующиеНули(ЧистаяСтрока(ОбычнаяНоменклатура.Артикул))+" "+ArtName;
			КонецЕсли;
			
		Иначе
			
			ARtID = "8e-"+Строка(ВыборкаЕГАИС.Ссылка.УникальныйИдентификатор());
			ArtName = ЧистаяСтрока(Лев(ВыборкаЕГАИС.Ссылка.Наименование,100))   +" "+ВыборкаЕГАИС.Ссылка.Объем +"л. "+ВыборкаЕГАИС.Ссылка.Крепость+"%";
			
			ОбычнаяНоменклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(ВыборкаЕГАИС.Ссылка,KM_Barcode);		
			Если УзелПО.НаименованиеЕГАИС и ЗначениеЗаполнено(ОбычнаяНоменклатура)  тогда
				ArtName = ЧистаяСтрока(ОбычнаяНоменклатура);
			КонецЕсли;
			
			Если УзелПО.ДобавлятьАртикулВНаименование и ЗначениеЗаполнено(ОбычнаяНоменклатура)  тогда
				ArtName = ""+УдалитьЛидирующиеНули(ЧистаяСтрока(ОбычнаяНоменклатура.Артикул))+" "+ArtName;
			КонецЕсли;
		КонецЕсли; 
		
		ОбъектТовара.name 	   = ArtName;
		ОбъектТовара.id 	   = ARtID;
		ОбъектТовара.price 	   = 0;
		
		СформироватьЗаголовкиJSONParamsТовара_EGAIS_ОПТ(УзелПО,ОбъектТовара,ОбычнаяНоменклатура,Истина,Шаблон);  
		
		СтруктураТекущейСтроки.Вставить("art", ОбъектТовара);
		
		Если Шаблон.ПроверкаЗадания = 2 или Шаблон.ПроверкаЗадания = 6 тогда //использование серий
			ДанныеНоменклатурыПоМарке = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруАкцизнойМарки(KM_Barcode);
			Если ДанныеНоменклатурыПоМарке.Количество()>0 тогда
				
				ЕстьОшибки = Ложь;
				ПроверитьДанныеНоменклатурыПоРеализации_EGAIS_ОПТ(СсылкаНаДок.ИсходныйДокумент, ДанныеНоменклатурыПоМарке, ArtName, ЕстьОшибки);	
				Если ЕстьОшибки Тогда  
					СтруктураОтвета.Вставить("Описание", "Номенклатура " + Строка(ArtName) + " не найдена в задании. Возможно проблема с сопоставлением");
					Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
				КонецЕсли;
				
				СправкаА = ДанныеНоменклатурыПоМарке[0].СправкаА;
				СправкаБ = ДанныеНоменклатурыПоМарке[0].СправкаБ;
				Серия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(СправкаБ, Истина);
				
				СерияСсылка = Серия[0].Серия;
				
				Попытка
					Для каждого СтрокаСерия Из Серия Цикл
						СтруктураОтбора = Новый Структура;
						СтруктураОтбора.Вставить("Номенклатура", ДанныеНоменклатурыПоМарке[0].Номенклатура);
						СтруктураОтбора.Вставить("Серия", СтрокаСерия.Серия);
						
						ПоискПоТЧТовары = СсылкаНаДок.ИсходныйДокумент.Товары.НайтиСтроки(СтруктураОтбора);
						
						Если ПоискПоТЧТовары.Количество() > 0 Тогда
							СерияСсылка = СтрокаСерия.Серия;
						Иначе
							ПоискПоТЧСерии = СсылкаНаДок.ИсходныйДокумент.Серии.НайтиСтроки(СтруктураОтбора);
							Если ПоискПоТЧСерии.Количество() > 0 Тогда
								СерияСсылка = СтрокаСерия.Серия;
								Прервать;
							КонецЕсли;
						КонецЕсли;						
					КонецЦикла;
				Исключение
					СерияСсылка = Серия[0].Серия;
				КонецПопытки;
				
				DMSN = СокрЛП(ЧистаяСтрока(""+ СерияСсылка.Наименование)); 
				
				Попытка
					Если ЗначениеЗаполнено(DMSN) Тогда 
						sn = ПолучитьЗначениеСерии_EGAIS_ОПТ(УзелПО, ВыборкаЕГАИС.Ссылка, DMSN);
						СтруктураТекущейСтроки.Вставить("sn", sn);
					КонецЕсли;	
				Исключение
				КонецПопытки;
				
			КонецЕсли;
		КонецЕсли;
		
		limit_qty = 0;		
		СтруктураТекущейСтроки.Вставить("limit_qty", limit_qty); 
		
		Если СокрЛП(ЧистаяСтрока(ОбъектТовара.name)) = "" Или СокрЛП(ЧистаяСтрока(ОбъектТовара.id)) = "" Тогда
			Продолжить;
		КонецЕсли;
		
		ОбъектСписка.Добавить(СтруктураТекущейСтроки);
	КонецЦикла;
	
	
	//ЗАПИСЬ	
	Если Не Шаблон.ГрупповаяРабота Тогда
		//ОБЫЧНАЯ ЛОГИКА
		Если Не ЗначениеЗаполнено(ДокДатаНачалаСбора) Или Не ЗначениеЗаполнено(ДокТСД) Тогда
			
			Попытка
				Объект = СсылкаНаДок.ПолучитьОбъект();
				Объект.ДатаНачалаСбора = ТекущаяДата();
				Объект.ТСД = УзелПО;
				
				Объект.Записать();
				
				//УДАЛЕНИЕ РЕГИСТРАЦИИ ДАННОГО ДОКУМЕНТА НА ДАННОМ УЗЛЕ 
				ДатаМобайл_ОбщийМодуль.УдалитьРегистрациюОбъекта(Объект, Ложь);
			Исключение
			КонецПопытки;
		КонецЕсли;
		
	Иначе
		//ГРУППОВОЙ ДОКУМЕНТ
		
		ДатаСбораПоТСД = ДатаМобайл_ОбщийМодуль.ПолучитьДатуГрупповогоДокумента(deviceId, СсылкаНаДок, "ДатаНачалаСбора");	
		Если Не ЗначениеЗаполнено(ДатаСбораПоТСД) Тогда	
			ДатаМобайл_ОбщийМодуль.СоздатьНачальнуюЗаписьТСДГрупповыхДокументов(deviceId, СсылкаНаДок, UserName);		
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ДокДатаНачалаСбора) Тогда
			Попытка
				Объект = СсылкаНаДок.ПолучитьОбъект();
				Объект.ДатаНачалаСбора = ТекущаяДата();
				
				Объект.Записать();
			Исключение
			КонецПопытки;	
		КонецЕсли;
	КонецЕсли;	
	
	Возврат ПодготовитьОтветJSON(ОбъектСписка);
	
КонецФункции   
Функция OnPalletScan_EGAIS_ОПТ(SN, UserName, Barcode, DocOutID, Cell, gs1) Экспорт 
	
	ОбъектСписка = Новый Массив; 
	СтруктураОтвета = Новый Структура;
	
	УзелПО = НайтиУзел(SN);
	Если УзелПО = Неопределено Тогда
		УзелПО = NewTSD(SN, UserName);
	КонецЕсли;	
	
	Попытка
		СсылкаНаДок=ПолучитьДокументПоИдентификатору(DocOutID);
	Исключение		
		СтруктураОтвета.Вставить("Описание", "Не нашли документ.");	
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
	КонецПопытки;
	
	Если СсылкаНаДок.ПолучитьОбъект() = Неопределено Тогда		
		СтруктураОтвета.Вставить("Описание", "Не нашли документ.");		
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
	КонецЕсли;	
	
	Если Не СсылкаНаДок.ТСД.Пустая() Тогда
		Если СсылкаНаДок.ТСД <> УзелПО Тогда			
			СтруктураОтвета.Вставить("Описание", "Чужой документ.");		
			Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
		КонецЕсли;	
	КонецЕсли;	
	
	Если СсылкаНаДок.ДатаЗавершенияСбора <> Дата(1,1,1) Тогда	
		СтруктураОтвета.Вставить("Описание", "Закрытый документ.");	
		Возврат ПодготовитьОтветJSON(, СтруктураОтвета);	
	КонецЕсли;	
	
	Шаблон = СсылкаНаДок.Шаблон;	
	
	Если ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И Шаблон.ЗапретСканированияУпаковок Тогда
		Возврат ПодготовитьОтветJSON(ОбъектСписка);	
	КонецЕсли;
	
	ЭтоВыборочнаяПроверка = Шаблон.ИспользоватьВыборочнуюПроверку;
	Barcode = СокрЛП(Barcode);
	
	Если Лев(Barcode,3) = "UPL" тогда		
		ТЗМарок = ДатаМобайл_ОбщийМодуль.ПолучитьТаблицуУпакованногоТовара_УпаковочногоЛиста(Barcode);
		
		Для Каждого СтрокаДока ИЗ ТЗМарок Цикл	
			
			СтруктураТекущейСтроки = Новый Структура;
			ОбъектТовара = ПолучитьСтруктуруОбъектаДляHttp("art","scan"); 
			
			Если (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания = 3 или Шаблон.ПроверкаЗадания = 6)) тогда
				
				УчетнаяНоменклатура = СтрокаДока.Номенклатура;
				DMArtID = "8a-"+Строка(УчетнаяНоменклатура.УникальныйИдентификатор());
				DMArtName = ЧистаяСтрока(Лев(УчетнаяНоменклатура.Наименование,100));
				
				ОбычнаяНоменклатура = УчетнаяНоменклатура;
				Если УзелПО.ДобавлятьАртикулВНаименование и ЗначениеЗаполнено(ОбычнаяНоменклатура) тогда
					DMArtName = ""+УдалитьЛидирующиеНули(ЧистаяСтрока(ОбычнаяНоменклатура.Артикул))+" "+DMArtName;
				КонецЕсли;
			Иначе
				DMArtID = "8e-"+Строка(СтрокаДока.АлкогольнаяПродукция.УникальныйИдентификатор());	
				DMArtName= ЧистаяСтрока(Лев(СтрокаДока.АлкогольнаяПродукция.Наименование,100))   +" "+СтрокаДока.АлкогольнаяПродукция.Объем +"л. "+СтрокаДока.АлкогольнаяПродукция.Крепость+"%";
				
				ОбычнаяНоменклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(СтрокаДока.АлкогольнаяПродукция);
				Если УзелПО.НаименованиеЕГАИС и ЗначениеЗаполнено(ОбычнаяНоменклатура) тогда	
					DMArtName = ЧистаяСтрока(ОбычнаяНоменклатура);					
				КонецЕсли;
				
				Если УзелПО.ДобавлятьАртикулВНаименование и ЗначениеЗаполнено(ОбычнаяНоменклатура) тогда	
					DMArtName = ""+УдалитьЛидирующиеНули(ЧистаяСтрока(ОбычнаяНоменклатура.Артикул))+" "+DMArtName;
				КонецЕсли;	
			КонецЕсли;  
			
			ОбъектТовара.name = DMArtName;				
			ОбъектТовара.id = DMArtID;
			
			СформироватьЗаголовкиJSONParamsТовара_EGAIS_ОПТ(УзелПО,ОбъектТовара,ОбычнаяНоменклатура,Истина,Шаблон);			
			
			СтруктураТекущейСтроки.Вставить("art", ОбъектТовара);
			
			limit_qty = 0;
			qty = СтрокаДока.Количество;
			
			СтруктураТекущейСтроки.Вставить("limit_qty", limit_qty);
			СтруктураТекущейСтроки.Вставить("qty", qty);
			
			Если ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") тогда
				Если Шаблон.ПроверкаЗадания = 2 или Шаблон.ПроверкаЗадания = 6 тогда //использование серий
					Серия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(СтрокаДока.СправкаБ);
					
					DMSN = СокрЛП(ЧистаяСтрока(""+ Серия.Наименование)); 
					
					Попытка
						Если ЗначениеЗаполнено(DMSN) Тогда 
							sn = ПолучитьЗначениеСерии_EGAIS_ОПТ(УзелПО, СтрокаДока.АлкогольнаяПродукция, DMSN);
							СтруктураТекущейСтроки.Вставить("sn", sn);
						КонецЕсли;	
					Исключение
					КонецПопытки;
				КонецЕсли;
			КонецЕсли;
			
			
			СтруктураТекущейСтроки.Вставить("pack", Barcode);
			
			ОбъектСписка.Добавить(СтруктураТекущейСтроки);			
		КонецЦикла;
		
		Возврат ПодготовитьОтветJSON(ОбъектСписка);
	КонецЕсли;
	
	
	ЭтоВыборочнаяПроверка = Шаблон.ИспользоватьВыборочнуюПроверку;
	
	Если ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") тогда	
		
		//ПРОВЕРКА УНИКАЛЬНОСТИ УПАКОВКИ 
		лЭтоКороб = ДатаМобайл_ОбщийМодуль.ПроверитьУпаковочныйлистЭтоКороб(Barcode);	
		Если БылоСканированиеУпаковкиВЭтомДокументе_EGAIS_ОПТ(Barcode,СсылкаНаДок,Шаблон) тогда
			СтруктураОтвета.Вставить("Описание", "Упаковка уже отсканирована в документе, запись невозможна. ");
			Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
		КонецЕсли;
		
		Если БылоСканированиеУпаковкиВСоставеДругойВЭтомДокументе_EGAIS_ОПТ(Barcode,СсылкаНаДок,Шаблон) и лЭтоКороб и Шаблон.ИспользованиеУпаковочныхЛистовПодбор=0 тогда
			СтруктураОтвета.Вставить("Описание", "Упаковка уже отсканирована в документе, запись невозможна. ");
			Возврат ПодготовитьОтветJSON(, СтруктураОтвета);			
		КонецЕсли;
		
		//ДОПОЛНИТЕЛЬНЫЕ ПРОВЕРКИ УПАКОВКИ	
		Если Шаблон.ПроверкаМарки = 2 тогда // ОтметкаВыбытия
			Если БылоСканированиеУпаковкиВЭтомТипеДокумента_EGAIS_ОПТ(Barcode,СсылкаНаДок,Шаблон) тогда
				СтруктураОтвета.Вставить("Описание", "Упаковка уже отсканирована в другом документе, запись невозможна.");
				Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
			КонецЕсли;
			
			Если БылоСканированиеУпаковкиВСоставеДругойВЭтомТипеДокумента_EGAIS_ОПТ(Barcode,СсылкаНаДок,Шаблон) и лЭтоКороб тогда
				СтруктураОтвета.Вставить("Описание", "Упаковка уже отсканирована в документе, запись невозможна. ");
				Возврат ПодготовитьОтветJSON(, СтруктураОтвета);			
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	
	Если (Шаблон.ИспользованиеУпаковочныхЛистовПодбор=3 и ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС")) или
		(Шаблон.ИспользованиеУпаковочныхЛистовПодбор=5 и ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС")) или
		(Шаблон.ИспользованиеУпаковочныхЛистовПодбор=3 и ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов")) тогда //агрегация и выемка марок
		
		ТЗМарок = ДатаМобайл_ОбщийМодуль.ПолучитьТаблицуУпакованныхМарок(Barcode);
		Для Каждого СтрокаДока ИЗ ТЗМарок Цикл							
			
			СтруктураТекущейСтроки = Новый Структура;
			ОбъектТовара = ПолучитьСтруктуруОбъектаДляHttp("art","scan"); 
			
			DMArtName= ЧистаяСтрока(Лев(СтрокаДока.АлкогольнаяПродукция.Наименование,100))   +" "+СтрокаДока.АлкогольнаяПродукция.Объем +"л. "+СтрокаДока.АлкогольнаяПродукция.Крепость+"%";
			DMArtID = "8e-"+Строка(СтрокаДока.АлкогольнаяПродукция.УникальныйИдентификатор());	
			
			ОбъектТовара.name = DMArtName;				
			ОбъектТовара.id = DMArtID;
			
			СформироватьЗаголовкиJSONParamsТовара_EGAIS_ОПТ(УзелПО,ОбъектТовара,СтрокаДока.АлкогольнаяПродукция,Истина,Шаблон);			
			
			СтруктураТекущейСтроки.Вставить("art", ОбъектТовара);
			
			limit_qty = 0;		
			qty = 1;
			
			СтруктураТекущейСтроки.Вставить("limit_qty", limit_qty);
			СтруктураТекущейСтроки.Вставить("qty", qty);
			
			Если ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") тогда
				Если Шаблон.ПроверкаЗадания = 2 или Шаблон.ПроверкаЗадания = 6 тогда //использование серий
					ДанныеНоменклатурыПоМарке = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруАкцизнойМарки(СтрокаДока.Марка);
					Если ДанныеНоменклатурыПоМарке.Количество()>0 тогда
						
						ЕстьОшибки = Ложь;
						ПроверитьДанныеНоменклатурыПоРеализации_EGAIS_ОПТ(СсылкаНаДок.ИсходныйДокумент, ДанныеНоменклатурыПоМарке, DMArtName, ЕстьОшибки);
						Если ЕстьОшибки Тогда  
							СтруктураОтвета.Вставить("Описание", "Номенклатура " + Строка(DMArtName) + " не найдена в задании. Возможно проблема с сопоставлением");
							Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
						КонецЕсли;
						
						СправкаА = ДанныеНоменклатурыПоМарке[0].СправкаА;
						СправкаБ = ДанныеНоменклатурыПоМарке[0].СправкаБ;
						Серия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(СправкаБ);
						
						DMSN = СокрЛП(ЧистаяСтрока(""+ Серия.Наименование));
						
						Попытка
							Если ЗначениеЗаполнено(DMSN) Тогда
								sn = ПолучитьЗначениеСерии_EGAIS_ОПТ(УзелПО, СтрокаДока.АлкогольнаяПродукция, DMSN);
								СтруктураТекущейСтроки.Вставить("sn", sn);
							КонецЕсли;	
						Исключение
						КонецПопытки;
						
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			ОбъектМаркировка = ПолучитьСтруктуруОбъектаДляHttp("marking");
			ОбъектМаркировка.mark = СтрокаДока.Марка;	
			
			Если ЗначениеЗаполнено(ОбъектМаркировка.mark) Тогда
				СтруктураТекущейСтроки.Вставить("marking", ОбъектМаркировка);
			КонецЕсли;
			
			ОбъектСписка.Добавить(СтруктураТекущейСтроки);			
			
		КонецЦикла;		
	Иначе
		
		Если ЭтоВыборочнаяПроверка И НЕ лЭтоКороб Тогда
			ТЗМарок = ДатаМобайл_ОбщийМодуль.ПолучитьТаблицуКоличестваМарок(Barcode);   
		Иначе
			ТЗМарок = ДатаМобайл_ОбщийМодуль.ПолучитьТаблицуКоличестваМарок(Barcode,Ложь,лЭтоКороб);
		КонецЕсли;
		
		Для Каждого СтрокаДока ИЗ ТЗМарок Цикл	
			
			
			СтруктураТекущейСтроки = Новый Структура;
			ОбъектТовара = ПолучитьСтруктуруОбъектаДляHttp("art","scan");  
			
			Если (ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") И (Шаблон.ПроверкаЗадания = 3 или Шаблон.ПроверкаЗадания = 6)) тогда
				Серия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(СтрокаДока.СправкаБ);
				Попытка УчетнаяНоменклатура = Серия.алкВладелец; Исключение УчетнаяНоменклатура = Справочники.Номенклатура.ПустаяСсылка(); КонецПопытки;
				Если УчетнаяНоменклатура.Пустая() тогда
					УчетнаяНоменклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(СтрокаДока.АлкогольнаяПродукция);
				КонецЕсли;	
				DMArtID = "8a-"+Строка(УчетнаяНоменклатура.УникальныйИдентификатор());
				DMArtName = ЧистаяСтрока(Лев(УчетнаяНоменклатура.Наименование,100));
				
				ОбычнаяНоменклатура = УчетнаяНоменклатура;
				Если УзелПО.ДобавлятьАртикулВНаименование и ЗначениеЗаполнено(ОбычнаяНоменклатура) тогда
					DMArtName = ""+УдалитьЛидирующиеНули(ЧистаяСтрока(ОбычнаяНоменклатура.Артикул))+" "+DMArtName;
				КонецЕсли;
				
			Иначе
				DMArtID = "8e-"+Строка(СтрокаДока.АлкогольнаяПродукция.УникальныйИдентификатор());	
				DMArtName= ЧистаяСтрока(Лев(СтрокаДока.АлкогольнаяПродукция.Наименование,100))   +" "+СтрокаДока.АлкогольнаяПродукция.Объем +"л. "+СтрокаДока.АлкогольнаяПродукция.Крепость+"%";
				
				ОбычнаяНоменклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(СтрокаДока.АлкогольнаяПродукция);
				
				Если УзелПО.НаименованиеЕГАИС И ЗначениеЗаполнено(ОбычнаяНоменклатура) Тогда
					DMArtName = ЧистаяСтрока(ОбычнаяНоменклатура);
				КонецЕсли;
				
				Если УзелПО.ДобавлятьАртикулВНаименование И ЗначениеЗаполнено(ОбычнаяНоменклатура) Тогда
					DMArtName = ""+УдалитьЛидирующиеНули(ЧистаяСтрока(ОбычнаяНоменклатура.Артикул))+" "+DMArtName;
				КонецЕсли;
				
			КонецЕсли; 
			
			ОбъектТовара.name = DMArtName;				
			ОбъектТовара.id = DMArtID;
			
			СформироватьЗаголовкиJSONParamsТовара_EGAIS_ОПТ(УзелПО,ОбъектТовара,ОбычнаяНоменклатура,Истина,Шаблон);			
			
			СтруктураТекущейСтроки.Вставить("art", ОбъектТовара);
			
			limit_qty = 0;		
			qty = СтрокаДока.Количество;
			
			СтруктураТекущейСтроки.Вставить("limit_qty", limit_qty);
			СтруктураТекущейСтроки.Вставить("qty", qty);
			
			
			Если ТипЗнч(Шаблон) = Тип("СправочникСсылка.ДатаМобайл_ШаблоныДокументов_ЕГАИС") тогда 
				Если Шаблон.ПроверкаЗадания = 2 или Шаблон.ПроверкаЗадания = 6 тогда //использование серий
					
					ДанныеНоменклатурыПоМарке = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(СтрокаДока.АлкогольнаяПродукция, , Истина);
					
					Если ДанныеНоменклатурыПоМарке.Количество()>0 тогда 
						ЕстьОшибки = Ложь;
						ПроверитьДанныеНоменклатурыПоРеализации_EGAIS_ОПТ(СсылкаНаДок.ИсходныйДокумент, ДанныеНоменклатурыПоМарке,DMArtName,ЕстьОшибки);
						Если ЕстьОшибки Тогда  
							СтруктураОтвета.Вставить("Описание", "Номенклатура " + Строка(DMArtName) + " не найдена в задании. Возможно проблема с сопоставлением");
							Возврат ПодготовитьОтветJSON(, СтруктураОтвета);
						КонецЕсли;
					КонецЕсли;
					
					Серия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(СтрокаДока.СправкаБ);
					DMSN = СокрЛП(ЧистаяСтрока(""+ Серия.Наименование));  
					
					Попытка
						Если ЗначениеЗаполнено(DMSN) Тогда
							sn = ПолучитьЗначениеСерии_EGAIS_ОПТ(УзелПО, СтрокаДока.АлкогольнаяПродукция, DMSN);
							СтруктураТекущейСтроки.Вставить("sn", sn);
						КонецЕсли;	
					Исключение
					КонецПопытки;
					
				КонецЕсли;
			КонецЕсли; 
			
			
			Если лЭтоКороб тогда
				СтруктураТекущейСтроки.Вставить("box_pack", Barcode);
			Иначе
				СтруктураТекущейСтроки.Вставить("pack", Barcode);
				
				Если ЭтоВыборочнаяПроверка Тогда
					СтруктураТекущейСтроки.Вставить("box_pack", СтрокаДока.Упаковка);
				КонецЕсли;	
			КонецЕсли;
			
			ОбъектСписка.Добавить(СтруктураТекущейСтроки);	
			
		КонецЦикла;
	КонецЕсли;
	
	Возврат ПодготовитьОтветJSON(ОбъектСписка);
	
КонецФункции
Функция ПолучитьСтруктуруСтрокиДокумента_EGAIS_ОПТ(ИмяТаблицы, УзелПО, СсылкаНаДок, СтрокаДокумента, UserName, ВызовИзWriteDoc = Ложь)
	
	ИспользоватьМаркировку 	= Истина;
	ИспользоватьЕГАИС 		= Истина;
	
	СтруктураСтроки = Новый Структура;  
	Шаблон = СсылкаНаДок.Шаблон;
	
	//Переменные Params
	СтруктураParams = Новый Структура;
	СтруктураParams.Вставить("KM_GTIN",       ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.marking.gtin));
	СтруктураParams.Вставить("KM_SN",	      ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.marking.sn));
	СтруктураParams.Вставить("KM_Barcode", 	  ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.marking.mark));
	СтруктураParams.Вставить("KM_RawBarcode", ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.marking.raw_barcode));		
	СтруктураParams.Вставить("KM_DecodedMrc", ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.marking.decoded_mrc));
	СтруктураParams.Вставить("KM_RawMrc",	  ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.marking.raw_mrc));	
	СтруктураParams.Вставить("KM_TNVED",	  ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.marking.tnvd));
	СтруктураParams.Вставить("GS1",			  ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.gs1_barcode));
	СтруктураParams.Вставить("packAttrs",	  СтрЗаменить(СтрокаДокумента.pack_attributes, "\\", ""));
	
	
	ПоискПоСопоставлению = Ложь;
	
	
	СтруктураСтроки.Вставить("ДокументТСД", 	 	СсылкаНаДок);
	СтруктураСтроки.Вставить("ИмяТаблицы", 			ИмяТаблицы);	
	СтруктураСтроки.Вставить("ИдентификаторСтроки", Число(СтрокаДокумента.row_id));
	
	СтруктураСтроки.Вставить("Штрихкод",			СтрокаДокумента.barcode.value);
	Попытка СтруктураСтроки.Вставить("ИдентификаторЕдИзм",	СтрокаДокумента.barcode.unit_id); Исключение СтруктураСтроки.Вставить("ИдентификаторЕдИзм", ""); КонецПопытки;
	СтруктураСтроки.Вставить("Уникальность",		Новый УникальныйИдентификатор());	
	СтруктураСтроки.Вставить("Ячейка", 				СтрокаДокумента.cell.barcode);
	СтруктураСтроки.Вставить("Количество",   		Число(СтрокаДокумента.qty));
	СтруктураСтроки.Вставить("Пользователь", 		UserName);
	СтруктураСтроки.Вставить("ТСД", 		 		УзелПО);
	
	Попытка
		СтруктураСтроки.Вставить("Дата", 		 	СтрокаДокумента.date);
	Исключение 
		СтруктураСтроки.Вставить("Дата", 		 	ТекущаяДата());
	КонецПопытки;
	
	СтруктураСтроки.Вставить("КодТовара", 			СтрокаДокумента.art.id);
	СтруктураСтроки.Вставить("НазваниеТовара",		СтрокаДокумента.art.name);
	СтруктураСтроки.Вставить("Номенклатура", Справочники.Номенклатура.ПустаяСсылка());
	СтруктураСтроки.Вставить("ХарактеристикаНоменклатуры", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	СтруктураСтроки.Вставить("ЕдиницаИзмерения", Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
	СтруктураСтроки.Вставить("КоэффициентЕдиницы", 1);        
	
	СтруктураСтроки.Вставить("СерийныйНомер", ДатаМобайл_Маркировка.ОбработатьЭкранированиеСтроки(СтрокаДокумента.sn,Ложь)); 
	
	Попытка 
		Если ЗначениеЗаполнено(СтруктураСтроки.СерийныйНомер) и СтрНачинаетсяС(СтруктураСтроки.СерийныйНомер, "[") Тогда 						
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(СтруктураСтроки.СерийныйНомер);
			МассивТекущейСерии = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
			
			СтруктураСтроки.СерийныйНомер = МассивТекущейСерии[0];		
		КонецЕсли;
	Исключение
	КонецПопытки;	
	
	СтруктураСтроки.Вставить("СерияСсылка", Справочники.СерииНоменклатуры.ПустаяСсылка());
	СтруктураСтроки.Вставить("НоваяЦена", Число(СтрокаДокумента.changed_price));
	
	Если СтруктураСтроки.Количество > 0 Тогда 
		СтруктураСтроки.Вставить("КоличествоМест", 1);
	ИначеЕсли СтруктураСтроки.Количество < 0 Тогда 
		СтруктураСтроки.Вставить("КоличествоМест", -1);
	Иначе
		СтруктураСтроки.Вставить("КоличествоМест", 0);
	КонецЕсли;
	
	Попытка СтруктураСтроки.Вставить("КоличествоВУпаковке", СтрокаДокумента.qty_in_pack); Исключение СтруктураСтроки.Вставить("КоличествоВУпаковке", 0); КонецПопытки;
	
	
	
	СтруктураСтроки.Вставить("КодТовараЕГАИС", СтрокаДокумента.art.id); 
	СтруктураСтроки.Вставить("НоменклатураЕГАИС", Справочники.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяСсылка());
	
	СтруктураСтроки.Вставить("ЕгаисПолныйКод", СтруктураParams.KM_Barcode);   
	СтруктураСтроки.Вставить("Короб", СтрокаДокумента.box_pack);
	СтруктураСтроки.Вставить("Палета", СтрокаДокумента.pack);
	
	СтруктураСтроки.Вставить("ЕгаисМарка", "");
	СтруктураСтроки.Вставить("PDF", "");
	СтруктураСтроки.Вставить("ЕгаисСправкаА", "");
	СтруктураСтроки.Вставить("ЕгаисСправкаБ", "");
	
	Если Лев(СтрокаДокумента.art.id,3) = "8a-" тогда //проверка задания 3 - по обычной номенклатуре
		Попытка
			СтруктураСтроки.Номенклатура=Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(Сред(СтрокаДокумента.art.id,4,36)));	
		Исключение	
		КонецПопытки;
		Если СтруктураParams.KM_Barcode <>"" тогда
			СтруктураСтроки.НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьЕГАИСПоМарке(СтруктураParams.KM_Barcode);
		КонецЕсли;
	Иначе
		Попытка
			СтруктураСтроки.НоменклатураЕГАИС=Справочники.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПолучитьСсылку(Новый УникальныйИдентификатор(Сред(СтрокаДокумента.art.id,4,36)));
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураСтроки.Номенклатура) и НЕ ЗначениеЗаполнено(СтруктураСтроки.НоменклатураЕГАИС) тогда  //ПИВО
		ПоискПоСопоставлению = Истина;
		Попытка СтруктураСтроки.НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьЕГАИСПоНоменклатуре_ОПТ(СтруктураСтроки.Номенклатура); Исключение КонецПопытки;
	КонецЕсли;
	
	
	Если ЗначениеЗаполнено(СтруктураParams.KM_Barcode) тогда //определение справок и серии новых марок при отгрузке
		ДанныеНоменклатурыПоМарке = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруАкцизнойМарки(СтруктураParams.KM_Barcode);
		Если ДанныеНоменклатурыПоМарке.Количество()>0 тогда      
			СтруктураСтроки.НоменклатураЕГАИС = ДанныеНоменклатурыПоМарке[0].АлкогольнаяПродукция;
			СтруктураСтроки.Номенклатура = ДанныеНоменклатурыПоМарке[0].Номенклатура;
			СтруктураСтроки.ЕгаисСправкаА = ДанныеНоменклатурыПоМарке[0].СправкаА;
			СтруктураСтроки.ЕгаисСправкаБ = ДанныеНоменклатурыПоМарке[0].СправкаБ;
			СтруктураСтроки.СерияСсылка = ДанныеНоменклатурыПоМарке[0].СерияНоменклатуры;
		Иначе //при приемке			
			Если НЕ ЗначениеЗаполнено(СтруктураСтроки.НоменклатураЕГАИС) Тогда 
				СтруктураСтроки.НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруАкцизнойМарки_Приемка(СтруктураParams.KM_Barcode,СсылкаНаДок);
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
	
	
	Если НЕ ЗначениеЗаполнено(СтруктураСтроки.Номенклатура) и ЗначениеЗаполнено(СтруктураСтроки.НоменклатураЕГАИС) и СтрокаДокумента.box_pack<>"" тогда
		ПоискПоСопоставлению = Истина;
		Попытка СтруктураСтроки.Номенклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоУпаковкеЕГАИС_ОПТ(СтруктураСтроки.НоменклатураЕГАИС,ЧистаяСтрока(СтрокаДокумента.box_pack)); Исключение КонецПопытки;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СтруктураСтроки.Номенклатура) и ЗначениеЗаполнено(СтруктураСтроки.НоменклатураЕГАИС) и СокрЛП(Шаблон.ВидДокумента)="ДатаМобайл_ЗаявкаНаСклад" тогда
		ПоискПоСопоставлению = Истина;
		Попытка СтруктураСтроки.Номенклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоИсходномуДокументу(СтруктураСтроки.НоменклатураЕГАИС,СсылкаНаДок); Исключение КонецПопытки;
	КонецЕсли;  
	
	Если НЕ ЗначениеЗаполнено(СтруктураСтроки.Номенклатура) и ЗначениеЗаполнено(СтруктураСтроки.НоменклатураЕГАИС) тогда
		ПоискПоСопоставлению = Истина;
		Попытка СтруктураСтроки.Номенклатура = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруПоЕГАИС_ОПТ(СтруктураСтроки.НоменклатураЕГАИС,ЧистаяСтрока(СтруктураParams.KM_Barcode)); Исключение КонецПопытки;
	КонецЕсли; 
	
	
	Если ЗначениеЗаполнено(СтруктураСтроки.Номенклатура) тогда
		ЗапросПоискаХарактеристик = Новый Запрос;
		ЗапросПоискаХарактеристик.Текст = "ВЫБРАТЬ Первые 1
		|	Ссылка КАК Характеристика
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры
		|ГДЕ
		|	Владелец = &ВидНоменклатуры
		|	И Наименование = ""Новая АМ""";
		ЗапросПоискаХарактеристик.УстановитьПараметр("ВидНоменклатуры", СтруктураСтроки.Номенклатура.ВидНоменклатуры);
		ВыборкаХарактеристик = ЗапросПоискаХарактеристик.Выполнить().Выбрать();
		Если ВыборкаХарактеристик.Следующий() Тогда
			СтруктураСтроки.ХарактеристикаНоменклатуры = ВыборкаХарактеристик.Характеристика;
		КонецЕсли; 	
	КонецЕсли; 			
	
	Если СтруктураСтроки.Штрихкод = "" и НЕ ЗначениеЗаполнено(СтруктураСтроки.ЕдиницаИзмерения) и ЗначениеЗаполнено(СтруктураСтроки.Номенклатура) тогда
		УстановитьЕдиницу_EGAIS_ОПТ(СтруктураСтроки);
	КонецЕсли;	
	
	
	Возврат СтруктураСтроки;
	
КонецФункции
Функция СоздатьДокумент_EGAIS_ОПТ(SN, UserName, DocOutID, TemplateID) 
	
	TemplateID = 1000-Число(TemplateID);
	
	УзелПО = НайтиУзел(SN);
	Если УзелПО = Неопределено Тогда
		УзелПО = NewTSD(SN, UserName);  
	КонецЕсли;
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ДатаМобайл_ШаблоныДокументов.Ссылка КАК ШаблонСсылка
	|ИЗ
	|	Справочник.ДатаМобайл_ШаблоныДокументов_ЕГАИС КАК ДатаМобайл_ШаблоныДокументов
	|ГДЕ
	|	ДатаМобайл_ШаблоныДокументов.Код = &ИД");
	Запрос.УстановитьПараметр("ИД", TemplateID);
	Рез = Запрос.Выполнить().Выбрать();
	Если Рез.Следующий() Тогда
		Док = Справочники.ДатаМобайл_ДокументыТСД_ЕГАИС.СоздатьЭлемент();
		Док.УстановитьНовыйКод();
		Док.Шаблон = Рез.ШаблонСсылка;
		Док.ДатаСоздания = ТекущаяДата();
		Док.ДатаНачалаСбора = ТекущаяДата();
		
		Если Не (Док.Шаблон.ГрупповаяРабота) Тогда
			Док.ТСД = УзелПО;
		КонецЕсли;
		
		Док.Дата = ТекущаяДата();
		Док.Номер = "DME-" + Формат(Док.код, "ЧДЦ=2; ЧРД=.; ЧН=0; ЧГ=0");
		Док.Комментарий = DocOutID;
		Док.Записать();
		
		Возврат Док.Ссылка;
	Иначе	
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции
Процедура ЗаполнитьОбъектШаблона_EGAIS_ОПТ(ОбъектШаблона, ШаблонСсылка)
	
	Модуль_СтроковыеФункцииКлиентСервер = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("СтроковыеФункцииКлиентСервер");
	
	Запрос = Новый Запрос(	
	"ВЫБРАТЬ 	
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка, ЗНАЧЕНИЕ(Справочник.ДатаМобайл_ШаблоныДокументов.ПустаяСсылка)) КАК ШаблонСсылка,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.Код, 0) КАК id,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.Наименование, """") КАК name,
	|	ИСТИНА КАК is_use_all_barcodes,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ПометкаУдаления, ЛОЖЬ) КАК is_deleted,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.РазрешеноСозданиеНаТСД, ЛОЖЬ) КАК is_allow_create_on_device,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ОбновлятьПриКаждомОткрытии, ЛОЖЬ) КАК is_load_rows_on_open_doc,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ОбновлятьТоварыСДокументом, ЛОЖЬ) КАК is_load_arts_with_doc,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ГенерацияПаклистаНаСервере, 0) КАК pack_list_generate_mode,
	|	ИСТИНА КАК is_use_barcode_templates,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.РазрешитьВыгрузкуНеполногоДокумента, 0) КАК unload_incorrect_doc_action,
	//|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.РазрешитьВыгрузкуНеполногоДокументаВариант, 0) КАК unload_incorrect_doc_option,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ПриСканированииНовогоТовара, 0) КАК new_art_action,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ГрупповаяРабота, ЛОЖЬ) КАК is_multi_doc,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ГрупповаяРаботаЗвуковоеОповещение, ЛОЖЬ) КАК is_play_multi_doc_sound,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ГрупповаяРаботаИнтервалОпроса, 0) КАК multi_doc_timeout,		
	|	ЛОЖЬ КАК is_use_online_arts_catalog,
	|	ИСТИНА КАК is_notify_getting_doc,
	|   1 = 1,
	|	2 = 2, 
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ВыгружатьВыполненныйНаТСДДокументАвтоматически, ЛОЖЬ) КАК is_unload_completed_doc,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.КоличествоМарокВКоробе, 0) КАК required_pack_qty
	//|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ТипБизнесПроцесса, 0) КАК process_id,
	//|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.Описание, """") КАК description,
	//|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.РежимСозданияДокументов, 0) КАК create_mode,
	//|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ПроверкаВложенностиУпаковок, 0) КАК selective_check_pack_mode,
	|	ПОМЕСТИТЬ ОбщиеНастройки
	|ИЗ
	|	Справочник.ДатаМобайл_ШаблоныДокументов_ЕГАИС КАК ДатаМобайл_ШаблоныДокументов
	|ГДЕ
	|	ДатаМобайл_ШаблоныДокументов.Ссылка = &ШаблонСсылка
	|;
	|  	ВЫБРАТЬ 
	|	ИСТИНА КАК is_use_operation,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ПриСканированииТовараПодбор, 0) КАК art_scan_action,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ПриПревышенииЗаданияПодбор, 0) КАК task_exceed_action,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ИспользованиеУпаковочныхЛистовПодбор, 0) КАК use_pack_mode,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.РучнойВводКоличестваПодбор, ЛОЖЬ) КАК is_manual_quantity,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ПодтверждатьЭнтеромПодбор, ЛОЖЬ) КАК is_enter_to_commit,
	|	ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.ОтсылатьГотовуюЗаписьНаСерверПодбор, ЛОЖЬ) КАК is_send_row_to_server
	|	ПОМЕСТИТЬ Подбор
	|ИЗ
	|	Справочник.ДатаМобайл_ШаблоныДокументов_ЕГАИС КАК ДатаМобайл_ШаблоныДокументов
	|ГДЕ
	|	ДатаМобайл_ШаблоныДокументов.Ссылка = &ШаблонСсылка
	|;
	|  	ВЫБРАТЬ 
	|	ЛОЖЬ КАК is_use_operation
	|	ПОМЕСТИТЬ Приемка
	|ИЗ
	|	Справочник.ДатаМобайл_ШаблоныДокументов_ЕГАИС КАК ДатаМобайл_ШаблоныДокументов
	|ГДЕ
	|	ДатаМобайл_ШаблоныДокументов.Ссылка = &ШаблонСсылка
	|;
	|  	ВЫБРАТЬ 
	|	ЛОЖЬ КАК is_egais_doc
	|	ПОМЕСТИТЬ ЕГАИС
	|ИЗ
	|	Справочник.ДатаМобайл_ШаблоныДокументов_ЕГАИС КАК ДатаМобайл_ШаблоныДокументов
	|ГДЕ
	|	ДатаМобайл_ШаблоныДокументов.Ссылка = &ШаблонСсылка
	|;
	|  	ВЫБРАТЬ 
	|	ИСТИНА КАК is_marking_doc,
	//|	ВЫБОР КОГДА ЕСТЬNULL(ДатаМобайл_ШаблоныДокументов.Ссылка.СопоставлениеЕГАИС, ЛОЖЬ) ТОГДА 2 ИНАЧЕ 0 КОНЕЦ КАК ean_scan_type,
	|	0 КАК ean_scan_type,
	|	ЛОЖЬ КАК is_ean_equals_gtin,
	|	ИСТИНА КАК is_ignore_art_mismatch_by_ean_km,
	|	ЛОЖЬ КАК is_search_by_km,
	|	ИСТИНА КАК is_only_mark_art,
	|	0 КАК without_km_enter_type,	
	|	0 КАК check_km_owner_action,
	|	0 КАК check_km_status_action,
	|	0 КАК sn_source,
	|	0 КАК check_ki_source,
	|	0 КАК use_osu_mode,
	|	0 КАК extended_pack_search
	|	ПОМЕСТИТЬ Маркировка
	|ИЗ
	|	Справочник.ДатаМобайл_ШаблоныДокументов_ЕГАИС КАК ДатаМобайл_ШаблоныДокументов
	|ГДЕ
	|	ДатаМобайл_ШаблоныДокументов.Ссылка = &ШаблонСсылка");
	
	
	Запрос.УстановитьПараметр("ШаблонСсылка", ШаблонСсылка);
	
	РезультатПакета = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	ПервыйЗапрос = РезультатПакета[0].Выгрузить();
	
	Для каждого Элемент Из ПервыйЗапрос Цикл
		ЗаполнитьЗначенияСвойств(ОбъектШаблона, Элемент);
		ОбъектШаблона.id = 1000-ОбъектШаблона.id;
	КонецЦикла;
	
	ВторойЗапрос = РезультатПакета[1].Выгрузить();
	Для каждого Элемент Из ВторойЗапрос Цикл
		ЗаполнитьЗначенияСвойств(ОбъектШаблона.select, Элемент);
	КонецЦикла;	 
	
	//Если ОбъектШаблона.DMonTaskType = 3 тогда
	//	ОбъектШаблона.DMonTaskType = 1; //Проверка по номенклатуре на ТСД аналогична проверке по номенклатуре ЕГАИС
	//ИначеЕсли ОбъектШаблона.DMonTaskType = 6 тогда
	//	ОбъектШаблона.DMonTaskType = 2; //Проверка по номенклатуре и сериям на ТСД аналогична проверке по номенклатуре ЕГАИС и партии					
	//ИначеЕсли ОбъектШаблона.DMonTaskType = 5 тогда
	//	ОбъектШаблона.DMonTaskType = 4; //Проверка помарочно с онлайн проверкой на ТСД аналогична, просто часть функционала на стороне 1с выполняется			
	//КонецЕсли;  
	
	Если ШаблонСсылка.ПроверкаЗадания = 2 или ШаблонСсылка.ПроверкаЗадания = 6 тогда  //Проверка по номенклатуре и сериям на ТСД аналогична проверке по номенклатуре ЕГАИС и партии					
		ОбъектШаблона.is_multi_sn_logic = Истина; 
		ОбъектШаблона.select.is_check_sn_by_task = Истина;
		ОбъектШаблона.select.use_sn_mode = 1;
		ОбъектШаблона.select.group_sn_type = 0;
	КонецЕсли;
	
	Если ШаблонСсылка.ИспользованиеУпаковочныхЛистовПодбор <> 0 тогда 					
		ОбъектШаблона.required_pack_qty = ШаблонСсылка.КоличествоМарокВКоробе;
	КонецЕсли;
	
	ТретийЗапрос = РезультатПакета[2].Выгрузить();
	Для каждого Элемент Из ТретийЗапрос Цикл
		ЗаполнитьЗначенияСвойств(ОбъектШаблона.insert, Элемент);
	КонецЦикла;	
	
	ЧетвертыйЗапрос = РезультатПакета[3].Выгрузить();
	Для каждого Элемент Из ЧетвертыйЗапрос Цикл
		ЗаполнитьЗначенияСвойств(ОбъектШаблона.egais, Элемент);
	КонецЦикла;	
	
	ПятыйЗапрос = РезультатПакета[4].Выгрузить();
	Для каждого Элемент Из ПятыйЗапрос Цикл
		ЗаполнитьЗначенияСвойств(ОбъектШаблона.marking, Элемент);
	КонецЦикла;	
	
	СтрокаРолей = "";
	ПолучитьРолиПоШаблону(ШаблонСсылка, СтрокаРолей);
	
	Если СтрокаРолей <> "" Тогда
		МассивРолей = Модуль_СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаРолей, ",");;
		ОбъектШаблона.Вставить("roles", МассивРолей);		
	КонецЕсли; 
	
КонецПроцедуры
Функция ПроверитьЗаписи_EGAIS_ОПТ(ИмяТаблицы, УзелПО, СсылкаНаДок, СтрокаДокумента, Объект = Неопределено)
	
	Модуль_ОбщегоНазначения = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ОбщегоНазначения");
	ЗначенияРеквизитовСсылкаНаДок = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаНаДок,"Шаблон");
	Шаблон = ЗначенияРеквизитовСсылкаНаДок.Шаблон;
	
	ЗначенияРеквизитовШаблон = Модуль_ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Шаблон,"ГрупповаяРабота,ИспользованиеУпаковочныхЛистовПодбор,
	|БыстроеСканирование");
	Шаблон_ГрупповаяРабота = ЗначенияРеквизитовШаблон.ГрупповаяРабота;
	Шаблон_ИспользованиеУпаковочныхЛистовПодбор = ЗначенияРеквизитовШаблон.ИспользованиеУпаковочныхЛистовПодбор;
	Шаблон_БыстроеСканирование = ЗначенияРеквизитовШаблон.БыстроеСканирование;;
	Шаблон_ИспользоватьМаркировку = Истина;
	Шаблон_МаркировкаСоздаватьСправочникКМЕслиНеНайден = Ложь;
	Шаблон_ДопРеквизиты = Ложь; 
	
	ЗапросСтрок = Новый Запрос;
	ЗапросСтрок.УстановитьПараметр("ТСД", УзелПО);
	ЗапросСтрок.УстановитьПараметр("ДокументТСД", СсылкаНаДок);
	ЗапросСтрок.УстановитьПараметр("ИдентификаторСтроки", Число(СтрокаДокумента.row_id));
	ЗапросСтрок.УстановитьПараметр("ИмяТаблицы", ИмяТаблицы);
	
	ЗапросСтрок.Текст = "ВЫБРАТЬ
	|	ИСТИНА КАК Выгружен
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК ДатаМобайл_СтрокиДокументов
	|ГДЕ
	|	ДатаМобайл_СтрокиДокументов.ТСД = &ТСД
	|	И ДатаМобайл_СтрокиДокументов.Ссылка = &ДокументТСД
	|	И ДатаМобайл_СтрокиДокументов.ИдентификаторСтроки = &ИдентификаторСтроки
	|	И ДатаМобайл_СтрокиДокументов.Количество > 0
	//|	И НЕ ДатаМобайл_СтрокиДокументов.ПризнакПовторнойВыгрузки
	|	
	|ОБЪЕДИНИТЬ
	|	
	|ВЫБРАТЬ
	|	ИСТИНА КАК Выгружен
	|ИЗ
	|	РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов КАК ДатаМобайл_СтрокиДокументов
	|ГДЕ
	|	ДатаМобайл_СтрокиДокументов.ТСД = &ТСД
	|	И ДатаМобайл_СтрокиДокументов.ДокументТСД = &ДокументТСД
	|	И ДатаМобайл_СтрокиДокументов.ИдентификаторСтроки = &ИдентификаторСтроки
	|	И ДатаМобайл_СтрокиДокументов.ИмяТаблицы = &ИмяТаблицы
	|	И ДатаМобайл_СтрокиДокументов.Количество > 0
	//|	И НЕ ДатаМобайл_СтрокиДокументов.ПризнакПовторнойВыгрузки
	|";
	
	Если Число(СтрокаДокумента.qty) < 0 Тогда
		ЗапросСтрок.Текст = СтрЗаменить(ЗапросСтрок.Текст, "Количество > 0", "Количество < 0");
	КонецЕсли;
	
	//Если ИмяТаблицы = "Insert" Тогда
	//	ЗапросСтрок.Текст = СтрЗаменить(ЗапросСтрок.Текст, "Подбор", "Приемка");
	//КонецЕсли;		
	
	Если Не ЗапросСтрок.Выполнить().Пустой() Тогда	
		
		//ОБНОВЛЕНИЕ ЗНАЧЕНИЙ ВВОДИМЫХ ПОСЛЕ ЗАПИСИ СТРОКИ
		Если Число(СтрокаДокумента.changed_price) > 0 
			Или (СтрокаДокумента.pack <> "" И Шаблон_ИспользованиеУпаковочныхЛистовПодбор = 2) Тогда
			
			Если Шаблон_ГрупповаяРабота Или Шаблон_БыстроеСканирование Тогда
				
				НаборЗаписей = РегистрыСведений.ДатаМобайл_СтрокиГрупповыхДокументов.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.ТСД.Установить(УзелПО);
				НаборЗаписей.Отбор.ДокументТСД.Установить(СсылкаНаДок);
				НаборЗаписей.Отбор.ДляОбмена.Установить(Ложь);
				НаборЗаписей.Отбор.ИдентификаторСтроки.Установить(Число(СтрокаДокумента.row_id));
				
				НаборЗаписей.Прочитать();
				
				Для каждого СтрокаЗаписи Из НаборЗаписей Цикл 
					СтрокаЗаписи.НоваяЦена = Число(СтрокаДокумента.changed_price);
					УстановитьУпаковочныйЛист(СтрокаЗаписи,СтрокаДокумента,Шаблон_ИспользоватьМаркировку,Шаблон_МаркировкаСоздаватьСправочникКМЕслиНеНайден, Шаблон);
				КонецЦикла;
				НаборЗаписей.Записать();
				
			Иначе
				Если Объект <> Неопределено Тогда
					СтруктураПоиска = Новый Структура("ИдентификаторСтроки,ТСД", Число(СтрокаДокумента.row_id), УзелПО);
					Если ИмяТаблицы = "Insert" Тогда
						СтрокиПодбора = Объект.СобранныеДанныеПриемка.НайтиСтроки(СтруктураПоиска);
					Иначе	
						СтрокиПодбора = Объект.СобранныеДанныеПодбор.НайтиСтроки(СтруктураПоиска);
					КонецЕсли;	
					Если СтрокиПодбора.Количество() > 0 Тогда
						Для каждого СтрокаПодбора Из СтрокиПодбора Цикл
							СтрокаПодбора.НоваяЦена = Число(СтрокаДокумента.changed_price);
							УстановитьУпаковочныйЛист(СтрокаПодбора, СтрокаДокумента, Шаблон_ИспользоватьМаркировку, Шаблон_МаркировкаСоздаватьСправочникКМЕслиНеНайден, Шаблон);
						КонецЦикла;
						
						Объект.Записать(); 
						
						//УДАЛЕНИЕ РЕГИСТРАЦИИ ДАННОГО ДОКУМЕНТА НА ДАННОМ УЗЛЕ 
						ДатаМобайл_ОбщийМодуль.УдалитьРегистрациюОбъекта(Объект, Ложь);						
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;
		
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции	
Процедура СформироватьЗаголовкиJSONParamsТовара_EGAIS_ОПТ(УзелПО, ОбъектТовара, Номенклатура, DMUseSN = Ложь, Шаблон = Неопределено)
	
	ОбъектТовара.is_use_sn = DMUseSN; 				
	ОбъектТовара.mark_type = 7;
	ЭтоНовыйТовар = Ложь;
	СтруктураАтрибутов = Новый Структура;
	
	Если ЗначениеЗаполнено(Номенклатура) тогда
		
		Атрибуты = ПолучитьАтрибуты(УзелПО); 				
		
		Для сч = 1 По 10 Цикл
			Попытка 
				ИмяАтрибута =  Атрибуты["ИмяАтрибута" + сч];
				Если ЭтоНовыйТовар Тогда
					СтруктураАтрибутов.Вставить("attr_" + сч, "");
				ИначеЕсли ИмяАтрибута = "!!! Ячейки !!!" Или ИмяАтрибута = "!!! Основная ячейка !!!" Или ИмяАтрибута = "!!! Дополнительные ячейки !!!" Тогда
					СтруктураАтрибутов.Вставить("attr_" + сч, ПолучитьСправочныеЯчейкиТовара(УзелПО, Номенклатура, ИмяАтрибута));
					//ИначеЕсли ИмяАтрибута = "!!! Характеристики !!!" Тогда
					//	СтруктураАтрибутов.Вставить("attr_" + сч, ЧистаяСтрока(НаименованиеХарактеристики));
				ИначеЕсли Лев(ИмяАтрибута, 3) = "ДР_" Тогда 
					СтруктураАтрибутов.Вставить("attr_" + сч, ПолучитьДополнительныйРеквизитАтрибута(Номенклатура, ИмяАтрибута));	
				ИначеЕсли ИмяАтрибута <> "" Тогда
					СтруктураАтрибутов.Вставить("attr_" + сч, ЧистаяСтрока(Номенклатура[ИмяАтрибута]));						
				Иначе 
					СтруктураАтрибутов.Вставить("attr_" + сч, "");
				КонецЕсли;
			Исключение
				СтруктураАтрибутов.Вставить("attr_" + сч, "");
			КонецПопытки;	
		КонецЦикла;
		
	КонецЕсли;
	
	ОбъектТовара.attributes = СтруктураАтрибутов;
	
	Попытка		
		МассивТиповСерийныхНомеров = Новый Массив;
		МассивТиповСерийныхНомеров.Добавить("10");	
		
		ОбъектТовара.Вставить("sn_types", МассивТиповСерийныхНомеров); 		
	Исключение
	КонецПопытки;
	
КонецПроцедуры
Функция ПолучитьЗначениеСерии_EGAIS_ОПТ(УзелПО, лТовар, лСерия, Insert = Ложь)
	
	ЗначениеСерии = ПолучитьЗначенияSNTypesСерии_EGAIS_ОПТ(лТовар, лСерия, УзелПО.СерииРассчитыватьГоденДо);		
	Возврат ЗначениеСерии;
	
КонецФункции
Функция ПолучитьЗначенияSNTypesСерии_EGAIS_ОПТ(лТовар, лСерия, РасчитыватьГоденДо)
	
	МассивТекущейСерии = Новый Массив;
	
	Если ЗначениеЗаполнено(лТовар) И ЗначениеЗаполнено(лСерия) Тогда	
		МассивТекущейСерии.Добавить(СокрЛП(лСерия));	
	КонецЕсли;
	
	СтрокаJSON = "";
	
	НастройкиСериализации = Новый НастройкиСериализацииJSON;
	НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.JavaScript;
	ПараметрыJSON = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, " ", Истина);
	
	Запись = Новый ЗаписьJSON;
	Запись.ПроверятьСтруктуру = Истина;
	Запись.УстановитьСтроку(ПараметрыJSON);
	
	ЗаписатьJSON(Запись, МассивТекущейСерии, НастройкиСериализации);
	СтрокаJSON = Запись.Закрыть();
	
	Возврат СтрокаJSON;
	
КонецФункции
Процедура ПроверитьДанныеНоменклатурыПоРеализации_EGAIS_ОПТ(лДокумент, лНоменклатураСписок, лНаименованиеЕГАИС_Номенклатуры,ЕстьОшибки);
	
	Попытка
		
		ЕстьОшибки = Ложь;
		
		Если ТипЗнч(лДокумент) <> Тип("ДокументСсылка.РеализацияТоваровУслуг")
			И ТипЗнч(лДокумент) <> Тип("ДокументСсылка.ДатаМобайл_ЗаявкаНаСклад")
			И ТипЗнч(лДокумент) <> Тип("ДокументСсылка.ЗаказКлиента")
			И ТипЗнч(лДокумент) <> Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			Возврат;
		КонецЕсли;
		
		Для Каждого СтрокаСписка из лНоменклатураСписок Цикл
			
			РезультатПоиска = лДокумент.Товары.НайтиСтроки(Новый Структура("Номенклатура", СтрокаСписка.Номенклатура));
			
			Если РезультатПоиска.Количество() = 0 Тогда
				ЕстьОшибки = Истина;
			Иначе
				ЕстьОшибки = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	Исключение
		
	КонецПопытки;
	
КонецПроцедуры
Функция БылоСканированиеКоробаСТакойМаркой_EGAIS_ОПТ(СсылкаНаДок, PDFBarcode, Шаблон) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСД_ЕГАИССобранныеДанныеПодбор.Короб КАК Короб
	|ПОМЕСТИТЬ СписокКоробов
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСД_ЕГАИССобранныеДанныеПодбор
	|ГДЕ
	|	ДатаМобайл_ДокументыТСД_ЕГАИССобранныеДанныеПодбор.Ссылка = &ДокументТСД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СписокКоробов.Короб КАК Короб,
	|	Хранилище.Марка КАК Марка
	|ИЗ
	|	СписокКоробов КАК СписокКоробов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.алкХранилищеАкцизныхМарок КАК Хранилище
	|		ПО (Хранилище.Упаковка = СписокКоробов.Короб)
	|ГДЕ
	|	Хранилище.Марка = &Марка";
	
	Запрос.УстановитьПараметр("Марка", PDFBarcode);
	Запрос.УстановитьПараметр("ДокументТСД", СсылкаНаДок);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество() > 0 Тогда
		Возврат Истина;		     	
	КонецЕсли;	
	
	Возврат Ложь;
	
КонецФункции
Функция БылоСканированиеКоробаКоторыйНеСоответстввуетМарке_EGAIS_ОПТ(СсылкаНаДок, АкцизнаяМарка, Шаблон, ТекущийКороб) 
	
	ЗапросМарок = Новый Запрос;
	ЗапросМарок.Текст = "ВЫБРАТЬ
	|	ЕГАИС_ТТНДанныеМарок.НомерКоробки КАК Короб,
	|	ЕСТЬNULL(ЕГАИС_ТТНДанныеУпаковок.ИерархияУпаковки,"""") КАК Палета
	|ИЗ
	|	Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.АкцизныеМарки КАК ЕГАИС_ТТНДанныеМарок
	|	ЛЕВОЕ СОЕДИНЕНИЕ  Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Упаковки КАК ЕГАИС_ТТНДанныеУпаковок
	|	ПО ЕГАИС_ТТНДанныеМарок.Ссылка = ЕГАИС_ТТНДанныеУпаковок.Ссылка
	|	И ЕГАИС_ТТНДанныеУпаковок.Упаковка = ЕГАИС_ТТНДанныеМарок.НомерКоробки
	|ГДЕ
	|   ЕГАИС_ТТНДанныеМарок.Ссылка = &СсылкаТТН
	|	И ЕГАИС_ТТНДанныеМарок.КодАкцизнойМарки = &АкцизнаяМарка
	|	И ЕстьNull(ЕГАИС_ТТНДанныеУпаковок.Упаковка, 0) <> ЕстьNull(ЕГАИС_ТТНДанныеУпаковок.ИерархияУпаковки, 1)
	|СГРУППИРОВАТЬ ПО
	|   ЕГАИС_ТТНДанныеМарок.НомерКоробки ,
	|   ЕСТЬNULL(ЕГАИС_ТТНДанныеУпаковок.ИерархияУпаковки,"""")";
	
	ЗапросМарок.Текст=СтрЗаменить(ЗапросМарок.Текст,".алкТоварноТранспортнаяНакладнаяЕГАИС.","."+Шаблон.ВидДокумента+".");	
	ЗапросМарок.УстановитьПараметр("СсылкаТТН",СсылкаНаДок.ИсходныйДокумент);
	ЗапросМарок.УстановитьПараметр("АкцизнаяМарка",АкцизнаяМарка);
	
	РезМарок=ЗапросМарок.Выполнить().Выбрать();
	
	Если РезМарок.Следующий() тогда
		
		Если ЗначениеЗаполнено(СокрЛП(РезМарок.Короб)) или ЗначениеЗаполнено(СокрЛП(РезМарок.Палета)) тогда
			
			Если СокрЛП(РезМарок.Короб) <> ТекущийКороб И СокрЛП(РезМарок.Палета) <> ТекущийКороб  тогда	
				Возврат Истина;	
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Ложь;			
	
КонецФункции
Функция ПолучитьСостояниеАкцизнойМарки_EGAIS_ОПТ(ИдентификаторМарки = "", Период = Неопределено)
	
	СтруктураДанных = Новый Структура("Марка, Упаковка, Регистратор, Период, АлкогольнаяПродукция, Организация, ПунктРазгрузки, ОтметкаВыбытия, СправкаБ");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Упаковка", ИдентификаторМарки);
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Период), Период, Неопределено));
	Запрос.Текст = "ВЫБРАТЬ
	|	алкХранилищеАкцизныхМарокСрезПоследних.Период,
	|	алкХранилищеАкцизныхМарокСрезПоследних.Регистратор,
	|	алкХранилищеАкцизныхМарокСрезПоследних.Марка,
	|	алкХранилищеАкцизныхМарокСрезПоследних.Упаковка,
	|	алкХранилищеАкцизныхМарокСрезПоследних.СправкаБ,
	|	алкХранилищеАкцизныхМарокСрезПоследних.АлкогольнаяПродукция,
	|	алкХранилищеАкцизныхМарокСрезПоследних.Организация,
	|	алкХранилищеАкцизныхМарокСрезПоследних.ПунктРазгрузки,
	|	алкХранилищеАкцизныхМарокСрезПоследних.ОтметкаВыбытия
	|ИЗ
	|	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(&Период, Марка = &Упаковка) КАК алкХранилищеАкцизныхМарокСрезПоследних";
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Если ТипЗнч(Результат.Регистратор) = Тип("ДокументСсылка.алкАктФиксацииШтрихкодовНаБалансеОрганизацииЕГАИС") тогда
			Если Результат.Регистратор.ОтменаФиксации тогда
				Возврат Неопределено;
			КонецЕсли;	
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтруктураДанных, Результат);
		
		Возврат СтруктураДанных;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции
Функция БылоСканированиеМаркиВЭтомДокументе_EGAIS_ОПТ(ИдентификаторМарки = "", ДокументТСД = Неопределено, Шаблон = Неопределено)
	
	Если ИдентификаторМарки = "" тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Упаковка", ИдентификаторМарки);
	Запрос.УстановитьПараметр("ДокументТСД", ДокументТСД);
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ЕстьNULL(Сумма(ЕстьNULL(ДМ_СобранныеДанныеПодбор.Количество,0)),0) Как Количество
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК ДМ_СобранныеДанныеПодбор
	|ГДЕ 
	|   ДМ_СобранныеДанныеПодбор.ЕгаисПолныйКод = &Упаковка
	|   И ДМ_СобранныеДанныеПодбор.Ссылка = &ДокументТСД";
	
	//Запрос.Текст = 
	//"ВЫБРАТЬ
	//|	алкХранилищеАкцизныхМарокСрезПоследних.Упаковка
	//|ПОМЕСТИТЬ Короба
	//|ИЗ
	//|	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(, Марка = &Упаковка) КАК алкХранилищеАкцизныхМарокСрезПоследних
	//|;
	//|
	//|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ
	//|	алкХранилищеУпаковокСрезПоследних.ИерархияУпаковки
	//|ПОМЕСТИТЬ Палеты
	//|ИЗ
	//|	РегистрСведений.алкХранилищеУпаковок.СрезПоследних КАК алкХранилищеУпаковокСрезПоследних
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Короба КАК Короба
	//|		ПО алкХранилищеУпаковокСрезПоследних.Упаковка = Короба.Упаковка
	//|;
	//|
	//|////////////////////////////////////////////////////////////////////////////////
	//|ВЫБРАТЬ
	//|	ЕСТЬNULL(СУММА(ЕСТЬNULL(ДМ_СобранныеДанныеПодбор.Количество, 0)), 0) КАК Количество
	//|ИЗ
	//|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК ДМ_СобранныеДанныеПодбор
	//|ГДЕ
	//|	ДМ_СобранныеДанныеПодбор.ЕгаисПолныйКод = &Упаковка
	//|	И ДМ_СобранныеДанныеПодбор.Ссылка = &ДокументТСД
	//|
	//|ОБЪЕДИНИТЬ ВСЕ
	//|
	//|ВЫБРАТЬ
	//|	ЕСТЬNULL(СУММА(ЕСТЬNULL(ДМ_СобранныеДанныеПодбор.Количество, 0)), 0)
