			КонецЕсли;
		Исключение
		КонецПопытки;
		
		limit_qty = 0;
		Если УзелПО.НеОтображатьОстатки Тогда
			limit_qty = 0;
		ИначеЕсли ЭтоУслуга Тогда
			limit_qty = 999;	
		Иначе
			limit_qty = Итог;
		КонецЕсли;
		
		// Количество в базовых
		qty = СтрокаДока.Количество * СтрокаДока.Коэффициент; 		
		
