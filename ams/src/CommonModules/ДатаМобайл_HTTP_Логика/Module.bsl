			//|	МИНИМУМ(ТаблицаТоваровВДокументе.НомерСтроки) КАК НомерСтроки,
			//// механизм работы с доп.формами -((
			//|	&УсловиеАтрибуты1 
			//// механизм работы с доп.формами -))
			//|ПОМЕСТИТЬ ЗапросСЛимитами
			//|ИЗ
			//|	Документ.ПриобретениеТоваровУслуг.Товары КАК ТаблицаТоваровВДокументе
			//|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг.Серии КАК ТаблицаСерийВДокументе
			//|		ПО ТаблицаТоваровВДокументе.Ссылка = ТаблицаСерийВДокументе.Ссылка
			//|			И ТаблицаТоваровВДокументе.Номенклатура = ТаблицаСерийВДокументе.Номенклатура
			//|			И ТаблицаТоваровВДокументе.Характеристика = ТаблицаСерийВДокументе.Характеристика
			//|ГДЕ
			//|	ТаблицаТоваровВДокументе.Ссылка = &ИсходныйДокумент
			//|	И ТаблицаСерийВДокументе.Ссылка = &ИсходныйДокумент
			//|
			//|СГРУППИРОВАТЬ ПО
			//|	ТаблицаТоваровВДокументе.Номенклатура,
			//|	ТаблицаТоваровВДокументе.Характеристика,
			//|	&УсловиеУпаковка,
			//|	ЕСТЬNULL(ТаблицаСерийВДокументе.Серия, ТаблицаТоваровВДокументе.Серия),
			//|	&УсловиеЦена,
			//// механизм работы с доп.формами -((
			//|	&УсловиеАтрибуты2
			//// механизм работы с доп.формами -))
			//|
			//|ИНДЕКСИРОВАТЬ ПО
			//|   Номенклатура,
			//|   Характеристика
			//|";
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЕСТЬNULL(ТаблицаСерийВДокументе.Номенклатура, ТаблицаТоваровВДокументе.Номенклатура) КАК Номенклатура,
			|	ЕСТЬNULL(ТаблицаСерийВДокументе.Характеристика, ТаблицаТоваровВДокументе.Характеристика) КАК Характеристика,
