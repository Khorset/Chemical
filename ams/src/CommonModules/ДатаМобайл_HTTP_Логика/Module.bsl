Функция БылоСканированиеПоУпаковкеПриПриемкеСОнлайнПроверкой_EGAIS_ОПТ(ИдентификаторУпаковки,ДокументТСД = Неопределено,Шаблон = Неопределено)
	
	Если ИдентификаторУпаковки = "" тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Упаковка", ИдентификаторУпаковки);
	Запрос.УстановитьПараметр("ДокументТСД", ДокументТСД);
	Запрос.УстановитьПараметр("Шаблон", Шаблон);
	
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ЕстьNULL(Сумма(ЕстьNULL(ДМ_СобранныеДанныеПодбор.Количество,0)),0) Как Количество
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК ДМ_СобранныеДанныеПодбор
	|ГДЕ 
	|   ДМ_СобранныеДанныеПодбор.Короб = &Упаковка
	|   И ДМ_СобранныеДанныеПодбор.Ссылка = &ДокументТСД";
	
	Если Шаблон<>Неопределено тогда
		Если Шаблон.ГрупповаяРабота	тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор","РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов");
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"ДМ_СобранныеДанныеПодбор.Ссылка","ДМ_СобранныеДанныеПодбор.ДокументТСД");
		КонецЕсли;	
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока  Выборка.Следующий() Цикл
		Если Выборка.Количество>0 тогда
			Возврат Истина;
		КонецЕсли;	
	КонецЦикла;
	
	
	Возврат Ложь;
	
	
