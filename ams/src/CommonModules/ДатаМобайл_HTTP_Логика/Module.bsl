			|ГДЕ
			|	ТаблицаТоваровВДокументе.Ссылка = &ИсходныйДокумент
			|	И ТаблицаСерийВДокументе.Ссылка = &ИсходныйДокумент
			|
			|СГРУППИРОВАТЬ ПО
			|	ЕСТЬNULL(ТаблицаСерийВДокументе.Номенклатура, ТаблицаТоваровВДокументе.Номенклатура),
			|	ЕСТЬNULL(ТаблицаСерийВДокументе.Характеристика, ТаблицаТоваровВДокументе.Характеристика),
			|	&УсловиеУпаковка,
			|	ЕСТЬNULL(ТаблицаСерийВДокументе.Серия, ТаблицаТоваровВДокументе.Серия),
			|	&УсловиеЦена,
			|	ВЫБОР
			|		КОГДА ЕСТЬNULL(ТаблицаСерийВДокументе.Количество, 0) = 0
			|			ТОГДА ВЫБОР
			|					КОГДА ЕСТЬNULL(ТаблицаТоваровВДокументе.Количество, 0) = 0
			|						ТОГДА ТаблицаТоваровВДокументе.КоличествоУпаковок
			|					ИНАЧЕ ЕСТЬNULL(ТаблицаТоваровВДокументе.Количество, 0)
			|				КОНЕЦ
			|		ИНАЧЕ ЕСТЬNULL(ТаблицаСерийВДокументе.Количество, 0)
			|	КОНЕЦ,
			// механизм работы с доп.формами -((
			|	&УсловиеАтрибуты2
			// механизм работы с доп.формами -))
			|
			|ОБЪЕДИНИТЬ
			|
			|ВЫБРАТЬ
			|	ТаблицаТоваровВДокументе.Номенклатура,
			|	ТаблицаТоваровВДокументе.Характеристика,
			|	&УсловиеУпаковка,
			|	ТаблицаТоваровВДокументе.Серия,
			|	&УсловиеЦена,
			|	ВЫБОР
			|		КОГДА ЕСТЬNULL(ТаблицаТоваровВДокументе.Количество, 0) = 0
			|			ТОГДА ТаблицаТоваровВДокументе.КоличествоУпаковок
			|		ИНАЧЕ ЕСТЬNULL(ТаблицаТоваровВДокументе.Количество, 0)
			|	КОНЕЦ,
			|	МИНИМУМ(ТаблицаТоваровВДокументе.НомерСтроки),
			// механизм работы с доп.формами -((
			|	&УсловиеАтрибуты1 
			// механизм работы с доп.формами -))
			|ИЗ
			|	Документ.ПриобретениеТоваровУслуг.Товары КАК ТаблицаТоваровВДокументе
			|ГДЕ
			|	ТаблицаТоваровВДокументе.Ссылка = &ИсходныйДокумент
			|	И ТаблицаТоваровВДокументе.СтатусУказанияСерий = 0
			|
			|СГРУППИРОВАТЬ ПО
			|	ТаблицаТоваровВДокументе.Номенклатура,
			|	ТаблицаТоваровВДокументе.Характеристика,
			|	&УсловиеУпаковка,
			|	ТаблицаТоваровВДокументе.Серия,
			|	&УсловиеЦена,
			|	ВЫБОР
			|		КОГДА ЕСТЬNULL(ТаблицаТоваровВДокументе.Количество, 0) = 0
			|			ТОГДА ТаблицаТоваровВДокументе.КоличествоУпаковок
			|		ИНАЧЕ ЕСТЬNULL(ТаблицаТоваровВДокументе.Количество, 0)
			|	КОНЕЦ,
			// механизм работы с доп.формами -((
			|	&УсловиеАтрибуты2
			// механизм работы с доп.формами -))
			|	
			|ИНДЕКСИРОВАТЬ ПО
			|   Номенклатура,
			|   Характеристика
			|";
		КонецЕсли;
		
	ИначеЕсли РеквизитыШаблона.ВидДокумента = "ЗаказНаЭмиссиюКодовМаркировкиСУЗ" Тогда
		ТекстЗапроса = "ВЫБРАТЬ
		|	ПулКодовМаркировкиСУЗ.ЗаказНаЭмиссию КАК Ссылка,
		|	ПулКодовМаркировкиСУЗ.КодМаркировки КАК КодМаркировки,
		|	ЗНАЧЕНИЕ(Справочник.ШтрихкодыУпаковокТоваров.) КАК ШтрихкодУпаковки,
		|	ВЫБОР
		|		КОГДА ПОДСТРОКА(ПулКодовМаркировкиСУЗ.КодМаркировки, 1, 4) = ""(01)""
		|			ТОГДА ""01"" + ПОДСТРОКА(ПулКодовМаркировкиСУЗ.КодМаркировки, 5, 14) + ""21"" + ПОДСТРОКА(ПулКодовМаркировкиСУЗ.КодМаркировки, 23, 100)
		|		ИНАЧЕ ПулКодовМаркировкиСУЗ.КодМаркировки
		|	КОНЕЦ КАК ЗначениеШтрихкода
		|ПОМЕСТИТЬ ВТ_Пул
		|ИЗ
		|	РегистрСведений.ПулКодовМаркировкиСУЗ КАК ПулКодовМаркировкиСУЗ
		|ГДЕ
		|	ПулКодовМаркировкиСУЗ.ЗаказНаЭмиссию = &ИсходныйДокумент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|" + Запрос.Текст;
		
		Запрос.Текст = ТекстЗапроса;	
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Документ.ПриобретениеТоваровУслуг.ШтрихкодыУпаковок", "ВТ_Пул");
		
	ИначеЕсли РеквизитыШаблона.ВидДокумента = "ПриходныйОрдерНаТовары" Или РеквизитыШаблона.ВидДокумента = "ПередачаТоваровМеждуОрганизациями" Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПриобретениеТоваровУслугШтрихкодыУпаковок.ЗначениеШтрихкода", "ПриобретениеТоваровУслугШтрихкодыУпаковок.ШтрихкодУпаковки.ЗначениеШтрихкода");	
	КонецЕсли;
		
