Функция ПолучитьКоэффициентУпаковки_EGAIS_ОПТ(BarcodeBox)
	
	ТекущийКоэффициент = 0;
	
	зпр=Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	|	Штрихкоды.Упаковка.Числитель КАК Коэффициент
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
	|ГДЕ
	|	Штрихкоды.Штрихкод = &код");
	
	зпр.УстановитьПараметр("Код",BarcodeBox);
	рез=зпр.Выполнить().Выгрузить();
	Если Рез.Количество()>0 и BarcodeBox<>"" тогда
		ТекущийКоэффициент=Рез[0].Коэффициент;
	КонецЕсли;
	
	Возврат ТекущийКоэффициент;
