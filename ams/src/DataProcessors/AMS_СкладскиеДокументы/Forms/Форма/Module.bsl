КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура НастройкаФормы()
	Элементы.Склад.Заголовок = "Склад";
	
	Имя = Элементы.Страницы.ТекущаяСтраница.Заголовок;
	
	Если Имя = "Перемещение товаров" Тогда
		Элементы.Склад.Заголовок = "Склад отправитель";
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыПеремещения.Отбор,"СкладОтправитель",Склад,ВидСравненияКомпоновкиДанных.Равно,,ЗначениеЗаполнено(Склад));
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыПеремещения.Отбор,"СкладПолучатель",СкладПолучатель,ВидСравненияКомпоновкиДанных.ВСписке,,ЗначениеЗаполнено(СкладПолучатель));
		
	ИначеЕсли Имя = "Оприходование излишков" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыОприходования.Отбор,"Склад",Склад,ВидСравненияКомпоновкиДанных.Равно,,ЗначениеЗаполнено(Склад));
		
	ИначеЕсли Имя = "Списание недостач" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыСписания.Отбор,"Склад",Склад,ВидСравненияКомпоновкиДанных.Равно,,ЗначениеЗаполнено(Склад));
		
	ИначеЕсли Имя = "Производство" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыПроизводства.Отбор,"Склад",Склад,ВидСравненияКомпоновкиДанных.Равно,,ЗначениеЗаполнено(Склад));
		
	ИначеЕсли Имя = "Разборка коробок" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыРазборки.Отбор,"Склад",Склад,ВидСравненияКомпоновкиДанных.Равно,,ЗначениеЗаполнено(Склад));
		
	ИначеЕсли Имя = "Пересчеты товаров" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыПересчёты.Отбор,"Склад",Склад,ВидСравненияКомпоновкиДанных.Равно,,ЗначениеЗаполнено(Склад));
		
	ИначеЕсли Имя = "Сборка наборов" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыСборкаНаборов.Отбор,"Склад",Склад,ВидСравненияКомпоновкиДанных.Равно,,ЗначениеЗаполнено(Склад));
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборДокументовПеремещенияТоваровПоСтатусу()
	СтатусОтгружено = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.СтатусыПеремещенийТоваров.Отгружено");
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ДокументыПеремещения.Отбор,"Статус",СтатусОтгружено,ВидСравненияКомпоновкиДанных.Равно,,ФлагОтгружено);
КонецПроцедуры


#КонецОбласти
