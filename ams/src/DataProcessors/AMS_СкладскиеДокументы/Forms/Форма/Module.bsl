
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	УстановитьОтборДокументовПеремещенияТоваровПоСтатусу();

	ИсключитьСклады = Новый СписокЗначений;
	ИсключитьСклады.Добавить(Справочники.Склады.НайтиПоНаименованию("Цех №1 Материалы в производстве",Истина));
	ИсключитьСклады.Добавить(Справочники.Склады.НайтиПоНаименованию("Цех №2 Материалы в производстве",Истина));
	ИсключитьСклады.Добавить(Справочники.Склады.НайтиПоНаименованию("Цех №3 Материалы в производстве",Истина));
	ИсключитьСклады.Добавить(Справочники.Склады.НайтиПоНаименованию("Цех №4 Материалы в производстве",Истина));
	
	ДокументыПеремещения.Параметры.УстановитьЗначениеПараметра("ИсключитьСклады",ИсключитьСклады);
	
	Если Пользователи.РолиДоступны("_БухгалтерСклада") И Не Пользователи.РолиДоступны("_НачальникСклада") Тогда
		Склад            = AMS_ВызовСервера.СкладПродукции();
		СкладПолучатель  = AMS_ВызовСервера.СкладКарантин();
		
		Элементы.Страницы.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
		Элементы.Страницы.ТекущаяСтраница    = Элементы.СтраницаПеремещениеТоваров;
		Элементы.ГруппаСклады.Доступность    = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	НастройкаФормы();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Запись_СборкаТоваров" ИЛИ ИмяСобытия = "Запись_ПеремещениеТоваров" Тогда
		//ПоказатьБракВЦехе();
		НастройкаФормы();
	
		ОбновитьОтображениеДанных();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	НастройкаФормы();
КонецПроцедуры

&НаКлиенте
Процедура СкладПриИзменении(Элемент)
	НастройкаФормы();
КонецПроцедуры

&НаКлиенте
Процедура СкладПолучательПриИзменении(Элемент)
