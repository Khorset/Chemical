	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество" + Парам.Нед1 + " КАК Про1,
	|	т.Количество" + Парам.Нед2 + " КАК Про2,
	|	т.Количество" + Парам.Нед3 + " КАК Про3,
	|	т.Количество" + Парам.Нед4 + " КАК Про4,
	|	т.Количество" + Парам.Нед5 + " КАК Про5,
	|	т.Количество" + Парам.Нед6 + " КАК Про6,
	|	ЕСТЬNULL(т.Количество" + Парам.Нед1 + ", 0)
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед2 + ", 0)
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед3 + ", 0)
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед4 + ", 0)
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед5 + ", 0)
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед6 + ", 0) КАК Про,";
	
	Если Парам.ТекНеделя >= Парам.Нед1 Тогда
		ТекстЗапроса = ТекстЗапроса + "
	|	ЕСТЬNULL(т.Количество" + Парам.Нед1 + ", 0)";
	КонецЕсли;
	
	Если Парам.ТекНеделя >= Парам.Нед2 Тогда
		ТекстЗапроса = ТекстЗапроса + "
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед2 + ", 0)";
	КонецЕсли;
	
	Если Парам.ТекНеделя >= Парам.Нед3 Тогда
		ТекстЗапроса = ТекстЗапроса + "
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед3 + ", 0)";
	КонецЕсли;
	
	Если Парам.ТекНеделя >= Парам.Нед4 Тогда
		ТекстЗапроса = ТекстЗапроса + "
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед4 + ", 0)";
	КонецЕсли;
	
	Если Парам.ТекНеделя >= Парам.Нед5 Тогда
		ТекстЗапроса = ТекстЗапроса + "
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед5 + ", 0)";
	КонецЕсли;
	
	Если Парам.ТекНеделя >= Парам.Нед6 Тогда
		ТекстЗапроса = ТекстЗапроса + "
	|	+ ЕСТЬNULL(т.Количество" + Парам.Нед6 + ", 0)";
	КонецЕсли;
	
	ТекстЗапроса = ТекстЗапроса + " КАК ПроПлан
