			Период.ДатаНачала    = НачалоДня(Парам.Дата8);
			Период.ДатаОкончания = КонецДня(Парам.Дата8);
		ИначеЕсли НомерКолонки = 50 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата9);
