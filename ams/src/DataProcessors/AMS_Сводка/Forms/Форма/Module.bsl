			Период.ДатаОкончания = КонецДня(Парам.Дата11);
		ИначеЕсли НомерКолонки = 53 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата12);
			Период.ДатаОкончания = КонецДня(Парам.Дата12);
		ИначеЕсли НомерКолонки = 54 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата13);
			Период.ДатаОкончания = КонецДня(Парам.Дата13);
		ИначеЕсли НомерКолонки = 55 Тогда
