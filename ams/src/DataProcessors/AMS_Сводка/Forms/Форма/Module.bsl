
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Дата = ТекущаяДатаСеанса();
	
	УправлениеЭлементамиФормы();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ВывестиСводку();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Запись_РеализацияТоваровУслуг" 
		Или ИмяСобытия = "Запись_ПроизводствоТоваровЗаСмену"
		Или ИмяСобытия = "Запись_ПеремещениеТоваров" 
		Или ИмяСобытия = "Запись_РегистрТоварныеОграничения"
		Или ИмяСобытия = "Запись_РасходныйОрдерНаТовары" 
		Или ИмяСобытия = "Запись_ТоварныеЗапасы" Тогда

		ВывестиСводку();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВозможностиСкладаДатаПриИзменении(Элемент)
	ВозможностиСклада = AMS_ВызовСервера.ПолучитьВозможностиСклада(ВозможностиСкладаДата);
КонецПроцедуры

&НаКлиенте
Процедура ТипПродукцииПриИзменении(Элемент)
	ЗаполнитьНазначениеПродукцииСписокВыбора();
	ВывестиСводку();
КонецПроцедуры

&НаКлиенте
Процедура НазначениеПродукцииПриИзменении(Элемент)
	ВывестиСводку();
КонецПроцедуры

&НаКлиенте
Процедура ВозможностиСкладаПриИзменении(Элемент)
	УстановитьВозможностиСклада();
КонецПроцедуры

&НаКлиенте
Процедура ЦехПриИзменении(Элемент)
	ВывестиСводку();
КонецПроцедуры

&НаКлиенте
Процедура ТабВыбор(Элемент, Область, СтандартнаяОбработка)
	Если СтрНайти(Область.Текст, "+/-") > 0 Тогда
		Если СтрНайти(Область.Текст, "Номенклатура") > 0 Тогда
			Таб.Область("C4:C11").Видимость = Не Таб.Область("C4:C11").Видимость;
			Видимость1 = Таб.Область("C4:C11").Видимость;

		ИначеЕсли СтрНайти(Область.Текст, "Резерв") > 0 Тогда
			Таб.Область("C23:C28").Видимость = Не Таб.Область("C23:C28").Видимость;
			Видимость2 = Таб.Область("C23:C28").Видимость;
		
		ИначеЕсли СтрНайти(Область.Текст, "План цехов") > 0 Тогда
			Таб.Область("C35:C40").Видимость = Не Таб.Область("C35:C40").Видимость;
			Видимость3 = Таб.Область("C35:C40").Видимость;
		
		ИначеЕсли СтрНайти(Область.Текст, "Ожидаемые") > 0 Тогда
			Таб.Область("C44:C63").Видимость = Не Таб.Область("C44:C63").Видимость;
			Видимость4 = Таб.Область("C44:C63").Видимость;
			
		ИначеЕсли СтрНайти(Область.Текст, "План / Факт") > 0 Тогда
			Таб.Область("C66:C71").Видимость = Не Таб.Область("C66:C71").Видимость;
			Видимость5 = Таб.Область("C66:C71").Видимость;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТабОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка, ДополнительныеПараметры)
	СтандартнаяОбработка = Ложь;
	ОбработкаРасшифровки(Элемент.ТекущаяОбласть.Имя, Расшифровка);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОбновить(Команда)
	ВывестиСводку();
КонецПроцедуры

&НаКлиенте
Процедура ЭкспортВEXCEL(Команда)
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок          = "Выберите каталог для сохранения СВОДКИ";
	Диалог.Фильтр             = "Файлы Excel (*.xlsx;*.xls)|*.xlsx;*.xls|";
	Диалог.МножественныйВыбор = Ложь;

	Если Диалог.Выбрать() Тогда
		Состояние("Создание файла EXCEL.");

		ИмяФайла = Диалог.ПолноеИмяФайла;

		ВыгрузитьСводку(ИмяФайла);

		Состояние();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Отчёт_ПроизводствоПродукции(Команда)
	Парам = Новый Структура;
	Парам.Вставить("КлючНазначенияИспользования", "ПроизводствоПродукции");
	ОткрытьФорму("Отчет.AMS_ПроизводствоПродукции.Форма", Парам);
КонецПроцедуры

&НаКлиенте
Процедура Отчёт_ДвижениеТоваров(Команда)
	Парам = Новый Структура;
	Парам.Вставить("КлючНазначенияИспользования", "Сводка номенклатуры");
	ОткрытьФорму("Отчет.AMS_ДвижениеТоваров.Форма", Парам, ЭтотОбъект, "ДвижениеТоваров="
		+ ОбщегоНазначенияКлиент.ДатаСеанса());
КонецПроцедуры

&НаКлиенте
Процедура РасчетТоварныхЗапасов(Команда)
	ОткрытьФорму("Обработка.AMS_Сводка.Форма.ФормаТоварныеЗапасы");
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ВывестиСводку()
	УстановитьПривилегированныйРежим(Истина);

	НомерСтроки = 0;

	Таб.Очистить();
	Таб.ФиксацияСверху=6;
	Таб.ФиксацияСлева=3;

	Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("МакетТовары");

	ОбластьШапка               = Макет.ПолучитьОбласть("Шапка");
	ОбластьИтоги               = Макет.ПолучитьОбласть("Итоги");
	ОбластьТипПродукции        = Макет.ПолучитьОбласть("ТипПродукции");
	ОбластьНазначениеПродукции = Макет.ПолучитьОбласть("НазначениеПродукции");
	ОбластьПодвал              = Макет.ПолучитьОбласть("Подвал");
	ОбластьДетали              = Макет.ПолучитьОбласть("Детали");
	ОбластьСтрока              = ОбластьДетали.Область("Строка");
 	ОбластьПроизв1             = ОбластьДетали.Область("Производство1"); // Колонка ПланХ1	и ФактХ1
	ОбластьПроизв2             = ОбластьДетали.Область("Производство2"); // Колонка ПланХ2	и ФактХ2

	Парам = ПодготовитьПараметрыСводки();
	
	Рез = ПолучитьДанныеСводки(Парам);
	
	ОбластьШапка.Параметры.Заполнить(Парам);
	Таб.Вывести(ОбластьШапка);

	ВыбИтог = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыбИтог.Следующий();

	ОбластьИтоги.Параметры.Заполнить(ВыбИтог);
	Таб.Вывести(ОбластьИтоги);
	
	Таб.НачатьАвтогруппировкуСтрок();
	
	ВыбТип = ВыбИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыбТип.Следующий() Цикл
		ОбластьТипПродукции.Параметры.ТипПродукции = ВыбТип.ТипПродукции;
		Таб.Вывести(ОбластьТипПродукции, 1, "ТипПродукции", Истина);

		ВыбНазначение = ВыбТип.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыбНазначение.Следующий() Цикл
			ОбластьНазначениеПродукции.Параметры.НазначениеПродукции = ВыбНазначение.НазначениеПродукции;
			Таб.Вывести(ОбластьНазначениеПродукции, 2, "НазначениеПродукции", Истина);

			ВыбТовар = ВыбНазначение.Выбрать();
			Пока ВыбТовар.Следующий() Цикл
				НомерСтроки = НомерСтроки + 1;
				
				ОбластьДетали.Параметры.Заполнить(ВыбТовар);
				ОбластьДетали.Параметры.НомерСтроки = НомерСтроки;

				ОбластьСтрока.ЦветФона = ЦветаСтиля.ЦветФонаПоля;
				
				Если ВыбТовар.MIN_1 > 0 Тогда
					ОбластьСтрока.ЦветФона = WebЦвета.ТусклоРозовый;
					
				ИначеЕсли ВыбТовар.MAX <> 0 И ВыбТовар.СвободноИтог > ВыбТовар.MAX Тогда
					ОбластьСтрока.ЦветФона = WebЦвета.СинийСПороховымОттенком;
				КонецЕсли;

				Если ВыбТовар.План1 - ВыбТовар.Факт1 > 5 Или ВыбТовар.Факт1 - ВыбТовар.План1 > 5 Тогда
					ОбластьПроизв1.ЦветФона = WebЦвета.Хаки;
				КонецЕсли;

				Если ВыбТовар.План2 - ВыбТовар.Факт2 > 5 Или ВыбТовар.Факт2 - ВыбТовар.План2 > 5 Тогда
					ОбластьПроизв2.ЦветФона = WebЦвета.Хаки;
				КонецЕсли;
				Таб.Вывести(ОбластьДетали, 4, "Товар", Истина);
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	Таб.ЗакончитьАвтогруппировкуСтрок();
	
	Таб.Вывести(ОбластьПодвал);

	Таб.Область("C4:C11").Видимость = Видимость1;
	Таб.Область("C23:C28").Видимость = Видимость2;
	Таб.Область("C35:C40").Видимость = Видимость3;
	Таб.Область("C44:C63").Видимость = Видимость4; 
	Таб.Область("C66:C71").Видимость = Видимость5; 
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеСводки(Парам) 
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТипПродукции",                  Парам.ТипПродукции);
	Запрос.УстановитьПараметр("СкладПродукции",                Парам.СкладПродукции);
	Запрос.УстановитьПараметр("НазначениеПродукции",           Парам.НазначениеПродукции);
	Запрос.УстановитьПараметр("ВидНоменклатуры",               Парам.ВидНоменклатуры);
	Запрос.УстановитьПараметр("ВидНоменклатурыПродукцияЦеха3", Парам.ВидНоменклатурыПродукцияЦеха3);
	Запрос.УстановитьПараметр("СписокЦехов",                   Парам.СписокЦехов);
	
	Запрос.УстановитьПараметр("Год",    Парам.Год);
	Запрос.УстановитьПараметр("Дата",   Парам.Дата);
	Запрос.УстановитьПараметр("Дата1",  Парам.Дата1);
	Запрос.УстановитьПараметр("Дата2",  Парам.Дата2);
	Запрос.УстановитьПараметр("Дата3",  Парам.Дата3);
	Запрос.УстановитьПараметр("Дата4",  Парам.Дата4);
	Запрос.УстановитьПараметр("Дата5",  Парам.Дата5);
	Запрос.УстановитьПараметр("Дата6",  Парам.Дата6);
	Запрос.УстановитьПараметр("Дата7",  Парам.Дата7);
	Запрос.УстановитьПараметр("Дата8",  Парам.Дата8);
	Запрос.УстановитьПараметр("Дата9",  Парам.Дата9);
	Запрос.УстановитьПараметр("Дата10", Парам.Дата10);
	Запрос.УстановитьПараметр("Дата11", Парам.Дата11);
	Запрос.УстановитьПараметр("Дата12", Парам.Дата12);
	Запрос.УстановитьПараметр("Дата13", Парам.Дата13);
	Запрос.УстановитьПараметр("Дата14", Парам.Дата14);
	Запрос.УстановитьПараметр("Дата15", Парам.Дата15);
	Запрос.УстановитьПараметр("Дата16", Парам.Дата16);
	Запрос.УстановитьПараметр("Дата17", Парам.Дата17);
	Запрос.УстановитьПараметр("Дата18", Парам.Дата18);
	Запрос.УстановитьПараметр("Дата19", Парам.Дата19);
	Запрос.УстановитьПараметр("Дата20", Парам.Дата20);
	Запрос.УстановитьПараметр("Дата21", Парам.Дата21);
	Запрос.УстановитьПараметр("Дата22", Парам.Дата22); 
	Запрос.УстановитьПараметр("НачПро", Парам.НачПро);
	Запрос.УстановитьПараметр("КонПро", Парам.КонПро);

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ном.Артикул КАК Артикул,
	|	т.Номенклатура КАК Номенклатура,
	|	ном.КоэффициентЕдиницыДляОтчетов КАК Кфц,
	|	упак.Числитель / ном.КоэффициентЕдиницыДляОтчетов КАК КоличествоНаПалете,
	|	д.Родитель КАК ТипПродукции,
	|	д.Родитель.Наименование КАК ТипНаименование,
	|	д.Ссылка КАК НазначениеПродукции,
	|	д.Наименование КАК НазначениеНаименование,
	|	ном.ВидНоменклатуры КАК ВидНоменклатуры,
	|	т.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ Прод
	|ИЗ
	|	Справочник.AMS_Продукция КАК д
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция.Товары КАК т
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК упак
	|				ПО (ном.НаборУпаковок = упак.Владелец
	|						ИЛИ ном.Ссылка = упак.Владелец)
	|					И ном._Упаковка = упак.Родитель
	|			ПО т.Номенклатура = ном.Ссылка
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	НЕ д.ЭтоГруппа
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТовОгр.Номенклатура КАК Номенклатура,
	|	ТовОгр.МинимальноеКоличествоЗапаса / Прод.Кфц КАК MIN,
	|	ТовОгр.МаксимальноеКоличествоЗапаса / Прод.Кфц КАК MAX
	|ПОМЕСТИТЬ ТовОрг
	|ИЗ
	|	РегистрСведений.ТоварныеОграничения КАК ТовОгр
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Прод КАК Прод
	|		ПО ТовОгр.Номенклатура = Прод.Номенклатура
	|			И (ТовОгр.Склад = &СкладПродукции)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Прод.Артикул КАК Артикул,
	|	Прод.Номенклатура КАК Номенклатура,
	|	Прод.Кфц КАК Кфц,
	|	Прод.КоличествоНаПалете КАК КоличествоНаПалете,
	|	ЕСТЬNULL(ТовОрг.MIN, 0) КАК MIN,
	|	ЕСТЬNULL(ТовОрг.MAX, 0) КАК MAX,
	|	Прод.ТипПродукции КАК ТипПродукции,
	|	Прод.ТипНаименование КАК ТипНаименование,
	|	Прод.НазначениеПродукции КАК НазначениеПродукции,
	|	Прод.НазначениеНаименование КАК НазначениеНаименование,
	|	Прод.ВидНоменклатуры КАК ВидНоменклатуры,
	|	Прод.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ Тов
	|ИЗ
	|	Прод КАК Прод
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТовОрг КАК ТовОрг
	|		ПО Прод.Номенклатура = ТовОрг.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.КоличествоПлан КАК КоличествоПлан,
	|	т.КоличествоФакт КАК КоличествоФакт,
	|	д.Ссылка КАК Док,
	|	д.Дата КАК Дата,
	|	д.Смена КАК Смена
	|ПОМЕСТИТЬ Цеха
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК д
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ПроизводствоЗаСмену.Продукция КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата7, ДЕНЬ)
	|	И НЕ д.Статус = ЗНАЧЕНИЕ(Перечисление._СтатусыПроизводства.Проект)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫБОР
	|		КОГДА т.ДокументОтгрузки ССЫЛКА Документ.ЗаказКлиента
	|			ТОГДА т.ДокументОтгрузки.ДатаОтгрузки
	|		ИНАЧЕ НАЧАЛОПЕРИОДА(т.ДокументОтгрузки.Дата, ДЕНЬ)
	|	КОНЕЦ КАК Дата,
	|	т.ДокументОтгрузки КАК ДокументОтгрузки,
	|	т.Номенклатура КАК Номенклатура,
	|	(т.КОтгрузкеОстаток + т.ВРезервеОстаток) / т.Номенклатура.КоэффициентЕдиницыДляОтчетов КАК Количество,
	|	ТИПЗНАЧЕНИЯ(т.ДокументОтгрузки) = ТИП(Документ.ЗаказКлиента) КАК ЭтоЗаказКлиента
	|ПОМЕСТИТЬ КОтгр
	|ИЗ
