	Массив.Добавить(Стр);

	Остаток = Остаток + План2;
	Стр = ПолучитьСтруктурыОтчета();
	Стр.Наименование = "План 2-я смена (18)";
	Стр.Приход       = План2;
	Стр.Остаток      = Остаток;
	Массив.Добавить(Стр);

	Остаток = Остаток - Факт2;
	Стр = ПолучитьСтруктурыОтчета();
	Стр.Наименование = "Факт 2-я смена (16)";
	Стр.Расход       = Факт2;
	Стр.Остаток      = Остаток;
	Массив.Добавить(Стр);

	Стр = ПолучитьСтруктурыОтчета();
	Стр.Наименование = "Итого остаток + план (31)";
	Стр.Остаток      = Остаток;
	Массив.Добавить(Стр);

	Шапка = "Свободный остаток + план производства: " + ПолучитьТекстЯчейки(ЛеваяЧасть + 3);
	
	Парам = Новый Структура("Заголовок, Массив", Шапка, Массив);

	ОткрытьФорму(AMS_Клиент.ПолучитьПолноеИмяФормы(ИмяФормы, "ФормаСвободныйОстаток"), Парам, ЭтотОбъект, Шапка);
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьНеобходимоПроизвести(ЛеваяЧасть)
	МинЗапас = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 6);
	Свободно = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 30); 
	
	Если Свободно < МинЗапас Тогда 

		Массив = Новый Массив;
		
		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "Установленный минимальный запас (6)";
		Стр.Приход       = МинЗапас;
		Стр.Остаток      = МинЗапас;
		Массив.Добавить(Стр);

		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "Свободный остаток (30)";
		Стр.Расход       = Свободно;
		Стр.Остаток      = МинЗапас - Свободно;
		Массив.Добавить(Стр);

		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "Необходимо произвести (31)";
		Стр.Остаток      = МинЗапас - Свободно;
		Массив.Добавить(Стр);

		Шапка = "Необходимо произвести: " + ПолучитьТекстЯчейки(ЛеваяЧасть + 3);
	
		Парам = Новый Структура("Заголовок, Массив", Шапка, Массив);

		ОткрытьФорму(AMS_Клиент.ПолучитьПолноеИмяФормы(ИмяФормы, "ФормаСвободныйОстаток"), Парам, ЭтотОбъект, Шапка);
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПланПроизводства(Дата, Номенклатура)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	д.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.AMS_ПланПроизводства КАК д
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ПланПроизводства.Товары КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	д.Год = &Год
	|	И т.Номенклатура = &Номенклатура";
	
	Запрос.УстановитьПараметр("Год", Год(Дата));
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	Выб.Следующий();
	
	Возврат Выб.Ссылка;
КонецФункции

&НаКлиенте
Процедура ПоказатьПроцентВыполнения(ЛеваяЧасть, Парам)
	Массив = Новый Массив;
	
	План = 0;
	Если Парам.Нед1 <= Парам.ТекНеделя Тогда 
		Про1 = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 66);
		План = План + Про1;
		
		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "План производства за неделю №" + Парам.Нед1 + " (66)";
		Стр.Приход = Про1;
		Массив.Добавить(Стр);
	КонецЕсли;

	Если Парам.Нед2 <= Парам.ТекНеделя Тогда 
		Про2 = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 67);
		План = План + Про2;
		
		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "План производства за неделю №" + Парам.Нед2 + " (67)";
		Стр.Приход = Про2;
		Массив.Добавить(Стр);
	КонецЕсли;

	Если Парам.Нед3 <= Парам.ТекНеделя Тогда 
		Про3 = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 68);
		План = План + Про3;
		
		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "План производства за неделю №" + Парам.Нед3 + " (68)";
		Стр.Приход = Про3;
		Массив.Добавить(Стр);
	КонецЕсли;

	Если Парам.Нед4 <= Парам.ТекНеделя Тогда 
		Про4 = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 69);
		План = План + Про4;
		
		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "План производства за неделю №" + Парам.Нед4 + " (69)";
		Стр.Приход = Про4;
		Массив.Добавить(Стр);
	КонецЕсли;

	Если Парам.Нед5 <= Парам.ТекНеделя Тогда 
		Про5 = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 70);
		План = План + Про5;
		
		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "План производства за неделю №" + Парам.Нед5 + " (70)";
		Стр.Приход = Про5;
		Массив.Добавить(Стр);
	КонецЕсли;

	Если Парам.Нед5 <= Парам.ТекНеделя Тогда 
		Про5 = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 71);
		План = План + Про5;
		
		Стр = ПолучитьСтруктурыОтчета();
		Стр.Наименование = "План производства за неделю №" + Парам.Нед5 + " (71)";
		Стр.Приход = Про5;
		Массив.Добавить(Стр);
	КонецЕсли;
	
	Факт = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 72); 
	Стр = ПолучитьСтруктурыОтчета();
	Стр.Наименование = "Фактически произведено (72)";
	Стр.Расход = Факт;
	Массив.Добавить(Стр);

	Стр = ПолучитьСтруктурыОтчета();
	Стр.Наименование = "Итого процент выполнения (73)";
	Стр.Приход = План;
	Стр.Расход = Факт;
	Стр.Остаток = ПолучитьЗначениеЯчейки(ЛеваяЧасть + 73);
	Массив.Добавить(Стр);
		
	Шапка = "Процент выполнения: " + ПолучитьТекстЯчейки(ЛеваяЧасть + 3);

	Парам = Новый Структура("Заголовок, Массив", Шапка, Массив);

	ОткрытьФорму(AMS_Клиент.ПолучитьПолноеИмяФормы(ИмяФормы, "ФормаСвободныйОстаток"), Парам, ЭтотОбъект, Шапка);
КонецПроцедуры

