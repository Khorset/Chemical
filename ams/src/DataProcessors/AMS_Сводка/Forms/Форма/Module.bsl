&НаКлиенте
Процедура ВыгрузитьСводку(ИмяФайла)
	Таб.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.XLSX);

	Попытка
		Excel = Новый COMОбъект("Excel.Application");
		Excel.Visible       = Ложь;
		Excel.DisplayAlerts = Ложь;
		Книга = Excel.WorkBooks.Open(ИмяФайла);
	Исключение
		Текст = "Проблемы с подключением к Excel. " + ОписаниеОшибки();
		ОбщегоНазначенияКлиент.СообщитьПользователю(Текст);
		Возврат;
	КонецПопытки;

	ExcelЛист = Книга.WorkSheets(1);

	Попытка
		ExcelЛист.SaveAs(ИмяФайла);
	Исключение
		Текст =  "Файл не сохранён! " + ОписаниеОшибки();
		ОбщегоНазначенияКлиент.СообщитьПользователю(Текст);
	КонецПопытки;

	Книга.Close();
	Excel.Quit();
КонецПроцедуры

&НаСервере
Процедура УстановитьВозможностиСклада()
	УстановитьПривилегированныйРежим(Истина);

	МенеджерЗаписи = РегистрыСведений._ВозможностиСклада.СоздатьМенеджерЗаписи();

	МенеджерЗаписи.Дата = ВозможностиСкладаДата;

	МенеджерЗаписи.Прочитать();

	Если ВозможностиСклада = 0 Тогда
		Если МенеджерЗаписи.Выбран() Тогда
			МенеджерЗаписи.Удалить();
		КонецЕсли;

	Иначе
		МенеджерЗаписи.Дата       = ВозможностиСкладаДата;
		МенеджерЗаписи.Количество = ВозможностиСклада;
		МенеджерЗаписи.Записать();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УправлениеЭлементамиФормы()
	Если Пользователи.РолиДоступны("_Цех1") Тогда
		Цех = 1;
	ИначеЕсли Пользователи.РолиДоступны("_Цех2") Тогда
		Цех = 2;
	ИначеЕсли Пользователи.РолиДоступны("_Цех3") Тогда
		Цех = 3;
	КонецЕсли;

	Элементы.Цех.СписокВыбора.НайтиПоЗначению(Цех);
	
	Элементы.РасчетТоварныхЗапасов.Видимость = Пользователи.РолиДоступны("AMS_Аналитик");
	
	Элементы.ВозможностиСклада.Доступность = Пользователи.РолиДоступны("_Директор, _СтаршийМенеджер");

	ВозможностиСкладаДата = мср.ПолучитьРабочийДень(1, Дата);
	ВозможностиСклада     = AMS_ВызовСервера.ПолучитьВозможностиСклада(ВозможностиСкладаДата);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	д.Ссылка КАК Ссылка,
	|	д.Наименование КАК Наименование
	|ИЗ
	|	Справочник.AMS_Продукция КАК д
	|ГДЕ
	|	д.ЭтоГруппа
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
	
	Элементы.ТипПродукции.СписокВыбора.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));;
	
	ЗаполнитьНазначениеПродукцииСписокВыбора();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНазначениеПродукцииСписокВыбора()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Родитель", ТипПродукции);
	
	ЗапросТекст = 	
	"ВЫБРАТЬ
	|	д.Ссылка КАК Ссылка,
	|	д.Наименование КАК Наименование
	|ИЗ
	|	Справочник.AMS_Продукция КАК д
	|ГДЕ
	|	Не д.ЭтоГруппа";
	
	Если ЗначениеЗаполнено(ТипПродукции) Тогда
		ЗапросТекст = ЗапросТекст + "
	|	И д.Родитель = &Родитель";
	КонецЕсли;
	
	ЗапросТекст = ЗапросТекст + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
	
	Запрос.Текст = ЗапросТекст;	

	Элементы.НазначениеПродукции.СписокВыбора.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
КонецПроцедуры

