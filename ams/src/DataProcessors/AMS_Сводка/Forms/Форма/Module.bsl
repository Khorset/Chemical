			Период.ДатаОкончания = КонецДня(Парам.Дата15);
		ИначеЕсли НомерКолонки = 57 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата16);
			Период.ДатаОкончания = КонецДня(Парам.Дата16);
		ИначеЕсли НомерКолонки = 58 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата17);
			Период.ДатаОкончания = КонецДня(Парам.Дата17);
