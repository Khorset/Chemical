&НаСервере
Функция ПодготовитьПараметрыСводки()
	НачМесяц = НачалоМесяца(Дата);

	СписокЦехов = Новый Массив();
	СписокЦехов.Добавить(AMS_ВызовСервера.Цех1());
	СписокЦехов.Добавить(AMS_ВызовСервера.Цех2());
	СписокЦехов.Добавить(AMS_ВызовСервера.Цех3());
	
	Если Цех = 1 Тогда
		ВидНоменклатуры = AMS_ВызовСервера.ВидыНоменклатурыЦеха1();
	ИначеЕсли Цех = 2 Тогда
		ВидНоменклатуры = AMS_ВызовСервера.ВидыНоменклатурыЦеха2();
	ИначеЕсли Цех = 3 Тогда
		ВидНоменклатуры = AMS_ВызовСервера.ВидыНоменклатурыЦеха3();
	Иначе
		ВидНоменклатуры = Неопределено;
	КонецЕсли;
	
	Парам = Новый Структура;
	Парам.Вставить("Дата",                Дата);
	Парам.Вставить("ТипПродукции",        ТипПродукции);
	Парам.Вставить("НазначениеПродукции", НазначениеПродукции);
	Парам.Вставить("ВидНоменклатуры",     ВидНоменклатуры);
	
	Парам.Вставить("СкладПродукции", AMS_ВызовСервера.СкладПродукции());
	Парам.Вставить("ВидНоменклатурыПродукцияЦеха3", AMS_ВызовСервера.ВидыНоменклатурыЦеха3());
	Парам.Вставить("СписокЦехов", СписокЦехов); 
	
	Парам.Вставить("Год", Год(Дата));
	Парам.Вставить("Дата1", мср.ПолучитьРабочийДень(1, Дата));
	Парам.Вставить("Дата2", мср.ПолучитьРабочийДень(2, Дата));
	Парам.Вставить("Дата3", мср.ПолучитьРабочийДень(3, Дата));
	Парам.Вставить("Дата4", мср.ПолучитьРабочийДень(4, Дата));
	Парам.Вставить("Дата5", мср.ПолучитьРабочийДень(5, Дата));
	Парам.Вставить("Дата6", мср.ПолучитьРабочийДень(6, Дата));
	Парам.Вставить("Дата7", мср.ПолучитьРабочийДень(7, Дата));
	Парам.Вставить("Дата8", мср.ПолучитьРабочийДень(8, Дата));
	Парам.Вставить("Дата7_",Формат(Парам.Дата8, "ДФ=dd.MM.yy") + " и далее");
	Парам.Вставить("Дата9", мср.ПолучитьРабочийДень(9, Дата));
	Парам.Вставить("Дата10", мср.ПолучитьРабочийДень(10, Дата));
	Парам.Вставить("Дата11", мср.ПолучитьРабочийДень(11, Дата));
	Парам.Вставить("Дата12", мср.ПолучитьРабочийДень(12, Дата));
	Парам.Вставить("Дата13", мср.ПолучитьРабочийДень(13, Дата));
	Парам.Вставить("Дата14", мср.ПолучитьРабочийДень(14, Дата));
	Парам.Вставить("Дата15", мср.ПолучитьРабочийДень(15, Дата));
	Парам.Вставить("Дата16", мср.ПолучитьРабочийДень(16, Дата));
	Парам.Вставить("Дата17", мср.ПолучитьРабочийДень(17, Дата));
	Парам.Вставить("Дата18", мср.ПолучитьРабочийДень(18, Дата));
	Парам.Вставить("Дата19", мср.ПолучитьРабочийДень(19, Дата));
	Парам.Вставить("Дата20", мср.ПолучитьРабочийДень(20, Дата));
	Парам.Вставить("Дата21", мср.ПолучитьРабочийДень(21, Дата));
	Парам.Вставить("Дата22", мср.ПолучитьРабочийДень(22, Дата));
	Парам.Вставить("Дата21_", Формат(Парам.Дата22, "ДФ=dd.MM.yy") + " и далее");
	Парам.Вставить("ТекНеделя", НеделяГода(Дата));
	Парам.Вставить("Нед1", НеделяГода(НачМесяц));
	Парам.Вставить("Нед2", НеделяГода(НачМесяц + 1 * 604800));
	Парам.Вставить("Нед3", НеделяГода(НачМесяц + 2 * 604800));
	Парам.Вставить("Нед4", НеделяГода(НачМесяц + 3 * 604800));
	Парам.Вставить("Нед5", НеделяГода(НачМесяц + 4 * 604800));
	Парам.Вставить("Нед6", НеделяГода(НачМесяц + 5 * 604800));
	Парам.Вставить("НачПро", НачалоНедели(НачМесяц));
	Парам.Вставить("КонПро", КонецНедели(НачМесяц + 5*604800));
	
	Парам.Вставить("Неделя1", "    " + Парам.Нед1 + "   " + Символы.ПС
		+ Формат(НачалоНедели(НачМесяц), "ДФ=dd.MM") + "-" + Формат(КонецНедели(НачМесяц), "ДФ=dd.MM"));
		
	Парам.Вставить("Неделя2", "    " + Парам.Нед2 + "   " + Символы.ПС
		+ Формат(НачалоНедели(НачМесяц + 604800), "ДФ=dd.MM") + "-" + Формат(КонецНедели(НачМесяц + 604800), "ДФ=dd.MM"));
		
	Парам.Вставить("Неделя3", "    " + Парам.Нед3 + "   " + Символы.ПС
		+ Формат(НачалоНедели(НачМесяц + 2*604800), "ДФ=dd.MM") + "-" + Формат(КонецНедели(НачМесяц + 2*604800), "ДФ=dd.MM"));
		
	Парам.Вставить("Неделя4", "    " + Парам.Нед4 + "   " + Символы.ПС
		+ Формат(НачалоНедели(НачМесяц + 3*604800), "ДФ=dd.MM") + "-" + Формат(КонецНедели(НачМесяц + 3*604800), "ДФ=dd.MM"));
		
	Парам.Вставить("Неделя5", "    " + Парам.Нед5 + "   " + Символы.ПС
		+ Формат(НачалоНедели(НачМесяц + 4*604800), "ДФ=dd.MM") + "-" + Формат(КонецНедели(НачМесяц + 4*604800), "ДФ=dd.MM"));

	Парам.Вставить("Неделя6", "    " + Парам.Нед6 + "   " + Символы.ПС
		+ Формат(НачалоНедели(НачМесяц + 5*604800), "ДФ=dd.MM") + "-" + Формат(КонецНедели(НачМесяц + 5*604800), "ДФ=dd.MM"));

	Если ДобавитьМесяц(Парам.Дата22, 12) = Неопределено Тогда
		Текст = "Календарь ""Производственный календарь"" не заполнен. Обратитесь к администратору.";
		ОбщегоНазначения.СообщитьПользователю(Текст);
	КонецЕсли; 
	
	Возврат Парам;
КонецФункции

&НаКлиенте
Процедура ОбработкаРасшифровки(ИмяОбласти, Номенклатура)
	Парам = ПодготовитьПараметрыСводки();
	
	Период = Новый СтандартныйПериод;
	Период.Вариант = ВариантСтандартногоПериода.ПроизвольныйПериод;
	
	СкладПродукции = AMS_ВызовСервера.СкладПродукции();

	ИмяКолонки   = Прав(ИмяОбласти, СтрДлина(ИмяОбласти) - СтрНайти(ИмяОбласти, "C"));
	НомерКолонки = Число(ИмяКолонки);
	ЛеваяЧасть   = Лев(ИмяОбласти, СтрДлина(ИмяОбласти) - СтрДлина(ИмяКолонки));

	Если НомерКолонки > 3 И Не ПолучитьЗначениеЯчейки(ЛеваяЧасть + НомерКолонки) > 0 Тогда 
		Возврат;
	КонецЕсли;
	
	Если НомерКолонки < 8 Тогда
		ПоказатьЗначение( , Номенклатура);

	ИначеЕсли НомерКолонки = 8 Тогда //Остатки продукции на складе
		ПоказатьДвижениеТоваров(Номенклатура, СкладПродукции, КонецДня(Парам.Дата - 86400));

	ИначеЕсли НомерКолонки = 9 Тогда //Остатки продукции в цехе
		ЦехНоменклатуры = AMS_ВызовСервера.ПолучитьЦехНоменклатуры(Номенклатура);
		
		ПоказатьДвижениеТоваров(Номенклатура, ЦехНоменклатуры, КонецДня(Парам.Дата - 86400));

	ИначеЕсли НомерКолонки = 10 Тогда //Просрочена отгрузка
		Шапка = "Просрочена отгрузка: " + Номенклатура;
		
		Период.ДатаНачала    = Парам.Дата - 2592000;
		Период.ДатаОкончания = КонецДня(Парам.Дата - 86400);

		Парам = Новый Структура;
		Парам.Вставить("Период",       Период);
		Парам.Вставить("Номенклатура", Номенклатура);
		Парам.Вставить("Склад",        СкладПродукции);
		Парам.Вставить("Резерв",       Истина);
		Парам.Вставить("БезЗаказов",   Истина); //показать только реализации
		Парам.Вставить("Заголовок",    Шапка);
	
		ОткрытьФорму(AMS_Клиент.ПолучитьПолноеИмяФормы(ИмяФормы, "ФормаКОтгрузке"), Парам, ЭтотОбъект, Шапка);
	
	ИначеЕсли НомерКолонки = 11 Тогда
		ПоказатьСвободныйОстатокНаУтро(ЛеваяЧасть);
		
	ИначеЕсли НомерКолонки = 12 Тогда // Приход на склад
		ПоказатьПриходНаСклад(Номенклатура, СкладПродукции);
		
	ИначеЕсли НомерКолонки = 13 Тогда //Расход на складе
		Период = Новый СтандартныйПериод;
		Период.Вариант = ВариантСтандартногоПериода.Сегодня;

		ПользовательскиеНастройки = Новый Структура;
		ПользовательскиеНастройки.Вставить("Период", Период);

		Отбор = Новый Структура;
		Отбор.Вставить("Номенклатура", Номенклатура);
		Отбор.Вставить("Склад", СкладПродукции);

		Парам = Новый Структура;
		Парам.Вставить("КлючНазначенияИспользования", "СкладПродукции");
		Парам.Вставить("СформироватьПриОткрытии", Истина);
		Парам.Вставить("ВидимостьКомандВариантовОтчетов", Ложь);
		Парам.Вставить("Отбор", Отбор);
		Парам.Вставить("ПользовательскиеНастройки", ПолучитьИзВременногоХранилища(
			AMS_ВызовСервера.ПолучитьАдресПользовательскиеНастройки("AMS_ДвижениеТоваров", ПользовательскиеНастройки,
			"ДвижениеТоваров")));
		
	ОткрытьФорму("Отчет.AMS_ДвижениеТоваров.Форма", Парам, ЭтотОбъект, Строка(Период) + Номенклатура + СкладПродукции);

	ИначеЕсли НомерКолонки = 14 Тогда //Оформлено к отгрузке
		Шапка = "К отгрузке: " + Номенклатура;

		Период.ДатаНачала    = НачалоДня(Парам.Дата);
		Период.ДатаОкончания = КонецДня(Парам.Дата);

		Парам = Новый Структура;
		Парам.Вставить("Период",       Период);
		Парам.Вставить("Номенклатура", Номенклатура);
		Парам.Вставить("Склад",        СкладПродукции);
		Парам.Вставить("Резерв",       Истина);
		Парам.Вставить("БезЗаказов",   Истина); //показать только реализации
		Парам.Вставить("Заголовок",    Шапка);
	
		ОткрытьФорму(AMS_Клиент.ПолучитьПолноеИмяФормы(ИмяФормы, "ФормаКОтгрузке"), Парам, ЭтотОбъект, Шапка);
	
	ИначеЕсли НомерКолонки = 15 Тогда
		ПоказатьСвободныйОстатокНаВечер(ЛеваяЧасть);
		
	ИначеЕсли НомерКолонки = 16 Или НомерКолонки = 17 Тогда
		Период.ДатаНачала    = НачалоДня(Дата);
		Период.ДатаОкончания = КонецДня(Дата);
		Смена = ПредопределенноеЗначение("Перечисление._ПроизводственныеСмены.Дневная");
		
		ПоказатьДокументыПроизводства(Номенклатура, Смена, Период);
		
	ИначеЕсли НомерКолонки = 18 Или НомерКолонки = 19 Тогда
		Период.ДатаНачала    = НачалоДня(Дата);
		Период.ДатаОкончания = КонецДня(Дата);
		Смена = ПредопределенноеЗначение("Перечисление._ПроизводственныеСмены.Вечерняя");
		
		ПоказатьДокументыПроизводства(Номенклатура, Смена, Период);
		
	ИначеЕсли НомерКолонки = 20 Тогда //Текущий остаток в цехе
		ЦехНоменклатуры = AMS_ВызовСервера.ПолучитьЦехНоменклатуры(Номенклатура);
		
		ПоказатьДвижениеТоваров(Номенклатура, ЦехНоменклатуры, КонецДня(Дата)); 

	ИначеЕсли НомерКолонки >= 21 И НомерКолонки <= 29 Тогда
		Если НомерКолонки = 21 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата1);
			Период.ДатаОкончания = КонецДня(Парам.Дата1);
		ИначеЕсли НомерКолонки = 22 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата2);
			Период.ДатаОкончания = КонецДня(Парам.Дата2);
		ИначеЕсли НомерКолонки = 23 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата3);
			Период.ДатаОкончания = КонецДня(Парам.Дата3);
		ИначеЕсли НомерКолонки = 24 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата4);
			Период.ДатаОкончания = КонецДня(Парам.Дата4);
		ИначеЕсли НомерКолонки = 25 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата5);
			Период.ДатаОкончания = КонецДня(Парам.Дата5);
		ИначеЕсли НомерКолонки = 26 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата6);
			Период.ДатаОкончания = КонецДня(Парам.Дата6);
		ИначеЕсли НомерКолонки = 27 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата7);
			Период.ДатаОкончания = КонецДня(Парам.Дата7);
		ИначеЕсли НомерКолонки = 28 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата8);
			Период.ДатаОкончания = ДобавитьМесяц(КонецДня(Парам.Дата8), 60);
		ИначеЕсли НомерКолонки = 29 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата1);
			Период.ДатаОкончания = ДобавитьМесяц(КонецДня(Парам.Дата8), 60);
		КонецЕсли;
			
		Шапка = "Резерв: " + Номенклатура;
		
		Парам = Новый Структура;
		Парам.Вставить("Период",       Период);
		Парам.Вставить("Номенклатура", Номенклатура);
		Парам.Вставить("Склад",        СкладПродукции);
		Парам.Вставить("Резерв",       Истина);
		Парам.Вставить("БезЗаказов",   Ложь); //показать заказы и реализации
		Парам.Вставить("Заголовок",    Шапка);
	
		ОткрытьФорму(AMS_Клиент.ПолучитьПолноеИмяФормы(ИмяФормы, "ФормаКОтгрузке"), Парам, ЭтотОбъект, Шапка + НомерКолонки);
		
	ИначеЕсли НомерКолонки = 30 Тогда
		ПоказатьСвободныйОстатокИтог(ЛеваяЧасть);
		
	ИначеЕсли НомерКолонки = 31 Тогда
		ПоказатьСвободныйОстатокИтогПлюсПлан(ЛеваяЧасть);
		
	ИначеЕсли НомерКолонки = 32 Тогда
		ПоказатьНеобходимоПроизвести(ЛеваяЧасть);
		
	ИначеЕсли НомерКолонки >= 33 И НомерКолонки <= 41 Тогда
		Смена = Неопределено;
		
		Если НомерКолонки = 33 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата1);
			Период.ДатаОкончания = КонецДня(Парам.Дата1);
			Смена = ПредопределенноеЗначение("Перечисление._ПроизводственныеСмены.Дневная");
		ИначеЕсли НомерКолонки = 34 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата1);
			Период.ДатаОкончания = КонецДня(Парам.Дата1);
			Смена = ПредопределенноеЗначение("Перечисление._ПроизводственныеСмены.Вечерняя");
		ИначеЕсли НомерКолонки = 35 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата2);
			Период.ДатаОкончания = КонецДня(Парам.Дата2);
		ИначеЕсли НомерКолонки = 36 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата3);
			Период.ДатаОкончания = КонецДня(Парам.Дата3);
		ИначеЕсли НомерКолонки = 37 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата4);
			Период.ДатаОкончания = КонецДня(Парам.Дата4);
		ИначеЕсли НомерКолонки = 38 Тогда
			Период.ДатаНачала    = НачалоДня(Парам.Дата5);
			Период.ДатаОкончания = КонецДня(Парам.Дата5);
		ИначеЕсли НомерКолонки = 39 Тогда
