      <calculatedFields>
        <dataPath>ЭтоТвердаяСтавка</dataPath>
        <expression>КатегорияПодакцизногоТовара.ТипСтавки = ЗНАЧЕНИЕ(Перечисление.ТипыСтавокПодакцизнойКатегории.Твердая)</expression>
        <title>
          <localValue>
            <content>
              <key>ru</key>
              <value>Это твердая ставка</value>
            </content>
          </localValue>
        </title>
        <useRestriction>
          <group>true</group>
          <order>true</order>
        </useRestriction>
        <valueType>
          <types>Boolean</types>
        </valueType>
      </calculatedFields>
      <calculatedFields>
        <dataPath>АвтозаполнениеКоэффициентаПересчета</dataPath>
        <expression>ЕСТЬNULL(Ссылка.ЕдиницаИзмерения.ТипИзмеряемойВеличины, ИСТИНА) = ЕСТЬNULL(КатегорияПодакцизногоТовара.ЕдиницаИзмерения.ТипИзмеряемойВеличины, ЛОЖЬ)</expression>
        <title>
          <localValue>
            <content>
              <key>ru</key>
              <value>Автозаполнение коэффициента пересчета</value>
            </content>
          </localValue>
        </title>
        <useRestriction>
          <group>true</group>
          <order>true</order>
        </useRestriction>
        <valueType>
          <types>Boolean</types>
        </valueType>
      </calculatedFields>
      <calculatedFields>
        <dataPath>ЕдиницаИзмеренияНоменклатурыВКатегорию</dataPath>
        <expression>ВЫБОР
	КОГДА КоэффициентПересчета > 0
	ТОГДА ПРЕДСТАВЛЕНИЕ(КатегорияПодакцизногоТовара.ЕдиницаИзмерения) + &quot;/&quot; +
		ПРЕДСТАВЛЕНИЕ(ЕдиницаИзмерения)
	ИНАЧЕ &quot;&quot;
КОНЕЦ</expression>
        <title>
          <localValue>
            <content>
              <key>ru</key>
              <value>Единица измерения номенклатуры в категорию</value>
            </content>
          </localValue>
        </title>
        <useRestriction>
          <group>true</group>
          <order>true</order>
        </useRestriction>
        <valueType>
          <types>String</types>
          <stringQualifiers/>
        </valueType>
      </calculatedFields>
