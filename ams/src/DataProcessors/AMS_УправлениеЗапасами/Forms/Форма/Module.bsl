#Область ОбработчикиСобытийЭлементовТаблицыФормыТовары

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
    Имя = Поле.Имя;
	
	Номенклатура = Элемент.ТекущиеДанные.Номенклатура;
    
    Если Имя = "ТоварыНомерПоПорядку" или Имя = "ТоварыНоменклатура" или Имя = "ТоварыУпаковка" Тогда 
        ПоказатьЗначение(,Номенклатура);
		
	Иначе
 	    Если Имя = "ТоварыСклад" Тогда 
	        Склад = AMS_ВызовСервера.СкладПродукции();
			
		ИначеЕсли Имя = "ТоварыБрак" Тогда
			Склад = AMS_ВызовСервера.СкладБракованнойПродукции();
			
		ИначеЕсли Имя = "ТоварыКарантин" Тогда 
			Склад = AMS_ВызовСервера.СкладКарантин();
			
	    ИначеЕсли Имя = "ТоварыЦех1" Тогда 
	        Склад = AMS_ВызовСервера.Цех1();
			
	    ИначеЕсли Имя = "ТоварыЦех2" Тогда 
	        Склад = AMS_ВызовСервера.Цех2();
			
	    ИначеЕсли Имя = "ТоварыЦех3" Тогда 
	        Склад = AMS_ВызовСервера.Цех3();
			
	    ИначеЕсли Имя = "ТоварыЦех4" Тогда 
	        Склад = AMS_ВызовСервера.Цех4();
			
 	    ИначеЕсли Имя = "ТоварыЦех1_" Тогда 
			Склад = AMS_ВызовСервера.Цех1_МатериалыВПроизводстве();
			
 	    ИначеЕсли Имя = "ТоварыЦех2_" Тогда 
			Склад = AMS_ВызовСервера.Цех2_МатериалыВПроизводстве();
			
 	    ИначеЕсли Имя = "ТоварыЦех3_" Тогда 
			Склад = AMS_ВызовСервера.Цех3_МатериалыВПроизводстве();
			
 	    ИначеЕсли Имя = "ТоварыЦех4_" Тогда 
			Склад = AMS_ВызовСервера.Цех4_МатериалыВПроизводстве();
			
 	    ИначеЕсли Имя = "ТоварыЛаб" Тогда 
			Склад = AMS_ВызовСервера.СкладЛаборатория();
			
 	    ИначеЕсли Имя = "ТоварыМосква" Тогда 
			Склад = AMS_ВызовСервера.СкладМосква();
			
 	    ИначеЕсли Имя = "ТоварыМО" Тогда 
			Склад = AMS_ВызовСервера.СкладМО();
			
	    ИначеЕсли Имя = "ТоварыСкладКомпании" Тогда 
	        Склад = AMS_ВызовСервера.СкладКомпании();
			
	    ИначеЕсли Имя = "ТоварыТНЦ" Тогда 
	        Склад = AMS_ВызовСервера.СкладТНЦ();
			
		ИначеЕсли Имя = "ТоварыРасход" Тогда 
	        Склад = AMS_ВызовСервера.СкладРасходныхМатериалов();
	    КонецЕсли;
	        
	    Отбор = Новый Структура;
	    Отбор.Вставить("Номенклатура",Номенклатура);
        Отбор.Вставить("Склад",Склад);  
	    
		Период = Новый СтандартныйПериод;
		Период.Вариант       = ВариантСтандартногоПериода.ПроизвольныйПериод;
		Период.ДатаНачала    = НачалоПериода;
		Период.ДатаОкончания = КонецГода(ОбщегоНазначенияКлиент.ДатаСеанса());
	    
	    ПользовательскиеНастройки = Новый Структура;
	    ПользовательскиеНастройки.Вставить("Период",Период);
	        
	    ПараметрыФормы = Новый Структура;
	    ПараметрыФормы.Вставить("СформироватьПриОткрытии",Истина);
	    ПараметрыФормы.Вставить("КлючНазначенияИспользования","УпрЗапасами" + Номенклатура + Склад);
	    ПараметрыФормы.Вставить("ВидимостьКомандВариантовОтчетов",Ложь);
	    ПараметрыФормы.Вставить("Отбор",Отбор);
		ПараметрыФормы.Вставить("КлючВарианта","ДвижениеТоваров");
		ПараметрыФормы.Вставить("ПользовательскиеНастройки",
			ПолучитьИзВременногоХранилища(AMS_ВызовСервера.ПолучитьАдресПользовательскиеНастройки(
				"AMS_ДвижениеТоваров", ПользовательскиеНастройки, "ДвижениеТоваров")));

		ОткрытьФорму("Отчет.AMS_ДвижениеТоваров.Форма",ПараметрыФормы);
    КонецЕсли;
КонецПроцедуры

#КонецОбласти

