#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьОтчет(Команда)
	СформироватьОтчет();
КонецПроцедуры

&НаКлиенте
Процедура Печать(Команда)
	ТабДок = Новый ТабличныйДокумент;
	
	ПоказатьНоменклатуруПоставщиков(ТабДок,Истина);
	
	ИдентификаторПечатнойФормы = "НоменклатураПоставщиков";
    НазваниеПечатнойФормы = НСтр("ru = 'Таблица соответствия наименований номенклатуры'");
    
    Если Не ОбщегоНазначенияКлиент.ПодсистемаСуществует("СтандартныеПодсистемы.Печать") Тогда
        ТабДок.Показать(НазваниеПечатнойФормы);
		//ДокументыПечатались = Истина;
        Возврат;
    КонецЕсли;     
	МодульУправлениеПечатьюКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("УправлениеПечатьюКлиент");     
	КоллекцияПечатныхФорм = МодульУправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(ИдентификаторПечатнойФормы);
	ПечатнаяФорма = МодульУправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, ИдентификаторПечатнойФормы);
	ПечатнаяФорма.СинонимМакета = НазваниеПечатнойФормы;
	ПечатнаяФорма.ТабличныйДокумент = ТабДок;
	ПечатнаяФорма.ИмяФайлаПечатнойФормы = НазваниеПечатнойФормы;
	
	ОбластиОбъектов = Новый СписокЗначений;
	МодульУправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм, ОбластиОбъектов);

	//ДокументыПечатались = Истина;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура СформироватьОтчет()
   УправлениеЭлементамиФормы();
   
   ИмяСтр = Элементы.Страницы.ТекущаяСтраница.Имя;
    
    Если ИмяСтр = "СтраницаНоменклатура" Тогда
		ПоказатьНоменклатуру();
		
	ИначеЕсли ИмяСтр = "СтраницаСпецификации" Тогда
		ПоказатьСпецификации();
		
	ИначеЕсли ИмяСтр = "СтраницаМатериалы" Тогда
		ПоказатьМатериал();
		
	ИначеЕсли ИмяСтр = "СтраницаНоменклатураПоставщиков" Тогда
		ПоказатьНоменклатуруПоставщиков(НоменклатураПоставщиков);

	ИначеЕсли ИмяСтр = "СтраницаКлассификаторы" Тогда
		ПоказатьКлассификаторы();
    
    ИначеЕсли ИмяСтр = "СтраницаПараметрыАналитики" Тогда
    	ПоказатьПараметрыАналитики();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УправлениеЭлементамиФормы()
	Элементы.Цех.Видимость = ОтборПоЦеху;
	
	Элементы.СтраницаПараметрыАналитики.Видимость = Пользователи.РолиДоступны("AMS_Маркетолог");
	
	Элементы.ГруппаСклады.Видимость = (Элементы.Страницы.ТекущаяСтраница=Элементы.СтраницаНоменклатура);
	Элементы.ГруппаОтбор.Видимость = Не (Элементы.Страницы.ТекущаяСтраница=Элементы.СтраницаПараметрыАналитики);
	
	Элементы.ТоварыГруппаПродукция.Видимость              = ОтборСкладыПродукции;
	Элементы.ТоварыГруппаПроизводство.Видимость           = ОтборСкладыПродукции Или ОтборСкладыМатериалов;
	Элементы.ТоварыГруппаМатериалыВПроизводстве.Видимость = ОтборСкладыМатериалов;
	Элементы.ТоварыГруппаОбразцы.Видимость                = ОтборСкладыПродукции;
	Элементы.ТоварыГруппаПрочие.Видимость                 = ОтборСкладыПрочие; 
КонецПроцедуры

&НаСервере
Процедура ПоказатьНоменклатуру()
	Товары.Очистить();
	
	Если ЗначениеЗаполнено(МемоИерархияНоменклатуры) Тогда 
		Рез = ПолучитьРезультатЗапросаПоНоменклатуре();
		Выб = Рез.Выбрать();
	    НомерСтроки = 0;
		
		Пока Выб.Следующий() Цикл
			НомерСтроки = НомерСтроки + 1;
			Стр = Товары.Добавить();
			ЗаполнитьЗначенияСвойств(Стр,Выб);
			Стр.НомерПоПорядку = НомерСтроки;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ИерархияНоменклатурыПриАктивизацииСтрокиОбработчикОжидания() Экспорт
	Если МемоИерархияНоменклатуры = Элементы.ИерархияНоменклатуры.ТекущаяСтрока Тогда
		Возврат;
	КонецЕсли;
	
	МемоИерархияНоменклатуры = Элементы.ИерархияНоменклатуры.ТекущаяСтрока;
	
	СформироватьОтчет();
КонецПроцедуры

&НаСервере
Процедура ПоказатьСпецификации()
	Материал  = AMS_ВызовСервера.ВидНоменклатурыМатериал();
	Основные  = AMS_ВызовСервера.ВидНоменклатурыОсновные();
	Расходные = AMS_ВызовСервера.ВидНоменклатурыРасходные();
	Услуга    = AMS_ВызовСервера.ВидНоменклатурыУслуга();
	
	Продукция.Очистить();
	ПродукцияСписокСпецификаций.Очистить();
	СпецификацияПродукции = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник._ВариантыСпецификацийНоменклатуры.ПустаяСсылка");
	
	Если ЗначениеЗаполнено(МемоИерархияНоменклатуры) Тогда 
		Рез = ПолучитьРезультатЗапросаПоНоменклатуре();
		Выб = Рез.Выбрать();
	    НомерСтроки = 0;
		
		Пока Выб.Следующий() Цикл
			Если Не (Выб.ВидНоменклатуры = Материал Или Выб.ВидНоменклатуры = Основные Или Выб.ВидНоменклатуры = Расходные Или Выб.ВидНоменклатуры = Услуга) Тогда 
				НомерСтроки = НомерСтроки + 1;
				Стр = Продукция.Добавить();
				ЗаполнитьЗначенияСвойств(Стр,Выб);
				Стр.НомерПоПорядку = НомерСтроки;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПродукцияПриАктивизацииСтрокиОбработчикОжидания() Экспорт
	Стр = Элементы.Продукция.ТекущиеДанные;
	
	Если Стр <> Неопределено Тогда
		Номенклатура = Стр.Номенклатура;
		
		Если МемоПродукция = Номенклатура Тогда
			Возврат;
		КонецЕсли;
		
		МемоПродукция = Номенклатура;
		ЗаполнитьСписокСпецификаций(МемоПродукция,"ПродукцияСписокСпецификаций");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокСпецификаций(Владелец,Таблица)
	Схема = Обработки.AMS_УправлениеЗапасами.ПолучитьМакет("СписокСпецификаций");
	
	Настройки = Схема.НастройкиПоУмолчанию;
	
	ПолеВладелец = Новый ПараметрКомпоновкиДанных("Владелец");
	Для каждого Элемент Из Настройки.ПараметрыДанных.Элементы Цикл
		Если Элемент.Параметр = ПолеВладелец Тогда
			Элемент.Использование = Истина;
			Элемент.Значение = Владелец;
		КонецЕсли;
	КонецЦикла;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Макет = КомпоновщикМакета.Выполнить(Схема,Настройки,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(Макет,,,Истина);
	
    ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
    
    Табл = РеквизитФормыВЗначение(Таблица);
    Табл.Очистить();
	ПроцессорВывода.УстановитьОбъект(Табл);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	ЗначениеВРеквизитФормы(Табл,Таблица);
КонецПроцедуры

&НаСервере
Процедура ПоказатьМатериал()
	Материал = AMS_ВызовСервера.ВидНоменклатурыМатериал();
	Основные = AMS_ВызовСервера.ВидНоменклатурыОсновные();
	Расходные = AMS_ВызовСервера.ВидНоменклатурыРасходные();
	
	Материалы.Очистить();
	ПродукцияФабрикаты.Очистить();
	МатериалыСписокСпецификаций.Очистить();
	СпецификацияМатериала = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник._ВариантыСпецификацийНоменклатуры.ПустаяСсылка");
	
	Если ЗначениеЗаполнено(МемоИерархияНоменклатуры) Тогда 
		Рез = ПолучитьРезультатЗапросаПоНоменклатуре();
		Выб = Рез.Выбрать();
	    НомерСтроки = 0;
		
		Пока Выб.Следующий() Цикл
			Если Выб.ВидНоменклатуры = Материал Или Выб.ВидНоменклатуры = Основные Или Выб.ВидНоменклатуры = Расходные Тогда 
				НомерСтроки = НомерСтроки + 1;
				Стр = Материалы.Добавить();
				ЗаполнитьЗначенияСвойств(Стр,Выб);
				Стр.НомерПоПорядку = НомерСтроки;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура МатериалыПриАктивизацииСтрокиОбработчикОжидания() Экспорт 
    Стр = Элементы.Материалы.ТекущиеДанные;
    
    Если Стр = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Номенклатура = Стр.Номенклатура;
    
    Если Номенклатура = МемоМатериал Тогда
		Возврат;
	Иначе
		МемоМатериал = Номенклатура;
	КонецЕсли;
	
    ПоказатьПродукцияФабрикаты(Номенклатура);
КонецПроцедуры

&НаСервере
Процедура ПоказатьПродукцияФабрикаты(Номенклатура)
	МатериалыСписокСпецификаций.Очистить();
	СпецификацияМатериала = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник._ВариантыСпецификацийНоменклатуры.ПустаяСсылка");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("СегментыНоменклатурыСтарая", AMS_ВызовСервера.СегментыНоменклатурыСтарая());

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК т
	|ГДЕ
	|	т.Сегмент = &СегментыНоменклатурыСтарая
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Спец.Владелец КАК Номенклатура,
	|	Спец.Владелец.Наименование КАК ВладелецНаименование
	|ИЗ
	|	Справочник._ВариантыСпецификацийНоменклатуры.Товары КАК Тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник._ВариантыСпецификацийНоменклатуры КАК Спец
	|		ПО Тов.Ссылка = Спец.Ссылка
	|ГДЕ
	|	НЕ Спец.ПометкаУдаления
	|	И Спец.Статус = ЗНАЧЕНИЕ(Перечисление._СтатусыСпецификаций.Действует)
	|	И Тов.Номенклатура = &Номенклатура
	|	И НЕ Спец.Владелец В
	|		(ВЫБРАТЬ
	|			т.Номенклатура КАК Номенклатура
	|		ИЗ
	|			вт КАК т)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВладелецНаименование";
	Результат = Запрос.Выполнить();
    Выборка   = Результат.Выбрать();
    
	Табл = РеквизитФормыВЗначение("ПродукцияФабрикаты");
	Табл.Очистить();
	
	НомерСтроки = 0;
    Пока Выборка.Следующий() Цикл
		НомерСтроки = НомерСтроки + 1;
        Стр = Табл.Добавить();
        Стр.СистемныеПоляНомерПоПорядку = НомерСтроки;
		Стр.Номенклатура                = Выборка.Номенклатура;
    КонецЦикла; 
	
	ЗначениеВРеквизитФормы(Табл,"ПродукцияФабрикаты");
КонецПроцедуры

&НаКлиенте
Процедура ПродукцияФабрикатыПриАктивизацииСтрокиОбработчикОжидания() Экспорт 
    Стр = Элементы.ПродукцияФабрикаты.ТекущиеДанные;
    
    Если Стр = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Номенклатура = Стр.Номенклатура;
    
    Если Номенклатура = МемоПродукцияФабрикат Тогда
		Возврат;
	Иначе
		МемоПродукцияФабрикат = Номенклатура;
	КонецЕсли;
	
    ЗаполнитьСписокСпецификаций(Номенклатура,"МатериалыСписокСпецификаций");
КонецПроцедуры

&НаСервере
Процедура ПоказатьНоменклатуруПоставщиков(ТабДок,ЭтоПечать = Ложь)
	ТабДок.Очистить();
	
	Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("НоменклатураПоставщиков");
	
	Утверждаю = Макет.ПолучитьОбласть("Утверждаю");
	Шапка     = Макет.ПолучитьОбласть("Шапка");
	Строка_   = Макет.ПолучитьОбласть("Строка_");
	Строка    = Макет.ПолучитьОбласть("Строка");
	Черта     = Макет.ПолучитьОбласть("Черта");

	Если ЭтоПечать Тогда
		ТабДок.Вывести(Утверждаю);
	КонецЕсли;

	ТабДок.Вывести(Шапка);

	Рез = ПолучитьРезультатЗапросаПоНоменклатуреПоставщиков();
	
	НомерСтроки = 0;
	МемоТовар      = Неопределено;
	
	Выб = Рез.Выбрать();
	Пока Выб.Следующий() Цикл
		Если МемоТовар = Выб.Номенклатура Тогда
			Парам = Строка.Параметры;
			ЗаполнитьЗначенияСвойств(Парам,Выб); 
			
			Парам.Номенклатура = Неопределено; 
			Парам.Код          = Неопределено; 
			Парам.ЕдКод        = Неопределено; 
			Парам.НомерСтроки  = Неопределено;
			
			ТабДок.Вывести(Строка);
		Иначе
			Парам = Строка_.Параметры;
			ЗаполнитьЗначенияСвойств(Парам,Выб); 
			
			НомерСтроки = НомерСтроки + 1;
			Парам.НомерСтроки  = НомерСтроки; 
			
			ТабДок.Вывести(Строка_);
		КонецЕсли;
		
		МемоТовар = Выб.Номенклатура; 
	КонецЦикла; 
	
	ТабДок.Вывести(Черта);
КонецПроцедуры

&НаСервере
Функция ПолучитьРезультатЗапросаПоНоменклатуреПоставщиков()
	Запрос = Новый Запрос;
	
    Если ОтборПоЦеху Тогда
		Сегменты = Новый Массив;
		
		Если Цех = AMS_ВызовСервера.Цех1() Тогда
	    	Сегменты.Добавить(AMS_ВызовСервера.СегментыНоменклатурыМатериалыЦеха1());
	    	Сегменты.Добавить(AMS_ВызовСервера.СегментыНоменклатурыУпаковкаЦеха1());
		
		ИначеЕсли Цех = AMS_ВызовСервера.Цех2() Тогда
	    	Сегменты.Добавить(AMS_ВызовСервера.СегментыНоменклатурыМатериалыЦеха2());
	    	Сегменты.Добавить(AMS_ВызовСервера.СегментыНоменклатурыУпаковкаЦеха2());
		
		ИначеЕсли Цех = AMS_ВызовСервера.Цех3() Тогда
	    	Сегменты.Добавить(AMS_ВызовСервера.СегментыНоменклатурыМатериалыЦеха3());
	    	Сегменты.Добавить(AMS_ВызовСервера.СегментыНоменклатурыУпаковкаЦеха3());
		
		ИначеЕсли Цех = AMS_ВызовСервера.Цех4() Тогда
	    	Сегменты.Добавить(AMS_ВызовСервера.СегментыНоменклатурыМатериалыЦеха4());
		КонецЕсли;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ОтборПоЦеху",         ОтборПоЦеху);
	Запрос.УстановитьПараметр("Сегменты",            Сегменты);
	Запрос.УстановитьПараметр("ИерархияНоменклатуры",МемоИерархияНоменклатуры);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	н.Код КАК Код,
	|	т.Упаковка.Код КАК ЕдКод,
	|	т.Упаковка КАК Ед,
	|	т.Ссылка КАК НоменклатураПоставщика,
	|	т.ВладелецНоменклатуры КАК Поставщик,
	|	т.КодОКЕИБазовойЕдиницыИзмерения КАК ЕдКодПоставщика,
	|	т.НаименованиеУпаковки КАК ЕдПоставщика
	|ИЗ
	|	Справочник.НоменклатураКонтрагентов КАК т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК н
	|		ПО т.Номенклатура = н.Ссылка
	|ГДЕ
	|	НЕ т.ПометкаУдаления
	|	И т.Владелец.Поставщик
	|	И НЕ т.Недействителен
	|	И НЕ т.НаименованиеНоменклатуры = т.Номенклатура.Наименование
	|	И НЕ т.Номенклатура В
	|				(ВЫБРАТЬ
	|					т.Номенклатура КАК Номенклатура
	|				ИЗ
	|					РегистрСведений.НоменклатураСегмента КАК т
	|				ГДЕ
	|					т.Сегмент.Наименование = ""Старая"")
	|	И т.Номенклатура В ИЕРАРХИИ(&ИерархияНоменклатуры)
	|	И ВЫБОР
	|			КОГДА &ОтборПоЦеху
	|				ТОГДА т.Номенклатура В
	|						(ВЫБРАТЬ
	|							т.Номенклатура КАК Номенклатура
	|						ИЗ
	|							РегистрСведений.НоменклатураСегмента КАК т
	|						ГДЕ
	|							т.Сегмент В (&Сегменты))
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	н.Наименование";
	
	Возврат Запрос.Выполнить();
КонецФункции

&НаСервере
Процедура ПоказатьКлассификаторы()
	Классификаторы.Очистить();
	
	Если ЗначениеЗаполнено(МемоИерархияНоменклатуры) Тогда 
		Рез = ПолучитьРезультатЗапросаПоНоменклатуре();
		Выб = Рез.Выбрать();
	    НомерСтроки = 0;
		
		Пока Выб.Следующий() Цикл
			НомерСтроки = НомерСтроки + 1;
			Стр = Классификаторы.Добавить();
			ЗаполнитьЗначенияСвойств(Стр,Выб);
			Стр.НомерПоПорядку = НомерСтроки;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПоказатьПараметрыАналитики()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СкладПродукции", AMS_ВызовСервера.СкладПродукции());
	Запрос.УстановитьПараметр("ВидыНоменклатуры", AMS_ВызовСервера.ВидыНоменклатурыПродукции());
	Запрос.УстановитьПараметр("ВидНоменклатурыПродукцияЦеха1", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха1());
	Запрос.УстановитьПараметр("ВидНоменклатурыПродукцияЦеха2", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха2());
	Запрос.УстановитьПараметр("ВидНоменклатурыПродукцияЦеха3", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха3());
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ном.Артикул КАК Артикул,
		|	т.Номенклатура КАК Номенклатура,
		|	ВЫРАЗИТЬ(ном.НаименованиеПолное КАК СТРОКА(50)) КАК НаименованиеПолное,
		|	ВЫБОР
		|		КОГДА ном.ВидНоменклатуры = &ВидНоменклатурыПродукцияЦеха1
		|			ТОГДА ""Цех 1""
		|		КОГДА ном.ВидНоменклатуры = &ВидНоменклатурыПродукцияЦеха2
		|			ТОГДА ""Цех 2""
		|		КОГДА ном.ВидНоменклатуры = &ВидНоменклатурыПродукцияЦеха3
		|			ТОГДА ""Цех 3""
		|	КОНЕЦ КАК Склад,
		|	РеквНом.Статус КАК Статус,
		|	ном.Марка КАК Бренд,
		|	РеквНом.Вид КАК Вид,
		|	РеквНом.Тип КАК Тип,
		|	РеквНом.Категория КАК Категория,
		|	РеквНом.Назначение КАК Назначение,
		|	РеквНом.МаксимальныйОбъемЗамеса,
		|	РеквНом.МинимальныйОбъемЗамеса,
		|	РеквНом.КоличествоФабрикатаВУпаковке
