#Область Аналитика

&НаСервере
Процедура ЗаписатьРеквизитНоменклатуры(Реквизит, Номенклатура, Значение)
	УстановитьПривилегированныйРежим(Истина);
	
	Если Реквизит = "Бренд" Тогда
		НоменклатураОбъект = Номенклатура.ПолучитьОбъект();
		НоменклатураОбъект.Марка = Значение;
		НоменклатураОбъект.Записать();
		
	Иначе 	
		Запись = РегистрыСведений.AMS_РеквизитыНоменклатуры.СоздатьМенеджерЗаписи();

		Запись.Номенклатура = Номенклатура;

		Запись.Прочитать();

		Запись.Номенклатура = Номенклатура;
		Запись[Реквизит]    = Значение;

		Запись.Записать(); 
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#КонецОбласти
