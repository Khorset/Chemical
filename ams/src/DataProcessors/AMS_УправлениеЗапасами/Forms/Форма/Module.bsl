	Массив = Новый Массив();
	
	Стр = Элементы.ПродукцияАналитика.ТекущиеДанные;
	
	Если Стр.Вид = ПредопределенноеЗначение("Перечисление.AMS_НоменклатураВид.Непрофессиональная")
		И Стр.Тип = ПредопределенноеЗначение("Перечисление.AMS_НоменклатураТип.БытоваяХимия") Тогда

		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляВанны"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляДома"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляКухни"));
				
	ИначеЕсли Стр.Вид = ПредопределенноеЗначение("Перечисление.AMS_НоменклатураВид.Профессиональная")
		И Стр.Тип = ПредопределенноеЗначение("Перечисление.AMS_НоменклатураТип.БытоваяХимия") Тогда
		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляВанны"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляОфиса"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляКухни"));

	ИначеЕсли Стр.Вид = ПредопределенноеЗначение("Перечисление.AMS_НоменклатураВид.Непрофессиональная")
		И Стр.Тип = ПредопределенноеЗначение("Перечисление.AMS_НоменклатураТип.Косметика") Тогда
		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.МылоЖидкое"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляВолос"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляДетей"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляЛица"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляРук"));		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.ДляТела"));		

	ИначеЕсли Стр.Вид = ПредопределенноеЗначение("Перечисление.AMS_НоменклатураВид.Профессиональная")
		И Стр.Тип = ПредопределенноеЗначение("Перечисление.AMS_НоменклатураТип.Косметика") Тогда
		
		Массив.Добавить(ПредопределенноеЗначение("Перечисление.AMS_НоменклатураКатегория.МылоЖидкое"));	
	КонецЕсли;	
	
	Элементы.ПродукцияАналитикаКатегория.СписокВыбора.ЗагрузитьЗначения(Массив);
