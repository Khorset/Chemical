КонецФункции

&НаКлиенте
Процедура ОбновлениеСписков_ЕГАИС()
	
	ТекДанные = Элементы.СписокДокументов_ЕГАИС.ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		ТабАнализа.Параметры.УстановитьЗначениеПараметра("Ссылка", Неопределено);
		ТабДокумента_ЕГАИС.Параметры.УстановитьЗначениеПараметра("Ссылка", Неопределено);
		//ТабАнализа.Параметры.УстановитьЗначениеПараметра("ИсходныйДокумент", Неопределено);
		
		Возврат;
	КонецЕсли;   
	
	ЗаменитьЗапрос_ЕГАИС(ТекДанные.Ссылка);
	
	Попытка ТабАнализа_ЕГАИС.Параметры.УстановитьЗначениеПараметра("Ссылка", ТекДанные.Ссылка); Исключение КонецПопытки;
	Попытка ТабАнализа_ЕГАИС.Параметры.УстановитьЗначениеПараметра("ИсходныйДокумент", ТекДанные.ИсходныйДокумент); Исключение КонецПопытки;
	Попытка ТабДокумента_ЕГАИС.Параметры.УстановитьЗначениеПараметра("Ссылка", ТекДанные.Ссылка); Исключение КонецПопытки;
	
	Если ТекДанные.ДатаЗавершенияСбора = Дата(1,1,1) Тогда
		Элементы.ГруппаВидаДанных.ТекущаяСтраница = Элементы.грДанные;
	Иначе	
		Элементы.ГруппаВидаДанных.ТекущаяСтраница = Элементы.грАнализ;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере                                                             	
Процедура ЗаменитьЗапрос_ЕГАИС(Элемент)
	
	Элемент = Элементы.СписокДокументов_ЕГАИС.ТекущаяСтрока;
	
	Если Не ЗначениеЗаполнено(Элемент) Тогда
		ТабАнализа.ТекстЗапроса = "ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК ХарактеристикаНоменклатуры,
		|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК ЕдиницаИзмерения,
		|	0 КАК План,
		|	0 КАК Факт,
		|	0 КАК Расхождения,
		|	"""" КАК Поле1,
		|	"""" КАК Поле2";
		Возврат;
	КонецЕсли;
	
	Если Элемент.Шаблон.ЕГАИС Тогда
		ТабАнализа_ЕГАИС.ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
		|	СУММА(ВложенныйЗапрос.План) КАК План,
		|	СУММА(ВложенныйЗапрос.Факт) КАК Факт,
		|	СУММА(-ВложенныйЗапрос.План + ВложенныйЗапрос.Факт) КАК Расхождения,
		|	ВложенныйЗапрос.ТипСтроки,
		|	ВложенныйЗапрос.Название
		|ИЗ
		|	(ВЫБРАТЬ
		|		СобранныеДанныеПодбор.НоменклатураЕГАИС КАК Номенклатура,
		|		0 КАК План,
		|		СобранныеДанныеПодбор.Количество КАК Факт,
		|		""Подбор"" КАК ТипСтроки,
		|		"""" КАК Название
		|	ИЗ
		|		Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК СобранныеДанныеПодбор
		|	ГДЕ
		|		СобранныеДанныеПодбор.Ссылка = &Ссылка
		|	
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ТаблицаДокумента1СПодбор.АлкогольнаяПродукция,
		|		ТаблицаДокумента1СПодбор.Количество,
		|		0,
		|		""Подбор"",
		|		""""
		|	ИЗ
		|		Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ТаблицаДокумента1СПодбор 
		|			
		|	ГДЕ
		|		ТаблицаДокумента1СПодбор.Ссылка = &ИсходныйДокумент) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.ТипСтроки,
		|	ВложенныйЗапрос.Номенклатура,
		|	ВложенныйЗапрос.Название
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВложенныйЗапрос.ТипСтроки,
		|	Номенклатура
		|"; 	
		
		ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса, "Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ТаблицаДокумента1СПодбор",
										"Документ." + Элемент.Шаблон.ВидДокумента + "." + Элемент.Шаблон.ИмяТабличнойЧастиПодбор + " КАК ТаблицаДокумента1СПодбор");							
		
		Если Элемент.Шаблон.ГрупповаяРабота И Элемент.ДатаЗавершения = Дата(1,1,1) Тогда
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса, "Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор", "РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов");
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса, "СобранныеДанныеПодбор.Ссылка = &Ссылка", "СобранныеДанныеПодбор.ДокументТСД = &Ссылка И НЕ СобранныеДанныеПодбор.ДляОбмена И СобранныеДанныеПодбор.ИмяТаблицы = ""Select""");
		КонецЕсли;
		
		
		Если Элемент.Шаблон.ВидДокумента = "ДатаМобайл_УпаковочныйЛист" Или Элемент.Шаблон.ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад" Тогда	
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса, "ТаблицаДокумента1СПодбор.АлкогольнаяПродукция", "ТаблицаДокумента1СПодбор.ЕГАИС_Номенклатура");
		ИначеЕсли Элемент.Шаблон.ВидДокумента = "алкАктФиксацииШтрихкодовНаБалансеОрганизацииЕГАИС" Тогда	
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса, "ТаблицаДокумента1СПодбор.Количество", "999");
		КонецЕсли;
		
		Если Элемент.Шаблон.ВидДокумента = "РеализацияТоваровУслуг" 
			Или Элемент.Шаблон.ВидДокумента = "ЗаказКлиента" 
			Или Элемент.Шаблон.ВидДокумента = "ПеремещениеТоваров"
			Или Элемент.Шаблон.ВидДокумента = "ПересчетТоваров"
			Или Элемент.Шаблон.ВидДокумента = "СписаниеНедостачТоваров" 
			Или Элемент.Шаблон.ВидДокумента = "ОрдерНаОтражениеНедостачТоваров"
			Или Элемент.Шаблон.ВидДокумента = "ВозвратТоваровПоставщику" 
			Или Элемент.Шаблон.ПроверкаЗадания = 3 Или Элемент.Шаблон.ПроверкаЗадания = 6 Тогда
			
			ТабАнализа_ЕГАИС.ТекстЗапроса = "ВЫБРАТЬ
			|	ВложенныйЗапрос.ТипСтроки КАК ТипСтроки,
			|	ВложенныйЗапрос.Название КАК Название,
			|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
			|	СУММА(ВложенныйЗапрос.План) КАК План,
			|	СУММА(ВложенныйЗапрос.Факт) КАК Факт,
			|	СУММА(-ВложенныйЗапрос.План + ВложенныйЗапрос.Факт) КАК Расхождения
			|ПОМЕСТИТЬ ВременнаяТаблица
			|ИЗ
			|	(ВЫБРАТЬ
			//|		СобранныеДанныеПодбор.НоменклатураЕГАИС КАК Номенклатура,
			|		СобранныеДанныеПодбор.Номенклатура КАК Номенклатура,
			|		0 КАК План,
			|		ВЫРАЗИТЬ(СобранныеДанныеПодбор.Количество * ВЫБОР
			|				КОГДА СобранныеДанныеПодбор.ЕдиницаИзмерения.Числитель ЕСТЬ NULL
			|					ТОГДА 1
			|				КОГДА СобранныеДанныеПодбор.ЕдиницаИзмерения.Числитель = 0
			|					ТОГДА 1
			|				ИНАЧЕ СобранныеДанныеПодбор.ЕдиницаИзмерения.Числитель
			|			КОНЕЦ КАК ЧИСЛО(19, 3)) КАК Факт,
			|		""Подбор"" КАК ТипСтроки,
			|		"""" КАК Название
			|	ИЗ
			|		Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК СобранныеДанныеПодбор
			|	ГДЕ
			|		СобранныеДанныеПодбор.Ссылка = &Ссылка
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		ТаблицаДокумента1СПодбор.Номенклатура,
			//|		МАКСИМУМ(ЕстьNULL(СоответствиеНоменклатурыЕГАИС.АлкогольнаяПродукция,ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяССылка))),
			|		ТаблицаДокумента1СПодбор.Количество,
			|		0,
			|		""Подбор"",
			|		"""" КАК Название
			|	ИЗ
			|		Документ.РеализацияТоваровУслуг.Товары КАК ТаблицаДокумента1СПодбор
			//|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.алкСоответствияАлкогольнойПродукцииЕГАИСИНоменклатуры КАК СоответствиеНоменклатурыЕГАИС
			//|			ПО СоответствиеНоменклатурыЕГАИС.Номенклатура = ТаблицаДокумента1СПодбор.Номенклатура
			|	ГДЕ
			|		ТаблицаДокумента1СПодбор.Ссылка = &ИсходныйДокумент) КАК ВложенныйЗапрос
			|
			|СГРУППИРОВАТЬ ПО
			|	ВложенныйЗапрос.ТипСтроки,
			|	ВложенныйЗапрос.Название,
			|	ВложенныйЗапрос.Номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВременнаяТаблица.ТипСтроки,
			|	ВременнаяТаблица.Название,
			|	ВременнаяТаблица.Номенклатура,
			|	ВременнаяТаблица.План,
			|	ВременнаяТаблица.Факт,
			|	ВременнаяТаблица.Расхождения
			|ИЗ
			|	ВременнаяТаблица КАК ВременнаяТаблица
			|ГДЕ
			|	(ВременнаяТаблица.План > 0
			|			ИЛИ ВременнаяТаблица.Факт > 0)";
			
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса, "Документ.РеализацияТоваровУслуг.Товары КАК ТаблицаДокумента1СПодбор",
											"Документ." + Элемент.Шаблон.ВидДокумента + "." + Элемент.Шаблон.ИмяТабличнойЧастиПодбор + " КАК ТаблицаДокумента1СПодбор");							
			
			Если Элемент.Шаблон.ГрупповаяРабота И Элемент.ДатаЗавершения = Дата(1,1,1) Тогда
				ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса, "Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор", "РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов");
				ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса, "СобранныеДанныеПодбор.Ссылка = &Ссылка", "СобранныеДанныеПодбор.ДокументТСД = &Ссылка И НЕ СобранныеДанныеПодбор.ДляОбмена И  СобранныеДанныеПодбор.ИмяТаблицы = ""Select""");
			КонецЕсли;			
		КонецЕсли;		
	КонецЕсли;
	
	Попытка ТабАнализа_ЕГАИС.Параметры.УстановитьЗначениеПараметра("ИсходныйДокумент", Элемент.ИсходныйДокумент); Исключение КонецПопытки;
	
КонецПроцедуры         	

&НаСервере
Функция ТекстЗапросаТабАнализа_ЕГАИС(Элемент, Расшифровка = Ложь, ТекстСообщенияОбОшибке = "")
	
	Если Расшифровка Тогда		
		//Вызывается для расшифровки по коробам и маркам в тч ТабАнализа_ЕГАИС
		ТекстСообщенияОбОшибке = "";
		
		Если ТипЗнч(Элемент.ИсходныйДокумент) <> Тип("ДокументСсылка.алкТоварноТранспортнаяНакладнаяЕГАИС")
			Или ТипЗнч(Элемент.ИсходныйДокумент) = Тип("ДокументСсылка.алкТоварноТранспортнаяНакладнаяЕГАИС") 
			И Элемент.ИсходныйДокумент.ВидДокумента <> Перечисления.алкВидыДокументовЕГАИС.Входящий Тогда
			ТекстСообщенияОбОшибке = "Расшифровку можножно сделать только к документу ТТН ЕГАИС входящий!" + Символы.ПС;
			Возврат Неопределено;
		КонецЕсли;
		
		ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СобранныеДанныеПодбор.НоменклатураЕГАИС КАК Номенклатура,
		|	0 КАК План,
		|	СобранныеДанныеПодбор.Количество КАК Факт,
		|	СобранныеДанныеПодбор.Короб КАК Короб,
		|	СобранныеДанныеПодбор.ЕгаисПолныйКод КАК Марка
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК СобранныеДанныеПодбор
		|ГДЕ
		|	СобранныеДанныеПодбор.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Товары.АлкогольнаяПродукция,
		|	ВЫБОР
		|		КОГДА АкцизныеМарки.Ссылка ЕСТЬ NULL
		|			ТОГДА Товары.Количество
		|		ИНАЧЕ 1
		|	КОНЕЦ,
		|	0,
		|	АкцизныеМарки.НомерКоробки,
		|	АкцизныеМарки.КодАкцизнойМарки
		|ИЗ
		|	Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.АкцизныеМарки КАК АкцизныеМарки
		|		ПО Товары.КлючСвязи = АкцизныеМарки.КлючСвязи
		|			И (АкцизныеМарки.Ссылка = &ИсходныйДокумент)
		|ГДЕ
		|	Товары.Ссылка = &ИсходныйДокумент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
		|	ВложенныйЗапрос.Короб КАК Короб,
		|	ВложенныйЗапрос.Марка КАК Марка,
		|	СУММА(ВложенныйЗапрос.План) КАК План,
		|	СУММА(ВложенныйЗапрос.Факт) КАК Факт,
		|	СУММА(-ВложенныйЗапрос.План + ВложенныйЗапрос.Факт) КАК Расхождения
		|ИЗ
		|	вт КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Номенклатура,
		|	ВложенныйЗапрос.Короб,
		|	ВложенныйЗапрос.Марка
		|
		|ИМЕЮЩИЕ
		|	(СУММА(ВложенныйЗапрос.План) > 0
		|		ИЛИ СУММА(ВложенныйЗапрос.Факт) > 0)";
		
	Иначе
		ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
		|	""Подбор"" КАК ТипСтроки,
		|	СУММА(ВложенныйЗапрос.План) КАК План,
		|	СУММА(ВложенныйЗапрос.Факт) КАК Факт,
		|	СУММА(-ВложенныйЗапрос.План + ВложенныйЗапрос.Факт) КАК Расхождения
		|ИЗ
		|	(ВЫБРАТЬ
		|		СобранныеДанныеПодбор.НоменклатураЕГАИС КАК Номенклатура,
		|		0 КАК План,
		|		СобранныеДанныеПодбор.Количество КАК Факт
		|	ИЗ
		|		Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК СобранныеДанныеПодбор
		|	ГДЕ
		|		СобранныеДанныеПодбор.Ссылка = &Ссылка
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ТаблицаДокумента1СПодбор.АлкогольнаяПродукция,
		|		ТаблицаДокумента1СПодбор.Количество,
		|		0
		|	ИЗ
		|		&ТаблицаДокумента1СПодбор КАК ТаблицаДокумента1СПодбор
		|	ГДЕ
		|		ТаблицаДокумента1СПодбор.Ссылка = &ИсходныйДокумент) КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Номенклатура
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура";
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
	"&ТаблицаДокумента1СПодбор",
	"Документ."+Элемент.Шаблон.ВидДокумента + "." + Элемент.Шаблон.ИмяТабличнойЧастиПодбор);							
	
	Если Элемент.Шаблон.ГрупповаяРабота И Элемент.ДатаЗавершения = Дата(1,1,1) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
		"Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор",
		"РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
		"СобранныеДанныеПодбор.Ссылка = &Ссылка",
		"СобранныеДанныеПодбор.ДокументТСД = &Ссылка И НЕ СобранныеДанныеПодбор.ДляОбмена И СобранныеДанныеПодбор.ИмяТаблицы = ""Select""");
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере                                                             	
Процедура ПодготовитьЗапрос_ТабАнализа_ЕГАИС(Элемент)
	
	Если Не ЗначениеЗаполнено(Элемент) Тогда Возврат; КонецЕсли;
	
	Если Элемент.Шаблон.ЕГАИС Тогда		
		ТабАнализа_ЕГАИС.ТекстЗапроса = ТекстЗапросаТабАнализа_ЕГАИС(Элемент);
		
		Если Элемент.Шаблон.ВидДокумента = "ДатаМобайл_УпаковочныйЛист" Или Элемент.Шаблон.ВидДокумента = "ДатаМобайл_ЗаявкаНаСклад" Тогда	
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса,
			"ТаблицаДокумента1СПодбор.АлкогольнаяПродукция",
			"ТаблицаДокумента1СПодбор.ЕГАИС_Номенклатура");
			
		ИначеЕсли Элемент.Шаблон.ВидДокумента = "алкАктФиксацииШтрихкодовНаБалансеОрганизацииЕГАИС" Тогда	
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса,
			"ТаблицаДокумента1СПодбор.Количество",
			"999");
			
		ИначеЕсли Элемент.Шаблон.ВидДокумента = "РеализацияТоваровУслуг" 
			Или Элемент.Шаблон.ВидДокумента = "ЗаказКлиента" 
			Или Элемент.Шаблон.ВидДокумента = "ПеремещениеТоваров"
			Или Элемент.Шаблон.ВидДокумента = "ПересчетТоваров"
			Или Элемент.Шаблон.ВидДокумента = "СписаниеНедостачТоваров" 
			Или Элемент.Шаблон.ВидДокумента = "ОрдерНаОтражениеНедостачТоваров"
			Или Элемент.Шаблон.ВидДокумента = "ВозвратТоваровПоставщику"
			Или Элемент.Шаблон.ПроверкаЗадания = 3 Или Элемент.Шаблон.ПроверкаЗадания = 6 Тогда
			
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса,
			"СобранныеДанныеПодбор.НоменклатураЕГАИС",
			"СобранныеДанныеПодбор.Номенклатура");
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса,
			"ТаблицаДокумента1СПодбор.АлкогольнаяПродукция",
			"ТаблицаДокумента1СПодбор.Номенклатура");
			ТабАнализа_ЕГАИС.ТекстЗапроса = СтрЗаменить(ТабАнализа_ЕГАИС.ТекстЗапроса,
			"СобранныеДанныеПодбор.Количество",
			"ВЫРАЗИТЬ(СобранныеДанныеПодбор.Количество * ВЫБОР
			|				КОГДА СобранныеДанныеПодбор.ЕдиницаИзмерения.Числитель ЕСТЬ NULL
			|					ТОГДА 1
			|				КОГДА СобранныеДанныеПодбор.ЕдиницаИзмерения.Числитель = 0
			|					ТОГДА 1
			|				ИНАЧЕ СобранныеДанныеПодбор.ЕдиницаИзмерения.Числитель
			|			КОНЕЦ КАК ЧИСЛО(19, 3))");
			
			ТабАнализа_ЕГАИС.ТекстЗапроса = ТабАнализа_ЕГАИС.ТекстЗапроса + Символы.ПС + 
			"ИМЕЮЩИЕ
			|	(СУММА(ВложенныйЗапрос.План) > 0
			|		ИЛИ СУММА(ВложенныйЗапрос.Факт) > 0)";			
		КонецЕсли;
		
		ТабАнализа_ЕГАИС.Параметры.УстановитьЗначениеПараметра("ИсходныйДокумент", Элемент.ИсходныйДокумент);
		
	Иначе 	
		ТабАнализа_ЕГАИС.ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СобранныеДанные.Номенклатура КАК Номенклатура,
		|	СобранныеДанные.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
		|	0 КАК План,
		|	СУММА(СобранныеДанные.Количество) КАК Факт,
		|	СУММА(СобранныеДанные.Количество) КАК Расхождения,
		|	""Размещение"" КАК ТипСтроки
		|ИЗ
		|	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС.СобранныеДанныеПодбор КАК СобранныеДанные
		|ГДЕ
		|	СобранныеДанные.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	СобранныеДанные.ХарактеристикаНоменклатуры,
		|	СобранныеДанные.Номенклатура
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура,
		|	ХарактеристикаНоменклатуры";		
	КонецЕсли;
	
	ТабАнализа_ЕГАИС.Параметры.УстановитьЗначениеПараметра("Ссылка", Элемент.Ссылка);
	
КонецПроцедуры         	

&НаКлиенте
Процедура СписокДокументовПриАктивизацииЯчейки_ЕГАИС(Элемент)
	
	ПодключитьОбработчикОжидания("ОбновлениеСписков_ЕГАИС", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаблокироватьДокумент_ЕГАИС(Команда)
	
	ТекДанные=Элементы.СписокДокументов_ЕГАИС.ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	СтрокаОшибок = ""; 
	
	Если не ЗаблокироватьДокументПоСтроке_ЕГАИС(ТекДанные.Ссылка, СтрокаОшибок) Тогда
		Сообщить("Не удалось:" + СтрокаОшибок);
		Возврат;
	КонецЕсли; 
	
	ПроверкаПланФакт(ТекДанные.Ссылка);
	ОповеститьобИзменении(ТекДанные.Ссылка); 
	
КонецПроцедуры

&НаКлиенте
Процедура РазблокироватьДокумент_ЕГАИС(Команда)
	
	ТекДанные = Элементы.СписокДокументов_ЕГАИС.ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	СтрокаОшибок = "";
	
	Если Не РазблокироватьДокументПоСтроке_ЕГАИС(ТекДанные.Ссылка, СтрокаОшибок) Тогда
		Сообщить("Не удалось:" + СтрокаОшибок);
		Возврат;
	КонецЕсли;
	
	ОповеститьобИзменении(ТекДанные.Ссылка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗаблокироватьДокументПоСтроке_ЕГАИС(Элемент, СтрокаОшибок)
	
	ДокументОб = Элемент.ПолучитьОбъект();
	
	Если ДокументОб.ДатаЗавершения <> Дата(1,1,1) Тогда
		СтрокаОшибок = "Документ уже закрыт!!";
		Возврат Ложь;
	КонецЕсли;
	
	Если ДокументОб.ДатаЗавершенияСбора = Дата(1,1,1) Тогда
		СтрокаОшибок = "Документ не завершен на ТСД!!";
		Возврат Ложь;
	КонецЕсли;
	
	ДокументОб.ДатаПриемкиОператором=ТекущаяДата();
	ДокументОб.ОбменДанными.Получатели.АвтоЗаполнение = Истина;
	
	Для каждого СтрТЧ Из ДокументОб.СобранныеДанныеПодбор Цикл
		Обработки.ДатаМобайл_АРМДиспетчера.УстановитьЕдиницу(СтрТЧ, Ложь);
	КонецЦикла;	
	
	ДокументОб.Записать();
	
	Возврат Истина;
	
КонецФункции	

&НаСервереБезКонтекста
Функция РазблокироватьДокументПоСтроке_ЕГАИС(Элемент, СтрокаОшибок)
	
	ДокументОб = Элемент.ПолучитьОбъект();
	
	Если ДокументОб.ДатаЗавершения <> Дата(1,1,1) Тогда
		СтрокаОшибок = "Документ уже закрыт!!";
		Возврат Ложь;
	КонецЕсли;	
	
	ДокументОб.ДатаПриемкиОператором = "";
	ДокументОб.ДатаЗавершенияСбора = "";
	ДокументОб.ОбменДанными.Получатели.АвтоЗаполнение = Истина;
	ДокументОб.Записать();
	
	Возврат Истина;
	
КонецФункции	

&НаСервереБезКонтекста
Функция СоздатьДокументПоСтроке_ЕГАИС(Элемент, СтрокаОшибок)
	
	ДокументОб = Элемент.ПолучитьОбъект();  
	
	Если ДокументОб.ДатаПриемкиОператором = Дата(1,1,1) Тогда
		СтрокаОшибок = "Документ надо сначала заблокировать!!";
		Возврат Неопределено;
	КонецЕсли;	
	
	Если ДокументОб.ДатаЗавершения <> Дата(1,1,1) Тогда
		СтрокаОшибок = "Документ уже закрыт!!";
		Возврат Неопределено;
	КонецЕсли;	 
	
	Возврат Обработки.ДатаМобайл_АРМДиспетчера.ВнестиДокументВБазу_ЕГАИС(ДокументОб, СтрокаОшибок);
	
КонецФункции

&НаСервереБезКонтекста
Функция ИмяОбъекта_ЕГАИС(Элемент)
	
	Если СокрЛП(Элемент.Шаблон.ВидДокументаНового) = "" Тогда //старая схема
		Возврат СокрЛП(Элемент.Шаблон.ВидДокумента);
		
	Иначе //новая схема
		Если СокрЛП(Элемент.Шаблон.ВидДокумента) = "ДатаМобайл_ЗаявкаНаСклад" 
			И СокрЛП(Элемент.Шаблон.ВидДокументаНового) = "алкТоварноТранспортнаяНакладнаяЕГАИС" 
			И Не ЗначениеЗаполнено(Элемент.НовыйДокумент) Тогда //реализация для ТТН ЕГАИС
			Возврат "РеализацияТоваровУслуг";
			
		ИначеЕсли СокрЛП(Элемент.Шаблон.ВидДокумента) = "ЗаказКлиента" 
			И СокрЛП(Элемент.Шаблон.ВидДокументаНового) = "алкТоварноТранспортнаяНакладнаяЕГАИС" 
			И Не ЗначениеЗаполнено(Элемент.НовыйДокумент) Тогда //реализация для ТТН ЕГАИС
			Возврат "РеализацияТоваровУслуг";
			
		ИначеЕсли (СокрЛП(Элемент.Шаблон.ВидДокумента) = "СписаниеНедостачТоваров" Или СокрЛП(Элемент.Шаблон.ВидДокумента) = "ОрдерНаОтражениеНедостачТоваров") 
			И СокрЛП(Элемент.Шаблон.ВидДокументаНового) = "алкАктОСписанииТовара" 
			И Не ЗначениеЗаполнено(Элемент.ИсходныйДокумент) Тогда //списание для ЕГАИС акта
			Возврат СокрЛП(Элемент.Шаблон.ВидДокумента);
		Иначе
			Возврат СокрЛП(Элемент.Шаблон.ВидДокументаНового);
		КонецЕсли;
	КонецЕсли;	
	
КонецФункции	

&НаСервереБезКонтекста
Функция ИмяОбъектаВЗапросе_ЕГАИС(Элемент)
	
	Возврат Элемент.Шаблон.ВидДокумента + "." + Элемент.Шаблон.ИмяТабличнойЧасти;
	
КонецФункции	

&НаКлиенте
Процедура ВнестиВБазу_ЕГАИС(Команда)
	
	ТекДанные = Элементы.СписокДокументов_ЕГАИС.ТекущиеДанные;
	
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаОшибок = "";
	
	Док = СоздатьДокументПоСтроке_ЕГАИС(ТекДанные.Ссылка, СтрокаОшибок);
	
	Если Док = Неопределено Тогда
		Сообщить("Не удалось:" + СтрокаОшибок);
		Возврат;
	КонецЕсли;
	
	ОповеститьобИзменении(ТекДанные.Ссылка);
	
	Если Док = "" Тогда
		Возврат;
	КонецЕсли;	
	
	ПоказатьЗначение(, Док);
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыВРаботе_ЕГАИС(Команда)
	
	ДатаМобайл_ОбщегоНазначенияКлиентСервер = ДатаМобайл_ОбщийМодульКлиент.ОбщийМодуль("ОбщегоНазначенияКлиентСервер");
	
	Если Элементы.СписокДокументов_ЕГАИСДокументыВРаботе_ЕГАИС.Пометка Тогда		
		ДатаМобайл_ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(СписокДокументов_ЕГАИС, "ДатаЗавершения");
		ДатаМобайл_ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(СписокДокументов_ЕГАИС, "ПометкаУдаления");
		
		Элементы.СписокДокументов_ЕГАИСДокументыВРаботе_ЕГАИС.Пометка = Ложь;
	Иначе		
		ДатаМобайл_ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(СписокДокументов_ЕГАИС, "ДатаЗавершения", Дата(1,1,1), ВидСравненияКомпоновкиДанных.Равно,, Истина);
		ДатаМобайл_ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(СписокДокументов_ЕГАИС, "ПометкаУдаления", Ложь, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		
		Элементы.СписокДокументов_ЕГАИСДокументыВРаботе_ЕГАИС.Пометка = Истина;
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Функция СтруктураПараметровДляРасшифровкиПоКоробкамЕГАИС(Элемент, Номенклатура)
	
	ТекстОшибки = "";
	ТекстЗапросаТабАнализа_ЕГАИС = ТекстЗапросаТабАнализа_ЕГАИС(Элемент, Истина, ТекстОшибки);
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Сообщить(ТекстОшибки);
	Иначе
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ТекстЗапроса", ТекстЗапросаТабАнализа_ЕГАИС);
		СтруктураПараметров.Вставить("ИсходныйДокумент", Элемент.ИсходныйДокумент);
		СтруктураПараметров.Вставить("Ссылка", Элемент);
		СтруктураПараметров.Вставить("Номенклатура", Номенклатура);
		Возврат СтруктураПараметров;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Процедура ПоказатьРасшифровкуПоКоробамЕГАИС(Команда)
	
	ТекущиеДанные1 = Элементы.СписокДокументов_ЕГАИС.ТекущиеДанные;
	ТекущиеДанные2 = Элементы.ТабАнализа_ЕГАИС.ТекущиеДанные;
	
	Если ТекущиеДанные1 <> Неопределено И ТекущиеДанные2 <> Неопределено Тогда
		Если ЗначениеЗаполнено(ТекущиеДанные1.Ссылка) Тогда
			СтруктураПараметров = СтруктураПараметровДляРасшифровкиПоКоробкамЕГАИС(ТекущиеДанные1.Ссылка, ТекущиеДанные2.Номенклатура);
			
			Если ЗначениеЗаполнено(СтруктураПараметров) Тогда
				ОткрытьФорму("Обработка.ДатаМобайл_АРМДиспетчера.Форма.ФормаРасшифровкаПоКоробамЕГАИС",
				СтруктураПараметров,,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			КонецЕсли; 
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

// Вкладка АГРЕГАЦИЯ
&НаСервереБезКонтекста
Функция ЗаданыНастройкиПечати(НастройкиПечати, СтруктураПоиска);
	
	СтрокиРеквизитов = НастройкиПечати.Печать.НайтиСтроки(СтруктураПоиска);	
	
	Если СтрокиРеквизитов.Количество() = 0 тогда	
		Возврат Ложь;
	КонецЕсли;	
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ПечатьУпаковкиРАР()
	
	//--------------------------------------------------------------------------------------------------------------
	// Печать упаковки РАР
	//--------------------------------------------------------------------------------------------------------------
	
	//ТипУпаковки - 1 - короб, 2 - палета, 3 - сборный короб, 4 - сборная палета 
	
	Модуль_МенеджерОборудованияВызовСервера = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("МенеджерОборудованияВызовСервера");
	Модуль_ГенерацияШтрихкода 				= ДатаМобайл_ОбщийМодуль.ОбщийМодуль("ГенерацияШтрихкода");
	
	Если Агрегация_ТипЭтикетки = 1 Или Агрегация_ТипЭтикетки = 3 Тогда
		СтруктураПоиска = Новый Структура("ТипОперации", "ЕГАИС Печать короба");
	ИначеЕсли Агрегация_ТипЭтикетки = 2 Или Агрегация_ТипЭтикетки = 4 Тогда
		СтруктураПоиска = Новый Структура("ТипОперации", "ЕГАИС Печать палеты");	
	КонецЕсли;
	
	СтрокиРеквизитов = Агрегация_НастройкиПечати.Печать.НайтиСтроки(СтруктураПоиска);	
	
	Если СтрокиРеквизитов.Количество() = 0 Тогда
		Сообщить("В настройках печати Не указаны шаблоны.");	
		Возврат Неопределено;
	КонецЕсли;	
	
	ТекущаяНастройкаПечати = СтрокиРеквизитов[0];
	
	ТЗДанныхПечати = Новый ТаблицаЗначений;
	ТЗДанныхПечати.Колонки.Добавить("Номенклатура");
	ТЗДанныхПечати.Колонки.Добавить("Штрихкод");
	ТЗДанныхПечати.Колонки.Добавить("СерияСсылка");
	ТЗДанныхПечати.Колонки.Добавить("НоменклатураЕГАИС");
	
	Стр = ТЗДанныхПечати.Добавить();
	Стр.Номенклатура = Агрегация_Номенклатура;
	Стр.Штрихкод = Агрегация_ШтрихкодКороба;
	Стр.СерияСсылка = Агрегация_СерияСсылка;	
	Стр.НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьЕГАИСПоНоменклатуре(Агрегация_Номенклатура);
	
	Таб = Новый ТабличныйДокумент; 
	
	Если Агрегация_ТипЭтикетки = 1 Или Агрегация_ТипЭтикетки = 3 Тогда
		Таб.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ЭтикеткаКоробРАР"+СокрЛП(ИмяКомпьютера());
		Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("ЭтикеткаКоробРАР");
		УдалитьШтрихкодКороба = Истина;
		УдаленШтрикодКороба=Ложь;
	ИначеЕсли Агрегация_ТипЭтикетки = 2 Или Агрегация_ТипЭтикетки = 4 Тогда
		Таб.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ЭтикеткаПалетаРАР"+СокрЛП(ИмяКомпьютера());
		Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("ЭтикеткаПалетаРАР");
	КонецЕсли;  
	
	ЭтикеткаОбласть = Макет.ПолучитьОбласть("Основная");
	
	Для НомерЭтикетки = 1 По Агрегация_КоличествоЭтикеток Цикл  // Количество этикеток РАР
		Если Агрегация_ПовторнаяПечать = Ложь Тогда 
			НовыйКодУпаковкиРАР = ДатаМобайл_ОбщийМодуль.ПолучитьКодУпаковкиРАР(Агрегация_НастройкиПечати, Агрегация_ТипЭтикетки, Ложь);
			
			Если НовыйКодУпаковкиРАР = Неопределено Тогда
				Сообщить("Не удалось сформировать код упаковки");
				Прервать;
				Возврат Неопределено;		
			КонецЕсли;
		Иначе	
			НовыйКодУпаковкиРАР = СокрЛП(Строка(Агрегация_ВыборШК));
		КонецЕсли;
		
		КоличествоКопий = ?(ТекущаяНастройкаПечати.КоличествоКопий < 1, 1, ТекущаяНастройкаПечати.КоличествоКопий);
		
		Для НомерКопии = 1 По КоличествоКопий Цикл  // Количество одинаковых копий этикеток РАР
			КоличествоМиллиметровВПикселе = 0.5;
			
			ПараметрыШтрихкода = Новый Структура;
			ПараметрыШтрихкода.Вставить("Ширина",          Окр(ЭтикеткаОбласть.Рисунки.Штрихкод.Ширина / КоличествоМиллиметровВПикселе));
			ПараметрыШтрихкода.Вставить("Высота",          Окр(ЭтикеткаОбласть.Рисунки.Штрихкод.Высота / КоличествоМиллиметровВПикселе));
			ПараметрыШтрихкода.Вставить("Штрихкод",        СокрЛП(НовыйКодУпаковкиРАР));
			ПараметрыШтрихкода.Вставить("ТипКода",         4); // Code128
			ПараметрыШтрихкода.Вставить("ОтображатьТекст", Ложь);
			ПараметрыШтрихкода.Вставить("РазмерШрифта",    6);
			
			Попытка
				ЭтикеткаОбласть.Рисунки.Штрихкод.Картинка = Модуль_МенеджерОборудованияВызовСервера.ПолучитьКартинкуШтрихкода(ПараметрыШтрихкода);
			Исключение
				РезультатОперации = Модуль_ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода);
				Если РезультатОперации.ДвоичныеДанные <> Неопределено Тогда
					ЭтикеткаОбласть.Рисунки.Штрихкод.Картинка = РезультатОперации.Картинка;		
				КонецЕсли;
			КонецПопытки;
			
			Если Агрегация_ТипЭтикетки = 1 Или Агрегация_ТипЭтикетки = 3 Тогда  // Доп. поля короба
				ТекущееНазваниеТовара = "";
				ТекущаяДатаРозлива = "";
				ТекущаяЕмкость = "";
				ТекущееКоличество = "";
				ТекущийНомерПартии = "";
				ТекущийEANКороба = "123467890123";
				
				Если ТЗДанныхПечати.Количество() > 0 Тогда
					Если Не ТЗДанныхПечати[0].Номенклатура.Пустая() Тогда
						ТекущееНазваниеТовара = "" + Лев(ТЗДанныхПечати[0].Номенклатура.Наименование, 150);
						ТекущаяЕмкость = "" + ТЗДанныхПечати[0].Номенклатура.алкЕмкость + " л.";
					КонецЕсли;
					
					Если ТЗДанныхПечати[0].Штрихкод <> "" Тогда
						ТекущийEANКороба = ТЗДанныхПечати[0].Штрихкод;
						КоэффициентКороба = ДатаМобайл_ОбщийМодуль.ПолучитьКоэффициентУпаковки(ТЗДанныхПечати[0].Штрихкод);
						
						Если КоэффициентКороба <> 0 Тогда
							ТекущееКоличество = "" + КоэффициентКороба + " шт.";
						КонецЕсли; 
						
						УдалитьШтрихкодКороба = Ложь;
					КонецЕсли;
					
					Если Не ТЗДанныхПечати[0].СерияСсылка.Пустая() Тогда
						ТекущаяДатаРозлива = "" + Формат(ТЗДанныхПечати[0].СерияСсылка.алкДатаНачалаРозлива, "ДФ=dd.MM.yyyy"); //из серии
						ТекущийНомерПартии = "" + ТЗДанныхПечати[0].СерияСсылка.Наименование; //из серии 
					КонецЕсли;
				КонецЕсли;
				
				//---  Название товара			
				ЭтикеткаОбласть.Параметры.Номенклатура = ТекущееНазваниеТовара;			
				
				//---  ДатаРозлива
				ЭтикеткаОбласть.Параметры.Дата = ТекущаяДатаРозлива;
				
				//---  Емкость
				//СтрЗначение = ТекущаяЕмкость;
				
				//---  Количество штук
				//СтрЗначение = ТекущееКоличество;	
				
				//---  Номерпартии
				ЭтикеткаОбласть.Параметры.Серия = ТекущийНомерПартии;
				
				//---  EAN короба
				Если Не УдаленШтрикодКороба Тогда 
					Если УдалитьШтрихкодКороба Тогда
						ЭтикеткаОбласть.Рисунки.Удалить(ЭтикеткаОбласть.Рисунки.ШтрихкодКороба);
						УдаленШтрикодКороба = Истина;
					Иначе
						КоличествоМиллиметровВПикселе = 0.5;
						
						ПараметрыШтрихкода = Новый Структура;
						ПараметрыШтрихкода.Вставить("Ширина",          Окр(ЭтикеткаОбласть.Рисунки.Штрихкод.Ширина / КоличествоМиллиметровВПикселе));
						ПараметрыШтрихкода.Вставить("Высота",          Окр(ЭтикеткаОбласть.Рисунки.Штрихкод.Высота / КоличествоМиллиметровВПикселе));
						ПараметрыШтрихкода.Вставить("Штрихкод",        СокрЛП(ТекущийEANКороба));
						ПараметрыШтрихкода.Вставить("ТипКода",         4); // Code128
						ПараметрыШтрихкода.Вставить("ОтображатьТекст", Ложь);
						ПараметрыШтрихкода.Вставить("РазмерШрифта",    6);
						
						Попытка
							ЭтикеткаОбласть.Рисунки.ШтрихкодКороба.Картинка = Модуль_МенеджерОборудованияВызовСервера.ПолучитьКартинкуШтрихкода(ПараметрыШтрихкода);
						Исключение
							РезультатОперации = Модуль_ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода);
							Если РезультатОперации.ДвоичныеДанные <> Неопределено Тогда
								ЭтикеткаОбласть.Рисунки.ШтрихкодКороба.Картинка = РезультатОперации.Картинка;		
							КонецЕсли;
						КонецПопытки;  
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
			
			Таб.Вывести(ЭтикеткаОбласть);
			Таб.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЦикла;
	КонецЦикла;
	
	Таб.Защита              = Ложь;
	Таб.ТолькоПросмотр      = Истина;
	Таб.ОтображатьСетку     = Ложь;
	Таб.ОтображатьЗаголовки = Ложь;
	
	Возврат Таб;
	
КонецФункции

&НаКлиенте
Процедура ПечатьУпаковок(Команда)
	
	Если Агрегация_ПовторнаяПечать И СокрЛП(Агрегация_ВыборШК) = "" Тогда
		Сообщить("Не указан штрихкод для повторной печати.");	
		Возврат;	
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Агрегация_НастройкиПечати) Тогда
		Сообщить("Не заданы настройки печати.");	
		Возврат;	
	КонецЕсли;
	
	НастройкиПечатиТСД = ПолучитьНастройкиПечатиНаСервере(Агрегация_НастройкиПечати);
	Организация  = НастройкиПечатиТСД[0];
	ЛинияРозлива = НастройкиПечатиТСД[1];
	КаталогСохранения = НастройкиПечатиТСД[2];
	АдресПринтсервера = НастройкиПечатиТСД[3];
	ПортПринтсервера  = НастройкиПечатиТСД[4];
	ОнлайнСвязьСПринтсервером = НастройкиПечатиТСД[5];
	
	Если Не ЗначениеЗаполнено(ЛинияРозлива) Или Не ЗначениеЗаполнено(Организация) Тогда
		Сообщить("В настройках печати не указана линия розлива Или организация.");	
		Возврат;	
	КонецЕсли;
	
	Если ОнлайнСвязьСПринтсервером Тогда
		Если Не ЗначениеЗаполнено(АдресПринтсервера) Тогда
			Сообщить("В настройках печати не указан адрес принтсервера.");	
			Возврат;
		КонецЕсли;
		
	Иначе	
		Если Не ЗначениеЗаполнено(КаталогСохранения) Тогда
			Сообщить("В настройках печати не указан каталог обмена.");	
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если Агрегация_ТипЭтикетки = 1 Тогда
		СтруктураПоиска = Новый Структура("ТипОперации", "ЕГАИС Печать короба");
	ИначеЕсли Агрегация_ТипЭтикетки = 2 Тогда
		СтруктураПоиска = Новый Структура("ТипОперации", "ЕГАИС Печать палеты");	
	КонецЕсли;	
	
	Если Не ЗаданыНастройкиПечати(Агрегация_НастройкиПечати, СтруктураПоиска) Тогда
		Сообщить("В настройках печати не указаны шаблоны для печати упаковки");	
		Возврат;
	КонецЕсли;	
	
	Если Агрегация_КоличествоЭтикеток = 0 Тогда
		Сообщить("Не указано количество этикеток");	
		Возврат;
	КонецЕсли;	
	
	Для сч = 1 По Агрегация_КоличествоЭтикеток Цикл
		Если Агрегация_ПовторнаяПечать = Ложь Тогда
			НовыйКодУпаковкиРАР = ДатаМобайл_ОбщийМодуль.ПолучитьКодУпаковкиРАР(Агрегация_НастройкиПечати, Агрегация_ТипЭтикетки, Ложь);
		Иначе
			НовыйКодУпаковкиРАР = СокрЛП(Строка(Агрегация_ВыборШК));
		КонецЕсли;
		
		Если НовыйКодУпаковкиРАР = Неопределено Тогда
			Сообщить("Не удалось сформировать код упаковки");
			Прервать;
			Возврат;
		КонецЕсли;
		
		ПечатьУпаковокНаСервере(Агрегация_НастройкиПечати, СтруктураПоиска, 
		КаталогСохранения, АдресПринтсервера, ПортПринтсервера, ОнлайнСвязьСПринтсервером,
		НовыйКодУпаковкиРАР, Агрегация_ТипЭтикетки, Агрегация_Номенклатура, 
		Агрегация_ШтрихкодКороба, Агрегация_СерияСсылка);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьНастройкиПечатиНаСервере(НастройкиПечати);
	
	МассивНастроек = Новый Массив;
	МассивНастроек.Добавить(НастройкиПечати.Организация);
	МассивНастроек.Добавить(НастройкиПечати.ЛинияРозливаЕГАИС);
	МассивНастроек.Добавить(НастройкиПечати.КаталогВыгрузкиФайлаПечати);
	МассивНастроек.Добавить(НастройкиПечати.АдресПринтсервера);
	МассивНастроек.Добавить(НастройкиПечати.ПортПринтсервера);
	МассивНастроек.Добавить(НастройкиПечати.ОнлайнСвязьСПринтсервером);
	
	Возврат МассивНастроек;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ПечатьУпаковокНаСервере(НастройкиПечати, СтруктураПоиска, КаталогСохранения, 
	АдресПринтсервера, ПортПринтсервера, ОнлайнСвязьСПринтсервером, НовыйКодУпаковкиРАР, 
	ТипЭтикетки, Номенклатура, ШтрихкодКороба, СерияСсылка)
	
	СтрокиРеквизитов = НастройкиПечати.Печать.НайтиСтроки(СтруктураПоиска);	
	
	ТЗДанныхПечати = Новый ТаблицаЗначений;
	ТЗДанныхПечати.Колонки.Добавить("Номенклатура");
	ТЗДанныхПечати.Колонки.Добавить("НоменклатураЕГАИС");
	ТЗДанныхПечати.Колонки.Добавить("Штрихкод");
	ТЗДанныхПечати.Колонки.Добавить("СерияСсылка");
	
	Стр = ТЗДанныхПечати.Добавить();
	Стр.Номенклатура = Номенклатура;
	Стр.НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьЕГАИСПоНоменклатуре(Номенклатура);
	Стр.Штрихкод = ШтрихкодКороба;
	Стр.СерияСсылка = СерияСсылка;
	
	ДатаМобайл_ОбщийМодуль.ПечатьУпаковкиРАР(СтрокиРеквизитов[0], КаталогСохранения, АдресПринтсервера, ПортПринтсервера, ОнлайнСвязьСПринтсервером, НовыйКодУпаковкиРАР, ТипЭтикетки, ТЗДанныхПечати);
	
КонецПроцедуры

&НаКлиенте
Процедура ПечатьУпаковок1С(Команда)
	
	Если Агрегация_ПовторнаяПечать И СокрЛП(Агрегация_ВыборШК) = "" Тогда
		Сообщить("Не указан штрихкод для повторной печати.");	
		Возврат;	
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(Агрегация_НастройкиПечати) Тогда
		Сообщить("Не заданы настройки печати.");	
		Возврат;	
	КонецЕсли;
	
	НастройкиПечатиТСД = ПолучитьНастройкиПечатиНаСервере(Агрегация_НастройкиПечати);
	Организация  = НастройкиПечатиТСД[0];
	ЛинияРозлива = НастройкиПечатиТСД[1];
	
	Если Не ЗначениеЗаполнено(ЛинияРозлива) Или Не ЗначениеЗаполнено(Организация) Тогда
		Сообщить("В настройках печати не указана линия розлива или организация.");	
		Возврат;	
	КонецЕсли;
	
	Если Агрегация_КоличествоЭтикеток = 0 тогда
		Сообщить("Не указано количество этикеток");	
		Возврат;
	КонецЕсли;	
	
	Таб = ПечатьУпаковкиРАР();
	
	Если Таб = Неопределено тогда
		//Сообщить("Не удалось вывести этикетку на печать, проверьте настройки печати");	
		Возврат;
	КонецЕсли;
	
	Если Агрегация_ТипЭтикетки = 1 или Агрегация_ТипЭтикетки = 3 тогда
		Таб.Показать("Этикетки на короба по формату РАР");	
	ИначеЕсли Агрегация_ТипЭтикетки = 2 или Агрегация_ТипЭтикетки = 4 тогда
		Таб.Показать("Этикетки на палеты по формату РАР");	
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура АктФиксацииМарок(Команда)   
	
	ФормаВыбора = ПолучитьФорму("Обработка.ДатаМобайл_АРМДиспетчера.Форма.ФормаАктФиксацииЕГАИС"); 
	ФормаВыбора.Открыть();
	
КонецПроцедуры

#КонецОбласти