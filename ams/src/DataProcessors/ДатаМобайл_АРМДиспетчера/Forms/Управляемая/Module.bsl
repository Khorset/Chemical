//ПЕЧАТЬ ЭТИКЕТОК
&НаКлиенте
Процедура ОтправитьНаПечать(Команда)
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(, "Выберите документ!");
		Возврат;
	КонецЕсли;    
	
	ПараметрыПечати = Новый Структура("ПараметрыЗаполнения");
	ЗаполнитьПараметрыФормыЦенников(ПараметрыПечати, ТекущиеДанные.Ссылка);
	
	Если ДатаМобайл_ОбщийМодуль.Есть115() И ДатаМобайл_ОбщийМодуль.Ценообразование25() Тогда 
		Попытка
			ФормаПечати = ПолучитьФорму("Обработка.ПечатьЭтикетокИЦенников2_5.Форма.ФормаТовары");	
		Исключение
			ФормаПечати = ПолучитьФорму("Обработка.ПечатьЭтикетокИЦенников.Форма.ФормаТовары");
		КонецПопытки;		
	Иначе	
		ФормаПечати = ПолучитьФорму("Обработка.ПечатьЭтикетокИЦенников.Форма.ФормаТовары", ПараметрыПечати);
	КонецЕсли;
	
	ФормаПечати.Открыть();
	
	// перенос кол-ва этикеток и ценников (по-другому не работает)
	Для каждого СтрокаТовара Из ПараметрыПечати.ПараметрыЗаполнения.Товары Цикл
		СтруктураПоиска = Новый Структура("Номенклатура");
		ЗаполнитьЗначенияСвойств(СтруктураПоиска, СтрокаТовара); 
		
		Если ЗначениеЗаполнено(СтрокаТовара.Характеристика) Тогда
			СтруктураПоиска.Вставить("Характеристика", СтрокаТовара.Характеристика);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТовара.Серия) Тогда
			СтруктураПоиска.Вставить("Серия", СтрокаТовара.Серия);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТовара.Упаковка) Тогда
			СтруктураПоиска.Вставить("Упаковка", СтрокаТовара.Упаковка);
		КонецЕсли;
		
		НайденныеСтроки = ФормаПечати.Объект.Товары.НайтиСтроки(СтруктураПоиска);
		
		Для каждого НайдСтрока Из НайденныеСтроки Цикл
			НайдСтрока.КоличествоЭтикеток = СтрокаТовара.КоличествоЭтикеток;
			НайдСтрока.КоличествоЦенников = СтрокаТовара.КоличествоЦенников;
		КонецЦикла;
	КонецЦикла; 
	
	ФормаПечати.ОбновитьОтображениеДанных();	
		
КонецПроцедуры

&НаСервере
Функция ЗаполнитьПараметрыФормыЦенников(ПараметрыПечати, ДокументТСД)
	
	ПараметрыЗаполнения = Новый Структура();
	
	ЗапросТоваров = Новый Запрос;
	
	#Область ТекстЗапроса
	ЗапросТоваров.Текст = "ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура КАК Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры КАК Характеристика,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЕдиницаИзмерения КАК Упаковка,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ШтрихКод КАК Штрихкод,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Количество КАК Количество,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура.ВесИспользовать КАК Весовой
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор
	|ГДЕ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Номенклатура,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.ХарактеристикаНоменклатуры,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.ЕдиницаИзмерения,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.ШтрихКод,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Количество,
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Номенклатура.ВесИспользовать
	|ИЗ
	|	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПриемка КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка
	|ГДЕ
	|	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Ссылка = &Ссылка
	|"; 
	#КонецОбласти
	
	ЗапросТоваров.УстановитьПараметр("Ссылка", ДокументТСД);

	Выборка = ЗапросТоваров.Выполнить().Выбрать();
	МассивТоваров = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		СтруктураТовар = Новый Структура("Номенклатура, Характеристика, Серия, Упаковка, 
		|Цена, Штрихкод, КоличествоЦенников, КоличествоЭтикеток, ОстатокНаСкладе, КоличествоВДокументе,
		|Весовой, ШаблонЦенника, ШаблонЭтикетки, ЦенаДополнительно, ДатаПоследнегоИзмененияЦены");
		
		ЗаполнитьЗначенияСвойств(СтруктураТовар, Выборка);
		СтруктураТовар.КоличествоВДокументе = Выборка.Количество;
		СтруктураТовар.КоличествоЭтикеток   = Выборка.Количество;
		СтруктураТовар.КоличествоЦенников   = Выборка.Количество;
		
		МассивТоваров.Добавить(СтруктураТовар);
	КонецЦикла;
	
	ПараметрыЗаполнения.Вставить("Дата", ДатаМобайл_ОбщийМодуль.ПолучитьТекущуюДату());
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьОрганизацию", ДокументТСД.Организация);
	СтруктураДействий.Вставить("ЗаполнитьСклад", ДокументТСД.Склад);
	СтруктураДействий.Вставить("ЗаполнитьВидЦены", ДокументТСД.Склад.УчетныйВидЦены);
	СтруктураДействий.Вставить("УстановитьРежим", "ПечатьЭтикетокИЦенников");
	СтруктураДействий.Вставить("ЗаполнитьТаблицуТоваров", Истина);
	СтруктураДействий.Вставить("ЗаполнитьКоличествоЭтикетокПоДокументу", Истина);
	СтруктураДействий.Вставить("ЗаполнитьКоличествоЦенниковПоДокументу", Истина);
	
	ПараметрыЗаполнения.Вставить("СтруктураДействий", СтруктураДействий); 
	ПараметрыЗаполнения.Вставить("Товары", МассивТоваров);
	
	ПараметрыПечати.ПараметрыЗаполнения = ПараметрыЗаполнения;
	
КонецФункции

