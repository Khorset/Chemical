		Если Справочники.ДатаМобайл_ШаблоныДокументов_ЕГАИС.НайтиПоНаименованию("Перемещение").Пустая() тогда
			НовыйШаблон = Справочники.ДатаМобайл_ШаблоныДокументов_ЕГАИС.СоздатьЭлемент();
