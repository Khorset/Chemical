	Исключение
	КонецПопытки;
	
	ОткрытьФорму("Обработка.ДатаМобайл_АРМДиспетчера.Форма.ФормаСозданияДокумента", ПараметрыОткрытия, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
