Процедура УдалитьФайлы_ОбработкаОповещения(ДополнительныеПараметры) Экспорт
	
	// обработка дополнительных действий.
	
КонецПроцедуры

&НаКлиенте
Процедура ПодтверждениеЗагрузки(РезультатВопроса, ПараметрыЗаписи) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Если Элементы.грЗакладки.ТекущаяСтраница = Элементы.грЗакладки.ПодчиненныеЭлементы.грШаблоны Тогда				 
			КонтекстВызова = "СписокШаблонов";
		ИначеЕсли Элементы.грЗакладки.ТекущаяСтраница = Элементы.грЗакладки.ПодчиненныеЭлементы.ГрПользователиИРоли Тогда				 
			КонтекстВызова = "Роли";
		ИначеЕсли Элементы.грЗакладки.ТекущаяСтраница = Элементы.грЗакладки.ПодчиненныеЭлементы.грТерминалы Тогда
			КонтекстВызова = "СписокТСД";
		КонецЕсли;
		
		ДополнительныеПараметры = Новый Структура("КонтекстВызова", КонтекстВызова);
		ОповещениеПослеЧтенияФайла = Новый ОписаниеОповещения("НачатьСозданиеДвоичныхДанныхИзФайла_ОбработкаОповещения", ЭтотОбъект, ДополнительныеПараметры);
		
		НачатьСозданиеДвоичныхДанныхИзФайла(ОповещениеПослеЧтенияФайла, ШаблоныПутьКФайлуНастроек);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодтверждениеВыгрузки(РезультатВопроса, ПараметрыЗаписи) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Если Элементы.грЗакладки.ТекущаяСтраница = Элементы.грЗакладки.ПодчиненныеЭлементы.грШаблоны Тогда
			КонтекстВызова = "Шаблоны";			
		ИначеЕсли Элементы.грЗакладки.ТекущаяСтраница = Элементы.грЗакладки.ПодчиненныеЭлементы.ГрПользователиИРоли Тогда				 
			КонтекстВызова = "Роли";
		ИначеЕсли Элементы.грЗакладки.ТекущаяСтраница = Элементы.грЗакладки.ПодчиненныеЭлементы.грТерминалы Тогда
			КонтекстВызова = "Терминалы";
		КонецЕсли;
		
		АдресФайлаВоВременномХранилище = ВыгрузитьНастройкиНаСервере(КонтекстВызова);
		
		ДополнительныеПараметры = Новый Структура("АдресФайлаВоВременномХранилище", АдресФайлаВоВременномХранилище);
		ОповещениеПослеЗаписиФайла = Новый ОписаниеОповещения("НачатьЗаписьДвоичныхДанныхВФайл_ОбработкаОповещения", ЭтотОбъект, ДополнительныеПараметры);
		
		ДвДанные = ПолучитьИзВременногоХранилища(АдресФайлаВоВременномХранилище);		
		ДвДанные.НачатьЗапись(ОповещениеПослеЗаписиФайла, ШаблоныПутьКФайлуНастроек);
	КонецЕсли;
	
КонецПроцедуры

