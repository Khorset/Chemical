			|		ЛЕВОЕ СОЕДИНЕНИЕ СтрокиНаборов КАК СтрокиНаборов
			|		ПО Состав.ВариантКомплектацииНабора = СтрокиНаборов.ВариантКомплектацииНабора
			|			И Состав.Номенклатура = СтрокиНаборов.Номенклатура
			|			И Состав.ХарактеристикаНоменклатуры = СтрокиНаборов.ХарактеристикаНоменклатуры
			|ГДЕ
			|	ЕСТЬNULL(СтрокиНаборов.Количество, 0) - Состав.КоличествоВНаборе > 1
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////";
			
			Если Не ИспользоватьМаркировку Тогда
				
				ТабАнализа.ТекстЗапроса = СтрЗаменить(ТабАнализа.ТекстЗапроса, 
				"ЕСТЬNULL(СтрокиНаборов.Количество, 0) - Состав.КоличествоВНаборе > 1",
				"ЕСТЬNULL(СтрокиНаборов.Количество, 0) - Состав.КоличествоВНаборе >= 1");
				
			КонецЕсли;	
	
		КонецЕсли;
				
		ТабАнализа.ТекстЗапроса = ТабАнализа.ТекстЗапроса + "
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ИтоговаяТаблица.ТипСтроки,
		|	ИтоговаяТаблица.Артикул КАК Артикул,
		|	ИтоговаяТаблица.Номенклатура КАК Номенклатура,
		|	ИтоговаяТаблица.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
		|	СУММА(ИтоговаяТаблица.План) КАК План,
		|	СУММА(ИтоговаяТаблица.Факт) КАК Факт,
		// БЫЛО:
		//|	СУММА(ИтоговаяТаблица.Расхождения) КАК Расхождения 
		// СТАЛО:
		|	ВЫБОР КОГДА &УчитыватьДопуски ТОГДА
		|		ВЫБОР КОГДА (ЕСТЬNULL(МИНИМУМ(ИтоговаяТаблица.ДопускЕд), 0) >= СУММА(ИтоговаяТаблица.Расхождения) И СУММА(ИтоговаяТаблица.Расхождения) > 0)
		|			ИЛИ (ЕСТЬNULL(МИНИМУМ(ИтоговаяТаблица.ДопускЕд), 0) >= - СУММА(ИтоговаяТаблица.Расхождения) И СУММА(ИтоговаяТаблица.Расхождения) < 0)
		|			ТОГДА 0
		|		ИНАЧЕ 
		|			СУММА(ИтоговаяТаблица.Расхождения)
		// ВЫЧИТАНИЕ ДОПУСКА ИЗ РАСХОЖДЕНИЯ ++
		//|			ВЫБОР КОГДА СУММА(ИтоговаяТаблица.Расхождения) < 0 
		//|				ТОГДА СУММА(ИтоговаяТаблица.Расхождения) + ЕСТЬNULL(МИНИМУМ(ИтоговаяТаблица.ДопускЕд), 0)
		//|			ИНАЧЕ СУММА(ИтоговаяТаблица.Расхождения) - ЕСТЬNULL(МИНИМУМ(ИтоговаяТаблица.ДопускЕд), 0) КОНЕЦ
		// ВЫЧИТАНИЕ ДОПУСКА ИЗ РАСХОЖДЕНИЯ --
		|		КОНЕЦ 
		|	ИНАЧЕ 
		|		СУММА(ИтоговаяТаблица.Расхождения) 
		|	КОНЕЦ КАК Расхождения
		|ПОМЕСТИТЬ ВременнаяТаблица
		|ИЗ
		//СПРАВОЧНИК ДОКУМЕНТ ТСД
		|	(ВЫБРАТЬ
		|		ВложенныйЗапрос.Номенклатура КАК Номенклатура,
		|		ЕСТЬNULL(ВложенныйЗапрос.ХарактеристикаНоменклатуры, """") КАК ХарактеристикаНоменклатуры,
		|		ВложенныйЗапрос.Артикул КАК Артикул,
		|		СУММА(ВложенныйЗапрос.План) КАК План,
		|		СУММА(ВложенныйЗапрос.Факт) КАК Факт,
		|		СУММА(-ВложенныйЗапрос.План + ВложенныйЗапрос.Факт) КАК Расхождения,		
		|		ВложенныйЗапрос.ТипСтроки КАК ТипСтроки,
		// допуск весового товара
		|		&ТекстДопускаВесовогоТовараВЕд КАК ДопускЕд
		|	ИЗ
		|		(ВЫБРАТЬ
		|			СобранныеДанныеПодбор.Номенклатура КАК Номенклатура,
		|			ЕСТЬNULL(СобранныеДанныеПодбор.ХарактеристикаНоменклатуры, """") КАК ХарактеристикаНоменклатуры,
		|			СобранныеДанныеПодбор.Номенклатура.Артикул КАК Артикул,
