  <attributes>
    <name>СписокТСД</name>
    <title>
      <key>ru</key>
      <value>Список ТСД</value>
    </title>
    <id>5</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокТСД.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокТСД.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДатаМобайл_ДокументыТСД.ТСД КАК ТСД,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДатаМобайл_ДокументыТСД.Ссылка) КАК Документов
ПОМЕСТИТЬ ДанныеДокументов
ИЗ
	Справочник.ДатаМобайл_ДокументыТСД КАК ДатаМобайл_ДокументыТСД
ГДЕ
	НЕ ДатаМобайл_ДокументыТСД.ТСД = ЗНАЧЕНИЕ(ПланОбмена.ДатаМобайл_СписокТСД.ПустаяСсылка)
	И ДатаМобайл_ДокументыТСД.ДатаЗавершения = ДАТАВРЕМЯ(1, 1, 1)
	И НЕ ДатаМобайл_ДокументыТСД.ПометкаУдаления

СГРУППИРОВАТЬ ПО
	ДатаМобайл_ДокументыТСД.ТСД
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПланОбменаДатаМобайл_СписокТСД.Ссылка КАК Ссылка,
	ПланОбменаДатаМобайл_СписокТСД.Код КАК Код,
	ЗначенияУзлаОбменаТСД1.Значение КАК ТекущийПользователь,
	ЗначенияУзлаОбменаТСД2.Значение КАК ДатаПоследнейЗагрузкиСправочников,
	ЗначенияУзлаОбменаТСД3.Значение КАК ДатаПоследнейАвторизацииПользователя,
	ДанныеДокументов.Документов КАК Документов,
	ПланОбменаДатаМобайл_СписокТСД.Описание КАК Описание,
	ЗначенияУзлаОбменаТСД4.Значение КАК ВерсияПО,
	ПланОбменаДатаМобайл_СписокТСД.Наименование КАК Наименование
ИЗ
	ПланОбмена.ДатаМобайл_СписокТСД КАК ПланОбменаДатаМобайл_СписокТСД
		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеДокументов КАК ДанныеДокументов
		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ДанныеДокументов.ТСД
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатаМобайл_ЗначенияУзлаОбменаТСД КАК ЗначенияУзлаОбменаТСД1
		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ЗначенияУзлаОбменаТСД1.ТСД
			И (ЗначенияУзлаОбменаТСД1.ТипЗначения = &quot;ТекущийПользователь&quot;)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатаМобайл_ЗначенияУзлаОбменаТСД КАК ЗначенияУзлаОбменаТСД2
		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ЗначенияУзлаОбменаТСД2.ТСД
			И (ЗначенияУзлаОбменаТСД2.ТипЗначения = &quot;ДатаПоследнейЗагрузкиСправочников&quot;)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатаМобайл_ЗначенияУзлаОбменаТСД КАК ЗначенияУзлаОбменаТСД3
		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ЗначенияУзлаОбменаТСД3.ТСД
			И (ЗначенияУзлаОбменаТСД3.ТипЗначения = &quot;ДатаПоследнейАвторизацииПользователя&quot;)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатаМобайл_ЗначенияУзлаОбменаТСД КАК ЗначенияУзлаОбменаТСД4
		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ЗначенияУзлаОбменаТСД4.ТСД
			И (ЗначенияУзлаОбменаТСД4.ТипЗначения = &quot;ВерсияПО&quot;)	</queryText>
      <mainTable>ExchangePlan.ДатаМобайл_СписокТСД</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
