    </title>
    <id>39</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокДокументов_ЕГАИС.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Ссылка,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ПометкаУдаления,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Код,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Дата,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДатаЗавершения,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДатаЗавершенияСбора,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДатаИзмененияКлиента,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДатаНачалаСбора,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДатаПриемкиОператором,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДатаСоздания,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДополнительныйДокумент,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ИсходныйДокумент,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Клиент,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Комментарий,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.НовыйДокумент,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Номер,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ПостановкаНаКарантин,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Склад,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.СсылкаНаИзображение,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ТСД,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Шаблон,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДокументЧекККМ,
	СправочникДатаМобайл_ДокументыТСД_ЕГАИС.Приоритет,
	ВЫБОР
		КОГДА СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ПометкаУдаления
			ТОГДА 8
		КОГДА НЕ СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ДатаПриемкиОператором = ДАТАВРЕМЯ(1, 1, 1)
				И НЕ СправочникДатаМобайл_ДокументыТСД_ЕГАИС.ПланРавноФакт
			ТОГДА 6
		ИНАЧЕ 0
	КОНЕЦ КАК СтатусИконки
ИЗ
	Справочник.ДатаМобайл_ДокументыТСД_ЕГАИС КАК СправочникДатаМобайл_ДокументыТСД_ЕГАИС</queryText>
