  <attributes>
    <name>СписокДокументов</name>
    <title>
      <key>ru</key>
      <value>Список документов</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокДокументов.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СправочникДатаМобайл_ДокументыТСД.Ссылка КАК Ссылка,
	СправочникДатаМобайл_ДокументыТСД.ПометкаУдаления КАК ПометкаУдаления,
	СправочникДатаМобайл_ДокументыТСД.Код КАК Код,
	СправочникДатаМобайл_ДокументыТСД.Шаблон КАК Шаблон,
	СправочникДатаМобайл_ДокументыТСД.ИсходныйДокумент КАК ИсходныйДокумент,
	СправочникДатаМобайл_ДокументыТСД.ТСД КАК ТСД,
	СправочникДатаМобайл_ДокументыТСД.ДатаСоздания КАК ДатаСоздания,
	СправочникДатаМобайл_ДокументыТСД.ДатаНачалаСбора КАК ДатаНачалаСбора,
	СправочникДатаМобайл_ДокументыТСД.ДатаЗавершенияСбора КАК ДатаЗавершенияСбора,
	СправочникДатаМобайл_ДокументыТСД.ДатаПриемкиОператором КАК ДатаПриемкиОператором,
	СправочникДатаМобайл_ДокументыТСД.ДатаЗавершения КАК ДатаЗавершения,
	ВЫРАЗИТЬ(СправочникДатаМобайл_ДокументыТСД.Комментарий КАК СТРОКА(100)) КАК Комментарий,
	СправочникДатаМобайл_ДокументыТСД.Номер КАК Номер,
	СправочникДатаМобайл_ДокументыТСД.Дата КАК Дата,
	СправочникДатаМобайл_ДокументыТСД.НовыйДокумент КАК НовыйДокумент,
	СправочникДатаМобайл_ДокументыТСД.Клиент КАК Клиент,
	СправочникДатаМобайл_ДокументыТСД.Склад КАК Склад,
	СправочникДатаМобайл_ДокументыТСД.ПланРавноФакт КАК ПланРавноФакт,
	СправочникДатаМобайл_ДокументыТСД.СкладПолучатель КАК СкладПолучатель,
	ВЫРАЗИТЬ(СправочникДатаМобайл_ДокументыТСД.Json КАК СТРОКА(100)) КАК ДополнительнаяИнформация,
	СправочникДатаМобайл_ДокументыТСД.ВремяСборки,
	СправочникДатаМобайл_ДокументыТСД.Приоритет,
	ВЫБОР 
		КОГДА СправочникДатаМобайл_ДокументыТСД.ПометкаУдаления ТОГДА 8 
		КОГДА НЕ СправочникДатаМобайл_ДокументыТСД.ДатаПриемкиОператором = ДАТАВРЕМЯ(1,1,1) И НЕ СправочникДатаМобайл_ДокументыТСД.ПланРавноФакт ТОГДА 6
		ИНАЧЕ 0 
	КОНЕЦ КАК СтатусИконки
ИЗ
	Справочник.ДатаМобайл_ДокументыТСД КАК СправочникДатаМобайл_ДокументыТСД
ГДЕ
	СправочникДатаМобайл_ДокументыТСД.РодительскийДокумент = ЗНАЧЕНИЕ(Справочник.ДатаМобайл_ДокументыТСД.ПустаяСсылка)
</queryText>
      <mainTable>Catalog.ДатаМобайл_ДокументыТСД</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <attributes>
    <name>ТабДокумента</name>
    <title>
      <key>ru</key>
      <value>Таб документа</value>
    </title>
    <id>3</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	&quot;Подбор    &quot; КАК Операция,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ШтрихКод,
	&quot;                                                  &quot;  КАК Артикул,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Номенклатура,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ХарактеристикаНоменклатуры,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Количество,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.ЕдиницаИзмерения,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.СерийныйНомер,	
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ячейка,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.УпаковочныйЛист,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Пользователь,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.НомерСтроки,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.КодТовара,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.НазваниеТовара
ИЗ
	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПодбор КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор
ГДЕ
	ДатаМобайл_ДокументыТСДСобранныеДанныеПодбор.Ссылка = ЗНАЧЕНИЕ(Справочник.ДатаМобайл_ДокументыТСД.ПустаяСсылка)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	&quot;Размещение&quot;,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Ссылка,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.ШтрихКод,
	&quot;                                                  &quot;,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Номенклатура,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.ХарактеристикаНоменклатуры,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Количество,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.ЕдиницаИзмерения,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.СерийныйНомер,	
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Ячейка,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.УпаковочныйЛист,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Пользователь,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.НомерСтроки,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.КодТовара,
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.НазваниеТовара
ИЗ
	Справочник.ДатаМобайл_ДокументыТСД.СобранныеДанныеПриемка КАК ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка
ГДЕ
	ДатаМобайл_ДокументыТСДСобранныеДанныеПриемка.Ссылка = ЗНАЧЕНИЕ(Справочник.ДатаМобайл_ДокументыТСД.ПустаяСсылка)
	
ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	Выбор когда ДатаМобайл_РегистрСведений.ИмяТаблицы = &quot;Select&quot; Тогда &quot;Подбор    &quot; Иначе &quot;Размещение&quot; Конец КАК Операция,
	ДатаМобайл_РегистрСведений.ДокументТСД,
	ДатаМобайл_РегистрСведений.ШтрихКод,
	&quot;                                                  &quot;,
	ДатаМобайл_РегистрСведений.Номенклатура,
	ДатаМобайл_РегистрСведений.ХарактеристикаНоменклатуры,
	ДатаМобайл_РегистрСведений.Количество,
	ДатаМобайл_РегистрСведений.ЕдиницаИзмерения,
	ДатаМобайл_РегистрСведений.СерийныйНомер,	
	ДатаМобайл_РегистрСведений.Ячейка,
	ДатаМобайл_РегистрСведений.УпаковочныйЛист,
	ДатаМобайл_РегистрСведений.Пользователь,
	ДатаМобайл_РегистрСведений.ИдентификаторСтроки,
	ДатаМобайл_РегистрСведений.КодТовара,
	ДатаМобайл_РегистрСведений.НазваниеТовара
ИЗ
	РегистрСведений.ДатаМобайл_СтрокиГрупповыхДокументов КАК ДатаМобайл_РегистрСведений
ГДЕ
	ДатаМобайл_РегистрСведений.ДокументТСД = ЗНАЧЕНИЕ(Справочник.ДатаМобайл_ДокументыТСД.ПустаяСсылка)
	И НЕ ДатаМобайл_РегистрСведений.ДляОбмена
	</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
