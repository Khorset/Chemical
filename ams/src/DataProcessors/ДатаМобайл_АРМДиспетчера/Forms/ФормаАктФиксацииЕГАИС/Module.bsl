&НаКлиенте
Процедура ПанельДокументовВыборДобавить(Кнопка)
		
	ПараметрыПодбора=Новый Структура;
	ПараметрыПодбора.Вставить("МножественныйВыбор", Истина);
	Подбор=Получитьформу("Документ.ДатаМобайл_УпаковочныйЛист.ФормаВыбора",ПараметрыПодбора,ЭтаФорма);
	Подбор.ЗакрыватьПривыборе=Ложь;
	Подбор.МножественныйВыбор=Истина;
	Подбор.ОткрытьМодально();	

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка=Ложь;
	Найти= ТаблицаДокументов.Найти(ВыбранноеЗначение.ТекущийЭлемент.ТекущаяСтрока,"Документ");
	Если Найти<>Неопределено тогда	
		Предупреждение("Документ "+ВыбранноеЗначение.ТекущийЭлемент.ТекущаяСтрока+" уже был добавлен в список.");
	ИначеЕсли
		ВыбранноеЗначение.ТекущийЭлемент.ТекущаяСтрока.Тип<>1 тогда
		Предупреждение("Документ "+ВыбранноеЗначение.ТекущийЭлемент.ТекущаяСтрока+" не является документом формирования коробов");
	Иначе	
		СтрокаТЧ = ТаблицаДокументов.Добавить();
		СтрокаТЧ.Документ = ВыбранноеЗначение.ТекущийЭлемент.ТекущаяСтрока;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПеренестиДанные(Команда)
	
	ПеренестиДанныеНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ПеренестиДанныеНаСервере()
	
	АктФиксацииОбъект=АктФиксации.ПолучитьОбъект();
	
	n= ТаблицаДокументов.Количество()-1;
	Для i=0 по n цикл
		ТекСтрока=ТаблицаДокументов.Получить(i);
		//Если  ТекСтрока.Документ.Тип<>1 или ТекСтрока.Документ.Тип<>3 тогда //добавляем только короба
		//	продолжить;
		//КонецЕсли;
		
		Для каждого СтрТЧ из ТекСтрока.Документ.Товары цикл
			Если  НЕ (СтрДлина(СтрТЧ.Марка)=68 или СтрДлина(СтрТЧ.Марка)=150) ИЛИ СтрТЧ.Марка=""  тогда //добавляем только корректные данные
				продолжить;
			КонецЕсли;
			
			ДанныеПоСправкам = ДатаМобайл_ОбщийМодуль.ПолучитьСправкиПоСерии(СтрТЧ.Серия);
			
			//Товары
			СтрокиПоиска = АктФиксацииОбъект.Товары.НайтиСтроки(Новый Структура("АлкогольнаяПродукция,СправкаА,СправкаБ",СтрТЧ.ЕГАИС_Номенклатура,ДанныеПоСправкам.СправкаА,ДанныеПоСправкам.СправкаБ));
			Если СтрокиПоиска.Количество()=0 тогда  //нет строк добавляем		
				СтрокаТабличнойЧасти=АктФиксацииОбъект.Товары.Добавить();
				СтрокаТабличнойЧасти.АлкогольнаяПродукция=СтрТЧ.ЕГАИС_Номенклатура;
				СтрокаТабличнойЧасти.СправкаА = ДанныеПоСправкам.СправкаА;
				СтрокаТабличнойЧасти.СправкаБ = ДанныеПоСправкам.СправкаБ;
			Иначе  //есть строка				
				СтрокаТабличнойЧасти = СтрокиПоиска[0];
			КонецЕсли;	
			Если НЕ (ЗначениеЗаполнено(СтрокаТабличнойЧасти.КлючСвязи)) Тогда
				СтрокаТабличнойЧасти.КлючСвязи = ПолучитьНовыйКлючСтроки(АктФиксацииОбъект.Товары);
			КонецЕсли;

			
			//Марки
			СтрокиПоискаМарок=АктФиксацииОбъект.АкцизныеМарки.НайтиСтроки(Новый Структура("КодАкцизнойМарки",СтрТЧ.Марка));
			Если СтрокиПоискаМарок.Количество()=0 тогда
				СтрокаМарки = АктФиксацииОбъект.АкцизныеМарки.Добавить();
				//нетиповое поле
				Попытка СтрокаМарки.НомерКоробки = СтрТЧ.Короб; Исключение КонецПопытки;
				//нетиповое поле
				СтрокаМарки.КодАкцизнойМарки = СтрТЧ.Марка;
				СтрокаМарки.КлючСвязи = СтрокаТабличнойЧасти.КлючСвязи;	
			Иначе
				СтрокаМарки=СтрокиПоискаМарок[0];
			КонецЕсли;
		КонецЦикла;
		
		УпакЛистОбъект=ТекСтрока.Документ.ПолучитьОбъект();
		УпакЛистОбъект.Основание = АктФиксацииОбъект.Ссылка;
		УпакЛистОбъект.Записать(); 
		
	КонецЦикла;

	АктФиксацииОбъект.Записать();
	
	ТаблицаДокументов.Очистить();
	Сообщить("Данные перенесены в ЕГАИС документ"); 
КонецПроцедуры


&НаСервере
Функция ПолучитьНовыйКлючСтроки(ТЧ)
	СвободныйКлюч=0;
	Для Каждого СтрокаТаблицы Из ТЧ Цикл
		СвободныйКлюч=макс(СтрокаТаблицы.КлючСвязи,СвободныйКлюч);
	КонецЦикла;
	СвободныйКлюч=СвободныйКлюч+1;
	
	Возврат СвободныйКлюч;
КонецФункции
