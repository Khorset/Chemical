Функция ПолучитьНовыйИдентификаторЕГАИС(Задание, ТЧ, лКоличествоСтрокВРеализации = 0)	
	
	СвободныйНомер = 0;
	
	Если лКоличествоСтрокВРеализации <> 0 И Не Задание.Шаблон.НезависимыеИдентификаторыСтрокТТН Тогда 
		СвободныйНомер = лКоличествоСтрокВРеализации;	
	КонецЕсли;
	
	Для каждого СтрокаТаблицы Из ТЧ Цикл
		Попытка
			ИдентификаторСтрокиЧислом = Число(СтрокаТаблицы.ИдентификаторСтроки);
			СвободныйНомер = Макс(СвободныйНомер, ИдентификаторСтрокиЧислом);
		Исключение
			Продолжить;
		КонецПопытки;
	КонецЦикла;	

    СвободныйНомер = СвободныйНомер + 1;
	
	Возврат СвободныйНомер; 
	
