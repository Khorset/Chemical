Процедура ДополнитьДокументПартионнымиТоварами(ПараметрыДокумента,ДокументЕГАИС,Задание)
	
	Если ПараметрыДокумента.ЭтоТТНпоРеализации Тогда 
		
		Если Задание.ДополнительныйДокумент <> Неопределено Тогда
			СсылкаНаТекущийДокументРеализации = Задание.ДополнительныйДокумент;
		Иначе
			СсылкаНаТекущийДокументРеализации = Задание.ИсходныйДокумент;
		КонецЕсли;
		
		Если СсылкаНаТекущийДокументРеализации.Товары.Количество() > 0 Тогда
			
			// 1.Получаем расхождения по номенклатуре
			ЗапросРасхождений = Новый Запрос("ВЫБРАТЬ
			|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
			|	СУММА(ВложенныйЗапрос.План) КАК План,
			|	СУММА(ВложенныйЗапрос.Факт) КАК Факт
			|ПОМЕСТИТЬ ВременнаяТаблицаРасхождений
			|Из
			|	(ВЫБРАТЬ
			|		ТаблицаДокументаЗадание.Номенклатура КАК Номенклатура,
			|		ТаблицаДокументаЗадание.Количество КАК План,
			|		0 КАК Факт
			|	Из
			|		Документ.РеализацияТоваровУслуг.Товары КАК ТаблицаДокументаЗадание
			|	ГДЕ
			|		ТаблицаДокументаЗадание.Ссылка = &ДокументРеализации
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		НоменклатураСопоставления.Номенклатура,
			|		0,
			|		ТаблицаДокументаПодбор.Количество
			|	ИЗ
			|		Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ТаблицаДокументаПодбор
			|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			|				СоответствиеСерийЕГАИС.СправкаА КАК СправкаА,
			|				СоответствиеСерийЕГАИС.СправкаБ КАК СправкаБ,
			|				МАКСИМУМ(СоответствиеСерийЕГАИС.СерияНоменклатуры.алкВладелец) КАК Номенклатура
			|			Из
			|				РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК СоответствиеСерийЕГАИС
			|			
			|			СГРУППИРОВАТЬ ПО
			|				СоответствиеСерийЕГАИС.СправкаА,
			|				СоответствиеСерийЕГАИС.СправкаБ) КАК НоменклатураСопоставления
			|			ПО (НоменклатураСопоставления.СправкаА = ТаблицаДокументаПодбор.СправкаА)
			|				И (НоменклатураСопоставления.СправкаБ = ТаблицаДокументаПодбор.СправкаБ)
			|	ГДЕ
			|		ТаблицаДокументаПодбор.Ссылка = &ДокументТТН) КАК ВложенныйЗапрос
			|
			|СГРУППИРОВАТЬ ПО
			|	ВложенныйЗапрос.Номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВременнаяТаблицаРасхождений.Номенклатура КАК Номенклатура,
			|	ВременнаяТаблицаРасхождений.План - ВременнаяТаблицаРасхождений.Факт КАК ПартионноеКоличество
			|Из
			|	ВременнаяТаблицаРасхождений КАК ВременнаяТаблицаРасхождений
			|ГДЕ
			|	ВременнаяТаблицаРасхождений.План - ВременнаяТаблицаРасхождений.Факт > 0");
			
			ЗапросРасхождений.УстановитьПараметр("ДокументТТН", ДокументЕГАИС.Ссылка);
			ЗапросРасхождений.УстановитьПараметр("ДокументРеализации", СсылкаНаТекущийДокументРеализации);					
			ТаблицаРасхождения = ЗапросРасхождений.Выполнить().Выгрузить();
			
			Если ТаблицаРасхождения.Количество() > 0 Тогда
				ЕстьРасхождения = Истина;
				
				ТЗПартионныхСтрок  = Новый ТаблицаЗначений;
				ТЗПартионныхСтрок.Колонки.Добавить("Номенклатура");
				ТЗПартионныхСтрок.Колонки.Добавить("ХарактеристикаНоменклатуры");
				ТЗПартионныхСтрок.Колонки.Добавить("СерияНоменклатуры");	
				ТЗПартионныхСтрок.Колонки.Добавить("Количество");
				
				Для каждого СтрокаРасхожденийНоменклатуры Из ТаблицаРасхождения Цикл
					
					ТекущееКоличествоДляВнесения = СтрокаРасхожденийНоменклатуры.ПартионноеКоличество;
					
					//2.Получаем расхождения по сериям
					ЗапросРасхожденийСерии=Новый Запрос("ВЫБРАТЬ
					|	ДанныеРеализации.Номенклатура КАК Номенклатура,
					|	ДанныеРеализации.Серия КАК СерияНоменклатуры,
					|	ДанныеРеализации.Количество КАК Количество
					|ПОМЕСТИТЬ ДанныеРеализации
					|Из
					|	Документ.РеализацияТоваровУслуг.Товары КАК ДанныеРеализации
					|ГДЕ
					|	ДанныеРеализации.Ссылка = &ДокументРеализации
					|	И ДанныеРеализации.Номенклатура = &Номенклатура
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
					|	ВложенныйЗапрос.СерияНоменклатуры КАК СерияНоменклатуры,
					|	СУММА(ВложенныйЗапрос.План) КАК План,
					|	СУММА(ВложенныйЗапрос.Факт) КАК Факт
					|ПОМЕСТИТЬ ВременнаяТаблицаРасхождений
					|Из
					|	(ВЫБРАТЬ
					|		ДанныеРеализации.Номенклатура КАК Номенклатура,
					|		ДанныеРеализации.СерияНоменклатуры КАК СерияНоменклатуры,
					|		ДанныеРеализации.Количество КАК План,
					|		0 КАК Факт
					|	Из
					|		ДанныеРеализации КАК ДанныеРеализации
					|	
					|	ОБЪЕДИНИТЬ ВСЕ
					|	
					|	ВЫБРАТЬ
					|		НоменклатураСопоставления.СерияНоменклатуры.алкВладелец,
					|		НоменклатураСопоставления.СерияНоменклатуры,
					|		0,
					|		ТаблицаДокументаПодбор.Количество
					|	Из
					|		Документ.алкТоварноТранспортнаяНакладнаяЕГАИС.Товары КАК ТаблицаДокументаПодбор
					|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
					|				МАКСИМУМ(СоответствиеСерийЕГАИС.СправкаА) КАК СправкаА,
					|				МАКСИМУМ(СоответствиеСерийЕГАИС.СправкаБ) КАК СправкаБ,
					|				ДанныеРеализации.СерияНоменклатуры КАК СерияНоменклатуры
					|			Из
					|				ДанныеРеализации КАК ДанныеРеализации
					|					ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.алкСоответствияСправокАиБЕГАИСИСерий КАК СоответствиеСерийЕГАИС
					|					ПО (СоответствиеСерийЕГАИС.СерияНоменклатуры = ДанныеРеализации.СерияНоменклатуры)
					|			
					|			СГРУППИРОВАТЬ ПО
					|				ДанныеРеализации.СерияНоменклатуры) КАК НоменклатураСопоставления
					|			ПО (НоменклатураСопоставления.СправкаА = ТаблицаДокументаПодбор.СправкаА)
					|				И (НоменклатураСопоставления.СправкаБ = ТаблицаДокументаПодбор.СправкаБ)
					|	ГДЕ
					|		ТаблицаДокументаПодбор.Ссылка = &ДокументТТН) КАК ВложенныйЗапрос
					|
					|СГРУППИРОВАТЬ ПО
					|	ВложенныйЗапрос.Номенклатура,
					|	ВложенныйЗапрос.СерияНоменклатуры
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	ВременнаяТаблицаРасхождений.Номенклатура КАК Номенклатура,
					|	ВременнаяТаблицаРасхождений.СерияНоменклатуры КАК СерияНоменклатуры,
					|	ВременнаяТаблицаРасхождений.План - ВременнаяТаблицаРасхождений.Факт КАК ПартионноеКоличество
					|Из
					|	ВременнаяТаблицаРасхождений КАК ВременнаяТаблицаРасхождений
					|ГДЕ
					|	ВременнаяТаблицаРасхождений.План - ВременнаяТаблицаРасхождений.Факт > 0");
					
					
					ЗапросРасхожденийСерии.УстановитьПараметр("ДокументТТН", ДокументЕГАИС.Ссылка);
					ЗапросРасхожденийСерии.УстановитьПараметр("ДокументРеализации", СсылкаНаТекущийДокументРеализации);
					ЗапросРасхожденийСерии.УстановитьПараметр("Номенклатура", СтрокаРасхожденийНоменклатуры.Номенклатура);
					ТаблицаРасхожденияСерии = ЗапросРасхожденийСерии.Выполнить().Выгрузить();
					
					Для каждого СтрокаРасхожденийНоменклатурыСерии Из ТаблицаРасхожденияСерии Цикл
						ТекущееКоличествоДляВнесенияСерии = Мин(ТекущееКоличествоДляВнесения, СтрокаРасхожденийНоменклатурыСерии.ПартионноеКоличество);
						
						СтрТЗПартионныхСтрок = ТЗПартионныхСтрок.Добавить();
						СтрТЗПартионныхСтрок.Номенклатура = СтрокаРасхожденийНоменклатурыСерии.Номенклатура;
						СтрТЗПартионныхСтрок.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
						СтрТЗПартионныхСтрок.СерияНоменклатуры = СтрокаРасхожденийНоменклатурыСерии.СерияНоменклатуры;
						СтрТЗПартионныхСтрок.Количество = ТекущееКоличествоДляВнесенияСерии;
						
						ТекущееКоличествоДляВнесения =  ТекущееКоличествоДляВнесения - ТекущееКоличествоДляВнесенияСерии;
						Если ТекущееКоличествоДляВнесения = 0 Тогда
							Прервать;
						КонецЕсли;	
					КонецЦикла;
					
					
				КонецЦикла;
				
				Если ТЗПартионныхСтрок.Количество() > 0 Тогда
					ВнестиПартионныеСтроки(ПараметрыДокумента, ДокументЕГАИС, СсылкаНаТекущийДокументРеализации, Задание, ТЗПартионныхСтрок);
					ДокументЕГАИС.Записать();
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;	
		
	КонецЕсли;
	
КонецПроцедуры
Процедура ВнестиПартионныеСтроки(ПараметрыДокумента,ДокументЕГАИС,СсылкаНаТекущийДокументРеализации,Задание,ТЗПартионныхСтрок)
	
	Если ПараметрыДокумента.ЭтоТТНпоРеализации Тогда
		
		Для каждого СтрТЧ Из ТЗПартионныхСтрок Цикл
			Количество = СтрТЧ.Количество;
			
			лЦена = 0;
			лИдентификаторСтроки = Неопределено;
			
			лСерия = СтрТЧ.СерияНоменклатуры;	
			ДанныеПоСправкам = ДатаМобайл_ОбщийМодуль.ПолучитьСправкиПоСерии(лСерия);
			лСправкаА = ДанныеПоСправкам.СправкаА;
			лСправкаБ = ДанныеПоСправкам.СправкаБ;
			лНомерПартии = Лев(Строка(лСерия), 36);
			
			НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьЕГАИСПоНоменклатуре(СтрТЧ.Номенклатура,лСерия);
			лКоличествоСтрокВРеализации = СсылкаНаТекущийДокументРеализации.Товары.Количество();
			ДанныеСтрокиРеализации = НайтиСтрокуТТНвРеализации(Задание,ДокументЕГАИС,СсылкаНаТекущийДокументРеализации,СтрТЧ,лСерия);
			
			лЦена = ДанныеСтрокиРеализации.Цена;
			лИдентификаторСтроки = ДанныеСтрокиРеализации.ИдентификаторСтроки;
			
			СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(Новый Структура("АлкогольнаяПродукция,СправкаА,СправкаБ,НомерПартии,Цена",НоменклатураЕГАИС,лСправкаА,лСправкаБ,лНомерПартии,лЦена));
			
			Если СтрокиПоиска.Количество() = 0 Тогда // нет строк добавляем		
				СтрокаТабличнойЧасти = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].Добавить();
				СтрокаТабличнойЧасти.АлкогольнаяПродукция = НоменклатураЕГАИС;
				СтрокаТабличнойЧасти.СправкаА = лСправкаА;
				СтрокаТабличнойЧасти.СправкаБ = лСправкаБ;
				
				Если ПараметрыДокумента.ЕстьРеквизитТЧ_КлючСвязи Тогда
					СтрокаТабличнойЧасти.КлючСвязи = ПолучитьНовыйКлючСтрокиЕгаисОпт(ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор]);
				КонецЕсли;
				
				Если ПараметрыДокумента.ЕстьРеквизитТЧ_ИдентификаторСтроки Тогда
					НуженНовыйИдентификатор = Ложь;
					
					Если лИдентификаторСтроки = Неопределено Тогда
						НуженНовыйИдентификатор = Истина;
					Иначе
						СтрокиПоискаИдентификатора = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(Новый Структура("ИдентификаторСтроки", Формат(лИдентификаторСтроки, "ЧГ=")));
						
						Если СтрокиПоискаИдентификатора.Количество()= 0 Тогда
							СтрокаТабличнойЧасти.ИдентификаторСтроки = Формат(лИдентификаторСтроки, "ЧГ=");
							СтрокаТабличнойЧасти.ИдентификаторСтрокиЧислом = Число(Формат(СтрокаТабличнойЧасти.ИдентификаторСтроки, "ЧГ="));
						Иначе
							НуженНовыйИдентификатор = Истина;
						КонецЕсли;
					КонецЕсли;
					
					Если НуженНовыйИдентификатор Тогда
						ИдентификаторСтроки = ПолучитьНовыйИдентификаторЕГАИС(Задание, ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор], лКоличествоСтрокВРеализации);
						СтрокаТабличнойЧасти.ИдентификаторСтроки = Формат(ИдентификаторСтроки, "ЧГ=");
						СтрокаТабличнойЧасти.ИдентификаторСтрокиЧислом = Число(Формат(СтрокаТабличнойЧасти.ИдентификаторСтроки, "ЧГ="));
					КонецЕсли;	
				КонецЕсли;		
				
				СтрокаТабличнойЧасти.НомерПартии = лНомерПартии;
				СтрокаТабличнойЧасти.Цена = лЦена;
				СтрокаТабличнойЧасти.Крепость =  СтрокаТабличнойЧасти.АлкогольнаяПродукция.Крепость;
				СтрокаТабличнойЧасти.КрепостьМин = СтрокаТабличнойЧасти.АлкогольнаяПродукция.Крепость;
				СтрокаТабличнойЧасти.КрепостьМакс = СтрокаТабличнойЧасти.АлкогольнаяПродукция.Крепость;	
				
			Иначе  // есть строка				
				СтрокаТабличнойЧасти = СтрокиПоиска[0];
			КонецЕсли;	
			
			СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.Количество + Количество;
			СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
		КонецЦикла;	
		
	КонецЕсли;
	
КонецПроцедуры
Функция НайтиКоробаПалеты(Палета, Период = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Палета", Палета);
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Период), Период, Неопределено));
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	алкХранилищеУпаковокСрезПоследних.Упаковка КАК Упаковка
	|ИЗ
	|	РегистрСведений.алкХранилищеУпаковок.СрезПоследних(&Период, ИерархияУпаковки = &Палета) КАК алкХранилищеУпаковокСрезПоследних";
	МассивКоробов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Упаковка");
	
	Возврат МассивКоробов;
	
КонецФункции
Функция НайтиМаркиУпаковки(Упаковка, Период = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Упаковка", Упаковка);
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Период), Период, Неопределено));
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	алкХранилищеАкцизныхМарокСрезПоследних.Марка КАК Марка
	|ИЗ
	|	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(&Период, Упаковка = &Упаковка) КАК алкХранилищеАкцизныхМарокСрезПоследних
	|ГДЕ
	|	алкХранилищеАкцизныхМарокСрезПоследних.ОтметкаВыбытия = ЛОЖЬ
	|	И алкХранилищеАкцизныхМарокСрезПоследних.АлкогольнаяПродукция <> ЗНАЧЕНИЕ(Справочник.алкКлассификаторАлкогольнойПродукцииЕГАИС.ПустаяСсылка)";
	
	МассивМарок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Марка");
	
	Возврат МассивМарок;
	
КонецФункции
Функция НайтиДанныеУпакЛиста(УпаковочныйЛист) 
	
	УпаковочныйЛист = СтрЗаменить(УпаковочныйЛист,"/","");
	
	Если Лев(УпаковочныйЛист,3) = "UPL" Тогда 
		КодУпакЛиста = Прав(УпаковочныйЛист,СтрДлина(УпаковочныйЛист) - 3); 
	Иначе     
		КодУпакЛиста = УпаковочныйЛист; 
	КонецЕсли; 
	
	Запрос = Новый Запрос; 
	Запрос.Текст = "ВЫБРАТЬ 
	|     ДатаМобайл_УпаковочныйЛистТовары.ЕГАИС_Номенклатура КАК НоменклатураЕГАИС,
	|     ДатаМобайл_УпаковочныйЛистТовары.СправкаБ КАК ЕгаисСправкаБ, 	
	|     ДатаМобайл_УпаковочныйЛистТовары.Марка КАК ЕгаисПолныйКод,
	|     ВЫБОР 
	|     	КОГДА ДатаМобайл_УпаковочныйЛистТовары.Количество = 1 или ДатаМобайл_УпаковочныйЛистТовары.Марка <> """" ТОГДА """" 
	|     	ИНАЧЕ ДатаМобайл_УпаковочныйЛистТовары.Короб 
	|     КОНЕЦ КАК Короб,
	|     ВЫБОР 
	|     	КОГДА ДатаМобайл_УпаковочныйЛистТовары.Количество = 1 или ДатаМобайл_УпаковочныйЛистТовары.Марка <> """" ТОГДА """" 
	|     	ИНАЧЕ ДатаМобайл_УпаковочныйЛистТовары.Палета 
	|     КОНЕЦ КАК Палета,
	|     ДатаМобайл_УпаковочныйЛистТовары.Количество КАК Количество,
	|     ДатаМобайл_УпаковочныйЛистТовары.Номенклатура КАК Номенклатура,
	|     ДатаМобайл_УпаковочныйЛистТовары.Характеристика КАК ХарактеристикаНоменклатуры,
	|     ДатаМобайл_УпаковочныйЛистТовары.Упаковка КАК ЕдиницаИзмерения,
	|     ДатаМобайл_УпаковочныйЛистТовары.Штрихкод КАК ШтрихКод,
	|     ДатаМобайл_УпаковочныйЛистТовары.Ссылка.Ответственный КАК Пользователь
	|ИЗ 
	|     Документ.ДатаМобайл_УпаковочныйЛист.Товары КАК ДатаМобайл_УпаковочныйЛистТовары 
	|ГДЕ 
	|     ДатаМобайл_УпаковочныйЛистТовары.Количество > 0 
	|     И (ДатаМобайл_УпаковочныйЛистТовары.Ссылка.Код = &КодУпакЛиста)"; 
	
	// искать по коду, если по коду нет - искать по номеру, где код не пустой
	
	Запрос.УстановитьПараметр("КодУпакЛиста", КодУпакЛиста); 		
	Рез = Запрос.Выполнить().Выгрузить(); 
	
	Если Рез.Количество() = 0 Тогда
		Рез = "";
		Запрос.Текст = "ВЫБРАТЬ 
		|     ДатаМобайл_УпаковочныйЛистТовары.ЕГАИС_Номенклатура КАК НоменклатураЕГАИС,
		|     ДатаМобайл_УпаковочныйЛистТовары.СправкаБ КАК ЕгаисСправкаБ, 	
		|     ДатаМобайл_УпаковочныйЛистТовары.Марка КАК ЕгаисПолныйКод,
		|     ВЫБОР 
		|     	КОГДА ДатаМобайл_УпаковочныйЛистТовары.Количество = 1 или ДатаМобайл_УпаковочныйЛистТовары.Марка <> """" ТОГДА """" 
		|     	ИНАЧЕ ДатаМобайл_УпаковочныйЛистТовары.Короб 
		|     КОНЕЦ КАК Короб,
		|     ВЫБОР 
		|     	КОГДА ДатаМобайл_УпаковочныйЛистТовары.Количество = 1 или ДатаМобайл_УпаковочныйЛистТовары.Марка <> """" ТОГДА """" 
		|     	ИНАЧЕ ДатаМобайл_УпаковочныйЛистТовары.Палета 
		|     КОНЕЦ КАК Палета,	
		|     ДатаМобайл_УпаковочныйЛистТовары.Количество КАК Количество,
		|     ДатаМобайл_УпаковочныйЛистТовары.Номенклатура КАК Номенклатура,
		|     ДатаМобайл_УпаковочныйЛистТовары.Характеристика КАК ХарактеристикаНоменклатуры,
		|     ДатаМобайл_УпаковочныйЛистТовары.Упаковка КАК ЕдиницаИзмерения,
		|     ДатаМобайл_УпаковочныйЛистТовары.Штрихкод КАК ШтрихКод,
		|     ДатаМобайл_УпаковочныйЛистТовары.Ссылка.Ответственный КАК Пользователь
		|ИЗ 
		|     Документ.ДатаМобайл_УпаковочныйЛист.Товары КАК ДатаМобайл_УпаковочныйЛистТовары 
		|ГДЕ 
		|     ДатаМобайл_УпаковочныйЛистТовары.Количество > 0 
		|     И (ДатаМобайл_УпаковочныйЛистТовары.Ссылка.Номер = &КодУпакЛиста)
		|	   И  ДатаМобайл_УпаковочныйЛистТовары.Ссылка.Код = """""; 
		
		Запрос.УстановитьПараметр("КодУпакЛиста", КодУпакЛиста); 		
		Рез = Запрос.Выполнить().Выгрузить(); 	
	КонецЕсли;
	
	Возврат  Рез;
	
КонецФункции
Функция ПроверитьУпаковочныйлистЭтоКороб(УпаковочныйЛист, Период = Неопределено)
	
	Если ПустаяСтрока(УпаковочныйЛист) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Упаковка", УпаковочныйЛист);
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Период), Период, Неопределено));
	Запрос.Текст = "ВЫБРАТЬ
	|	алкХранилищеУпаковокСрезПоследних.Упаковка,
	|	алкХранилищеУпаковокСрезПоследних.ИерархияУпаковки
	|ИЗ
	|	РегистрСведений.алкХранилищеУпаковок.СрезПоследних(&Период, ИерархияУпаковки = &Упаковка) КАК алкХранилищеУпаковокСрезПоследних";
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции
Функция НайтиТекущийКоробМарки(Марка, Период = Неопределено)
	
	Если ПустаяСтрока(Марка) Тогда
		Возврат "";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Марка", Марка);
	Запрос.УстановитьПараметр("Период", ?(ЗначениеЗаполнено(Период), Период, Неопределено));
	Запрос.Текст = "ВЫБРАТЬ
	|	алкХранилищеАкцизныхМарокСрезПоследних.Упаковка
	|ИЗ
	|	РегистрСведений.алкХранилищеАкцизныхМарок.СрезПоследних(&Период, Марка = &Марка) КАК алкХранилищеАкцизныхМарокСрезПоследних";
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Упаковка;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции
Функция СобратьПараметрыЕгаисОпт(ДокументЕГАИС, Задание)
	
	МетаданныеДокумента = ДокументЕГАИС.Метаданные();
	ПараметрыДокумента = Новый Структура();
	
	ПараметрыДокумента.Вставить("Док", ДокументЕГАИС);
	ПараметрыДокумента.Вставить("Об", Задание);
	ПараметрыДокумента.Вставить("мВалютаРегламентированногоУчета", Константы.ВалютаРегламентированногоУчета.Получить());
	ПараметрыДокумента.Вставить("мВалютаУпрУчета", Константы.ВалютаУправленческогоУчета.Получить());
	
	Если СокрЛП(Задание.Шаблон.ВидДокументаНового) = "" Тогда // старая схема
		ПараметрыДокумента.Вставить("ИмяТЧПодбор", Задание.Шаблон.ИмяТабличнойЧастиПодбор);		
	Иначе // новая схема	
		ПараметрыДокумента.Вставить("ИмяТЧПодбор", Задание.Шаблон.ИмяТабличнойЧастиНовойПодбор);
	КонецЕсли;
	
	ПараметрыДокумента.Вставить("КодыНепроверяемыхМарок", ДатаМобайл_ОбщийМодуль.СформироватьСписокНепроверяемыхМарокЕГАИС());
	ПараметрыДокумента.Вставить("ЕстьРеквизит_ВидДокумента", МетаданныеДокумента.Реквизиты.Найти("ВидДокумента") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьРеквизит_ФорматТТН", МетаданныеДокумента.Реквизиты.Найти("ФорматТТН") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьРеквизит_ФорматАкта", МетаданныеДокумента.Реквизиты.Найти("ФорматАкта") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьРеквизит_СтатусДокумента", МетаданныеДокумента.Реквизиты.Найти("СтатусДокумента") <> Неопределено);
	
	ЭтоВходящееНаправление = Ложь;
	Если ПараметрыДокумента.ЕстьРеквизит_ВидДокумента Тогда
		Если ДокументЕГАИС.ВидДокумента = Перечисления.алкВидыДокументовЕГАИС.Входящий Тогда
			ЭтоВходящееНаправление = Истина;
		КонецЕсли;
	КонецЕсли;
	ПараметрыДокумента.Вставить("ЭтоВходящееНаправление", ЭтоВходящееНаправление);
	
	ПараметрыДокумента.Вставить("ЕстьТЧМарок", МетаданныеДокумента.ТабличныеЧасти.Найти("АкцизныеМарки") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьТЧКодыМарок", МетаданныеДокумента.ТабличныеЧасти.Найти("КодыМарок") <> Неопределено);
	
	ПараметрыДокумента.Вставить("ЕстьТЧУпаковок", МетаданныеДокумента.ТабличныеЧасти.Найти("Упаковки") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьТЧСерий", МетаданныеДокумента.ТабличныеЧасти.Найти("Серии") <> Неопределено);
	
	ПараметрыДокумента.Вставить("ЕстьРеквизитТЧ_Марка", МетаданныеДокумента.ТабличныеЧасти[ПараметрыДокумента.ИмяТЧПодбор].Реквизиты.Найти("Марка") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьРеквизитТЧ_ЕГАИС_Номенклатура", МетаданныеДокумента.ТабличныеЧасти[ПараметрыДокумента.ИмяТЧПодбор].Реквизиты.Найти("ЕГАИС_Номенклатура") <> Неопределено);		
	ПараметрыДокумента.Вставить("ЕстьРеквизитТЧ_КлючСвязи", МетаданныеДокумента.ТабличныеЧасти[ПараметрыДокумента.ИмяТЧПодбор].Реквизиты.Найти("КлючСвязи") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьРеквизитТЧ_КлючСтроки", МетаданныеДокумента.ТабличныеЧасти[ПараметрыДокумента.ИмяТЧПодбор].Реквизиты.Найти("КлючСтроки") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьРеквизитТЧ_ИдентификаторСтроки", МетаданныеДокумента.ТабличныеЧасти[ПараметрыДокумента.ИмяТЧПодбор].Реквизиты.Найти("ИдентификаторСтроки") <> Неопределено);
	
	ПараметрыДокумента.Вставить("ЕстьРеквизитТЧ_Количество", МетаданныеДокумента.ТабличныеЧасти[ПараметрыДокумента.ИмяТЧПодбор].Реквизиты.Найти("Количество") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьРеквизитТЧ_СправкаА", МетаданныеДокумента.ТабличныеЧасти[ПараметрыДокумента.ИмяТЧПодбор].Реквизиты.Найти("СправкаА") <> Неопределено);
	ПараметрыДокумента.Вставить("ЕстьРеквизитТЧ_СправкаБ", МетаданныеДокумента.ТабличныеЧасти[ПараметрыДокумента.ИмяТЧПодбор].Реквизиты.Найти("СправкаБ") <> Неопределено);
	
	ЭтоТТНпоРеализации = Ложь;
	Если (СокрЛП(Задание.Шаблон.ВидДокумента) = "ДатаМобайл_ЗаявкаНаСклад" Или СокрЛП(Задание.Шаблон.ВидДокумента) = "РеализацияТоваровУслуг") И МетаданныеДокумента.Имя = "алкТоварноТранспортнаяНакладнаяЕГАИС" Тогда
		ЭтоТТНпоРеализации = Истина;
	КонецЕсли;   
	
	Если (СокрЛП(Задание.Шаблон.ВидДокумента) = "ЗаказКлиента" Или СокрЛП(Задание.Шаблон.ВидДокумента) = "РеализацияТоваровУслуг") И МетаданныеДокумента.Имя = "алкТоварноТранспортнаяНакладнаяЕГАИС" Тогда
		ЭтоТТНпоРеализации = Истина;
	КонецЕсли;
	ПараметрыДокумента.Вставить("ЭтоТТНпоРеализации", ЭтоТТНпоРеализации);
	
	ЭтоТТНпоПеремещению = Ложь;
	Если СокрЛП(Задание.Шаблон.ВидДокумента) = "ПеремещениеТоваров" И МетаданныеДокумента.Имя = "алкТоварноТранспортнаяНакладнаяЕГАИС" 
		Или СокрЛП(Задание.Шаблон.ВидДокумента) = "ЗаказКлиента" И СокрЛП(Задание.Шаблон.ВидДокументаНового) = "ЧекККМ" И МетаданныеДокумента.Имя = "алкТоварноТранспортнаяНакладнаяЕГАИС" Тогда
		ЭтоТТНпоПеремещению = Истина;
	КонецЕсли;
	ПараметрыДокумента.Вставить("ЭтоТТНпоПеремещению", ЭтоТТНпоПеремещению);
	
	ЭтоАктПоСписанию = Ложь;
	Если (СокрЛП(Задание.Шаблон.ВидДокумента) = "СписаниеНедостачТоваров" Или СокрЛП(Задание.Шаблон.ВидДокумента) = "ОрдерНаОтражениеНедостачТоваров") И МетаданныеДокумента.Имя = "алкАктОСписанииТовара" Тогда
		ЭтоАктПоСписанию = Истина;
	КонецЕсли;
	ПараметрыДокумента.Вставить("ЭтоАктПоСписанию", ЭтоАктПоСписанию);
	
	ЭтоТТНпоВозвратТоваровПоставщику = Ложь;
	Если СокрЛП(Задание.Шаблон.ВидДокумента) = "ВозвратТоваровПоставщику" И МетаданныеДокумента.Имя = "алкТоварноТранспортнаяНакладнаяЕГАИС" Тогда
		ЭтоТТНпоВозвратТоваровПоставщику = Истина;
	КонецЕсли;
	ПараметрыДокумента.Вставить("ЭтоТТНпоВозвратТоваровПоставщику", ЭтоТТНпоВозвратТоваровПоставщику);
	
	Возврат ПараметрыДокумента;
	
КонецФункции
Процедура ОбработатьСтрокуТЧ_Марки_ЕГАИС(ДокументЕГАИС, ПараметрыДокумента, Задание, СтрТЧ,
	лТекущаяМарка, лТекущийКороб, лТекущаяПалета, Количество, ОписаниеОшибкиЗагрузки = Неопределено)	
	
	МетаданныеДокумента = ДокументЕГАИС.Метаданные();
	Модуль_алкИнтеграцияЕГАИСВызовСервера = ДатаМобайл_ОбщийМодуль.ОбщийМодуль("алкИнтеграцияЕГАИСВызовСервера");
	
	//ДанныеНоменклатурыПоМарке = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруАкцизнойМарки(лТекущаяМарка);
	//лСправкаА=Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	//лСправкаБ=Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	//лСерия = Справочники.СерииНоменклатуры.ПустаяСсылка();
	//Если ДанныеНоменклатурыПоМарке.Количество()>0 Тогда
	//	лСправкаА = ДанныеНоменклатурыПоМарке[0].СправкаА;
	//	лСправкаБ = ДанныеНоменклатурыПоМарке[0].СправкаБ;
	//	лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(лСправкаБ);
	//КонецЕсли;
	
	лСправкаА = Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка(); 
	лСправкаБ = Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	лСерия = Справочники.СерииНоменклатуры.ПустаяСсылка();
	лЦена = 0;
	лИдентификаторСтроки = Неопределено;
	лКоличествоСтрокВРеализации = 0;
	
	Если СтрДлина(лТекущаяМарка) = 68 И СтрТЧ.ЕгаисМарка <> "" Тогда
		лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоМарке(СтрТЧ.НоменклатураЕГАИС, СтрТЧ.ЕгаисМарка);
		ДанныеПоСправкам = ДатаМобайл_ОбщийМодуль.ПолучитьСправкиПоСерии(лСерия);
		лСправкаА = ДанныеПоСправкам.СправкаА;
		лСправкаБ = ДанныеПоСправкам.СправкаБ;
	Иначе
		ДанныеНоменклатурыПоМарке = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруАкцизнойМарки(лТекущаяМарка);
		
		Если ДанныеНоменклатурыПоМарке.Количество() > 0 Тогда
			лСправкаА = ДанныеНоменклатурыПоМарке[0].СправкаА;
			лСправкаБ = ДанныеНоменклатурыПоМарке[0].СправкаБ;
			лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(лСправкаБ);
		КонецЕсли;
	КонецЕсли;	
	
	Если (Задание.Шаблон.ПроверкаЗадания = 3 Или Задание.Шаблон.ПроверкаЗадания = 6) И (лТекущийКороб <> "" Или лТекущаяПалета <> "") Тогда
		СтрТЧ.НоменклатураЕГАИС = ДатаМобайл_ОбщийМодуль.ПолучитьЕГАИСПоМарке(лТекущаяМарка);	
	КонецЕсли;	
	
	Если ПараметрыДокумента.ЭтоТТНпоРеализации Тогда
		Если Задание.ДополнительныйДокумент <> Неопределено Тогда
			СсылкаНаТекущийДокументРеализации = Задание.ДополнительныйДокумент;
		Иначе
			СсылкаНаТекущийДокументРеализации = Задание.ИсходныйДокумент;
		КонецЕсли;
		
		лКоличествоСтрокВРеализации = СсылкаНаТекущийДокументРеализации.Товары.Количество();
		лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьПартиюПоСправкамТТН(лСправкаА, лСправкаБ, СтрТЧ.Номенклатура, ДокументЕГАИС, СсылкаНаТекущийДокументРеализации);
		лНомерПартии = Лев(Строка(лСерия), 36);
		
		Если СтрТЧ.Номенклатура.Пустая() Тогда
			Попытка СтрТЧ.Номенклатура = лСерия.алкВладелец; Исключение КонецПопытки;	
		КонецЕсли;
		
		ДанныеСтрокиРеализации = НайтиСтрокуТТНвРеализации(Задание, ДокументЕГАИС, СсылкаНаТекущийДокументРеализации, СтрТЧ, лСерия);
		 // лЦена = НайтиЦенуТТНвРеализации(Задание, ДокументЕГАИС, СтрТЧ, лСерия); 
		лЦена = ДанныеСтрокиРеализации.Цена;
		лИдентификаторСтроки = ДанныеСтрокиРеализации.ИдентификаторСтроки;
		СтруктураПоиска = Новый Структура("АлкогольнаяПродукция, СправкаА, СправкаБ, НомерПартии, Цена", СтрТЧ.НоменклатураЕГАИС, лСправкаА, лСправкаБ, лНомерПартии, лЦена);
		СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(СтруктураПоиска);
		
	ИначеЕсли ПараметрыДокумента.ЭтоТТНпоПеремещению Тогда
		
		СсылкаНаТекущийДокументПеремещения = Задание.ИсходныйДокумент;
		лКоличествоСтрокВРеализации = СсылкаНаТекущийДокументПеремещения.Товары.Количество();
		лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьПартиюПоСправкамТТН(лСправкаА, лСправкаБ, СтрТЧ.Номенклатура, ДокументЕГАИС, СсылкаНаТекущийДокументПеремещения);
		лНомерПартии = Лев(Строка(лСерия), 36);
		
		Если СтрТЧ.Номенклатура.Пустая() Тогда
			Попытка СтрТЧ.Номенклатура = лСерия.алкВладелец; Исключение КонецПопытки;	
		КонецЕсли;
		
		ДанныеСтрокиПеремещение = НайтиСтрокуТТНвПеремещение(Задание, ДокументЕГАИС, СсылкаНаТекущийДокументПеремещения, СтрТЧ, лСерия);
		лИдентификаторСтроки = ДанныеСтрокиПеремещение.ИдентификаторСтроки;
		
		лВидЦены = СсылкаНаТекущийДокументПеремещения.ВидЦены;
		лЦена = ПолучитьЦенуТовара(СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры, лВидЦены);
		СтруктураПоиска = Новый Структура("АлкогольнаяПродукция, СправкаА, СправкаБ, НомерПартии, Цена", СтрТЧ.НоменклатураЕГАИС, лСправкаА, лСправкаБ, лНомерПартии, лЦена);
		СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(СтруктураПоиска);
		
	ИначеЕсли МетаданныеДокумента.Имя = "алкТоварноТранспортнаяНакладнаяЕГАИС" И Не ПараметрыДокумента.ЭтоВходящееНаправление Тогда	
		лЦена = 0;
		лНомерПартии = Лев(Строка(лСерия), 36);
		
		МассивРеализаций = Модуль_алкИнтеграцияЕГАИСВызовСервера.ПолучитьМассивУчетныхДокументовДляДокументаЕГАИС(ДокументЕГАИС.Ссылка);
		
		Если МассивРеализаций.Количество() = 0 Тогда
			СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(Новый Структура("АлкогольнаяПродукция, СправкаА, СправкаБ", СтрТЧ.НоменклатураЕГАИС, лСправкаА, лСправкаБ));
		Иначе
			лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьПартиюПоСправкамТТН(лСправкаА, лСправкаБ, СтрТЧ.Номенклатура, ДокументЕГАИС, МассивРеализаций[0].УчетныйДокумент);
			лНомерПартии = Лев(Строка(лСерия), 36);
			Если СтрТЧ.Номенклатура.Пустая() Тогда
				Попытка СтрТЧ.Номенклатура = лСерия.алкВладелец; Исключение КонецПопытки;	
			КонецЕсли;
			
			лКоличествоСтрокВРеализации = МассивРеализаций[0].УчетныйДокумент.Товары.Количество();
			ДанныеСтрокиРеализации = НайтиСтрокуТТНвРеализации(Задание, ДокументЕГАИС, МассивРеализаций[0].УчетныйДокумент, СтрТЧ, лСерия);
			
			лЦена = ДанныеСтрокиРеализации.Цена;
			лИдентификаторСтроки = ДанныеСтрокиРеализации.ИдентификаторСтроки;
			СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(Новый Структура("АлкогольнаяПродукция, СправкаА, СправкаБ, НомерПартии, Цена", СтрТЧ.НоменклатураЕГАИС, лСправкаА, лСправкаБ, лНомерПартии, лЦена));
		КонецЕсли;
		
	ИначеЕсли ПараметрыДокумента.ЕстьРеквизитТЧ_Марка И ПараметрыДокумента.ЕстьРеквизитТЧ_ЕГАИС_Номенклатура Тогда
		СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(Новый Структура("Марка", лТекущаяМарка));							
	ИначеЕсли ПараметрыДокумента.ЕстьРеквизитТЧ_СправкаА И ПараметрыДокумента.ЕстьРеквизитТЧ_СправкаБ Тогда
		СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(Новый Структура("АлкогольнаяПродукция, СправкаА, СправкаБ", СтрТЧ.НоменклатураЕГАИС, лСправкаА, лСправкаБ));
	Иначе	
		СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(Новый Структура("АлкогольнаяПродукция", СтрТЧ.НоменклатураЕГАИС));
	КонецЕсли;
	
	Если СтрокиПоиска.Количество() = 0 Тогда // нет строк добавляем		
		СтрокаТабличнойЧасти = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].Добавить();
		
		Если ПараметрыДокумента.ЕстьРеквизитТЧ_ЕГАИС_Номенклатура Тогда
			СтрокаТабличнойЧасти.ЕГАИС_Номенклатура = СтрТЧ.НоменклатураЕГАИС;
		Иначе	
			СтрокаТабличнойЧасти.АлкогольнаяПродукция = СтрТЧ.НоменклатураЕГАИС;
		КонецЕсли;
		
		Если ПараметрыДокумента.ЕстьРеквизитТЧ_СправкаА И ПараметрыДокумента.ЕстьРеквизитТЧ_СправкаБ Тогда
			СтрокаТабличнойЧасти.СправкаА = лСправкаА;
			СтрокаТабличнойЧасти.СправкаБ = лСправкаБ;
		КонецЕсли;
		
		Если ПараметрыДокумента.ЕстьРеквизитТЧ_КлючСвязи Тогда
			СтрокаТабличнойЧасти.КлючСвязи = ПолучитьНовыйКлючСтрокиЕгаисОпт(ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор]);
		КонецЕсли;
		
		Если ПараметрыДокумента.ЕстьРеквизитТЧ_ИдентификаторСтроки Тогда
			НуженНовыйИдентификатор = Ложь;
			Если лИдентификаторСтроки = Неопределено Тогда
				НуженНовыйИдентификатор = Истина;
			Иначе
				СтрокиПоискаИдентификатора = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(Новый Структура("ИдентификаторСтроки", Формат(лИдентификаторСтроки, "ЧГ = ")));
				Если СтрокиПоискаИдентификатора.Количество() = 0 Тогда
					СтрокаТабличнойЧасти.ИдентификаторСтроки = Формат(лИдентификаторСтроки, "ЧГ = ");
					СтрокаТабличнойЧасти.ИдентификаторСтрокиЧислом = Число(Формат(СтрокаТабличнойЧасти.ИдентификаторСтроки, "ЧГ = "));
				Иначе
					НуженНовыйИдентификатор = Истина;
				КонецЕсли;
			КонецЕсли;
			
			Если НуженНовыйИдентификатор Тогда
				СтрокаТабличнойЧасти.ИдентификаторСтроки = Формат(ПолучитьНовыйИдентификаторЕГАИС(Задание, ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор], лКоличествоСтрокВРеализации), "ЧГ = ");
				СтрокаТабличнойЧасти.ИдентификаторСтрокиЧислом = Число(Формат(СтрокаТабличнойЧасти.ИдентификаторСтроки, "ЧГ = "));
			КонецЕсли;	
		КонецЕсли;
		
		Если ПараметрыДокумента.ЭтоТТНпоРеализации 
			Или (МетаданныеДокумента.Имя = "алкТоварноТранспортнаяНакладнаяЕГАИС" И Не ПараметрыДокумента.ЭтоВходящееНаправление) Тогда
			СтрокаТабличнойЧасти.НомерПартии = лНомерПартии;
			СтрокаТабличнойЧасти.Цена = лЦена;
			СтрокаТабличнойЧасти.Крепость = СтрокаТабличнойЧасти.АлкогольнаяПродукция.Крепость;
			СтрокаТабличнойЧасти.КрепостьМин = СтрокаТабличнойЧасти.АлкогольнаяПродукция.Крепость;
			СтрокаТабличнойЧасти.КрепостьМакс = СтрокаТабличнойЧасти.АлкогольнаяПродукция.Крепость;
		КонецЕсли;
		
		Если ПараметрыДокумента.ЕстьРеквизитТЧ_Марка И ПараметрыДокумента.ЕстьРеквизитТЧ_ЕГАИС_Номенклатура Тогда // упаковочный лист
			СтрокаТабличнойЧасти.Марка = лТекущаяМарка;
			СтрокаТабличнойЧасти.DataMatrix = СтрТЧ.ЕгаисМарка;
			СтрокаТабличнойЧасти.Номенклатура = СтрТЧ.Номенклатура;
			СтрокаТабличнойЧасти.Характеристика = СтрТЧ.ХарактеристикаНоменклатуры;
			СтрокаТабличнойЧасти.Штрихкод = СтрТЧ.Штрихкод;			
			СтрокаТабличнойЧасти.Короб = лТекущийКороб;
			СтрокаТабличнойЧасти.Палета = лТекущаяПалета;
			 // СЕРИЯ				
			СтрокаТабличнойЧасти.Серия = лСерия;
			СтрокаТабличнойЧасти.СправкаБ = лСправкаБ;
		КонецЕсли;
		
	Иначе // есть строка				
		СтрокаТабличнойЧасти = СтрокиПоиска[0];
	КонецЕсли;	
	
	 // МАРКИ
	Если ПараметрыДокумента.ЕстьТЧМарок И лТекущаяМарка<>"" И Не ПараметрыДокумента.ЭтоВходящееНаправление Тогда		
		ЕстьРеквизитТЧ_КлючСвязи_Марки = МетаданныеДокумента.ТабличныеЧасти["АкцизныеМарки"].Реквизиты.Найти("КлючСвязи") <> Неопределено;
		ЕстьРеквизитТЧ_НомерКоробки_Марки = МетаданныеДокумента.ТабличныеЧасти["АкцизныеМарки"].Реквизиты.Найти("НомерКоробки") <> Неопределено; 
		СтрокиПоискаМарок = ДокументЕГАИС.АкцизныеМарки.НайтиСтроки(Новый Структура("КодАкцизнойМарки", лТекущаяМарка));
		
		Если СтрокиПоискаМарок.Количество() = 0 Тогда
			СтрокаМарки = ДокументЕГАИС.АкцизныеМарки.Добавить();
			СтрокаМарки.КодАкцизнойМарки = лТекущаяМарка;
			
			Если ЕстьРеквизитТЧ_КлючСвязи_Марки Тогда
				СтрокаМарки.КлючСвязи = СтрокаТабличнойЧасти.КлючСвязи;
			КонецЕсли;
			
			Если ЕстьРеквизитТЧ_НомерКоробки_Марки Тогда
				СтрокаМарки.НомерКоробки = лТекущийКороб;
			КонецЕсли;
			
		Иначе
			 // ОШИБКА МАРКА УЖЕ ЕСТЬ, ПРИ ЗАГРУЗКЕ НЕ СОЙДЕТСЯ КОЛИЧЕСТВО ПО ТОВАРАМ И МАРКАМ
			ОписаниеОшибкиЗагрузки = "Дубль марки";
			СтрокаМарки = СтрокиПоискаМарок[0];
		КонецЕсли;		
	КонецЕсли;		
	 // МАРКИ
	
	 // МАРКИ СТАРЫЕ
	Если ПараметрыДокумента.ЕстьТЧКодыМарок И лТекущаяМарка<>"" И Не ПараметрыДокумента.ЭтоВходящееНаправление Тогда		
		ЕстьРеквизитТЧ_КлючСвязи_Марки = МетаданныеДокумента.ТабличныеЧасти["КодыМарок"].Реквизиты.Найти("КлючСвязи") <> Неопределено;
		СтрокиПоискаМарок = ДокументЕГАИС.КодыМарок.НайтиСтроки(Новый Структура("Код", лТекущаяМарка));
		
		Если СтрокиПоискаМарок.Количество() = 0 Тогда
			СтрокаМарки = ДокументЕГАИС.КодыМарок.Добавить();
			СтрокаМарки.Код = лТекущаяМарка;
			
			Если ЕстьРеквизитТЧ_КлючСвязи_Марки Тогда
				СтрокаМарки.КлючСвязи = СтрокаТабличнойЧасти.КлючСвязи;
			КонецЕсли;
		Иначе
			 // ОШИБКА МАРКА УЖЕ ЕСТЬ, ПРИ ЗАГРУЗКЕ НЕ СОЙДЕТСЯ КОЛИЧЕСТВО ПО ТОВАРАМ И МАРКАМ
			ОписаниеОшибкиЗагрузки = "Дубль марки";
			СтрокаМарки = СтрокиПоискаМарок[0];
		КонецЕсли;		
	КонецЕсли;		
	 // МАРКИ	
	
	 // УПАКОВКИ
	Если ПараметрыДокумента.ЕстьТЧУпаковок И лТекущийКороб <> "" И Не ПараметрыДокумента.ЭтоВходящееНаправление Тогда	
		СтрокиПоискаУпаковок = ДокументЕГАИС.Упаковки.НайтиСтроки(Новый Структура("Упаковка, ИерархияУпаковки", лТекущийКороб, лТекущаяПалета));
		
		Если СтрокиПоискаУпаковок.Количество() = 0 Тогда
			СтрокаУпаковки = ДокументЕГАИС.Упаковки.Добавить();
			СтрокаУпаковки.Упаковка = лТекущийКороб;
			СтрокаУпаковки.ИерархияУпаковки = лТекущаяПалета;
		КонецЕсли;
	КонецЕсли;
	
	Если ПараметрыДокумента.ЕстьТЧУпаковок И лТекущаяПалета <> "" И Не ПараметрыДокумента.ЭтоВходящееНаправление Тогда	
		СтрокиПоискаУпаковок = ДокументЕГАИС.Упаковки.НайтиСтроки(Новый Структура("Упаковка, ИерархияУпаковки", лТекущаяПалета, ""));
		
		Если СтрокиПоискаУпаковок.Количество() = 0 Тогда
			СтрокаУпаковки = ДокументЕГАИС.Упаковки.Добавить();
			СтрокаУпаковки.Упаковка = лТекущаяПалета;
			СтрокаУпаковки.ИерархияУпаковки = "";
		КонецЕсли;
	КонецЕсли;		
	 // УПАКОВКИ
	
	Если ПараметрыДокумента.ЕстьРеквизитТЧ_Количество Тогда
		СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.Количество+Количество;
	КонецЕсли;
	
	Если ПараметрыДокумента.ЭтоТТНпоРеализации Или (МетаданныеДокумента.Имя = "алкТоварноТранспортнаяНакладнаяЕГАИС" И Не ПараметрыДокумента.ЭтоВходящееНаправление) Тогда
		СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
	КонецЕсли;	
	
КонецПроцедуры	
Процедура ОбработатьСтрокуТЧ_Марки(ДокументЕГАИС, ПараметрыДокумента, Задание, СтрТЧ, 
	лТекущаяМарка, лТекущийКороб, лТекущаяПалета, Количество)	
	
	МетаданныеДокумента = ДокументЕГАИС.Метаданные();
	
	ДанныеНоменклатурыПоМарке = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруАкцизнойМарки(лТекущаяМарка);
	лСправкаА = Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	лСправкаБ = Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	лСерия = Справочники.СерииНоменклатуры.ПустаяСсылка();
	
	Если ДанныеНоменклатурыПоМарке.Количество()>0 Тогда
		лСправкаА = ДанныеНоменклатурыПоМарке[0].СправкаА;
		лСправкаБ = ДанныеНоменклатурыПоМарке[0].СправкаБ;
		лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(лСправкаБ);
		//лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьСвободнуюСериюПоСправкамFIFO(лСправкаА, лСправкаБ, СтрТЧ.Номенклатура, ДокументЕГАИС);
	КонецЕсли;	
	
	лСтруктураПоиска = Новый Структура("Номенклатура, Характеристика", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры);	
	
	Если МетаданныеДокумента.Имя = "ПеремещениеТоваров" или МетаданныеДокумента.Имя = "ПересчетТоваров" Тогда
		лСтруктураПоиска.Вставить("Серия", лСерия);
	КонецЕсли;	
	
	СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(лСтруктураПоиска);
	
	Если СтрокиПоиска.Количество() = 0 Тогда // нет строк добавляем		
		СтрокаТабличнойЧасти = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].Добавить();
		
		Если МетаданныеДокумента.Имя = "РеализацияТоваровУслуг" Тогда
			Если СокрЛП(Задание.Шаблон.ВидДокумента) = "ДатаМобайл_ЗаявкаНаСклад" Тогда
				СтрокиПоискаОснование = Задание.ИсходныйДокумент.ДокументОснование.Товары.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры));	
			Иначе // ЗаказКлиента
				СтрокиПоискаОснование = Задание.ИсходныйДокумент.Товары.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры));
			КонецЕсли;
			
			Если СтрокиПоискаОснование.Количество() <> 0 Тогда // есть в основании
				ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокиПоискаОснование[0], , "Количество, КоличествоУпаковок");
				//СтрокаТабличнойЧасти.Серия = лСерия;
			Иначе
				СтрокаТабличнойЧасти.Номенклатура = СтрТЧ.Номенклатура;
				СтрокаТабличнойЧасти.Характеристика = СтрТЧ.ХарактеристикаНоменклатуры;
				//СтрокаТабличнойЧасти.Серия = лСерия;
				СтрокаТабличнойЧасти.Упаковка = СтрТЧ.ЕдиницаИзмерения;
				ОбработатьНовуюСтрокуТЧ(ПараметрыДокумента, ДокументЕГАИС, ПараметрыДокумента.ИмяТЧПодбор, СтрокаТабличнойЧасти);
			КонецЕсли;
		Иначе
			СтрокаТабличнойЧасти.Номенклатура = СтрТЧ.Номенклатура;
			СтрокаТабличнойЧасти.Характеристика = СтрТЧ.ХарактеристикаНоменклатуры;
			Попытка СтрокаТабличнойЧасти.Упаковка = СтрТЧ.ЕдиницаИзмерения; Исключение КонецПопытки;
			
			Если МетаданныеДокумента.Имя = "ПеремещениеТоваров" Или МетаданныеДокумента.Имя = "ПересчетТоваров" Тогда
				СтрокаТабличнойЧасти.Серия = лСерия;
			КонецЕсли;	
			
			ОбработатьНовуюСтрокуТЧ(ПараметрыДокумента, ДокументЕГАИС, ПараметрыДокумента.ИмяТЧПодбор, СтрокаТабличнойЧасти);
		КонецЕсли;
	Иначе // есть строка				
		СтрокаТабличнойЧасти = СтрокиПоиска[0];
	КонецЕсли;	
	
	Если МетаданныеДокумента.Имя = "ПересчетТоваров" Тогда
		СтрокаТабличнойЧасти.КоличествоФакт = СтрокаТабличнойЧасти.КоличествоФакт + Количество;
		Попытка СтрокаТабличнойЧасти.КоличествоУпаковокФакт = СтрокаТабличнойЧасти.КоличествоФакт/?(СтрокаТабличнойЧасти.Упаковка.Числитель = 0, 1, СтрокаТабличнойЧасти.Упаковка.Числитель); Исключение КонецПопытки;
	Иначе
		СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.Количество + Количество;
		Попытка СтрокаТабличнойЧасти.КоличествоУпаковок = СтрокаТабличнойЧасти.Количество/?(СтрокаТабличнойЧасти.Упаковка.Числитель = 0, 1, СтрокаТабличнойЧасти.Упаковка.Числитель); Исключение КонецПопытки;
	КонецЕсли;	
	
	ОбработатьСтрокуТЧ(ДокументЕГАИС, ПараметрыДокумента.ИмяТЧПодбор, СтрокаТабличнойЧасти, Задание.Шаблон);
	
	// Серии в отдельной ТЧ
	Если МетаданныеДокумента.ТабличныеЧасти.Найти("Серии") <> Неопределено И Не лСерия.Пустая() Тогда
		Если МетаданныеДокумента.Имя = "ПоступлениеТоваровУслуг" Или МетаданныеДокумента.Имя = "ПриобретениеТоваровУслуг" Или МетаданныеДокумента.Имя = "РеализацияТоваровУслуг" или (СтрокаТабличнойЧасти.СтатусУказанияСерий<>13 и СтрокаТабличнойЧасти.СтатусУказанияСерий<>14 и СтрокаТабличнойЧасти.СтатусУказанияСерий<>9 и СтрокаТабличнойЧасти.СтатусУказанияСерий<>10 и СтрокаТабличнойЧасти.СтатусУказанияСерий<>0) Тогда
			лСтруктураПоискаСерий = Новый Структура("Номенклатура, Характеристика, Серия", СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.Характеристика, лСерия);
			СтрокиПоискаСерий = ДокументЕГАИС["Серии"].НайтиСтроки(лСтруктураПоискаСерий);
			
			Если СтрокиПоискаСерий.Количество() = 0 Тогда
				СтрокаТабличнойЧастиСерии = ДокументЕГАИС["Серии"].Добавить();
				СтрокаТабличнойЧастиСерии.Номенклатура = СтрокаТабличнойЧасти.Номенклатура;
				СтрокаТабличнойЧастиСерии.Характеристика = СтрокаТабличнойЧасти.Характеристика;
				СтрокаТабличнойЧастиСерии.Серия = лСерия;
				Попытка СтрокаТабличнойЧастиСерии.Склад = СтрокаТабличнойЧасти.Склад; Исключение КонецПопытки;
				Попытка СтрокаТабличнойЧастиСерии.Назначение = СтрокаТабличнойЧасти.Назначение; Исключение КонецПопытки;
			Иначе	
				СтрокаТабличнойЧастиСерии = СтрокиПоискаСерий[0];
			КонецЕсли;
			
			СтрокаТабличнойЧастиСерии.Количество = СтрокаТабличнойЧастиСерии.Количество+Количество;
		КонецЕсли;
	КонецЕсли;	
	// Серии в отдельной ТЧ
	
КонецПроцедуры	
Процедура ОбработатьСтрокуТЧ_Марки_ЧекККМ(ДокументЕГАИС, ПараметрыДокумента, Задание, СтрТЧ, 
	лТекущаяАкцизнаяМарка, лТекущаяМарка, лТекущийКороб, лТекущаяПалета, Количество)	
	
	МетаданныеДокумента = ДокументЕГАИС.Метаданные();
	
	ДанныеНоменклатурыПоМарке = ДатаМобайл_ОбщийМодуль.ПолучитьНоменклатуруАкцизнойМарки(лТекущаяМарка);
	лСправкаА = Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	лСправкаБ = Справочники.алкКлассификаторСправокАиБ.ПустаяСсылка();
	лСерия = Справочники.СерииНоменклатуры.ПустаяСсылка();
	
	Если ДанныеНоменклатурыПоМарке.Количество() > 0 Тогда
		лСправкаА = ДанныеНоменклатурыПоМарке[0].СправкаА;
		лСправкаБ = ДанныеНоменклатурыПоМарке[0].СправкаБ;
		лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьСериюПоСправкам(лСправкаБ);
		// лСерия = ДатаМобайл_ОбщийМодуль.ПолучитьСвободнуюСериюПоСправкамFIFO(лСправкаА, лСправкаБ, СтрТЧ.Номенклатура, ДокументЕГАИС);
	КонецЕсли;	
	
	лСтруктураПоиска = Новый Структура("Номенклатура, Характеристика", СтрТЧ.Номенклатура, СтрТЧ.ХарактеристикаНоменклатуры);
	СтрокиПоиска = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(лСтруктураПоиска);
	
	Если СтрокиПоиска.Количество() = 0 Тогда // нет строк добавляем		
		СтрокаТабличнойЧасти = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].Добавить();
		СтрокаТабличнойЧасти.Номенклатура = СтрТЧ.Номенклатура;
		СтрокаТабличнойЧасти.Характеристика = СтрТЧ.ХарактеристикаНоменклатуры;
		Попытка СтрокаТабличнойЧасти.Упаковка = СтрТЧ.ЕдиницаИзмерения; Исключение КонецПопытки;
		
		ОбработатьНовуюСтрокуТЧ(ПараметрыДокумента, ДокументЕГАИС, ПараметрыДокумента.ИмяТЧПодбор, СтрокаТабличнойЧасти);
		Если Не (ЗначениеЗаполнено(СтрокаТабличнойЧасти.ИдентификаторСтроки)) Тогда
			СтрокаТабличнойЧасти.ИдентификаторСтроки = Новый УникальныйИдентификатор();
		КонецЕсли;	
		
		СтрокиПоискаИсходный = Задание.ИсходныйДокумент[ПараметрыДокумента.ИмяТЧПодбор].НайтиСтроки(лСтруктураПоиска);
		
		Если СтрокиПоискаИсходный.Количество() = 0 Тогда // нет строк
		Иначе	
			СтрокаТабличнойЧасти.Цена = СтрокиПоискаИсходный[0].Цена;
		КонецЕсли;
		
		Если СтрокаТабличнойЧасти.КлючСвязи = 0 Тогда
			ЗначениеМаксимальногоЭлемента = 0; // Значение, заведомо меньшее любого элемента в массиве.
			СписокКлючей = ДокументЕГАИС[ПараметрыДокумента.ИмяТЧПодбор].ВыгрузитьКолонку("КлючСвязи");
			
			Для Индекс = 0 По СписокКлючей.Количество() - 1 Цикл
				Если СписокКлючей[Индекс] > ЗначениеМаксимальногоЭлемента Тогда
					ЗначениеМаксимальногоЭлемента = СписокКлючей[Индекс];
				КонецЕсли;
			КонецЦикла; 
			
			СтрокаТабличнойЧасти.КлючСвязи = ЗначениеМаксимальногоЭлемента + 1;
		КонецЕсли;
		
		Попытка СтрокаТабличнойЧасти.Продавец = ДокументЕГАИС.Кассир; Исключение КонецПопытки;
		
	Иначе // есть строка				
		СтрокаТабличнойЧасти = СтрокиПоиска[0];
	КонецЕсли;	
	
	СтрокаТабличнойЧасти.Количество = СтрокаТабличнойЧасти.Количество + Количество;
	Попытка СтрокаТабличнойЧасти.КоличествоУпаковок = СтрокаТабличнойЧасти.Количество/?(СтрокаТабличнойЧасти.Упаковка.Числитель = 0, 1, СтрокаТабличнойЧасти.Упаковка.Числитель); Исключение КонецПопытки;		
	
	ОбработатьСтрокуТЧ(ДокументЕГАИС, ПараметрыДокумента.ИмяТЧПодбор, СтрокаТабличнойЧасти, Задание.Шаблон);
	
	// Серии в отдельной ТЧ
	Если МетаданныеДокумента.ТабличныеЧасти.Найти("Серии") <> Неопределено и Не лСерия.Пустая() Тогда
		Если МетаданныеДокумента.Имя = "ПоступлениеТоваровУслуг" или МетаданныеДокумента.Имя = "ПриобретениеТоваровУслуг" Или МетаданныеДокумента.Имя = "РеализацияТоваровУслуг" или (СтрокаТабличнойЧасти.СтатусУказанияСерий <> 13 и СтрокаТабличнойЧасти.СтатусУказанияСерий <> 14 и СтрокаТабличнойЧасти.СтатусУказанияСерий <> 9 и СтрокаТабличнойЧасти.СтатусУказанияСерий <> 10 и СтрокаТабличнойЧасти.СтатусУказанияСерий <> 0) Тогда
			лСтруктураПоискаСерий = Новый Структура("Номенклатура, Характеристика, Серия", СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.Характеристика, лСерия);
			СтрокиПоискаСерий = ДокументЕГАИС["Серии"].НайтиСтроки(лСтруктураПоискаСерий);
			
			Если СтрокиПоискаСерий.Количество() = 0 Тогда
				СтрокаТабличнойЧастиСерии = ДокументЕГАИС["Серии"].Добавить();
				СтрокаТабличнойЧастиСерии.Номенклатура = СтрокаТабличнойЧасти.Номенклатура;
				СтрокаТабличнойЧастиСерии.Характеристика = СтрокаТабличнойЧасти.Характеристика;
				СтрокаТабличнойЧастиСерии.Серия = лСерия;
				Попытка СтрокаТабличнойЧастиСерии.Склад = СтрокаТабличнойЧасти.Склад; Исключение КонецПопытки;
				Попытка СтрокаТабличнойЧастиСерии.Назначение = СтрокаТабличнойЧасти.Назначение; Исключение КонецПопытки;
			Иначе	
				СтрокаТабличнойЧастиСерии = СтрокиПоискаСерий[0];
			КонецЕсли;
			
			СтрокаТабличнойЧастиСерии.Количество = СтрокаТабличнойЧастиСерии.Количество+Количество;
		КонецЕсли;
	КонецЕсли;	
	// Серии в отдельной ТЧ
	
	ЕстьРеквизитИдентификаторСтрокиМарок = МетаданныеДокумента.ТабличныеЧасти["АкцизныеМарки"].Реквизиты.Найти("ИдентификаторСтроки") <> Неопределено; 
	ЕстьРеквизитКлючСвязиМарок = МетаданныеДокумента.ТабличныеЧасти["АкцизныеМарки"].Реквизиты.Найти("КлючСвязи") <> Неопределено; 
	ЕстьРеквизитКоличествоМарок = МетаданныеДокумента.ТабличныеЧасти["АкцизныеМарки"].Реквизиты.Найти("Количество") <> Неопределено; 
	ЕстьРеквизитСправка2 = МетаданныеДокумента.ТабличныеЧасти["АкцизныеМарки"].Реквизиты.Найти("Справка2") <> Неопределено; 
	
	СтрокиПоискаМарок = ДокументЕГАИС.АкцизныеМарки.НайтиСтроки(Новый Структура("АкцизнаяМарка", лТекущаяАкцизнаяМарка));
	
	Если СтрокиПоискаМарок.Количество() = 0 Тогда
		СтрокаМарки = ДокументЕГАИС.АкцизныеМарки.Добавить();
		СтрокаМарки.АкцизнаяМарка = лТекущаяАкцизнаяМарка;
		
		Если ЕстьРеквизитИдентификаторСтрокиМарок Тогда
			СтрокаМарки.ИдентификаторСтроки = СтрокаТабличнойЧасти.ИдентификаторСтроки;
		КонецЕсли;
		
		Если ЕстьРеквизитКлючСвязиМарок Тогда
			СтрокаМарки.КлючСвязи = СтрокаТабличнойЧасти.КлючСвязи; 
		КонецЕсли;
		
		Если ЕстьРеквизитКоличествоМарок Тогда
			СтрокаМарки.Количество = 1; 
		КонецЕсли;
		
		Если ЕстьРеквизитСправка2 Тогда
			СтрокаМарки.Справка2 = ПолучитьСправку2ПоАкцизнойМарке(лТекущаяАкцизнаяМарка); 
		КонецЕсли;
		
	Иначе
		СтрокаМарки = СтрокиПоискаМарок[0];
	КонецЕсли;
	
КонецПроцедуры	
Процедура ОтменитьРезервыИсходногоДокумента(Задание)
	
	ОбъектЗаказа = Задание.ИсходныйДокумент.ПолучитьОбъект();
	
	Для каждого CтрокаЗаказа Из ОбъектЗаказа.Товары Цикл
		CтрокаЗаказа.Отменено = Истина;
	КонецЦикла;   
	
	ОбъектЗаказа.Статус = Перечисления.СтатусыЗаказовКлиентов.Закрыт;
	ОбъектЗаказа.Записать();
	
КонецПроцедуры
Функция ПолучитьСправку2ПоАкцизнойМарке(ТекущаяАкцизнаяМарка)
	
	лСправка2 = Справочники.Справки2ЕГАИС.ПустаяСсылка();
	
	ЗапросМарок = Новый Запрос(	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	АкцизныеМаркиЕГАИС.Справка2 КАК Справка2
	|ИЗ
	|	РегистрСведений.АкцизныеМаркиЕГАИС КАК АкцизныеМаркиЕГАИС
	|ГДЕ
	|	АкцизныеМаркиЕГАИС.АкцизнаяМарка = &ТекущаяАкцизнаяМарка");
	
	ЗапросМарок.УстановитьПараметр("ТекущаяАкцизнаяМарка", ТекущаяАкцизнаяМарка);
	
	РезультатЗапроса = ЗапросМарок.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		
		лСправка2 = ВыборкаДетальныеЗаписи.Справка2;
	КонецЕсли;
	
	Возврат лСправка2;
	
КонецФункции
Функция ПолучитьОрганизациюЕГАИС(ТекущаяОрганизация)
	
	лОрганизацияЕГАИС = Справочники.алкКлассификаторОрганизацийЕГАИС.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	алкСоответствияОрганизацийЕГАИСИКонтрагентов.ОрганизацияЕГАИС
		|ИЗ
		|	РегистрСведений.алкСоответствияОрганизацийЕГАИСИКонтрагентов КАК алкСоответствияОрганизацийЕГАИСИКонтрагентов
		|ГДЕ
		|	алкСоответствияОрганизацийЕГАИСИКонтрагентов.Контрагент = &ТекущаяОрганизация
		//|	И алкСоответствияОрганизацийЕГАИСИКонтрагентов.ПунктРазгрузкиКонтрагента = &ТекущийПунктРазгрузкиОрганизации
		|	И алкСоответствияОрганизацийЕГАИСИКонтрагентов.Контрагент ССЫЛКА Справочник.Организации";
	
	Запрос.УстановитьПараметр("ТекущаяОрганизация", ТекущаяОрганизация);
	//Запрос.УстановитьПараметр("ТекущийПунктРазгрузкиОрганизации", ТекущийПунктРазгрузкиОрганизации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		
		лОрганизацияЕГАИС = ВыборкаДетальныеЗаписи.ОрганизацияЕГАИС;
	КонецЕсли;
	
	Возврат лОрганизацияЕГАИС;
	
КонецФункции
Функция ПолучитьНовыйКлючСтрокиЕгаисОпт(ТЧ)
	
	СвободныйКлюч = 0;
	
	Для каждого СтрокаТаблицы Из ТЧ Цикл
		СвободныйКлюч = Макс(СтрокаТаблицы.КлючСвязи, СвободныйКлюч);
	КонецЦикла;
	
	СвободныйКлюч = СвободныйКлюч + 1;
	
	Возврат СвободныйКлюч; 
	
