
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Объект.ТокенАвторизации = AMS_Сервер.ПолучитьТокенАвторизации(Пользователи.АвторизованныйПользователь());
	
	Если Пользователи.РолиДоступны("AMS_Аналитик") Тогда
		Элементы.КлиентыВыгрузитьЦеныВсемКлиентам.Видимость = Истина;
		
		НаборЗаписей = РегистрыСведений.AMS_МенеджерыВ2В.СоздатьНаборЗаписей();
		НаборЗаписей.Прочитать();
		ЗначениеВРеквизитФормы(НаборЗаписей, "Менеджеры");
		
	Иначе
		Элементы.КлиентыВыгрузитьЦеныВсемКлиентам.Видимость = Ложь;
		Элементы.СтраницаПользователиВ2В.Видимость = Ложь;;
	КонецЕсли;
	
	Элементы.ЗаказыСтатус_ВОжидании.Видимость  = AMS_ВызовСервера.ЭтоKhors();

	ЗаполнитьСписокЗаказов();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Запись_ЗаказКлиента" Тогда
		ЗаполнитьСписокЗаказов();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если ТекущаяСтраница = Элементы.СтраницаЗаказы Тогда
		ЗаполнитьСписокЗаказов();

	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаКлиенты Тогда
		Если Объект.Клиенты.Количество() = 0 Тогда
			ЗаполнитьСписокКлиентов();
		КонецЕсли;
		
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаЦены Тогда
		СформироватьПрайсЛистКлиентаВ2В(ПолучитьДанныеКлиентаДляПрайса());
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗаказы

&НаКлиенте
Процедура ЗаказыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекущиеДанные = Элементы.Заказы.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаказКлиента = ТекущиеДанные.ЗаказКлиента;
	
	Если ЗначениеЗаполнено(ЗаказКлиента) Тогда
		ПоказатьЗначение(, ЗаказКлиента);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыКлиенты

&НаКлиенте
Процедура КлиентыПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если Не ТекущиеДанные = Неопределено Тогда
		Партнер = ТекущиеДанные.Партнер;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КлиентыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекущиеДанные = Элементы.Клиенты.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Партнер = ТекущиеДанные.Партнер;
	
	Если ЗначениеЗаполнено(Партнер) Тогда
		ПоказатьЗначение(, Партнер);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

