
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Процедура ПолучитьЗаказы() Экспорт
	Табл = ПолучитьШаблонТаблицыЗаказов();

	МассивЗаказов = ЗагрузитьЗаказыКлиентовНаВ2В();
	
	Для Каждого Стр Из МассивЗаказов Цикл
		Статус = Стр["status"]["name"];
		
		Если Статус = "Отменен" Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтр = Табл.Добавить();
		
		НовСтр.Id             = Стр["id"];
		НовСтр.ДатаСоздания   = Дата(1970,1,1) + Стр["creationTime"];
		НовСтр.ДатаОбновления = Дата(1970,1,1) + Стр["updateTime"];
		НовСтр.Статус         = Статус;
		НовСтр.ПартнерИмя     = Стр["client"]["fullName"];
		НовСтр.ПартнерКод     = Стр["client"]["code1c"];
		НовСтр.Сумма          = Стр["baseAmount"];
		НовСтр.Комментарий    = Стр["comment"];
		НовСтр.КонтрагентИмя  = Стр["company"]["name"];
		НовСтр.ИНН            = Формат(Стр["company"]["taxpayerNumber"], "ЧГ=0");
		НовСтр.КПП            = Стр["company"]["ogrn"];
	КонецЦикла; 

	Таб = ПолучитьДанныеДляСписокаЗаказов(Табл);
	
	Заказы.Загрузить(Таб);
КонецПроцедуры

Процедура ПолучитьКлиентов() Экспорт
	МассивКлиентов = ЗагрузитьМассивКлиентовВ2В();
	
	Табл = ПолучитьШаблонТаблицыКлиентов();

	Для Каждого Стр Из МассивКлиентов Цикл
		КодПартнера = Стр["code1c"];
		
		Если ПустаяСтрока(КодПартнера) Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтр = Табл.Добавить();
		
		НовСтр.code1c       = КодПартнера;
		НовСтр.Id           = Стр["id"];
		НовСтр.fullName     = Стр["fullName"];
		НовСтр.company      = Стр["company"];
		НовСтр.manager      = Стр["manager"];
		
		Если ТипЗнч(Стр["accessTime"]) = Тип("Число") Тогда
			НовСтр.accessTime   = Дата(1970,1,1) + Стр["accessTime"];
		КонецЕсли;
		
		Если ТипЗнч(Стр["creationTime"]) = Тип("Число") Тогда
			НовСтр.creationTime = Дата(1970,1,1) + Стр["creationTime"];
		КонецЕсли;
		
		НовСтр.phone          = Стр["phone"];
		НовСтр.email          = Стр["email"];
		НовСтр.isChecked      = Стр["isChecked"];
		НовСтр.countOrders  = Стр["statistic"]["countOrders"];
		НовСтр.amountOrders  = Стр["statistic"]["amountOrders"];
	КонецЦикла; 
	 
	Таб = ПолучитьТаблицуКлиентов(Табл);
	
	Клиенты.Загрузить(Таб);
КонецПроцедуры

Процедура ВыгрузитьЦеныКлиентаНаВ2В(Код, Соглашение) Экспорт
	HTTPСоединение = Новый HTTPСоединение("b2b.cafe",,,,, AMS_Сервер.ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1.5.4/prices/update_client");
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("Accept-Language", "ru");
	
	ДанныеЗапроса = Новый Структура();
	ДанныеЗапроса.Вставить("userIds", Код);
	ДанныеЗапроса.Вставить("prices", ПолучитьУстановленныеЦеныКлиента(Соглашение));
	
	ТелоЗапроса = AMS_Сервер.СтруктураВJson(ДанныеЗапроса);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		//@skip-check module-unused-local-variable
		СтруктураОтвета = AMS_Сервер.JSONВСоответствие(ТелоОтвета);
	
	Иначе
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		ТекстОшибки = НСтр("ru = 'ВыгрузитьЦеныКлиентаНаВ2В.Ошибка: %Причина%'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Причина%", ТелоОтвета);
		ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ЗаказыНаВ2В

Функция ЗагрузитьЗаказыКлиентовНаВ2В()
	МассивЗаказов = Новый Массив();
	
	РежимБезопасности = БезопасныйРежим();
	
	Если ТипЗнч(РежимБезопасности) = тип("Булево") и РежимБезопасности = Истина тогда
		УстановитьОтключениеБезопасногоРежима(Истина);
	КОнецЕсли;
	
	Если ПустаяСтрока(ТокенАвторизации) тогда
		ТокенАвторизации = AMS_Сервер.ПолучитьТокенАвторизации(Пользователи.АвторизованныйПользователь());
	КОнецЕсли;
	
	Если Не ЗначениеЗаполнено(ТокенАвторизации) Тогда
		ВызватьИсключение "Нет токена авторизации";
	КонецЕсли;  

	HTTPСоединение = Новый HTTPСоединение("b2b.cafe",,,,, AMS_Сервер.ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1.5.4/order/list");
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("Accept-Language", "ru");
	
	Отбор = ОтборЗаказовВ2В();

	ТелоЗапроса = AMS_Сервер.СтруктураВJson(Отбор);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		СтруктураОтвета = AMS_Сервер.JSONВСоответствие(ТелоОтвета); 
		
		Результат = СтруктураОтвета["result"];
		
		МассивЗаказов = Результат["items"];
		
	ИначеЕсли HTTPОтвет.КодСостояния = 401 Тогда	
		ТокенАвторизации = AMS_Сервер.ПолучитьТокенАвторизации(Пользователи.АвторизованныйПользователь());

		ТекстОшибки = НСтр("ru = 'ЗагрузитьЗаказыКлиентовНаВ2В.Ошибка: Истекла авторизация: Нажмите кнопку ""Обновить"".'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	
	Иначе
		ТекстОшибки = НСтр("ru = 'ЗагрузитьЗаказыКлиентовНаВ2В.Ошибка: Не удалось прочитать файл из временного хранилища по причине: %Причина%'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Причина%", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
		
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
		
	Возврат МассивЗаказов;
КонецФункции

