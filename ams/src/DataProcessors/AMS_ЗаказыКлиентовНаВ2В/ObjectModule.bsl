Функция ПолучитьДанныеДляСписокаЗаказов(Табл)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Табл", Табл);
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Табл.Id КАК Id,
		|	Табл.ДатаСоздания КАК ДатаСоздания,
		|	Табл.ДатаОбновления КАК ДатаОбновления,
		|	Табл.Статус КАК Статус,
		|	Табл.ПартнерИмя КАК ПартнерИмя,
		|	Табл.ПартнерКод КАК ПартнерКод,
		|	Табл.КонтрагентИмя КАК КонтрагентИмя,
		|	ВЫРАЗИТЬ(Табл.ИНН КАК СТРОКА(20)) КАК ИНН,
		|	ВЫРАЗИТЬ(Табл.КПП КАК СТРОКА(20)) КАК КПП,
		|	Табл.Сумма КАК Сумма,
		|	Табл.Комментарий КАК Комментарий
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	&Табл КАК Табл
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Id
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	вт.Id КАК Id,
		|	Парт.Ссылка КАК Партнер,
		|	Парт.ОсновнойМенеджер КАК Менеджер
		|ПОМЕСТИТЬ Парт
		|ИЗ
		|	вт КАК вт
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Парт
		|		ПО вт.ПартнерКод = Парт.Код
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Id
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	вт.Id КАК Id,
		|	вт.ДатаСоздания КАК ДатаСоздания,
		|	вт.ДатаОбновления КАК ДатаОбновления,
		|	вт.Статус КАК Статус,
		|	вт.ПартнерИмя КАК ПартнерИмя,
		|	вт.ПартнерКод КАК ПартнерКод,
		|	Парт.Партнер КАК Партнер,
		|	вт.КонтрагентИмя КАК КонтрагентИмя,
		|	вт.ИНН КАК ИНН,
		|	вт.КПП КАК КПП,
		|	вт.Сумма КАК Сумма,
		|	вт.Комментарий КАК Комментарий,
		|	Парт.Менеджер КАК Менеджер
		|ПОМЕСТИТЬ таб
		|ИЗ
		|	вт КАК вт
		|		ЛЕВОЕ СОЕДИНЕНИЕ Парт КАК Парт
		|		ПО вт.Id = Парт.Id
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Id
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	таб.Id КАК Id,
		|	Контр.Ссылка КАК Контрагент
		|ПОМЕСТИТЬ Конт
		|ИЗ
		|	таб КАК таб
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контр
		|		ПО таб.Партнер = Контр.Партнер
		|		И (таб.ИНН = Контр.ИНН
		|		И таб.КПП = Контр.КПП
		|		ИЛИ таб.КПП = Контр.НалоговыйНомер)
		|		И таб.КПП = Контр.КПП
		|ГДЕ
		|	НЕ Контр.ПометкаУдаления
		|	И НЕ Контр._Закрыт
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Id
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	таб.Id КАК Id,
		|	таб.ДатаСоздания КАК ДатаСоздания,
		|	таб.ДатаОбновления КАК ДатаОбновления,
		|	таб.Статус КАК Статус,
		|	таб.ПартнерИмя КАК ПартнерИмя,
		|	таб.ПартнерКод КАК ПартнерКод,
		|	таб.Партнер КАК Партнер,
		|	таб.КонтрагентИмя КАК КонтрагентИмя,
		|	Конт.Контрагент КАК Контрагент,
		|	таб.ИНН КАК ИНН,
		|	таб.КПП КАК КПП,
		|	таб.Сумма КАК Сумма,
		|	таб.Менеджер КАК Менеджер,
		|	ДокЗаказ.Дата КАК Дата,
		|	ДокЗаказ.Номер КАК Номер,
		|	ДокЗаказ.Ссылка КАК ЗаказКлиента,
		|	таб.Комментарий КАК Комментарий,
		|	ВЫБОР
		|		КОГДА ДокЗаказ.ПометкаУдаления
		|			ТОГДА 1
		|		ИНАЧЕ ВЫБОР
		|			КОГДА ДокЗаказ.Проведен
		|				ТОГДА 0
		|			ИНАЧЕ 2
		|		КОНЕЦ
		|	КОНЕЦ КАК СостоянияДокумента
		|ИЗ
		|	таб КАК таб
		|		ЛЕВОЕ СОЕДИНЕНИЕ Конт КАК Конт
		|		ПО таб.Id = Конт.Id
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ДокЗаказ
		|		ПО таб.Id = ДокЗаказ.AMS_ID
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаСоздания,
		|	Id";
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ПолучитьШаблонТаблицыЗаказов()
	Табл = Новый ТаблицаЗначений();
	Табл.Колонки.Добавить("Id",             ОбщегоНазначения.ОписаниеТипаЧисло(10));
	Табл.Колонки.Добавить("ДатаСоздания",   ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	Табл.Колонки.Добавить("ДатаОбновления", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	Табл.Колонки.Добавить("Статус",         ОбщегоНазначения.ОписаниеТипаСтрока(30));
	Табл.Колонки.Добавить("ПартнерИмя",     ОбщегоНазначения.ОписаниеТипаСтрока(200));
	Табл.Колонки.Добавить("ПартнерКод",     ОбщегоНазначения.ОписаниеТипаСтрока(11));
	Табл.Колонки.Добавить("Сумма",          ОбщегоНазначения.ОписаниеТипаЧисло(10, 2));
	Табл.Колонки.Добавить("Комментарий",    ОбщегоНазначения.ОписаниеТипаСтрока(0));
	Табл.Колонки.Добавить("КонтрагентИмя",  ОбщегоНазначения.ОписаниеТипаСтрока(200));
	Табл.Колонки.Добавить("ИНН",            ОбщегоНазначения.ОписаниеТипаСтрока(12));
	Табл.Колонки.Добавить("КПП",            ОбщегоНазначения.ОписаниеТипаСтрока(13));
	
	Возврат Табл;
КонецФункции

#КонецОбласти

#Область КлиентыНаВ2В

Функция ПолучитьТаблицуКлиентов(Табл)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("В2В", Табл);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Парт.Код КАК code1c,
	|	Парт.Ссылка КАК Партнер,
	|	Парт.ГруппаДоступа КАК ГруппаДоступа,
	|	Парт.ОсновнойМенеджер КАК Менеджер
	|ПОМЕСТИТЬ Клиенты
	|ИЗ
	|	Справочник.Партнеры КАК Парт
	|ГДЕ
	|	НЕ Парт.ПометкаУдаления
	|	И НЕ Парт._Закрыт
	|	И Парт.Клиент
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Партнер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Клиенты.Партнер КАК Партнер,
	|	Правила.Ссылка КАК ПравилоПродаж,
	|	Правила.Соглашение КАК Соглашение
	|ПОМЕСТИТЬ Правила
	|ИЗ
	|	Клиенты КАК Клиенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_ПравилаПродаж КАК Правила
	|		ПО Клиенты.Партнер = Правила.Владелец
	|ГДЕ
	|	НЕ Правила.ПометкаУдаления
	|	И Правила.Основное
	|	И Правила.СтатусПравилаПродажи = ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыПравилПродаж.Действует)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Партнер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Клиенты.code1c КАК code1c,
	|	Клиенты.Партнер КАК Партнер,
	|	Клиенты.ГруппаДоступа КАК ГруппаДоступа,
	|	Клиенты.Менеджер КАК Менеджер,
	|	Правила.ПравилоПродаж КАК ПравилоПродаж,
	|	Правила.Соглашение КАК Соглашение
	|ПОМЕСТИТЬ С1
	|ИЗ
	|	Клиенты КАК Клиенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Правила КАК Правила
	|		ПО Клиенты.Партнер = Правила.Партнер
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	code1c
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Id КАК Id,
	|	т.code1c КАК code1c,
	|	т.fullName КАК fullName,
	|	т.company КАК company,
	|	т.manager КАК manager,
	|	т.accessTime КАК accessTime,
	|	т.creationTime КАК creationTime,
	|	т.phone КАК phone,
	|	т.email КАК email,
	|	т.isChecked КАК isChecked,
	|	т.countOrders КАК countOrders,
	|	т.amountOrders КАК amountOrders
	|ПОМЕСТИТЬ В2В
	|ИЗ
	|	&В2В КАК т
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	code1c
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	С1.code1c КАК code1c,
	|	С1.Партнер КАК Партнер,
	|	С1.ГруппаДоступа КАК ГруппаДоступа,
	|	С1.ПравилоПродаж КАК ПравилоПродаж,
	|	С1.Соглашение КАК Соглашение,
	|	С1.Менеджер КАК Менеджер,
	|	В2В.Id КАК Id,
	|	В2В.fullName КАК fullName,
	|	В2В.company КАК company,
	|	В2В.manager КАК manager,
	|	В2В.accessTime КАК accessTime,
	|	В2В.creationTime КАК creationTime,
	|	В2В.phone КАК phone,
	|	В2В.email КАК email,
	|	В2В.isChecked КАК isChecked,
	|	В2В.countOrders КАК countOrders,
	|	В2В.amountOrders КАК amountOrders
	|ИЗ
	|	С1 КАК С1
	|		ЛЕВОЕ СОЕДИНЕНИЕ В2В КАК В2В
	|		ПО С1.code1c = В2В.code1c
	|
	|УПОРЯДОЧИТЬ ПО
	|	С1.ГруппаДоступа.Наименование,
	|	С1.Партнер.Наименование";
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ЗагрузитьМассивКлиентовВ2В()
	МассивКлиентов = Новый Массив();
	
	РежимБезопасности = БезопасныйРежим();
	
	Если ТипЗнч(РежимБезопасности) = тип("Булево") и РежимБезопасности = Истина тогда
		УстановитьОтключениеБезопасногоРежима(Истина);
	КОнецЕсли;
	
	Если ПустаяСтрока(ТокенАвторизации) тогда
		ТокенАвторизации = AMS_Сервер.ПолучитьТокенАвторизации(Пользователи.АвторизованныйПользователь());
	КОнецЕсли;
	
	Если Не ЗначениеЗаполнено(ТокенАвторизации) Тогда
		ВызватьИсключение "Нет токена авторизации";
	КонецЕсли;  

	HTTPСоединение = Новый HTTPСоединение("b2b.cafe",,,,, AMS_Сервер.ТАЙМАУТ(), Новый ЗащищенноеСоединениеOpenSSL());
	HTTPЗапрос = Новый HTTPЗапрос("/api/v1.5.4/clients/list");
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенАвторизации);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("Accept-Language", "ru");
	
	Отбор = Новый Структура();
	Отбор.Вставить("offset", 0);
	Отбор.Вставить("length", 1000);
	Отбор.Вставить("order", "accessTime_desc");

	ТелоЗапроса = AMS_Сервер.СтруктураВJson(Отбор);
	
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния = 200 Тогда
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		СтруктураОтвета = AMS_Сервер.JSONВСоответствие(ТелоОтвета); 
		
		Результат = СтруктураОтвета["result"];
		
		МассивКлиентов = Результат["items"];
		
	ИначеЕсли HTTPОтвет.КодСостояния = 401 Тогда	
		ТокенАвторизации = AMS_Сервер.ПолучитьТокенАвторизации(Пользователи.АвторизованныйПользователь());

		ТекстОшибки = НСтр("ru = 'ЗагрузитьСписокКлиентовНаВ2В.Ошибка: Истекла авторизация: Нажмите кнопку ""Обновить"".'");
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	
	Иначе
		ТекстОшибки = НСтр("ru = 'ЗагрузитьСписокКлиентовНаВ2В.Ошибка: Не удалось прочитать файл из временного хранилища по причине: %Причина%'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Причина%", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
		
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
		
	Возврат МассивКлиентов;
КонецФункции

Функция ПолучитьШаблонТаблицыКлиентов()
	Табл = Новый ТаблицаЗначений();
	Табл.Колонки.Добавить("Id",           ОбщегоНазначения.ОписаниеТипаЧисло(10)); //Идентификатор клиента.
	Табл.Колонки.Добавить("code1c",       ОбщегоНазначения.ОписаниеТипаСтрока(11)); //Идентификатор клиента.
	Табл.Колонки.Добавить("fullName",     ОбщегоНазначения.ОписаниеТипаСтрока(200)); //Полное имя пользователя.
	Табл.Колонки.Добавить("company",      ОбщегоНазначения.ОписаниеТипаСтрока(200)); //Название компании клиента. Если нет названия, то будет ИНН. Если нет ИНН, будет ОГРН.
	Табл.Колонки.Добавить("manager",      ОбщегоНазначения.ОписаниеТипаСтрока(200)); //Имя менеджера клиента.
	Табл.Колонки.Добавить("accessTime",   ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя)); //Время последней активности клиента.
	Табл.Колонки.Добавить("creationTime", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя)); //Время регистрации клиента.
	Табл.Колонки.Добавить("phone",        ОбщегоНазначения.ОписаниеТипаСтрока(200)); //Телефон клиента.
	Табл.Колонки.Добавить("email",        ОбщегоНазначения.ОписаниеТипаСтрока(200)); //Email клиента.
	Табл.Колонки.Добавить("isChecked",    Новый ОписаниеТипов("Булево")); //Активирован ли клиент.
	Табл.Колонки.Добавить("countOrders",  ОбщегоНазначения.ОписаниеТипаЧисло(10)); //Количество заказов клиента.
	Табл.Колонки.Добавить("amountOrders",  ОбщегоНазначения.ОписаниеТипаЧисло(15, 2)); //Сумма заказов клиента.
	
	Возврат Табл;
КонецФункции

Функция ПолучитьУстановленныеЦеныКлиента(Соглашение)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Соглашение", Соглашение);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	Ном.Код КАК sku,
	|	Ном.Артикул КАК Артикул,
	|	Ном.СтавкаНДС.Ставка КАК Ставка
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	Справочник.AMS_Продукция.Товары КАК т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция КАК д
	|		ПО т.Ссылка = д.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО т.Номенклатура = Ном.Ссылка
	|ГДЕ
	|	т.В2В
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Согл.Ссылка КАК Соглашение,
	|	Согл.ВидЦен КАК ВидЦеныОсновная,
	|	СоглЦенГр.ВидЦен КАК ВидЦеныМега
	|ПОМЕСТИТЬ Согл
	|ИЗ
	|	Справочник.СоглашенияСКлиентами КАК Согл
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СоглЦенГр
	|		ПО Согл.Ссылка = СоглЦенГр.Ссылка
	|ГДЕ
	|	Согл.Ссылка = &Соглашение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Цен.Номенклатура КАК Номенклатура,
	|	Цен.Цена КАК Цена,
	|	Цен.ВидЦены КАК ВидЦены
	|ПОМЕСТИТЬ ЦеныОсн
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, ИСТИНА
	|	И ВидЦены В
	|		(ВЫБРАТЬ
	|			Согл.ВидЦеныОсновная КАК ВидЦеныОсновная
	|		ИЗ
	|			Согл КАК Согл)
	|	И Номенклатура В
	|		(ВЫБРАТЬ
	|			тов.Номенклатура КАК Номенклатура
	|		ИЗ
	|			тов КАК тов)) КАК Цен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Цен.Номенклатура,
	|	Цен.Цена,
	|	Цен.ВидЦены
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, ИСТИНА
	|	И ВидЦены В
	|		(ВЫБРАТЬ
	|			Согл.ВидЦеныМега КАК ВидЦеныМега
	|		ИЗ
	|			Согл КАК Согл)
	|	И Номенклатура В
	|		(ВЫБРАТЬ
	|			тов.Номенклатура КАК Номенклатура
	|		ИЗ
	|			тов КАК тов)) КАК Цен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Согл.Номенклатура КАК Номенклатура,
	|	Согл.Цена КАК Цена,
	|	NULL КАК ВидЦены
	|ПОМЕСТИТЬ ЦенДоп
	|ИЗ
	|	Справочник.СоглашенияСКлиентами.Товары КАК Согл
	|ГДЕ
	|	ИСТИНА
	|	И Согл.Ссылка В
	|		(ВЫБРАТЬ
	|			Согл.Соглашение КАК Соглашение
	|		ИЗ
	|			Согл КАК Согл)
	|	И Согл.Номенклатура В
	|		(ВЫБРАТЬ
	|			тов.Номенклатура КАК Номенклатура
	|		ИЗ
	|			тов КАК тов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.sku КАК sku,
	|	ЕСТЬNULL(ЦенДоп.Цена, ЦеныОсн.Цена) КАК price,
	|	тов.Ставка КАК vatRate
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныОсн КАК ЦеныОсн
	|		ПО тов.Номенклатура = ЦеныОсн.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенДоп КАК ЦенДоп
	|		ПО тов.Номенклатура = ЦенДоп.Номенклатура
	|ГДЕ
	|	ЕСТЬNULL(ЦенДоп.Цена, ЦеныОсн.Цена) > 0";
	
	Табл = Запрос.Выполнить().Выгрузить();
	
	МассивЦен = Новый Массив;
	
	Для каждого Стр Из Табл Цикл
		МассивЦен.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;

	Возврат МассивЦен;
КонецФункции

#КонецОбласти

#Область ЦеныНаВ2В

Функция ПолучитьДанныеПрайсаКлиентаВ2В(Стр) Экспорт
	ЦеноваяГруппаБХ   = Справочники.ЦеновыеГруппы.НайтиПоНаименованию("Бытовая химия");
	ЦеноваяГруппаМЕГА = Справочники.ЦеновыеГруппы.НайтиПоНаименованию("МЕГА");
	
	//@skip-check bsl-legacy-check-string-literal
	ВидЦен1 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.Соглашение, "ВидЦен");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Соглашение", Стр.Соглашение);
	Запрос.УстановитьПараметр("ЦеноваяГруппа", ЦеноваяГруппаМЕГА);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.ВидЦен КАК ВидЦен
	|ИЗ
	|	Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК т
	|ГДЕ
	|	т.Ссылка = &Соглашение
	|	И т.ЦеноваяГруппа = &ЦеноваяГруппа";
	
	Рез = Запрос.Выполнить();
	
	Если Рез.Пустой() Тогда
		ВидЦен2 = Справочники.ВидыЦен.ПустаяСсылка();
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		ВидЦен2 = Выб.ВидЦен;
	КонецЕсли;

	ВидЦен3 = Справочники.ВидыЦен.НайтиПоНаименованию("Более 1 млн.", Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаЦены", Стр.ДатаЦены);
	Запрос.УстановитьПараметр("ЦеноваяГруппаБХ", ЦеноваяГруппаБХ);
	Запрос.УстановитьПараметр("ЦеноваяГруппаМЕГА", ЦеноваяГруппаМЕГА);
	Запрос.УстановитьПараметр("ВидЦен1", ВидЦен1);
	Запрос.УстановитьПараметр("ВидЦен2", ВидЦен2);
	Запрос.УстановитьПараметр("ВидЦен3", ВидЦен3);
	Запрос.УстановитьПараметр("ЦеныВ2В", AMS_Сервер.ПолучитьЦеныКлиентаНаВ2В(Стр.Id));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	AMS_Продукция.Родитель.Наименование КАК ТипПродукции,
	|	AMS_Продукция.Наименование КАК НазначениеПродукции,
	|	AMS_ПродукцияТовары.ТоварныйЗнак КАК ТоварныйЗнак,
	|	AMS_ПродукцияТовары.ТоварныйЗнак.Порядок КАК ТоварныйЗнакПорядок,
	|	AMS_ПродукцияТовары.НомерСтроки КАК НомерСтроки,
	|	AMS_ПродукцияТовары.Номенклатура КАК Номенклатура,
	|	AMS_ПродукцияТовары.КфцРРЦ КАК КфцРРЦ,
	|	Ном.НаименованиеПолное КАК НаименованиеПолное,
	|	AMS_ПродукцияТовары.Маркер КАК Маркер,
	|	Ном.Артикул КАК Артикул,
	|	Ном.Код КАК Код,
	|	AMS_ПродукцияТовары.Объем КАК Объем,
	|	Ном.КоэффициентЕдиницыДляОтчетов КАК КолНаМесто,
	|	Ном.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	(100 + СтавкиНДС.Ставка) / 100 КАК Ставка
	|ПОМЕСТИТЬ Ном
	|ИЗ
	|	Справочник.AMS_Продукция КАК AMS_Продукция
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция.Товары КАК AMS_ПродукцияТовары
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтавкиНДС КАК СтавкиНДС
	|				ПО Ном.СтавкаНДС = СтавкиНДС.Ссылка
	|			ПО AMS_ПродукцияТовары.Номенклатура = Ном.Ссылка
	|		ПО AMS_Продукция.Ссылка = AMS_ПродукцияТовары.Ссылка
	|ГДЕ
	|	НЕ AMS_Продукция.ЭтоГруппа
	|	И AMS_ПродукцияТовары.Прайс
	|	И (Ном.ЦеноваяГруппа = &ЦеноваяГруппаБХ
	|	ИЛИ Ном.ЦеноваяГруппа = &ЦеноваяГруппаМЕГА)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РегЦены.Номенклатура КАК Номенклатура,
	|	РегЦены.Цена КАК Цена
	|ПОМЕСТИТЬ Цены1
	|ИЗ
	|	Ном КАК Ном
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаЦены, ВидЦены = &ВидЦен1) КАК РегЦены
	|		ПО Ном.Номенклатура = РегЦены.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РегЦены.Номенклатура КАК Номенклатура,
	|	РегЦены.Цена КАК Цена
	|ПОМЕСТИТЬ Цены2
	|ИЗ
	|	Ном КАК Ном
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаЦены, ВидЦены = &ВидЦен2) КАК РегЦены
	|		ПО Ном.Номенклатура = РегЦены.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
