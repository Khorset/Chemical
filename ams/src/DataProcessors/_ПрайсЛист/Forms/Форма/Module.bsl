&НаКлиенте
Процедура ПечатьПрайса(Команда)
	Прайс.ПолеСлева               = 5;
	Прайс.ПолеСправа              = 5;
	Прайс.РазмерКолонтитулаСверху = 0;
	Прайс.РазмерКолонтитулаСнизу  = 0;
	Прайс.АвтоМасштаб             = Истина;
	Прайс.ОриентацияСтраницы      = ОриентацияСтраницы.Портрет;

	Массив = Новый Массив;
	Массив.Добавить(Скидка); 

	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Обработка._ПрайсЛист", "Прайс", Массив, Неопределено,
	Новый Структура("ТабличныйДокумент", Прайс));
КонецПроцедуры

