#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПоказатьПрайс()
	ЕстьСкидка  = ЗначениеЗаполнено(Скидка);
	НомерСтроки = 0;
	
	Рез = ПолучитьДанныеПрайса();

	Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("Прайс");
	
	ОблЛоготип             = Макет.ПолучитьОбласть("Логотип");
	ОблСкидкаКлиента       = Макет.ПолучитьОбласть("СкидкаКлиента");
	ОблТипПродукции        = Макет.ПолучитьОбласть("ТипПродукции");
	ОблНазначениеПродукции = Макет.ПолучитьОбласть("НазначениеПродукции");
	ОблТоварныйЗнак        = Макет.ПолучитьОбласть("ТоварныйЗнак");
	ОблПодвал              = Макет.ПолучитьОбласть("Подвал");

	Если ЕстьСкидка Тогда
		ОблШапка = Макет.ПолучитьОбласть("Шапка");
		ОблТовар = Макет.ПолучитьОбласть("Товар");
	Иначе
		ОблШапка = Макет.ПолучитьОбласть("Шапка1");
		ОблТовар = Макет.ПолучитьОбласть("Товар1");
	КонецЕсли;

	Прайс.Очистить();

	ОблЛоготип.Параметры.Срок = "Действителен с " + Формат(ДатаПрайсаУстановленная, "ДЛФ=ДД");
	Прайс.Вывести(ОблЛоготип);
	
	Если ЕстьСкидка Тогда
		ОблСкидкаКлиента.Параметры.СкидкаКлиента = "ПЕРСОНАЛЬНАЯ СКИДКА: " + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Скидка, "ЗначениеСкидкиНаценки") + " %";
		Прайс.Вывести(ОблСкидкаКлиента);
	КонецЕсли;

	Прайс.Вывести(ОблШапка);
	
	Выб1 = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выб1.Следующий() Цикл
		ОблТипПродукции.Параметры.Заполнить(Выб1);
		Прайс.Вывести(ОблТипПродукции);
	
		Выб2 = Выб1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выб2.Следующий() Цикл
			ОблНазначениеПродукции.Параметры.Заполнить(Выб2);
			Прайс.Вывести(ОблНазначениеПродукции);
	
			Выб3 = Выб2.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Выб3.Следующий() Цикл
				ОблТоварныйЗнак.Параметры.Заполнить(Выб3);
				Прайс.Вывести(ОблТоварныйЗнак);
	
				Выб4 = Выб3.Выбрать();
				Пока Выб4.Следующий() Цикл
					НомерСтроки = НомерСтроки + 1;
					
					ОблТовар.Параметры.Заполнить(Выб4);
					
					ОблТовар.Параметры.НомерСтроки = НомерСтроки;
					
					Прайс.Вывести(ОблТовар);
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	Прайс.Вывести(ОблПодвал);
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеПрайса()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаЦены", ДатаЦены); 
	Запрос.УстановитьПараметр("ВидЦены", Справочники.AMS_Константы["ВидыЦенБазовая"].Значение);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	д.Родитель КАК ТипПродукции,
	|	д.Ссылка КАК НазначениеПродукции,
	|	т.ТоварныйЗнак КАК ТоварныйЗнак,
	|	т.Номенклатура КАК Номенклатура,
	|	ном.НаименованиеПолное КАК НаименованиеПолное,
	|	т.Маркер КАК Маркер,
	|	ном.Артикул КАК Артикул,
	|	т.Объем КАК Объем,
	|	ном.КоэффициентЕдиницыДляОтчетов КАК КолНаМесто,
	|	д.Родитель.Наименование КАК ТипНаименование,
	|	д.Наименование КАК НазначениеНаименование,
	|	т.ТоварныйЗнак.Порядок КАК ТоварныйЗнакПорядок,
	|	т.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ Продукция
	|ИЗ
	|	Справочник.AMS_Продукция КАК д
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция.Товары КАК т
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|			ПО т.Номенклатура = ном.Ссылка
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	НЕ д.ЭтоГруппа
	|	И т.Прайс
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.ВидЦены КАК ВидЦены,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Период КАК Период
	|ПОМЕСТИТЬ ДатыЦен
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры КАК т
	|ГДЕ
	|	т.ВидЦены = &ВидЦены
	|	И т.Период <= &ДатаЦены
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Цены.Номенклатура КАК Номенклатура,
	|	Цены.Цена КАК Цена
	|ПОМЕСТИТЬ ЦенаБазовая
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры КАК Цены
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыЦен КАК ДатыЦен
	|		ПО Цены.Номенклатура = ДатыЦен.Номенклатура
	|		И Цены.Период = ДатыЦен.Период
	|		И Цены.ВидЦены = ДатыЦен.ВидЦены
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Продукция.ТипПродукции КАК ТипПродукции,
	|	Продукция.НазначениеПродукции КАК НазначениеПродукции,
	|	Продукция.ТоварныйЗнак КАК ТоварныйЗнак,
	|	Продукция.Номенклатура КАК Номенклатура,
	|	Продукция.НаименованиеПолное КАК НаименованиеПолное,
	|	Продукция.Маркер КАК Маркер,
	|	Продукция.Артикул КАК Артикул,
	|	Продукция.Объем КАК Объем,
	|	Продукция.КолНаМесто КАК КолНаМесто,
	|	ЦенаБазовая.Цена КАК ЦенаБезНДС,
	|	ЦенаБазовая.Цена * 1.2 КАК ЦенаСНДС,
	|	Продукция.ТипНаименование КАК ТипНаименование,
	|	Продукция.НазначениеНаименование КАК НазначениеНаименование,
	|	Продукция.ТоварныйЗнакПорядок КАК ТоварныйЗнакПорядок,
	|	Продукция.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Продукция КАК Продукция
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦенаБазовая КАК ЦенаБазовая
	|		ПО Продукция.Номенклатура = ЦенаБазовая.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТипНаименование,
	|	НазначениеНаименование,
	|	ТоварныйЗнакПорядок,
	|	НомерСтроки
	|ИТОГИ
	|ПО
	|	ТипПродукции,
	|	НазначениеПродукции,
	|	ТоварныйЗнак";

	Возврат Запрос.Выполнить();
КонецФункции

&НаСервере
Процедура ЗаполнитьТаблицыВидовЦен()
	БытХим = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._ТипыВидовЦен.БытоваяХимия");
	МЕГА   = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._ТипыВидовЦен.МЕГА");
	Спец   = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._ТипыВидовЦен.Специальная");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВидыЦен.Ссылка КАК ВидЦены,
		|	ВидыЦен._ТипВидаЦены КАК ТипВидаЦены
		|ИЗ
		|	Справочник.ВидыЦен КАК ВидыЦен
		|ГДЕ
		|	НЕ ВидыЦен._ТипВидаЦены = ЗНАЧЕНИЕ(Перечисление._ТипыВидовЦен.ПустаяСсылка)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидыЦен.Наименование";
	
	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	
	Пока Выб.Следующий() Цикл
		Если Выб.ТипВидаЦены = БытХим Тогда
			Стр = ВидыЦенБытХим.Добавить();
			Стр.ВидЦены = Выб.ВидЦены;
		
		ИначеЕсли Выб.ТипВидаЦены = МЕГА Тогда
			Стр = ВидыЦенМЕГА.Добавить();
			Стр.ВидЦены = Выб.ВидЦены;
		
		ИначеЕсли Выб.ТипВидаЦены = Спец Тогда
			Стр = ВидыЦенСпец.Добавить();
			Стр.ВидЦены = Выб.ВидЦены;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура НастроитьПараметры()
	ВидыЦен.Очистить();
	
	ЕстьВидЦенБытХим = Ложь;
	ЕстьВидЦенМЕГА = Ложь;
	ЕстьСпецЦены = Ложь;
	
	Для Каждого Стр Из ВидыЦенБытХим Цикл
		Если Стр.Метка Тогда
			ВидыЦен.Добавить(Стр.ВидЦены);
			ЕстьВидЦенБытХим = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Стр Из ВидыЦенМЕГА Цикл
		Если Стр.Метка Тогда
			ВидыЦен.Добавить(Стр.ВидЦены);
			ЕстьВидЦенМЕГА = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Стр Из ВидыЦенСпец Цикл
		Если Стр.Метка Тогда
			ВидыЦен.Добавить(Стр.ВидЦены);
			ЕстьСпецЦены = Истина;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПоказатьЦены()
	НастроитьПараметры();
	
	Цены.Очистить();
	
	СКД = РеквизитФормыВЗначение("Объект").ПолучитьМакет("скдЦены");
	
	Настройки = СКД.НастройкиПоУмолчанию;
	
	
	Парам = Новый Структура;
	Парам.Вставить("Период",КонецДня(ДатаЦенПрайса));
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Настройки.Отбор,"ВидЦены",ВидыЦен,ВидСравненияКомпоновкиДанных.ВСписке,,Истина);
	
	Если ЕстьВидЦенБытХим И ЕстьВидЦенМЕГА Тогда 
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Настройки.Отбор,"ЭтоМЕГА",,,,Ложь);
		
	Иначе 
		Если ЕстьВидЦенБытХим Тогда 
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Настройки.Отбор,"ЭтоМЕГА",Ложь,ВидСравненияКомпоновкиДанных.Равно,,Истина);
		КонецЕсли;
		Если ЕстьВидЦенМЕГА Тогда 
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Настройки.Отбор,"ЭтоМЕГА",Истина,ВидСравненияКомпоновкиДанных.Равно,,Истина);
		КонецЕсли;
	КонецЕсли;	
	
	Если ЕстьСпецЦены И Не (ЕстьВидЦенБытХим Или ЕстьВидЦенМЕГА) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Настройки.Отбор,"Цена",0,ВидСравненияКомпоновкиДанных.Больше,,Истина);
	Иначе 
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Настройки.Отбор,"Цена",,,,Ложь);
	КонецЕсли;	
	
	мср.ПолучитьДанныеНаОснованииСКД(СКД,Цены,Настройки,Парам);
КонецПроцедуры

