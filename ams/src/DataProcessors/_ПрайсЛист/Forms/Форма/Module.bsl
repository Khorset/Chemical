
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ВариантПрайса = 1;
	ДатаЦены      = ТекущаяДатаСеанса();
	ДатаЦенПрайса = ТекущаяДатаСеанса();
	
	ЗаполнитьТаблицыВидовЦен();
	
	ПериодОтчетаПоИсторииЦен.Вариант       = ВариантСтандартногоПериода.ПроизвольныйПериод;
	ПериодОтчетаПоИсторииЦен.ДатаНачала    = ДобавитьМесяц(ДатаЦенПрайса, -12);
	ПериодОтчетаПоИсторииЦен.ДатаОкончания = ДатаЦенПрайса; 
	
	БезОграничений = AMS_ВызовСервера.ЕстьПравоАМС(Перечисления.AMS_Права.ПроведениеРеализацииБезОграничений);
	
	Элементы.СтраницаУстановкаЦен.Видимость = AMS_ВызовСервера.ЭтоKhors() Или БезОграничений;
	Элементы.СтраницаДокументы.Видимость = AMS_ВызовСервера.ЭтоKhors() Или БезОграничений;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	НастройкаСтраницаПрайсы();
	ПоказатьЦены();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если ТекущаяСтраница = Элементы.СтраницаПрайс Тогда 
//		ЗаполнитьСписокВыбораСкидок();
		ПоказатьПрайс();
	
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаЦены Тогда 
		ПоказатьЦены();
		
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаИсторияЦены Тогда 
		ПоказатьИсториюЦены();
		
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаУстановкаЦен Тогда
		НастройкаДействий();
		ПоказатьТовары();
		
	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаПечать Тогда 
		НастройкаСтраницаПрайсы();
	КонецЕсли;
КонецПроцедуры

