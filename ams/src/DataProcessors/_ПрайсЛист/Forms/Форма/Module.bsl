&НаКлиенте
Процедура ВыполнитьДействиеНаСервере()
	Если ДействиеОбласть = 0 Тогда
		Массив = Элементы.Товары.ВыделенныеСтроки;
		Для каждого Элемент Из Массив Цикл
			ВыполнитьДействиеВСтроке(Товары.НайтиПоИдентификатору(Элемент));
		КонецЦикла;
		
	Иначе
		Для каждого Стр Из Товары Цикл
			ВыполнитьДействиеВСтроке(Стр);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьДействиеВСтроке(Стр)
	Если Действие = 0 Тогда
		Стр.Цена = Стр.ЦенаБазовая * (100 + Процент) / 100;
		
	ИначеЕсли Действие = 1 Тогда
		Стр.Цена = Стр.ЦенаБазовая * (100 - Процент) / 100;
		
	ИначеЕсли Действие = 2 Тогда
		Стр.Цена = Процент;
		
	ИначеЕсли Действие = 3 Тогда
		Стр.Цена = 0;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
    Если Результат = КодВозвратаДиалога.Да Тогда
        ЗаписатьИзмененияЦен();
    КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаписатьИзмененияЦен()
	Табл = ПолучитьНовыеЦены();
	
	Если Табл.Количество() = 0 Тогда 
		ОбщегоНазначения.СообщитьПользователю("Новых цен не обнаружено.");
	КонецЕсли;
	
	ТабДок = ПолучитьТаблДокументовУстановкаЦенНоменклатуры(ДатаЦеныНовая);
	
	КолДок = ТабДок.Количество();
	
	Если КолДок > 0 Тогда 
		Док = ТабДок[0].Документ.ПолучитьОбъект();
	Иначе
		Док = Документы.УстановкаЦенНоменклатуры.СоздатьДокумент();
	КонецЕсли;
	
	Док.Дата = ДатаЦеныНовая; 
	Док.Ответственный = Пользователи.ТекущийПользователь(); 
	Док.Комментарий = Комментарий; 
	Док.Согласован = Истина; 
	Док.Статус = Перечисления.СтатусыУстановокЦенНоменклатуры.Согласован; 
	
	Данные = ПолучитьДанныеПоЦенам(Табл,ДатаЦеныНовая,ВидЦеныНовая);

	РезТовары = Данные.Товары;
	РезВидыЦен = Данные.ВидыЦен;
	
	Табл = Док.Товары;
	Табл.Очистить();
	Выб = РезТовары.Выбрать();
	Пока Выб.Следующий() Цикл
		Стр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(Стр,Выб);
	КонецЦикла;
	
	Табл = Док.ВидыЦен;
	Табл.Очистить();
	Выб = РезВидыЦен.Выбрать();
	Пока Выб.Следующий() Цикл
		Стр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(Стр,Выб);
	КонецЦикла;
	
	мср.ЗаписатьДокумент(Док,РежимЗаписиДокумента.Проведение); 
	
	ПоказатьТовары();
	
	Если КолДок > 1 Тогда
		Для Сч = 2 По КолДок Цикл
			Док = ТабДок[Сч-1].Документ.ПолучитьОбъект();
		    мср.УстановитьПометкуУдаленияДокументу(Док,Истина);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьНовыеЦены()
	Таб = РеквизитФормыВЗначение("Товары");
	
	Табл = Таб.СкопироватьКолонки("Номенклатура,Цена");
	
	Для каждого Стр Из Таб Цикл
		Если Стр.Цена = 0 Или Стр.Цена = Стр.ЦенаСтарая Тогда 
			Продолжить;
		КонецЕсли;
		
		НовСтр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр,Стр);
	КонецЦикла;
	
	Возврат Табл;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьТаблДокументовУстановкаЦенНоменклатуры(Дата)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата",Дата);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	д.Номер КАК Номер,
	|	д.Дата КАК Дата,
	|	д.Ссылка КАК Документ,
	|	д.Комментарий КАК Комментарий
	|ИЗ
	|	Документ.УстановкаЦенНоменклатуры КАК д
	|ГДЕ
	|	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	д.МоментВремени";
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьДанныеПоЦенам(Табл,Дата,ВидЦены)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата",Дата);
	Запрос.УстановитьПараметр("ВидЦены",ВидЦены);
	Запрос.УстановитьПараметр("Табл",Табл);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Цена КАК Цена
	|ПОМЕСТИТЬ Таб
	|ИЗ
	|	&Табл КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&ВидЦены КАК ВидЦены,
	|	Таб.Номенклатура КАК Номенклатура,
	|	Таб.Цена КАК Цена
	|ПОМЕСТИТЬ НовЦена
	|ИЗ
	|	Таб КАК Таб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.ВидЦены КАК ВидЦены,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Цена КАК Цена
	|ПОМЕСТИТЬ СтарЦена
	|ИЗ
	|	Документ.УстановкаЦенНоменклатуры.Товары КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.УстановкаЦенНоменклатуры КАК д
	|		ПО т.Ссылка = д.Ссылка
	|ГДЕ
	|	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НовЦена.ВидЦены КАК ВидЦены,
	|	НовЦена.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВсеТовары
	|ИЗ
	|	НовЦена КАК НовЦена
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СтарЦена.ВидЦены,
	|	СтарЦена.Номенклатура
	|ИЗ
	|	СтарЦена КАК СтарЦена
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВсеТовары.ВидЦены КАК ВидЦены,
	|	ВсеТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	ВсеТовары КАК ВсеТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&ВидЦены КАК ВидЦены
	|ПОМЕСТИТЬ НовВидыЦен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.ВидЦены КАК ВидЦены
	|ПОМЕСТИТЬ СтарВидыЦен
	|ИЗ
	|	Документ.УстановкаЦенНоменклатуры.ВидыЦен КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.УстановкаЦенНоменклатуры КАК д
	|		ПО т.Ссылка = д.Ссылка
	|ГДЕ
	|	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НовВидыЦен.ВидЦены КАК ВидЦены
	|ПОМЕСТИТЬ ВсеВидыЦен
	|ИЗ
	|	НовВидыЦен КАК НовВидыЦен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СтарВидыЦен.ВидЦены
	|ИЗ
	|	СтарВидыЦен КАК СтарВидыЦен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВсеВидыЦен.ВидЦены КАК ВидЦены
	|ПОМЕСТИТЬ ВидыЦен
	|ИЗ
	|	ВсеВидыЦен КАК ВсеВидыЦен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыЦен.ВидЦены КАК ВидЦены
	|ИЗ
	|	ВидыЦен КАК ВидыЦен
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВидыЦен.ВидЦены.Наименование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.ВидЦены КАК ВидЦены,
	|	Товары.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА НовЦена.Цена ЕСТЬ NULL
	|			ТОГДА СтарЦена.Цена
	|		ИНАЧЕ НовЦена.Цена
	|	КОНЕЦ КАК Цена,
	|	ИСТИНА КАК ЦенаИзмененаВручную
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ СтарЦена КАК СтарЦена
	|		ПО Товары.ВидЦены = СтарЦена.ВидЦены
	|			И Товары.Номенклатура = СтарЦена.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ НовЦена КАК НовЦена
	|		ПО Товары.ВидЦены = НовЦена.ВидЦены
	|			И Товары.Номенклатура = НовЦена.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	Товары.ВидЦены.Наименование,
	|	Товары.Номенклатура.Наименование";
	
	Рез = Запрос.ВыполнитьПакет();
	
	Данные = Новый Структура;
	Данные.Вставить("ВидыЦен",Рез[9]);
	Данные.Вставить("Товары",Рез[10]);
	
	Возврат Данные;
КонецФункции

&НаСервереБезКонтекста
Процедура УстановитьЗначениеКонстанты(Константа,Значение)
	Константы[Константа].Установить(Значение);
КонецПроцедуры

&НаСервере
Процедура НастройкаСтраницаПрайсы()
	ДатаПрайсаУстановленная = Константы._ДатаПрайса.Получить();
	ДатаПрайсаУстановленнаяМЕГА = Константы._ДатаПрайсаМЕГА.Получить();
	
	ЗаполнитьСпискиВыбораВидовЦен();
	
	ЭтоСтаршийМенеджер = AMS_ВызовСервера.ДоступнаКонкретнаяРоль("_СтаршийМенеджер") Или AMS_ВызовСервера.ЭтоKhors();
	
	Элементы.ДатаПрайсаУстановленная.Доступность     = ЭтоСтаршийМенеджер;
	Элементы.ДатаПрайсаУстановленнаяМЕГА.Доступность = ЭтоСтаршийМенеджер;
	
	Элементы.ФлагПроизвольнойДатыПрайса.Видимость = ЭтоСтаршийМенеджер;
	Элементы.ДатаПрайсаПроизвольная.Видимость     = ФлагПроизвольнойДатыПрайса;
	
	Если ВариантПрайса = 1 или ВариантПрайса = 2 или ВариантПрайса = 3 или ВариантПрайса = 4 Тогда
		Элементы.СтраницыПрайса.Видимость = Истина;
		Элементы.СтраницыПрайса.ТекущаяСтраница = Элементы["СтраницаПрайса" + ВариантПрайса];
	Иначе
		Элементы.СтраницыПрайса.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСпискиВыбораВидовЦен()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Ссылка КАК ВидЦены,
	|	т.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ВидыЦен КАК т
	|ГДЕ
	|	НЕ т.ЦенаВключаетНДС
	|	И т.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДействияВидовЦен.Действует)";
	
	Таб = Запрос.Выполнить().Выгрузить();
	Таб.Сортировать("Наименование");
	
	МассивБытХим = Новый Массив;
	МассивМега   = Новый Массив;
	
	Для каждого Стр Из Таб Цикл
		Если СтрНайти(Стр.Наименование,"Плановая") > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрНайти(Стр.Наименование,"МЕГА") > 0 Тогда
			МассивМега.Добавить(Стр.ВидЦены);
		Иначе
			МассивБытХим.Добавить(Стр.ВидЦены);
		КонецЕсли;
	КонецЦикла;
	
	Элементы.ВидЦеныБытХим.СписокВыбора.ЗагрузитьЗначения(МассивБытХим);
	Элементы.ВидЦеныБытХим1.СписокВыбора.ЗагрузитьЗначения(МассивБытХим);
	
	Элементы.ВидЦеныМега.СписокВыбора.ЗагрузитьЗначения(МассивМега);
	Элементы.ВидЦеныМега1.СписокВыбора.ЗагрузитьЗначения(МассивМега);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПоследнееСоглашение(ПартнерПрайса)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Партнер",ПартнерПрайса);
	
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	т.Соглашение КАК Соглашение
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК т
	|ГДЕ
	|	НЕ т.ПометкаУдаления
	|	И т.Партнер = &Партнер
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.МоментВремени УБЫВ";
	
	Рез = Запрос.Выполнить();
	
	Если Рез.Пустой() Тогда 
		Возврат Справочники.СоглашенияСКлиентами.ПустаяСсылка();
		
	Иначе 
		Выб = Рез.Выбрать();
		Выб.Следующий();
		
		Возврат Выб.Соглашение;
	КонецЕсли;
КонецФункции

&НаКлиенте
Функция ПолучитьПараметры(ТипПрайса)
	Парам = AMS_ВызовСервера.ПолучитьПараметрыДляПрайса(ТипПрайса,ВариантПрайса,СоглашениеПрайса,ВидЦеныБытХим,ВидЦеныМега);

	Если ФлагПроизвольнойДатыПрайса Тогда 
		Дата = ДатаПрайсаПроизвольная;

	Иначе
		Если ВариантПрайса = 1 Тогда
			Если ЗначениеЗаполнено(ВидЦеныМега) Тогда 
				Дата = ?(ДатаПрайсаУстановленная >= ДатаПрайсаУстановленнаяМЕГА,ДатаПрайсаУстановленная,ДатаПрайсаУстановленнаяМЕГА);
			Иначе
				Дата = ДатаПрайсаУстановленная;
			КонецЕсли;
				
		ИначеЕсли ВариантПрайса = 2 Тогда
			Если ЗначениеЗаполнено(ВидЦеныБытХим) И ЗначениеЗаполнено(ВидЦеныМега) Тогда 
				Дата = ?(ДатаПрайсаУстановленная >= ДатаПрайсаУстановленнаяМЕГА,ДатаПрайсаУстановленная,ДатаПрайсаУстановленнаяМЕГА);
				
			Иначе
				Если ЗначениеЗаполнено(ВидЦеныБытХим) Тогда 
					Дата = ДатаПрайсаУстановленная;
				ИначеЕсли ЗначениеЗаполнено(ВидЦеныМега) Тогда 
					Дата = ДатаПрайсаУстановленнаяМЕГА;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли ВариантПрайса = 3 Или ВариантПрайса = 5 Или ВариантПрайса = 6 Тогда
			Дата = ДатаПрайсаУстановленная;
			
		ИначеЕсли ВариантПрайса = 4 Или ВариантПрайса = 7 Или ВариантПрайса = 8 Тогда
			Дата = ДатаПрайсаУстановленнаяМЕГА;
		КонецЕсли;
	КонецЕсли;
	
	Парам.Вставить("Организация",Организация);
	Парам.Вставить("Дата"       ,Дата);
	Парам.Вставить("Период"     ,?(ДатаЦенПрайса = '0001.01.01',Дата,ДатаЦенПрайса));
	
	Возврат Парам;
КонецФункции

