&НаКлиенте
Процедура ЗаписатьВExcel(Команда)
	Парам = ПолучитьПараметры(1);
	
	ИмяФайла = "Прайс_АМС_" + Формат(Парам.Период,"ДЛФ=Д");
	Если ВариантПрайса = 1 Тогда
		ИмяФайла = ИмяФайла + "_" + ПартнерПрайса;
	КонецЕсли;

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок          = "Выберите каталог для сохранения ЗАКАЗА";
	Диалог.Фильтр             = "Файлы Excel (*.xlsx;*.xls)|*.xlsx;*.xls|";
	Диалог.МножественныйВыбор = Ложь;
	Диалог.ПолноеИмяФайла     = ИмяФайла;
	
	Если Диалог.Выбрать() Тогда
		Состояние("Создание файла EXCEL.");
		
		ТабДок = ПолучитьТабДокПрайса(Парам);
		
		ТабДок.Записать(Диалог.ПолноеИмяФайла,ТипФайлаТабличногоДокумента.XLSX);
		
		Состояние();
	КонецЕсли;
КонецПроцедуры

