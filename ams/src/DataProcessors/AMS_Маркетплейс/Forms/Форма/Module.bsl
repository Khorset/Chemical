#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура СообщитьПользователю(Текст, Поле, ПутьКДанным, КлючДанных = Неопределено)
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = Текст;
	Сообщение.Поле = Поле;
	
	Если Не КлючДанных = Неопределено Тогда
		Сообщение.ПутьКДанным = ПутьКДанным;
	КонецЕсли;
	
	Сообщение.Сообщить();
КонецПроцедуры

&НаСервере
Процедура УстановитьОтбор()
	Стр = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(Партнер, "Код, Наименование");
	ПартнерКод          = Стр.Код;
	ПартнерНаименование = Стр.Наименование;
	
	ОтборПоПартнеру = ЗначениеЗаполнено(Партнер);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ЗаказыКлиента.Отбор,"ХозяйственнаяОперация",
		Перечисления.ХозяйственныеОперации.ПередачаНаКомиссию, ВидСравненияКомпоновкиДанных.Равно,, Истина);
										
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ЗаказыКлиента.Отбор,"Партнер",
		Партнер, ВидСравненияКомпоновкиДанных.Равно,, ОтборПоПартнеру);
										
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ПередачиТоваровХранителю.Отбор,"Партнер",
		Партнер, ВидСравненияКомпоновкиДанных.Равно,, ОтборПоПартнеру);
										
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ОтчетыКомиссионера.Отбор,"Партнер",
		Партнер, ВидСравненияКомпоновкиДанных.Равно,, ОтборПоПартнеру);
										
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ПоступлениеТоваровОтХранителя.Отбор,"Партнер",
		Партнер, ВидСравненияКомпоновкиДанных.Равно,, ОтборПоПартнеру);
										
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(РеализацияТоваровУслуг.Отбор,"ХозяйственнаяОперация",
		Перечисления.ХозяйственныеОперации.РеализацияЧерезКомиссионера, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(РеализацияТоваровУслуг.Отбор,"Партнер",
		Партнер, ВидСравненияКомпоновкиДанных.ВСписке,, ОтборПоПартнеру);
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикОкончанияПомещения(ОписаниеПомещенногоФайла, ДополнительныеПараметры = Неопределено) Экспорт
	Если ОписаниеПомещенногоФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	ИмяФайла = ОписаниеПомещенногоФайла.СсылкаНаФайл.Имя;
		
	Данные = ПрочитатьИзВременногоХранилища(ОписаниеПомещенногоФайла.Адрес, ДополнительныеПараметры);
		
	Парам = Новый Структура();
	Парам.Вставить("Комиссионер", ДополнительныеПараметры);
	Парам.Вставить("Данные", Данные.Продажа);
	
	ПараметрыЗаполненияФормы = Новый Структура("Маркетплейс", Парам);
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаОтчетыКомиссионера Тогда
		ОткрытьФорму("Документ.ОтчетКомиссионера.Форма.ФормаДокумента", ПараметрыЗаполненияФормы);
		// Далее см. AMS_СобытияФорм.СформироватьДокументаОтчетКомиссионера
	Иначе
		ОткрытьФорму("Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента", ПараметрыЗаполненияФормы);
		// Далее см. AMS_СобытияФорм.СформироватьОтчетКомиссионера
	КонецЕсли;

	Если Не Данные.Списание = Неопределено Тогда
		Парам = Новый Структура();
		Парам.Вставить("Комиссионер", ДополнительныеПараметры);
		Парам.Вставить("Данные", Данные.Списание);
		
		ПараметрыЗаполненияФормы = Новый Структура("Маркетплейс", Парам);
		
		ОткрытьФорму("Документ.ОтчетОСписанииТоваровСХранения.Форма.ФормаДокумента", ПараметрыЗаполненияФормы);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПрочитатьИзВременногоХранилища(АдресВХ, ДополнительныеПараметры)
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xlsx");
	
	ДанныеФайла = ПолучитьИзВременногоХранилища(АдресВХ);
	
	ДанныеФайла.Записать(ИмяВременногоФайла);
	
	СпособЧтения = СпособЧтенияЗначенийТабличногоДокумента.Текст;
	
	Попытка
		ТабДок.Прочитать(ИмяВременногоФайла, СпособЧтения);
	
	Исключение
		ТекстОшибки = НСтр("ru = 'AMS_Маркетплейс.ПрочитатьИзВременногоХранилища.Ошибка: Не удалось прочитать файл из временного хранилища по причине: %Причина%'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Причина%", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
		ВызватьИсключение ТекстОшибки;
	КонецПопытки;
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаОтчетыКомиссионера Тогда
		Если ПартнерКод = "01-01002322" Тогда      //Алькор и Ко (Летуаль)
			Данные = ПрочитатьФайлЛетуаль();

		ИначеЕсли ПартнерКод = "01-01002442" Тогда //Детский мир маркетплейс
			Данные = ПрочитатьФайлДетскийМир();
			
		ИначеЕсли ПартнерКод = "01-01002250" Тогда //Интернет Решения (OZON)
			Данные = ПрочитатьФайлOzon();
		
		ИначеЕсли ПартнерКод = "01-01002441" Тогда //МАГНИТ МАРКЕТ ООО
			Данные = ПрочитатьФайлМагнитМаркет();
		
		ИначеЕсли ПартнерКод = "01-01002247" Тогда //РВБ (Валберис)
			Данные = ПрочитатьФайлWB();
			
		ИначеЕсли ПартнерКод = "01-01002235" Тогда //Яндекс Маркет ООО
			Данные = ПрочитатьФайлЯндексМаркет();
		КонецЕсли;
		
	Иначе
		Если ПартнерКод = "01-01002247" Тогда //РВБ (Валберис)
			Данные = ПрочитатьФайлВыкупаWB();
		КонецЕсли;
	КонецЕсли;
		
	УдалитьФайлы(ИмяВременногоФайла);
	
	Возврат Данные;
КонецФункции

&НаСервере
Функция ПрочитатьФайлЛетуаль()
	ЛистДТ = ТабДок.ПолучитьОбласть("Отчет");
	
	Табл = ПолучитьСтруктуруДанныхОтчета();
	
	Счет = 0;
	
	Для НомерСтроки = 14 По ЛистДТ.ВысотаТаблицы Цикл
		Попытка
			Артикул    = ЛистДТ.Область(НомерСтроки, 5, НомерСтроки, 5).Текст;
			Цена       = Число(ЛистДТ.Область(НомерСтроки, 16, НомерСтроки, 16).Текст);
			Количество = Число(ЛистДТ.Область(НомерСтроки, 17, НомерСтроки, 17).Текст);

			Счет  = Счет + 1;
			
			Стр1 = Табл.Добавить();

			Стр1.НомерСтроки  = Счет;
			Стр1.Артикул      = Артикул;
			Стр1.Количество   = Количество;
			Стр1.Цена         = Цена;
		Исключение
			Продолжить;
		КонецПопытки;
	КонецЦикла;
	
	Массив = Новый Массив();
	Для Каждого Стр Из Табл Цикл
		Массив.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));	
	КонецЦикла;

	Данные = Новый Структура();
	
	Данные.Вставить("Продажа",  Массив);
	Данные.Вставить("Списание", Неопределено);
	
	Возврат Данные;
КонецФункции

&НаСервере
Функция ПрочитатьФайлДетскийМир()
	ЛистДТ = ТабДок.ПолучитьОбласть("Продажи");
	
	Табл = ПолучитьСтруктуруДанныхОтчета();
	
	Счет = 0;
	Для НомерСтроки = 31 По ЛистДТ.ВысотаТаблицы Цикл
		Попытка
			Счет  = Счет + 1;
			
			Артикул = ЛистДТ.Область(НомерСтроки, 7, НомерСтроки, 7).Текст;
			
			Если ПустаяСтрока(Артикул) Тогда
				Прервать;
			КонецЕсли;
			
			Количество = Число(ЛистДТ.Область(НомерСтроки, 13, НомерСтроки, 13).Текст);
			Цена       = Число(ЛистДТ.Область(НомерСтроки, 21, НомерСтроки, 21).Текст);
			
			Стр1 = Табл.Добавить();
			Стр1.НомерСтроки = Счет;
			Стр1.Артикул     = Артикул;
			Стр1.Количество  = Количество;
			Стр1.Цена        = Цена;
		Исключение
			ТекстОшибки = НСтр("ru = 'AMS_Маркетплейс.ПрочитатьФайлДетскийМир.Ошибка: Не удалось прочитать данные их файл отчета по причине: %Причина%'");
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Причина%", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
			ВызватьИсключение ТекстОшибки;
		КонецПопытки;
	КонецЦикла;
	
	Массив = Новый Массив();
	Для Каждого Стр Из Табл Цикл
		Массив.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));	
	КонецЦикла;

	Данные = Новый Структура();
	
	Данные.Вставить("Продажа",  Массив);
	Данные.Вставить("Списание", Неопределено);
	
	Возврат Данные;
КонецФункции

&НаСервере
Функция ПрочитатьФайлOzon()
	ЛистДТ = ТабДок.ПолучитьОбласть("Отчет_о_реализации");
	
	Табл = ПолучитьСтруктуруДанныхОтчета();
	
	НомСтроки = 0;
	
	Для НомерСтроки = 16 По ЛистДТ.ВысотаТаблицы Цикл
		Попытка
			Номер = ЛистДТ.Область(НомерСтроки, 1, НомерСтроки, 1).Текст;
			Если ПустаяСтрока(Номер) Или Число(Номер) = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Артикул = ЛистДТ.Область(НомерСтроки, 3, НомерСтроки, 3).Текст;
			
			РеалСуммаТекст = ЛистДТ.Область(НомерСтроки, 6, НомерСтроки, 6).Текст;
			Если ПустаяСтрока(РеалСуммаТекст) Тогда
				РеалСумма = 0;
			Иначе 
				РеалСумма = Число(РеалСуммаТекст);	
			КонецЕсли;
			
			РеалВыплатаТекст = ЛистДТ.Область(НомерСтроки, 7, НомерСтроки, 7).Текст;
			Если ПустаяСтрока(РеалВыплатаТекст) Тогда
				РеалВыплата = 0;
			Иначе
				РеалВыплата = Число(РеалВыплатаТекст);
			КонецЕсли;
			
			РеалКоличествоТекст = ЛистДТ.Область(НомерСтроки, 8, НомерСтроки, 8).Текст;
			Если ПустаяСтрока(РеалКоличествоТекст) Тогда
				РеализованоКоличество = 0;
			Иначе
				РеализованоКоличество = Число(РеалКоличествоТекст);
			КонецЕсли;
			
			РеализованоСумма = РеалСумма + РеалВыплата;
			РеализованоЦена  = ?(РеализованоКоличество = 0, 0, РеализованоСумма / РеализованоКоличество);
			
			ВозвратСуммаТекст = ЛистДТ.Область(НомерСтроки, 10, НомерСтроки, 10).Текст;
			Если ПустаяСтрока(ВозвратСуммаТекст) Тогда
				ВозвратСумма = 0;
			Иначе
				ВозвратСумма = Число(ВозвратСуммаТекст);
			КонецЕсли;
			
			ВозвратВыплатаТекст = ЛистДТ.Область(НомерСтроки, 11, НомерСтроки, 11).Текст;
			Если ПустаяСтрока(ВозвратВыплатаТекст) Тогда
				ВозвратВыплата = 0;
			Иначе
				ВозвратВыплата = Число(ВозвратВыплатаТекст);
			КонецЕсли;
			
			ВозвратКоличествоТекст = ЛистДТ.Область(НомерСтроки, 12, НомерСтроки, 12).Текст;
			Если ПустаяСтрока(ВозвратКоличествоТекст) Тогда
				ВозвратКоличество = 0;
			Иначе
				ВозвратКоличество = Число(ВозвратКоличествоТекст);
			КонецЕсли;
			
			ВозвращеноСумма = ВозвратСумма + ВозвратВыплата;
			ВозвращеноЦена  = ?(ВозвратКоличество = 0, 0, ВозвращеноСумма / ВозвратКоличество);
			
			Если РеализованоКоличество > 0 Тогда
				Стр = Табл.Добавить();
				
				НомСтроки = НомСтроки + 1;
							
				Стр.НомерСтроки = НомСтроки;
				Стр.Артикул     = Артикул;
				Стр.Количество  = РеализованоКоличество;
				Стр.Сумма       = РеализованоСумма;
				Стр.Цена        = РеализованоЦена;
			КонецЕсли;
			
			Если ВозвратКоличество > 0 Тогда
				Стр = Табл.Добавить();
				
				НомСтроки = НомСтроки + 1;
				
				Стр.НомерСтроки = НомСтроки;
				Стр.Артикул     = Артикул;
				Стр.Количество  = -ВозвратКоличество;
				Стр.Сумма       = -ВозвращеноСумма;
				Стр.Цена        = ВозвращеноЦена;
			КонецЕсли;
		
		Исключение
			ТекстОшибки = НСтр("ru = 'AMS_Маркетплейс.ПрочитатьФайлOzon.Ошибка: Не удалось прочитать данные их файл отчета по причине: %Причина%'");
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Причина%", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка);
			ВызватьИсключение ТекстОшибки;
		КонецПопытки;
	КонецЦикла;
	
	Массив = Новый Массив();
	
	Для Каждого Стр Из Табл Цикл
		Массив.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));	
	КонецЦикла;

	Данные = Новый Структура();
	Данные.Вставить("Продажа", Массив);
	Данные.Вставить("Списание", Неопределено);
	
	Возврат Данные;
КонецФункции

