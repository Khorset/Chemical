
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
	// Возврат при получении формы для анализа.
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьСписокКомиссионеров()
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьОтбор();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПартнерПриИзменении(Элемент)
	УстановитьОтбор();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДокументыСборкаНаборов

&НаКлиенте
Процедура ДокументыСборкаНаборовПриАктивизацииСтроки(Элемент)
	Если Элемент.ТекущиеДанные = Неопределено Тогда 
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(МатериалыСборкаНаборов.Отбор,"Ссылка",,ВидСравненияКомпоновкиДанных.Равно,,Истина);
    Иначе
        Док = Элемент.ТекущаяСтрока;
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(МатериалыСборкаНаборов.Отбор,"Ссылка",Док,ВидСравненияКомпоновкиДанных.Равно,,Истина);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьОтчетКомиссионера(Команда)
	Если ПартнерКод = "01-01002322"          //Алькор и Ко (Летуаль)
		Или ПартнерКод = "01-01002250"       //Интернет Решения (OZON)
		Или ПартнерКод = "01-01002442"       //Детский мир маркетплейс
		Или ПартнерКод = "01-01002441"       //МАГНИТ МАРКЕТ ООО
		Или ПартнерКод = "01-01002247"       //РВБ (Валберис)
		Или ПартнерКод = "01-01002235" Тогда //Яндекс Маркет ООО

		ОбработкаОкончанияПомещения = Новый ОписаниеОповещения("ОбработчикОкончанияПомещения", ЭтотОбъект, Партнер);
		
		ПараметрыДиалога = Новый ПараметрыДиалогаПомещенияФайлов();
		ПараметрыДиалога.Фильтр = "Excel файлы(*.xls;*.xlsx)|*.xls;*.xlsx";
		ПараметрыДиалога.Заголовок ="Выбирите файл отчета комиссионера """ + ПартнерНаименование + """";
		ПараметрыДиалога.МножественныйВыбор = Ложь;
		
		НачатьПомещениеФайлаНаСервер(ОбработкаОкончанияПомещения, , , , ПараметрыДиалога, УникальныйИдентификатор);
		
	Иначе
		Текст = НСтр("ru = 'Модуль загрузки для данного комиссионера отсутствует!'");
		СообщитьПользователю(Текст, "Партнер", "Объект");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
