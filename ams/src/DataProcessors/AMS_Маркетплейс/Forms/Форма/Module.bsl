Процедура ЗаполнитьСписокКомиссионеров()
	УстановитьПривилегированныйРежим(Истина);
	
	ГруппаДоступаМаркетплейс = Справочники.ГруппыДоступаПартнеров.НайтиПоНаименованию("Маркетплейс", Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ГруппаДоступа", ГруппаДоступаМаркетплейс);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	т.Ссылка КАК Партнер,
	|	т.Наименование КАК Наименование
	|ИЗ
	|	Справочник.Партнеры КАК т
	|ГДЕ
	|	т.ГруппаДоступа = &ГруппаДоступа
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";

	Табл = Запрос.Выполнить().Выгрузить();
	
	Если Табл.Количество() > 0 Тогда
		Элементы.Партнер.СписокВыбора.ЗагрузитьЗначения(Табл.ВыгрузитьКолонку("Партнер"));
	КонецЕсли;
КонецПроцедуры

