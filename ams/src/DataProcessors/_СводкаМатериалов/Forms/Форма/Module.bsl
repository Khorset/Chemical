    СписокВыбора.Добавить(AMS_ВызовСервера.НоменклатураКрасители());
    СписокВыбора.Добавить(AMS_ВызовСервера.НоменклатураОтдушки());
    СписокВыбора.Добавить(AMS_ВызовСервера.НоменклатураКоробки());
    СписокВыбора.Добавить(AMS_ВызовСервера.НоменклатураКанистры());
    СписокВыбора.Добавить(AMS_ВызовСервера.НоменклатураФлаконы());
    СписокВыбора.Добавить(AMS_ВызовСервера.НоменклатураКрышки());
    СписокВыбора.Добавить(AMS_ВызовСервера.НоменклатураЭтикетки());
    СписокВыбора.Добавить(AMS_ВызовСервера.НоменклатураУпаковка());
КонецПроцедуры

