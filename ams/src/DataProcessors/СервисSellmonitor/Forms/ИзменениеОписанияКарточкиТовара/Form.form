            <id>218</id>
            <title>
              <key>ru</key>
              <value>Изменить описание в карточках</value>
            </title>
            <visible>true</visible>
            <enabled>true</enabled>
            <userVisible>
              <common>true</common>
            </userVisible>
            <dataPath xsi:type="form:DataPath">
              <segments>СписокКТ</segments>
