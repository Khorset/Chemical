#КонецОбласти

#Область Печать_ПрайсЛист

Функция СформироватьПрайсЛист(Парам) Экспорт
	Результат = Новый ТабличныйДокумент;
	Результат.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	Результат.АвтоМасштаб        = Истина;

	ТипПрайса     = Парам.ТипПрайса;
	ВариантПрайса = Парам.ВариантПрайса;

	ПрайсБазовый = Не (ВариантПрайса = 1 Или ВариантПрайса = 2 Или ВариантПрайса = 3 Или ВариантПрайса = 4);

	ИмяМакета = "Обработка._ПрайсЛист.ПрайсЛист";
	Если ПрайсБазовый Тогда
		ИмяМакета = ИмяМакета + Парам.ВариантПрайса;
	КонецЕсли;
	Макет = УправлениеПечатью.МакетПечатнойФормы(ИмяМакета);

	ЦеноваяГруппа = Парам.ЦеноваяГруппа;
	Если Парам.Организация = AMS_ВызовСервера.ОрганизацияТД() Тогда
		Если ЦеноваяГруппа.Количество() = 2 Тогда
			ОблЗаголовок = Макет.ПолучитьОбласть("ТД_ЗМ");
		Иначе
			Если ЦеноваяГруппа[0] = AMS_ВызовСервера.ЦеноваяГруппаМЕГА() Тогда
				ОблЗаголовок = Макет.ПолучитьОбласть("ТД_М");
			Иначе
				ОблЗаголовок = Макет.ПолучитьОбласть("ТД_З");
			КонецЕсли;
		КонецЕсли;

	Иначе
		Если ЦеноваяГруппа.Количество() = 2 Тогда
			ОблЗаголовок = Макет.ПолучитьОбласть("Кемикал_ЗМ");
		Иначе
			Если ЦеноваяГруппа[0] = AMS_ВызовСервера.ЦеноваяГруппаМЕГА() Тогда
				ОблЗаголовок = Макет.ПолучитьОбласть("Кемикал_М");
			Иначе
				ОблЗаголовок = Макет.ПолучитьОбласть("Кемикал_З");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	ОблЗаголовок.Параметры.Дата = "Действителен с " + Формат(Парам.Дата, "ДЛФ=ДД");
	Результат.Вывести(ОблЗаголовок);

	Табл = ПолучитьСтруктуруПродукции(ВариантПрайса, ЦеноваяГруппа);

	Если ТипПрайса = 1 Тогда
		ВывестиПрайсЛистТип1(Результат, Макет, Табл, Парам);

	ИначеЕсли ТипПрайса = 2 Тогда
		ВывестиПрайсЛистТип2(Результат, Макет, Табл, Парам);

	ИначеЕсли ТипПрайса = 3 Тогда
		ВывестиПрайсЛистТип3(Результат, Макет, Табл, Парам);

		КолСтр = Результат.ВысотаТаблицы;
		КолКол = Результат.ШиринаТаблицы;

		Для Стр = 1 По КолСтр Цикл
			Для Кол = 1 По КолКол Цикл
				ОбластьКартинки = Результат.Область(Стр, Кол);
				ФайлКартинки    = ОбластьКартинки.Расшифровка;

				Если ЗначениеЗаполнено(ФайлКартинки) И ТипЗнч(ФайлКартинки) = Тип(
					"СправочникСсылка.НоменклатураПрисоединенныеФайлы") Тогда
					ПутьКФайлу = "\\AMSSERVN\1sbdb\1C_DB\1C_Filestoms\" + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
						ФайлКартинки, "ПутьКФайлу");
					Картинка = Новый Картинка(ПутьКФайлу);
					КартинкаВДокументе = Результат.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Картинка);
					КартинкаВДокументе.Картинка = Картинка;
					КартинкаВДокументе.РазмерКартинки = РазмерКартинки.АвтоРазмер;

					КартинкаВДокументе.Расположить(ОбластьКартинки);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Процедура ВывестиПрайсЛистТип1(Результат, Макет, Табл, Парам)
	МассивВыводимыхОбластей = Новый Массив;

	ОблШапка  = Макет.ПолучитьОбласть("Шапка");
	ОблПодвал = Макет.ПолучитьОбласть("Подвал");

	Результат.Вывести(ОблШапка);

	Номер = 0;
	НомерГруппы = 0;
	КолСтрок    = Табл.Количество();
	Для Каждого Стр Из Табл Цикл
		НомерСтроки = Табл.Индекс(Стр) + 1;

		ЭтоГруппа = Не ЗначениеЗаполнено(Стр.ВидПродукции);

		Если ЭтоГруппа Тогда
			НомерГруппы = НомерГруппы + 1;
			Обл = Макет.ПолучитьОбласть("Родитель");
			Обл.Параметры.Родитель = Стр.Родитель;

			МассивВыводимыхОбластей.Добавить(Обл);

		Иначе
			Если Стр.ВидПродукции.Товары.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;

			Номер = Номер + 1;

			Обл = Макет.ПолучитьОбласть(Стр.Макет);

			ПараметрыОбласти = Обл.Параметры;

			ЗаполнитьЗначенияСвойств(ПараметрыОбласти, Стр);

			ПараметрыОбласти.Номер = Номер;
			
			//@skip-check query-in-loop
			ДополнитьПараметрыОбласти(ПараметрыОбласти, Стр, Парам);

			МассивВыводимыхОбластей.Добавить(Обл);
		КонецЕсли;

		Если ЭтоГруппа Тогда
			Если Парам.ВариантПрайса <= 3 Тогда //По соглашению и Произвольные цены
				Если НомерГруппы = 3 Или НомерГруппы = 14 Тогда
					Результат.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЕсли;

			ИначеЕсли Парам.ВариантПрайса = 5 Тогда //Базовые цены
				Если НомерГруппы = 2 Тогда
					Результат.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЕсли;

			ИначеЕсли Парам.ВариантПрайса = 6 Тогда //Оптовые цены
				Если НомерГруппы = 3 Тогда
					Результат.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЕсли;

			ИначеЕсли Парам.ВариантПрайса = 7 Тогда //Базовые цены МЕГА
				Если НомерГруппы = 5 Тогда
					Результат.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;

		Если Не Результат.ПроверитьВывод(МассивВыводимыхОбластей) Тогда
			Результат.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;

		Если НомерСтроки = КолСтрок Тогда
			МассивВыводимыхОбластей.Добавить(ОблПодвал);

			Если Не Результат.ПроверитьВывод(МассивВыводимыхОбластей) Тогда
				Результат.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
		КонецЕсли;

		Результат.Вывести(Обл);

		МассивВыводимыхОбластей.Очистить();
	КонецЦикла;

	Если Парам.Организация = AMS_ВызовСервера.ОрганизацияАМСНовая() Тогда
		ОблПодвал.Параметры.Директор = "Директор ___________________________ /Огнев Эдуард Викторович/";
	Иначе
		ОблПодвал.Параметры.Директор = "Генеральный директор ___________________________ /Огнев Эдуард Викторович/";
	КонецЕсли;

	Результат.Вывести(ОблПодвал);
КонецПроцедуры

Процедура ВывестиПрайсЛистТип2(Результат, Макет, Табл, Парам)
	ОблШапка  = Макет.ПолучитьОбласть("Шапка");
	ОблГруппа = Макет.ПолучитьОбласть("Родитель");
	ОблСтрока = Макет.ПолучитьОбласть("Строка");
	ОблПодвал = Макет.ПолучитьОбласть("Подвал");

	Результат.Вывести(ОблШапка);

	Номер = 0;
	НомерГруппы = 0;
	Для Каждого Стр Из Табл Цикл

		ЭтоГруппа = Не ЗначениеЗаполнено(Стр.ВидПродукции);

		Если ЭтоГруппа Тогда
			НомерГруппы = НомерГруппы + 1;
			ОблГруппа.Параметры.Родитель = Стр.Родитель;
			Результат.Вывести(ОблГруппа);

		Иначе
			//@skip-check query-in-loop
			Товары = ПолучитьЦенуПродукции(Стр.ВидПродукции, Парам);

			Для Каждого Выб Из Товары Цикл
				Номер = Номер + 1;
				ЗаполнитьЗначенияСвойств(ОблСтрока.Параметры, Выб);
				ОблСтрока.Параметры.Номер = Номер;
				Результат.Вывести(ОблСтрока);
			КонецЦикла;
		КонецЕсли;

	КонецЦикла;

	Если Парам.Организация = AMS_ВызовСервера.ОрганизацияАМСНовая() Тогда
		ОблПодвал.Параметры.Директор = "Директор _______________ /Огнев Эдуард Викторович/";
	Иначе
		ОблПодвал.Параметры.Директор = "Генеральный директор ________________ /Огнев Эдуард Викторович/";
	КонецЕсли;
	Результат.Вывести(ОблПодвал);
КонецПроцедуры

Процедура ВывестиПрайсЛистТип3(Результат, Макет, Табл, Парам)
	ОблШапка  = Макет.ПолучитьОбласть("Шапка");
	ОблГруппа = Макет.ПолучитьОбласть("Родитель");
	ОблПодвал = Макет.ПолучитьОбласть("Подвал");
	ОблСтрока   = Макет.ПолучитьОбласть("Строка3");

	Результат.Вывести(ОблШапка);

	Номер = 0;
	НомерГруппы = 0;
	Для Каждого Стр Из Табл Цикл
		ЭтоГруппа = Не ЗначениеЗаполнено(Стр.ВидПродукции);

		Если ЭтоГруппа Тогда
			НомерГруппы = НомерГруппы + 1;
			ОблГруппа.Параметры.Родитель = Стр.Родитель;
			Результат.Вывести(ОблГруппа);

		Иначе
			//@skip-check query-in-loop
			Товары = ПолучитьЦенуПродукции(Стр.ВидПродукции, Парам);

			Для Каждого Выб Из Товары Цикл
				Номер = Номер + 1;
				ЗаполнитьЗначенияСвойств(ОблСтрока.Параметры, Выб);
				ОблСтрока.Параметры.Номер = Номер;
				Результат.Вывести(ОблСтрока);
			КонецЦикла;
		КонецЕсли;

	КонецЦикла;

	Если Парам.Организация = AMS_ВызовСервера.ОрганизацияАМСНовая() Тогда
		ОблПодвал.Параметры.Директор = "Директор _______________ /Огнев Эдуард Викторович/";
	Иначе
		ОблПодвал.Параметры.Директор = "Генеральный директор ________________ /Огнев Эдуард Викторович/";
	КонецЕсли;
	Результат.Вывести(ОблПодвал);
КонецПроцедуры

Процедура ДополнитьПараметрыОбласти(ПараметрыОбласти, Стр, Парам)
	ВидПродукции = Стр.ВидПродукции;

	Товары = ПолучитьЦенуПродукции(ВидПродукции, Парам);

	Для Каждого Выб Из Товары Цикл
		Сч = Выб.НомерСтроки;

		Попытка
			ПараметрыОбласти["Артикул" + Сч] = Выб.Артикул;
		Исключение
			// Обработка исключения не требуется
			А = 1;
		КонецПопытки;

		Попытка
			ПараметрыОбласти["Наименование" + Сч] = Выб.Наименование;
		Исключение
			// Обработка исключения не требуется
			А = 1;
		КонецПопытки;

		Попытка
			ПараметрыОбласти["Вес" + Сч] = ПреобразоватьСтроку(Выб.Вес);
		Исключение
			// Обработка исключения не требуется
			А = 1;
		КонецПопытки;

		Попытка
			ПараметрыОбласти["Количество" + Сч] = ПреобразоватьСтроку(Выб.Количество);
		Исключение
			// Обработка исключения не требуется
			А = 1;
		КонецПопытки;

		Попытка
			ПараметрыОбласти["Цена1БезНДС" + Сч] = Выб.Цена1БезНДС;
			ПараметрыОбласти["Цена1СНДС" + Сч]   = Выб.Цена1СНДС;
			ПараметрыОбласти["Цена2БезНДС" + Сч] = Выб.Цена2БезНДС;
			ПараметрыОбласти["Цена2СНДС" + Сч]   = Выб.Цена2СНДС;
			ПараметрыОбласти["Цена3БезНДС" + Сч] = Выб.Цена3БезНДС;
			ПараметрыОбласти["Цена3СНДС" + Сч]   = Выб.Цена3СНДС;
			ПараметрыОбласти["Цена4БезНДС" + Сч] = Выб.Цена4БезНДС;
			ПараметрыОбласти["Цена4СНДС" + Сч]   = Выб.Цена4СНДС;
			ПараметрыОбласти["Цена5БезНДС" + Сч] = Выб.Цена5БезНДС;
			ПараметрыОбласти["Цена5СНДС" + Сч]   = Выб.Цена5СНДС;
			ПараметрыОбласти["Цена6БезНДС" + Сч] = Выб.Цена6БезНДС;
			ПараметрыОбласти["Цена6СНДС" + Сч]   = Выб.Цена6СНДС;
		Исключение
			// Обработка исключения не требуется
			Если А = 1 Тогда
				А = 1;
			КонецЕсли;
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьЦенуПродукции(ВидПродукции, Парам)
	Цены = Новый ТаблицаЗначений;
	Цены.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Цены.Колонки.Добавить("Цена", Новый ОписаниеТипов("Число"));

	ЦеныСоглашения = Парам.ЦеныСоглашения;
	Для Каждого Стр Из ЦеныСоглашения Цикл
		НовСтр = Цены.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидПродукции", ВидПродукции);
	Запрос.УстановитьПараметр("ТипПрайса", Парам.ТипПрайса);
	Запрос.УстановитьПараметр("Период", КонецДня(Парам.Период));
	Запрос.УстановитьПараметр("ВидЦены1", Парам.ВидЦены1);
	Запрос.УстановитьПараметр("ВидЦены2", Парам.ВидЦены2);
	Запрос.УстановитьПараметр("ВидЦены3", Парам.ВидЦены3);
	Запрос.УстановитьПараметр("ВидЦены4", Парам.ВидЦены4);
	Запрос.УстановитьПараметр("ВидЦены5", Парам.ВидЦены5);
	Запрос.УстановитьПараметр("ВидЦены6", Парам.ВидЦены6);
	Запрос.УстановитьПараметр("Цены", Цены);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Цена КАК Цена
	|ПОМЕСТИТЬ ц
	|ИЗ
	|	&Цены КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА &ТипПрайса = 1
	|			ТОГДА т.НомерСтроки
	|		ИНАЧЕ т.Номер
	|	КОНЕЦ КАК НомерСтроки,
	|	т.Наименование КАК Наименование,
	|	т.Вес КАК Вес,
	|	т.Количество КАК Количество,
	|	т.Номенклатура КАК Номенклатура,
	|	ном.НаименованиеПолное КАК Представление,
	|	ном.Артикул КАК Артикул,
	|	ном.ВесЧислитель КАК ВесУпак,
	|	ном.КоэффициентЕдиницыДляОтчетов КАК КолУпак,
	|	ном.ФайлКартинки КАК ФайлКартинки
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	Справочник._ПродукцияКомпании.Товары КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|		ПО т.Номенклатура = ном.Ссылка
	|ГДЕ
