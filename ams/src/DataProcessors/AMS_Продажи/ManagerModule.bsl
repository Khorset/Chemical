Функция СформироватьПечатнуюФормуСН(МассивОбъектов, ОбъектыПечати, ПараметрыПечати, КомплектыПечати = Неопределено) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ПолеСлева = 5;
	ТабличныйДокумент.ПолеСправа = 5;
	ТабличныйДокумент.РазмерКолонтитулаСверху = 0;
	ТабличныйДокумент.РазмерКолонтитулаСнизу = 0;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;

	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ__СН";

	ДанныеДляПечати = ПолучитьДанныеДляПечатиСН(МассивОбъектов);

	ЗаполнитьТабДокСН(ТабличныйДокумент, ДанныеДляПечати, ОбъектыПечати, ПараметрыПечати, КомплектыПечати);

	Возврат ТабличныйДокумент;
КонецФункции

Функция ПолучитьДанныеДляПечатиСН(МассивОбъектов)
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("ПродукцияЦеха1", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха1());
	Запрос.УстановитьПараметр("ПродукцияЦеха2", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха2());
	Запрос.УстановитьПараметр("ПродукцияЦеха3", AMS_ВызовСервера.ВидНоменклатурыПродукцияЦеха3());
	Запрос.УстановитьПараметр("ХозТовар", AMS_ВызовСервера.ВидНоменклатурыТовар());

	Запрос.Текст =
	"ВЫБРАТЬ
	|	Реал.Партнер КАК Клиент,
	|	Реал.Партнер.НаименованиеПолное КАК ПартнерНаименованиеПолное,
	|	Реал.Партнер.Код КАК ПартнерКод,
	|	Реал.СпособДоставки КАК СпособДоставки,
	|	Реал.ВремяДоставкиС КАК ВремяДоставкиС,
	|	Реал.ВремяДоставкиПо КАК ВремяДоставкиПо,
	|	Реал.AMS_Обрешетка КАК Обрешетка,
	|	Реал.AMS_СпособПередачиТоваров КАК СпособПередачиТоваров,
	|	Реал.AMS_УсловияОтгрузки КАК УсловияОтгрузки,
	|	Реал.AMS_КоличествоПалет КАК КоличествоПалет,
	|	Реал.AMS_Вес КАК Вес,
	|	Реал.AMS_Объем КАК Объем,
	|	Реал.СуммаДокумента КАК СуммаДокумента,
	|	Реал.Ссылка КАК Ссылка,
	|	1 КАК Связь
	|ПОМЕСТИТЬ док1
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реал
	|ГДЕ
	|	Реал.Ссылка В(&МассивОбъектов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	СУММА(т.Количество) КАК Количество,
	|	СУММА(т.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	СУММА(т.Сумма * 1.22) КАК Сумма,
	|	т.Упаковка КАК Упаковка
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК т
	|ГДЕ
	|	т.Ссылка В(&МассивОбъектов)
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура,
	|	т.Упаковка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Реал.Номер КАК Номер,
	|	Реал.Дата КАК Дата,
	|	Реал.Организация КАК Организация,
	|	Реал.Контрагент КАК Покупатель,
	|	Реал.Грузополучатель КАК Грузополучатель,
	|	Реал.ПеревозчикПартнер КАК Перевозчик,
	|	Реал.ПеревозчикПартнер.НаименованиеПолное КАК ПеревозчикНаименование,
	|	Реал.АдресДоставки КАК АдресДоставки,
	|	Реал.АдресДоставкиПеревозчика КАК АдресДоставкиПеревозчика,
	|	Реал.ДополнительнаяИнформацияПоДоставке КАК ДополнительнаяИнформацияПоДоставке,
	|	Реал.Комментарий КАК Комментарий,
	|	Реал.AMS_ТелефонВодителяКлиента КАК ТелефонВодителяКлиента,
	|	Реал.AMS_ПравилоПродажи КАК ПравилоПродажи,
	|	Реал.Ссылка КАК Ссылка,
	|	1 КАК Связь
	|ПОМЕСТИТЬ шапка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реал
	|ГДЕ
	|	Реал.Ссылка В(&МассивОбъектов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	шапка.Номер КАК Номер,
	|	шапка.Дата КАК Дата,
	|	док1.Клиент КАК Клиент,
	|	док1.ПартнерКод КАК ПартнерКод,
	|	док1.ПартнерНаименованиеПолное КАК КлиентНаименование,
	|	док1.СпособДоставки КАК СпособДоставки,
	|	шапка.АдресДоставки КАК АдресДоставки,
	|	док1.ВремяДоставкиС КАК ВремяДоставкиС,
	|	док1.ВремяДоставкиПо КАК ВремяДоставкиПо,
	|	док1.Обрешетка КАК Обрешетка,
	|	док1.СпособПередачиТоваров КАК СпособПередачиТоваров,
	|	док1.УсловияОтгрузки КАК УсловияОтгрузки,
	|	док1.КоличествоПалет КАК КоличествоПалет,
	|	док1.Вес КАК ИтогоВес,
	|	док1.Объем КАК ИтогоОбъем,
	|	док1.СуммаДокумента КАК ИтогоСумма,
	|	шапка.Организация КАК Организация,
	|	шапка.Покупатель КАК Покупатель,
	|	шапка.Грузополучатель КАК Грузополучатель,
	|	шапка.Перевозчик КАК Перевозчик,
	|	шапка.ПеревозчикНаименование КАК ПеревозчикНаименование,
	|	шапка.АдресДоставкиПеревозчика КАК АдресДоставкиПеревозчика,
	|	шапка.ДополнительнаяИнформацияПоДоставке КАК ДополнительнаяИнформацияПоДоставке,
	|	шапка.Комментарий КАК Комментарий,
	|	шапка.ТелефонВодителяКлиента КАК ТелефонВодителяКлиента,
	|	шапка.ПравилоПродажи КАК ПравилоПродажи,
	|	шапка.Ссылка КАК Ссылка
	|ИЗ
	|	док1 КАК док1
	|		ЛЕВОЕ СОЕДИНЕНИЕ шапка КАК шапка
	|		ПО док1.Связь = шапка.Связь
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Реал.Номер КАК Номер,
	|	Реал.Дата КАК Дата
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реал
	|ГДЕ
	|	Реал.Ссылка В(&МассивОбъектов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ном.ВидНоменклатуры = &ПродукцияЦеха1
	|			ТОГДА 1
	|		КОГДА ном.ВидНоменклатуры = &ПродукцияЦеха2
	|			ТОГДА 2
	|		КОГДА ном.ВидНоменклатуры = &ПродукцияЦеха3
	|			ТОГДА 3
	|		КОГДА ном.ВидНоменклатуры = &ХозТовар
	|			ТОГДА 5
	|	КОНЕЦ КАК Цех,
	|	ном.Артикул КАК Артикул,
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Упаковка КАК Ед,
	|	тов.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВЫРАЗИТЬ(тов.Количество / ЕСТЬNULL(Палл.Числитель, 1) КАК ЧИСЛО(10, 3)) КАК КоличествоПалет,
	|	ВЫРАЗИТЬ(тов.Сумма / тов.КоличествоУпаковок КАК ЧИСЛО(10, 2)) КАК Цена,
	|	ВЫРАЗИТЬ(тов.Сумма КАК ЧИСЛО(10, 2)) КАК Сумма,
	|	ВЫРАЗИТЬ(тов.КоличествоУпаковок * Упак.Вес / 1000 КАК ЧИСЛО(10, 3)) КАК Вес,
	|	ВЫРАЗИТЬ(тов.КоличествоУпаковок * Упак.Объем / 1000 КАК ЧИСЛО(10, 3)) КАК Объем
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|		ПО тов.Номенклатура = ном.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Упак
	|		ПО тов.Упаковка = Упак.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК Палл
	|		ПО тов.Номенклатура = Палл.Владелец
	|			И тов.Упаковка = Палл.Родитель
	|
	|УПОРЯДОЧИТЬ ПО
	|	Цех,
	|	ном.Наименование";

	Рез = Запрос.ВыполнитьПакет();
	РезультатПоШапке = Рез[3];
	РезультатПоНомерамУПД = Рез[4];
	РезультатПоТабличнойЧасти = Рез[5];

	Возврат Новый Структура("РезультатПоШапке,РезультатПоНомерамУПД,РезультатПоТабличнойЧасти", РезультатПоШапке,
		РезультатПоНомерамУПД, РезультатПоТабличнойЧасти);
КонецФункции

Процедура ЗаполнитьТабДокСН(ТабличныйДокумент, ДанныеДляПечати, ОбъектыПечати, ПараметрыПечати, КомплектыПечати = Неопределено)
	Просмотр = Неопределено;
	ПараметрыПечати.Свойство("Просмотр", Просмотр);
	
	Если Пользователи.РолиДоступны("_КладовщикСклада") Тогда
		Просмотр = Истина;
	КонецЕсли;

	ВыбПоШапке = ДанныеДляПечати.РезультатПоШапке.Выбрать();
	ВыбПоШапке.Следующий();

	ВыбПоНомерам = ДанныеДляПечати.РезультатПоНомерамУПД.Выбрать();
	ВыбПоТоварам = ДанныеДляПечати.РезультатПоТабличнойЧасти;

	Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.AMS_Продажи.СкладскаяНакладная");

	НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

	ВывестиШапкуСН(ВыбПоШапке, ВыбПоНомерам, Макет, ТабличныйДокумент, Просмотр);

	НомерСтраницы = 1;
	НомерСтроки = 0;
	ИтогоКоличествоУпаковок = 0;
	ИтогоКоличествоПалет = 0;
		
	// Создаем массив для проверки вывода
	МассивВыводимыхОбластей = Новый Массив;
		
	// Выводим многострочную часть документа
	ОбластьЗаголовокТаблицы = Макет.ПолучитьОбласть("ЗаголовокТаб");
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка");

	ВыводШапки = 0;

	Стр = ВыбПоТоварам.Выбрать();
	КоличествоСтрок = Стр.Количество();
	Пока Стр.Следующий() Цикл
		НомерСтроки = НомерСтроки + 1;

		ИтогоКоличествоУпаковок = ИтогоКоличествоУпаковок + Стр.КоличествоУпаковок;
		ИтогоКоличествоПалет = ИтогоКоличествоПалет + Стр.КоличествоПалет;

		ОбластьСтрока.Параметры.Заполнить(Стр);
		ОбластьСтрока.Параметры.НомерСтроки = НомерСтроки;

		Если НомерСтроки = 0 И ВыводШапки <> 2 Тогда
			ВыводШапки = 1;
		КонецЕсли;

		Если (НомерСтроки = 1 И ВыводШапки = 0) Или (НомерСтроки = 0 И ВыводШапки = 1) Тогда
			ВыводШапки = 2;
			ОбластьЗаголовокТаблицы.Параметры.НомерСтраницы = "Страница " + НомерСтраницы;
			ТабличныйДокумент.Вывести(ОбластьЗаголовокТаблицы);
		КонецЕсли;

		МассивВыводимыхОбластей.Очистить();
		МассивВыводимыхОбластей.Добавить(ОбластьСтрока);
		Если НомерСтроки = КоличествоСтрок Тогда
			ОбластьПодвал = ЗаполнитьПодвалСН(ВыбПоШапке, ИтогоКоличествоУпаковок, ИтогоКоличествоПалет, КоличествоСтрок, Макет);
			МассивВыводимыхОбластей.Добавить(ОбластьПодвал);
		КонецЕсли;

		Если Не ТабличныйДокумент.ПроверитьВывод(МассивВыводимыхОбластей) Тогда
			НомерСтраницы = НомерСтраницы + 1;
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();

			ОбластьЗаголовокТаблицы.Параметры.НомерСтраницы = "Страница " + НомерСтраницы;
			ТабличныйДокумент.Вывести(ОбластьЗаголовокТаблицы);
		КонецЕсли;

		ТабличныйДокумент.Вывести(ОбластьСтрока);
	КонецЦикла;
		
	// Выводим подвал документа
	ОбластьПодвала = ЗаполнитьПодвалСН(ВыбПоШапке, ИтогоКоличествоУпаковок, ИтогоКоличествоПалет, КоличествоСтрок, Макет);
	ТабличныйДокумент.Вывести(ОбластьПодвала);

	Если Не ПустаяСтрока(ВыбПоШапке.УсловияОтгрузки) Тогда
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		ОбластьУсловия = Макет.ПолучитьОбласть("УсловияОтгрузки");
		ОбластьУсловия.Параметры.УсловияОтгрузки = ВыбПоШапке.УсловияОтгрузки;
		ТабличныйДокумент.Вывести(ОбластьУсловия);
	КонецЕсли;
	
	УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыбПоШапке.Ссылка);
КонецПроцедуры

Процедура ВывестиШапкуСН(ВыбПоШапке, ВыбПоНомерам, Макет, ТабличныйДокумент, Просмотр)
	Распоряжение = "УПД: ";
	Пока ВыбПоНомерам.Следующий() Цикл
		Распоряжение = Распоряжение + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ВыбПоНомерам.Номер) + " от "
			+ Формат(ВыбПоНомерам.Дата, "ДЛФ=Д") + ", ";
	КонецЦикла;
	Распоряжение = Лев(Распоряжение, СтрДлина(Распоряжение) - 2);

	ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
	Парам = ОбластьМакета.Параметры;
	Парам.Документ = "Складская накладная № " + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ВыбПоШапке.Номер)
		+ " от " + Формат(ВыбПоШапке.Дата, "ДЛФ=ДД");
	Парам.Распоряжение = Распоряжение;

	Парам.Организация  = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
		ВыбПоШапке.Организация, ВыбПоШапке.Дата), "ПолноеНаименование, ИНН, КПП");

	Парам.Организация = СтрЗаменить(Парам.Организация, "774301001", "505045001");
	
	ТабличныйДокумент.Вывести(ОбластьМакета);

	ОбластьМакета = Макет.ПолучитьОбласть("Клиент");
	Парам = ОбластьМакета.Параметры;
	Парам.Клиент = ВыбПоШапке.КлиентНаименование;
	Парам.Покупатель = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
		ВыбПоШапке.Покупатель, ВыбПоШапке.Дата), "ПолноеНаименование, ИНН, КПП");
	Если Не ЗначениеЗаполнено(ВыбПоШапке.Грузополучатель) Или ВыбПоШапке.Грузополучатель = ВыбПоШапке.Покупатель Тогда
		Парам.Грузополучатель = "он же";
	Иначе
		Парам.Грузополучатель = ФормированиеПечатныхФорм.ОписаниеОрганизации(
			ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыбПоШапке.Грузополучатель, ВыбПоШапке.Дата),
			"ПолноеНаименование, ИНН, КПП");
	КонецЕсли;
	ТабличныйДокумент.Вывести(ОбластьМакета);

	СпособДоставки = ВыбПоШапке.СпособДоставки;

	Если СпособДоставки = Перечисления.СпособыДоставки.Самовывоз Тогда
		Способ = "Самовывоз (с нашего склада)";
	ИначеЕсли СпособДоставки = Перечисления.СпособыДоставки.ДоКлиента Тогда
		Способ = "Наша транспортная служба до клиента";
	ИначеЕсли СпособДоставки = Перечисления.СпособыДоставки.СиламиПеревозчикаПоАдресу Тогда
		Способ = "Наша транспортная служба до перевозчика";
	ИначеЕсли СпособДоставки = Перечисления.СпособыДоставки.КПолучателюОпределяетСлужбаДоставки Тогда
		Способ = "Наша транспортная служба до пункта перегрузки";
	КонецЕсли;

	Если СпособДоставки = Перечисления.СпособыДоставки.Самовывоз Тогда
		ОбластьМакета  = Макет.ПолучитьОбласть("СпособДоставки1");
		ОбластьМакета.Параметры.СпособДоставки = Способ;
	Иначе
		ОбластьМакета  = Макет.ПолучитьОбласть("СпособДоставки2");

		Час = Час(ВыбПоШапке.ВремяДоставкиС);
		Мин = Минута(ВыбПоШапке.ВремяДоставкиС);
		Если Час < 10 Тогда
			Час = "0" + Строка(Час);
		Иначе
			Час = Строка(Час);
		КонецЕсли;
		Если Мин < 10 Тогда
			Мин = "0" + Строка(Мин);
		Иначе
			Мин = Строка(Мин);
		КонецЕсли;
		ВремяС = Час + ":" + Мин;

		Час = Час(ВыбПоШапке.ВремяДоставкиПо);
		Мин = Минута(ВыбПоШапке.ВремяДоставкиПо);
		Если Час < 10 Тогда
			Час = "0" + Строка(Час);
		Иначе
			Час = Строка(Час);
		КонецЕсли;
		Если Мин < 10 Тогда
			Мин = "0" + Строка(Мин);
		Иначе
			Мин = Строка(Мин);
		КонецЕсли;
		ВремяПо = Час + ":" + Мин;

		Парам = ОбластьМакета.Параметры;
		Парам.СпособДоставки = Способ;
		Парам.ВремяДоставки = "Время доставки с " + ВремяС + " по " + ВремяПо;
	КонецЕсли;
	ТабличныйДокумент.Вывести(ОбластьМакета);

	Если СпособДоставки = Перечисления.СпособыДоставки.СиламиПеревозчикаПоАдресу Тогда
		ОбластьМакета = Макет.ПолучитьОбласть("Перевозчик");
		Парам = ОбластьМакета.Параметры;
		Парам.Перевозчик = ВыбПоШапке.ПеревозчикНаименование;
		Парам.АдресДоставкиПеревозчика = ВыбПоШапке.АдресДоставкиПеревозчика;
		ТабличныйДокумент.Вывести(ОбластьМакета);
	КонецЕсли;

	ОбластьМакета = Макет.ПолучитьОбласть("АдресДоставки");
	Парам = ОбластьМакета.Параметры;
	Парам.АдресДоставки = ВыбПоШапке.АдресДоставки;
	Если Не ПустаяСтрока(ВыбПоШапке.ТелефонВодителяКлиента) Тогда
		Парам.АдресДоставки = Парам.АдресДоставки + ", тел. " + СокрЛП(ВыбПоШапке.ТелефонВодителяКлиента);
	КонецЕсли;
	ТабличныйДокумент.Вывести(ОбластьМакета);

	ОбластьМакета = Макет.ПолучитьОбласть("Условия");
	Парам = ОбластьМакета.Параметры;
	Парам.УсловияОтгрузки = ВыбПоШапке.УсловияОтгрузки;
	Парам.ДопИнфо         = ВыбПоШапке.ДополнительнаяИнформацияПоДоставке;
	Парам.СпособПередачи  = ?(ВыбПоШапке.СпособПередачиТоваров = 0, "Палетами. ", "Коробками (канистрами). ")
							+ ?(ВыбПоШапке.Обрешетка, "В обрешетке.", "Без обрешетки.");
	Парам.Комментарий     = ВыбПоШапке.Комментарий;
	ТабличныйДокумент.Вывести(ОбластьМакета);

	Если Не Просмотр = Неопределено Тогда
		ОбластьМакета = Макет.ПолучитьОбласть("Просмотр");
		ТабличныйДокумент.Вывести(ОбластьМакета);
	КонецЕсли;
КонецПроцедуры

Функция ЗаполнитьПодвалСН(ВыбПоШапке, ИтогоКоличествоУпаковок, ИтогоКоличествоПалет, КоличествоСтрок, Макет)
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	ОбластьПодвал.Параметры.Заполнить(ВыбПоШапке);

	ИтоговаяСтрока = НСтр("ru='Всего наименований %КоличествоНаименований%, на сумму %СуммаДокумента% руб.'");
	ИтоговаяСтрока = СтрЗаменить(ИтоговаяСтрока, "%КоличествоНаименований%", ЧислоПрописью(КоличествоСтрок, ,
		",,,,,,,,0"));
	ИтоговаяСтрока = СтрЗаменить(ИтоговаяСтрока, "%СуммаДокумента%", ВыбПоШапке.ИтогоСумма);

	ОбластьПодвал.Параметры.ИтогоКоличествоУпаковок = ИтогоКоличествоУпаковок;
	ОбластьПодвал.Параметры.ИтогоКоличествоПалет = ИтогоКоличествоПалет;
	ОбластьПодвал.Параметры.ИтоговаяСтрока = ИтоговаяСтрока + ", НДС в том числе";
	ОбластьПодвал.Параметры.СуммаПрописью = РаботаСКурсамиВалют.СформироватьСуммуПрописью(ВыбПоШапке.ИтогоСумма,
		Константы.ВалютаРегламентированногоУчета.Получить());

	Возврат ОбластьПодвал;
КонецФункции

#КонецОбласти

#Область Печать_УпаковочныйЛист

Функция СформироватьПечатнуюФормуУпаковочныйЛист(МассивОбъектов, ОбъектыПечати, ПараметрыПечати, КомплектыПечати = Неопределено) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ПолеСлева = 5;
	ТабличныйДокумент.ПолеСправа = 5;
	ТабличныйДокумент.РазмерКолонтитулаСверху = 0;
	ТабличныйДокумент.РазмерКолонтитулаСнизу = 0;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;

	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_УЛ";

	ЗаполнитьТабДокУпаковочныйЛист(ТабличныйДокумент, МассивОбъектов, ОбъектыПечати, ПараметрыПечати, КомплектыПечати);

	Возврат ТабличныйДокумент;
КонецФункции

Процедура ЗаполнитьТабДокУпаковочныйЛист(ТабличныйДокумент, МассивОбъектов, ОбъектыПечати, ПараметрыПечати, КомплектыПечати = Неопределено)
	Реализация = МассивОбъектов[0];
	
	Если ТипЗнч(Реализация) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда 
		Реал = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Реализация,
			"Номер, Дата, Организация, Договор, Валюта, Контрагент, Грузополучатель, AMS_КоличествоПалет, Ссылка");
	Иначе
		Возврат;
	КонецЕсли;		

	Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.AMS_Продажи.УпаковочныйЛист");

	ОбластьШапка    = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапкаТаб = Макет.ПолучитьОбласть("ЗаголовокТаб");
	ОбластьСтрока   = Макет.ПолучитьОбласть("Строка"); 
	ОбластьТНВЭД    = Макет.ПолучитьОбласть("СтрокаТНВЭД"); 
	ОбластьПодвал   = Макет.ПолучитьОбласть("Подвал");

	
	Парам = ОбластьШапка.Параметры;
	
	Парам.Документ          = "Упаковочный лист № " + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Реал.Номер) 
								+ " от " + Формат(Реал.Дата, "ДЛФ=ДД") + " к " + Реал.Договор;
	Парам.Организация       = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								Реал.Организация, Реал.Дата), "ПолноеНаименование");
	Парам.ОрганизацияАдрес  = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								Реал.Организация, Реал.Дата), "ЮридическийАдрес");
	Парам.ОрганизацияИНН    = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								Реал.Организация, Реал.Дата), "ИНН");
	Парам.Покупатель        = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								Реал.Контрагент, Реал.Дата), "ПолноеНаименование");
	Парам.ПокупательАдрес   = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								Реал.Контрагент, Реал.Дата), "ЮридическийАдрес");
	Парам.ПокупательИНН     = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								Реал.Контрагент, Реал.Дата), "ИНН");

	Если Не ЗначениеЗаполнено(Реал.Грузополучатель) Или Реал.Грузополучатель = Реал.Контрагент Тогда
		Парам.Грузополучатель = "он же";
	Иначе
		Парам.Грузополучатель = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								Реал.Грузополучатель, Реал.Дата), "ПолноеНаименование");
	КонецЕсли;

	ТабличныйДокумент.Вывести(ОбластьШапка);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Реализация", Реализация);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	СУММА(т.Количество) КАК Количество,
	|	МАКСИМУМ(т.Цена) КАК Цена
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Реализация
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ном.КодТНВЭД КАК КодТНВЭД,
	|	Ном.Артикул КАК Артикул,
	|	Ном.НаименованиеПолное КАК Номенклатура,
	|	Ном.ЕдиницаИзмерения КАК Ед,
	|	Ном.КоэффициентЕдиницыДляОтчетов КАК Кфц,
	|	Товары.Количество КАК Количество,
	|	Товары.Количество / Ном.КоэффициентЕдиницыДляОтчетов КАК КоличествоУпаковок,
	|	Товары.Цена / Ном.КоэффициентЕдиницыДляОтчетов КАК Цена,
	|	Товары.Цена * Товары.Количество / Ном.КоэффициентЕдиницыДляОтчетов КАК Сумма,
	|	Ном.ВесЧислитель * Товары.Количество КАК ВесНетто,
	|	Ном._Упаковка.Вес * Товары.Количество / Ном.КоэффициентЕдиницыДляОтчетов КАК ВесБрутто,
	|	Ном.СтранаПроисхождения КАК СтранаПроисхождения,
	|	Ном.Производитель КАК Производитель,
	|	ВЫБОР
	|		КОГДА Штрихкоды.Штрихкод ЕСТЬ NULL
	|			ТОГДА ШтрихкодыКанистр.Штрихкод
	|		ИНАЧЕ Штрихкоды.Штрихкод
	|	КОНЕЦ КАК Штрихкод
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
	|			ПО Ном.Ссылка = Штрихкоды.Номенклатура
	|				И (Штрихкоды.Упаковка.Числитель = 1)
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений._ШтрихкодыКанистр КАК ШтрихкодыКанистр
	|			ПО Ном.Ссылка = ШтрихкодыКанистр.Номенклатура
	|		ПО Товары.Номенклатура = Ном.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	КодТНВЭД,
	|	Ном.Наименование";
	
	Табл = Запрос.Выполнить().Выгрузить();
	
	КоличествоСтрок = Табл.Количество();
	
	ВыводШапки    = 0;
	НомерСтроки   = 0;
	НомСтр        = 0;
	
	Количество  = 0;
	КолУпаковок = 0;
	Сумма       = 0;
	ВесНетто    = 0;
	ВесБрутто   = 0;

	ИтогоКоличество  = 0;
	ИтогоКолУпаковок = 0;
	ИтогоСумма       = 0;
	ИтогоВесНетто    = 0;
	ИтогоВесБрутто   = 0;

	НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1; 
	
	МассивВыводимыхОбластей = Новый Массив; // Создаем массив для проверки вывода

	ВыводШапки = 0;
	
	Для каждого Стр Из Табл Цикл
		НомерСтроки = НомерСтроки + 1;
		НомСтр      = НомСтр + 1;
		
		Если НомерСтроки = 1 Тогда
			КодТНВЭД = Стр.КодТНВЭД;
		КонецЕсли;

		Если Не КодТНВЭД = Стр.КодТНВЭД Тогда 
			ОбластьТНВЭД.Параметры.Количество         = Количество;
			ОбластьТНВЭД.Параметры.КоличествоУпаковок = КолУпаковок;
			ОбластьТНВЭД.Параметры.Сумма              = Сумма;
			ОбластьТНВЭД.Параметры.ВесНетто           = ВесНетто;
			ОбластьТНВЭД.Параметры.ВесБрутто          = ВесБрутто;
			
			МассивВыводимыхОбластей.Добавить(ОбластьТНВЭД);
			
			ТабличныйДокумент.Вывести(ОбластьТНВЭД); 

			Количество  = 0;
			КолУпаковок = 0;
			Сумма       = 0;
			ВесНетто    = 0;
			ВесБрутто   = 0;
		КонецЕсли;
		
		Количество  = Количество  + Стр.Количество;
		КолУпаковок = КолУпаковок + Стр.КоличествоУпаковок;
		Сумма       = Сумма       + Стр.Сумма;
		ВесНетто    = ВесНетто    + Стр.ВесНетто;
		ВесБрутто   = ВесБрутто   + Стр.ВесБрутто;
			
		ИтогоКоличество  = ИтогоКоличество  + Стр.Количество;
		ИтогоКолУпаковок = ИтогоКолУпаковок + Стр.КоличествоУпаковок;
		ИтогоСумма       = ИтогоСумма       + Стр.Сумма;
		ИтогоВесНетто    = ИтогоВесНетто    + Стр.ВесНетто;
		ИтогоВесБрутто   = ИтогоВесБрутто   + Стр.ВесБрутто; 
		
		ОбластьСтрока.Параметры.Заполнить(Стр);
		ОбластьСтрока.Параметры.НомСтр = НомСтр;

		Если НомерСтроки = 0 И ВыводШапки <> 2 Тогда
			ВыводШапки = 1;
		КонецЕсли;

		Если (НомерСтроки = 1 И ВыводШапки = 0) Или (НомерСтроки = 0 И ВыводШапки = 1) Тогда
			ВыводШапки = 2;
			ТабличныйДокумент.Вывести(ОбластьШапкаТаб);
		КонецЕсли;

		МассивВыводимыхОбластей.Очистить();
		
		МассивВыводимыхОбластей.Добавить(ОбластьСтрока);
		
		Если НомерСтроки = КоличествоСтрок Тогда
			ОбластьТНВЭД.Параметры.Количество         = Количество;
			ОбластьТНВЭД.Параметры.КоличествоУпаковок = КолУпаковок;
			ОбластьТНВЭД.Параметры.Сумма              = Сумма;
			ОбластьТНВЭД.Параметры.ВесНетто           = ВесНетто;
			ОбластьТНВЭД.Параметры.ВесБрутто          = ВесБрутто;
			
			МассивВыводимыхОбластей.Добавить(ОбластьТНВЭД);
			
			ОбластьПодвал.Параметры.Количество         = ИтогоКоличество;
			ОбластьПодвал.Параметры.КоличествоУпаковок = ИтогоКолУпаковок;
			ОбластьПодвал.Параметры.Сумма              = ИтогоСумма;
			ОбластьПодвал.Параметры.ВесНетто           = ИтогоВесНетто;
			ОбластьПодвал.Параметры.ВесБрутто          = ИтогоВесБрутто;
			
			ОбластьПодвал.Параметры.Мест = "Количество мест " + ИтогоКолУпаковок + "шт."; 
			ОбластьПодвал.Параметры.Вес  = "Вес НЕТТО: " + ИтогоВесНетто + " кг.,      Вес БРУТТО: " 
														+ ИтогоВесБрутто + " кг."; 
			ОбластьПодвал.Параметры.СуммаПрописью = "Всего отгружено на сумму: " 
											+ РаботаСКурсамиВалют.СформироватьСуммуПрописью(ИтогоСумма, Реал.Валюта); 
			ОбластьПодвал.Параметры.Упаковано = "Упаковано на  " + Реал.AMS_КоличествоПалет + " палетах"; 

			МассивВыводимыхОбластей.Добавить(ОбластьПодвал);
		КонецЕсли;

		Если Не ТабличныйДокумент.ПроверитьВывод(МассивВыводимыхОбластей) Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ТабличныйДокумент.Вывести(ОбластьШапкаТаб);
		КонецЕсли;

		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		КодТНВЭД = Стр.КодТНВЭД;
	КонецЦикла;
		
	Если НомерСтроки = КоличествоСтрок Тогда 
		ТабличныйДокумент.Вывести(ОбластьТНВЭД);
	КонецЕсли;
	
	ТабличныйДокумент.Вывести(ОбластьПодвал);

	УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, Реал.Ссылка);
КонецПроцедуры

#КонецОбласти

#Область Печать_Доверенность

Функция СформироватьПечатнуюФормуДоверенность(МассивОбъектов, ОбъектыПечати) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	Док = МассивОбъектов[0];

	ДанныеПечати = ПолучитьДанныеДляПечатнойФормыДоверенность(Док);

	ТабличныйДокумент = Новый ТабличныйДокумент;

	ПервыйДокумент = Истина;

	Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.AMS_Продажи.Доверенность");

	Пока ДанныеПечати.Следующий() Цикл

		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;

		ПервыйДокумент = Ложь;

		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;

		НомерДокументаНаПечать        = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ДанныеПечати.Номер, Ложь, Истина);

		СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
			ДанныеПечати.Организация, ДанныеПечати.ДатаДокумента, , ДанныеПечати.БанковскийСчет);
		НазваниеФормы = НСтр("ru='Типовая межотраслевая форма № М-2а'");
		КодПоОКУД = "0315002";
		
		// Заполнить реквизиты шапки
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");

		СтруктураДанныхШапка = Новый Структура;
		ОбластьМакета.Параметры.Заполнить(ДанныеПечати);
		СтруктураДанныхШапка.Вставить("НомерДокумента", НомерДокументаНаПечать);
		СтруктураДанныхШапка.Вставить("НазваниеФормы", НазваниеФормы);
		СтруктураДанныхШапка.Вставить("ДатаДокумента", Формат(ДанныеПечати.ДатаДокумента,
			"ДФ = ""дд ММММ гггг """"г."""));
		СтруктураДанныхШапка.Вставить("СрокДействия", Формат(ДанныеПечати.СрокДействия, "ДФ = ""дд ММММ гггг """"г."""));

		ПредставлениеОрганизации = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации,
			"ПолноеНаименование,ЮридическийАдрес");
		СтруктураДанныхШапка.Вставить("ОрганизацияПредставление", ПредставлениеОрганизации);

		РеквизитыПотребителя = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации,
			"ПолноеНаименование,ЮридическийАдрес,Телефоны");
		СтруктураДанныхШапка.Вставить("РеквизитыПотребителя", РеквизитыПотребителя);

		РеквизитыПлательщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации,
			"ПолноеНаименование,ИНН,КПП,ЮридическийАдрес");
		СтруктураДанныхШапка.Вставить("РеквизитыПлательщика", РеквизитыПлательщика);

		СтруктураДанныхШапка.Вставить("ОрганизацияКодПоОКПО", СведенияОбОрганизации.КодПоОКПО);
		СтруктураДанныхШапка.Вставить("КодПоОКУД", КодПоОКУД);

		СтруктураДанныхШапка.Вставить("РеквизитыСчета", ФормированиеПечатныхФорм.ОписаниеОрганизации(
			СведенияОбОрганизации, "НомерСчета,Банк,БИК,КоррСчет,"));
			
		//СтруктураДанныхШапка.Вставить("ДолжностьДоверенного",);
		ФамилияИмяОтчествоДоверенного = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(
			ДанныеПечати.ФамилияИмяОтчествоДоверенного, ДанныеПечати.ДатаДокумента);
		СтруктураДанныхШапка.Вставить("ФамилияИмяОтчествоДоверенного", ФамилияИмяОтчествоДоверенного);
		СтруктураДанныхШапка.Вставить("ПаспортСерия", ДанныеПечати.ПаспортСерия);
		СтруктураДанныхШапка.Вставить("ПаспортНомер", ДанныеПечати.ПаспортНомер);
		СтруктураДанныхШапка.Вставить("ПаспортВыдан", ДанныеПечати.ПаспортВыдан);
		СтруктураДанныхШапка.Вставить("ПаспортДатаВыдачи", ДанныеПечати.ПаспортДатаВыдачи);

		СтруктураДанныхШапка.Вставить("РеквизитыДокументаНаПолучение", "Товарная накладная " + НомерДокументаНаПечать
			+ " от " + Формат(ДанныеПечати.ДатаОснования, "ДФ = ""дд ММ гггг """"г."""));

		ОбластьМакета.Параметры.Заполнить(СтруктураДанныхШапка);
		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, ОбластьМакета,
			ДанныеПечати.Ссылка);
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		// Заполнить таблицу
		ОбластьМакета = Макет.ПолучитьОбласть("ЗаголовокТаблицы");
		ТабличныйДокумент.Вывести(ОбластьМакета);

		ОбластьМакета = Макет.ПолучитьОбласть("СтрокаТаблицы");
		ОбластьМакета.Параметры.КоличествоМест = ЧислоПрописью(Док.Товары.Итог("КоличествоУпаковок"), , ",,,,,,,,0");
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		// Заполнить реквизиты подвала
		ОбластьМакета = Макет.ПолучитьОбласть("Подвал");

		СтруктураДанныхПодвал = Новый Структура;
		ОтветственноеЛицо = мср.ПолучитьОтветственноеЛицо(ДанныеПечати.Организация);
		Если ОтветственноеЛицо = Неопределено Тогда
			СтруктураДанныхПодвал.Вставить("ФИОРуководителя", ДанныеПечати.Руководитель);
			СтруктураДанныхПодвал.Вставить("ФИОГлавногоБухгалтера", ДанныеПечати.ГлавныйБухгалтер);
		Иначе
			СтруктураДанныхПодвал.Вставить("ФИОРуководителя", ОтветственноеЛицо);
			СтруктураДанныхПодвал.Вставить("ФИОГлавногоБухгалтера", ОтветственноеЛицо);
		КонецЕсли;
		ОбластьМакета.Параметры.Заполнить(СтруктураДанныхПодвал);
		ТабличныйДокумент.Вывести(ОбластьМакета);

		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати,
			ДанныеПечати.Ссылка);
	КонецЦикла;

	ТабличныйДокумент.АвтоМасштаб = Истина;

	Возврат ТабличныйДокумент;
КонецФункции

Функция ПолучитьДанныеДляПечатнойФормыДоверенность(Док)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Док", Док);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка КАК Ссылка,
	|	РеализацияТоваровУслуг.БанковскийСчетОрганизации КАК БанковскийСчет,
	|	ПРЕДСТАВЛЕНИЕ(РеализацияТоваровУслуг.Валюта) КАК ВалютаПредставление,
	|	РеализацияТоваровУслуг.Дата КАК ДатаДокумента,
	|	РеализацияТоваровУслуг.Дата КАК ДатаОснования,
	|	Организации._Руководитель КАК Руководитель,
	|	Организации._ГлавныйБухгалтер КАК ГлавныйБухгалтер,
	|	РеализацияТоваровУслуг.Номер КАК Номер,
	|	РеализацияТоваровУслуг.Организация КАК Организация,
	|	ДОБАВИТЬКДАТЕ(РеализацияТоваровУслуг.Дата, ДЕНЬ, 10) КАК СрокДействия,
	|	РеализацияТоваровУслуг.СуммаДокумента КАК СуммаДокумента,
	|	Рейсы.Водитель КАК ФамилияИмяОтчествоДоверенного,
	|	ДокФизЛиц.Серия КАК ПаспортСерия,
	|	ДокФизЛиц.Номер КАК ПаспортНомер,
	|	ДокФизЛиц.ДатаВыдачи КАК ПаспортДатаВыдачи,
	|	ДокФизЛиц.КемВыдан КАК ПаспортВыдан
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО РеализацияТоваровУслуг.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист.Распоряжения КАК Распоряжения
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист.Рейсы КАК Рейсы
	|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц КАК ДокФизЛиц
	|				ПО Рейсы.Водитель = ДокФизЛиц.Физлицо
	|				И (ДокФизЛиц.ЯвляетсяДокументомУдостоверяющимЛичность)
	|			ПО Распоряжения.Ссылка = Рейсы.Ссылка
	|			И Распоряжения.ТранспортноеСредство = Рейсы.ТранспортноеСредство
	|		ПО РеализацияТоваровУслуг.Ссылка = Распоряжения.Распоряжение
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка = &Док";

	Возврат Запрос.Выполнить().Выбрать();
КонецФункции

#КонецОбласти

#Область Печать_ТранспортнаяНакладная

Функция СформироватьПечатнуюФормуТранспортнаяНакладная(МассивОбъектов, ПараметрыПечати) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	ТранспортноеСредство = ПараметрыПечати.ТранспортноеСредство;
	Распоряжение         = ПараметрыПечати.Распоряжение;
	Образец              = ПараметрыПечати.Образец;

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб         = Истина;
	ТабДок.ОриентацияСтраницы  = ОриентацияСтраницы.Портрет;
	ТабДок.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ТРАНСПОРТНАЯ_НАКЛАДНАЯ";

	Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.AMS_Продажи.ТранспортнаяНакладная");
	Шапка1    = Макет.ПолучитьОбласть("Шапка1");
	Шапка2    = Макет.ПолучитьОбласть("Шапка2");
	ОбластьТН = Макет.ПолучитьОбласть("ТН");
	Подвал    = Макет.ПолучитьОбласть("Подвал");

	Док = МассивОбъектов[0];

	Отказ = Ложь;

	Данные = ПолучитьДанныеЛогЛиста(Док, Распоряжение, Отказ);
	
	Если Отказ Тогда
		Возврат ТабДок;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ТранспортноеСредство) Тогда
		ТранспортноеСредство = Данные.ТранспортноеСредство;
	КонецЕсли;

	СКД = ПолучитьМакет("скдТН");

	Настройки    = СКД.НастройкиПоУмолчанию;

	ПараметрыСКД = Новый Структура;
	ПараметрыСКД.Вставить("ЛогистическийЛист", Данные.ЛогистическийЛист);

	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Настройки.Отбор, "ТранспортноеСредство", ТранспортноеСредство,
		ВидСравненияКомпоновкиДанных.Равно, , ЗначениеЗаполнено(ТранспортноеСредство));

	Таб = Новый ДеревоЗначений;

	мср.ПолучитьДанныеНаОснованииСКД(СКД, Таб, Настройки, ПараметрыСКД);

	Для Каждого Авто Из Таб.Строки Цикл
		ВесОбщий = Авто.Вес;

		Для Каждого Стр Из Авто.Строки Цикл
			НомерЗаказа      = "";
			ЕстьРаспоряжение = Ложь;
			
			Для Каждого Стр1 Из Стр.Строки Цикл
				Если ЗначениеЗаполнено(Распоряжение) И Распоряжение = Стр1.Распоряжение Тогда
					ЕстьРаспоряжение = Истина;
				КонецЕсли;
				
				//@skip-check bsl-legacy-check-string-literal
				ОрганизацияРеализации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр1.Распоряжение, "Организация");
				
				//@skip-check query-in-loop
				НомерДата = ПолучитьНомерДатуДокумента(Стр1.Распоряжение);
				
				Если Не НомерДата = Неопределено Тогда
					НомерЗаказа = НомерЗаказа + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(НомерДата.Номер) 
									+ " от " + Формат(НомерДата.Дата, "ДФ=""дд'.'ММ'.'гг""") + ", ";
				КонецЕсли;
			КонецЦикла;
			НомерЗаказа = Лев(НомерЗаказа, СтрДлина(НомерЗаказа) - 2);

			ДолжностьКладовщика = ОрганизацияРеализации._ДолжностьКладовщика;
			Кладовщик           = ОрганизацияРеализации._Кладовщик;
			СведенияОрганизация      = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Данные.Организация, Данные.Дата);
			СведенияГрузоотправитель = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Стр.Грузоотправитель, Данные.Дата,
				Ложь);
			СведенияГрузополучатель  = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Стр.Грузополучатель, Данные.Дата,
				Ложь);
			СведенияОПеревозчике     = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Стр.ПеревозчикКонтрагент,
				Данные.Дата, Ложь);

			ПервыйДокумент = Истина;

			НомерСтрокиНачало = ТабДок.ВысотаТаблицы + 1;

			ПечататьНомерЗаказа = (СтрНайти(Стр.ПартнерНаименование, "Перекресток") > 0 Или СтрНайти(Стр.ПартнерНаименование, "Тандер") > 0);

			Если Не ПервыйДокумент Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;

			ПервыйДокумент = Ложь;

			Если ПечататьНомерЗаказа Тогда
				Шапка2.Параметры.НомерЗаказа = "Номер заказа " + СокрП(Сред(Стр.Основание, 7, СтрДлина(Стр.Основание) - 6));
				Шапка2.Параметры.НомерУПД    = "Номер УПД " + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Стр.Номер);
			КонецЕсли;

			ОбластьТН.Параметры.ДатаТН      = Формат(Данные.Дата, "ДЛФ=ДД");
			ОбластьТН.Параметры.НомерТН     = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Данные.Номер) + "/"
				+ Стр.НомерРейса + "/" + Стр.ПорядокВМаршруте;
			ОбластьТН.Параметры.НомерЗаказа = НомерЗаказа;

			Если Стр.ВидДок = "Реализация" Тогда
				ОбластьТН.Параметры.Организация = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияГрузоотправитель,
					"ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны");
			Иначе
				ОбластьТН.Параметры.Организация = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОрганизация,
					"ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны");
			КонецЕсли;

			ОбластьТН.Параметры.Грузополучатель   = ФормированиеПечатныхФорм.ОписаниеОрганизации(
				СведенияГрузополучатель, "ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны");
			ОбластьТН.Параметры.МестоВыгрузки     = Стр.МестоВыгрузки;
			ОбластьТН.Параметры.НаименованиеГруза = Стр.НаименованиеГруза;

			КоличествоМест = Стр.КоличествоПалетДок;
			КоличествоМест = Стр.КоличествоУпаковокДок;

			КолМест = Строка(Окр(КоличествоМест)) + " (" + СокрЛП(ЧислоПрописью(КоличествоМест, , ",,,,,,,,0")) + ")";
			Если КоличествоМест = 1 Тогда
				ГрузМест = " грузовое место";
			ИначеЕсли КоличествоМест = 2 Или КоличествоМест = 3 Или КоличествоМест = 4 Тогда
				ГрузМест = " грузовых места";
			Иначе
				ГрузМест = " грузовых мест";
			КонецЕсли;

			ОбластьТН.Параметры.КоличествоМест = ?(КоличествоМест = 0, "", КолМест + ГрузМест);
			ОбластьТН.Параметры.ВесОбъем       = "Масса (брутто) " + Строка(Стр.Вес) + " (" + СокрЛП(ЧислоПрописью(
				Стр.Вес, , ",,,,,,,,0")) + ") кг, " + "объём " + Строка(Окр(Стр.Объем, 3)) + " куб. м.";
			ОбластьТН.Параметры.СтоимостьГруза = Строка(Стр.СуммаДокумента) + ?(Стр.СуммаДокумента = 0, "", " руб.");

			Если Стр.ВидДок = "ВПереработку" Тогда
				ВидДок = "М-15";
			ИначеЕсли Стр.ВидДок = "Реализация" Тогда
				ВидДок = ?(Данные.Организация = AMS_ВызовСервера.ОрганизацияТрейд(), "ТОРГ-12", "УПД");
			Иначе
				ВидДок = "УПД";
			КонецЕсли;

			ОбластьТН.Параметры.ПереченьДокументов = ВидДок + " " + НомерЗаказа;
			ОбластьТН.Параметры.Сертификаты        = "Санитарно-эпидемиологические заключения и сертификаты соответсвия";
			ОбластьТН.Параметры.МестоВыгрузки      = Стр.МестоВыгрузки + ". " + Формат(Данные.Дата, "ДЛФ=Д") + " "
				+ Формат(Стр.ВремяВыгрузки, "ДФ=ЧЧ:мм");
			ОбластьТН.Параметры.Начальник          = "Шаров Виталий Владимирович, тел. 8 (495) 232-24-01";
			ОбластьТН.Параметры.Перевозчик         = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПеревозчике,
				"ПолноеНаименование,ФактическийАдрес,Телефоны");
			ОбластьТН.Параметры.Водитель           = "" + Стр.Водитель + ", тел: " + Стр.ВодительТелефон;
			ОбластьТН.Параметры.ТипАвто            = Стр.Марка + " грузоподъёмность " + Стр.Грузоподъемность + " т";
			ОбластьТН.Параметры.НомерАвто          = Стр.ТранспортноеСредство;
			ОбластьТН.Параметры.КтоГрузит          = ФормированиеПечатныхФорм.ОписаниеОрганизации(
				СведенияГрузоотправитель, "ПолноеНаименование");
			ОбластьТН.Параметры.ЧьеМестоПогрузки   = ФормированиеПечатныхФорм.ОписаниеОрганизации(
				СведенияГрузоотправитель, "ПолноеНаименование,ИНН");
			ОбластьТН.Параметры.МестоПогрузки      = Стр.МестоПогрузки;

			Если Стр.ВидДок = "ВПереработку" Или Стр.ВидДок = "Реализация" Тогда
				ОбластьТН.Параметры.ВремяЗагрузки = Стр.ВремяЗагрузкиОтНас;
			Иначе
				ОбластьТН.Параметры.ВремяЗагрузки = Стр.ВремяЗагрузкиКНам;
			КонецЕсли;

			ОбластьТН.Параметры.Масса = "Масса (брутто) " + Строка(Стр.Вес) 
				+ " (" + СокрЛП(ЧислоПрописью(Стр.Вес, , ",,,,,,,,0")) + ") кг, (определено взвешиванием)";

			Если Стр.ВидДок = "ЗаказПоставщику" Или Стр.ВидДок = "ЗаявкаНаВозврат" Тогда
				ОбластьТН.Параметры.НачСклада = "";
			Иначе
				Если Стр.ВидДок = "ВПереработку" Тогда
					ОбластьТН.Параметры.НачСклада = "Главный инженер Щукин А.В.";
				Иначе
					ОбластьТН.Параметры.НачСклада = ДолжностьКладовщика + " " + Кладовщик;
				КонецЕсли;
			КонецЕсли;

			ОбластьТН.Параметры.Водитель  = "" + Стр.Водитель;

			Подвал.Параметры.МестоВыгрузки = Стр.МестоВыгрузки;
			Подвал.Параметры.ВремяВыгрузки = Формат(Данные.Дата, "ДЛФ=Д") + " " + Формат(Стр.ВремяВыгрузки, "ДФ=ЧЧ:мм");

			Если Стр.ВидДок = "Реализация" Тогда
				Подвал.Параметры.Упаковка = "Груз упакован в картонные коробки, упаковка не нарушена, маркировка нанесена.";
			Иначе
				Подвал.Параметры.Упаковка = "";
			КонецЕсли;

			Подвал.Параметры.КоличествоМест = КолМест + ГрузМест;
			Подвал.Параметры.Вес            = "" + Окр(Стр.Вес, 3) + " кг (брутто) / " + Окр(?(Стр.ВесНетто = Неопределено, Стр.Вес, Стр.ВесНетто), 3) + " кг (нетто)";
			Подвал.Параметры.Водитель       = "" + Стр.Водитель;

			СтоимостьДоставки = Стр.СтоимостьДоставки - ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.ТранспортноеСредство, "_СтавкаАгента");
			СтоимостьДоставки = СтоимостьДоставки * Стр.Вес / ВесОбщий;

			Если Стр.ЮрФизЛицо = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление.ЮрФизЛицо.ИндивидуальныйПредприниматель") Тогда
				Подвал.Параметры.СуммаБезНДС = Формат(СтоимостьДоставки, "ЧЦ=10; ЧДЦ=2; ЧФ=""Ч руб.""");
				Подвал.Параметры.СтавкаНДС   = "Без НДС";
				Подвал.Параметры.СуммаНДС    = "0,00 руб.";
				Подвал.Параметры.Сумма       = Формат(СтоимостьДоставки, "ЧЦ=10; ЧДЦ=2; ЧФ=""Ч руб.""");
			Иначе
				СуммаНДС    = СтоимостьДоставки * 22 / 100;
				СуммаБезНДС = СтоимостьДоставки - СуммаНДС;

				Подвал.Параметры.СуммаБезНДС = Формат(СуммаБезНДС, "ЧЦ=10; ЧДЦ=2; ЧФ=""Ч руб.""");
				Подвал.Параметры.СтавкаНДС   = "22 %";
				Подвал.Параметры.СуммаНДС    = Формат(СуммаНДС, "ЧЦ=10; ЧДЦ=2; ЧФ=""Ч руб.""");
				Подвал.Параметры.Сумма       = Формат(СтоимостьДоставки, "ЧЦ=10; ЧДЦ=2; ЧФ=""Ч руб.""");
			КонецЕсли;

			Подвал.Параметры.Перевозчик  = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПеревозчике, "ПолноеНаименование,ФактическийАдрес,Телефоны");
			Подвал.Параметры.Организация = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОрганизация, "ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны");
			Подвал.Параметры.Договор     = Стр.Договор;
			Подвал.Параметры.Водитель    = Стр.Водитель;
			Подвал.Параметры.Бухгалтер   = мср.ПолучитьОтветственноеЛицо(Данные.Организация);

			Если ЗначениеЗаполнено(Распоряжение) И Не ЕстьРаспоряжение Тогда
				Продолжить;
			КонецЕсли;

			Если Образец Тогда
				ТабДок.Вывести(Макет.ПолучитьОбласть("Образец"));
				Если ПечататьНомерЗаказа Тогда
					ТабДок.Вывести(Шапка2);
				Иначе
					ТабДок.Вывести(Шапка1);
				КонецЕсли;
				ТабДок.Вывести(ОбластьТН);
				ТабДок.Вывести(Подвал);

			Иначе
				Для индекс = 1 По 3 Цикл
					Если индекс = 1 Тогда
						ОбластьТН.Параметры.Пункт0_1 = "1 (грузоотправителю)";
					ИначеЕсли индекс = 2 Тогда
						ОбластьТН.Параметры.Пункт0_1 = "2 (грузополучателю)";
					ИначеЕсли индекс = 3 Тогда
						ОбластьТН.Параметры.Пункт0_1 = "3 (перевозчику)";
					КонецЕсли;

					Если ПечататьНомерЗаказа Тогда
						ТабДок.Вывести(Шапка2);
					Иначе
						ТабДок.Вывести(Шапка1);
					КонецЕсли;
					ТабДок.Вывести(ОбластьТН);
					ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
					ТабДок.Вывести(Подвал);
					ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЦикла;
			КонецЕсли;

			ОбъектыПечати = Новый СписокЗначений;
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДок, НомерСтрокиНачало, ОбъектыПечати, Стр.Распоряжение);
		КонецЦикла;
	КонецЦикла;

	Возврат ТабДок;
КонецФункции

Функция ПолучитьДанныеЛогЛиста(Док, Распоряжение, Отказ)
	УстановитьПривилегированныйРежим(Истина);

	ТранспортноеСредство = Неопределено;

	Если Не ЗначениеЗаполнено(Распоряжение) Тогда
		ЛогистическийЛист = Док;

	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1 РАЗЛИЧНЫЕ
		|	т.Ссылка КАК ЛогистическийЛист,
		|	т.ТранспортноеСредство
		|ИЗ
		|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
		|ГДЕ
		|	т.Распоряжение = &Док";

		Запрос.УстановитьПараметр("Док", Распоряжение);

		Рез = Запрос.Выполнить();

		Если Рез.Пустой() Тогда
			ОбщегоНазначения.СообщитьПользователю("Для выбранного документа назначен транспорт доставки.", , , , Отказ);
		Иначе
			Выб = Рез.Выбрать();
			Выб.Следующий();

			ЛогистическийЛист    = Выб.ЛогистическийЛист;
			ТранспортноеСредство = Выб.ТранспортноеСредство;
		КонецЕсли;
	КонецЕсли;

	Если Не Отказ Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Лист.Номер КАК Номер,
		|	Лист.Дата КАК Дата,
		|	Лист.Организация КАК Организация,
		|	Орг._Руководитель КАК Руководитель,
		|	Орг._ДолжностьРуководителя КАК ДолжностьРуководителя
		|ИЗ
		|	Документ.AMS_ЛогистическийЛист КАК Лист
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Орг
		|		ПО Лист.Организация = Орг.Ссылка
		|ГДЕ
		|	Лист.Ссылка = &ЛогистическийЛист";

		Запрос.УстановитьПараметр("ЛогистическийЛист", ЛогистическийЛист);

		Рез = Запрос.Выполнить();

		Если Рез.Пустой() Тогда
			Возврат Неопределено;
		Иначе
			Выб = Рез.Выбрать();
			Выб.Следующий();

			Стр = Новый Структура;
			Стр.Вставить("ЛогистическийЛист", ЛогистическийЛист);
			Стр.Вставить("ТранспортноеСредство", ТранспортноеСредство);
			Стр.Вставить("Номер", Выб.Номер);
			Стр.Вставить("Дата", Выб.Дата);
			Стр.Вставить("Организация", Выб.Организация);
			Стр.Вставить("Руководитель", Выб.Руководитель);
			Стр.Вставить("ДолжностьРуководителя", Выб.ДолжностьРуководителя);

			Возврат Стр;
		КонецЕсли;
	КонецЕсли;
КонецФункции

Функция ПолучитьНомерДатуДокумента(Распоряжение)
	Если Не ЗначениеЗаполнено(Распоряжение) Тогда
			Возврат Неопределено;
		
	ИначеЕсли ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ЗаказКлиента", Распоряжение);
		
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	т.Номер КАК Номер,
		|	т.Дата КАК Дата
		|ИЗ
		|	Документ.ОтгрузкаТоваровКлиенту КАК т
		|ГДЕ
		|	т.ЗаказКлиента = &ЗаказКлиента
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	т.Номер,
		|	т.Дата
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК т
		|ГДЕ
		|	т.ЗаказКлиента = &ЗаказКлиента";

		Табл = Запрос.Выполнить().Выгрузить();
		
		Если Табл.Количество() = 0 Тогда
			Возврат Неопределено;
		Иначе
			Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Табл[0]);
		КонецЕсли;
		
	Иначе
		Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Распоряжение, "Номер, Дата");
	КонецЕсли;
КонецФункции

