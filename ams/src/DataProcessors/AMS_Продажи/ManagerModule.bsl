	|	И &ПоказатьСамовывоз
	|	И Реал.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Распоряжение КАК Распоряжение,
	|	СУММА(ЕСТЬNULL(т.КоличествоУпаковок, 0)) КАК КоличествоУпаковок
	|ПОМЕСТИТЬ упак
	|ИЗ
