	|	Контр2.НаименованиеПолное КАК ГрузополучательНаименование,
	|	Контр2.ИНН КАК ГрузополучательИНН,
	|	Контр2.КПП КАК ГрузополучательКПП,
	|	шапка.АдресДоставки КАК АдресДоставки,
	|	док1.СпособПередачиТоваров КАК СпособПередачиТоваров,
	|	док1.КоличествоПалет КАК КоличествоПалет,
	|	док1.Обрешетка КАК Обрешетка,
	|	шапка.Грузоотправитель КАК Грузоотправитель,
	|	Орг.НаименованиеСокращенное КАК ГрузоотправительНаименование,
	|	Орг.ИНН КАК ГрузоотправительИНН,
	|	Орг.КПП КАК ГрузоотправительКПП,
	|	шапка.Менеджер КАК Менеджер
	|ИЗ
	|	док1 КАК док1
	|		ЛЕВОЕ СОЕДИНЕНИЕ шапка КАК шапка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
	|			ПО шапка.Перевозчик = Партнеры.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контр1
	|			ПО шапка.Контрагент = Контр1.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контр2
	|			ПО шапка.Грузополучатель = Контр2.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Орг
	|			ПО шапка.Грузоотправитель = Орг.Ссылка
	|		ПО док1.Связь = шапка.Связь
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	док2.Реализация КАК Реализация,
	|	Реал.Номер КАК Номер,
	|	Реал.Дата КАК Дата
	|ИЗ
	|	док2 КАК док2
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реал
	|		ПО док2.Реализация = Реал.Ссылка";

	Рез = Запрос.ВыполнитьПакет();
	РезультатПоШапке = Рез[3];
	РезультатПоНомерамУПД = Рез[4];

	Возврат Новый Структура("РезультатПоШапке,РезультатПоНомерамУПД", РезультатПоШапке, РезультатПоНомерамУПД);
