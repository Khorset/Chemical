#Область Печать_ДопСоглашение

Функция СформироватьДопСоглашение(МассивОбъектов)
	Док    = МассивОбъектов[0];
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Док);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	д.Дата КАК Дата,
	|	д.Договор.Номер КАК ДоговорНомер,
	|	д.Договор.Дата КАК ДоговорДата,
	|	д.Организация.НаименованиеПолное КАК Заказчик,
	|	д.Партнер.НаименованиеПолное КАК Перевозчик
	|ИЗ
	|	Документ._ТранспортныеУслуги КАК д
	|ГДЕ
	|	д.Ссылка = &Ссылка";	
	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	Выб.Следующий();

	Таб = ПолучитьТаблицуМаршрутов(Док);

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.АвтоМасштаб        = Истина;

	Макет = Документы._ТранспортныеУслуги.ПолучитьМакет("ДопСоглашение");

	ОблШапка  = Макет.ПолучитьОбласть("Шапка");
	ОблСтрока = Макет.ПолучитьОбласть("Строка");
	ОблПодвал = Макет.ПолучитьОбласть("Подвал");
	
	ОблШапка.Параметры.Номер = Выб.ДоговорНомер;
	ОблШапка.Параметры.Дата  = Формат(Выб.ДоговорДата, "ДЛФ=ДД");
	
	ТабДок.Вывести(ОблШапка);
	
	НомерСтроки = 0;
	Для каждого Стр Из Таб Цикл
		НомерСтроки = НомерСтроки + 1;
		ОблСтрока.Параметры.Заполнить(Стр);
		ОблСтрока.Параметры.НомерСтроки = НомерСтроки;
		
		ТабДок.Вывести(ОблСтрока);
	КонецЦикла;
	
	
	ОблПодвал.Параметры.Дата       = Формат(Выб.Дата, "ДЛФ=ДД");
	ОблПодвал.Параметры.Заказчик   = Выб.Заказчик;
	ОблПодвал.Параметры.Перевозчик = Выб.Перевозчик;
		
	ТабДок.Вывести(ОблПодвал);
	
	Возврат ТабДок;
КонецФункции

Функция ПолучитьТаблицуМаршрутов(Док)
	АдресСклада = "МО, г. Лосино-Петровский";

	Таб = Новый ТаблицаЗначений;
	Таб.Колонки.Добавить("Тип");
	Таб.Колонки.Добавить("Маршрут");
	Таб.Колонки.Добавить("Стоимость");
	Таб.Колонки.Добавить("Справка");

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Док);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.ЛогистическийЛист КАК ЛогистическийЛист,
	|	т.ТранспортноеСредство КАК ТранспортноеСредство,
	|	авто.Тип КАК Тип,
	|	т.СтоимостьДоставки КАК СтоимостьДоставки,
	|	т.Водитель КАК Водитель
	|ПОМЕСТИТЬ ДокТУ
	|ИЗ
	|	Документ._ТранспортныеУслуги.Рейсы КАК т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТранспортныеСредства КАК авто
	|		ПО т.ТранспортноеСредство = авто.Ссылка
	|ГДЕ
	|	т.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДокТУ.ЛогистическийЛист КАК ЛогистическийЛист,
	|	ДокТУ.ТранспортноеСредство КАК ТранспортноеСредство,
	|	Заказы.АдресДоставки КАК АдресДоставки,
	|	Заказы.Подвоз КАК Подвоз
	|ПОМЕСТИТЬ Адреса
	|ИЗ
	|	ДокТУ КАК ДокТУ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист.Распоряжения КАК Заказы
	|		ПО ДокТУ.ЛогистическийЛист = Заказы.Ссылка
	|			И ДокТУ.ТранспортноеСредство = Заказы.ТранспортноеСредство
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокТУ.ЛогистическийЛист КАК ЛогистическийЛист,
	|	ДокТУ.ТранспортноеСредство КАК ТранспортноеСредство,
	|	ДокТУ.Водитель КАК Водитель,
	|	ДокТУ.Тип КАК Тип,
	|	ДокТУ.СтоимостьДоставки КАК Стоимость,
	|	Адреса.АдресДоставки КАК Адрес,
	|	Адреса.Подвоз КАК Подвоз
	|ИЗ
	|	ДокТУ КАК ДокТУ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Адреса КАК Адреса
	|		ПО ДокТУ.ЛогистическийЛист = Адреса.ЛогистическийЛист
	|			И ДокТУ.ТранспортноеСредство = Адреса.ТранспортноеСредство
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокТУ.ЛогистическийЛист.МоментВремени
	|ИТОГИ
	|	МАКСИМУМ(Водитель),
	|	МАКСИМУМ(Тип),
	|	МАКСИМУМ(Стоимость)
	|ПО
	|	ЛогистическийЛист,
	|	ТранспортноеСредство";

	Рез = Запрос.Выполнить();

	Выб1 = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выб1.Следующий() Цикл
		
		Выб2 = Выб1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выб2.Следующий() Цикл
			Стр = Таб.Добавить();

			Стр.Тип       = Выб2.Тип;
			Стр.Стоимость = Выб2.Стоимость;
			Стр.Справка   = "" + Выб2.ТранспортноеСредство + " (" + Выб2.Водитель + ")";

			ПервыйАдрес = Истина;
			Маршрут     = "";
			Подвоз      = Ложь;


			Выб3 = Выб2.Выбрать();
			Пока Выб3.Следующий() Цикл
				Подвоз = Выб3.Подвоз;

				Если ПервыйАдрес И Не Выб3.Подвоз Тогда
					Маршрут = АдресСклада;

					ПервыйАдрес = Ложь;
				КонецЕсли;

				Маршрут = Маршрут + " - " + Выб3.Адрес;
			КонецЦикла;

			Если Подвоз Тогда
				Маршрут = Маршрут + " - " + АдресСклада;
			КонецЕсли;

			Стр.Маршрут = Маршрут;
		КонецЦикла;
	КонецЦикла;

	Возврат Таб;
КонецФункции

#КонецОбласти

#Область Печать_СпецификацияЭкпорт

Функция СформироватьПечатнуюФормуСпецификацияЭкпорт(МассивОбъектов, ОбъектыПечати, ПараметрыПечати, КомплектыПечати = Неопределено) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ПолеСлева = 5;
	ТабличныйДокумент.ПолеСправа = 5;
	ТабличныйДокумент.РазмерКолонтитулаСверху = 0;
	ТабличныйДокумент.РазмерКолонтитулаСнизу = 0;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;

	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_УЛ";

	ЗаполнитьТабДокСпецификацияЭкпорт(ТабличныйДокумент, МассивОбъектов, ОбъектыПечати, ПараметрыПечати, КомплектыПечати);

	Возврат ТабличныйДокумент;
КонецФункции

Процедура ЗаполнитьТабДокСпецификацияЭкпорт(ТабличныйДокумент, МассивОбъектов, ОбъектыПечати, ПараметрыПечати, КомплектыПечати = Неопределено)
	Реализация = МассивОбъектов[0];
	
	Если ТипЗнч(Реализация) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда 
		ДанныеРеализации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Реализация,
			"Номер, Дата, Организация, Договор, Валюта, Контрагент, Грузополучатель, AMS_КоличествоПалет, Ссылка");
	Иначе
		Возврат;
	КонецЕсли;		

	Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.AMS_Продажи.СпецификацияЭкспорт");

	ОбластьШапка    = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапкаТаб = Макет.ПолучитьОбласть("ЗаголовокТаб");
	ОбластьСтрока   = Макет.ПолучитьОбласть("Строка"); 
	ОбластьПодвал   = Макет.ПолучитьОбласть("Подвал");

	
	Парам = ОбластьШапка.Параметры;
	
	Парам.Документ         = "Спецификация № " + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ДанныеРеализации.Номер) 
								+ " от " + Формат(ДанныеРеализации.Дата, "ДЛФ=ДД") + " к " + ДанныеРеализации.Договор;
	Парам.Организация      = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								ДанныеРеализации.Организация, ДанныеРеализации.Дата), "ПолноеНаименование");
	Парам.ОрганизацияАдрес = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								ДанныеРеализации.Организация, ДанныеРеализации.Дата), "ЮридическийАдрес");
	Парам.ОрганизацияИНН   = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								ДанныеРеализации.Организация, ДанныеРеализации.Дата), "ИНН");
	Парам.Покупатель       = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								ДанныеРеализации.Контрагент, ДанныеРеализации.Дата), "ПолноеНаименование");
	Парам.ПокупательАдрес  = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								ДанныеРеализации.Контрагент, ДанныеРеализации.Дата), "ЮридическийАдрес");
	Парам.ПокупательИНН    = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
								ДанныеРеализации.Контрагент, ДанныеРеализации.Дата), "ИНН");

	Если Не ЗначениеЗаполнено(ДанныеРеализации.Грузополучатель) 
		Или ДанныеРеализации.Грузополучатель = ДанныеРеализации.Контрагент Тогда
		Парам.Грузополучатель = "он же";
	Иначе
		Парам.Грузополучатель = ФормированиеПечатныхФорм.ОписаниеОрганизации(
			ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеРеализации.Грузополучатель, ДанныеРеализации.Дата), "ПолноеНаименование");
	КонецЕсли;

	Парам.Оплата   = "Оплата производится Покупателем путём перечисления 100% предоплаты на расчётный счет Поставщика";
	Парам.Поставка = "FCA - Москва, автомабильный, оплата российский рубль. " + ДанныеРеализации.Договор;

	ТабличныйДокумент.Вывести(ОбластьШапка);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Реализация", Реализация);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	СУММА(т.Количество) КАК Количество,
	|	МАКСИМУМ(т.Цена) КАК Цена
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Реализация
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Ном.Артикул КАК Артикул,
	|	Ном.НаименованиеПолное КАК Номенклатура,
	|	Ном.ЕдиницаИзмерения КАК Ед,
	|	Ном.КоэффициентЕдиницыДляОтчетов КАК Кфц,
	|	Товары.Количество КАК Количество,
	|	Товары.Количество / Ном.КоэффициентЕдиницыДляОтчетов КАК КоличествоУпаковок,
	|	Товары.Цена / Ном.КоэффициентЕдиницыДляОтчетов КАК Цена,
	|	Товары.Цена * Товары.Количество / Ном.КоэффициентЕдиницыДляОтчетов КАК Сумма,
	|	Ном.ВесЧислитель * Товары.Количество КАК ВесНетто,
	|	Ном._Упаковка.Вес * Товары.Количество / Ном.КоэффициентЕдиницыДляОтчетов КАК ВесБрутто,
	|	Ном.СтранаПроисхождения КАК СтранаПроисхождения,
	|	Ном.КодТНВЭД КАК КодТНВЭД
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО Товары.Номенклатура = Ном.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ном.Наименование";
	
	Табл = Запрос.Выполнить().Выгрузить();
	
	КоличествоСтрок = Табл.Количество();
	
	ВыводШапки    = 0;
	НомерСтроки   = 0;
	
	ИтогоКоличество  = 0;
	ИтогоКолУпаковок = 0;
	ИтогоСумма       = 0;
	ИтогоВесНетто    = 0;
	ИтогоВесБрутто   = 0;

	НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1; 
	
	МассивВыводимыхОбластей = Новый Массив; // Создаем массив для проверки вывода

	ВыводШапки = 0;
	
	Для каждого Стр Из Табл Цикл
		НомерСтроки = НомерСтроки + 1;
		
		ИтогоКоличество  = ИтогоКоличество  + Стр.Количество;
		ИтогоКолУпаковок = ИтогоКолУпаковок + Стр.КоличествоУпаковок;
		ИтогоСумма       = ИтогоСумма       + Стр.Сумма;
		ИтогоВесНетто    = ИтогоВесНетто    + Стр.ВесНетто;
		ИтогоВесБрутто   = ИтогоВесБрутто   + Стр.ВесБрутто; 
		
		ОбластьСтрока.Параметры.Заполнить(Стр);
		ОбластьСтрока.Параметры.НомСтр = НомерСтроки;

		Если НомерСтроки = 0 И ВыводШапки <> 2 Тогда
			ВыводШапки = 1;
		КонецЕсли;

		Если (НомерСтроки = 1 И ВыводШапки = 0) Или (НомерСтроки = 0 И ВыводШапки = 1) Тогда
			ВыводШапки = 2;
			ТабличныйДокумент.Вывести(ОбластьШапкаТаб);
		КонецЕсли;

		МассивВыводимыхОбластей.Очистить();
		
		МассивВыводимыхОбластей.Добавить(ОбластьСтрока);
		
		Если НомерСтроки = КоличествоСтрок Тогда
			ОбластьПодвал.Параметры.Количество         = ИтогоКоличество;
			ОбластьПодвал.Параметры.КоличествоУпаковок = ИтогоКолУпаковок;
			ОбластьПодвал.Параметры.Сумма              = ИтогоСумма;
			ОбластьПодвал.Параметры.ВесНетто           = ИтогоВесНетто;
			ОбластьПодвал.Параметры.ВесБрутто          = ИтогоВесБрутто;
			
			ОбластьПодвал.Параметры.Мест = "Количество мест " + ИтогоКолУпаковок + "шт."; 
			ОбластьПодвал.Параметры.Вес  = "Вес НЕТТО: " + ИтогоВесНетто + " кг.,      Вес БРУТТО: " + ИтогоВесБрутто + " кг."; 
			ОбластьПодвал.Параметры.СуммаПрописью = "Всего отгружено на сумму: " 
											+ РаботаСКурсамиВалют.СформироватьСуммуПрописью(ИтогоСумма, ДанныеРеализации.Валюта); 
			ОбластьПодвал.Параметры.Упаковано = "Упаковано на  " + ДанныеРеализации.AMS_КоличествоПалет + " палетах"; 

			МассивВыводимыхОбластей.Добавить(ОбластьПодвал);
		КонецЕсли;

		Если Не ТабличныйДокумент.ПроверитьВывод(МассивВыводимыхОбластей) Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ТабличныйДокумент.Вывести(ОбластьШапкаТаб);
		КонецЕсли;

		ТабличныйДокумент.Вывести(ОбластьСтрока);
	КонецЦикла;
	
	ТабличныйДокумент.Вывести(ОбластьПодвал);

	УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ДанныеРеализации.Ссылка);
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли