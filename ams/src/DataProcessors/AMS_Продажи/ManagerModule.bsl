	|		ПО тов.Номенклатура = ц6.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ц КАК ц
	|		ПО тов.Номенклатура = ц.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	тов.НомерСтроки";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ПолучитьСтруктуруПродукции(ВариантПрайса, ЦеноваяГруппа)
	УстановитьПривилегированныйРежим(Истина);

	СКД  = Справочники._ПродукцияКомпании.ПолучитьМакет("МакетПрайс");
	Табл = Новый ТаблицаЗначений;

	Если ЦеноваяГруппа.Количество() = 1 Тогда
		Настройки = СКД.НастройкиПоУмолчанию;
		ОтборЭтоМега = Настройки.Отбор.Элементы.Получить(0);
		ОтборЭтоМега.Использование = Истина;

		Если ЦеноваяГруппа[0] = AMS_ВызовСервера.ЦеноваяГруппаМЕГА() Тогда
			ОтборЭтоМега.ПравоеЗначение = Истина;
		Иначе
			ОтборЭтоМега.ПравоеЗначение = Ложь;
		КонецЕсли;

		мср.ПолучитьДанныеНаОснованииСКД(СКД, Табл, Настройки, Неопределено);
	Иначе
		мср.ПолучитьДанныеНаОснованииСКД(СКД, Табл, Неопределено, Неопределено);
	КонецЕсли;

	Возврат Табл;
КонецФункции

Функция ПреобразоватьСтроку(Стр)
	Поз = СтрНайти(Стр, "Туба");
	Если Поз > 0 Тогда
		Возврат "Туба" + Символы.ПС + Сред(Стр, 6);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Банка");
	Если Поз > 0 Тогда
		Возврат "Банка" + Символы.ПС + Сред(Стр, 7);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Пакет");
	Если Поз > 0 Тогда
		Возврат "Пакет" + Символы.ПС + Сред(Стр, 7);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Коробка");
	Если Поз > 0 Тогда
		Возврат "Коробка" + Символы.ПС + Сред(Стр, 9);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Спайка");
	Если Поз > 0 Тогда
		Возврат "Спайка" + Символы.ПС + Сред(Стр, Поз + 7);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Пуш-пул");
	Если Поз > 0 Тогда
		Возврат "Пуш-пул" + Символы.ПС + Сред(Стр, 9);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Флип-топ");
	Если Поз > 0 Тогда
		Возврат "Флип-топ" + Символы.ПС + Сред(Стр, 10);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Дозатор");
	Если Поз > 0 Тогда
		Возврат "Дозатор" + Символы.ПС + Сред(Стр, 9);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Триггер");
	Если Поз > 0 Тогда
		Возврат "Триггер" + Символы.ПС + Сред(Стр, 9);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Смен.блок");
	Если Поз > 0 Тогда
		Возврат "Сменный" + Символы.ПС + "блок" + Символы.ПС + Сред(Стр, Поз + 10);
	КонецЕсли;

	Поз = СтрНайти(Стр, "Шоу-бокс");
	Если Поз > 0 Тогда
		Возврат "Шоу-бокс" + Символы.ПС + Сред(Стр, Поз + 9);
	КонецЕсли;

	Возврат Стр;
КонецФункции

#КонецОбласти

#Область Печать_НакладнаяНаПеремещениеПалет

Функция СформироватьНакладнаяНаПалеты(МассивОбъектов) Экспорт
	УстановитьПривилегированныйРежим(Истина);

	ТабДок = Новый ТабличныйДокумент;

	Рез = ПолучитьДанныеДляПечатиНакладнаяНаПалеты(МассивОбъектов[0]);

	РезультатПоШапке = Рез[1];
	РезультатПоТЧ    = Рез[2];

	Если Не РезультатПоШапке.Пустой() Тогда
		ТабДок.АвтоМасштаб         = Истина;
		ТабДок.ОриентацияСтраницы  = ОриентацияСтраницы.Портрет;
		ТабДок.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_НакладнаяНаПалеты";

		Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.AMS_Продажи.НакладнаяНаПалеты");
		ОблШапка1  = Макет.ПолучитьОбласть("Шапка1");
		ОблШапка2  = Макет.ПолучитьОбласть("Шапка2");
		ОблСтрока1 = Макет.ПолучитьОбласть("Строка1");
		ОблСтрока2 = Макет.ПолучитьОбласть("Строка2");
		ОблПодвал  = Макет.ПолучитьОбласть("Подвал");
		Для а = 1 По 3 Цикл
			Выб = РезультатПоШапке.Выбрать();
			Выб.Следующий();

			Парам = Новый Структура;
			Парам.Вставить("УПД", "к УПД № " + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Выб.Номер) + " от "
				+ Формат(Выб.Дата, "ДЛФ=Д"));
			Парам.Вставить("Отправитель", Выб.Организация);
			Парам.Вставить("Покупатель", Выб.Партнер);
			Парам.Вставить("Водитель", ?(Выб.Водитель = Null, "", Строка(Выб.Водитель) + ", " + Строка(
				Выб.ТранспортноеСредство)));
			ОблШапка1.Параметры.Заполнить(Парам);

			ТабДок.Вывести(ОблШапка1);

			Сч = 0;
			Выб = РезультатПоТЧ.Выбрать();
			Пока Выб.Следующий() Цикл
				Сч = Сч + 1;
				ОблСтрока1.Параметры.Сч           = Сч;
				ОблСтрока1.Параметры.Номенклатура = Выб.Номенклатура;
				ОблСтрока1.Параметры.Количество = Строка(Выб.Количество) + " ("
					+ ФормированиеПечатныхФорм.КоличествоПрописью(Выб.Количество) + ")";
				ТабДок.Вывести(ОблСтрока1);
			КонецЦикла;

			ТабДок.Вывести(ОблШапка2);

			Сч = 0;
			Выб = РезультатПоТЧ.Выбрать();
			Пока Выб.Следующий() Цикл
				Сч = Сч + 1;
				ОблСтрока2.Параметры.Сч           = Сч;
				ОблСтрока2.Параметры.Номенклатура = Выб.Номенклатура;
				ТабДок.Вывести(ОблСтрока2);
			КонецЦикла;

			ТабДок.Вывести(ОблПодвал);
		КонецЦикла;
	КонецЕсли;

	Возврат ТабДок;
КонецФункции

Функция ПолучитьДанныеДляПечатиНакладнаяНаПалеты(Ссылка)
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ Палеты
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Ссылка
	|	И т.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Реал.Номер КАК Номер,
	|	Реал.Дата КАК Дата,
	|	Реал.Организация.НаименованиеСокращенное КАК Организация,
	|	Реал.Партнер.НаименованиеПолное КАК Партнер,
	|	ЛогЛистРаспоряжения.ТранспортноеСредство КАК ТранспортноеСредство,
	|	ЛогЛистРейсы.Водитель КАК Водитель
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реал
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист.Распоряжения КАК ЛогЛистРаспоряжения
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист.Рейсы КАК ЛогЛистРейсы
	|			ПО ЛогЛистРаспоряжения.Ссылка = ЛогЛистРейсы.Ссылка
	|				И ЛогЛистРаспоряжения.ТранспортноеСредство = ЛогЛистРейсы.ТранспортноеСредство
	|		ПО Реал.Ссылка = ЛогЛистРаспоряжения.Распоряжение
	|ГДЕ
	|	Реал.Ссылка В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				т.Ссылка КАК Ссылка
	|			ИЗ
	|				Палеты КАК т)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Палеты.Номенклатура КАК Номенклатура,
	|	Палеты.Количество КАК Количество
	|ИЗ
	|	Палеты КАК Палеты";

	Возврат Запрос.ВыполнитьПакет();
КонецФункции

#КонецОбласти

#Область Печать_АктПереводаНаименований

Функция СформироватьАктПереводаНаименований(МассивОбъектов)
	УстановитьПривилегированныйРежим(Истина);

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ПолеСлева = 5;
	ТабличныйДокумент.ПолеСправа = 5;
	ТабличныйДокумент.РазмерКолонтитулаСверху = 0;
	ТабличныйДокумент.РазмерКолонтитулаСнизу = 0;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;

	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ__АктПереводаНаименований";

	ДанныеДляПечати = ПолучитьДанныеДляПечатиАктПереводаНаименований(МассивОбъектов);

	ЗаполнитьТабДокАктПереводаНаименований(ТабличныйДокумент, ДанныеДляПечати);

	Возврат ТабличныйДокумент;
КонецФункции

Функция ПолучитьДанныеДляПечатиАктПереводаНаименований(МассивОбъектов)
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	д.Организация КАК Организация,
	|	д.Организация._ДолжностьРуководителя КАК ДолжностьРуководителя,
	|	д.Организация._Руководитель КАК ИмяРуководителя,
	|	д.Партнер КАК Партнер,
	|	д.Номер КАК Номер,
	|	д.Дата КАК Дата,
	|	д.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
	|	д.ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
	|	т.Склад КАК Склад,
	|	т.Склад.ТекущийОтветственный КАК НачальникСклада,
	|	т.НоменклатураПартнера.НаименованиеНоменклатуры КАК НоменклатураПоставщика,
	|	т.НоменклатураПартнера.КодОКЕИБазовойЕдиницыИзмерения КАК ЕдПоставщикаКод,
	|	т.НоменклатураПартнера.НаименованиеУпаковки КАК ЕдПоставщика,
	|	т.Номенклатура.Наименование КАК Номенклатура,
	|	т.Номенклатура.ЕдиницаИзмерения.Код КАК ЕдКод,
	|	ВЫБОР
	|		КОГДА т.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА т.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ т.Упаковка
	|	КОНЕЦ КАК Ед,
	|	т.Количество КАК Количество,
	|	т.Цена КАК Цена
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг.Товары КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг КАК д
	|		ПО т.Ссылка = д.Ссылка
	|ГДЕ
	|	т.Ссылка В(&МассивОбъектов)
	|	И т.НоменклатураПартнера.НаименованиеНоменклатуры <> т.Номенклатура.Наименование
	|ИТОГИ ПО
	|	Склад";

	Возврат Запрос.Выполнить();
КонецФункции

Процедура ЗаполнитьТабДокАктПереводаНаименований(ТабличныйДокумент, ДанныеДляПечати)
	Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.AMS_Продажи.АктПереводаНаименований");

	Шапка  = Макет.ПолучитьОбласть("Шапка");
	Строка = Макет.ПолучитьОбласть("Строка");
	Подвал = Макет.ПолучитьОбласть("Подвал");

	ПерваяСтраница = Истина;

	ВыборкаСклад = ДанныеДляПечати.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаСклад.Следующий() Цикл
		Если Не ПерваяСтраница Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;

		ПерваяСтраница = Ложь;

		НомерСтроки = 0;

		Выб = ВыборкаСклад.Выбрать();

		КоличествоСтрок = Выб.Количество();

		Пока Выб.Следующий() Цикл
			НомерСтроки = НомерСтроки + 1;

			Если НомерСтроки = 1 Тогда
				Шапка.Параметры.ДолжностьРуководителя = Выб.ДолжностьРуководителя;
				Шапка.Параметры.ИмяРуководителя       = Выб.ИмяРуководителя;

				Шапка.Параметры.Номер = "№ " + ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Выб.Номер) + " от "
					+ Формат(Выб.Дата, "ДЛФ=Д") + " г.";

				Шапка.Параметры.Организация = Выб.Организация;
				Шапка.Параметры.Партнер     = Выб.Партнер;

				Шапка.Параметры.ГлавныйИнженер  = "главный инженер Голощапов В.И.,";
				Шапка.Параметры.НачальникСклада = "начальник склада " + Выб.НачальникСклада + ",";
				Шапка.Параметры.БухгалтерСклада = "бухгалтер склада Субботина А.М.,";

				Шапка.Параметры.НомерПоставщика = "№ " + Выб.НомерВходящегоДокумента + " от " + Формат(
					Выб.ДатаВходящегоДокумента, "ДЛФ=Д") + " г.";

				ТабличныйДокумент.Вывести(Шапка);
			КонецЕсли;

			Строка.Параметры.Заполнить(Выб);
			Строка.Параметры.НомерСтроки = НомерСтроки;

			ТабличныйДокумент.Вывести(Строка);

			Если НомерСтроки = КоличествоСтрок Тогда
				Подвал.Параметры.ГлавныйИнженер  = "Голощапов В.И.";
				Подвал.Параметры.НачальникСклада = Выб.НачальникСклада;
				Подвал.Параметры.БухгалтерСклада = "Субботина А.М.";
				Подвал.Параметры.Кладовщик       = "Субботина А.М.";

				ТабличныйДокумент.Вывести(Подвал);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область Печать_ЛогистическийЛист

Функция СформироватьЛогистическийЛист(МассивДокументов, Парам)
	Док    = МассивДокументов[0];

	Рез    = ПолучитьДанныеЛогистическогоЛиста(Док, Парам.Доставка);

	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабДок.АвтоМасштаб        = Истина;

	Макет = Документы.AMS_ЛогистическийЛист.ПолучитьМакет("ЛогистическийЛист");

	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьАвто   = Макет.ПолучитьОбласть("Авто");
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
	ОбластьИтог   = Макет.ПолучитьОбласть("Итого");

	МассивВыводимыхОбластей = Новый Массив;

	ТабДок.НачатьАвтогруппировкуСтрок();
	
	ОбластьШапка.Параметры.Заголовок  = "Логистический лист № " + Док.Номер + " от " + Формат(Док.Дата, "ДЛФ=ДД");
	ТабДок.Вывести(ОбластьШапка);

	Выб1 = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Выб1.Следующий();
	ОбластьИтог.Параметры.Заполнить(Выб1);

	Выб2 = Выб1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выб2.Следующий() Цикл
		ОбластьАвто.Параметры.Заполнить(Выб2);
		
		Если Выб2.НаименованиеАвто = "Самовывоз" Тогда
			Авто = Выб2.НаименованиеАвто;
		Иначе
			Авто = Выб2.НаименованиеАвто + ", " + Выб2.Водитель + ", тел. "	+ Выб2.Телефон + " (перевозчик: " + Выб2.Перевозчик + ")";
		КонецЕсли;
		
		ОбластьАвто.Параметры.ТранспортноеСредство = Авто;

		МассивВыводимыхОбластей.Очистить();
		МассивВыводимыхОбластей.Добавить(ОбластьАвто);

		Выб3 = Выб2.Выбрать();
		Пока Выб3.Следующий() Цикл
			ОбластьСтрока.Параметры.Заполнить(Выб3);
			МассивВыводимыхОбластей.Добавить(ОбластьСтрока);
		КонецЦикла;

		Если Не ТабДок.ПроверитьВывод(МассивВыводимыхОбластей) Тогда
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;

		ТабДок.Вывести(ОбластьАвто, 1, "Авто", Истина);

		Выб3.Сбросить();
		Пока Выб3.Следующий() Цикл
			ОбластьСтрока.Параметры.Заполнить(Выб3);

			Если Выб2.НаименованиеАвто = "Самовывоз" Тогда
				ОбластьСтрока.Параметры.НомерСтроки = "";
				ОбластьСтрока.Параметры.АдресДоставки = "";
			КонецЕсли;

			ТабДок.Вывести(ОбластьСтрока, 2, "Документ", Истина);
		КонецЦикла;
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьИтог);

	ТабДок.ЗакончитьАвтогруппировкуСтрок();

	Возврат ТабДок;
КонецФункции

Функция ПолучитьДанныеЛогистическогоЛиста(Док, Доставка)
	ПоказатьСамовывоз = Ложь;
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Док.Дата);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	т.Номер КАК Номер
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист КАК т
	|ГДЕ
	|	т.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И НЕ т.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номер";
	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	Пока Выб.Следующий() Цикл
		Если Док.Номер = Выб.Номер Тогда
			ПоказатьСамовывоз = Истина;
		КонецЕсли;
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Док.Дата);
	Запрос.УстановитьПараметр("Ссылка", Док);
	Запрос.УстановитьПараметр("Доставка", Доставка);
	Запрос.УстановитьПараметр("ПоказатьСамовывоз", ПоказатьСамовывоз);

	Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Тран._Перевозчик КАК Перевозчик,
	|	Рейсы.ТранспортноеСредство КАК ТранспортноеСредство,
	|	Тран.Наименование КАК НаименованиеАвто,
	|	Тран.ГрузоподъемностьВТоннах КАК Тоннаж,
	|	Рейсы.Водитель КАК Водитель,
	|	Физл.Представление КАК Телефон,
	|	Рейсы.ВремяЗагрузки КАК ВремяЗагрузки,
	|	Рейсы.ВремяЗагрузкиФакт КАК ВремяЗагрузкиФакт,
	|	Рейсы.Отправлено КАК Отправлено,
	|	Распоряжения.Распоряжение КАК Распоряжение,
	|	Распоряжения.Распоряжение ССЫЛКА Документ.ЗаказКлиента
	|		ИЛИ Распоряжения.Распоряжение ССЫЛКА Документ.РеализацияТоваровУслуг
	|		ИЛИ Распоряжения.Распоряжение ССЫЛКА Документ.ОтгрузкаТоваровКлиенту
	|		ИЛИ Распоряжения.Распоряжение ССЫЛКА Документ.ПередачаТоваровХранителю
	|		ИЛИ Распоряжения.Распоряжение ССЫЛКА Документ.AMS_ПередачаВПереработку КАК Доставка,
	|	Распоряжения.ПорядокВМаршруте КАК НомерСтроки
	|ПОМЕСТИТЬ ЛогЛист
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист.Рейсы КАК Рейсы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист.Распоряжения КАК Распоряжения
	|		ПО Рейсы.Ссылка = Распоряжения.Ссылка
	|			И Рейсы.ТранспортноеСредство = Распоряжения.ТранспортноеСредство
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТранспортныеСредства КАК Тран
	|		ПО Рейсы.ТранспортноеСредство = Тран.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица.КонтактнаяИнформация КАК Физл
	|		ПО Рейсы.Водитель = Физл.Ссылка
	|			И (Физл.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица))
	|ГДЕ
	|	Рейсы.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
