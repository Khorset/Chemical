				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НедостачаШт</dataPath>
			<field>НедостачаШт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Недостача шт</v8:content>
				</v8:item>
			</title>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ='3'</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НедостачаУпак</dataPath>
			<field>НедостачаУпак</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Недостача упак</v8:content>
				</v8:item>
			</title>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="xs:string">ЧДЦ='3'</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">10</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НомерВПрайсе</dataPath>
			<field>НомерВПрайсе</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Номер в прайсе</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НаименованиеПолное</dataPath>
			<field>НаименованиеПолное</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	т.НомерСтроки КАК НомерСтроки,
	т.Номенклатура КАК Номенклатура,
	н.Артикул КАК Артикул,
	н.НаименованиеПолное КАК НаименованиеПолное,
	н._НомерВПрайсе КАК НомерВПрайсе,
	ВЫБОР
		КОГДА н._Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ПРЕДСТАВЛЕНИЕ(н.ЕдиницаИзмерения)
		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(н._Упаковка)
	КОНЕЦ КАК Ед,
	ВЫБОР
		КОГДА н._Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА н.ЕдиницаИзмерения.Код
		ИНАЧЕ н._Упаковка.ЕдиницаИзмерения.Код
	КОНЕЦ КАК ОКЕИ,
	т.Количество КАК КолУчетШт,
	т.Количество / н.КоэффициентЕдиницыДляОтчетов КАК КолУчетУпак,
	т.КоличествоФакт КАК КолФактШт,
	т.КоличествоФакт / н.КоэффициентЕдиницыДляОтчетов КАК КолФактУпак,
	ВЫБОР
		КОГДА т.КоличествоФакт &gt; т.Количество
			ТОГДА т.КоличествоФакт - т.Количество
		ИНАЧЕ 0
	КОНЕЦ КАК ИзлишекШт,
	ВЫБОР
		КОГДА т.КоличествоФакт &gt; т.Количество
			ТОГДА (т.КоличествоФакт - т.Количество) / н.КоэффициентЕдиницыДляОтчетов
		ИНАЧЕ 0
	КОНЕЦ КАК ИзлишекУпак,
	ВЫБОР
		КОГДА т.Количество &gt; т.КоличествоФакт
			ТОГДА т.Количество - т.КоличествоФакт
		ИНАЧЕ 0
	КОНЕЦ КАК НедостачаШт,
	ВЫБОР
		КОГДА т.Количество &gt; т.КоличествоФакт
			ТОГДА (т.Количество - т.КоличествоФакт) / н.КоэффициентЕдиницыДляОтчетов
		ИНАЧЕ 0
	КОНЕЦ КАК НедостачаУпак
ПОМЕСТИТЬ тов
ИЗ
	Документ.ПересчетТоваров.Товары КАК т
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК н
		ПО т.Номенклатура = н.Ссылка
ГДЕ
	т.Ссылка = &amp;Ссылка

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	тов.Номенклатура КАК Номенклатура,
	МАКСИМУМ(д.Ссылка.Дата) КАК Дата
ПОМЕСТИТЬ дат
ИЗ
	тов КАК тов
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ПроизводствоЗаСмену.Продукция КАК д
		ПО тов.Номенклатура = д.Номенклатура
ГДЕ
	тов.Номенклатура.ВидНоменклатуры В (&amp;ВидыНоменклатурыПродукции)
СГРУППИРОВАТЬ ПО
	тов.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	дат.Номенклатура КАК Номенклатура,
	т.Цена КАК Цена
ПОМЕСТИТЬ цен
ИЗ
	дат КАК дат
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ПроизводствоЗаСмену.Продукция КАК т
		ПО дат.Дата = т.Ссылка.Дата
		И дат.Номенклатура = т.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	тов.НомерСтроки КАК НомерСтроки,
	тов.Номенклатура КАК Номенклатура,
	тов.Артикул КАК Артикул,
	тов.НаименованиеПолное КАК НаименованиеПолное,
	тов.НомерВПрайсе КАК НомерВПрайсе,
	тов.ОКЕИ КАК ОКЕИ,
	тов.Ед КАК Ед,
	цен.Цена КАК Цена,
	тов.КолУчетШт КАК КолУчетШт,
	тов.КолУчетУпак КАК КолУчетУпак,
	тов.КолФактШт КАК КолФактШт,
	тов.КолФактУпак КАК КолФактУпак,
	тов.ИзлишекШт КАК ИзлишекШт,
	тов.ИзлишекУпак КАК ИзлишекУпак,
	тов.НедостачаШт КАК НедостачаШт,
	тов.НедостачаУпак КАК НедостачаУпак
ИЗ
	тов КАК тов
		ЛЕВОЕ СОЕДИНЕНИЕ цен КАК цен
		ПО тов.Номенклатура = цен.Номенклатура</query>
	</dataSet>
	<parameter>
		<name>Ссылка</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Ссылка</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:DocumentRef.ПересчетТоваров</v8:Type>
		</valueType>
		<value xsi:type="dcscor:DesignTimeValue">Документ.ПересчетТоваров.ПустаяСсылка</value>
		<useRestriction>false</useRestriction>
	</parameter>
	<parameter>
		<name>ВидыНоменклатурыПродукции</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Виды номенклатуры продукции</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:CatalogRef.ВидыНоменклатуры</v8:Type>
		</valueType>
		<useRestriction>false</useRestriction>
		<valueListAllowed>true</valueListAllowed>
	</parameter>
	<template>
		<name>Макет1</name>
		<template xmlns:dcsat="http://v8.1c.ru/8.1/data-composition-system/area-template" xsi:type="dcsat:AreaTemplate">
			<dcsat:item xsi:type="dcsat:TableRow">
				<dcsat:tableCell>
					<dcsat:item xsi:type="dcsat:Field">
						<dcsat:value xsi:type="v8:LocalStringType">
							<v8:item>
								<v8:lang>ru</v8:lang>
								<v8:content>№</v8:content>
							</v8:item>
						</dcsat:value>
					</dcsat:item>
					<dcsat:appearance>
						<dcscor:item>
							<dcscor:parameter>СтильГраницы</dcscor:parameter>
							<dcscor:value xsi:type="v8ui:Line" width="0" gap="false">
								<v8ui:style xsi:type="v8ui:SpreadsheetDocumentCellLineType">None</v8ui:style>
							</dcscor:value>
							<dcscor:item>
								<dcscor:parameter>СтильГраницы.Слева</dcscor:parameter>
								<dcscor:value xsi:type="v8ui:Line" width="1" gap="false">
									<v8ui:style xsi:type="v8ui:SpreadsheetDocumentCellLineType">Solid</v8ui:style>
								</dcscor:value>
							</dcscor:item>
							<dcscor:item>
								<dcscor:parameter>СтильГраницы.Сверху</dcscor:parameter>
								<dcscor:value xsi:type="v8ui:Line" width="1" gap="false">
									<v8ui:style xsi:type="v8ui:SpreadsheetDocumentCellLineType">Solid</v8ui:style>
								</dcscor:value>
							</dcscor:item>
							<dcscor:item>
								<dcscor:parameter>СтильГраницы.Справа</dcscor:parameter>
								<dcscor:value xsi:type="v8ui:Line" width="1" gap="false">
									<v8ui:style xsi:type="v8ui:SpreadsheetDocumentCellLineType">Solid</v8ui:style>
								</dcscor:value>
							</dcscor:item>
							<dcscor:item>
								<dcscor:parameter>СтильГраницы.Снизу</dcscor:parameter>
								<dcscor:value xsi:type="v8ui:Line" width="1" gap="false">
									<v8ui:style xsi:type="v8ui:SpreadsheetDocumentCellLineType">Solid</v8ui:style>
								</dcscor:value>
							</dcscor:item>
						</dcscor:item>
						<dcscor:item>
							<dcscor:parameter>ГоризонтальноеПоложение</dcscor:parameter>
							<dcscor:value xsi:type="v8ui:HorizontalAlign">Center</dcscor:value>
						</dcscor:item>
						<dcscor:item>
							<dcscor:parameter>ВертикальноеПоложение</dcscor:parameter>
							<dcscor:value xsi:type="v8ui:VerticalAlign">Center</dcscor:value>
						</dcscor:item>
						<dcscor:item>
							<dcscor:parameter>Размещение</dcscor:parameter>
