			<field>Автор</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НАЧАЛОПЕРИОДА(реал.Дата, ДЕНЬ) КАК ДатаОтгрузки,
	ЕСТЬNULL(озт.Ссылка, реал.Ссылка) КАК Загрузка,
	озд.Номер КАК ЗагрузкаНомер,
	реал.Ссылка КАК Ссылка,
	реал.Номер КАК Номер,
	реал.Партнер КАК Клиент,
	реал.Контрагент КАК Контрагент,
	реал.СуммаДокумента КАК СуммаДокумента,
	реал.Партнер.AMS_Лимит КАК Лимит,
	ВЫБОР
		КОГДА реал.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчикаПоАдресу)
			ТОГДА реал.АдресДоставкиПеревозчика
		ИНАЧЕ реал.АдресДоставки
	КОНЕЦ КАК АдресДоставки,
	реал.СпособДоставки КАК СпособДоставки,
	реал.ВремяДоставкиС КАК ВремяДоставкиС,
	озд.AMS_КоличествоПалет КАК КоличествоПалетФакт,
	реал.AMS_КоличествоПалет КАК КоличествоПалет,
	реал.AMS_КоличествоПалетРасчет КАК КоличествоПалетРасчет,
	реал.AMS_КоличествоУпаковок КАК КоличествоУпаковок,
	реал.AMS_Вес КАК Вес,
	реал.AMS_Объем КАК Объем,
	реал.AMS_УсловияОтгрузки КАК УсловияОтгрузки,
	озд.УсловияОтгрузки КАК УсловияОтгрузкиОЗ,
	ВЫРАЗИТЬ(реал.Комментарий КАК СТРОКА(500)) КАК Комментарий,
	реал.Автор КАК Автор,
	реал.Менеджер КАК Менеджер,
	реал.Дата КАК Дата,
	реал.AMS_СтатусРеализации КАК Статус,
	реал.Партнер.ГруппаДоступа КАК ГруппаДоступа,
	реал.Организация КАК Организация,
	реал.Проведен КАК Проведен,
	ВЫБОР
		КОГДА реал.Проведен
			ТОГДА ВЫБОР
				КОГДА реал.AMS_СтатусРеализации = ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке)
					ТОГДА 1
				ИНАЧЕ 2
			КОНЕЦ
		ИНАЧЕ 3
	КОНЕЦ КАК ПорядокСтатусов,
	ВЫБОР
		КОГДА реал.ПометкаУдаления
			ТОГДА 1
		ИНАЧЕ ВЫБОР
			КОГДА реал.Проведен
				ТОГДА 0
			ИНАЧЕ 2
		КОНЕЦ
	КОНЕЦ КАК СостоянияДокумента,
	реал.AMS_УтвержденаОтгрузка КАК УтвержденаОтгрузка,
	реал.AMS_ЦенаИзменена КАК ЦенаИзменена,
	реал.Соглашение КАК Соглашение,
	ВЫБОР
		КОГДА реал.AMS_ID = 0
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК В2В
ПОМЕСТИТЬ док
ИЗ
	Документ.РеализацияТоваровУслуг КАК реал
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ОбъединеннаяЗагрузка.Реализации КАК озт
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ОбъединеннаяЗагрузка КАК озд
			ПО озт.Ссылка = озд.Ссылка
		ПО реал.Ссылка = озт.Реализация
ГДЕ
	реал.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование))
	И реал.Склад = &amp;СкладПродукции

ИНДЕКСИРОВАТЬ ПО
	Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Док.Ссылка КАК Ссылка,
	ДОБАВИТЬКДАТЕ(Док.Дата, ДЕНЬ, ГрафикиОплатыЭтапы.Сдвиг) КАК ДатаПлатежа
ПОМЕСТИТЬ этап
ИЗ
	док КАК Док
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГрафикиОплаты.Этапы КАК ГрафикиОплатыЭтапы
			ПО СоглашенияСКлиентами.ГрафикОплаты = ГрафикиОплатыЭтапы.Ссылка
		ПО Док.Соглашение = СоглашенияСКлиентами.Ссылка
ГДЕ
	ГрафикиОплатыЭтапы.НомерСтроки = 1

ИНДЕКСИРОВАТЬ ПО
	Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	док.ДатаОтгрузки КАК ДатаОтгрузки,
	док.Загрузка КАК Загрузка,
	док.ЗагрузкаНомер КАК ЗагрузкаНомер,
	док.Ссылка КАК Ссылка,
	док.Номер КАК Номер,
	док.Клиент КАК Клиент,
	док.Контрагент КАК Контрагент,
	док.СуммаДокумента КАК СуммаДокумента,
	док.Лимит КАК Лимит,
	док.АдресДоставки КАК АдресДоставки,
	док.СпособДоставки КАК СпособДоставки,
	док.ВремяДоставкиС КАК ВремяДоставкиС,
	док.КоличествоПалетФакт КАК КоличествоПалетФакт,
	док.КоличествоПалет КАК КоличествоПалет,
	док.КоличествоПалетРасчет КАК РасчетПалет,
	док.КоличествоУпаковок КАК КоличествоУпаковок,
	док.Вес КАК Вес,
	док.Объем КАК Объем,
	док.УсловияОтгрузки КАК УсловияОтгрузки,
	док.УсловияОтгрузкиОЗ КАК УсловияОтгрузкиОЗ,
	док.Комментарий КАК Комментарий,
	док.Менеджер КАК Менеджер,
	док.Дата КАК Дата,
	док.Статус КАК Статус,
	док.ГруппаДоступа КАК ГруппаДоступа,
	ЕСТЬNULL(РАЗНОСТЬДАТ(док.Дата, этап.ДатаПлатежа, ДЕНЬ), 0) КАК Срок,
	док.Организация КАК Организация,
	док.Проведен КАК Проведен,
	док.ПорядокСтатусов КАК ПорядокСтатусов,
	док.СостоянияДокумента КАК СостоянияДокумента,
	док.УтвержденаОтгрузка КАК УтвержденаОтгрузка,
	док.ЦенаИзменена КАК ЦенаИзменена,
	док.В2В КАК В2В,
	док.Автор КАК Автор
ИЗ
	док КАК док
		ЛЕВОЕ СОЕДИНЕНИЕ этап КАК этап
		ПО док.Ссылка = этап.Ссылка</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Долги</name>
