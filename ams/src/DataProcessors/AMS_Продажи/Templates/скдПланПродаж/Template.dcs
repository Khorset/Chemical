			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Остаток</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Валюта</dataPath>
			<field>Валюта</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДолгКлиента</dataPath>
			<field>ДолгКлиента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Долг клиента</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Клиент</dataPath>
			<field>Клиент</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Клиент</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Организация</dataPath>
			<field>Организация</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Организация</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ОбъектРасчетов</dataPath>
			<field>ОбъектРасчетов</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.АналитикаУчетаПоПартнерам.Организация КАК Организация,
	т.АналитикаУчетаПоПартнерам.Партнер КАК Клиент,
	т.ОбъектРасчетов КАК ЗаказКлиента,
	т.ОбъектРасчетов.Дата КАК ДатаДокумента,
	ЕСТЬNULL(т.СуммаОстаток, 0) КАК Остаток
ПОМЕСТИТЬ д
ИЗ
	РегистрНакопления.РасчетыСКлиентами.Остатки(, ) КАК т
ГДЕ
	т.СуммаОстаток &lt;&gt; 0

ИНДЕКСИРОВАТЬ ПО
	ЗаказКлиента
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	д.ЗаказКлиента КАК ЗаказКлиента,
	МАКСИМУМ(Этапы.ДатаПлатежа) КАК ДатаПлатежа
ПОМЕСТИТЬ этап
ИЗ
	д КАК д
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АктВыполненныхРабот.ЭтапыГрафикаОплаты КАК Этапы
		ПО д.ЗаказКлиента.Объект = Этапы.Ссылка

СГРУППИРОВАТЬ ПО
	д.ЗаказКлиента

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	д.ЗаказКлиента,
	МАКСИМУМ(Этапы.ДатаПлатежа)
ИЗ
	д КАК д
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.ЭтапыГрафикаОплаты КАК Этапы
		ПО д.ЗаказКлиента.Объект = Этапы.Ссылка

СГРУППИРОВАТЬ ПО
	д.ЗаказКлиента

ИНДЕКСИРОВАТЬ ПО
	ЗаказКлиента
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	д.Организация КАК Организация,
	д.Клиент КАК Клиент,
	д.ЗаказКлиента КАК ЗаказКлиента,
	д.ДатаДокумента КАК ДатаДокумента,
	этап.ДатаПлатежа КАК ДатаПлатежа,
	д.Остаток КАК Остаток
ПОМЕСТИТЬ до
ИЗ
	д КАК д
		ЛЕВОЕ СОЕДИНЕНИЕ этап КАК этап
		ПО д.ЗаказКлиента = этап.ЗаказКлиента

ИНДЕКСИРОВАТЬ ПО
	ЗаказКлиента
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	до.Организация КАК Организация,
	до.Клиент КАК Клиент,
	до.ЗаказКлиента КАК ЗаказКлиента,
	ЕСТЬNULL(до.Остаток, 0) КАК Остаток,
	ВЫБОР
		КОГДА ЕСТЬNULL(до.Остаток, 0) &gt; 0
			ТОГДА ЕСТЬNULL(до.Остаток, 0)
		ИНАЧЕ 0
	КОНЕЦ КАК ДолгКлиента,
	ВЫБОР
		КОГДА ЕСТЬNULL(до.Остаток, 0) &lt; 0
			ТОГДА -ЕСТЬNULL(до.Остаток, 0)
		ИНАЧЕ 0
	КОНЕЦ КАК ДолгНаш,
	ВЫБОР
		КОГДА до.ДатаПлатежа &lt; &amp;ТекДата
				И ЕСТЬNULL(до.Остаток, 0) &gt; 0
			ТОГДА ЕСТЬNULL(до.Остаток, 0)
		ИНАЧЕ 0
	КОНЕЦ КАК ДолгКлиентаПросроченный
ПОМЕСТИТЬ до1
ИЗ
	до КАК до

ИНДЕКСИРОВАТЬ ПО
	ЗаказКлиента
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	до1.Организация КАК Организация,
	до1.Клиент КАК Клиент,
	СУММА(до1.Остаток) КАК Остаток,
	СУММА(до1.ДолгКлиента) КАК ДолгКлиента,
	СУММА(до1.ДолгНаш) КАК ДолгНаш,
	СУММА(до1.ДолгКлиентаПросроченный) КАК ДолгКлиентаПросроченный
ИЗ
	до1 КАК до1

СГРУППИРОВАТЬ ПО
	до1.Клиент,
	до1.Организация</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Листы</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ссылка</dataPath>
			<field>Ссылка</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Ссылка</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЕстьЛист</dataPath>
			<field>ЕстьЛист</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Есть лист</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	т.Распоряжение КАК Ссылка,
	МАКСИМУМ(ИСТИНА) КАК ЕстьЛист
ИЗ
	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист КАК д
		ПО т.Ссылка = д.Ссылка
ГДЕ
	д.Проведен
СГРУППИРОВАТЬ ПО
	т.Распоряжение</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Предоплата</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Предоплата</dataPath>
			<field>Предоплата</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ссылка</dataPath>
			<field>Ссылка</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Ссылка</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.ОбъектРасчетов.Объект КАК Ссылка,
	СУММА(т.Оплачивается) КАК Предоплата
ИЗ
	РегистрНакопления.РасчетыСКлиентами КАК т
ГДЕ
	т.ОбъектРасчетов.Объект &lt;&gt; т.Регистратор
	И т.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)

СГРУППИРОВАТЬ ПО
	т.ОбъектРасчетов</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>Печать</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ссылка</dataPath>
			<field>Ссылка</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Ссылка</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЕстьСН</dataPath>
			<field>ЕстьСН</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Есть СН</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЕстьУПД</dataPath>
			<field>ЕстьУПД</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Есть УПД</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	реал.Ссылка КАК Ссылка
ПОМЕСТИТЬ Док
ИЗ
	Документ.РеализацияТоваровУслуг КАК реал
ГДЕ
	реал.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование))
	И реал.Склад = &amp;СкладПродукции

ИНДЕКСИРОВАТЬ ПО
	Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	т.Документ КАК Документ,
	МАКСИМУМ(т.Период) КАК ДатаОтмены
ПОМЕСТИТЬ вт1
ИЗ
	РегистрСведений.AMS_ИсторияРеализации КАК т
ГДЕ
	т.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ОтменаПечати)
СГРУППИРОВАТЬ ПО
	т.Документ

ИНДЕКСИРОВАТЬ ПО
	Документ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	т.Документ КАК Документ,
	МАКСИМУМ(т.Период) КАК ДатаСН
ПОМЕСТИТЬ вт2
ИЗ
	РегистрСведений.AMS_ИсторияРеализации КАК т
ГДЕ
	т.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ПечатьСН)
СГРУППИРОВАТЬ ПО
	т.Документ

ИНДЕКСИРОВАТЬ ПО
	Документ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	т.Документ КАК Документ,
	МАКСИМУМ(т.Период) КАК ДатаУПД
ПОМЕСТИТЬ вт3
ИЗ
	РегистрСведений.AMS_ИсторияРеализации КАК т
ГДЕ
	т.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ПечатьУПД)
	ИЛИ т.Событие = ЗНАЧЕНИЕ(Перечисление.AMS_СобытияРеализации.ПечатьТОРГ12)
СГРУППИРОВАТЬ ПО
	т.Документ

ИНДЕКСИРОВАТЬ ПО
	Документ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Док.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА вт1.ДатаОтмены ЕСТЬ NULL
			ТОГДА ВЫБОР
				КОГДА вт2.ДатаСН ЕСТЬ NULL
					ТОГДА ЛОЖЬ
				ИНАЧЕ ИСТИНА
			КОНЕЦ
		ИНАЧЕ ВЫБОР
			КОГДА вт2.ДатаСН &gt; вт1.ДатаОтмены
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	КОНЕЦ КАК ЕстьСН,
	ВЫБОР
		КОГДА вт1.ДатаОтмены ЕСТЬ NULL
			ТОГДА ВЫБОР
				КОГДА вт3.ДатаУПД ЕСТЬ NULL
					ТОГДА ЛОЖЬ
				ИНАЧЕ ИСТИНА
			КОНЕЦ
		ИНАЧЕ ВЫБОР
			КОГДА вт3.ДатаУПД &gt; вт1.ДатаОтмены
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ
	КОНЕЦ КАК ЕстьУПД
ИЗ
	Док КАК Док
		ЛЕВОЕ СОЕДИНЕНИЕ вт1 КАК вт1
		ПО Док.Ссылка = вт1.Документ
		ЛЕВОЕ СОЕДИНЕНИЕ вт2 КАК вт2
		ПО Док.Ссылка = вт2.Документ
		ЛЕВОЕ СОЕДИНЕНИЕ вт3 КАК вт3
		ПО Док.Ссылка = вт3.Документ</query>
	</dataSet>
	<dataSetLink>
		<sourceDataSet>Реализации</sourceDataSet>
		<destinationDataSet>Долги</destinationDataSet>
		<sourceExpression>Клиент</sourceExpression>
		<destinationExpression>Клиент</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>Реализации</sourceDataSet>
		<destinationDataSet>Листы</destinationDataSet>
		<sourceExpression>Ссылка</sourceExpression>
		<destinationExpression>Ссылка</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>Реализации</sourceDataSet>
		<destinationDataSet>Предоплата</destinationDataSet>
		<sourceExpression>Ссылка</sourceExpression>
		<destinationExpression>Ссылка</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>Реализации</sourceDataSet>
		<destinationDataSet>Долги</destinationDataSet>
		<sourceExpression>Организация</sourceExpression>
		<destinationExpression>Организация</destinationExpression>
	</dataSetLink>
	<dataSetLink>
		<sourceDataSet>Реализации</sourceDataSet>
		<destinationDataSet>Печать</destinationDataSet>
		<sourceExpression>Ссылка</sourceExpression>
		<destinationExpression>Ссылка</destinationExpression>
	</dataSetLink>
	<calculatedField>
		<dataPath>ДолгКлиента</dataPath>
		<expression>ЕСТЬNULL(ДолгКлиентаПросроченный, 0)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Долг клиента</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>Сальдо</dataPath>
		<expression>ЕСТЬNULL(ДолгНаш, 0) - ЕСТЬNULL(ДолгКлиентаПросроченный, 0)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Сальдо</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>СуммаЛимит</dataPath>
		<expression>ВЫБОР
		КОГДА Лимит &gt; 0
			ТОГДА ЕСТЬNULL(Остаток, 0) + СуммаДокумента
		ИНАЧЕ 0
КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Сумма лимит</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>ДолгНаш</dataPath>
		<expression>ЕСТЬNULL(ДолгНаш, 0)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Долг наш</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<calculatedField>
		<dataPath>ЦветФона</dataPath>
		<expression>ВЫБОР КОГДА Проведен
   ТОГДА ВЫБОР КОГДА ДатаОтгрузки &lt; &amp;ТекДата ТОГДА 1
      ИНАЧЕ ВЫБОР КОГДА ЕстьЛист  ТОГДА 2
         ИНАЧЕ ВЫБОР КОГДА УтвержденаОтгрузка ТОГДА 3 ИНАЧЕ 4
         КОНЕЦ
      КОНЕЦ
   КОНЕЦ
ИНАЧЕ 0
КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Цвет фона</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<totalField>
		<dataPath>Вес</dataPath>
		<expression>Сумма(Вес)</expression>
	</totalField>
	<totalField>
		<dataPath>Объем</dataPath>
		<expression>Сумма(Объем)</expression>
	</totalField>
	<parameter>
		<name>Период</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Период</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
	</parameter>
	<parameter>
		<name>ТекДата</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Тек дата</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>false</useRestriction>
	</parameter>
	<parameter>
		<name>СкладПродукции</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Склад продукции</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:CatalogRef.Склады</v8:Type>
		</valueType>
		<value xsi:nil="true"/>
		<useRestriction>false</useRestriction>
	</parameter>
	<settingsVariant>
		<dcsset:name>Основной</dcsset:name>
		<dcsset:presentation xsi:type="xs:string">Основной</dcsset:presentation>
		<dcsset:settings xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows">
			<dcsset:selection>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>ДатаОтгрузки</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Клиент</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Загрузка</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
					<dcsset:field>Ссылка</dcsset:field>
				</dcsset:item>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
