#Область Печать

&НаКлиенте
Процедура ПечатьКомплектДокумента(Команда)
	ТекущиеДанные = Элементы.Продажи.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Ложь;

	СпособДоставки  = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Реализация, "СпособДоставки");
	СпособСамовывоз = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление.СпособыДоставки.Самовывоз");
	Самовывоз      = (СпособДоставки = СпособСамовывоз);

	Если Не ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Реализация, "AMS_УтвержденаОтгрузка") Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Документ не утверждён к отгрузке.", , , , Отказ);
	КонецЕсли;

	Если Не Самовывоз И Не AMS_ВызовСервера.ВключенВЛогитическийЛист(Реализация) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Документ не включен в логистический лист.", , , , Отказ);
	КонецЕсли;

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Парам = Новый Структура("Документ", Реализация);
	ОткрытьФорму("Обработка.AMS_Продажи.Форма.ФормаПечать", Парам, ЭтотОбъект, , , , ,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

