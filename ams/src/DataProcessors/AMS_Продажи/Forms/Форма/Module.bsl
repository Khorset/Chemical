&НаСервереБезКонтекста
Функция ПолучитьЗаголовок()
	УстановитьПривилегированныйРежим(Истина);
	
	ТекДата = ТекущаяДатаСеанса();
	
	Если ДеньНедели(ТекДата) = 1 Тогда
		ДатаНачала    = НачалоНедели(НачалоНедели(ТекДата) - 3600);
		ДатаОкончания = КонецНедели(НачалоНедели(ТекДата) - 3600);
	Иначе
		ДатаНачала 	  = НачалоНедели(ТекДата);
		ДатаОкончания = КонецНедели(ТекДата);
	КонецЕсли;		

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	д.Ссылка КАК Ссылка,
	|	д.СуммаДокумента КАК СуммаДокумента
	|ПОМЕСТИТЬ Продано
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК д
	|ГДЕ
	|	д.Проведен
	|	И НЕ д.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))
	|	И д.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	д.Ссылка,
	|	д.СуммаДокумента
	|ИЗ
	|	Документ.ОтчетКомиссионера КАК д
	|ГДЕ
	|	д.Проведен
	|	И д.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(Продано.СуммаДокумента) КАК Продано
	|ПОМЕСТИТЬ вт1
	|ИЗ
	|	Продано КАК Продано
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	д.Ссылка КАК Ссылка,
	|	д.СуммаДокумента КАК Поступило
	|ПОМЕСТИТЬ Оплачено
	|ИЗ
	|	Документ.ПоступлениеБезналичныхДенежныхСредств КАК д
	|ГДЕ
	|	д.Проведен
	|	И д.ПроведеноБанком
	|	И д.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента)
	|	И д.ДатаПроведенияБанком МЕЖДУ &ДатаНачала И &ДатаОкончания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(Оплачено.Поступило) КАК Оплачено
	|ПОМЕСТИТЬ вт2
	|ИЗ
	|	Оплачено КАК Оплачено
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	вт1.Продано КАК Продано,
	|	вт2.Оплачено КАК Оплачено
	|ИЗ
	|	вт1 КАК вт1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт2 КАК вт2
	|		ПО (ИСТИНА)";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		ТекстЗаголовка = "План продаж";
		
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		
		Продано  = ?(Выб.Продано = NULL, 0, Выб.Продано);
		Оплачено = ?(Выб.Оплачено = NULL, 0, Выб.Оплачено);
		
		Если Продано = 0 И Оплачено = 0 Тогда
			ТекстЗаголовка = НСтр("ru='План продаж'");
		Иначе
			ТекстЗаголовка = НСтр("ru='Продано на %Продано% руб., Поступило %Оплачено% руб.'");
			ТекстЗаголовка = СтрЗаменить(ТекстЗаголовка, "%Продано%", ?(Продано = 0, "0", Формат(Продано, "ЧДЦ=0")));
			ТекстЗаголовка = СтрЗаменить(ТекстЗаголовка, "%Оплачено%", ?(Оплачено = 0, "0", Формат(Оплачено, "ЧДЦ=0")));
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТекстЗаголовка;
КонецФункции

&НаКлиенте
Процедура ПоказатьВозможностиСклада() Экспорт
	ИнфоСклад = ПолучитьВозвожностиСклада(ДатаВозможностиСклада);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьВозвожностиСклада(ДатаОтгрузки)
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаОтгрузки", ДатаОтгрузки);
	Запрос.УстановитьПараметр("СкладПродукции", AMS_ВызовСервера.СкладПродукции());

	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВЫБОР
	|		КОГДА т.ДокументОтгрузки ССЫЛКА Документ.ЗаказКлиента
	|			ТОГДА т.ДокументОтгрузки.ДатаОтгрузки
	|		ИНАЧЕ НАЧАЛОПЕРИОДА(т.ДокументОтгрузки.Дата, ДЕНЬ)
	|	КОНЕЦ КАК ДатаОтгрузки,
	|	т.ДокументОтгрузки КАК ДокументОтгрузки
	|ПОМЕСТИТЬ КОтгр
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &СкладПродукции) КАК т
	|ГДЕ
	|	(ТИПЗНАЧЕНИЯ(т.ДокументОтгрузки) = ТИП(Документ.ЗаказКлиента)
	|			ИЛИ ТИПЗНАЧЕНИЯ(т.ДокументОтгрузки) = ТИП(Документ.РеализацияТоваровУслуг))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(т.ДокументОтгрузки.AMS_УтвержденаОтгрузка, ЛОЖЬ) КАК УтвержденаОтгрузка,
	|	т.ДокументОтгрузки.AMS_КоличествоУпаковок КАК КоличествоУпаковок
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	КОтгр КАК т
	|ГДЕ
	|	т.ДатаОтгрузки = &ДатаОтгрузки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СУММА(ВЫБОР
	|			КОГДА вт.УтвержденаОтгрузка
	|				ТОГДА ЕСТЬNULL(вт.КоличествоУпаковок, 0)
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КОтгрузке,
	|	СУММА(ВЫБОР
	|			КОГДА НЕ вт.УтвержденаОтгрузка
	|				ТОГДА ЕСТЬNULL(вт.КоличествоУпаковок, 0)
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК Резерв
	|ИЗ
	|	вт КАК вт";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат "";
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();

		Возможность = AMS_ВызовСервера.ПолучитьВозможностиСклада(ДатаОтгрузки);
		Остаток     = Возможность - ?(Выб.КОтгрузке = NULL, 0, Выб.КОтгрузке) - ?(Выб.Резерв = NULL, 0, Выб.Резерв);

		Возврат "- " + Возможность + ": к отгрузке - " 
			+ ?(Выб.КОтгрузке = 0 Или Выб.КОтгрузке = NULL, "0", Формат(Выб.КОтгрузке, "ЧДЦ=0")) 
			+ ", в резерве - " + ?(Выб.Резерв = 0 Или Выб.Резерв = NULL, "0", Формат(Выб.Резерв, "ЧДЦ=0")) 
			+ ", остаток - " + Формат(Остаток, "ЧДЦ=0") + " упак.";
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ПоказатьНовыхКлиентов() Экспорт
