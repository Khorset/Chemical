&НаКлиенте
Процедура КнопкаСоздатьЗаказКлиента(Команда)
	ОткрытьФорму("Документ.ЗаказКлиента.ФормаОбъекта");
КонецПроцедуры

&НаКлиенте
Процедура КнопкаСоздатьРеализациюТоворомУслуг(Команда)
	ТекущиеДанные = Элементы.Продажи.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;		
	КонецЕсли;
		
	ЗаказКлиента = ТекущиеДанные.ЗаказКлиента;
	
	Если Не ЗначениеЗаполнено(ЗаказКлиента) Тогда
		Текст = "Не выбран заказ клиента.";
		ПоказатьПредупреждение(, Текст, 10);
		Возврат;
	КонецЕсли;
	
	Если Не AMS_ВызовСервера.ЭтоKhors() Тогда
		Отказ = Ложь;
		AMS_ВызовСервера.ПроверитьВозможностьСозданияРеализацииНаОснованииЗаказаКлиента(ЗаказКлиента, Отказ);
		Если Отказ Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	МассивСсылок = Новый Массив;
	МассивСсылок.Добавить(ЗаказКлиента);

	ПараметрыОткрытия = СозданиеНаОснованииУТВызовСервера.РеализацияТоваровУслугПараметрыОткрытияФормы(МассивСсылок);

	ОткрытьФорму("Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента", ПараметрыОткрытия);
КонецПроцедуры

&НаКлиенте
Процедура КнопкаОбеспечение(Команда)
	Отбор = Новый Структура;
	Отбор.Вставить("Дата", ОбщегоНазначенияКлиент.ДатаСеанса());
	Отбор.Вставить("СкладПродукции", AMS_ВызовСервера.СкладПродукции());

	Парам = Новый Структура;
	Парам.Вставить("КлючНазначенияИспользования", "Обеспечение");
	Парам.Вставить("СформироватьПриОткрытии", Истина);
	Парам.Вставить("ВидимостьКомандВариантовОтчетов", Ложь);
	Парам.Вставить("Отбор", Отбор);
		
	ОткрытьФорму("Отчет.AMS_Обеспечение.Форма", Парам, ЭтотОбъект);
КонецПроцедуры

