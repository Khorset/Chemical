&НаСервере
Процедура НастройкаФормы()
	Khors     = AMS_ВызовСервера.ЭтоKhors();
	БухМен    = Пользователи.РолиДоступны("_ГлавныйБухгалтер, _Бухгалтер, _СтаршийМенеджер, AMS_МенеджерПродаж"); // только Менеждеры
	БухСклада = Пользователи.РолиДоступны("_БухгалтерСклада");
	Склад     = Пользователи.РолиДоступны("_НачальникСклада, _КладовщикСклада");

	ТекСтр       = Элементы.Страницы.ТекущаяСтраница;
	ТекСтрПрайса = Элементы.СтраницыПрайсов.ТекущаяСтраница;
	
	ТекСтрПродажи = ТекСтр = Элементы.СтраницаПродажи;

	Элементы.ФормаВыполнитьВыгрузкуПродаж.Видимость = Khors;

	Элементы.ГруппаШапкаПланПродаж.Видимость  = ТекСтрПродажи;
	Элементы.ГруппаШапкаБланк_Прайс.Видимость = Не ТекСтрПродажи;
	Элементы.ГруппаПечать.Видимость           = Не ТекСтрПродажи;
	
	Элементы.ГруппаВыборКлиентаБланк_Прайс.Видимость  = (ТекСтр = Элементы.СтраницаБланк Или ТекСтрПрайса = Элементы.СтраницаПрайс);
														
	Элементы.ИнфоНовыеКлиенты.Видимость = Не ПустаяСтрока(ИнфоНовыеКлиенты) И Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаПродажи;

	Если (БухСклада Или Склад) И Не Khors Тогда
		Элементы.СтраницаБланк.Видимость = Ложь;		
		Элементы.СтраницаПрайсы.Видимость = Ложь;
	КонецЕсли;

	Элементы.Продажи.КонтекстноеМеню.Видимость = БухМен;

	Элементы.ПродажиПечатьКомплектДокумента.Видимость                = БухСклада;
	Элементы.ПродажиПечатьУПД.Видимость                              = БухМен Или БухСклада;
	Элементы.ПродажиПечатьСкладскаяНакладная.Видимость               = БухМен Или БухСклада Или Склад;
	Элементы.ПродажиПечатьСчетНаОплату.Видимость                     = БухМен;
	Элементы.ПродажиПечатьДоверенность.Видимость                     = БухМен Или БухСклада;
	Элементы.ПродажиПечатьТранспортнаяНакладная.Видимость            = БухМен Или БухСклада;
	Элементы.ПродажиПечатьТТН.Видимость                              = БухМен Или БухСклада;
	Элементы.ПродажиПечатьТОРГ_12.Видимость                          = БухМен Или БухСклада;
	Элементы.ПродажиПечатьСчетФактура.Видимость                      = БухМен Или БухСклада;
	Элементы.ПродажиПечатьСпецификации.Видимость                     = БухМен Или БухСклада;
	Элементы.ПродажиПечатьАктаОРасхождениях.Видимость                = БухМен Или БухСклада;
	Элементы.ПродажиПечатьПалетнаяЭтикетка.Видимость                 = БухМен Или БухСклада Или Склад;
	Элементы.ПродажиПечатьЗаявкаПеревозчику.Видимость                = БухМен Или БухСклада;
	Элементы.ПродажиПечатьСертификатыНоменклатурыРеестр.Видимость    = БухМен Или БухСклада;
	Элементы.ПродажиПечатьСертификатыНоменклатурыБезДублей.Видимость = БухМен Или БухСклада;
	Элементы.ПродажиПечатьНакладнаяНаПалеты.Видимость                = БухМен Или БухСклада;
	
	Элементы.ПродажиПечатьРазрешитьИзменения.Видимость = БухСклада;

	Элементы.ПродажиГруппаОтчеты.Видимость     = БухМен;
	Элементы.ПродажиГруппаДополнительныеОтчеты.Видимость = БухМен;
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	УсловноеОформление.Элементы.Очистить();

	// Просрочен - Красный
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Продажи.Имя);
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Объект.Продажи.Цвет");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = 1;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.ЛососьТемный);

	// Разрешить отгрузку - Зелёный
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Продажи.Имя);
