#Область ОбработчикиСобытийЭлементовТаблицыФормыПродажи

&НаКлиенте
Процедура ПродажиПриАктивизацииСтроки(Элемент)
	Стр = Элементы.Продажи.ТекущиеДанные;

	Если Стр = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаказКлиента = Стр.ЗаказКлиента;
	Реализация   = Стр.Реализация;
	
	Если ЗначениеЗаполнено(Реализация) Тогда
		Данные = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(Реализация, "AMS_ПравилоПродажи, Соглашение, АдресДоставки");
		Элементы.ПродажиГруппаПечатьОтРеализации.Видимость = Истина;
	Иначе
		Данные = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(ЗаказКлиента, "AMS_ПравилоПродажи, Соглашение, АдресДоставки");
		Элементы.ПродажиГруппаПечатьОтРеализации.Видимость = Ложь;
	КонецЕсли;

	Партнер        = Стр.Клиент;
	ПравилоПродажи = Данные.AMS_ПравилоПродажи;
	Соглашение     = Данные.Соглашение;
	АдресДоставки  = Данные.АдресДоставки;
	ИнфоЛимит      = ?(Стр.Лимит > 0, "Лимит: " + Стр.Лимит + "/" + Стр.СуммаЛимит, "");
КонецПроцедуры

&НаКлиенте
Процедура ПродажиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Стр = Элемент.ТекущиеДанные;

	Если Стр = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "ПродажиСуммаДокумента" Или Поле.Имя = "ПродажиДолгКлиентаПросрочен"
		Или Поле.Имя = "ПродажиДолгНаш" Или Поле.Имя = "ПродажиСуммаЛимит" Тогда
		
		Отбор = Новый Структура;
		Отбор.Вставить("Организация", Стр.Организация);
		Отбор.Вставить("Клиент", Стр.Клиент);
	
		Парам = Новый Структура;
		Парам.Вставить("ВидимостьКомандВариантовОтчетов", Ложь);
		Парам.Вставить("СформироватьПриОткрытии", Истина);
		Парам.Вставить("КлючНазначенияИспользования", Стр.Клиент);
		Парам.Вставить("Отбор", Отбор);
	
		ОткрытьФорму("Отчет.AMS_РасчетыСКлиентами.Форма", Парам, ЭтотОбъект);
			
	ИначеЕсли Не ЗначениеЗаполнено(Стр.ЗаказКлиента) И ЗначениеЗаполнено(Стр.Реализация) Тогда
		ПоказатьЗначение(, Стр.Реализация);
	
	ИначеЕсли ЗначениеЗаполнено(Стр.ЗаказКлиента) И Не ЗначениеЗаполнено(Стр.Реализация) Тогда
		ПоказатьЗначение(, Стр.ЗаказКлиента);
	
	ИначеЕсли Поле.Имя = "ПродажиСостоянияЗаказ" Или Поле.Имя = "ПродажиНомер" Или Поле.Имя = "ПродажиДата" Тогда
		ПоказатьЗначение(, Стр.ЗаказКлиента);
	
	Иначе	
		ПоказатьЗначение(, Стр.Реализация);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

