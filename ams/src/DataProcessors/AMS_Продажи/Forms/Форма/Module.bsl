
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	УстановитьОтключениеБезопасногоРежима(Истина);
	
	ДатаВозможностиСклада = мср.ПолучитьРабочийДень(1);
	
	УстановитьДатыПрайса();
	
	УстановитьУсловноеОформление();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	НастройкаФормы();
	
	ПоказатьПродажи();
	
	Заголовок = ПолучитьЗаголовок();
	
	ПодключитьОбработчикОжидания("ОбновитьЗаголовокФормы", 60);
	ПодключитьОбработчикОжидания("ПоказатьВозможностиСклада", 0.1, Истина);
	ПодключитьОбработчикОжидания("ПоказатьНовыхКлиентов", 1, Истина);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Запись_ЗаказКлиента" 
		Или ИмяСобытия = "Запись_ОтгрузкаТоваровКлиенту"
		Или ИмяСобытия = "Запись_РеализацияТоваровУслуг"
		Или ИмяСобытия = "Запись_ЛогистическийЛист" 
		Или ИмяСобытия = "Запись_РасходныйОрдерНаТовары" Тогда
			
		ПоказатьПродажи();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ГруппаДоступаПриИзменении(Элемент)
	ПоказатьПродажи();
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	ПодключитьОбработчикОжидания("ПоказатьВозможностиСклада", 0.1, Истина);
КонецПроцедуры

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если ТекущаяСтраница = Элементы.СтраницаПродажи Тогда
		ПоказатьПродажи();

	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаБланк Тогда
		СформироватьБланкЗаказа();

	ИначеЕсли ТекущаяСтраница = Элементы.СтраницаПрайсы Тогда
		СформироватьПрайсЛист();
	КонецЕсли;
	
	НастройкаФормы();
КонецПроцедуры

&НаКлиенте
Процедура СтраницыПрайсовПриСменеСтраницы(Элемент, ТекущаяСтраница)
	УстановитьДатыПрайса();
	СформироватьПрайсЛист();
	НастройкаФормы();
КонецПроцедуры

&НаКлиенте
Процедура ПартнерПриИзменении(Элемент)
	ПартнерПриИзмененииНаСервере();

	Если Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаБланк Тогда
		СформироватьБланкЗаказа();

	ИначеЕсли Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаПрайсы Тогда
		СформироватьПрайсЛист();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПравилоПродажиПриИзменении(Элемент)
	ЗаполнитьШапкуПоПравилуПродаж();

	Если Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаБланк Тогда
