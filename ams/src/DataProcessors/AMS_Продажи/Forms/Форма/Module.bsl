&НаКлиенте
Процедура ПечатьПрайс(Команда)
	ТекСтр = Элементы.Страницы.ТекущаяСтраница;
	
	Если ТекСтр = Элементы.СтраницаБланк Тогда
		ТабДок = ТабДокБланк;
	
	ИначеЕсли ТекСтр = Элементы.СтраницаПрайсы Тогда
		ТекСтр = Элементы.СтраницыПрайсов.ТекущаяСтраница;
		
		Если ТекСтр = Элементы.СтраницаПрайс Тогда
			ТабДок = ТабДокПрайс;
		
		ИначеЕсли ТекСтр = Элементы.СтраницаПрайсОпт Тогда
			ТабДок = ТабДокПрайсОпт;
			
		ИначеЕсли ТекСтр = Элементы.СтраницаПрайсОптСНГ Тогда
			ТабДок = ТабДокПрайсОптСНГ;
			
		ИначеЕсли ТекСтр = Элементы.СтраницаПрайсСети Тогда
			ТабДок = ТабДокПрайсСети;
			
		ИначеЕсли ТекСтр = Элементы.СтраницаПрайсМЕГА Тогда
			ТабДок = ТабДокПрайсМЕГА;
			
		КонецЕсли;
	КонецЕсли;

	Массив = Новый Массив;
	Массив.Добавить(Партнер);

	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Обработка.AMS_Продажи", "Прайс", Массив, Неопределено,
		Новый Структура("ТабличныйДокумент", ТабДок));
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьExcel(Команда)
	ЭтоБланкЗаказа  = Ложь;
	
	ТекСтр = Элементы.Страницы.ТекущаяСтраница;
	
	Если ТекСтр = Элементы.СтраницаБланк Тогда
		Если Не ЗначениеЗаполнено(Партнер) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Не заполнено поле ""Партнер"".'"));
			Возврат;
		КонецЕсли;
		
		ИмяПартнера    = СокрЛП(ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Партнер, "Наименование"));
		ИмяФайла       = "Бланк заказа " + ИмяПартнера;
		ЭтоБланкЗаказа = Истина;;
		ТабДок         = ТабДокБланк;
	
	ИначеЕсли ТекСтр = Элементы.СтраницаПрайсы Тогда
		ТекСтр = Элементы.СтраницыПрайсов.ТекущаяСтраница;

		Если ТекСтр = Элементы.СтраницаПрайс Тогда
			Если Не ЗначениеЗаполнено(Партнер) Тогда
				ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Не заполнено поле ""Партнер"".'"));
				Возврат;
			КонецЕсли;
			
			ИмяПартнера = СокрЛП(ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Партнер, "Наименование"));
			ИмяФайла    = "Прайс-лист " + ИмяПартнера;
			ТабДок      = ТабДокПрайс;
		
		ИначеЕсли ТекСтр = Элементы.СтраницаПрайсОпт Тогда
			ИмяФайла    = "Прайс-лист оптовый бытовая химия";
			ТабДок = ТабДокПрайсОпт;
	
		ИначеЕсли ТекСтр = Элементы.СтраницаПрайсОптСНГ Тогда
			ИмяФайла    = "Прайс-лист оптовый бытовая химия (СНГ)";
			ТабДок = ТабДокПрайсОптСНГ;
	
		ИначеЕсли ТекСтр = Элементы.СтраницаПрайсСети Тогда
			ИмяФайла    = "Прайс-лист оптовый бытовая химия (Сети)";
			ТабДок = ТабДокПрайсСети;
		
		ИначеЕсли ТекСтр = Элементы.СтраницаПрайсМЕГА Тогда
			ИмяФайла    = "Прайс-лист МЕГА";
			ТабДок = ТабДокПрайсМЕГА;
		КонецЕсли;
	КонецЕсли;

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок          = "Выберите каталог для сохранения ЗАКАЗА";
	Диалог.Фильтр             = "Файлы Excel (*.xlsx;*.xls)|*.xlsx;*.xls|";
	Диалог.МножественныйВыбор = Ложь;
	Диалог.ПолноеИмяФайла     = ИмяФайла;

	Если Диалог.Выбрать() Тогда
		Состояние("Создание файла EXCEL.");

		ИмяФайла = Диалог.ПолноеИмяФайла;

		ТабДок.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.XLSX);

		Если ЭтоБланкЗаказа Тогда
			ОтредактироватьФайлЗаказаEXCEL(ИмяФайла);
		КонецЕсли;

		Состояние();
	КонецЕсли;
КонецПроцедуры

