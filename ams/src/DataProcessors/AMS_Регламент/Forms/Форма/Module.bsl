	Если ЗначениеЗаполнено(Документ) Тогда
		ДокументОбъект = Документ.ПолучитьОбъект();
		ДокументОбъект.AMS_ПравилоПродажи = Справочники.AMS_ПравилаПродаж.ПустаяСсылка();
		ДокументОбъект.Записать();
	КонецЕсли;
