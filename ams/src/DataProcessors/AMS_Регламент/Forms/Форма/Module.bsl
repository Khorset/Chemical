&НаСервереБезКонтекста
Функция ПолучитьПомеченноеНаУдалениеПравило(Партнер)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Владелец", Партнер);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Ссылка
	|ИЗ
	|	Справочник.AMS_ПравилаПродаж КАК т
	|ГДЕ
	|	т.Владелец = &Владелец
	|	И т.ПометкаУдаления";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Справочники.AMS_ПравилаПродаж.ПустаяСсылка();
	Иначе
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Ссылка;
	КонецЕсли;
КонецФункции

&НаСервере
Процедура ЗаполнитьТаблицуРеализаций()
	Если ЗначениеЗаполнено(Правило) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Правило", Правило);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	д.Ссылка КАК Документ
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК д
		|ГДЕ
		|	д.AMS_ПравилоПродажи = &Правило
		|
		|УПОРЯДОЧИТЬ ПО
		|	д.МоментВремени";
		
		Табл = РеквизитФормыВЗначение("РеализацииДляУдаленияПравил");
		Табл = Запрос.Выполнить().Выгрузить();
		ЗначениеВРеквизитФормы(Табл,"РеализацииДляУдаленияПравил");
	Иначе
		РеализацииДляУдаленияПравил.Очистить();
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УдалитьВсеПравилаНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПравилаПродаж.Ссылка КАК Правило,
	|	Реализация.Ссылка КАК Реализация
	|ИЗ
	|	Справочник.AMS_ПравилаПродаж КАК ПравилаПродаж
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
	|		ПО ПравилаПродаж.Ссылка = Реализация.AMS_ПравилоПродажи
	|ГДЕ
	|	ПравилаПродаж.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПравилаПродаж.Наименование,
	|	Реализация.МоментВремени";
	
	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	
	Пока Выб.Следующий() Цикл
		УдалитьПравило(Выб.Реализация);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПравилаПродаж.Ссылка КАК Правило,
	|	ЗаказКлиента.Ссылка КАК Реализация
	|ИЗ
	|	Справочник.AMS_ПравилаПродаж КАК ПравилаПродаж
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ЗаказКлиента
	|		ПО ПравилаПродаж.Ссылка = ЗаказКлиента.AMS_ПравилоПродажи
	|ГДЕ
	|	ПравилаПродаж.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПравилаПродаж.Наименование,
	|	ЗаказКлиента.МоментВремени";
	
	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	
	Пока Выб.Следующий() Цикл
		УдалитьПравило(Выб.Реализация);
	КонецЦикла;
	
КонецПроцедуры

