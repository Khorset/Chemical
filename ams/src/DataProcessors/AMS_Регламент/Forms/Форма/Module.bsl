&НаСервере
Процедура ЗаписатьПродажиПоМесяцам()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаНачала", Период.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", Период.ДатаОкончания);
	Запрос.УстановитьПараметр("ВидыНоменклатуры", AMS_ВызовСервера.ВидыНоменклатурыПродукции());
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	НАЧАЛОПЕРИОДА(д.Дата, МЕСЯЦ) КАК Дата,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ д.Ссылка) КАК КоличествоПродаж,
	|	т.Номенклатура КАК Номенклатура,
	|	н.Наименование КАК Наименование,
	|	СУММА(т.Количество) КАК Количество
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК д
	|		ПО т.Ссылка = д.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК н
	|		ПО т.Номенклатура = н.Ссылка
	|ГДЕ
	|	д.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И д.Проведен
	|	И н.ВидНоменклатуры В (&ВидыНоменклатуры)
	|
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(д.Дата, МЕСЯЦ),
	|	т.Номенклатура,
	|	н.Наименование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Дата КАК Период,
	|	вт.Номенклатура КАК Номенклатура,
	|	вт.КоличествоПродаж КАК КоличествоПродаж,
	|	вт.Количество КАК Количество
	|ИЗ
	|	вт КАК вт
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период,
	|	вт.Наименование
	|ИТОГИ ПО
	|	Период";
	
	Рез = Запрос.Выполнить();
	
	ВыбДата = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыбДата.Следующий() Цикл
		Набор = РегистрыСведений._ПродажиПоМесяцам.СоздатьНаборЗаписей();
		
		Набор.Отбор.Период.Установить(ВыбДата.Период);
		Набор.Прочитать();
		Набор.Очистить();
	
		ВыбНом = ВыбДата.Выбрать();
		Пока ВыбНом.Следующий() Цикл
			Стр = Набор.Добавить();
			ЗаполнитьЗначенияСвойств(Стр,ВыбНом);
		КонецЦикла;
		
		Набор.Записать();
	КонецЦикла;
КонецПроцедуры

