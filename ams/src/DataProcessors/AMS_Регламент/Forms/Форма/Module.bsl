&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если НЕ AMS_ВызовСервера.ЭтоKhors() Тогда
		Отказ = Истина;
	КонецЕсли;
	
	
	// НАСТРОЙКА ПЕРИОДА
	Если НЕ ЗначениеЗаполнено(Объект.НачалоПериода) Тогда
        Объект.НачалоПериода = НачалоГода(ТекущаяДатаСеанса());
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.КонецПериода) Тогда
		Объект.КонецПериода = ТекущаяДатаСеанса();
	КонецЕсли;
КонецПроцедуры

