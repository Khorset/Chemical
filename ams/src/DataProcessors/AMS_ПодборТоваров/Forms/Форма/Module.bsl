
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = "Клиент";

	ТипПродукции = Новый Структура();
	ТипПродукции.Вставить("Химия", Справочники.AMS_Продукция.НайтиПоКоду("001"));
	ТипПродукции.Вставить("Косметика", Справочники.AMS_Продукция.НайтиПоКоду("002"));
	ТипПродукции.Вставить("Моющие", Справочники.AMS_Продукция.НайтиПоКоду("003"));
	ТипПродукции.Вставить("Наборы", Справочники.AMS_Продукция.НайтиПоКоду("044"));
	ТипПродукции.Вставить("ХозТовары", Справочники.AMS_Продукция.НайтиПоКоду("049"));
	ТипПродукции.Вставить("Контракт", Справочники.AMS_Продукция.НайтиПоКоду("039"));

	АдресДанных = Неопределено;
	Если Параметры.Свойство("АдресДанных", АдресДанных) Тогда
		ЗагрузитьИсходнуюТаблицуТовары(АдресДанных);
	КонецЕсли;
	
	Элементы.СтраницаТовары.Видимость = AMS_ВызовСервера.ЭтоKhors();
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		Элементы.ПодборДоступно.Видимость          = Ложь;
		Элементы.ХимияДоступно.Видимость           = Ложь;
		Элементы.КосметикаДоступно.Видимость       = Ложь;
		Элементы.МоющиеДоступно.Видимость          = Ложь;
		Элементы.ДеревоНаборыДоступно.Видимость    = Ложь;
		Элементы.ДеревоХозтоварыДоступно.Видимость = Ложь;
		Элементы.КонтрактДоступно.Видимость        = Ложь;
	КонецЕсли;
	
	УстановитьУсловноеОформление();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПоказатьДанныеФормыПодбора();
	ЗагрузитьТаблицыВыбораТоваров();
	ЗаполнитьКоличествоПалетВес();
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, СтандартнаяОбработка)
	Если Модифицированность Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект), НСтр(
			"ru = 'Данные были изменены. Перенести изменения в документ?'"), РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОтборПриИзменении(Элемент)
	ПоказатьДанныеФормыПодбора();
КонецПроцедуры

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаПодбор Тогда
		ПоказатьПодбор();
	Иначе
		ЗагрузитьТаблицыВыбораТоваров();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПодбор

&НаКлиенте
Процедура ПодборКоличествоУпаковокПриИзменении(Элемент)
	Стр = Подбор.НайтиПоИдентификатору(Элементы.Подбор.ТекущаяСтрока);
	
	Если Стр.КоличествоУпаковок = 0 Тогда
		ИндексСтроки = Стр.НомерСтроки - 1;
		
		Подбор.Удалить(Подбор.Индекс(Стр));
		
		СчСтрок = 0;
		Для каждого СтрПодбор Из Подбор Цикл
			СчСтрок = СчСтрок + 1;
			СтрПодбор.НомерСтроки = СчСтрок;
		КонецЦикла;
		
		Если ИндексСтроки + 1 > СчСтрок Тогда
			ИндексСтроки = ИндексСтроки - 1;
		КонецЕсли;
		
		Если ИндексСтроки > 0 Тогда
			Элементы.Подбор.ТекущаяСтрока=Подбор[ИндексСтроки].ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
	
	СтрТовары = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Стр.Номенклатура))[0];

	Стр.Остаток = Стр.Доступно - Стр.КоличествоУпаковок;

	Сумма = Стр.Цена * Стр.КоличествоУпаковок;
	
	Если Стр.ФлагСкидка Тогда
		Стр.Сумма = Сумма - Сумма * Стр.ПроцентРучнойСкидки / 100;
	Иначе
		Стр.Сумма = Сумма; 
	КонецЕсли;
	
	СтрТовары.КоличествоУпаковок = Стр.КоличествоУпаковок;
	СтрТовары.Сумма              = Стр.Сумма;
	
	ЗаполнитьКоличествоПалетВес();
КонецПроцедуры

&НаКлиенте
Процедура ПодборЦенаПриИзменении(Элемент)
	Стр = Подбор.НайтиПоИдентификатору(Элементы.Подбор.ТекущаяСтрока);
	
	Если Стр.Цена = Стр.ЦенаСоглашение Тогда
		Стр.ВидЦены = Стр.ВидЦеныСоглашение;
	Иначе
		Стр.ВидЦены = ПредопределенноеЗначение("Справочник.ВидыЦен.ПустаяСсылка");
	КонецЕсли;	

	СтрТовары = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Стр.Номенклатура))[0];

	Сумма = Стр.Цена * Стр.КоличествоУпаковок;
	
	Если Стр.ФлагСкидка Тогда
		Стр.СуммаРучнойСкидки = Сумма * Стр.ПроцентРучнойСкидки / 100;
		Стр.Сумма = Сумма - Стр.СуммаРучнойСкидки;
	Иначе
		Стр.Сумма   = Сумма; 
	КонецЕсли;
	
	СтрТовары.Сумма = Стр.Сумма;
КонецПроцедуры

&НаКлиенте
Процедура ПодборФлагСкидкаПриИзменении(Элемент)
	Стр = Подбор.НайтиПоИдентификатору(Элементы.Подбор.ТекущаяСтрока);
	
	Сумма = Стр.Цена * Стр.КоличествоУпаковок;
	
	Если Стр.ФлагСкидка Тогда
		Стр.Сумма = Сумма - Сумма * Стр.ПроцентРучнойСкидки / 100;
	Иначе
		Стр.Сумма = Сумма; 
	КонецЕсли;
КонецПроцедуры

