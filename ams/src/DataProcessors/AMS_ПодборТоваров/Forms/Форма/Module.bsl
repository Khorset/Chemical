#Область ЗагрузкаИзБланкаЗаказа

&НаКлиенте
Функция ПолучитьДанныеИзБланкаЗаказа(ИмяФайла, Отказ) Экспорт
	ВыбФайл = Новый Файл(ИмяФайла);
	Если Не ВыбФайл.Существует() Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Файл не существует!");
		Возврат Неопределено;
	КонецЕсли;

	Попытка
		Excel = Новый COMОбъект("Excel.Application");
		Excel.Visible       = Ложь;
		Excel.DisplayAlerts = Ложь;
		Excel.WorkBooks.Open(ИмяФайла);
		ExcelЛист = Excel.Sheets(1);
	Исключение
		ОбщегоНазначенияКлиент.СообщитьПользователю("Ошибка. Возможно неверно указан номер листа книги Excel.");
		Возврат Неопределено;
	КонецПопытки;

	ExcelЛист.Unprotect("Sergik");

	ВсегоСтрок = ExcelЛист.Cells(1, 1).SpecialCells(11).Row;
	ВсегоКолонок = ExcelЛист.UsedRange.Columns.Count();
	
	Если ВсегоКолонок = 18 Или ВсегоКолонок = 19 Или ВсегоКолонок >= 21 Тогда
		Если ВсегоКолонок = 18 Тогда
			КолонкаКодТовара  = 6;
			КолонкаКоличество = 14;
			
		ИначеЕсли ВсегоКолонок = 19 Тогда
			КолонкаКодТовара = 7;
			КолонкаКоличество = 15;
			
		ИначеЕсли ВсегоКолонок >= 21 Тогда
			КолонкаКодТовара = 2;
			КолонкаКоличество = 16;
		КонецЕсли;

		МассивКодТовара  = ExcelЛист.Range(ExcelЛист.Cells(10, КолонкаКодТовара), ExcelЛист.Cells(ВсегоСтрок, КолонкаКодТовара)).Value.Выгрузить()[0];
		МассивКоличество = ExcelЛист.Range(ExcelЛист.Cells(10, КолонкаКоличество), ExcelЛист.Cells(ВсегоСтрок, КолонкаКоличество)).Value.Выгрузить()[0];
		
	Иначе 
		КолонкаКодТовара  = 2;
		КолонкаКоличество = 15;
		
		МассивКодТовара  = ExcelЛист.Range(ExcelЛист.Cells(9, КолонкаКодТовара), ExcelЛист.Cells(ВсегоСтрок, КолонкаКодТовара)).Value.Выгрузить()[0];
		МассивКоличество = ExcelЛист.Range(ExcelЛист.Cells(9, КолонкаКоличество), ExcelЛист.Cells(ВсегоСтрок, КолонкаКоличество)).Value.Выгрузить()[0];
	КонецЕсли;

	Excel.WorkBooks.Close();
	Excel.Quit();
	Excel.DisplayAlerts = Истина;

	МассивСтрок = Новый Массив;

	Индекс = МассивКоличество.Количество() - 1;
	Для Сч = 0 По Индекс Цикл
		КодТовара = МассивКодТовара[Сч];
		
		Если КодТовара = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Количество = МассивКоличество[Сч];

		Если Не (Количество = Неопределено Или Количество = "") И Количество > 0 Тогда
			МассивСтрок.Добавить(Новый Структура("КодТовара,Количество", КодТовара, Количество));

			Если Не Количество = Цел(Количество) Тогда
				Номенклатура = AMS_ВызовСервера.ПолучитьНоменклатуруПоКоду(КодТовара);
				ОбщегоНазначенияКлиент.СообщитьПользователю("Для товара """ + Номенклатура
					+ """ указано не целое количество упаковок (" + Окр(Количество, 3) + ").", , , , Отказ);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Возврат МассивСтрок;
КонецФункции

&НаКлиенте
Процедура ЗагрузитьИзБланкаЗаказаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ОчиститьСообщения();

	Для каждого Стр Из Результат Цикл
		СтрТовары = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Стр.Номенклатура))[0];
		
		Кфц = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Стр.Номенклатура, "КоэффициентЕдиницыДляОтчетов");
		
		СтрТовары.КоличествоУпаковок = Стр.Количество / Кфц;
		СтрТовары.Сумма = СтрТовары.КоличествоУпаковок * СтрТовары.Цена;
	КонецЦикла;
	
	ПоказатьДанныеФормыПодбора();
КонецПроцедуры

