&НаКлиенте
Процедура ЗагрузитьИзВнешнегоФайла(Команда)
	Парам = Новый Структура("Партнер", Партнер);
	Оповещение = Новый ОписаниеОповещения("ЗагрузитьИзВнешнегоФайлаЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Обработка.AMS_ПодборТоваров.Форма.ФормаЗагрузкиИзВнешнегоФайла", Парам,
		ЭтотОбъект,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзДокументовРеализации(Команда)
	Отказ = Ложь;
	
	Если Не ЗначениеЗаполнено(Объект.Партнер) Тогда 
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не заполнено поле ""Клиент""",,,,Отказ);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Соглашение) Тогда 
		ОбщегоНазначенияКлиент.СообщитьПользователю("Не заполнено поле ""Соглашение""",,,,Отказ);
	КонецЕсли;

	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	
//	Парам = Новый Структура("АдресДанных", АМС_ВызовСервера.ПоместитьВоВременноеХранилищеТовары(Объект));
//	
//	ОткрытьФорму("Документ.РеализацияТоваровУслуг.Форма.AMS_ФормаДобавленияТовара",Парам,,,,,
//		Новый ОписаниеОповещения("AMS_ОткрытьФормуДобавленияТовараЗавершение",ЭтотОбъект),
//		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзБланкаЗаказа(Команда)
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок          = "Выберите файл";
	Диалог.Каталог            = "d:\Архив\";
	Диалог.ПолноеИмяФайла     = "";
	Диалог.Фильтр             = "Файлы Excel (*.xls, *.xlsx)|*.xl*";
	Диалог.МножественныйВыбор = Ложь;
	
	Если Диалог.Выбрать() Тогда
		Состояние("Загрузка данных их файла EXCEL");
		
		Отказ = Ложь;
		
		МассивСтрок = ПолучитьДанныеИзБланкаЗаказа(Диалог.ПолноеИмяФайла,Отказ);
		
		Если Отказ Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;

	Парам = Новый Структура;
	Парам.Вставить("МассивСтрок", МассивСтрок);
	Парам.Вставить("Партнер", Партнер);

	Оповещение = Новый ОписаниеОповещения("ЗагрузитьИзБланкаЗаказаЗавершение", ЭтотОбъект); 
	
	ОткрытьФорму("Обработка.AMS_ПодборТоваров.Форма.ФормаЗагрузкиИзБланкаЗаказа", Парам,
		ЭтотОбъект,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗагрузитьИсходнуюТаблицуТовары(АдресДанных)
	УстановитьПривилегированныйРежим(Истина);

	Данные = ПолучитьИзВременногоХранилища(АдресДанных);

	Ссылка = Данные.Ссылка;

	Стр = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Данные.Партнер, "_АртикулКлиента, _АртикулКлиентаПлюс");

	СортироватьПоЗаказу = Стр._АртикулКлиента Или Стр._АртикулКлиентаПлюс;

	МВТ = Новый МенеджерВременныхТаблиц;
	
	ПараметрыМВТ = Новый Структура();
	ПараметрыМВТ.Вставить("ДатаЦены", Данные.ДатаДокумента);
	ПараметрыМВТ.Вставить("МЕГА", Справочники.ЦеновыеГруппы.НайтиПоНаименованию("МЕГА", Истина));
	ПараметрыМВТ.Вставить("Соглашение", Данные.Соглашение);
	//@skip-check bsl-legacy-check-string-literal
	ПараметрыМВТ.Вставить("ВидЦены", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные.Соглашение, "ВидЦен"));
	ПараметрыМВТ.Вставить("Партнер", Данные.Партнер);
	ПараметрыМВТ.Вставить("ПравилоПродажи", Данные.ПравилоПродажи);
	
	AMS_ВызовСервера.ПолучитьПродукцию(МВТ, ПараметрыМВТ);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;

	Запрос.УстановитьПараметр("ДатаПроизводства",    ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ДатаДокумента",       Данные.ДатаДокумента);
	Запрос.УстановитьПараметр("Проведен",            Данные.Проведен);
	Запрос.УстановитьПараметр("СортироватьПоЗаказу", СортироватьПоЗаказу);
	Запрос.УстановитьПараметр("Товары",              Данные.Товары);
	Запрос.УстановитьПараметр("СкладПродукции",      AMS_ВызовСервера.СкладПродукции());

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество,
	|	т.ВидЦены КАК ВидЦены,
	|	т.Сумма КАК Сумма,
	|	т.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки
	|ПОМЕСТИТЬ ЗагрузкаДок
	|ИЗ
	|	&Товары КАК т
	|ГДЕ
	|	т.Количество > 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗагрузкаДок.Номенклатура КАК Номенклатура,
	|	ЗагрузкаДок.ВидЦены КАК ВидЦеныДокумент,
	|	СУММА(ЗагрузкаДок.Количество) КАК Количество,
	|	СУММА(ЗагрузкаДок.Сумма) / СУММА(ЗагрузкаДок.Количество) КАК ЦенаДокумент,
	|	СУММА(ЗагрузкаДок.Сумма) КАК Сумма,
	|	МАКСИМУМ(ЗагрузкаДок.ПроцентРучнойСкидки) КАК ПроцентРучнойСкидки
	|ПОМЕСТИТЬ ТовДок
	|ИЗ
	|	ЗагрузкаДок КАК ЗагрузкаДок
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗагрузкаДок.Номенклатура,
	|	ЗагрузкаДок.ВидЦены
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	СУММА(т.КоличествоПлан) КАК План1,
	|	СУММА(т.КоличествоФакт) КАК Факт1
	|ПОМЕСТИТЬ Произ1
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК д
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ПроизводствоЗаСмену.Продукция КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	НЕ д.ПометкаУдаления
	|	И д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаПроизводства, ДЕНЬ) И КОНЕЦПЕРИОДА(&ДатаПроизводства, ДЕНЬ)
	|	И д.Смена = ЗНАЧЕНИЕ(Перечисление._ПроизводственныеСмены.Дневная)
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	СУММА(т.КоличествоПлан) КАК План2,
	|	СУММА(т.КоличествоФакт) КАК Факт2
	|ПОМЕСТИТЬ Произ2
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК д
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ПроизводствоЗаСмену.Продукция КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	НЕ д.ПометкаУдаления
	|	И д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаПроизводства, ДЕНЬ) И КОНЕЦПЕРИОДА(&ДатаПроизводства, ДЕНЬ)
	|	И д.Смена = ЗНАЧЕНИЕ(Перечисление._ПроизводственныеСмены.Вечерняя)
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(т.ВНаличииОстаток, 0) КАК Остаток
	|ПОМЕСТИТЬ НаСкладе
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(, Склад = &СкладПродукции) КАК т
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(т.ВРезервеОстаток, 0) + ЕСТЬNULL(т.КОтгрузкеОстаток, 0) КАК КОтгрузке
	|ПОМЕСТИТЬ Резерв
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &СкладПродукции) КАК т
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Скидка КАК ПроцентРучнойСкидки
	|ПОМЕСТИТЬ Акции
	|ИЗ
	|	Справочник.AMS_Акции КАК д
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Акции.Товары КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	НЕ д.ПометкаУдаления
	|	И НЕ д.ЭтоГруппа
	|	И &ДатаДокумента МЕЖДУ НАЧАЛОПЕРИОДА(д.ДатаНачала, ДЕНЬ) И КОНЕЦПЕРИОДА(д.ДатаОкончания, ДЕНЬ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Товары.ТипПродукции КАК ТипПродукции,
	|	Товары.ТипПродукцииНаименование КАК ТипПродукцииНаименование,
	|	Товары.НазначениеПродукции КАК НазначениеПродукции,
	|	Товары.НазначениеПродукцииНаименование КАК НазначениеПродукцииНаименование,
	|	Товары.ТоварныйЗнак КАК ТоварныйЗнак,
	|	Товары.ТоварныйЗнакПорядок КАК ТоварныйЗнакПорядок,
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Артикул КАК Артикул,
	|	Товары.Прайс КАК Прайс,
	|	Товары.Заказ КАК Заказ,
	|	Товары.ВнеПрайса КАК ВнеПрайса,
	|	Товары.Упаковка КАК Упаковка,
	|	Товары.Кфц КАК Кфц,
	|	ВЫБОР
	|		КОГДА &Проведен
	|			ТОГДА (ЕСТЬNULL(НаСкладе.Остаток, 0) - ЕСТЬNULL(Резерв.КОтгрузке, 0) + ЕСТЬNULL(ТовДок.Количество, 0)) / Товары.Кфц
	|		ИНАЧЕ (ЕСТЬNULL(НаСкладе.Остаток, 0) - ЕСТЬNULL(Резерв.КОтгрузке, 0)) / Товары.Кфц
	|	КОНЕЦ КАК Доступно,
	|	ТовДок.Количество / Товары.Кфц КАК КоличествоУпаковок,
	|	ТовДок.Сумма КАК Сумма,
	|	ТовКлиента.ТоварКлиента КАК ТоварКлиента,
	|	Произ1.План1 КАК План1,
	|	Произ1.Факт1 КАК Факт1,
	|	Произ2.План2 КАК План2,
	|	Произ2.Факт2 КАК Факт2,
	|	Товары.ВидЦеныСоглашение КАК ВидЦеныСоглашение,
	|	Товары.ЦенаСоглашение * Товары.Кфц КАК ЦенаСоглашение,
	|	ТовДок.ВидЦеныДокумент КАК ВидЦеныДокумент,
	|	ТовДок.ЦенаДокумент * Товары.Кфц КАК ЦенаДокумент,
	|	Товары.ЦенаСоглашение * Товары.Кфц КАК Цена,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Акции.ПроцентРучнойСкидки, 0) > 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ФлагСкидкаАкция,
	|	ЕСТЬNULL(Акции.ПроцентРучнойСкидки, 0) КАК ПроцентРучнойСкидкиАкция,
	|	ВЫБОР
	|		КОГДА ТовДок.ПроцентРучнойСкидки ЕСТЬ NULL
	|				ИЛИ ТовДок.ПроцентРучнойСкидки = 0
	|			ТОГДА ЕСТЬNULL(Акции.ПроцентРучнойСкидки, 0)
	|		ИНАЧЕ ЕСТЬNULL(ТовДок.ПроцентРучнойСкидки, 0)
	|	КОНЕЦ КАК ПроцентРучнойСкидки,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТовДок.ПроцентРучнойСкидки, 0) > 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ФлагСкидка,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТовДок.ПроцентРучнойСкидки, 0) > 0
	|				ИЛИ ЕСТЬNULL(Акции.ПроцентРучнойСкидки, 0) > 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Флаг,
	|	Товары.Наименование КАК ПорядокНаш,
	|	ВЫБОР
	|		КОГДА &СортироватьПоЗаказу
	|			ТОГДА ВЫБОР
	|					КОГДА НомКлиента.ПорядковыйНомерКлиента ЕСТЬ NULL
	|						ТОГДА Товары.Наименование
	|					ИНАЧЕ НомКлиента.ПорядковыйНомерКлиента
	|				КОНЕЦ
	|		ИНАЧЕ Товары.Наименование
	|	КОНЕЦ КАК ПорядокКлиента
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТовДок КАК ТовДок
	|		ПО Товары.Номенклатура = ТовДок.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТовКлиента КАК ТовКлиента
	|		ПО Товары.Номенклатура = ТовКлиента.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Произ1 КАК Произ1
	|		ПО Товары.Номенклатура = Произ1.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Произ2 КАК Произ2
	|		ПО Товары.Номенклатура = Произ2.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ НомКлиента КАК НомКлиента
	|		ПО Товары.Номенклатура = НомКлиента.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ НаСкладе КАК НаСкладе
	|		ПО Товары.Номенклатура = НаСкладе.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Резерв КАК Резерв
	|		ПО Товары.Номенклатура = Резерв.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Акции КАК Акции
	|		ПО Товары.Номенклатура = Акции.Номенклатура
	|ГДЕ
	|	Товары.Подбор
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТипПродукцииНаименование,
	|	НазначениеПродукцииНаименование,
	|	ТоварныйЗнакПорядок,
	|	НомерСтроки";
	
	Табл = Запрос.Выполнить().Выгрузить();
	
	Объект.Товары.Загрузить(Табл);
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьДанныеФормыПодбора()
	ПоказатьПодбор();
	ЗагрузитьТаблицыВыбораТоваров();
	УстановитьВидимостьСтраниц();
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьПодбор()
	Подбор.Очистить();
	
	МассивСтрок = ПолучитьРезультатПодбора();

	НомерСтроки = 0;
	Для Каждого Стр Из МассивСтрок Цикл
		НомерСтроки = НомерСтроки + 1;
		
		НовСтр = Подбор.Добавить();
		
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
		
		НовСтр.НомерСтроки = НомерСтроки;
	КонецЦикла;
	
	ЗаполнитьКоличествоПалетВес();
КонецПроцедуры

&НаСервере
Функция ПолучитьРезультатПодбора()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("СортироватьПоЗаказу", СортироватьПоЗаказу);
	Запрос.УстановитьПараметр("Проведен", Проведен);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Номенклатура КАК Номенклатура,
		|	т.Артикул КАК Артикул,
		|	т.Упаковка КАК Упаковка,
		|	т.План1 КАК План1,
		|	т.Факт1 КАК Факт1,
		|	т.План2 КАК План2,
		|	т.Факт2 КАК Факт2,
		|	т.Остаток КАК Остаток,
		|	т.Доступно КАК Доступно,
		|	т.КоличествоУпаковок КАК КоличествоУпаковок,
		|	т.ВидЦеныСоглашение КАК ВидЦеныСоглашение,
		|	т.ЦенаСоглашение КАК ЦенаСоглашение,
		|	т.ФлагСкидка КАК ФлагСкидка,
		|	т.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки,
		|	т.ПроцентРучнойСкидкиАкция КАК ПроцентРучнойСкидкиАкция,
		|	т.Сумма КАК Сумма,
		|	т.ПорядокНаш КАК ПорядокНаш,
		|	т.ПорядокКлиента КАК ПорядокКлиента
		|ПОМЕСТИТЬ Продукция
		|ИЗ
		|	&Товары КАК т
		|ГДЕ
		|	т.КоличествоУпаковок > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Продукция.Номенклатура КАК Номенклатура,
		|	Продукция.Артикул КАК Артикул,
		|	Продукция.Упаковка КАК Упаковка,
		|	Продукция.План1 КАК План1,
		|	Продукция.Факт1 КАК Факт1,
		|	Продукция.План2 КАК План2,
		|	Продукция.Факт2 КАК Факт2,
		|	Продукция.Доступно КАК Доступно,
		|	Продукция.КоличествоУпаковок КАК КоличествоУпаковок,
		|	Продукция.Остаток КАК Остаток,
		|	Продукция.ВидЦеныСоглашение КАК ВидЦены,
		|	Продукция.ЦенаСоглашение КАК Цена,
		|	Продукция.ФлагСкидка КАК ФлагСкидка,
		|	Продукция.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки,
		|	Продукция.ПроцентРучнойСкидкиАкция КАК ПроцентРучнойСкидкиАкция,
		|	Продукция.Сумма КАК Сумма,
		|	ВЫРАЗИТЬ(Продукция.ПорядокКлиента КАК СТРОКА(50)) КАК ПорядокКлиента,
		|	ВЫРАЗИТЬ(Продукция.ПорядокНаш КАК СТРОКА(50)) КАК ПорядокНаш
		|ИЗ
		|	Продукция КАК Продукция
		|
		|УПОРЯДОЧИТЬ ПО " + ?(СортироватьПоЗаказу, "ПорядокКлиента", "ПорядокНаш");
		
	Табл = Запрос.Выполнить().Выгрузить();
	
	МассивСтрок = Новый Массив();
	
	Для Каждого Стр Из Табл Цикл
		МассивСтрок.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;
	
	Возврат МассивСтрок;
КонецФункции

&НаКлиенте
Процедура ЗагрузитьТаблицыВыбораТоваров()
	ЗагрузитьДеревоТипПродукции(ДеревоХимия, Элементы.ДеревоХимия, ТипПродукции.Химия);
	ЗагрузитьДеревоТипПродукции(ДеревоКосметика, Элементы.ДеревоКосметика, ТипПродукции.Косметика);
	ЗагрузитьДеревоТипПродукции(ДеревоМоющие, Элементы.ДеревоМоющие, ТипПродукции.Моющие);
	ЗагрузитьДеревоТипПродукции(ДеревоНаборы, Элементы.ДеревоНаборы, ТипПродукции.Наборы);
	ЗагрузитьДеревоТипПродукции(ДеревоХозтовары, Элементы.ДеревоХозтовары, ТипПродукции.ХозТовары);
	ЗагрузитьДеревоТипПродукции(ДеревоКонтракт, Элементы.ДеревоКонтракт, ТипПродукции.Контракт);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДеревоТипПродукции(Дерево, ЭлементДерево, Тип)
	Дерево.ПолучитьЭлементы().Очистить();

	НазначениеПродукции = Неопределено; 
	
	СтруктураОтбора = Новый Структура("ТипПродукции", Тип);
	Если Отбор = "Клиент" Тогда
		СтруктураОтбора.Вставить("ТоварКлиента", Истина);
	КонецЕсли;

	СтрокиТипа = Объект.Товары.НайтиСтроки(СтруктураОтбора);

	Для Каждого Стр Из СтрокиТипа Цикл
		Если Не НазначениеПродукции = Стр.НазначениеПродукции Тогда
			Стр1 = Дерево.ПолучитьЭлементы().Добавить();
			Стр1.Номенклатура = Стр.НазначениеПродукции;
			Стр1.Уровень = 1;
			
			Стр2 = Стр1.ПолучитьЭлементы().Добавить();
			Стр2.Номенклатура = Стр.ТоварныйЗнак;
			Стр2.Уровень = 2;
			
			ТоварныйЗнак = Стр.ТоварныйЗнак;

			Стр3 = Стр2.ПолучитьЭлементы().Добавить();
			ЗаполнитьЗначенияСвойств(Стр3, Стр);
			
			Номенклатура = Стр.Номенклатура;
		КонецЕсли;				
		
		Если ЗначениеЗаполнено(Стр.ТоварныйЗнак) И Не ТоварныйЗнак = Стр.ТоварныйЗнак Тогда
			Стр2 = Стр1.ПолучитьЭлементы().Добавить();
			
			Стр2.Номенклатура = Стр.ТоварныйЗнак;
			Стр2.Уровень = 2;
			
			Стр3 = Стр2.ПолучитьЭлементы().Добавить();
			ЗаполнитьЗначенияСвойств(Стр3, Стр);
			
			Номенклатура = Стр.Номенклатура;
		КонецЕсли;
		
		Если Не Номенклатура = Стр.Номенклатура Тогда
			Стр3 = Стр2.ПолучитьЭлементы().Добавить();
			ЗаполнитьЗначенияСвойств(Стр3, Стр);
		КонецЕсли;
		
		Если Проведен Тогда 
			Стр3.Доступно = Стр3.Доступно + Стр3.КоличествоУпаковок;
		КонецЕсли;
		
		Стр3.Остаток = Стр3.Доступно - Стр3.КоличествоУпаковок;

		НазначениеПродукции = Стр.НазначениеПродукции;
		ТоварныйЗнак        = Стр.ТоварныйЗнак;
	КонецЦикла;

	Для каждого Стр1 Из Дерево.ПолучитьЭлементы() Цикл
		ЭлементДерево.Развернуть(Стр1.ПолучитьИдентификатор());
		
		Для каждого Стр2 Из Стр1.ПолучитьЭлементы() Цикл
			ЭлементДерево.Развернуть(Стр2.ПолучитьИдентификатор());
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьСтраниц()
	НомерСтрокиХимия     = 0;
	НомерСтрокиКосметика = 0;
	НомерСтрокиМоющие    = 0;
	НомерСтрокиНаборы    = 0;
	НомерСтрокиХоз       = 0;
	НомерСтрокиКонтракт  = 0;

	Запрос = Новый Запрос;
	Запрос.установитьПараметр("ТоварыПодбора", Объект.Товары.Выгрузить(, "ТипПродукции, ТоварКлиента"));
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	т.ТипПродукции КАК ТипПродукции,
		|	т.ТоварКлиента КАК ТоварКлиента
		|ПОМЕСТИТЬ Продукция
		|ИЗ
		|	&ТоварыПодбора КАК т";
		
	Если Отбор = "Клиент" Тогда Запрос.Текст = Запрос.Текст + "	
		|ГДЕ
		|	т.ТоварКлиента";
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + "
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	AMS_Продукция.Код КАК Код,
		|	КОЛИЧЕСТВО(Продукция.ТоварКлиента) КАК Количество
		|ИЗ
		|	Продукция КАК Продукция
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция КАК AMS_Продукция
		|		ПО Продукция.ТипПродукции = AMS_Продукция.Ссылка
		|СГРУППИРОВАТЬ ПО
		|	AMS_Продукция.Код";
	
	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();
	
	Пока Выб.Следующий() Цикл
		Если Выб.Код = "001" Тогда
			НомерСтрокиХимия = Выб.Количество;
		КонецЕсли;
		
		Если Выб.Код = "002" Тогда
			НомерСтрокиКосметика = Выб.Количество;
		КонецЕсли;
		
		Если Выб.Код = "003" Тогда
			НомерСтрокиМоющие    = Выб.Количество;
		КонецЕсли;
		
		Если Выб.Код = "044" Тогда
			НомерСтрокиНаборы    = Выб.Количество;
		КонецЕсли;

		Если Выб.Код = "049" Тогда
			НомерСтрокиХоз       = Выб.Количество;
		КонецЕсли;
		
		Если Выб.Код = "039" Тогда
			НомерСтрокиКонтракт  = Выб.Количество;
		КонецЕсли;
	КонецЦикла;

	Элементы.СтраницаБытоваяХимия.Заголовок = "1. Бытовая химия (" + НомерСтрокиХимия + ")";
	Элементы.СтраницаКосметика.Заголовок    = "2. Косметика (" + НомерСтрокиКосметика + ")";
	Элементы.СтраницаПрофХимия.Заголовок    = "3. Проф. химия (" + НомерСтрокиМоющие + ")";
	Элементы.СтраницаНаборы.Заголовок       = "4. Наборы (" + НомерСтрокиНаборы + ")";
	Элементы.СтраницаХозТовары.Заголовок    = "5. Хозтовары (" + НомерСтрокиХоз + ")";
	Элементы.СтраницаКонтракт.Заголовок     = "6. Контракт (" + НомерСтрокиКонтракт + ")";
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКоличествоПалетВес()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить(, "Номенклатура, КоличествоУпаковок"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.КоличествоУпаковок КАК КоличествоУпаковок
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Товары КАК Товары
	|ГДЕ
	|	Товары.КоличествоУпаковок > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	вт.КоличествоУпаковок * Ном.КоэффициентЕдиницыДляОтчетов КАК Количество
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО вт.Номенклатура = Ном.Ссылка";
	
	Табл = Запрос.Выполнить().Выгрузить();

	Элементы.СтраницаПодбор.Заголовок = "Товары (" + Табл.Количество() + ")";

	Стр = AMS_Сервер.ПолучитьВесОбъемТоваров(Табл);
	
	Вес             = Стр.Вес;
	КоличествоПалет = Стр.КоличествоПалетМоно + Стр.КоличествоПалетСборных;
	
	Если КоличествоПалет > 0 Тогда 
		Элементы.КоличетсвоПалет.Заголовок = "Количество палет: " + Формат(КоличествоПалет, "ЧДЦ=0; ЧФ=""Ч шт.""");
	Иначе		
		Элементы.КоличетсвоПалет.Заголовок = "";
	КонецЕсли;
	
	Если Вес > 0 Тогда 
		Элементы.Вес.Заголовок = "Вес: " + Формат(Стр.Вес, "ЧДЦ=3; ЧФ=""Ч т.""");
	Иначе		
		Элементы.Вес.Заголовок = "";
	КонецЕсли;
	
	ЛогистическийЛист = AMS_ВызовСервера.ПолучитьЛогистическийЛист(Ссылка);
	
	Если Не ЛогистическийЛист = Неопределено Тогда
		Стр = ПолучитьВозможностиЗагрузки(ЛогистическийЛист, Ссылка);
		
		ПерегрузПал = КоличествоПалет - Стр.КоличествоПалет;
		ПерегрузВес = Вес - Стр.Вес;

		Если ПерегрузПал > 0 Или ПерегрузВес > 0.01 Тогда
			Элементы.Перегруз.Видимость             = Истина;
			Элементы.ПеренестиВДокумент.Доступность = Ложь;
			Элементы.Перегруз.Заголовок = "Перегруз транспортного средства " + Стр.ТранспортноеСредство + ": "
				+ ?(ПерегрузПал > 0, "палет на " + ПерегрузПал + " шт.", "")
				+ ?(ПерегрузПал > 0 И ПерегрузВес > 0, ", ", "")
				+ ?(ПерегрузВес > 0, "вес на " + Формат(ПерегрузВес, "ЧДЦ=3; ЧФ=""Ч т."""), "");
		Иначе
			Элементы.Перегруз.Видимость             = Ложь;
			Элементы.ПеренестиВДокумент.Доступность = Истина;
			Элементы.Перегруз.Заголовок = "";
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьВозможностиЗагрузки(ЛогистическийЛист, Распоряжение)
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЛогистическийЛист", ЛогистическийЛист);
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка,
	|	т.ТранспортноеСредство КАК ТранспортноеСредство
	|ПОМЕСТИТЬ авто
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
	|ГДЕ
	|	т.Ссылка = &ЛогистическийЛист
	|	И т.Распоряжение = &Распоряжение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	авто.ТранспортноеСредство КАК ТранспортноеСредство,
	|	авто.ТранспортноеСредство.ГрузоподъемностьВТоннах КАК ВесАвто,
	|	авто.ТранспортноеСредство.AMS_КоличествоПалет КАК КоличествоПалетАвто,
	|	СУММА(ВЫБОР
	|		КОГДА Распоряжения.Распоряжение = &Распоряжение
	|			ТОГДА 0
	|		ИНАЧЕ Распоряжения.Распоряжение.AMS_Вес
	|	КОНЕЦ) КАК Вес,
	|	СУММА(ВЫБОР
	|		КОГДА Распоряжения.Распоряжение = &Распоряжение
	|			ТОГДА 0
	|		ИНАЧЕ Распоряжения.Распоряжение.AMS_КоличествоПалет
	|	КОНЕЦ) КАК КоличествоПалет
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	авто КАК авто
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.AMS_ЛогистическийЛист.Распоряжения КАК Распоряжения
	|		ПО авто.Ссылка = Распоряжения.Ссылка
	|		И авто.ТранспортноеСредство = Распоряжения.ТранспортноеСредство
	|СГРУППИРОВАТЬ ПО
	|	авто.ТранспортноеСредство,
	|	авто.ТранспортноеСредство.ГрузоподъемностьВТоннах,
	|	авто.ТранспортноеСредство.AMS_КоличествоПалет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.ТранспортноеСредство КАК ТранспортноеСредство,
	|	вт.ВесАвто - вт.Вес КАК Вес,
	|	вт.КоличествоПалетАвто - вт.КоличествоПалет КАК КоличествоПалет
	|ИЗ
	|	вт КАК вт";
	
	 Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Запрос.Выполнить().Выгрузить()[0]);
КонецФункции

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	Если Ответ = КодВозвратаДиалога.Да Тогда
		Модифицированность = Ложь;
		ПеренестиТоварыВДокумент();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиТоварыВДокумент()
	// Снятие модифицированности, т.к. перед закрытием признак проверяется.
	Модифицированность = Ложь;

	Данные = ПолучитьМассивСтрок();

	Закрыть(Данные);
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзВнешнегоФайлаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ОчиститьСообщения();

	Для каждого Стр Из Результат Цикл
		СтрТовары = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Стр.Номенклатура))[0];
		
		Кфц = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Стр.Номенклатура, "КоэффициентЕдиницыДляОтчетов");
		
		СтрТовары.КоличествоУпаковок = Стр.Количество / Кфц;
		СтрТовары.Сумма = СтрТовары.КоличествоУпаковок * СтрТовары.Цена;
	КонецЦикла;
	
	ПоказатьДанныеФормыПодбора();
КонецПроцедуры

//Желательно использовать эту процедуру
//@skip-check module-unused-method
&НаКлиенте
Процедура НайтиСтрокуДерева(КоллекцияЭлементовДерева, Номенклатура, ИдентификаторСтроки, ПрекратитьПоиск)
	Для каждого СтрокаДерева Из КоллекцияЭлементовДерева Цикл
		Если ПрекратитьПоиск Тогда
			Возврат;
		КонецЕсли;
		
		Если СтрокаДерева.Номенклатура = Номенклатура Тогда
			ИдентификаторСтроки = СтрокаДерева.ПолучитьИдентификатор();
			ПрекратитьПоиск = Истина;
			Возврат;
		КонецЕсли;
		
		КоллекцияЭлементов = СтрокаДерева.ПолучитьЭлементы();

		Если КоллекцияЭлементов.Количество() > 0 Тогда
			НайтиСтрокуДерева(КоллекцияЭлементов, Номенклатура, ИдентификаторСтроки, ПрекратитьПоиск);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивСтрок()
	Таб = РеквизитФормыВЗначение("Подбор");

	Табл = Таб.СкопироватьКолонки("Номенклатура, Упаковка, КоличествоУпаковок, Цена, Сумма, ВидЦены, ПроцентРучнойСкидки");

	Для Каждого Стр Из Таб Цикл
		НовСтр = Табл.Добавить();

		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
		
		Если Не Стр.ФлагСкидка Тогда
			НовСтр.ПроцентРучнойСкидки = 0;
		КонецЕсли;
	КонецЦикла;

	МассивСтрок = Новый Массив;
	Для Каждого Стр Из Табл Цикл
		МассивСтрок.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;

	Возврат МассивСтрок;
КонецФункции

