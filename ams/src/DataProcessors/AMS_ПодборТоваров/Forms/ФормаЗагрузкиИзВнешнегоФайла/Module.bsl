#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
	Партнер = Параметры.Партнер;
	Родитель = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Партнер, "Родитель");
	Партнер = ?(ЗначениеЗаполнено(Родитель), Родитель, Партнер);
	
	ИмяИБ           = "АМС";
	ИмяНаименования = "Артикул";
	ИмяКоличество   = "Упаковка"; 

	ИнициализироватьТабличныйДокумент();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТовары

&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
	Стр = Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	Кфц = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Стр.Номенклатура, "КоэффициентЕдиницыДляОтчетов");
	
	Стр.КоличествоУпаковок = Стр.Количество / Кфц;
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКоличествоУпаковокПриИзменении(Элемент)
	Стр = Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	Кфц = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Стр.Номенклатура, "КоэффициентЕдиницыДляОтчетов");
	
	Стр.Количество = Стр.КоличествоУпаковок * Кфц;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Далее(Команда)
	ДанныеЗаполнены = ЗначениеЗаполнено(ТабДок.Область("R2C1").Текст);

	Если Не ДанныеЗаполнены Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("ru = 'Необходимо скопировать колонки в таблицу из внешнего файла.'"));
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	Состояние(НСтр("ru = 'Осуществляется сопоставление введенных данных с данными информационной базы. Пожалуйста подождите...'"),,,БиблиотекаКартинок.Информация32);
	
	Табл = ЗаполнитьЗагруженныйТовар();
	
	Штука = (ИмяКоличество = "Штука");
	
	Если ИмяИБ = "АМС" И ИмяНаименования = "Артикул" Тогда
		СопоставитьДанныеПоАртикул(Табл, Штука);
		
	ИначеЕсли ИмяИБ = "АМС" И ИмяНаименования = "Код" Тогда
		СопоставитьДанныеПоКод(Табл, Штука);
		
	ИначеЕсли ИмяИБ = "АМС" И ИмяНаименования = "Номенклатура" Тогда
		СопоставитьДанныеПоНоменклатура(Табл, Штука);
		
	ИначеЕсли ИмяИБ = "АМС" И ИмяНаименования = "Штрихкод" Тогда
		СопоставитьДанныеПоШтрихкод(Табл, Штука);
		
	ИначеЕсли ИмяИБ = "Клиента" И ИмяНаименования = "Артикул" Тогда
		СопоставитьДанныеПоАртикулКлиента(Табл, Штука);
		
	ИначеЕсли ИмяИБ = "Клиента" И ИмяНаименования = "Код" Тогда
		СопоставитьДанныеПоКодКлиента(Табл, Штука);
		
	ИначеЕсли ИмяИБ = "Клиента" И ИмяНаименования = "Номенклатура" Тогда
		СопоставитьДанныеПоНоменклатураКлиента(Табл, Штука);
		
	ИначеЕсли ИмяИБ = "Клиента" И ИмяНаименования = "Штрихкод" Тогда
		СопоставитьДанныеПоШтрихкодКлиента(Табл, Штука);
	КонецЕсли;	

	Элементы.Шаги.ТекущаяСтраница = Элементы.Шаг2;
КонецПроцедуры

&НаКлиенте
Процедура Назад(Команда)
	Элементы.Шаги.ТекущаяСтраница = Элементы.Шаг1;
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФорму(Команда)
	Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиТовары(Команда)
	ОчиститьСообщения(); 
	
	МассивСтрок = ПолучитьНайденныеТовары();
	
	Если Не МассивСтрок = Неопределено Тогда
		Закрыть(МассивСтрок);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ИнициализироватьТабличныйДокумент()
	Макет = Обработки.AMS_ПодборТоваров.ПолучитьМакет("МакетЗагрузкиДанных");
	
	Обл = Макет.ПолучитьОбласть("Колонка1");
	ТабДок.Присоединить(Обл); 
	Обл = Макет.ПолучитьОбласть("Колонка2");
	ТабДок.Присоединить(Обл); 

	ТабДок.ФиксацияСверху = 1;
КонецПроцедуры

&НаСервере
Функция ЗаполнитьЗагруженныйТовар()
	Табл = Новый ТаблицаЗначений;
	Табл.Колонки.Добавить("Колонка1", Новый ОписаниеТипов("Строка"));
	Табл.Колонки.Добавить("Колонка2", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 3)));
	
	ВысотаШапки = 1;
	НомерСтроки = ВысотаШапки + 1;
 	СтроковыйНомер = Формат(НомерСтроки, "ЧН=0; ЧГ=0");

	ДанныеЗаполнены = ЗначениеЗаполнено(ТабДок.Область("R" + СтроковыйНомер + "C1").Текст);

	Пока ДанныеЗаполнены Цикл
		НовСтр = Табл.Добавить();
		
		Попытка
			НовСтр.Колонка1 = СокрЛП(ТабДок.Область("R" + СтроковыйНомер + "C1").Текст);
			
			ТекстКолонка2 = СокрЛП(ТабДок.Область("R" + СтроковыйНомер + "C2").Текст);
			Если ПустаяСтрока(ТекстКолонка2) Тогда 
				НовСтр.Колонка2 = 0;
			Иначе
				НовСтр.Колонка2 = Число(ТекстКолонка2);
			КонецЕсли;
		Исключение
			//@skip-check bsl-legacy-check-static-feature-access
			ОбщегоНазначения.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
		
		НомерСтроки = НомерСтроки + 1;
		СтроковыйНомер = Формат(НомерСтроки, "ЧН=0; ЧГ=0");
		
		Попытка
			ДанныеЗаполнены = ЗначениеЗаполнено(ТабДок.Область("R" + СтроковыйНомер + "C1").Текст);
		Исключение
			//@skip-check bsl-legacy-check-static-feature-access
			ОбщегоНазначения.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЦикла;

	Возврат Табл;
КонецФункции

&НаСервере
Процедура СопоставитьДанныеПоАртикул(Табл, Штука)
	Товары.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Табл);
	Запрос.УстановитьПараметр("Штука", Штука);
	Запрос.УстановитьПараметр("Партнер", Партнер);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(т.Колонка1 КАК СТРОКА(500)) КАК ЗагружаемыйТовар,
	|	т.Колонка2 КАК Количество
	|ПОМЕСТИТЬ Тов
	|ИЗ
	|	&Товары КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Тов.ЗагружаемыйТовар КАК ЗагружаемыйТовар,
	|	Прод.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &Штука
	|			ТОГДА Тов.Количество
	|		ИНАЧЕ Тов.Количество * Ном.КоэффициентЕдиницыДляОтчетов
	|	КОНЕЦ КАК Количество,
	|	ВЫБОР
	|		КОГДА &Штука
	|			ТОГДА Тов.Количество / Ном.КоэффициентЕдиницыДляОтчетов
	|		ИНАЧЕ Тов.Количество
	|	КОНЕЦ КАК КоличествоУпаковок
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Тов КАК Тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.AMS_Продукция.Товары КАК Прод
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|			ПО Прод.Номенклатура = Ном.Ссылка
	|		ПО Тов.ЗагружаемыйТовар = Прод.Номенклатура.Артикул
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	НомКонтр.Код КАК КодКлиента,
	|	НомКонтр.Артикул КАК АртикулКлиента,
	|	НомКонтр.НаименованиеНоменклатуры КАК НоменклатураКлиента
	|ПОМЕСТИТЬ НомКонт
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НоменклатураКонтрагентов КАК НомКонтр
	|		ПО (&Партнер = НомКонтр.Владелец)
	|			И вт.Номенклатура = НомКонтр.Номенклатура
	|ГДЕ
	|	НЕ НомКонтр.Недействителен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.ЗагружаемыйТовар КАК ЗагружаемыйТовар,
	|	вт.Номенклатура КАК Номенклатура,
	|	вт.Количество КАК Количество,
	|	вт.КоличествоУпаковок КАК КоличествоУпаковок,
	|	НомКонт.КодКлиента КАК КодКлиента,
	|	НомКонт.АртикулКлиента КАК АртикулКлиента,
	|	НомКонт.НоменклатураКлиента КАК НоменклатураКлиента
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ НомКонт КАК НомКонт
	|		ПО вт.Номенклатура = НомКонт.Номенклатура";
	
	Товары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

