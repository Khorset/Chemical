&НаСервере
Функция ПолучитьНайденныеТовары()
	Отказ       = Ложь;
	МассивСтрок = Новый Массив;
	НомерСтроки = 0;
	
	Для каждого Стр Из Товары Цикл
		НомерСтроки = НомерСтроки + 1;
		
		Если Не ЗначениеЗаполнено(Стр.Номенклатура) Тогда
			ОбщегоНазначения.СообщитьПользователю("По данным для поиска в строке " + НомерСтроки + " совпадений не найдено.",,,,Отказ);
		КонецЕсли;
			
		Если Стр.Количество = 0 Тогда
			ОбщегоНазначения.СообщитьПользователю("В строке " + НомерСтроки + " не указано количество.",,,,Отказ);
		КонецЕсли; 
		
		Если Стр.КоличествоУпаковок - Цел(Стр.КоличествоУпаковок) > 0 Тогда
			ОбщегоНазначения.СообщитьПользователю("В строке " + НомерСтроки + " не указано не целое количество упаковок.",,,,Отказ);
		КонецЕсли; 

		НовСтр = Новый Структура("Номенклатура, Количество");
		НовСтр.Номенклатура = Стр.Номенклатура;
		НовСтр.Количество   = Стр.Количество;
		
		МассивСтрок.Добавить(НовСтр);
	КонецЦикла; 

	Если Отказ Тогда
		Возврат Неопределено;
	Иначе
		Возврат МассивСтрок;
	КонецЕсли;
КонецФункции

