#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;

	ВыбратьПродукцию();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТаблицаНоменклатуры

&НаКлиенте
Процедура ТаблицаНоменклатурыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ЗакрытьЭтуФорму();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗакрытьЭтуФорму()
	Стр = Элементы.ТаблицаНоменклатуры.ТекущиеДанные;
	
	Данные = Новый Структура();
	Данные.Вставить("Номенклатура", Стр.Номенклатура);
	Данные.Вставить("Количество", Стр.Количество);
	Данные.Вставить("КоличествоУпаковок", Стр.КоличествоУпаковок);
	Данные.Вставить("Упаковка", Стр.Упаковка);
	
	Закрыть(Данные);
КонецПроцедуры

&НаСервере
Процедура ВыбратьПродукцию()
 
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидНоменклатуры", мср.СоответствиеЦехВидНоменклатуры().Получить(Параметры.Склад));
	Запрос.УстановитьПараметр("Склад",           AMS_ВызовСервера.СкладБракованнойПродукции());
	Запрос.УстановитьПараметр("Дата",            Параметры.Дата);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура,
	|	т.ВНаличииОстаток КАК Количество,
	|	т.ВНаличииОстаток / т.Номенклатура.КоэффициентЕдиницыДляОтчетов КАК КоличествоУпаковок,
	|	т.Номенклатура._Упаковка КАК Упаковка
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(&Дата, Склад = &Склад
	|	И Номенклатура.ВидНоменклатуры В (&ВидНоменклатуры)) КАК т
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Номенклатура.Наименование";

	Рез = Запрос.Выполнить();
	
	Выб = Рез.Выбрать();
	
	НомерСтроки = 0;
	
	Пока Выб.Следующий() Цикл
		НомерСтроки = НомерСтроки + 1;
		
		Стр = ТаблицаНоменклатуры.Добавить();
		
		ЗаполнитьЗначенияСвойств(Стр, Выб);
		
		Стр.НомерСтроки = НомерСтроки;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Параметры.Номенклатура) И ТаблицаНоменклатуры.Количество() > 0 Тогда
		МассивСтрок = ТаблицаНоменклатуры.НайтиСтроки(Новый Структура("Номенклатура", Параметры.Номенклатура));

		Если МассивСтрок.Количество() > 0 Тогда
			Элементы.ТаблицаНоменклатуры.ТекущаяСтрока = МассивСтрок[0].ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти