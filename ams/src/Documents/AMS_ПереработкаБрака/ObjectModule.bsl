КонецПроцедуры

Процедура ОформитьОприходованиеМатериалов_Оприходование(ТабДок, Отказ)
	СтрДок = ТабДок.Найти(Перечисления.AMS_ОперацииПроизводства.ОприходованиеМатериаловИзБрака);
	
	Если СтрДок = Неопределено Тогда
		Док = Документы.ОприходованиеИзлишковТоваров.СоздатьДокумент();
	Иначе
		Док = СтрДок.Ссылка.ПолучитьОбъект();
	КонецЕсли;

	Док.Дата                  = Дата;
	Док.Организация           = Организация;
	Док.Склад                 = Склад;
	Док.Подразделение         = мср.СоответствиеЦехПодразделение().Получить(Склад);
	Док.Валюта                = Константы.ВалютаУправленческогоУчета.Получить();
	Док.ВидЦены               = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "УчетныйВидЦены");
	Док.СтатьяДоходов         = ПланыВидовХарактеристик.СтатьиДоходов.НайтиПоКоду("01-000001");
	Док.Ответственный         = Автор;
	Док.Автор                 = Автор;
	Док._Основание            = Ссылка;
	Док._ОперацияПроизводства = Перечисления.AMS_ОперацииПроизводства.ОприходованиеМатериаловИзБрака;
	Док.Комментарий = "Сформирован автоматичестки. Оприходование материалов из состава бракованной продукции (Переработка брака № "
		+ Номер + " от " + Формат(Док.Дата, "ДЛФ=Д") + " г.)";

	Док.Товары.Очистить();

	Для Каждого Стр Из МатериалыСтарые Цикл
		НовСтр = Док.Товары.Добавить();
		НовСтр.Номенклатура = Стр.Номенклатура;
		НовСтр.Количество   = Стр.Количество;
		Если Стр.Цена < 0.01 Тогда
			НовСтр.Цена = 0.01;
		Иначе
			НовСтр.Цена = Стр.Цена;
		КонецЕсли;
		НовСтр.Сумма = НовСтр.Количество * НовСтр.Цена;
	КонецЦикла;

	мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ);
КонецПроцедуры

