#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Если Не Пользователи.РолиДоступны("_НачальникЦеха, _ГлавныйБухгалтер, _Бухгалтер") Тогда
		Возврат;
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Если Пользователи.РолиДоступны("_Цех1") Тогда
		Склад = AMS_ВызовСервера.Цех1();

	ИначеЕсли Пользователи.РолиДоступны("_Цех2") Тогда
		Склад = AMS_ВызовСервера.Цех2();
	
	ИначеЕсли Пользователи.РолиДоступны("_Цех3") Тогда
		Склад = AMS_ВызовСервера.Цех3();
	КонецЕсли;

	Автор = Пользователи.ТекущийПользователь();
	Смена = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Дневная");
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Если Не Склад = AMS_ВызовСервера.ПолучитьЦехНоменклатуры(Номенклатура) Тогда
		ТекстОшибки = """" + Номенклатура + """ не является продукцией склада """ + Склад + """.";
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
	КонецЕсли;

	Для Каждого Стр Из МатериалыСтарые Цикл
		Если Не Стр.Количество = Стр.КоличествоОтходы + Стр.КоличествоПереработка Тогда
			ТекстОшибки = "В таблице ""Материалы в составе бракованной продукции"" для """ + Стр.Номенклатура
				+ """ указано не правильное количество ""в отходы"" или ""в переработку"".";
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
		КонецЕсли;
	КонецЦикла;

	ПроверитьНаличиеНоменклатураБрак_МатериалыНовые(Отказ);

	Если Дата > КонецДня(ТекущаяДатаСеанса()) Тогда
		ТекстОшибки = "Проведение будущей датой запрещено.";
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	НаборЗаписей = РегистрыСведений._СтоимостьПродукции.СоздатьНаборЗаписей();

	НаборЗаписей.Отбор.Период.Установить(Дата);

	НаборЗаписей.Прочитать();

	Если НаборЗаписей.Количество() > 0 Тогда
		НаборЗаписей.Очистить();
	КонецЕсли;

	НоваяЗапись = НаборЗаписей.Добавить();

	НоваяЗапись.Период       = НачалоДня(Дата);
	НоваяЗапись.Номенклатура = Номенклатура;
	НоваяЗапись.Стоимость    = Цена;

	НаборЗаписей.Записать();

	//

	Подразделение = мср.СоответствиеЦехПодразделение().Получить(Склад);

	Если Склад = AMS_ВызовСервера.Цех1() Тогда
		ФасовкаПродукции = Справочники._Работы.Фасовка1;
		
	ИначеЕсли Склад = AMS_ВызовСервера.Цех2() Тогда
		ФасовкаПродукции = Справочники._Работы.Фасовка2;
		
	ИначеЕсли Склад = AMS_ВызовСервера.Цех3() Тогда
		ФасовкаПродукции = Справочники._Работы.Фасовка3;
	КонецЕсли;

	Движения._Зарплата.Записывать = Истина;

	//@skip-check expression-not-collection
	Для Каждого Стр Из Фасовка Цикл
		Движение = Движения._Зарплата.Добавить();

		Движение.Период        = Дата;
		Движение.Подразделение = Подразделение;
		Движение.Сотрудник     = Стр.Сотрудник;
		Движение.Работа        = ФасовкаПродукции;
		Движение.Сумма         = Стр.Сумма;
	КонецЦикла;

	Для Каждого Стр Из Работы Цикл
		Движение = Движения._Зарплата.Добавить();

		Движение.Период        = Дата;
		Движение.Подразделение = Подразделение;
		Движение.Сотрудник     = Стр.Сотрудник;
		Движение.Работа        = Стр.Работа;
		Движение.Сумма         = Стр.Сумма;
	КонецЦикла;
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	Дата = ТекущаяДатаСеанса();
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ТабДок = AMS_Сервер.ПолучитьДокументыПереработкиБрака(Ссылка);
	
	Если Проведен Тогда
		ДатаНачалаОрдернойСхемыПриОтраженииИзлишковНедостач = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "ДатаНачалаОрдернойСхемыПриОтраженииИзлишковНедостач");
		
		ОформитьПеремещениеБракаВЦех(ТабДок, Отказ);
		
		ОформитьСписаниеБракаВЦехе_Списание(ТабДок, Отказ);
		ОформитьОприходованиеМатериалов_Оприходование(ТабДок, Отказ);

		Если Дата >= ДатаНачалаОрдернойСхемыПриОтраженииИзлишковНедостач Тогда
			ОформитьСписаниеБракаВЦехе_Ордер(ТабДок, Отказ);
			ОформитьОприходованиеМатериалов_Ордер(ТабДок, Отказ);
		КонецЕсли;
		
		ОформитьПеремещениеМатериаловВОтходы(ТабДок, Отказ);
		ОформитьВнутреннееПотреблениеМатериалов(ТабДок, Отказ);
		ОформитьОприходованиеПродукции(ТабДок, Отказ);
		
		ОпменитьПеремещениеМатериаловДопЦех(ТабДок, Отказ);
	
	ИначеЕсли ПометкаУдаления Тогда
		Для каждого Стр Из ТабДок Цикл
			мср.УстановитьПометкуУдаленияДокументу(Стр.Ссылка, Истина);
		КонецЦикла;
	
	Иначе	
		Для каждого Стр Из ТабДок Цикл
			Если Стр.Проведен Тогда
				мср.ЗаписатьДокумент(Стр.Ссылка, РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОформитьПеремещениеБракаВЦех(ТабДок, Отказ)
	Стр = ТабДок.Найти(Перечисления.AMS_ОперацииПроизводства.ПеремещениеБракаВЦех);
	
	Если Стр = Неопределено Тогда
		Док = Документы.ПеремещениеТоваров.СоздатьДокумент();
	Иначе
		Док = Стр.Ссылка.ПолучитьОбъект();
	КонецЕсли;
	
	Док.Дата                       = Дата;
	Док.Организация                = Организация;
	Док.Статус                     = Перечисления.СтатусыПеремещенийТоваров.Принято;
	Док.СкладОтправитель           = AMS_ВызовСервера.СкладБракованнойПродукции();
	Док.СкладПолучатель            = Склад;
	Док.ВидЦены                    = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "УчетныйВидЦены");
	Док.СпособДоставки             = Перечисления.СпособыДоставки.Самовывоз;
	Док.ВариантПриемкиТоваров      = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
	Док.ПеремещениеПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
	Док.НаправлениеДеятельности    = Справочники.НаправленияДеятельности.НайтиПоНаименованию("Продажа", Истина);
	Док.Подразделение              = AMS_ВызовСервера.ПодразделениеПроизводство();
	Док.ХозяйственнаяОперация      = Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
	Док.Ответственный              = Автор;
	Док.Автор                      = Автор;
	Док._Основание                 = Ссылка;
	Док._ОперацияПроизводства      = Перечисления.AMS_ОперацииПроизводства.ПеремещениеБракаВЦех;
	Док.Комментарий = "Сформирован автоматичестки. Перемещение бракованной продукции на переработу (Переработка брака № "
		+ Номер + " от " + Формат(Док.Дата, "ДЛФ=Д") + " г.)";

	Док.Товары.Очистить();

	Стр = Док.Товары.Добавить();

	Стр.Номенклатура       = НоменклатураБрак;
	Стр.Количество         = КоличествоБрак;
	Стр.КоличествоУпаковок = КоличествоУпаковокБрак;
	Стр.Упаковка           = УпаковкаБрак;
	
	мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ);
КонецПроцедуры

Процедура ОформитьСписаниеБракаВЦехе_Списание(ТабДок, Отказ)
	СтрДок = ТабДок.Найти(Перечисления.AMS_ОперацииПроизводства.СписаниеБракаВЦехе);
	
	Если СтрДок = Неопределено Тогда
		Док = Документы.СписаниеНедостачТоваров.СоздатьДокумент();
	Иначе
		Док = СтрДок.Ссылка.ПолучитьОбъект();
	КонецЕсли;

	Док.Дата                              = Дата + 10;
	Док.Организация                       = Организация;
	Док.Склад                             = Склад;
	Док.Подразделение                     = мср.СоответствиеЦехПодразделение().Получить(Склад);
	Док.СтатьяРасходов                    = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("01-000079");
	Док.ВидЦены                           = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "УчетныйВидЦены");
	Док.ИсточникИнформацииОЦенахДляПечати = Перечисления.ИсточникиИнформацииОЦенахДляПечати.ПоВидуЦен;
	Док.Ответственный                     = Автор;
	Док.Автор                             = Автор;
	Док._Основание                        = Ссылка;
	Док._ОперацияПроизводства             = Перечисления.AMS_ОперацииПроизводства.СписаниеБракаВЦехе;
	Док.Комментарий = "Сформирован автоматичестки. Списание бракованной продукции (Переработка брака № "
		+ Номер + " от " + Формат(Док.Дата, "ДЛФ=Д") + " г.)";

	Док.Товары.Очистить();

	Стр = Док.Товары.Добавить();

	Стр.Номенклатура = НоменклатураБрак;
	Стр.Количество   = КоличествоБрак;

	мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ);
КонецПроцедуры

