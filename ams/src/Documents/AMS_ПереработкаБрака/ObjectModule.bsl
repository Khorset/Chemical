КонецПроцедуры

Процедура ОформитьПеремещениеМатериаловВОтходы(ТабДок, Отказ)
	СтрДок = ТабДок.Найти(Перечисления.AMS_ОперацииПроизводства.ПеремещениеМатериаловБракаВОтходы);
	
	Табл = Новый ТаблицаЗначений();
	Табл.Колонки.Добавить("Номенклатура");
	Табл.Колонки.Добавить("Количество");

	Для Каждого Стр Из МатериалыСтарые Цикл
		Если Стр.КоличествоОтходы > 0 Тогда
			НовСтр = Табл.Добавить();
			НовСтр.Номенклатура = Стр.Номенклатура;
			НовСтр.Количество = Стр.КоличествоОтходы;
		КонецЕсли;
	КонецЦикла;
	
	Если Табл.Количество() = 0 И Не СтрДок = Неопределено Тогда
			мср.УстановитьПометкуУдаленияДокументу(СтрДок.Ссылка, Истина);
		
	Иначе	
		Если СтрДок = Неопределено Тогда
			Док = Документы.ПеремещениеТоваров.СоздатьДокумент();
		Иначе
			Док = СтрДок.Ссылка.ПолучитьОбъект();
		КонецЕсли;
		
		Док.Дата                       = Дата + 10;
		Док.Организация                = Организация;
		Док.Статус                     = Перечисления.СтатусыПеремещенийТоваров.Принято;
		Док.СкладОтправитель           = Склад;
		Док.СкладПолучатель            = Справочники.Склады.НайтиПоНаименованию("Склад возвратных отходов", Истина);
		Док.ВидЦены                    = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "УчетныйВидЦены");
		Док.СпособДоставки             = Перечисления.СпособыДоставки.Самовывоз;
		Док.ВариантПриемкиТоваров      = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
		Док.ПеремещениеПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		Док.ХозяйственнаяОперация      = Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
		Док.Ответственный              = Автор;
		Док.Автор                      = Автор;
		Док.Подразделение              = AMS_ВызовСервера.ПодразделениеПроизводство();
		Док.НаправлениеДеятельности    = Справочники.НаправленияДеятельности.НайтиПоНаименованию("Продажа", Истина);
		Док._Основание                 = Ссылка;
		Док._ОперацияПроизводства      = Перечисления.AMS_ОперацииПроизводства.ПеремещениеМатериаловБракаВОтходы;
		Док.Комментарий = "Сформирован автоматичестки. Перемещение неиспользуемых материалов на склад отходов (Переработка брака № "
			+ Номер + " от " + Формат(Док.Дата, "ДЛФ=Д") + " г.)";
	
		Док.Товары.Очистить();
	
		Для Каждого Стр Из Табл Цикл
			НовСтр = Док.Товары.Добавить();
			НовСтр.Номенклатура       = Стр.Номенклатура;
			НовСтр.Количество         = Стр.Количество;
			НовСтр.КоличествоУпаковок = Стр.Количество;
		КонецЦикла;
	
		мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ);
	КонецЕсли;
КонецПроцедуры

Процедура ОформитьВнутреннееПотреблениеМатериалов(ТабДок, Отказ)
	СтрДок = ТабДок.Найти(Перечисления.AMS_ОперацииПроизводства.СписаниеМатериаловНаПереработкуБрака);
	
	Табл = Новый ТаблицаЗначений();
	Табл.Колонки.Добавить("Номенклатура");
	Табл.Колонки.Добавить("Количество");
	
	Для Каждого Стр Из МатериалыСтарые Цикл
		Если Стр.КоличествоПереработка > 0 Тогда
			НовСтр = Табл.Добавить();
			НовСтр.Номенклатура = Стр.Номенклатура;
			НовСтр.Количество   = Стр.КоличествоПереработка;
		КонецЕсли;
	КонецЦикла;

	Для Каждого Стр Из МатериалыНовые Цикл
		Если AMS_ВызовСервера.ЭтоФабрикат(Стр.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;
		
		НовСтр = Табл.Добавить();
		НовСтр.Номенклатура = Стр.Номенклатура;
		НовСтр.Количество   = Стр.Количество;
	КонецЦикла;

	Для Каждого Стр Из Сырье Цикл
		НовСтр = Табл.Добавить();
		НовСтр.Номенклатура = Стр.Номенклатура;
		НовСтр.Количество   = Стр.Количество;
	КонецЦикла;
	
	Табл.Свернуть("Номенклатура", "Количество");
	Табл.Сортировать("Номенклатура");
	
	Если Табл.Количество() = 0 И Не СтрДок = Неопределено Тогда
			мср.УстановитьПометкуУдаленияДокументу(СтрДок.Ссылка, Истина);
		
	Иначе	
		Если СтрДок = Неопределено Тогда
			Док = Документы.ВнутреннееПотребление.СоздатьДокумент();
		Иначе
			Док = СтрДок.Ссылка.ПолучитьОбъект();
		КонецЕсли;

		Док.Дата                  = Дата + 20;
		Док.Организация           = Организация;
		Док.Склад                 = Склад;
		Док.Подразделение         = мср.СоответствиеЦехПодразделение().Получить(Склад);
		Док.ВидЦены               = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "УчетныйВидЦены");
		Док.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СписаниеТоваровПоТребованию;
		Док.Ответственный         = Автор;
		Док._Основание            = Ссылка;
		Док._ОперацияПроизводства = Перечисления.AMS_ОперацииПроизводства.СписаниеМатериаловНаПереработкуБрака;
		Док.Комментарий = "Сформирован автоматичестки. Списание материалов на переработку бракованной продукции (Переработка брака № "
			+ Номер + " от " + Формат(Док.Дата, "ДЛФ=Д") + " г.)";
	
		Док.Товары.Очистить();
		
		АналитикаРасходов = Справочники.ПрочиеРасходы.НайтиПоНаименованию("Материалы в производство", Истина);
		
		Для Каждого Стр Из Табл Цикл
			НовСтр = Док.Товары.Добавить();
	
			НовСтр.Номенклатура       = Стр.Номенклатура;
			НовСтр.КоличествоУпаковок = Стр.Количество;
			НовСтр.Количество         = Стр.Количество;
			НовСтр.СтатьяРасходов     = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("01-000082");
			НовСтр.АналитикаРасходов  = АналитикаРасходов;
		КонецЦикла;
	
		мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ);
	КонецЕсли;
КонецПроцедуры

Процедура ОформитьОприходованиеПродукции(ТабДок, Отказ)
	СтрДок = ТабДок.Найти(Перечисления.AMS_ОперацииПроизводства.ПроизводствоПродукцииИзБрака);

	Если СтрДок = Неопределено Тогда
		Док = Документы.ПрочееОприходованиеТоваров.СоздатьДокумент();
	Иначе
		Док = СтрДок.Ссылка.ПолучитьОбъект();
	КонецЕсли;

	Док.Дата                  = Дата + 30;
	Док.Организация           = Организация;
	Док.Склад                 = Склад;
	Док.Подразделение         = мср.СоответствиеЦехПодразделение().Получить(Склад);
	Док.ВидЦены               = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "УчетныйВидЦены");
	Док.Валюта                = Константы.ВалютаУправленческогоУчета.Получить();
	Док.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеИзПроизводства;
	Док.ВариантПриемкиТоваров = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
	Док._Основание            = Ссылка;
	Док._ОперацияПроизводства = Перечисления.AMS_ОперацииПроизводства.ПроизводствоПродукцииИзБрака;
	Док.Ответственный         = Автор;
	Док.Комментарий = "Сформирован автоматичестки. Оприходование переработанной бракованной продукции (Переработка брака № "
		+ Номер + " от " + Формат(Док.Дата, "ДЛФ=Д") + " г.)";

	Док.Товары.Очистить();

	Стр = Док.Товары.Добавить();
	Стр.Номенклатура = Номенклатура;
	Стр.Упаковка = Упаковка;
	Стр.КоличествоУпаковок = КоличествоУпаковок;
	Стр.Количество = Количество;
	Стр.Цена = Цена * ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "КоэффициентЕдиницыДляОтчетов");
	Стр.Сумма = Цена * Количество;
	Стр.СтатьяРасходовДоходов = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("01-000081");
	Стр.АналитикаРасходов = AMS_ВызовСервера.ПодразделениеПроизводство();

	мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ);
КонецПроцедуры

Процедура ОпменитьПеремещениеМатериаловДопЦех(ТабДок, Отказ)
	СтрДок = ТабДок.Найти(Перечисления.AMS_ОперацииПроизводства.ПеремещениеМатериаловНаПереработкуБрака);

	Если Не СтрДок = Неопределено Тогда
		мср.УстановитьПометкуУдаленияДокументу(СтрДок.Ссылка, Истина);
	КонецЕсли;
КонецПроцедуры

Процедура ПроверитьНаличиеНоменклатураБрак_МатериалыНовые(Отказ)
	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("МатериалыНовые", МатериалыНовые.Выгрузить());
	Запрос.УстановитьПараметр("Дата", Дата - 1);
	Запрос.УстановитьПараметр("СкладБракованнойПродукции", AMS_ВызовСервера.СкладБракованнойПродукции());
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("НоменклатураБрак", НоменклатураБрак);
	Запрос.УстановитьПараметр("КоличествоНоменклатураБрак", КоличествоБрак);
	Запрос.УстановитьПараметр("ВидНоменклатурыМатериал", AMS_ВызовСервера.ВидНоменклатурыМатериал());

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ МатериалыНовые
	|ИЗ
	|	&МатериалыНовые КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&СкладБракованнойПродукции КАК Склад,
	|	&НоменклатураБрак КАК Номенклатура,
	|	&КоличествоНоменклатураБрак - ЕСТЬNULL(ТоварыНаСкладах.ВНаличииОстаток, 0) КАК Остаток
	|ПОМЕСТИТЬ Остатки
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(&Дата, Склад = &СкладБракованнойПродукции
	|	И Номенклатура = &НоменклатураБрак) КАК ТоварыНаСкладах
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&Склад,
	|	МатериалыНовые.Номенклатура,
	|	МатериалыНовые.Количество - ЕСТЬNULL(ТоварыНаСкладах.ВНаличииОстаток, 0)
	|ИЗ
	|	МатериалыНовые КАК МатериалыНовые
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Дата, Склад = &Склад) КАК ТоварыНаСкладах
	|		ПО МатериалыНовые.Номенклатура = ТоварыНаСкладах.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.Склад КАК Склад,
	|	Остатки.Номенклатура КАК Номенклатура,
	|	Остатки.Остаток КАК Остаток,
	|	Ном.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ИЗ
	|	Остатки КАК Остатки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО Остатки.Номенклатура = Ном.Ссылка
	|		И Ном.ВидНоменклатуры = &ВидНоменклатурыМатериал
	|ГДЕ
	|	Остатки.Остаток > 0";

	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();

	Пока Выб.Следующий() Цикл
		ТекстОшибки = "Для переработки недостаточно """ + Выб.Номенклатура + """ на складе """ + Выб.Склад
			+ """ в количестве " + Выб.Остаток + " " + Выб.ЕдиницаИзмерения + ".";

		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , , Отказ);
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#КонецЕсли