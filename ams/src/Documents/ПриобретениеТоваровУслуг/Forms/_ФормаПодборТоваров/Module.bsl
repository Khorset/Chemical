	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг.Товары КАК Тов
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг КАК Док
	|			ПО Тов.Ссылка = Док.Ссылка
	|		ПО ном.Номенклатура = Тов.Номенклатура
	|ГДЕ
	|	НЕ Док.ПометкаУдаления
	|	И Док.Дата < &ДатаТекДок
	|	И Док.Партнер = &Партнер
	|СГРУППИРОВАТЬ ПО
	|	ном.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Тов.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(Тов.Сумма / ЕСТЬNULL(Тов.Количество, 1)) КАК Цена
	|ПОМЕСТИТЬ цен
	|ИЗ
	|	ном КАК ном
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ц КАК ц
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг.Товары КАК Тов
	|			ПО ц.Ссылка = Тов.Ссылка
	|			И ц.Номенклатура = Тов.Номенклатура
	|		ПО ном.Номенклатура = ц.Номенклатура
	|СГРУППИРОВАТЬ ПО
	|	Тов.Номенклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
