		Возврат;
	КонецЕсли;
	
	ПоказатьТабТовары();
	ПересчитатьТаблицу();
	УправлениеЭлементамиФормы();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормытТовары

&НаКлиенте
Процедура тТоварыЦех1ПриИзменении(Элемент)
	Стр = ТекущийЭлемент.ТекущиеДанные;
	
	Номенклатура = Стр.Номенклатура;
	Количество   = Стр.Цех1;
	
	Запомнить(Номенклатура,Количество,"Цех1");
	
	ПересчитатьСтроку(Стр);
	РассчитатьИтог()
КонецПроцедуры

&НаКлиенте
Процедура тТоварыЦех2ПриИзменении(Элемент)
	Стр = ТекущийЭлемент.ТекущиеДанные;
	
	Номенклатура = Стр.Номенклатура;
