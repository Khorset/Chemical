
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Данные = ПолучитьИзВременногоХранилища(Параметры.Адрес);
	
	Заголовок   = Данные.Заголовок;
	Организация = Данные.Организация;
	СкладЦех1   = AMS_ВызовСервера.Цех1();
	СкладЦех2   = AMS_ВызовСервера.Цех2();
	СкладЦех3   = AMS_ВызовСервера.Цех3();
	СкладРМ     = AMS_ВызовСервера.СкладРасходныхМатериалов();
	
	СоздатьУсловноеОформление();
	
	ПодготовитьИсходныеДанные(Данные);
	
	ПоказатьТабТовары();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура фЦех1ПриИзменении(Элемент)
	Если фЦех1 = Ложь И фЦех1+фЦех2+фЦех3+фРасходный = 0 Тогда
		фЦех1 = Истина;
		Возврат;
	КонецЕсли;
	
	ПоказатьТабТовары();
	ПересчитатьТаблицу();
	УправлениеЭлементамиФормы();
КонецПроцедуры

&НаКлиенте
Процедура фЦех2ПриИзменении(Элемент)
	Если фЦех2 = Ложь И фЦех1+фЦех2+фЦех3+фРасходный = 0 Тогда
		фЦех2 = Истина;
		Возврат;
	КонецЕсли;
	
	ПоказатьТабТовары();
	ПересчитатьТаблицу();
	УправлениеЭлементамиФормы();
КонецПроцедуры

