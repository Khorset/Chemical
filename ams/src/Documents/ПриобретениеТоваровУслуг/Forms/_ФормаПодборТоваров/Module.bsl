	Номенклатура = Стр.Номенклатура;
	Количество   = Стр.Расходный;
	
	Запомнить(Номенклатура,Количество,"Расходный");
	
	ПересчитатьСтроку(Стр);
	РассчитатьИтог()
КонецПроцедуры

&НаКлиенте
Процедура тТоварыУслугиПриИзменении(Элемент)
	Стр=ТекущийЭлемент.ТекущиеДанные;
	
	Стр.Сумма=Стр.Цена*Стр.Услуги;
	
	РассчитатьИтог()
КонецПроцедуры

&НаКлиенте
Процедура тТоварыЦенаПриИзменении(Элемент)
	Стр=ТекущийЭлемент.ТекущиеДанные;
	
	Если Стр.Номенклатура.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга") Тогда
		Стр.Сумма=Стр.Цена*Стр.Услуги;
	Иначе	
		Стр.Сумма=Стр.Цена*Стр.Количество;
	КонецЕсли; 
	
	РассчитатьИтог()
КонецПроцедуры

&НаКлиенте
Процедура тТоварыСуммаПриИзменении(Элемент)
	Стр=ТекущийЭлемент.ТекущиеДанные;
	
	Стр.Цена=Стр.Сумма/Стр.Итого;
	
	РассчитатьИтог()
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	ПеренестиДанныеВДокумент();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СоздатьУсловноеОформление()
	ЦветФона = ЦветаСтиля.ЦветФонаКнопки;
	
	УсловноеОформление.Элементы.Очистить();
	
	//Доступность ячеек в колонке Цех1
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("тТоварыЦех1");
	
	Отбор = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("тТовары.фЦех1");
	Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветФона);
	Элемент.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);

	//Доступность ячеек в колонке Цех2
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("тТоварыЦех2");
	
	Отбор = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("тТовары.фЦех2");
	Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветФона);
	Элемент.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
	
	//Доступность ячеек в колонке Цех3
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("тТоварыЦех3");
	
	Отбор = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("тТовары.фЦех3");
	Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветФона);
	Элемент.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
	
	//Доступность ячеек в колонке Расходный
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("тТоварыРасходный");
	
	Отбор = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("тТовары.фРасходный");
	Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветФона);
	Элемент.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
	
	//Доступность ячеек в колонке Услуги
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("тТоварыУслуги");
	
	Отбор = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("тТовары.фУслуги");
	Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.ПравоеЗначение = Ложь;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветФона);
	Элемент.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
	
	//Доступность ячеек в колонке Сумма
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("тТоварыСумма");
	
	Отбор = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("тТовары.Итого");
	Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.ПравоеЗначение = 0;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветФона);
	Элемент.Оформление.УстановитьЗначениеПараметра("Доступность", Ложь);
КонецПроцедуры

&НаСервере
Процедура ПодготовитьИсходныеДанные(Данные)
	Флаг = Новый Структура;
	Флаг.Вставить("фЦех1",Ложь);
	Флаг.Вставить("фЦех2",Ложь);
	Флаг.Вставить("фЦех3",Ложь);
	Флаг.Вставить("фРасходный",Ложь);
	Флаг.Вставить("фУслуги",Ложь);
	
	Склад = Данные.Склад;
	
	Результат = ПолучитьДанныеЗапроса(Данные);
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
	   	НовСтр = тТоварыКлиента.Добавить();
		
		ЗаполнитьЗначенияСвойств(НовСтр,Выборка);
		
		Если Выборка.Цех1 > 0 Тогда фЦех1 = Истина;	КонецЕсли;
		Если Выборка.Цех2 > 0 Тогда фЦех2 = Истина;	КонецЕсли;
		Если Выборка.Цех3 > 0 Тогда фЦех3 = Истина;	КонецЕсли;
		Если Выборка.Расходный > 0 Тогда фРасходный = Истина; КонецЕсли;
		
		Если Выборка.фЦех1 Тогда Флаг.фЦех1 = Истина;	КонецЕсли;
		Если Выборка.фЦех2 Тогда Флаг.фЦех2 = Истина;	КонецЕсли;
		Если Выборка.фЦех3 Тогда Флаг.фЦех3 = Истина;	КонецЕсли;
		Если Выборка.фРасходный Тогда Флаг.фРасходный = Истина; КонецЕсли;
		Если Выборка.фУслуги Тогда Флаг.фУслуги = Истина; КонецЕсли;
	КонецЦикла;
	
	КоличествоВыбранныхСкладов = фЦех1 + фЦех2 + фЦех3 + фРасходный;
	
	Элементы.тТоварыУслуги.Видимость = Флаг.фУслуги;
	
	Если КоличествоВыбранныхСкладов = 0 Тогда
		Если НЕ ЗначениеЗаполнено(Склад) Тогда
			фЦех1      = Флаг.фЦех1;
			фЦех2      = Флаг.фЦех2;
			фЦех3      = Флаг.фЦех3;
			фРасходный = Флаг.фРасходный;
				
		ИначеЕсли Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор("1fe241fb-1785-11e2-8e90-001e67078c9d")) Тогда //Цеха
			фЦех1      = Флаг.фЦех1;
			фЦех2      = Флаг.фЦех2;
			фЦех3      = Флаг.фЦех3;
			фРасходный = Флаг.фРасходный;
			
		Иначе
			фЦех1      = (Склад = СкладЦех1);
			фЦех2      = (Склад = СкладЦех2);
			фЦех3      = (Склад = СкладЦех3);
			фРасходный = (Склад = СкладРМ);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеЗапроса(Данные)
    УстановитьПривилегированныйРежим(Истина);
	
    Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаТекДок", Данные.ДатаТекДок);
	Запрос.УстановитьПараметр("Товары"    , Данные.Товары);
	Запрос.УстановитьПараметр("Партнер"   , Данные.Партнер);
	Запрос.УстановитьПараметр("СкладРМ"   , СкладРМ);
	Запрос.УстановитьПараметр("Цех1"      , СкладЦех1);
	Запрос.УстановитьПараметр("Цех2"      , СкладЦех2);
	Запрос.УстановитьПараметр("Цех3"      , СкладЦех3);
	Запрос.УстановитьПараметр("Старые"    , Справочники.Номенклатура.НайтиПоКоду("01-0000812"));
	
	Запрос.УстановитьПараметр("ВидНоменклатурыРасходные", AMS_ВызовСервера.ВидНоменклатурыРасходные());
	
	Запрос.УстановитьПараметр("СегментМатериалыЦеха1", AMS_ВызовСервера.СегментыНоменклатурыМатериалыЦеха1());
	Запрос.УстановитьПараметр("СегментМатериалыЦеха2", AMS_ВызовСервера.СегментыНоменклатурыМатериалыЦеха2());
	Запрос.УстановитьПараметр("СегментМатериалыЦеха3", AMS_ВызовСервера.СегментыНоменклатурыМатериалыЦеха3());
	
	Запрос.УстановитьПараметр("СегментУпаковкаЦеха1", AMS_ВызовСервера.СегментыНоменклатурыУпаковкаЦеха1());
	Запрос.УстановитьПараметр("СегментУпаковкаЦеха2", AMS_ВызовСервера.СегментыНоменклатурыУпаковкаЦеха2());
	Запрос.УстановитьПараметр("СегментУпаковкаЦеха3", AMS_ВызовСервера.СегментыНоменклатурыУпаковкаЦеха3());

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	т.Склад КАК Склад,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество,
	|	т.Сумма КАК Сумма
	|ПОМЕСТИТЬ т
	|ИЗ
	|	&Товары КАК т
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Склад КАК Склад,
	|	т.Номенклатура КАК Номенклатура,
	|	СпрНом.ТипНоменклатуры КАК ТипНоменклатуры,
	|	СУММА(т.Количество) КАК Количество,
	|	СУММА(т.Сумма) КАК Сумма
	|ПОМЕСТИТЬ тч
	|ИЗ
	|	т КАК т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНом
	|		ПО т.Номенклатура = СпрНом.Ссылка
	|СГРУППИРОВАТЬ ПО
	|	т.Склад,
	|	т.Номенклатура,
	|	СпрНом.ТипНоменклатуры
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Ссылка КАК Номенклатура
	|ПОМЕСТИТЬ стар
	|ИЗ
	|	Справочник.Номенклатура КАК т
	|ГДЕ
	|	т.Родитель = &Старые
	|	И НЕ т.ЭтоГруппа
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	тов.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ н
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг.Товары КАК тов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг КАК док
	|		ПО тов.Ссылка = док.Ссылка
	|ГДЕ
	|	док.Партнер = &Партнер
	|	И НЕ тов.Номенклатура В
	|		(ВЫБРАТЬ
	|			стар.Номенклатура
	|		ИЗ
	|			стар КАК стар)
	|	И док.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	тч.Номенклатура
	|ИЗ
	|	тч КАК тч
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	н.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ но
	|ИЗ
	|	н КАК н
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	но.Номенклатура КАК Номенклатура,
	|	СпрНом.ЕдиницаДляОтчетов КАК ЕдиницаДляОтчетов,
	|	СпрНом.КоэффициентЕдиницыДляОтчетов КАК Кфц,
	|	СпрНом.Наименование
	|ПОМЕСТИТЬ ном
	|ИЗ
	|	но КАК но
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНом
	|		ПО но.Номенклатура = СпрНом.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ном.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(Док.Ссылка) КАК Ссылка
	|ПОМЕСТИТЬ ц
	|ИЗ
