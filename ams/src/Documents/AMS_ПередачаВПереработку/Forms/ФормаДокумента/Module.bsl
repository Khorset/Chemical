&НаСервере
Функция ПолучитьАдресВХранилище()
	Попытка
		ЗаблокироватьДанныеФормыДляРедактирования();

		Данные = Новый Структура;

		Данные.Вставить("Контрагент", Объект.Контрагент);
		Данные.Вставить("Склад", Объект.Склад);
		Данные.Вставить("Дата", Объект.Дата - 1);
		Данные.Вставить("Расход", Объект.Товары.Выгрузить( , "Номенклатура,Количество"));
		Данные.Вставить("Приход", ПолучитьТоварыОснования(Объект.Основание));

		Возврат ПоместитьВоВременноеХранилище(Данные);

	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьТоварыОснования(Основание)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Основание", Основание);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура,
	|	т.Количество
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Основание
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т.Номенклатура,
	|	т.Количество
	|ИЗ
	|	Документ._ВозвратИзПереработки.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Основание
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т.Номенклатура,
	|	т.Количество
	|ИЗ
	|	Документ.ВводОстатковТоваров.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Основание
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т.Номенклатура,
	|	т.Количество
	|ИЗ
	|	Документ.ОприходованиеИзлишковТоваров.Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Основание";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьЦену(Номенклатура)
	Цена = ПолучитьЦенуИзПередачаВПереработку(Номенклатура);

	Если Цена = 0 Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	т.Номенклатура КАК Номенклатура,
		|	МАКСИМУМ(т.Период) КАК Период
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатурыПоставщиков КАК т
		|ГДЕ
		|	т.Номенклатура = &Номенклатура
		|СГРУППИРОВАТЬ ПО
		|	т.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	т.Цена * 100 / 120 КАК Цена
		|ИЗ
		|	вт КАК вт
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатурыПоставщиков КАК т
		|		ПО вт.Номенклатура = т.Номенклатура
		|		И вт.Период = т.Период";

		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

		Рез = Запрос.Выполнить();

		Если Рез.Пустой() Тогда
			Возврат 0;

		Иначе
			Выб = Рез.Выбрать();
			Выб.Следующий();

			Возврат Выб.Цена;
		КонецЕсли;

	Иначе
		Возврат Цена;
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьЦенуИзПередачаВПереработку(Номенклатура)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	т.Цена КАК Цена
	|ИЗ
	|	Документ.AMS_ПередачаВПереработку.Товары КАК т
	|ГДЕ
	|	т.Номенклатура = &Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Ссылка.Дата УБЫВ";

	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат 0;

	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();

		Возврат Выб.Цена;
	КонецЕсли;
КонецФункции

