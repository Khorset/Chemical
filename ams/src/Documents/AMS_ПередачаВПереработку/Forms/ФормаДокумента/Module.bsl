	СтруктураДействий.Вставить("ПересчитатьЦенуЗаУпаковку", Стр.Количество);
	СтруктураДействий.Вставить("ПересчитатьСумму");

	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(Стр, СтруктураДействий, КэшированныеЗначения);

	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма");
КонецПроцедуры
