#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Подбор(Команда)
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Поле ""Контрагент"" не заполнено", Объект.Ссылка,
			"Объект.Контрагент");
		Возврат;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Объект.Склад) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Поле ""Склад"" не заполнено", Объект.Ссылка, "Объект.Склад");
		Возврат;
	КонецЕсли;

	КонтрагентНаименование = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Объект.Контрагент, "Наименование");

	Если КонтрагентНаименование = "Эстервуд" Тогда
		Парам = Новый Структура;
		Парам.Вставить("Продукция", ПолучитьДавальческуюПродукциюЭстервуд());
		Парам.Вставить("Склад", Объект.Склад);
		Парам.Вставить("Дата", Объект.Дата - 1);
		Парам.Вставить("Товары", ПолучитьТовары());

		ОткрытьФорму("Документ.AMS_ПередачаВПереработку.Форма.ПодборСырья", Парам, ЭтотОбъект, , , ,
			Новый ОписаниеОповещения("ОткрытьФормуПодборЗавершение", ЭтотОбъект),
			РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	Иначе
		Если Не ЗначениеЗаполнено(Объект.Основание) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю("Поле ""Основание"" не заполнено", Объект.Ссылка,
				"Объект.Основание");
			Возврат;
		КонецЕсли;

		АдресВХранилищеДляПодбора = ПолучитьАдресВХранилище();
		Если Не АдресВХранилищеДляПодбора = Неопределено Тогда
			ОткрытьФорму("Документ.AMS_ПередачаВПереработку.Форма.ПодборПреформ", Новый Структура("АдресВХранилище",
				АдресВХранилищеДляПодбора), ЭтотОбъект, , , , Новый ОписаниеОповещения("ОткрытьФормуПодборЗавершение",
				ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПечатьНакладнаяНаПеремещение(Команда)
	МассивВыделенныхДокументов = Новый Массив;
	МассивВыделенныхДокументов.Добавить(Объект.Ссылка);
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.AMS_ПередачаВПереработку", "НакладнаяНаПеремещение",
		МассивВыделенныхДокументов, Неопределено);
КонецПроцедуры

