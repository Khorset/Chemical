#Область ОписаниеПеременных

&НаКлиенте
Перем КэшированныеЗначения;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Элементы.Партнер.СписокВыбора.ЗагрузитьЗначения(мср.ПолучитьМассивПартнеровДавальческих());
	Элементы.ТоварыНоменклатура.СписокВыбора.ЗагрузитьЗначения(мср.ПолучитьМатериалыВПереработку());

	Элементы.Товары.ТолькоПросмотр = Не (AMS_ВызовСервера.ЭтоKhors() Или Пользователи.РолиДоступны("_Бухгалтер"));

	Элементы.ПеремещениеТоваров.Видимость = AMS_ВызовСервера.ЭтоKhors();

	СервисДоставки.ПриСозданииНаСервере(ЭтотОбъект);
	
	ДоставкаТоваров.ЗаполнитьРеквизитыДоставки(Элементы, "СпособДоставки", Объект);

	ДанныеДоставки = AMS_СобытияФорм.ПолучитьТранспортДоставки(Объект.Ссылка);
	Если Не ДанныеДоставки = Неопределено Тогда
		AMS_ТранспортноеСредство = ДанныеДоставки.ТранспортноеСредство;
		AMS_Водитель             = ДанныеДоставки.Водитель;
		AMS_ТелефонВодителя      = AMS_ВызовСервера.ПолучитьТелефонМобильныйФизическиеЛица(ДанныеДоставки.Водитель);
	КонецЕсли;
	
	УстановитьУсловноеОформление();
	
	AMS_УправлениеРеквизитамиДоставки();
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	AMS_Сервер.УстановитьВремяДокумента(ТекущийОбъект, "AMS_ПередачаВПереработку", 31500, 32000); //08:45 - 09:00
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить("Запись_AMS_ПередачаВПереработку", ПараметрыЗаписи, Объект.Ссылка);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПартнерПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(Объект.Партнер) Тогда
		ДоставкаТоваровКлиентСервер.ОчиститьРеквизитыДоставки(Элементы, Объект);
		Возврат;
	КонецЕсли;

	Контрагент = AMS_ВызовСервера.ПолучитьКонтрагентаПартнёра(Объект.Партнер);
	Если Не Контрагент = Неопределено Тогда
		Объект.Контрагент = Контрагент;
	КонецЕсли;

	Если ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Объект.Партнер, "Код") = "01-00001278" Тогда // Эстервуд
		Объект.Склад = AMS_ВызовСервера.Цех1();
	КонецЕсли;

	ПриИзмененииПартнераСервер();
КонецПроцедуры

