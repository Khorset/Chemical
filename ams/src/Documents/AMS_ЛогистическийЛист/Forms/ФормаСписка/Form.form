  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	т.Ссылка КАК Ссылка,
	т.Номер КАК Номер,
	т.Дата КАК Дата,
	т.Статус КАК Статус,
	т.ПометкаУдаления КАК ПометкаУдаления,
	т.Проведен КАК Проведен
ПОМЕСТИТЬ Док
ИЗ
	Документ.AMS_ЛогистическийЛист КАК т

ИНДЕКСИРОВАТЬ ПО
	Ссылка
;

////////////////////////////////////////////////////////////////////////////////
 ВЫБРАТЬ
	т.Регистратор КАК Регистратор,
	СУММА(т.ВесДоставка) КАК ВесДоставка,
	СУММА(т.КоличествоПалетДоставка) КАК КоличествоПалетДоставка,
	СУММА(т.ВесПодвоз) КАК ВесПодвоз,
	СУММА(т.КоличествоПалетПодвоз) КАК КоличествоПалетПодвоз
ПОМЕСТИТЬ Рейсы
ИЗ
	Док КАК Док
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений._Рейсы КАК т
		ПО Док.Ссылка = т.Регистратор
СГРУППИРОВАТЬ ПО
	т.Регистратор

ИНДЕКСИРОВАТЬ ПО
	Регистратор
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Док.Ссылка КАК Ссылка,
	Док.Номер КАК Номер,
	Док.Дата КАК Дата,
	Док.Статус КАК Статус,
	Док.Проведен КАК Проведен,
	Док.ПометкаУдаления КАК ПометкаУдаления,
	ВЫБОР
		КОГДА Док.Проведен
			ТОГДА 1
		ИНАЧЕ ВЫБОР
			КОГДА Док.ПометкаУдаления
				ТОГДА 3
			ИНАЧЕ 0
		КОНЕЦ
	КОНЕЦ КАК НомерКартинки,
	ЕСТЬNULL(Рейсы.ВесДоставка, 0) КАК ВесДоставка,
	ЕСТЬNULL(Рейсы.КоличествоПалетДоставка, 0) КАК ПалетДоставка,
	ЕСТЬNULL(Рейсы.ВесПодвоз, 0) КАК ВесПодвоз,
	ЕСТЬNULL(Рейсы.КоличествоПалетПодвоз, 0) КАК ПалетПодвоз
ИЗ
	Док КАК Док
		ЛЕВОЕ СОЕДИНЕНИЕ Рейсы КАК Рейсы
		ПО Док.Ссылка = Рейсы.Регистратор</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
