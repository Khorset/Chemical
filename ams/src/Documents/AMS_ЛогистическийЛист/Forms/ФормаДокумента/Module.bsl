&НаСервере
Процедура ПроверитьРаспоряженияПогрузка(Отказ = Ложь)
	Для Каждого Стр Из Объект.Распоряжения Цикл
		Док = Стр.Распоряжение;

		Если ТипЗнч(Док) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			ДатаРейса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "ДатаОтгрузки");
		ИначеЕсли ТипЗнч(Док) = Тип("ДокументСсылка.ЗаказПоставщику") Или ТипЗнч(Док) = Тип("ДокументСсылка.ЗаявкаНаВозвратТоваровОтКлиента") Тогда
			ДатаРейса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "ДатаПоступления");
		Иначе
			ДатаРейса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "Дата");
		КонецЕсли;
	
		Если НачалоДня(Объект.Дата) <> НачалоДня(ДатаРейса) Тогда
			Текст = "Дата отгрузки/поступления " + Док + " не соответствует дате логистического листа.";
			ОбщегоНазначения.СообщитьПользователю(Текст, , , , Отказ);
		КонецЕсли;
	
		ПометкаУдаления = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док, "ПометкаУдаления");
		
		Если ПометкаУдаления Тогда
			Текст = "Документ " + Док + " помечен на удаление.";
			ОбщегоНазначения.СообщитьПользователю(Текст, , , , Отказ);
		КонецЕсли;
	КонецЦикла;

	Для Каждого Стр Из Объект.Рейсы Цикл
		Если Стр.Пробег = 0 Тогда
			Текст = "Для автомобиля " + Стр.ТранспортноеСредство + " не заполнено поле ""Расстояние""";
			ОбщегоНазначения.СообщитьПользователю(Текст, , , , Отказ);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКоличествоПалетВес()
	ПалетДоставка  = 0;
	ВесДоставка    = 0;
	ВесДоставка    = 0;

	Таб1 = Задания.ПолучитьЭлементы();
	Для Каждого Стр1 Из Таб1 Цикл
		Палет1 = 0;
		ПалетПлан1 = 0;
		Вес1 = 0;
		ВесПлан1 = 0;

		Таб2 = Стр1.ПолучитьЭлементы();
		Для Каждого Стр2 Из Таб2 Цикл
			Палет1     = Палет1 + Стр2.КоличествоПалет;
			ПалетПлан1 = ПалетПлан1 + ?(Стр2.КоличествоПалетПлан = 0, Стр2.КоличествоПалет, Стр2.КоличествоПалетПлан);
			Вес1       = Вес1 + Стр2.Вес;
			ВесПлан1   = ВесПлан1 + ?(Стр2.ВесПлан = 0, Стр2.Вес, Стр2.ВесПлан);
		КонецЦикла;

		Стр1.КоличествоПалетИнфо = ?(ПалетПлан1 = Палет1, Строка(Палет1), Строка(ПалетПлан1) + "/" + Строка(Палет1));
		Стр1.ВесИнфо = ?(ВесПлан1 = Вес1, Формат(Вес1, "ЧДЦ=1"), Формат(ВесПлан1, "ЧДЦ=1") + "/" + Формат(Вес1, "ЧДЦ=1"));

		ПалетДоставка = ПалетДоставка + Палет1;
		ВесДоставка   = ВесДоставка + Вес1;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПоказатьПретензии()
	Претензии.Очистить();

	Строки = Объект.Распоряжения.НайтиСтроки(Новый Структура("ЕстьПретензия", Истина));

	НомерСтроки = 0;
	Для Каждого Стр Из Строки Цикл
		НомерСтроки = НомерСтроки + 1;
		НовСтр = Претензии.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
		НовСтр.НомерСтроки = НомерСтроки;
	КонецЦикла;

	КоличествоПретензий = Претензии.Количество();
КонецПроцедуры

