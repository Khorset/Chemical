&НаСервере
Процедура НастройкаФормы()
	ЭтоKhors     = AMS_ВызовСервера.ЭтоKhors();
	ЭтоЛогист    = Пользователи.РолиДоступны("AMS_Диспетчер") Или ЭтоKhors;
	ЭтоСклад     = Пользователи.РолиДоступны("_НачальникСклада");
	ЭтоМенеджер  = (Пользователи.РолиДоступны("_СтаршийМенеджер, AMS_МенеджерПродаж") 
						Или Не ПравоДоступа("Изменение", Метаданные.Документы.AMS_ЛогистическийЛист))
					И Не ЭтоKhors;
	ЭтоБухСклада = Пользователи.РолиДоступны("_БухгалтерСклада");

	План       = Объект.Статус = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._СтатусыДоставки.План");
	Погрузка   = Объект.Статус = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._СтатусыДоставки.Погрузка");
	Отправлено = Объект.Статус = ОбщегоНазначения.ПредопределенныйЭлемент("Перечисление._СтатусыДоставки.Отправлено");

	Элементы.Номер.ТолькоПросмотр = Истина;
	Элементы.Дата.ТолькоПросмотр  = Не План;

	Элементы.ОтменыДоставки.ТолькоПросмотр  = Не ЭтоKhors;
	Элементы.ВозвратыТоваров.ТолькоПросмотр = Не ЭтоKhors;

	Элементы.ФормаПечатьМаршрутныйЛистExcel.Доступность = ЭтоЛогист;

	Элементы.ФормаПечатьКомплектДокументов.Видимость   = ЭтоБухСклада Или ЭтоKhors;
	Элементы.ФормаПечатьКомплектДокументов.Доступность = Погрузка Или Отправлено;

	Элементы.ГруппаПлан.Видимость = Не Отправлено;

	Элементы.ЗаданияГруппаЕсть.Видимость = Отправлено И ЭтоЛогист;

	ТолькоПросмотр = Не (ЭтоЛогист Или ЭтоСклад);

	Если ЭтоЛогист Тогда 
		// Ничего не делаем (Логист может быть и Менеджером)
	ИначеЕсли ЭтоСклад Или ЭтоМенеджер Тогда
		Элементы.ЗаданияУдалитьДоставку.Видимость = Ложь;
		Элементы.ЗаданияВозвратТовара.Видимость   = Ложь;

		Если ЭтоСклад Тогда
			Элементы.ДополнительноеВремя.Видимость = Ложь;
			Элементы.НарушенияДоговора.Видимость   = Ложь;
			Элементы.Претензии.Видимость           = Ложь;
	
		ИначеЕсли ЭтоМенеджер Тогда
			Элементы.ТранспортМетка.Доступность = Ложь;
	
			Элементы.ТранспортВодитель.ТолькоПросмотр         = Истина;
			Элементы.ЗаданияГруппаЗагрузкаФакт.ТолькоПросмотр = Истина;
			Элементы.ЗаданияОтправлено.ТолькоПросмотр         = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
//	ЭтоМенеджер  = Пользователи.РолиДоступны("AMS_МенеджерПродаж");

	УсловноеОформление.Элементы.Очистить();
	
	//Транспорт
	//Изменить цвет текста, если транспорт не участвует в рейсе - снята Метка
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Транспорт.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Транспорт.Метка");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Ложь;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЗаблокированныйРеквизитЦвет);
	
	//Распоряжения: Заказ клиента - цвет фона розовый
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Распоряжения.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Распоряжения.Порядок");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = 1;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ФонПодписьНеверна);
	
	//Распоряжения: Загрузка утверждена менеджером - цвет фона зеленый
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Распоряжения.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Распоряжения.УтвержденаОтгрузка");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветТекстаКонтрагентаДействующего);
	
	//Распоряжения: Зона не указана - вывести текст <зона не указана>
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.РаспоряженияЗонаДоставки.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Распоряжения.ЗонаДоставки");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Справочники.ЗоныДоставки.ПустаяСсылка();

	//@skip-check new-font
	Элемент.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(, , , Истина));
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<зона не указана>'"));
	
	//Распоряжения: Подвоз товаров на наш склад
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Распоряжения.Имя);

