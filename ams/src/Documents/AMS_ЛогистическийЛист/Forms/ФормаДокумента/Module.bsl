
#Область ОписаниеПеременных

&НаКлиенте
Перем МеСтатус;

&НаКлиенте
Перем МеМодифицированность;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.Дата = мср.ПолучитьРабочийДень(1);
	КонецЕсли;
	
	Элементы.Организация.СписокВыбора.Добавить(AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию());
	
	Элементы.СтрТЧ.Видимость = AMS_ВызовСервера.ЭтоKhors();

	УстановитьУсловноеОформление();

	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ЗаданияВремяЗагрузкиФакт);
	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ЗаданияОтправлено);

	ПоменятьЗаказыНаРеализации();
	ПоказатьТранспортКЗагрузке();
	ПоказатьДокументыКЗагрузке();
	ПоказатьЗадания();
	ПоказатьДополнительноеВремя();
	ПоказатьНарушенияДоговора();
	ПоказатьПретензии();

	НастройкаФормы();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Запись_ТранспортноеСредство" Тогда
		ПоказатьТранспортКЗагрузке();

	ИначеЕсли ИмяСобытия = "Запись_ЗаказКлиента" Или ИмяСобытия = "Запись_РеализацияТоваровУслуг" 
		Или ИмяСобытия = "Запись_ПередачаТоваровХранителю" Или ИмяСобытия = "Запись_AMS_ПередачаВПереработку" 
		Или ИмяСобытия = "Запись_ЗаказПоставщику" Или ИмяСобытия = "Запись_ЗаявкаНаВозвратТоваровОтКлиента" Тогда
		
		ДатаОтгрузки = ПолучитьДатуОтгрузки(ИмяСобытия, Источник);
	
		Если ДеньГода(Объект.Дата) = ДеньГода(ДатаОтгрузки) Тогда
			Прочитать();
			ПоказатьДокументыКЗагрузке();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить("Запись_ЛогистическийЛист", ПараметрыЗаписи, Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Объект.Статус = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._СтатусыДоставки.План") Тогда
		Если Объект.Проведен Тогда
			ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения;
		Иначе
			ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Запись;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	ПоказатьДокументыКЗагрузке();
КонецПроцедуры

&НаКлиенте
Процедура СтатусНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	МеСтатус             = Объект.Статус;
	МеМодифицированность = Модифицированность;
КонецПроцедуры

&НаКлиенте
Процедура СтатусПриИзменении(Элемент)
	Если Объект.Статус = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._СтатусыДоставки.Погрузка") Тогда
		Отказ = Ложь;
	
		ПроверитьРаспоряженияПогрузка(Отказ);
	
		Если Отказ Тогда
			Объект.Статус = МеСтатус;
	
			Если Не МеМодифицированность Тогда
				Объект.Статус = МеСтатус;
				Модифицированность = Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
		
	НастройкаФормы();
КонецПроцедуры

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	Если ТекущаяСтраница = Элементы.СтрДоставка Тогда
		ПоказатьТранспортКЗагрузке();
		ПоказатьДокументыКЗагрузке();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТранспорт

&НаКлиенте
Процедура ТранспортВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если AMS_ВызовСервера.ДоступнаРоль("AMS_Диспетчер") Тогда
		Если Поле.Имя = "ТранспортМетка" Тогда
			Возврат;
		КонецЕсли;

		Стр = ТекущийЭлемент.ТекущиеДанные;

		Если Стр.Метка Тогда
			СтандартнаяОбработка = Ложь;
			ОткрытьФормуПодборДокументовВТранспорт(Новый Структура("Авто, УПД",	Стр.ТранспортноеСредство, Неопределено));
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТранспортМеткаПриИзменении(Элемент)
	Стр = ТекущийЭлемент.ТекущиеДанные;

	ТранспортноеСредство = Стр.ТранспортноеСредство;

	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект, ТранспортноеСредство);
	ПоказатьВопрос(Оповещение, "Транспортному средству " + ТранспортноеСредство
		+ " будет установлен стасут ""Не работает"". Продолжить выполнение операции?", РежимДиалогаВопрос.ДаНет);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРаспоряжения

&НаКлиенте
Процедура РаспоряженияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если AMS_ВызовСервера.ДоступнаРоль("AMS_Диспетчер") Или AMS_ВызовСервера.ЭтоKhors() Тогда
		Стр = ТекущийЭлемент.ТекущиеДанные;

		Если Поле.Имя = "РаспоряженияРасстояние" Тогда
			Парам = Новый Структура;
			Парам.Вставить("ЗонаДоставки", Стр.ЗонаДоставки);
			Парам.Вставить("Партнер", Стр.Партнер);
			Парам.Вставить("АдресДоставки", Стр.АдресДоставки);
			Парам.Вставить("ИндексСтроки", ВыбраннаяСтрока - 1);

			Оповещение = Новый ОписаниеОповещения("ПослеВводаРасстояния", ЭтотОбъект, Парам);
			ПоказатьВводЧисла(Оповещение, Стр.Расстояние, "Введите расстояние", 10, 0);

		Иначе
			ПоказатьЗначение( , Стр.Распоряжение);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗадания

&НаКлиенте
Процедура ЗаданияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Имя = Поле.Имя;
	Стр = Элемент.ТекущиеДанные;

	Авто  = Стр.ТранспортноеСредство;
	Док   = Стр.Распоряжение;
	Адрес = Стр.АдресДоставки;

	Если AMS_ВызовСервера.ДоступнаРоль("_БухгалтерСклада") И ЗначениеЗаполнено(Док) И Не AMS_ВызовСервера.ЭтоKhors() Тогда
		ПоказатьЗначение( , Док);
		Возврат;
	КонецЕсли;

	Если Не AMS_ВызовСервера.ДоступнаРоль("AMS_Диспетчер") Тогда
		Возврат;
	КонецЕсли;

	Если Имя = "ЗаданияТранспортНомер" И Не ПустаяСтрока(Адрес) Тогда
		Если Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыДоставки.Отправлено") Тогда
			ПоказатьЗначение( , Док);
		Иначе
			УправлениеКонтактнойИнформациейКлиент.ПоказатьАдресНаКарте(Адрес, "Яндекс.Карты");
		КонецЕсли;
		
	ИначеЕсли Объект.Статус = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._СтатусыДоставки.Погрузка")
		И (Имя = "ЗаданияДатаЗагрузкиФакт" Или Имя = "ЗаданияВремяЗагрузкиФакт" Или Имя = "ЗаданияОтправлено") Тогда
		// Производим ввод данных

	ИначеЕсли Объект.Статус = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._СтатусыДоставки.Отправлено")
		И (Имя = "ЗаданияЕстьЧек" Или Имя = "ЗаданияЕстьНарушениеДоговора" Или Имя = "ЗаданияЕстьПретензия") Тогда
		// Производим ввод данных

	ИначеЕсли Имя = "ЗаданияПеревозчик" Тогда
		Если ЗначениеЗаполнено(Стр.Перевозчик) Тогда
			ПоказатьЗначение( , Стр.Перевозчик);

		ИначеЕсли ЗначениеЗаполнено(Стр.Партнер) Тогда
			ПоказатьЗначение( , Стр.Партнер);
		КонецЕсли;

	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыДоставки.План")
		И ЗначениеЗаполнено(Авто) И Не ЗначениеЗаполнено(Док) Тогда

		Если ПолучитьКоличествоЗагруженныхУПД(Авто) = 1 Тогда
			Док = ПолучитьУПД(Авто);
		Иначе
			Док = Неопределено;
		КонецЕсли;

		ОткрытьФормуПодборДокументовВТранспорт(Новый Структура("Авто, УПД", Авто, Док));

	ИначеЕсли ЗначениеЗаполнено(Док) Тогда
		ПоказатьЗначение( , Док);

	ИначеЕсли ЗначениеЗаполнено(Авто) Тогда
		ПоказатьЗначение( , Авто);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаданияПриИзменении(Элемент)
	ТекДанные = Элемент.ТекущиеДанные;
	ТекПоле   = Элемент.ТекущийЭлемент.Имя;

	Авто = ТекДанные.ТранспортноеСредство;
	УПД  = ТекДанные.Распоряжение;

	Если ТекПоле = "ЗаданияДатаЗагрузкиФакт" Тогда
		УстановитьДатаЗагрузкиФакт(Авто, ТекДанные.ДатаЗагрузкиФакт);

	ИначеЕсли ТекПоле = "ЗаданияВремяЗагрузкиФакт" Тогда
		УстановитьВремяЗагрузкиФакт(Авто, ТекДанные.ВремяЗагрузкиФакт);

	ИначеЕсли ТекПоле = "ЗаданияОтправлено" Тогда
		УстановитьОтправлено(Авто, ТекДанные.Отправлено);

	ИначеЕсли ТекПоле = "ЗаданияЕстьЧек" Тогда
		УстановитьЕстьЧек(УПД, ТекДанные.ЕстьЧек);

	ИначеЕсли ТекПоле = "ЗаданияЕстьНарушениеДоговора" Тогда
		УстановитьЕстьНарушениеДоговора(УПД, ТекДанные.ЕстьНарушениеДоговора);

	ИначеЕсли ТекПоле = "ЗаданияЕстьПретензия" Тогда
		УстановитьЕстьПретензия(УПД, ТекДанные.ЕстьПретензия);

	ИначеЕсли ТекПоле = "ЗаданияЕстьУПД" Тогда
		УстановитьЕстьУПД(УПД, ТекДанные.ЕстьУПД);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДополнительноеВремя

&НаКлиенте
Процедура ДополнительноеВремяСтоимостьЧекаПриИзменении(Элемент)
	ТекДанные = ТекущийЭлемент.ТекущиеДанные;

	Авто           = ТекДанные.ТранспортноеСредство;
	УПД            = ТекДанные.Распоряжение;
	СтоимостьЧека  = ТекДанные.СтоимостьЧека;

	УстановитьСтоимостьЧека(Авто, УПД, СтоимостьЧека);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыНарушенияДоговора

&НаКлиенте
Процедура НарушенияДоговораПунктДоговораПриИзменении(Элемент)
	ТекДанные = ТекущийЭлемент.ТекущиеДанные;

	Авто          = ТекДанные.ТранспортноеСредство;
	УПД           = ТекДанные.Распоряжение;
	ПунктДоговора = ТекДанные.ПунктДоговора;

	УстановитьПунктДоговора(Авто, УПД, ПунктДоговора);
КонецПроцедуры
&НаКлиенте
Процедура НарушенияДоговораСуммаШтрафаПриИзменении(Элемент)
	ТекДанные = ТекущийЭлемент.ТекущиеДанные;

	Авто        = ТекДанные.ТранспортноеСредство;
	УПД         = ТекДанные.Распоряжение;
	СуммаШтрафа = ТекДанные.СуммаШтрафа;

	УстановитьСуммаШтрафа(Авто, УПД, СуммаШтрафа);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПретензии

&НаКлиенте
Процедура ПретензииВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекПоле = Поле.Имя;

	Если ТекПоле = "ПретензииСодержаниеПретензии" Тогда
		ТекДанные = Элемент.ТекущиеДанные;

		Подсказка = "Содержание претензии";
		Оповещение = Новый ОписаниеОповещения("ПослеВводаСодержания", ЭтотОбъект,
			Новый Структура("ТранспортноеСредство,Распоряжение", ТекДанные.ТранспортноеСредство,
			ТекДанные.Распоряжение));
		СодержаниеПретензии = ТекДанные.СодержаниеПретензии;

		ПоказатьВводСтроки(Оповещение, СодержаниеПретензии, Подсказка, , Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПретензииСуммаПретензииПриИзменении(Элемент)
	ТекДанные = ТекущийЭлемент.ТекущиеДанные;

	Авто = ТекДанные.ТранспортноеСредство;
	УПД  = ТекДанные.Распоряжение;

	СуммаПретензии = ТекДанные.СуммаПретензии;

	УстановитьСуммаПретензии(Авто, УПД, СуммаПретензии);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

#Область ПодменюПечать

&НаКлиенте
Процедура ПечатьЛогистическийЛист(Команда)
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Необходимо предварительно записать изменения.");
		Возврат;
	КонецЕсли;

	Массив = Новый Массив;
	Массив.Добавить(Объект.Ссылка);

	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Обработка.AMS_Продажи", "ЛогистическийЛист", Массив, Неопределено,
		Новый Структура("Доставка", Неопределено));
КонецПроцедуры

&НаКлиенте
Процедура ПечатьЛогистическийЛистДоставка(Команда)
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Необходимо предварительно записать изменения.");
		Возврат;
	КонецЕсли;

	Массив = Новый Массив;
	Массив.Добавить(Объект.Ссылка);

	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Обработка.AMS_Продажи", "ЛогистическийЛистДоставка", Массив,
		Неопределено, Новый Структура("Доставка", Истина));
КонецПроцедуры

&НаКлиенте
Процедура ПечатьЛогистическийЛистПодвоз(Команда)
	Если Модифицированность Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Необходимо предварительно записать изменения.");
		Возврат;
	КонецЕсли;

	Массив = Новый Массив;
	Массив.Добавить(Объект.Ссылка);

	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Обработка.AMS_Продажи", "ЛогистическийЛистПодвоз", Массив,
		Неопределено, Новый Структура("Доставка", Ложь));
КонецПроцедуры

&НаКлиенте
Процедура ПечатьМаршрутныйЛист(Команда)
	МассивОбъектов       = Новый Массив;
	МассивОбъектов.Добавить(Объект.Ссылка);

	ТабличныеДокументы = Новый СписокЗначений;

	Парам = Новый Структура("Лист,Дата,Номер", Объект.Ссылка, Объект.Дата, Объект.Номер);
	Парам.Вставить("Перевозчик");
	
	МассивПеревозчиков = ПолучитьМассивПеревозчиков();
	
	Для Каждого Перевозчик Из МассивПеревозчиков Цикл
		Парам.Перевозчик = Перевозчик;
	
		ПечатнаяФорма = AMS_ВызовСервера.СформироватьМаршрутныйЛист(Парам);

		ТабличныеДокументыДляПечати(ТабличныеДокументы, ПечатнаяФорма);
		
	КонецЦикла;
	
	УправлениеПечатьюКлиент.РаспечататьТабличныеДокументы(ТабличныеДокументы, МассивОбъектов, Ложь, 1);
КонецПроцедуры

&НаКлиенте
Процедура ПечатьМаршрутныйЛистExcel(Команда)
	Состояние("Создание файлов EXCEL.");

	МассивПеревозчиков = ПолучитьМассивПеревозчиков();

	Парам = Новый Структура("Лист,Дата,Номер", Объект.Ссылка, Объект.Дата, Объект.Номер);
	Парам.Вставить("Перевозчик");

	Для Каждого Перевозчик Из МассивПеревозчиков Цикл
		Парам.Перевозчик = Перевозчик;

		ТабДок = AMS_ВызовСервера.СформироватьМаршрутныйЛист(Парам);
		
		//ТабДок.Показать();

		ИмяКаталогаЛогиста   = "\\AMSSERVN\disk_y\ОТДЕЛ ПРОДАЖ\Логист\ЗАЯВКИ НА ТРАНСПОРТ\";
		ПапкаКаталогаЛогиста = Новый Файл(ИмяКаталогаЛогиста);

		Если Не ПапкаКаталогаЛогиста.Существует() Тогда
			ИмяКаталогаЛогиста  = "F:\arhiv\";
		КонецЕсли;

		ИмяКаталога = СокрЛП(ИмяКаталогаЛогиста + Формат(Объект.Дата, "ДФ=""гггг'_'ММ'_'дд""") + " - "
			+ ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Объект.Номер));
		ФайлКаталога = Новый Файл(ИмяКаталога);
		
		Если Не ФайлКаталога.Существует() Тогда
			СоздатьКаталог(ИмяКаталога);
		КонецЕсли;

		ПолныйПутьКФайлу = ИмяКаталога + "\" + ?(ЗначениеЗаполнено(Перевозчик), Перевозчик, "Неизвестно") + ".XLSX";

		Попытка
			ТабДок.Записать(ПолныйПутьКФайлу, ТипФайлаТабличногоДокумента.XLSX);
			ОбщегоНазначенияКлиент.СообщитьПользователю("Записан новый файл " + ПолныйПутьКФайлу);
		Исключение
			ОбщегоНазначенияКлиент.СообщитьПользователю(ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;

	Состояние();
КонецПроцедуры

