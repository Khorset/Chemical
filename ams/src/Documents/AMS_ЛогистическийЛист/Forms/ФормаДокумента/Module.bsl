		Возврат;
	КонецЕсли;

	Модифицированность = Истина;

	ОформитьОтменуДоставки(Результат);
КонецПроцедуры

&НаСервере
Процедура ОформитьОтменуДоставки(Результат)
	МассивРаспоряжений = Результат.МассивРаспоряжений;

	Для Каждого Док Из МассивРаспоряжений Цикл
		Стр = Объект.ОтменыДоставки.Добавить();

		ЗаполнитьЗначенияСвойств(Стр, Результат);
		ЗаполнитьЗначенияСвойств(Стр, Док);

		МассивСтрок = Объект.Распоряжения.НайтиСтроки(Новый Структура("Распоряжение", Док.Распоряжение));
		Если МассивСтрок.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		Объект.Распоряжения.Удалить(МассивСтрок[0].НомерСтроки - 1);

	КонецЦикла;

	МассивСтрок = Объект.Распоряжения.НайтиСтроки(Новый Структура("ТранспортноеСредство",
		Результат.ТранспортноеСредство));

	Если МассивСтрок.Количество() = 0 Тогда
		МассивСтрок = Объект.Рейсы.НайтиСтроки(Новый Структура("ТранспортноеСредство", Результат.ТранспортноеСредство));
		Объект.Рейсы.Удалить(МассивСтрок[0].НомерСтроки - 1);
	КонецЕсли;

	ПоказатьЗадания();
КонецПроцедуры

