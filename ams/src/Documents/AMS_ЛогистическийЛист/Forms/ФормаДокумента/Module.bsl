&НаСервере
Процедура ОформитьВозвратТовара(Результат)
	МассивРаспоряжений = Результат.МассивРаспоряжений;

	Для Каждого Док Из МассивРаспоряжений Цикл
		Стр = Объект.ВозвратыТоваров.Добавить();

		ЗаполнитьЗначенияСвойств(Стр, Результат);
		ЗаполнитьЗначенияСвойств(Стр, Док);

		МассивСтрок = Объект.Распоряжения.НайтиСтроки(Новый Структура("Распоряжение", Док.Распоряжение));
		Если МассивСтрок.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		Объект.Распоряжения.Удалить(МассивСтрок[0].НомерСтроки - 1);
	КонецЦикла;

	ПоказатьЗадания();
КонецПроцедуры

&НаКлиенте
Функция ПолучитьДанныеДляОтменыДоставки(ТранспортноеСредство, Распоряжение)
	Если Распоряжение = Неопределено Тогда
		СтрДок = Объект.Распоряжения.НайтиСтроки(Новый Структура("ТранспортноеСредство", ТранспортноеСредство));
	Иначе
		СтрДок = Объект.Распоряжения.НайтиСтроки(Новый Структура("Распоряжение", Распоряжение));
	КонецЕсли;

	МассивРаспоряжений = Новый Массив;

	Для Каждого Стр Из СтрДок Цикл
		МассивРаспоряжений.Добавить(Стр.Распоряжение);
	КонецЦикла;

	СтрРейсы = Объект.Рейсы.НайтиСтроки(Новый Структура("ТранспортноеСредство", ТранспортноеСредство))[0];

	Парам = Новый Структура;
	Парам.Вставить("ВыполнитьДействие", "Отменить доставку");
	Парам.Вставить("ТранспортноеСредство", ТранспортноеСредство);
	Парам.Вставить("Водитель", СтрРейсы.Водитель);
	Парам.Вставить("СтоимостьДоставки", СтрРейсы.СтоимостьДоставки);
	Парам.Вставить("МассивРаспоряжений", МассивРаспоряжений);

	Возврат Парам;
КонецФункции

&НаКлиенте
Функция ПолучитьДанныеДляВозвратаТовара(ТранспортноеСредство, Распоряжение)
	Если Не ЗначениеЗаполнено(ТранспортноеСредство) Тогда
		ТранспортноеСредство = Объект.Распоряжения.НайтиСтроки(Новый Структура("Распоряжение",
			Распоряжение))[0].ТранспортноеСредство;
	КонецЕсли;

	СтрДок = Объект.Распоряжения.НайтиСтроки(Новый Структура("ТранспортноеСредство", ТранспортноеСредство));

	МассивРаспоряжений = Новый Массив;

	Для Каждого Стр Из СтрДок Цикл
		Данные = Новый Структура;
		Данные.Вставить("Распоряжение", Стр.Распоряжение);
		Данные.Вставить("СтоимостьЧека", Стр.СтоимостьЧека);
		Данные.Вставить("ПунктДоговора", Стр.ПунктДоговора);
		Данные.Вставить("СуммаШтрафа", Стр.СуммаШтрафа);
		Данные.Вставить("СодержаниеПретензии", Стр.СодержаниеПретензии);
		Данные.Вставить("СуммаПретензии", Стр.СуммаПретензии);

		ДанДок = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(Стр.Распоряжение,
			"Организация,Партнер,СуммаДокумента,AMS_КоличествоПалет,AMS_Вес");
		Данные.Вставить("ОрганизацияЗаказа", ДанДок.Организация);
		Данные.Вставить("Партнер", ДанДок.Партнер);
		Данные.Вставить("СуммаДокумента", ДанДок.СуммаДокумента);
		Данные.Вставить("Вес", ДанДок._Вес);
		Данные.Вставить("КоличествоПалет", ДанДок._КоличествоПалет);

		МассивРаспоряжений.Добавить(Данные);
	КонецЦикла;

	СтрРейсы = Объект.Рейсы.НайтиСтроки(Новый Структура("ТранспортноеСредство", ТранспортноеСредство))[0];

	Парам = Новый Структура;
	Парам.Вставить("ВыполнитьДействие", "Возврат товара");
	Парам.Вставить("Организация", Объект.Организация);
	Парам.Вставить("ТранспортноеСредство", ТранспортноеСредство);
	Парам.Вставить("Водитель", СтрРейсы.Водитель);
	Парам.Вставить("СтоимостьДоставки", СтрРейсы.СтоимостьДоставки);
	Парам.Вставить("МассивРаспоряжений", МассивРаспоряжений);

	Возврат Парам;
КонецФункции

&НаСервере
Процедура ПоменятьЗаказыНаРеализации()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЛогистическийЛист", Объект.Ссылка);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Распоряжение КАК ЗаказКлиента,
	|	Реал.Ссылка КАК Реализация
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реал
	|		ПО т.Распоряжение.Номер = Реал.AMS_ЗаказКлиентаНомер
	|ГДЕ
	|	т.Ссылка = &ЛогистическийЛист
	|	И т.Распоряжение ССЫЛКА Документ.ЗаказКлиента
	|	И НЕ Реал.Ссылка ЕСТЬ NULL";
	
	Рез = Запрос.Выполнить(); Выб = Рез.Выбрать();
	
	Пока Выб.Следующий() Цикл
		Стр = Объект.Распоряжения.НайтиСтроки(Новый Структура("Распоряжение", Выб.ЗаказКлиента))[0];
		Стр.Распоряжение = Выб.Реализация;
		Модифицированность = Истина;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиТаблицыФормыТранспорт

&НаСервере
Процедура ПоказатьТранспортКЗагрузке()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("Рейсы", Объект.Рейсы.Выгрузить( , "ТранспортноеСредство"));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.ТранспортноеСредство КАК ТранспортноеСредство
	|ПОМЕСТИТЬ УжеТут
	|ИЗ
	|	&Рейсы КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИСТИНА КАК Метка,
	|	т.Ссылка КАК ТранспортноеСредство,
	|	т._Водитель КАК Водитель,
	|	т.AMS_КоличествоПалет КАК КоличествоПалет,
	|	т.ГрузоподъемностьВТоннах КАК ГрузоподъемностьВТоннах
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Справочник.ТранспортныеСредства КАК т
	|ГДЕ
	|	т._Статус = ЗНАЧЕНИЕ(Перечисление._СтатусыТранспортныхСредств.Работает)
	|	И НЕ т.Ссылка В
	|		(ВЫБРАТЬ
	|			т.ТранспортноеСредство КАК ТранспортноеСредство
	|		ИЗ
	|			УжеТут КАК т)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Метка КАК Метка,
	|	вт.ТранспортноеСредство КАК ТранспортноеСредство,
	|	вт.Водитель КАК Водитель
	|ИЗ
	|	вт КАК вт
	|
	|УПОРЯДОЧИТЬ ПО
	|	вт.КоличествоПалет УБЫВ,
	|	вт.ТранспортноеСредство.Наименование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(вт.КоличествоПалет) КАК КоличествоПалет,
	|	СУММА(вт.ГрузоподъемностьВТоннах) КАК ГрузоподъемностьВТоннах
	|ИЗ
	|	вт КАК вт";

	Пакет = Запрос.ВыполнитьПакет();

	Транспорт.Загрузить(Пакет[2].Выгрузить());

	Выб = Пакет[3].Выбрать();
	Выб.Следующий();
	ПалетАвто = Выб.КоличествоПалет;
	ВесАвто = Выб.ГрузоподъемностьВТоннах;

	Элементы.Транспорт.ТекущаяСтрока = 0;
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПодборДокументовВТранспорт(ДопПараметры)
	ПараметрыФормы = ПолучитьПараметрыДляПодбораРаспоряжений(ДопПараметры.Авто);
	
	ОткрытьФорму("Документ.AMS_ЛогистическийЛист.Форма.ПодборДокументовВТранспорт", ПараметрыФормы, , , , , 
		Новый ОписаниеОповещения("ОткрытьФормуПодборДокументовВТранспортЗавершение", ЭтотОбъект, ДопПараметры),
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПодборДокументовВТранспортЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Модифицированность = Истина;

	ЗаписатьРезультатПодбораУПД(Результат, ДополнительныеПараметры.Авто);
	ПоказатьТранспортКЗагрузке();
	ПоказатьДокументыКЗагрузке();
	ОбновитьДеревоЗаданий(ДополнительныеПараметры);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДеревоЗаданий(Парам)
	ПоказатьЗадания();

	ИдентификаторСтроки = 0;
	ПрекратитьПоиск     = Ложь;
	НайтиСтрокуДерева(Задания.ПолучитьЭлементы(), Парам.Авто, Парам.УПД, ИдентификаторСтроки, ПрекратитьПоиск);
	Элементы.Задания.ТекущаяСтрока = ИдентификаторСтроки;
КонецПроцедуры

&НаКлиенте
Процедура НайтиСтрокуДерева(КоллекцияЭлементовДерева, Авто, УПД, ИдентификаторСтроки, ПрекратитьПоиск)
	Если ЗначениеЗаполнено(УПД) Тогда
		НайтиСтрокуДереваУПД(КоллекцияЭлементовДерева, УПД, ИдентификаторСтроки, ПрекратитьПоиск);

		Если ИдентификаторСтроки = 0 Тогда
			НайтиСтрокуДереваАвто(КоллекцияЭлементовДерева, Авто, ИдентификаторСтроки, ПрекратитьПоиск);
		КонецЕсли;

	Иначе
		НайтиСтрокуДереваАвто(КоллекцияЭлементовДерева, Авто, ИдентификаторСтроки, ПрекратитьПоиск);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура НайтиСтрокуДереваУПД(КоллекцияЭлементовДерева, УПД, ИдентификаторСтроки, ПрекратитьПоиск)
	Для Каждого СтрокаДерева Из КоллекцияЭлементовДерева Цикл
		Если ПрекратитьПоиск Тогда
			Возврат;
		КонецЕсли;

		Если СтрокаДерева.Распоряжение = УПД Тогда
			ИдентификаторСтроки = СтрокаДерева.ПолучитьИдентификатор();
			ПрекратитьПоиск = Истина;
			Возврат;
		КонецЕсли;

		КоллекцияЭлементов = СтрокаДерева.ПолучитьЭлементы();

		Если КоллекцияЭлементов.Количество() > 0 Тогда
			НайтиСтрокуДереваУПД(КоллекцияЭлементов, УПД, ИдентификаторСтроки, ПрекратитьПоиск);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура НайтиСтрокуДереваАвто(КоллекцияЭлементовДерева, Авто, ИдентификаторСтроки, ПрекратитьПоиск)
	Если ПрекратитьПоиск Тогда
		Возврат;
	КонецЕсли;

	Для Каждого СтрокаДерева Из КоллекцияЭлементовДерева Цикл
		Если ПрекратитьПоиск Тогда
			Возврат;
		КонецЕсли;

		Если СтрокаДерева.ТранспортноеСредство = Авто Тогда
			ИдентификаторСтроки = СтрокаДерева.ПолучитьИдентификатор();
			ПрекратитьПоиск = Истина;
			Возврат;
		КонецЕсли;

		КоллекцияЭлементов = СтрокаДерева.ПолучитьЭлементы();

		Если КоллекцияЭлементов.Количество() > 0 Тогда
			НайтиСтрокуДереваАвто(КоллекцияЭлементов, Авто, ИдентификаторСтроки, ПрекратитьПоиск);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
&НаСервере
Процедура УстановитьСтатусНеРаботает(ТранспортноеСредство)
	Авто = ТранспортноеСредство.ПолучитьОбъект();
	Авто._Статус = Перечисления._СтатусыТранспортныхСредств.НеРаботает;
	Авто.Записать();
КонецПроцедуры

&НаСервере
Функция ПолучитьПараметрыДляПодбораРаспоряжений(ТранспортноеСредство)
	Табл = Объект.Рейсы.Выгрузить();

	Стр = Табл.Найти(ТранспортноеСредство, "ТранспортноеСредство");	

	Если Стр = Неопределено Тогда
		Рейс = Неопределено;	
	Иначе
		Рейс = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр);
		Табл.Удалить(Стр);
	КонецЕсли;
	
	МассивЗагрузок = Новый Массив;
	Для Каждого Стр Из Табл Цикл
		МассивЗагрузок.Добавить(Стр.ВремяЗагрузки);
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжения", Объект.Распоряжения.Выгрузить(, "ТранспортноеСредство, ПорядокВМаршруте, Распоряжение"));
	Запрос.УстановитьПараметр("ТранспортноеСредство", ТранспортноеСредство);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.ТранспортноеСредство КАК ТранспортноеСредство,
	|	т.ПорядокВМаршруте КАК ПорядокВМаршруте,
	|	т.Распоряжение КАК Распоряжение
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Распоряжения КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	т.ПорядокВМаршруте КАК ПорядокВМаршруте,
	|	т.Распоряжение КАК Распоряжение
	|ИЗ
	|	вт КАК т
	|ГДЕ
	|	т.ТранспортноеСредство = &ТранспортноеСредство
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядокВМаршруте";

	РаспоряженияДляАвто = Запрос.Выполнить().Выгрузить();

	Парам = Новый Структура;
	Парам.Вставить("Дата", Объект.Дата);
	Парам.Вставить("ТранспортноеСредство", ТранспортноеСредство);
	Парам.Вставить("РаспоряженияДляПобдора", РеквизитФормыВЗначение("Распоряжения"));
	Парам.Вставить("Рейс", Рейс);
	Парам.Вставить("РаспоряженияДляАвто", РаспоряженияДляАвто);
	Парам.Вставить("МассивЗагрузок", МассивЗагрузок);

	Возврат Новый Структура("АдресДанных", ПоместитьВоВременноеХранилище(Парам));
КонецФункции

&НаСервере
Процедура ЗаписатьРезультатПодбораУПД(Результат, Авто)
	ВремяЗагрузкиФакт = '00010101';
	Отправлено        = '00010101';

	Рейс      = Результат.Рейс;
	МассивУПД = Результат.МассивУПД;

	Рейсы = Объект.Рейсы;
	Докты = Объект.Распоряжения;

	Строки = Рейсы.НайтиСтроки(Новый Структура("ТранспортноеСредство", Авто));
	Для Каждого Стр Из Строки Цикл
		ВремяЗагрузкиФакт = Стр.ВремяЗагрузкиФакт;
		Отправлено        = Стр.Отправлено;

		Рейсы.Удалить(Рейсы.Индекс(Стр));
	КонецЦикла;

	Строки = Докты.НайтиСтроки(Новый Структура("ТранспортноеСредство", Авто));
	Для Каждого Стр Из Строки Цикл
		Докты.Удалить(Докты.Индекс(Стр));
	КонецЦикла;

	Если МассивУПД.Количество() > 0 Тогда
		Стр = Рейсы.Добавить();

		ЗаполнитьЗначенияСвойств(Стр, Рейс);

		Если ВремяЗагрузкиФакт = '00010101' Тогда
			Стр.ВремяЗагрузкиФакт = НачалоДня(Стр.ВремяЗагрузки);
		Иначе
			Стр.ВремяЗагрузкиФакт = ВремяЗагрузкиФакт;
		КонецЕсли;

		Стр.Отправлено = Отправлено;
	КонецЕсли;

	Для Каждого Стр Из МассивУПД Цикл
		Распоряжение = Стр.Распоряжение;

		НовСтр = Докты.Добавить();
		НовСтр.ТранспортноеСредство = Авто;
		НовСтр.ПорядокВМаршруте     = Стр.ПорядокВМаршруте;
		НовСтр.Распоряжение         = Распоряжение;
		НовСтр.АдресДоставки        = Стр.АдресДоставки;
		НовСтр.Расстояние           = Стр.Расстояние;
		НовСтр.Подвоз               = Стр.Подвоз;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиТаблицыФормыРаспоряжения

&НаСервере
Процедура ПоказатьДокументыКЗагрузке()
	Коннектор = РеквизитФормыВЗначение("Объект");
	Табл      = РеквизитФормыВЗначение("Распоряжения");
	
	Коннектор.ЗаполнитьТаблицуРаспоряжений(Табл, ПалетРеал, ВесРеал);
	
	ЗначениеВРеквизитФормы(Табл, "Распоряжения");
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаРасстояния(Расстояние, Парам) Экспорт
	Если Расстояние <> Неопределено Тогда
		AMS_ВызовСервера.ЗаписатьРасстояние(Парам.Партнер, Парам.АдресДоставки, Расстояние);
		ПоказатьДокументыКЗагрузке();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиТаблицыФормыЗадания

&НаСервере
Процедура ПоказатьЗадания()
	Задания.ПолучитьЭлементы().Очистить();

	Рез = ПолучитьДанныеЗаданий();

	НомерПП = 0;

	Выб1 = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выб1.Следующий() Цикл
		Стр1 = Задания.ПолучитьЭлементы().Добавить();

		ЗаполнитьЗначенияСвойств(Стр1, Выб1, , "Пробег,Расстояние");

		НомерПП = НомерПП + 1;

		Стр1.НомерПП        = НомерПП;
		Стр1.ТранспортНомер = "" + Выб1.ТранспортноеСредство + ", " + Выб1.Водитель + ", " + Выб1.Телефон;
		Стр1.АдресДоставки  = "";
		Стр1.Пробег         = Выб1.Пробег;

		Если Стр1.УтвержденаОтгрузка Тогда
			Стр1.КоличествоПалетИнфо = Выб1.КоличествоПалет;
			Стр1.ВесИнфо             = Формат(Выб1.Вес, "ЧДЦ=1");
		
		Иначе
			Стр1.КоличествоПалетИнфо = ?(Выб1.КоличествоПалетПлан = 0 Или Выб1.КоличествоПалетПлан = Выб1.КоличествоПалет, 
				Строка(Выб1.КоличествоПалет), 
				Строка(Выб1.КоличествоПалетПлан) + "/" + Строка(Выб1.КоличествоПалет));
				
			Стр1.ВесИнфо = ?(Выб1.ВесПлан = 0 Или Выб1.ВесПлан = Выб1.Вес, 
				Формат(Выб1.Вес, "ЧДЦ=1"),
				Формат(Выб1.ВесПлан, "ЧДЦ=1") + "/" + Формат(Выб1.Вес, "ЧДЦ=1"));
		КонецЕсли;

		Стр1.ДатаЗагрузки     = Выб1.ВремяЗагрузки;
		Стр1.ДатаЗагрузкиФакт = Выб1.ВремяЗагрузкиФакт;
		Стр1.ВремяДоставки    = Формат(Выб1.ВремяДоставкиС, "ДФ=""ЧЧ:мм""") + "-" + Формат(Выб1.ВремяДоставкиПо, "ДФ=""ЧЧ:мм""");
		Стр1.Менеджер         = Неопределено;

		Выб2 = Выб1.Выбрать();
		Пока Выб2.Следующий() Цикл
			Стр2 = Стр1.ПолучитьЭлементы().Добавить();

			ЗаполнитьЗначенияСвойств(Стр2, Выб2, , "Пробег,Расстояние");

			Стр2.Расстояние = Выб2.Расстояние;

			Стр2.Емкость       = 0;
			Стр2.Тоннаж        = 0;
			Стр2.ВремяЗагрузки = Неопределено;
			Стр2.ВремяДоставки = Неопределено;
			Стр2.Перевозчик    = Неопределено;

			Если Стр2.УтвержденаОтгрузка Тогда
				Стр2.КоличествоПалетИнфо = Выб2.КоличествоПалет;
				Стр2.ВесИнфо             = Формат(Выб2.Вес, "ЧДЦ=1");
			Иначе
				Стр2.КоличествоПалетИнфо = ?(Выб2.КоличествоПалетПлан = 0 Или Выб2.КоличествоПалетПлан = Выб2.КоличествоПалет, 
					Строка(Выб2.КоличествоПалет), Строка(Выб2.КоличествоПалетПлан) + "/" + Строка(Выб2.КоличествоПалет));
					
				Стр2.ВесИнфо = ?(Выб2.ВесПлан = 0 Или Выб2.ВесПлан = Выб2.Вес, 
					Формат(Выб2.Вес,"ЧДЦ=1"), Формат(Выб2.ВесПлан,"ЧДЦ=1") + "/" + Формат(Выб2.Вес,"ЧДЦ=1"));
			КонецЕсли;

			Стр2.ВремяДоставки = Формат(Выб2.ВремяДоставкиС, "ДФ=""ЧЧ:мм""") + "-" + Формат(Выб2.ВремяДоставкиПо, "ДФ=""ЧЧ:мм""");
			
			Стр2.ПоказатьФлагЕсть    = Истина;
			Стр2.Номер               = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Выб2.Номер);
			Стр2.Дата                = Формат(Выб2.Дата, "ДЛФ=Д");
			Стр2.СтоимостьДоставки   = Выб2.СуммаДокумента;
		КонецЦикла;
	КонецЦикла;

	КоличествоМаршрутов = НомерПП;

	ЗаполнитьКоличествоПалетВес();
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеЗаданий()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("Рейсы", Объект.Рейсы.Выгрузить());
	Запрос.УстановитьПараметр("Распоряжения", Объект.Распоряжения.Выгрузить());

	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.ТранспортноеСредство КАК ТранспортноеСредство,
	|	т.Водитель КАК Водитель,
	|	т.ВремяЗагрузки КАК ВремяЗагрузки,
	|	т.ВремяЗагрузкиФакт КАК ВремяЗагрузкиФакт,
	|	т.СтоимостьДоставки КАК СтоимостьДоставки,
	|	т.Пробег КАК Пробег,
	|	т.Отправлено КАК Отправлено
	|ПОМЕСТИТЬ рейсы
	|ИЗ
	|	&Рейсы КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.ТранспортноеСредство КАК ТранспортноеСредство,
	|	т.ПорядокВМаршруте КАК ПорядокВМаршруте,
	|	т.Распоряжение КАК Распоряжение,
	|	т.ЕстьЧек КАК ЕстьЧек,
	|	т.СтоимостьЧека КАК СтоимостьЧека,
	|	т.ЕстьНарушениеДоговора КАК ЕстьНарушениеДоговора,
	|	т.ПунктДоговора КАК ПунктДоговора,
