#Область ПроцедурыЗаписиДанных

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗакрытьФорму();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФорму()
	Отказ = Ложь;

	ПроверитьРезультат(Отказ);

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Модифицированность = Ложь; //Снятие модифицированности, т.к. перед закрытием признак проверяется

	Закрыть(ПолучитьМассивРезультата());
КонецПроцедуры

&НаСервере
Процедура ПроверитьРезультат(Отказ)
	Если ЗагрузкаДата = Дата(1, 1, 1) Тогда
		ОбщегоНазначения.СообщитьПользователю("Не указана Дата начала загрузки.", , , , Отказ);
	КонецЕсли;

	Если ЗагрузкаВремя = Дата(1, 1, 1) Тогда
		ОбщегоНазначения.СообщитьПользователю("Не указано Время начала загрузки.", , , , Отказ);
	КонецЕсли;
	
	Перевозчик   = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТранспортноеСредство, "_Перевозчик");
	Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Перевозчик, "Наименование");

	Если СтоимостьДоставки = 0 И СтрНайти(Наименование, "АМС Медиа") = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю("Не указана Стоимость доставки.", , , , Отказ);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивРезультата()
	МассивУПД = Новый Массив;
	
	Для Каждого Стр Из Результат Цикл
		Если ТипЗнч(Стр.Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
			Или ТипЗнч(Стр.Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента")
			Или ТипЗнч(Стр.Распоряжение) = Тип("ДокументСсылка.AMS_ПередачаВПереработку")
			Или ТипЗнч(Стр.Распоряжение) = Тип("ДокументСсылка.ПередачаТоваровХранителю") Тогда
			Подвоз  = Ложь;
		Иначе
			Подвоз  = Истина;
		КонецЕсли;

		НовСтр = Новый Структура;
		НовСтр.Вставить("ТранспортноеСредство", ТранспортноеСредство);
		НовСтр.Вставить("Подвоз", Подвоз);

		НовСтр.Вставить("ПорядокВМаршруте", Стр.ПорядокВМаршруте);
		НовСтр.Вставить("Распоряжение", Стр.Распоряжение);
		НовСтр.Вставить("АдресДоставки", Стр.АдресДоставки);
		НовСтр.Вставить("Расстояние", Стр.Расстояние);

		МассивУПД.Добавить(НовСтр);
	КонецЦикла;

	Рейс = Новый Структура;
	Рейс.Вставить("ТранспортноеСредство", ТранспортноеСредство);
	Рейс.Вставить("Водитель", Водитель);
	Рейс.Вставить("ВремяЗагрузки", '00010101000000' + (ЗагрузкаДата - '00010101000000') + (ЗагрузкаВремя
		- '00010101000000'));
	Рейс.Вставить("СтавкаВодителя", СтавкаВодителя);
	Рейс.Вставить("СтавкаАгента", СтавкаАгента);
	Рейс.Вставить("Коэффициент", Коэффициент);
	Рейс.Вставить("СтоимостьПропуска", СтоимостьПропуска);
	Рейс.Вставить("СтоимостьДоставки", СтоимостьДоставки);
	Рейс.Вставить("Пробег", Пробег);

	Данные = Новый Структура;
	Данные.Вставить("Рейс", Рейс);
	Данные.Вставить("МассивУПД", МассивУПД);

	Возврат Данные;
КонецФункции

