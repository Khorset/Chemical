&НаСервере
Процедура ДобавитьСтрокуМаршрута(Распоряжение)
	Строки = Распоряжения.НайтиСтроки(Новый Структура("Распоряжение", Распоряжение));
	Строки[0].ПорядокВМаршруте = Результат.Количество() + 1;
КонецПроцедуры

&НаСервере
Процедура УдалитьСтрокуМаршрута(Распоряжение)
	Строки = Распоряжения.НайтиСтроки(Новый Структура("Распоряжение", Распоряжение));
	Строки[0].ПорядокВМаршруте = 0;

	Строки = Результат.НайтиСтроки(Новый Структура("Распоряжение", Распоряжение));
	Результат.Удалить(Результат.Индекс(Строки[0]));

	УстановитьПорядокВМаршруте();
КонецПроцедуры

