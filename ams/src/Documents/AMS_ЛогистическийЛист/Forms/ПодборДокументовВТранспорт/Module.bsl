
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	УстановитьУсловноеОформление();

	Данные = ПолучитьИзВременногоХранилища(Параметры.АдресДанных);

	Дата                   = Данные.Дата;
	ТранспортноеСредство   = Данные.ТранспортноеСредство;
	РаспоряженияДляПобдора = Данные.РаспоряженияДляПобдора;
	Рейс                   = Данные.Рейс;
	РаспоряженияДляАвто    = Данные.РаспоряженияДляАвто;
	МассивЗагрузок         = Данные.МассивЗагрузок;

	Стр = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТранспортноеСредство,
		"_Водитель,_Перевозчик,_СтавкаВодителя,_СтавкаАгента,_СтоимостьПропуска,ГрузоподъемностьВТоннах,AMS_КоличествоПалет");

	Если Рейс = Неопределено Тогда
		Пробег            = 0;
		Водитель          = Стр._Водитель;
		ВремяЗагрузки     = НачалоДня(Дата) + 3600 * 8;
		СтавкаВодителя    = Стр._СтавкаВодителя;
		СтоимостьПропуска = Стр._СтоимостьПропуска;
		СтавкаАгента      = Стр._СтавкаАгента;
		Коэффициент       = 1;
		СтоимостьДоставки = СтавкаВодителя + СтоимостьПропуска;
	Иначе
		Пробег            = Рейс.Пробег;
		Водитель          = Рейс.Водитель;
		ВремяЗагрузки     = Рейс.ВремяЗагрузки;
		СтавкаВодителя    = Рейс.СтавкаВодителя;
		СтоимостьПропуска = Рейс.СтоимостьПропуска;
		Коэффициент       = ?(Рейс.Коэффициент = 0, 1, Рейс.Коэффициент);
		СтоимостьДоставки = Рейс.СтоимостьДоставки;
		СтавкаАгента      = Рейс.СтавкаАгента;
	КонецЕсли;
	
	ПалетЕмкость = Стр.AMS_КоличествоПалет;
	ВесЕмкость   = Стр.ГрузоподъемностьВТоннах;
	Перевозчик   = Стр._Перевозчик;
	СтавкаАгента = Стр._СтавкаАгента;

	Элементы.СтавкаАгента.Видимость = СтавкаАгента > 0;

	ПалетЕмкость1 = ПалетЕмкость;
	ВесЕмкость1   = ВесЕмкость;

	ЗагрузкаДата  = НачалоДня(ВремяЗагрузки);
	ЗагрузкаВремя = Дата(1, 1, 1) + (ВремяЗагрузки - НачалоДня(ВремяЗагрузки));

	Распоряжения.Загрузить(РаспоряженияДляПобдора);

	Таб = ПолучитьДанныеРаспоряжений(РаспоряженияДляАвто);
	
	Для Каждого Стр Из Таб Цикл
		НовСтр = Распоряжения.Добавить();

		ЗаполнитьЗначенияСвойств(НовСтр, Стр);

		НовСтр.Метка = Истина;

		Если Стр.УтвержденаОтгрузка Тогда
			НовСтр.КоличествоПалетИнфо = Строка(Стр.КоличествоПалет);
			НовСтр.ВесИнфо             = Формат(Стр.Вес, "ЧДЦ=1");
		Иначе
			НовСтр.КоличествоПалетИнфо = ?(Стр.КоличествоПалетПлан = 0 Или Стр.КоличествоПалетПлан = Стр.КоличествоПалет, 
				Строка(Стр.КоличествоПалет), Строка(Стр.КоличествоПалетПлан) + "/" + Строка(Стр.КоличествоПалет));
			
			НовСтр.ВесИнфо = ?(Стр.ВесПлан = 0 Или Стр.ВесПлан = Стр.Вес, 
				Формат(Стр.Вес, "ЧДЦ=1"), Формат(Стр.ВесПлан, "ЧДЦ=1") + "/" + Формат(Стр.Вес, "ЧДЦ=1"));
		КонецЕсли;

		НовСтр.ВремяДоставки = Формат(Стр.ВремяДоставкиС, "ДФ=""ЧЧ:мм""") + "-" + Формат(Стр.ВремяДоставкиПо, "ДФ=""ЧЧ:мм""");
		НовСтр.Расстояние    = Стр.Расстояние;
		НовСтр.Номер         = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Стр.Номер);
	КонецЦикла;

	Распоряжения.Сортировать("Подвоз, ПартнерНаименование, АдресДоставки");

	Для Каждого Элемент Из МассивЗагрузок Цикл
		НовСтр = ЧасыЗагрузки.Добавить();
		НовСтр.ВремяЗагрузки = Элемент;
	КонецЦикла;
	
	ПоказатьНомерЗагрузки();

	ЗаполнитьТабРезультат();

	ДоставкаТоваровКлиентСервер.ЗаполнитьСписокВыбораПоляВремени(Элементы.ЗагрузкаВремя);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВодительПриИзменении(Элемент)
	ЗаписатьВодителяАвто(ТранспортноеСредство, Водитель);
КонецПроцедуры

&НаКлиенте
Процедура СтоимостьПропускаПриИзменении(Элемент)
	СтоимостьДоставки = СтавкаВодителя * Коэффициент + СтоимостьПропуска;
КонецПроцедуры

&НаКлиенте
Процедура КоэффициентПриИзменении(Элемент)
	СтоимостьДоставки = СтавкаВодителя * Коэффициент + СтоимостьПропуска;
КонецПроцедуры

&НаКлиенте
Процедура СтоимостьДоставкиПриИзменении(Элемент)
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузкаДатаПриИзменении(Элемент)
	Модифицированность = Истина;

	ПоказатьНомерЗагрузки();
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузкаВремяПриИзменении(Элемент)
	Модифицированность = Истина;

	ПоказатьНомерЗагрузки();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРаспоряжения

&НаКлиенте
Процедура РаспоряженияПриАктивизацииСтроки(Элемент)
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Распоряжение = Элемент.ТекущиеДанные.Распоряжение;

	Если ЗначениеЗаполнено(Распоряжение) И ТипЗнч(Распоряжение) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ОсобыеУсловияПеревозкиОписание = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(
			Элемент.ТекущиеДанные.Распоряжение, "ОсобыеУсловияПеревозкиОписание");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РаспоряженияМеткаПриИзменении(Элемент)
	ТекДанные = ТекущийЭлемент.ТекущиеДанные;

	Если ТекДанные.Метка Тогда
		ДобавитьСтрокуМаршрута(ТекДанные.Распоряжение);
	Иначе
		УдалитьСтрокуМаршрута(ТекДанные.Распоряжение);
	КонецЕсли;

	ЗаполнитьТабРезультат();

	Модифицированность = Истина;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	Если ПалетОстаток < 0 Или ВесОстаток < 0 Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);
		ТекстВопроса = "Перегруз. Продолжить?";

		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет, "Вопрос");

	Иначе
		ЗакрытьФорму();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Вниз(Команда)
	Стр = Элементы.Результат.ТекущиеДанные;

	Если Стр = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Результат.Сдвинуть(Результат.Индекс(Стр), 1);
	Исключение
		Возврат;
	КонецПопытки;

	УстановитьПорядокВМаршруте();

	Для Каждого Строка Из Результат Цикл
		Если Строка.Номер = Стр.Номер Тогда
			ИдентификаторСтроки = Строка.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Элементы.Результат.ТекущаяСтрока = ИдентификаторСтроки;

	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура Вверх(Команда)
	Стр = Элементы.Результат.ТекущиеДанные;

	Если Стр = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Результат.Сдвинуть(Результат.Индекс(Стр), -1);
	Исключение
		Возврат;
	КонецПопытки;

	УстановитьПорядокВМаршруте();

	Для Каждого Строка Из Результат Цикл
		Если Строка.Номер = Стр.Номер Тогда
			ИдентификаторСтроки = Строка.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Элементы.Результат.ТекущаяСтрока = ИдентификаторСтроки;

	Модифицированность = Истина;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработчикиТаблицыФормыРезультат

&НаСервере
Процедура ЗаполнитьТабРезультат()
	Доставка = Ложь;
	Подвоз   = Ложь;

	ПалетЗагружено = 0;
	ВесЗагружено   = 0;

	ПалетЗагружено1 = 0;
	ВесЗагружено1   = 0;

	Результат.Очистить();

	Для Каждого Стр Из Распоряжения Цикл
		Если Стр.Метка Тогда
			НовСтр = Результат.Добавить();

			ЗаполнитьЗначенияСвойств(НовСтр, Стр);

			Если НовСтр.Подвоз = Ложь Тогда
				Доставка = Истина;
				ПалетЗагружено = ПалетЗагружено + ?(Стр.КоличествоПалетПлан = 0, Стр.КоличествоПалет, Стр.КоличествоПалетПлан);
				ВесЗагружено   = ВесЗагружено + ?(Стр.ВесПлан = 0, Стр.Вес, Стр.ВесПлан);
			Иначе
				Подвоз = Истина;
				ПалетЗагружено1 = ПалетЗагружено1 + Стр.КоличествоПалет;
				ВесЗагружено1   = ВесЗагружено1 + Стр.Вес;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Результат.Сортировать("ПорядокВМаршруте");

	ПалетОстаток = ПалетЕмкость - ПалетЗагружено;
	ВесОстаток   = ВесЕмкость - ВесЗагружено;

	ПалетОстаток1 = ПалетЕмкость1 - ПалетЗагружено1;
	ВесОстаток1   = ВесЕмкость1 - ВесЗагружено1;

	Элементы.ГруппаВес.Видимость = Доставка;
	Элементы.ГруппаПодвоз.Видимость   = Подвоз;
КонецПроцедуры

&НаСервере
Процедура УстановитьПорядокВМаршруте()
	Табл = РеквизитФормыВЗначение("Результат");
	Для Каждого Стр Из Табл Цикл
		Стр.ПорядокВМаршруте = Табл.Индекс(Стр) + 1;
	КонецЦикла;
	ЗначениеВРеквизитФормы(Табл, "Результат");

	Табл = РеквизитФормыВЗначение("Распоряжения");
	Для Каждого Стр Из Результат Цикл
		НовСтр = Табл.Найти(Стр.Распоряжение, "Распоряжение");
		НовСтр.ПорядокВМаршруте = Стр.ПорядокВМаршруте;
	КонецЦикла;
	ЗначениеВРеквизитФормы(Табл, "Распоряжения");
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиТаблицыФормыРаспоряжения

&НаСервереБезКонтекста
Функция ПолучитьДанныеРаспоряжений(РаспоряженияДляАвто)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РаспоряженияДляАвто", РаспоряженияДляАвто);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Распоряжение КАК Распоряжение,
	|	т.ПорядокВМаршруте КАК ПорядокВМаршруте
	|ПОМЕСТИТЬ Док
	|ИЗ
	|	&РаспоряженияДляАвто КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Ссылка КАК Распоряжение,
	|	т.ЗонаДоставки КАК ЗонаДоставки,
	|	т.AMS_КоличествоПалет КАК КоличествоПалет,
	|	т.AMS_КоличествоПалет КАК КоличествоПалетПлан,
	|	т.AMS_Вес КАК Вес,
	|	т.AMS_ВесПлан КАК ВесПлан,
	|	т.ВремяДоставкиС КАК ВремяДоставкиС,
	|	т.ВремяДоставкиПо КАК ВремяДоставкиПо,
	|	ВЫБОР
	|		КОГДА т.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчикаПоАдресу)
	|			ТОГДА т.АдресДоставкиПеревозчика
	|		ИНАЧЕ т.АдресДоставки
	|	КОНЕЦ КАК АдресДоставки,
	|	т.Номер КАК Номер,
	|	т.Дата КАК Дата,
	|	т.Партнер КАК Партнер,
	|	т.СуммаДокумента КАК СуммаДокумента,
	|	ЛОЖЬ КАК УтвержденаОтгрузка,
	|	1 КАК Порядок,
	|	ЛОЖЬ КАК Подвоз,
	|	Док.ПорядокВМаршруте КАК ПорядокВМаршруте
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Док КАК Док
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК т
	|		ПО Док.Распоряжение = т.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т.Ссылка,
	|	т.ЗонаДоставки,
	|	т.AMS_КоличествоПалет,
	|	т.AMS_КоличествоПалетПлан,
	|	т.AMS_Вес,
	|	т.AMS_ВесПлан,
	|	т.ВремяДоставкиС,
	|	т.ВремяДоставкиПо,
	|	ВЫБОР
	|		КОГДА т.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчикаПоАдресу)
	|			ТОГДА т.АдресДоставкиПеревозчика
	|		ИНАЧЕ т.АдресДоставки
	|	КОНЕЦ,
	|	т.Номер,
	|	т.Дата,
	|	т.Партнер,
	|	т.СуммаДокумента,
	|	т.AMS_УтвержденаОтгрузка,
	|	2,
	|	ЛОЖЬ,
	|	Док.ПорядокВМаршруте
	|ИЗ
	|	Док КАК Док
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК т
	|		ПО Док.Распоряжение = т.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т.Ссылка,
	|	т.ЗонаДоставки,
	|	т.AMS_КоличествоПалет,
	|	т.AMS_КоличествоПалет,
	|	т.AMS_Вес,
	|	т.AMS_Вес,
	|	т.ВремяДоставкиС,
	|	т.ВремяДоставкиПо,
	|	ВЫБОР
	|		КОГДА т.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчикаПоАдресу)
	|			ТОГДА т.АдресДоставкиПеревозчика
	|		ИНАЧЕ т.АдресДоставки
	|	КОНЕЦ,
	|	т.Номер,
	|	т.Дата,
	|	т.Партнер,
	|	т.СуммаДокумента,
	|	ЛОЖЬ,
	|	3,
	|	ЛОЖЬ,
	|	Док.ПорядокВМаршруте
	|ИЗ
	|	Док КАК Док
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтгрузкаТоваровКлиенту КАК т
	|		ПО Док.Распоряжение = т.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т.Ссылка,
	|	т.ЗонаДоставки,
	|	т.AMS_КоличествоПалет,
	|	т.AMS_КоличествоПалет,
	|	т.AMS_Вес,
	|	т.AMS_Вес,
	|	т.ВремяДоставкиС,
	|	т.ВремяДоставкиПо,
	|	т.АдресДоставки,
	|	т.Номер,
	|	т.Дата,
	|	т.Партнер,
	|	т.СуммаДокумента,
	|	ЛОЖЬ,
	|	4,
	|	ЛОЖЬ,
	|	Док.ПорядокВМаршруте
	|ИЗ
	|	Док КАК Док
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПередачаТоваровХранителю КАК т
	|		ПО Док.Распоряжение = т.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	т.Ссылка,
	|	т.ЗонаДоставки,
	|	т.AMS_КоличествоПалет,
	|	т.AMS_КоличествоПалет,
	|	т.AMS_Вес,
	|	т.AMS_Вес,
	|	т.ВремяДоставкиС,
	|	т.ВремяДоставкиПо,
	|	т.АдресДоставки,
	|	т.Номер,
	|	т.Дата,
	|	т.Партнер,
	|	т.СуммаДокумента,
	|	ЛОЖЬ,
	|	5,
	|	ЛОЖЬ,
	|	Док.ПорядокВМаршруте
	|ИЗ
	|	Док КАК Док
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ПередачаВПереработку КАК т
	|		ПО Док.Распоряжение = т.Ссылка
	|
