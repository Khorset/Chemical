#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьФорму()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЛогистическийЛист", Параметры.ЛогистическийЛист);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Распоряжение КАК Распоряжение
	|ПОМЕСТИТЬ Лист
	|ИЗ
	|	Документ.AMS_ЛогистическийЛист.Распоряжения КАК т
	|ГДЕ
	|	т.Ссылка = &ЛогистическийЛист
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Лист.Распоряжение КАК Реализация
	|ПОМЕСТИТЬ док
	|ИЗ
	|	Лист КАК Лист
	|ГДЕ
	|	Лист.Распоряжение ССЫЛКА Документ.РеализацияТоваровУслуг
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Реал.Ссылка
	|ИЗ
	|	Лист КАК Лист
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реал
	|		ПО Лист.Распоряжение = Реал.ЗаказКлиента
	|ГДЕ
	|	Лист.Распоряжение ССЫЛКА Документ.ЗаказКлиента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Документ КАК Документ,
	|	МАКСИМУМ(т.Период) КАК ДатаОтмены
	|ПОМЕСТИТЬ вт1
	|ИЗ
	|	РегистрСведений.AMS_ИсторияРеализации КАК т
	|ГДЕ
	|	т.Операция = ""Отмена печати""
	|	И т.Документ В
	|		(ВЫБРАТЬ
	|			док.Реализация КАК Реализация
	|		ИЗ
	|			док КАК док)
	|СГРУППИРОВАТЬ ПО
	|	т.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Документ КАК Документ,
	|	МАКСИМУМ(т.Период) КАК ДатаСН
	|ПОМЕСТИТЬ вт2
	|ИЗ
	|	РегистрСведений.AMS_ИсторияРеализации КАК т
	|ГДЕ
	|	т.Операция = ""Печать СН""
	|	И т.Документ В
	|		(ВЫБРАТЬ
	|			док.Реализация КАК Реализация
	|		ИЗ
	|			док КАК док)
	|СГРУППИРОВАТЬ ПО
	|	т.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Документ КАК Документ,
	|	МАКСИМУМ(т.Период) КАК ДатаУПД
	|ПОМЕСТИТЬ вт3
	|ИЗ
	|	РегистрСведений.AMS_ИсторияРеализации КАК т
	|ГДЕ
	|	т.Операция В (""Печать УПД"", ""Печать ТОРГ-12"")
	|	И т.Документ В
	|		(ВЫБРАТЬ
	|			док.Реализация КАК Реализация
	|		ИЗ
	|			док КАК док)
	|СГРУППИРОВАТЬ ПО
	|	т.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Реал.Номер КАК Номер,
	|	Реал.Дата КАК Дата,
	|	Реал.Партнер КАК Партнер,
	|	Реал.СуммаДокумента КАК СуммаДокумента,
	|	Парт._КолЭкзАктОРасхождениях КАК АктОРасхождениях,
	|	Парт._КолЭкзСпецификация КАК Спецификация,
	|	Парт._КолЭкзСЧ КАК Счет,
	|	Парт._КолЭкзСФ КАК СчетФактура,
	|	Парт._КолЭкзТТН КАК ТТН,
	|	Парт._КолЭкзТОРГ12 КАК ТОРГ12,
	|	Парт._КолЭкзУПД КАК УПД,
	|	док.Реализация КАК Реализация,
	|	Реал.AMS_УтвержденаОтгрузка КАК УтвержденаОтгрузка,
	|	ВЫБОР
	|		КОГДА вт1.ДатаОтмены ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|				КОГДА вт2.ДатаСН ЕСТЬ NULL
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|			КОГДА вт2.ДатаСН > вт1.ДатаОтмены
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	КОНЕЦ КАК ПечатьСН,
	|	ВЫБОР
	|		КОГДА вт1.ДатаОтмены ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|				КОГДА вт3.ДатаУПД ЕСТЬ NULL
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|			КОГДА вт3.ДатаУПД > вт1.ДатаОтмены
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	КОНЕЦ КАК ПечатьУПД,
	|	Парт.Наименование КАК Наименование
	|ПОМЕСТИТЬ вт4
	|ИЗ
	|	док КАК док
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реал
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Парт
	|			ПО Реал.Партнер = Парт.Ссылка
	|		ПО док.Реализация = Реал.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт1 КАК вт1
	|		ПО док.Реализация = вт1.Документ
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт2 КАК вт2
	|		ПО док.Реализация = вт2.Документ
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт3 КАК вт3
	|		ПО док.Реализация = вт3.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА вт4.УтвержденаОтгрузка
	|			ТОГДА ВЫБОР
	|				КОГДА вт4.ПечатьСН
	|				И вт4.ПечатьУПД
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Метка,
	|	вт4.Номер КАК Номер,
	|	вт4.Дата КАК Дата,
	|	вт4.Партнер КАК Партнер,
	|	вт4.СуммаДокумента КАК СуммаДокумента,
	|	вт4.АктОРасхождениях КАК АктОРасхождениях,
	|	вт4.Спецификация КАК Спецификация,
	|	1 КАК СН,
	|	вт4.Счет КАК Счет,
	|	вт4.СчетФактура КАК СчетФактура,
	|	вт4.ТТН КАК ТТН,
	|	вт4.ТОРГ12 КАК ТОРГ12,
	|	ВЫБОР
	|		КОГДА вт4.ПечатьУПД
	|			ТОГДА 0
	|		ИНАЧЕ вт4.УПД
	|	КОНЕЦ КАК УПД,
	|	вт4.Реализация КАК Реализация,
	|	вт4.УтвержденаОтгрузка КАК УтвержденаОтгрузка,
	|	вт4.ПечатьСН КАК ПечатьСН,
	|	вт4.ПечатьУПД КАК ПечатьУПД,
	|	вт4.Наименование КАК Наименование
	|ИЗ
	|	вт4 КАК вт4
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование,
	|	Номер";
	ТаблицаДокументов.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	УсловноеОформление.Элементы.Очистить();

	//
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Отгрузка.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаДокументов.УтвержденаОтгрузка");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветТекстаКонтрагентаДействующего);
	
	//
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Отгрузка.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаДокументов.УтвержденаОтгрузка");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеРавно;
	ОтборЭлемента.ПравоеЗначение = Истина;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветАктивности);
	
	//
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ОтгрузкаМетка.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаДокументов.УтвержденаОтгрузка");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеРавно;
	ОтборЭлемента.ПравоеЗначение = Истина;

	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
КонецПроцедуры

#Область ПроцедурыПечати

&НаКлиенте
Процедура Распечатать(ТабличныеДокументы, МассивОбъектов, КоличествоЭкземпляров, НаименованиеДокумента)
	Для Экземпляр = 1 По КоличествоЭкземпляров Цикл
		УправлениеПечатьюКлиент.РаспечататьТабличныеДокументы(ТабличныеДокументы, МассивОбъектов, Ложь, 1);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция СкладскаяНакладная(МассивОбъектов)
	Возврат Обработки.AMS_Продажи.СформироватьПечатнуюФормуСН(МассивОбъектов, Новый СписокЗначений, Новый Структура);
КонецФункции

&НаСервере
Функция УПД(МассивОбъектов)
	СтруктураТипов = ОбщегоНазначенияУТ.СоответствиеМассивовПоТипамОбъектов(МассивОбъектов);

	Возврат Обработки.ПечатьОбщихФорм.СформироватьПечатнуюФормуУПД(СтруктураТипов, Новый СписокЗначений,
		Новый Структура("ТипПечати", "АМС"));
КонецФункции

&НаСервере
Функция ТОРГ12(МассивОбъектов)
	СтруктураТипов = ОбщегоНазначенияУТ.СоответствиеМассивовПоТипамОбъектов(МассивОбъектов);
	ПараметрыПечати = Новый Структура;
	ПараметрыПечати.Вставить("ТипПечати", "АМС");
	ПараметрыПечати.Вставить("ВыводитьУслуги", Ложь);

	Возврат Обработки.ПечатьОбщихФорм.СформироватьПечатнуюФормуТОРГ12(СтруктураТипов, Новый СписокЗначений,
		ПараметрыПечати);
КонецФункции

