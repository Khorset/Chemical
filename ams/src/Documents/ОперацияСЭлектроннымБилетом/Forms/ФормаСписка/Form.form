    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДанныеДокумента.ТипУслуги КАК ТипУслуги,
	ВЫБОР
		КОГДА ДанныеДокумента.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.ПустаяСсылка)
			ТОГДА &amp;ТипДокументаЭлектронныйБилет
		ИНАЧЕ ДанныеДокумента.ТипОперации
	КОНЕЦ КАК ТипДокумента,
	ДанныеДокумента.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.ПустаяСсылка) КАК ЭтоЭлектронныйБилет,
	ДанныеДокумента.НомерБилета КАК НомерБилета,
	ДанныеДокумента.Номер КАК Номер,
	ДанныеДокумента.Дата КАК Дата,
	ДанныеДокумента.Сотрудник КАК Сотрудник,
	ВЫБОР
		КОГДА ДанныеДокумента.ТипОперации = ЗНАЧЕНИЕ(Перечисление.ТипыОперацийСБилетами.ПустаяСсылка)
			ТОГДА ДанныеДокумента.ФИОПассажира
		ИНАЧЕ СведенияОбЭлектронномБилете.ФИОПассажира
	КОНЕЦ КАК ФИОПассажира,
	ДанныеДокумента.СуммаДокумента КАК Сумма,
	ДанныеДокумента.Валюта КАК Валюта,
	ДанныеДокумента.ДатаОтправления КАК ДатаОтправления,
	ДанныеДокумента.ДеталиПоездки КАК ДеталиПоездки,
	ДанныеДокумента.ДокументОснование КАК Заявка,
	ДанныеДокумента.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	ДанныеДокумента.Подразделение КАК Подразделение,
	ДанныеДокумента.Организация КАК Организация,
	ДанныеДокумента.Ссылка КАК Ссылка
ИЗ
	Документ.ОперацияСЭлектроннымБилетом КАК ДанныеДокумента
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацияСЭлектроннымБилетом КАК СведенияОбЭлектронномБилете
		ПО ДанныеДокумента.ЭлектронныйБилет = СведенияОбЭлектронномБилете.Ссылка
ГДЕ
	Не ДанныеДокумента.УдалитьТипБронирования = ЗНАЧЕНИЕ(Перечисление.УдалитьТипыБронирования.Бронирование)</queryText>
      <mainTable>Document.ОперацияСЭлектроннымБилетом</mainTable>
