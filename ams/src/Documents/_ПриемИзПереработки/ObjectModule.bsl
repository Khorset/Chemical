#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	УстановитьПривилегированныйРежим(Истина);
	
	КлючевыеРеквизитыТабличнойЧасти = Новый Массив;
	КлючевыеРеквизитыТабличнойЧасти.Добавить("Номенклатура");
	КлючевыеРеквизитыТабличнойЧасти.Добавить("Спецификация");
	ОбщегоНазначенияУТ.ПроверитьНаличиеДублейСтрокТЧ(
		ЭтотОбъект,
		"Товары",
		КлючевыеРеквизитыТабличнойЧасти,
		Отказ,,
		Истина);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	НачатьТранзакцию();

	Попытка

		Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ
			|	т.СборкаТоваров КАК СборкаТоваров,
			|	т.Номенклатура КАК Флакон,
			|	т.Спецификация КАК Спецификация,
			|	т.Количество КАК Количество
			|ПОМЕСТИТЬ вт
			|ИЗ
			|	&Товары КАК т
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	вт.СборкаТоваров КАК СборкаТоваров,
			|	вт.Флакон КАК Флакон,
			|	вт.Спецификация КАК Спецификация,
			|	Спец.Номенклатура КАК Преформа,
			|	вт.Количество * Спец.Количество КАК Количество
			|ИЗ
			|	вт КАК вт
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры.Товары КАК Спец
			|		ПО вт.Спецификация = Спец.Ссылка";

			Запрос.УстановитьПараметр("Товары", Товары.Выгрузить());

			Табл = Запрос.Выполнить().Выгрузить();

			Для Каждого Стр Из Товары Цикл
				СтрТабл = Табл.Найти(Стр.Номенклатура, "Флакон");

				Если Не СтрТабл = Неопределено Тогда
					Стр.СборкаТоваров = ПолучитьДокументСборкаТоваров(СтрТабл, Отказ);
				КонецЕсли;
			КонецЦикла;

			ОформитьДокументПеремещениеТоваров(Отказ);

		ИначеЕсли РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
			ОтменитьПроведение(Отказ);
		КонецЕсли;

		Если Отказ Тогда
			ОтменитьТранзакцию();
			Возврат;
		КонецЕсли;

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ОбщегоНазначения.СообщитьПользователю(ИнформацияОбОшибке());
		Возврат;
	КонецПопытки;
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	ПеремещениеТоваров = Документы.ПеремещениеТоваров.ПустаяСсылка();
	Для Каждого Стр Из Товары Цикл
		Стр.СборкаТоваров = Документы.СборкаТоваров.ПустаяСсылка();
	КонецЦикла;
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	ЗаполнитьРеквизитыПоУмолчанию();
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Период", Дата);
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	&Период КАК Период,
	|	&Партнер КАК Партнер,
	|	&Контрагент КАК Контрагент,
	|	т.Номенклатура КАК Номенклатура,
	|	тов.Количество * т.Количество / д.Количество КАК Количество
	|ИЗ
	|	Документ._ПриемИзПереработки.Товары КАК тов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры КАК д
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВариантыКомплектацииНоменклатуры.Товары КАК т
	|			ПО (т.Ссылка = д.Ссылка)
	|		ПО тов.Спецификация = д.Ссылка
	|ГДЕ
	|	тов.Ссылка = &Ссылка";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат;
	КонецЕсли;

	Движения._ТоварыПереданные.Записывать = Истина;
	Движения._ТоварыПереданные.Загрузить(Рез.Выгрузить());
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьДокументСборкаТоваров(Выб, Отказ)
	СборкаТоваров = Выб.СборкаТоваров;

	Если ЗначениеЗаполнено(СборкаТоваров) Тогда
		Док = СборкаТоваров.ПолучитьОбъект();
	Иначе
		Док = Документы.СборкаТоваров.СоздатьДокумент();
	КонецЕсли;

	Если Док.ПометкаУдаления <> ПометкаУдаления Тогда
		мср.УстановитьПометкуУдаленияДокументу(Док, ПометкаУдаления, Отказ);
	КонецЕсли;

	Док.Дата = Дата;

	Док.Количество            = Выб.Количество;
	Док.КоличествоУпаковок    = Выб.Количество;
	Док.Комментарий           = "Сформирован автоматичестки. Оформление переработки товаров (на складе компании). Приём из переработки № "
		+ Номер + " от " + Формат(Дата, "ДЛФ=Д") + " г.";
	Док.Номенклатура          = Выб.Флакон;
	Док.Организация           = Организация;
	Док.Ответственный         = Ответственный;
	Док.Склад                 = AMS_ВызовСервера.СкладКомпании();
	Док.ВариантКомплектации   = Выб.Спецификация;
	Док.Подразделение         = Подразделение;
	Док.Статус                = Перечисления.СтатусыСборокТоваров.СобраноРазобрано;
	Док.СборкаПодДеятельность = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
	Док.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СборкаТоваров;
	Док.ВариантПриемкиТоваров = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
	Док.AMS_Операция             = Перечисления.AMS_ОперацияСборкаТоваров.ПроизводствоФлаконов;

	Табл = Док.Товары;
	Табл.Очистить();
	НовСтр = Табл.Добавить();

	НовСтр.Номенклатура       = Выб.Преформа;
	НовСтр.Количество         = Выб.Количество;
	НовСтр.КоличествоУпаковок = Выб.Количество;

	мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ);

	Возврат Док.Ссылка;
КонецФункции

Процедура ОформитьДокументПеремещениеТоваров(Отказ)
	Если ЗначениеЗаполнено(ПеремещениеТоваров) Тогда
		Док = ПеремещениеТоваров.ПолучитьОбъект();
	Иначе
		Док = Документы.ПеремещениеТоваров.СоздатьДокумент();
	КонецЕсли;

	Если Док.ПометкаУдаления <> ПометкаУдаления Тогда
		мср.УстановитьПометкуУдаленияДокументу(Док, ПометкаУдаления, Отказ);
	КонецЕсли;

	Док.Дата = Дата + 10;

	Док.ВидЦены                 = Справочники.Склады.УчетныйВидЦены(Склад);
	Док.Организация             = Организация;
	Док.Ответственный           = Ответственный;
	Док.Автор                   = Ответственный;
	Док.Подразделение           = Подразделение;
	Док.СкладОтправитель        = AMS_ВызовСервера.СкладКомпании();
	Док.СкладПолучатель         = Склад;
	Док.Статус                  = Перечисления.СтатусыПеремещенийТоваров.Принято;
	Док.НаправлениеДеятельности = Справочники.НаправленияДеятельности.НайтиПоНаименованию("Продажа", Истина);
	Док.ХозяйственнаяОперация   = Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
	Док.СпособДоставки          = Перечисления.СпособыДоставки.Самовывоз;
	Док.ВариантПриемкиТоваров   = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
	Док.Комментарий             = "Сформирован автоматичестки. Оформление приёма из переработку (со склад компании). Приём из переработки № "
		+ Номер + " от " + Формат(Дата, "ДЛФ=Д") + " г.";

	Док._ОперацияПроизводства = Перечисления.AMS_ОперацииПроизводства.ПриемИзПереработки;

	Табл = Док.Товары;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Товары", Товары.Выгрузить( , "Номенклатура,Количество"));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&Товары КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	СУММА(вт.Количество) КАК Количество,
	|	СУММА(вт.Количество) КАК КоличествоУпаковок
	|ИЗ
	|	вт КАК вт
	|
	|СГРУППИРОВАТЬ ПО
	|	вт.Номенклатура";

	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();

	Табл.Очистить();

	Пока Выб.Следующий() Цикл
		Стр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Выб);
	КонецЦикла;

	мср.ЗаписатьДокумент(Док, РежимЗаписиДокумента.Проведение, Отказ);

	Если Отказ Тогда
		ОбщегоНазначения.СообщитьПользователю(
			"Не удалось записать документ перемещения давальческой продукции на склад.");
	Иначе
		ПеремещениеТоваров = Док.Ссылка;
	КонецЕсли;
КонецПроцедуры
Процедура ЗаполнитьРеквизитыПоУмолчанию()
	Склад         = AMS_ВызовСервера.ПолучитьСвойСклад();
	Ответственный = Пользователи.ТекущийПользователь();
КонецПроцедуры
Процедура ОтменитьПроведение(Отказ)
	Если ЗначениеЗаполнено(ПеремещениеТоваров) Тогда
		Если ПометкаУдаления Тогда
			мср.УстановитьПометкуУдаленияДокументу(ПеремещениеТоваров, Истина, Отказ);

		ИначеЕсли ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПеремещениеТоваров, "Проведен") Тогда
			мср.ЗаписатьДокумент(ПеремещениеТоваров, РежимЗаписиДокумента.ОтменаПроведения, Отказ);
		КонецЕсли;
	КонецЕсли;

	Для Каждого Стр Из Товары Цикл
		СборкаТоваров = Стр.СборкаТоваров;
		Если ЗначениеЗаполнено(СборкаТоваров) Тогда
			Если ПометкаУдаления Тогда
				мср.УстановитьПометкуУдаленияДокументу(СборкаТоваров, Истина, Отказ);

			ИначеЕсли ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СборкаТоваров, "Проведен") Тогда
				мср.ЗаписатьДокумент(СборкаТоваров, РежимЗаписиДокумента.ОтменаПроведения, Отказ);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьНаборыЗначенийДоступа(Таблица) Экспорт
	СтрокаТаб = Таблица.Добавить();
	СтрокаТаб.ЗначениеДоступа = Организация;

	СтрокаТаб = Таблица.Добавить();
	СтрокаТаб.ЗначениеДоступа = Склад;
КонецПроцедуры

#КонецОбласти

#КонецЕсли