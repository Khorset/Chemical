#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьРеализации();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРеализации

&НаКлиенте
Процедура РеализацииВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	// Снятие модифицированности, т.к. перед закрытием признак проверяется.
	Модифицированность = Ложь;

	Стр = Элемент.ТекущиеДанные;

	Данные = Новый Структура;
	Данные.Вставить("Реализация", Стр.Реализация);
	Данные.Вставить("ВремяДоставкиПо", Стр.ВремяДоставкиПо);
	Данные.Вставить("СуммаДокумента", Стр.СуммаДокумента);
	Данные.Вставить("КоличествоПалет", Стр.КоличествоПалет);
	Данные.Вставить("Вес", Стр.Вес);
	Данные.Вставить("Объем", Стр.Объем);
	Данные.Вставить("Обрешетка", Стр.Обрешетка);
	Данные.Вставить("СпособПередачиТоваров", Стр.СпособПередачиТоваров);
	Данные.Вставить("УсловияОтгрузки", Стр.УсловияОтгрузки);
	Данные.Вставить("ОсобыеУсловияПеревозкиОписание", Стр.ОсобыеУсловияПеревозкиОписание);

	Закрыть(Данные);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьРеализации()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Параметры.Дата);
	Запрос.УстановитьПараметр("Партнер", Параметры.Партнер);
	Запрос.УстановитьПараметр("СпособДоставки", Параметры.СпособДоставки);
	Запрос.УстановитьПараметр("ВремяДоставкиС", Параметры.ВремяДоставкиС);
	Запрос.УстановитьПараметр("АдресДоставки", Параметры.АдресДоставки);
	Запрос.УстановитьПараметр("МассивРеализаций", Параметры.МассивРеализаций);

	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.Ссылка КАК Реализация,
	|	т.ВремяДоставкиПо КАК ВремяДоставкиПо,
	|	т.СуммаДокумента КАК СуммаДокумента,
	|	т.AMS_КоличествоПалет КАК КоличествоПалет,
	|	т.AMS_Вес КАК Вес,
	|	т.AMS_Объем КАК Объем,
	|	т.AMS_Обрешетка КАК Обрешетка,
	|	т.AMS_СпособПередачиТоваров КАК СпособПередачиТоваров,
	|	т.AMS_УсловияОтгрузки КАК УсловияОтгрузки,
	|	т.ОсобыеУсловияПеревозкиОписание КАК ОсобыеУсловияПеревозкиОписание
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК т
	|ГДЕ
	|	т.Проведен
	|	И т.AMS_СтатусРеализации = ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке)
	|	И т.Партнер = &Партнер
	|	И т.СпособДоставки = &СпособДоставки
	|	И т.ВремяДоставкиС = &ВремяДоставкиС
	|	И т.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И ВЫБОР
	|		КОГДА т.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчикаПоАдресу)
	|			ТОГДА т.АдресДоставкиПеревозчика = &АдресДоставки
	|		ИНАЧЕ т.АдресДоставки = &АдресДоставки
	|	КОНЕЦ
	|	И НЕ т.Ссылка В (&МассивРеализаций)
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Номер";
	Реализации.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

#КонецОбласти