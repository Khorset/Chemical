&НаСервере
Функция ПолучитьМассивДокументов_AMS_ПроизводствоЗаСмену(Дата, Смена, Номенклатура)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Смена", Смена);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	д.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК д
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ПроизводствоЗаСмену.Продукция КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И д.Смена = &Смена
	|	И т.Номенклатура = &Номенклатура";
	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат Рез.Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ЗаписатьМинимальноеКоличествоЗапаса(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	ПараметрыЗаписи = Новый Структура();
	ПараметрыЗаписи.Вставить("Ресурс", "МинимальноеКоличествоЗапаса");
	ПараметрыЗаписи.Вставить("Значение", Результат);
	ПараметрыЗаписи.Вставить("Склад", Склад);
	ПараметрыЗаписи.Вставить("Номенклатура", ДополнительныеПараметры.Номенклатура);
	
	AMS_ВызовСервера.ЗаписатьРегистрТоварныеОграничения(ПараметрыЗаписи);
		
	ПоказатьПлан();
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьМаксимальноеКоличествоЗапаса(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;	
	КонецЕсли;
		
	ПараметрыЗаписи = Новый Структура();
	ПараметрыЗаписи.Вставить("Ресурс", "МаксимальноеКоличествоЗапаса");
	ПараметрыЗаписи.Вставить("Значение", Результат);
	ПараметрыЗаписи.Вставить("Склад", Склад);
	ПараметрыЗаписи.Вставить("Номенклатура", ДополнительныеПараметры.Номенклатура);
	
	AMS_ВызовСервера.ЗаписатьРегистрТоварныеОграничения(ПараметрыЗаписи);
		
	ПоказатьПлан();
КонецПроцедуры

