#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура НастройкаФормы()
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Склад", Склад,
		ВидСравненияКомпоновкиДанных.Равно, , ЗначениеЗаполнено(Склад));
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Статус", ПредопределенноеЗначение(
		"Перечисление._СтатусыПроизводства.Выполнено"), ВидСравненияКомпоновкиДанных.НеРавно, , СкрытьЗакрытые);
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	УсловноеОформление.Элементы.Очистить();

	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Упаковка.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Упаковка.Минус");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Меньше;
	ОтборЭлемента.ПравоеЗначение = 0;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаВнимание);

	//

	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Сырье.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Сырье.Минус");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Меньше;
	ОтборЭлемента.ПравоеЗначение = 0;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаВнимание);

	//
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Поступления.Имя);

	ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;

	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Поступления.НомерВходящегоДокумента");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;

	ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Поступления.ДатаВходящегоДокумента");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветВажного);
КонецПроцедуры

&НаСервере
Процедура ПоказатьПлан()
	//Получить начальную дату
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НАЧАЛОПЕРИОДА(т.Дата, ДЕНЬ) КАК Дата
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК т
	|ГДЕ
	|	т.Склад = &Склад
	|	И НЕ т.Статус В (ЗНАЧЕНИЕ(Перечисление._СтатусыПроизводства.Выполнено), ЗНАЧЕНИЕ(Перечисление._СтатусыПроизводства.РасчётЗарплаты))
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата";
	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Дата1 = НачалоДня(ТекущаяДатаСеанса());
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		Дата1 = Выб.Дата;
	КонецЕсли;

	Дата2 = мср.ПолучитьРабочийДень(1, Дата1);
	Дата3 = мср.ПолучитьРабочийДень(2, Дата1);
	Дата4 = мср.ПолучитьРабочийДень(3, Дата1);

	Если Элементы.Страницы.ТекущаяСтраница = Элементы.СтрПлан Тогда
		ПоказатьПланПроизводства();

		Элементы.ПланГруппа1.Заголовок = Формат(Дата1, "ДЛФ=ДД");
		Элементы.ПланГруппа2.Заголовок = Формат(Дата2, "ДЛФ=ДД");
		Элементы.ПланГруппа3.Заголовок = Формат(Дата3, "ДЛФ=ДД");
		Элементы.ПланГруппа4.Заголовок = Формат(Дата4, "ДЛФ=ДД");

	ИначеЕсли Элементы.Страницы.ТекущаяСтраница = Элементы.СтрУпаковка Тогда
		ПоказатьРасходМатериалов("Упаковка");

		Элементы.УпаковкаГруппа1.Заголовок = Формат(Дата1, "ДЛФ=ДД");
		Элементы.УпаковкаГруппа2.Заголовок = Формат(Дата2, "ДЛФ=ДД");
		Элементы.УпаковкаГруппа3.Заголовок = Формат(Дата3, "ДЛФ=ДД");
		Элементы.УпаковкаГруппа4.Заголовок = Формат(Дата4, "ДЛФ=ДД");

	ИначеЕсли Элементы.Страницы.ТекущаяСтраница = Элементы.СтрСырье Тогда
		ПоказатьРасходМатериалов("Сырье");

		Элементы.СырьеГруппа1.Заголовок = Формат(Дата1, "ДЛФ=ДД");
		Элементы.СырьеГруппа2.Заголовок = Формат(Дата2, "ДЛФ=ДД");
		Элементы.СырьеГруппа3.Заголовок = Формат(Дата3, "ДЛФ=ДД");
		Элементы.СырьеГруппа4.Заголовок = Формат(Дата4, "ДЛФ=ДД");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПоказатьПланПроизводства()
	Табл = ПолучитьДанныеПланаПроизводства();

	НомерСтроки = 0;
	Сегмент     = Неопределено;

	План.Очистить();

	Для Каждого Стр Из Табл Цикл
		Если Не Сегмент = Стр.Сегмент Тогда
			Сегмент = Стр.Сегмент;
			НовСтр = План.Добавить();
			НовСтр.Номенклатура = Стр.Сегмент;
		КонецЕсли;

		НовСтр = План.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);

		НомерСтроки = НомерСтроки + 1;
		НовСтр.НомерСтроки = НомерСтроки;
	КонецЦикла;
КонецПроцедуры

