#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Элементы.Склад.СписокВыбора.Добавить(AMS_ВызовСервера.Цех1());
	Элементы.Склад.СписокВыбора.Добавить(AMS_ВызовСервера.Цех2());
	Элементы.Склад.СписокВыбора.Добавить(AMS_ВызовСервера.Цех3());
	Элементы.Склад.СписокВыбора.Добавить(AMS_ВызовСервера.Цех4());
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если Не ЗначениеЗаполнено(Склад) Тогда
		Склад = AMS_ВызовСервера.Цех1();
	КонецЕсли;
	
	НастройкаФормы();
	УстановитьУсловноеОформление();
	ПоказатьПлан();
	ПоказатьРасходМатериалов("Упаковка");
	ПоказатьРасходМатериалов("Сырье");
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Запись_ПроизводствоЗаСмену" Тогда
		ОбновитьИнтерфейс();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СкладПриИзменении(Элемент)
	ОчиститьСообщения(); 
	
	НастройкаФормы();
	ПоказатьПлан();
	ПоказатьРасходМатериалов("Упаковка");
	ПоказатьРасходМатериалов("Сырье");
КонецПроцедуры

&НаКлиенте
Процедура СкрытьЗакрытыеПриИзменении(Элемент)
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Статус", ПредопределенноеЗначение(
		"Перечисление._СтатусыПроизводства.Выполнено"), ВидСравненияКомпоновкиДанных.НеРавно, , СкрытьЗакрытые);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Продукция.Отбор, "ПроизводствоЗаСмену",
		Элементы.Список.ТекущаяСтрока, ВидСравненияКомпоновкиДанных.Равно, , Истина);
КонецПроцедуры

&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	ОчиститьСообщения(); 
	ПоказатьПлан();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПлан

&НаКлиенте
Процедура ПланВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;

	Имя = Поле.Имя;

	Если Имя = "ПланНомерСтроки" Или Имя = "ПланАртикул" Или Имя = "ПланНоменклатура" Или Имя = "ПланИтого" Тогда
		Возврат;
	КонецЕсли;

	Стр = Элемент.ТекущиеДанные;

	Номенклатура = Стр.Номенклатура;

	Если ТипЗнч(Номенклатура) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
		Возврат;
	КонецЕсли;

	Если Прав(Поле.Имя, 1) = "1" Тогда
		Дата = Дата1;
	ИначеЕсли Прав(Поле.Имя, 1) = "2" Тогда
		Дата = Дата2;
	ИначеЕсли Прав(Поле.Имя, 1) = "3" Тогда
		Дата = Дата3;
	ИначеЕсли Прав(Поле.Имя, 1) = "4" Тогда
		Дата = Дата4;
	КонецЕсли;

	Если Лев(Прав(Поле.Имя, 2), 1) = "Д" Тогда
		Смена = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Дневная");
	Иначе
		Смена = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Вечерняя");
	КонецЕсли;

	Массив = ПолучитьМассивДокументов_AMS_ПроизводствоЗаСмену(Дата, Смена, Номенклатура);

	Если Не Массив = Неопределено Тогда
		Для Каждого Док Из Массив Цикл
			ПоказатьЗначение( , Док);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыУпаковка

&НаКлиенте
Процедура УпаковкаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;

	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Номенклатура = ТекущиеДанные.Номенклатура;

	Если Поле.Имя = "УпаковкаМинЗапас" Тогда
		Оповещение = Новый ОписаниеОповещения("ЗаписатьМинимальноеКоличествоЗапаса", ЭтотОбъект,
			Новый Структура("Номенклатура", Номенклатура));
		
		ПоказатьВводЧисла(Оповещение, ТекущиеДанные.МинЗапас, "Минимальные запасы");

	ИначеЕсли Поле.Имя = "УпаковкаМаксЗапас" Тогда
		Оповещение = Новый ОписаниеОповещения("ЗаписатьМаксимальноеКоличествоЗапаса", ЭтотОбъект,
			Новый Структура("Номенклатура", Номенклатура));
		
		ПоказатьВводЧисла(Оповещение, ТекущиеДанные.МаксЗапас, "Максимальные запасы");
		
	Иначе
		Отбор = Новый Структура;
		Отбор.Вставить("Номенклатура", Номенклатура);
		Отбор.Вставить("Склад", Склад);

		Период = Новый СтандартныйПериод;
		Период.Вариант = ВариантСтандартногоПериода.Месяц;

		ПользовательскиеНастройки = Новый Структура;
		ПользовательскиеНастройки.Вставить("Период", Период);

		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("СформироватьПриОткрытии", Истина);
		ПараметрыФормы.Вставить("КлючНазначенияИспользования", "УпрЗапасами" + Номенклатура + Склад);
		ПараметрыФормы.Вставить("ВидимостьКомандВариантовОтчетов", Ложь);
		ПараметрыФормы.Вставить("Отбор", Отбор);
		ПараметрыФормы.Вставить("КлючВарианта", "ДвижениеТоваров");
		ПараметрыФормы.Вставить("ПользовательскиеНастройки", ПолучитьИзВременногоХранилища(
			AMS_ВызовСервера.ПолучитьАдресПользовательскиеНастройки("AMS_ДвижениеТоваров", ПользовательскиеНастройки,
			"ДвижениеТоваров")));

		ОткрытьФорму("Отчет.AMS_ДвижениеТоваров.Форма", ПараметрыФормы);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

