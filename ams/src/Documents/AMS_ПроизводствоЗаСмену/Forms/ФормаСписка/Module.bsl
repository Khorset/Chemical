&НаСервере
Процедура ПоказатьРасходМатериалов(ВидМатериала)
	НомерСтроки         = 0;
	КоличествоСообщений = 0;
	ТекстСообщения      = "Необходимо заказать поставку:" + Символы.ПС;
	
	Если ВидМатериала = "Упаковка" Тогда
		ЭлементФормы  = Элементы.СтрУпаковка;
		Табл          = Упаковка;
		ДанныеРасхода = ПолучитьДанныеРасходаУпаковки();
			
	ИначеЕсли ВидМатериала = "Сырье" Тогда
		ЭлементФормы  = Элементы.СтрСырье;	
		Табл          = Сырье;
		ДанныеРасхода = ПолучитьДанныеРасходаСырья();
	КонецЕсли;

	Табл.Очистить();

	Для Каждого Стр Из ДанныеРасхода Цикл
		НомерСтроки = НомерСтроки + 1;
		
		НовСтр = Табл.Добавить();
		
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);

		НовСтр.НомерСтроки = НомерСтроки;
		
		Если Стр.Минус < 0 Тогда
			КоличествоСообщений = КоличествоСообщений + 1;
			ТекстСообщения = ТекстСообщения + КоличествоСообщений + ". " + Стр.Номенклатура + Символы.ПС;
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоСообщений > 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		ЭлементФормы.ЦветТекстаЗаголовка  = ЦветаСтиля.ЦветОтрицательногоЧисла;
	Иначе
		ЭлементФормы.ЦветТекстаЗаголовка  = Новый Цвет();
	КонецЕсли;
КонецПроцедуры

