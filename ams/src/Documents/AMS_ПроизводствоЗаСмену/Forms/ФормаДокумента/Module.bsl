	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Товар = Элемент.ТекущиеДанные.Номенклатура;
КонецПроцедуры

&НаКлиенте
Процедура ПродукцияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ИмяПоля = Поле.Имя; 
	
	Если Не ЭтоМойДок Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Номенклатура = Элемент.ТекущиеДанные.Номенклатура;

	Если ИмяПоля = "ПродукцияНомерСтроки" Или ИмяПоля = "ПродукцияНоменклатура" 
		Или ИмяПоля = "ПродукцияСпецификация" Или ИмяПоля = "ПродукцияЕд" Тогда
		
		Если AMS_ВызовСервера.ЭтоKhors() Или ЭтоБух Тогда
			ОткрытьФормуПланированияПроизводства(Номенклатура);

		ИначеЕсли AMS_ВызовСервера.ЕстьПравоАМС(ПредопределенноеЗначение("Перечисление.AMS_Права.Продукция_ПроизводствоПередача")) Тогда
			ОткрытьФормуПланированияПроизводства(Номенклатура);
		КонецЕсли;
	
	ИначеЕсли ИмяПоля = "ПродукцияФакт" 
		И (AMS_ВызовСервера.ЕстьПравоАМС(ПредопределенноеЗначение("Перечисление.AMS_Права.Продукция_ПроизводствоПередача"))
			Или AMS_ВызовСервера.ЕстьПравоАМС(ПредопределенноеЗначение("Перечисление.AMS_Права.Продукция_ПередачаНаСклад")))
		И (Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.ВРаботе")
			Или AMS_ВызовСервера.ЭтоKhors())Тогда
		
		Парам = Новый Структура();
		Парам.Вставить("МассивСтрок", ПолучитьМассивСтрокПродукцияФакт());
		Парам.Вставить("Склад", Объект.Склад);
			
		ОткрытьФорму("Документ.AMS_ПроизводствоЗаСмену.Форма.ФормаПодбораФакт", Парам, , , , ,
			Новый ОписаниеОповещения("ОткрытьФормаПодбораФактЗавершение", ЭтотОбъект, Новый Структура("Номенклатура", Номенклатура)), 
			РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		
	ИначеЕсли ИмяПоля = "ПродукцияПлан" Или ИмяПоля = "ПродукцияУтверждено" Тогда
		ПоказатьДвижениеТовара(Номенклатура, Объект.Склад);

	ИначеЕсли ИмяПоля = "ПродукцияНачОстаток" Или ИмяПоля = "ПродукцияСдано" Или ИмяПоля = "ПродукцияКонОстаток" Тогда
		ПоказатьДвижениеТовара(Номенклатура, AMS_ВызовСервера.СкладПродукции());
	КонецЕсли;
КонецПроцедуры

