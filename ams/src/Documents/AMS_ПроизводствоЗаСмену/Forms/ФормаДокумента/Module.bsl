	НомерБригады = Сред(Элемент.Имя, 7);

	Парам = Новый Структура;
	Парам.Вставить("НомерБригады", НомерБригады);
	Парам.Вставить("МассивСтрок", ПолучитьМассивСтрокСотрудники(НомерБригады));
	Парам.Вставить("СуммаБригады", ПолучитьСуммуБригады(НомерБригады));

	ОткрытьФорму("Документ.AMS_ПроизводствоЗаСмену.Форма.ВыборСоставаБригады", Парам, ЭтотОбъект, , , ,
		Новый ОписаниеОповещения("ОткрытьВыборСоставаБригадыЗавершение", ЭтотОбъект),
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
