&НаСервереБезКонтекста
Функция ПолучитьНаличиеДокументовНаДату(Дата, Склад, Ссылка)
	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК т
	|ГДЕ
	|	т.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И НЕ т.Ссылка = &Ссылка
	|	И т.Склад = &Склад
	|	И т.Цех = ЗНАЧЕНИЕ(Перечисление._МестаПроизводства.Основной)
	|	И т.Смена = ЗНАЧЕНИЕ(Перечисление._ПроизводственныеСмены.Дневная)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК т
	|ГДЕ
	|	т.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И НЕ т.Ссылка = &Ссылка
	|	И т.Склад = &Склад
	|	И т.Цех = ЗНАЧЕНИЕ(Перечисление._МестаПроизводства.Основной)
	|	И т.Смена = ЗНАЧЕНИЕ(Перечисление._ПроизводственныеСмены.Вечерняя)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК т
	|ГДЕ
	|	т.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И НЕ т.Ссылка = &Ссылка
	|	И т.Склад = &Склад
	|	И т.Цех = ЗНАЧЕНИЕ(Перечисление._МестаПроизводства.Дополнительный)
	|	И т.Смена = ЗНАЧЕНИЕ(Перечисление._ПроизводственныеСмены.Дневная)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК т
	|ГДЕ
	|	т.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И НЕ т.Ссылка = &Ссылка
	|	И т.Склад = &Склад
	|	И т.Цех = ЗНАЧЕНИЕ(Перечисление._МестаПроизводства.Дополнительный)
	|	И т.Смена = ЗНАЧЕНИЕ(Перечисление._ПроизводственныеСмены.Вечерняя)";
	Рез = Запрос.ВыполнитьПакет();

	Стр = Новый Структура;
	Стр.Вставить("ОсновнойДневная", Не Рез[0].Пустой());
	Стр.Вставить("ОсновнойВечерняя", Не Рез[1].Пустой());
	Стр.Вставить("ДополнительныйДневная", Не Рез[2].Пустой());
	Стр.Вставить("ДополнительныйВечерняя", Не Рез[3].Пустой());

	Возврат Стр;
КонецФункции

&НаСервере
Процедура ПолучитьДокументыПроизводстваПродукции()
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
