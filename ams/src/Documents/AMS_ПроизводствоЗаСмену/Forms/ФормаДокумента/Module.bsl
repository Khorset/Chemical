&НаСервере
Процедура УдалитьПродукциюНаСервере(Продукция, Фабрикат)
	Если ЗначениеЗаполнено(Фабрикат) Тогда
		Строки = Объект.Продукция.НайтиСтроки(Новый Структура("Фабрикат", Фабрикат));
	
		Для Каждого ТекСтр Из Строки Цикл
			Объект.Продукция.Удалить(ТекСтр);
		КонецЦикла;
	
		Строки = Объект.Фабрикаты.НайтиСтроки(Новый Структура("Номенклатура", Фабрикат));
		
		Для Каждого ТекСтр Из Строки Цикл
			Объект.Фабрикаты.Удалить(ТекСтр);
		КонецЦикла;
	
	Иначе
		Строки = Объект.Продукция.НайтиСтроки(Новый Структура("Номенклатура", Продукция));
	
		Для Каждого ТекСтр Из Строки Цикл
			Объект.Продукция.Удалить(ТекСтр);
		КонецЦикла;
	КонецЕсли;	

	ЗаполнитьРасходМатериалов();
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьДвижениеТовара(Номенклатура, Склад)
	ИмяОтчета   = "AMS_ДвижениеТоваров";
	ИмяВарианта = "ДвижениеТоваров";

	Период = Новый СтандартныйПериод;
	Период.Вариант = ВариантСтандартногоПериода.Месяц;

	ПользовательскиеНастройки = Новый Структура;
	ПользовательскиеНастройки.Вставить("Период", Период);

	Отбор = Новый Структура;
	Отбор.Вставить("Склад", Склад);
	Отбор.Вставить("Номенклатура", Номенклатура);

	Парам = Новый Структура;
	Парам.Вставить("ВидимостьКомандВариантовОтчетов", Ложь);
	Парам.Вставить("СформироватьПриОткрытии", Истина);
	Парам.Вставить("Отбор", Отбор);
	Парам.Вставить("КлючНазначенияИспользования", "План производства");
	Парам.Вставить("ПользовательскиеНастройки", ПолучитьИзВременногоХранилища(
		AMS_ВызовСервера.ПолучитьАдресПользовательскиеНастройки(ИмяОтчета, ПользовательскиеНастройки, ИмяВарианта)));

	ОткрытьФорму("Отчет." + ИмяОтчета + ".Форма", Парам, ЭтотОбъект, Номенклатура);
КонецПроцедуры

&НаСервере
Функция ПолучитьТекстВопросаУдалитьПродукцию(ТекПродукция)
	СтрПрод = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТекПродукция, "Наименование,_ИспользуетФабрикат,_Фабрикат");

	Текст = "Удалить продукцию:" + Символы.ПС + СтрПрод.Наименование;

	Если СтрПрод._ИспользуетФабрикат Тогда
		ТекФабрикат = СтрПрод._Фабрикат;

		Для Каждого Стр Из Продукция Цикл
			Если Стр.Номенклатура = ТекПродукция Тогда
				Продолжить;
			КонецЕсли;

			СтрНом = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Стр.Номенклатура, "Наименование,_Фабрикат");

			Если СтрНом._Фабрикат = ТекФабрикат Тогда
				Текст = Текст + Символы.ПС + СтрНом.Наименование;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Возврат Текст + "?";
КонецФункции

&НаСервере
Функция ПолучитьПараметрыНоменклатуры(Продукция)
	СпецификацияПродукции = Неопределено;
	Фабрикат              = Неопределено;
	СпецификацияФабриката = Неопределено;

	МассивФабрикаты = Новый Массив;
	МассивПродукция = Новый Массив;

	Табл = Объект.Продукция.Выгрузить();
	Для Каждого Стр Из Табл Цикл
		МассивПродукция.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));

		Если Стр.Номенклатура = Продукция Тогда
			СпецификацияПродукции = Стр.Спецификация;
			Фабрикат              = Стр.Фабрикат;
		КонецЕсли;
	КонецЦикла;
	
	Табл = Объект.Фабрикаты.Выгрузить();
	Для Каждого Стр Из Табл Цикл
		МассивФабрикаты.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));

		Если Стр.Номенклатура = Фабрикат Тогда
			СпецификацияФабриката = Стр.Спецификация;
		КонецЕсли;
	КонецЦикла;
	
	ПарамФормы = Новый Структура;
	
	ПарамФормы.Вставить("Дата", Объект.Дата);
	ПарамФормы.Вставить("Смена", Объект.Смена);
	ПарамФормы.Вставить("Статус", Объект.Статус);
	ПарамФормы.Вставить("Склад", Объект.Склад);
	ПарамФормы.Вставить("Продукция", Продукция);
	ПарамФормы.Вставить("СпецификацияПродукции", СпецификацияПродукции);
	ПарамФормы.Вставить("Фабрикат", Фабрикат);
	ПарамФормы.Вставить("СпецификацияФабриката", СпецификацияФабриката);
	ПарамФормы.Вставить("МассивПродукция", МассивПродукция);
	ПарамФормы.Вставить("МассивФабрикаты", МассивФабрикаты);

	Возврат ПарамФормы;
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьСтоимостьПродукции(Дата)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Дата);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	д.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК д
	|ГДЕ
	|	д.Проведен
	|	И д.Статус В (ЗНАЧЕНИЕ(Перечисление._СтатусыПроизводства.Выполнено), ЗНАЧЕНИЕ(Перечисление._СтатусыПроизводства.РасчётЗарплаты))
	|	И д.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ВЫРАЗИТЬ(т.Цена / н.КоэффициентЕдиницыДляОтчетов КАК ЧИСЛО(10, 2))) КАК Стоимость
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	вт КАК вт
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.AMS_ПроизводствоЗаСмену.Продукция КАК т
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК н
	|			ПО т.Номенклатура = н.Ссылка
	|		ПО вт.Ссылка = т.Ссылка
	|ГДЕ
	|	т.Цена > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Стоимость КАК Стоимость
	|ПОМЕСТИТЬ рег
	|ИЗ
	|	РегистрСведений._СтоимостьПродукции.СрезПоследних(
	|			ДОБАВИТЬКДАТЕ(&Дата, ДЕНЬ, -1),
	|			Номенклатура В
	|				(ВЫБРАТЬ
	|					тов.Номенклатура КАК Номенклатура
	|				ИЗ
	|					тов КАК тов)) КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Стоимость КАК Стоимость,
	|	ЕСТЬNULL(рег.Стоимость, 0) КАК СтоимостьСтарая
	|ПОМЕСТИТЬ итог
	|ИЗ
	|	тов КАК тов
	|		ЛЕВОЕ СОЕДИНЕНИЕ рег КАК рег
	|		ПО тов.Номенклатура = рег.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	итог.Номенклатура КАК Номенклатура,
	|	итог.Стоимость КАК Стоимость
	|ИЗ
	|	итог КАК итог
	|ГДЕ
	|	НЕ итог.Стоимость = итог.СтоимостьСтарая";

	Рез = Запрос.Выполнить();
	Выб = Рез.Выбрать();

	НаборЗаписей = РегистрыСведений._СтоимостьПродукции.СоздатьНаборЗаписей();

	НаборЗаписей.Отбор.Период.Установить(Дата);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() > 0 Тогда
		НаборЗаписей.Очистить();
	КонецЕсли;

	Пока Выб.Следующий() Цикл
		НоваяЗапись = НаборЗаписей.Добавить();

		НоваяЗапись.Период = Дата;
		ЗаполнитьЗначенияСвойств(НоваяЗапись, Выб);
	КонецЦикла;

	НаборЗаписей.Записать();
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьМассивНеотгруженныхТоваров(ТекущийДокумент)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.КоличествоФакт КАК Количество,
	|	т.Номенклатура._Упаковка КАК Упаковка
	|ПОМЕСТИТЬ Сделано
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену.Продукция КАК т
	|ГДЕ
	|	т.Ссылка = &ТекущийДокумент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	СУММА(т.КоличествоУпаковок) КАК Количество
	|ПОМЕСТИТЬ Сдано
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК д
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров.Товары КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	д.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПеремещенийТоваров.Принято)
	|	И НЕ д.ПометкаУдаления
	|	И д._Основание = &ТекущийДокумент
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(Сделано.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(Сделано.Количество, 0) - ЕСТЬNULL(Сдано.Количество, 0) КАК Количество,
	|	Сделано.Упаковка КАК Упаковка
	|ИЗ
	|	Сделано КАК Сделано
	|		ЛЕВОЕ СОЕДИНЕНИЕ Сдано КАК Сдано
	|		ПО Сделано.Номенклатура = Сдано.Номенклатура
	|ГДЕ
	|	НЕ ЕСТЬNULL(Сделано.Количество, 0) - ЕСТЬNULL(Сдано.Количество, 0) = 0";

	Табл = Запрос.Выполнить().Выгрузить();

	Массив = Новый Массив;

	Для Каждого Стр Из Табл Цикл
		Массив.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;

	Возврат Массив;
КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	УсловноеОформление.Элементы.Очистить();

	//	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ПродукцияФакт.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Объект.Статус");
	ОтборЭлемента.ПравоеЗначение = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.ВРаботе");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветВажного);
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Ложь);

	// Не работает
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Продукция.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Продукция.Факт");
	ОтборЭлемента.ПравоеЗначение = Новый ПолеКомпоновкиДанных("Продукция.Сдано");
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеРавно;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветАктивности);

	//  не работает
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ДокументыПроизводства.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ДокументыПроизводства.СформированАвтоматически");
	ОтборЭлемента.ПравоеЗначение = Истина;
	ОтборЭлемента.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаШапкиОтчета);
КонецПроцедуры

