&НаСервере
Процедура ЗаполнитьРасходМатериалов()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Продукция", Объект.Продукция.Выгрузить());
	Запрос.УстановитьПараметр("Фабрикаты", Объект.Фабрикаты.Выгрузить());
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("ВидыНоменклатуры", AMS_ВызовСервера.ВидыНоменклатурыФабрикаты());

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Продукция,
	|	т.Спецификация КАК Спецификация,
	|	т.КоличествоПлан КАК КоличествоПлан,
	|	т.КоличествоФакт КАК КоличествоФакт
	|ПОМЕСТИТЬ п
	|ИЗ
	|	&Продукция КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Фабрикат,
	|	т.Спецификация КАК Спецификация,
	|	т.КоличествоПлан КАК КоличествоПлан,
	|	т.КоличествоФакт КАК КоличествоФакт
	|ПОМЕСТИТЬ ф
	|ИЗ
	|	&Фабрикаты КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	п.Продукция КАК Продукция,
	|	СпецТ.Номенклатура КАК Номенклатура,
	|	п.КоличествоПлан * СпецТ.Количество КАК КоличествоПлан,
	|	п.КоличествоФакт * СпецТ.Количество КАК КоличествоФакт
	|ПОМЕСТИТЬ п1
	|ИЗ
	|	п КАК п
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник._ВариантыСпецификацийНоменклатуры.Товары КАК СпецТ
	|		ПО п.Спецификация = СпецТ.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО СпецТ.Номенклатура = Ном.Ссылка
	|ГДЕ
	|	НЕ Ном.ВидНоменклатуры В (&ВидыНоменклатуры)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ф.Фабрикат КАК Фабрикат,
	|	СпецТ.Номенклатура КАК Номенклатура,
	|	ф.КоличествоПлан * СпецТ.Количество / СпецД.Количество КАК КоличествоПлан,
	|	ф.КоличествоФакт * СпецТ.Количество / СпецД.Количество КАК КоличествоФакт
	|ПОМЕСТИТЬ ф1
	|ИЗ
	|	ф КАК ф
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник._ВариантыСпецификацийНоменклатуры.Товары КАК СпецТ
	|		ПО ф.Спецификация = СпецТ.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник._ВариантыСпецификацийНоменклатуры КАК СпецД
	|		ПО ф.Спецификация = СпецД.Ссылка
	|ГДЕ
	|	НЕ СпецТ.Номенклатура.Код = ""01-00000017""
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	п1.Продукция КАК Продукция,
	|	п1.Номенклатура КАК Номенклатура,
	|	п1.КоличествоПлан КАК КоличествоПлан,
	|	п1.КоличествоФакт КАК КоличествоФакт
	|ИЗ
	|	п1 КАК п1
	|
	|УПОРЯДОЧИТЬ ПО
	|	п1.Номенклатура.Наименование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ф1.Фабрикат КАК Фабрикат,
	|	ф1.Номенклатура КАК Номенклатура,
	|	ф1.КоличествоПлан КАК КоличествоПлан,
	|	ф1.КоличествоФакт КАК КоличествоФакт
	|ИЗ
	|	ф1 КАК ф1
	|
	|УПОРЯДОЧИТЬ ПО
	|	ф1.Номенклатура.Наименование";

	Рез = Запрос.ВыполнитьПакет();
	Объект.МатериалыПродукции.Загрузить(Рез[4].Выгрузить());
	Объект.МатериалыФабриката.Загрузить(Рез[5].Выгрузить());
КонецПроцедуры

