&НаСервере
Функция ПолучитьМассивСтрокСотрудники(НомерБригады)
	Склад = Объект.Склад;

	Если Склад = AMS_ВызовСервера.Цех1() Тогда
		ГруппаФасовщики = Справочники.ФизическиеЛица.ПолучитьСсылку(
			Новый УникальныйИдентификатор("0c039e32-07ad-11eb-8de3-a4bf015601f8"));
			
	ИначеЕсли Склад = AMS_ВызовСервера.Цех2() Тогда  // Грецкий
		ГруппаФасовщики = Новый Массив;
		ГруппаФасовщики.Добавить(Справочники.ФизическиеЛица.ПолучитьСсылку(
			Новый УникальныйИдентификатор("0c039e32-07ad-11eb-8de3-a4bf015601f8"))); //Цех1
		ГруппаФасовщики.Добавить(Справочники.ФизическиеЛица.ПолучитьСсылку(
			Новый УникальныйИдентификатор("14e401a8-07ad-11eb-8de3-a4bf015601f8"))); //Цех2
			
	ИначеЕсли Склад = AMS_ВызовСервера.Цех3() Тогда
		ГруппаФасовщики = Справочники.ФизическиеЛица.ПолучитьСсылку(
			Новый УникальныйИдентификатор("14e401aa-07ad-11eb-8de3-a4bf015601f8"));
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ГруппаФасовщики", ГруппаФасовщики);
	Запрос.УстановитьПараметр("ФасовкаБригады", Объект.ФасовкаБригады.Выгрузить());
	Запрос.УстановитьПараметр("НомерБригады", НомерБригады);
	Запрос.УстановитьПараметр("Подработка", Объект.Подработка);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Сотрудник,
	|	т._НомерГруппы КАК НомерГруппы
	|ПОМЕСТИТЬ лица
	|ИЗ
	|	Справочник.ФизическиеЛица КАК т
	|ГДЕ
	|	т.Родитель В (&ГруппаФасовщики)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.НомерБригады КАК НомерБригады,
	|	т.Сотрудник КАК Сотрудник,
	|	т.Подработка КАК Подработка,
	|	т.Сумма КАК Сумма
	|ПОМЕСТИТЬ ЛицаВкл
	|ИЗ
	|	&ФасовкаБригады КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЛицаВкл.НомерБригады КАК НомерБригады,
	|	ЛицаВкл.Сотрудник КАК Сотрудник,
	|	ЛицаВкл.Подработка КАК Подработка,
	|	ЛицаВкл.Сумма КАК Сумма
	|ПОМЕСТИТЬ НашаБригада
	|ИЗ
	|	ЛицаВкл КАК ЛицаВкл
	|ГДЕ
	|	ЛицаВкл.НомерБригады = &НомерБригады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЛицаВкл.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ ДругиеБригады
	|ИЗ
	|	ЛицаВкл КАК ЛицаВкл
	|ГДЕ
	|	НЕ ЛицаВкл.Сотрудник В
	|				(ВЫБРАТЬ
	|					т.Сотрудник КАК Сотрудник
	|				ИЗ
	|					НашаБригада КАК т)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НашаБригада.Сотрудник ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК Метка,
	|	лица.Сотрудник КАК Сотрудник,
	|	лица.НомерГруппы КАК НомерГруппы,
	|	ВЫБОР
	|		КОГДА НашаБригада.Подработка ЕСТЬ NULL
	|			ТОГДА &Подработка
	|		ИНАЧЕ НашаБригада.Подработка
	|	КОНЕЦ КАК Подработка,
	|	НашаБригада.Сумма КАК Сумма,
	|	ВЫБОР
	|		КОГДА ДругиеБригады.Сотрудник ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК Включен
	|ИЗ
	|	лица КАК лица
	|		ЛЕВОЕ СОЕДИНЕНИЕ НашаБригада КАК НашаБригада
	|		ПО лица.Сотрудник = НашаБригада.Сотрудник
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДругиеБригады КАК ДругиеБригады
	|		ПО лица.Сотрудник = ДругиеБригады.Сотрудник";

	МассивСтрок = Новый Массив;
	Табл = Запрос.Выполнить().Выгрузить();
	Для Каждого Стр Из Табл Цикл
		МассивСтрок.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;

	Возврат МассивСтрок;
КонецФункции

&НаСервере
Процедура ЗаполнитьФасовкаБригады(Результат)
	Склад = Объект.Склад;
	Если Склад = AMS_ВызовСервера.Цех1() Тогда
		Работа = Справочники._Работы.Фасовка1;
		
	ИначеЕсли Склад = AMS_ВызовСервера.Цех2() Тогда
		Работа = Справочники._Работы.Фасовка2;
		
	ИначеЕсли Склад = AMS_ВызовСервера.Цех3() Тогда
		Работа = Справочники._Работы.Фасовка3;
	КонецЕсли;

	НомерБригады = Результат.НомерБригады;
	МассивСтрок = Результат.МассивСтрок;

	КоличествоВБригаде = МассивСтрок.Количество();

	ФасовкаБригады = Объект.ФасовкаБригады;

	Строки = ФасовкаБригады.НайтиСтроки(Новый Структура("НомерБригады", НомерБригады));
	Для Каждого Стр Из Строки Цикл
		ФасовкаБригады.Удалить(Стр);
	КонецЦикла;

	Если КоличествоВБригаде = 0 Тогда
		Возврат;
	КонецЕсли;

	ИтогоСумма = ПолучитьСуммуБригады(НомерБригады);

	Для Каждого Стр Из МассивСтрок Цикл
		НовСтр = ФасовкаБригады.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
		НовСтр.Работа = Работа;
		НовСтр.Сумма = ?(КоличествоВБригаде = 0, 0, ИтогоСумма / КоличествоВБригаде) * ?(Стр.Подработка
			= Объект.Подработка, Объект.Подработка, Стр.Подработка);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивСтрокТовары(НомерБригады)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("НомерБригады", НомерБригады);
	Запрос.УстановитьПараметр("Продукция", Объект.Продукция.Выгрузить());
	Запрос.УстановитьПараметр("ФасовкаПродукция", Объект.ФасовкаПродукция.Выгрузить());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.КоличествоФакт КАК КоличествоФакт
	|ПОМЕСТИТЬ прод
	|ИЗ
	|	&Продукция КАК т
	|ГДЕ
	|	т.КоличествоФакт > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.НомерБригады КАК НомерБригады,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	&ФасовкаПродукция КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	СУММА(тов.Количество) КАК Расфасовано
	|ПОМЕСТИТЬ уже
	|ИЗ
	|	тов КАК тов
	|ГДЕ
	|	НЕ тов.НомерБригады = &НомерБригады
	|
	|СГРУППИРОВАТЬ ПО
	|	тов.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Количество КАК Количество
	|ПОМЕСТИТЬ текБригада
	|ИЗ
	|	тов КАК тов
	|ГДЕ
	|	тов.НомерБригады = &НомерБригады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	прод.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(прод.КоличествоФакт, 0) - ЕСТЬNULL(уже.Расфасовано, 0) КАК Остаток,
	|	ЕСТЬNULL(текБригада.Количество, 0) КАК Количество
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	прод КАК прод
	|		ЛЕВОЕ СОЕДИНЕНИЕ уже КАК уже
	|		ПО прод.Номенклатура = уже.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ текБригада КАК текБригада
	|		ПО прод.Номенклатура = текБригада.Номенклатура
	|ГДЕ
	|	НЕ ЕСТЬNULL(прод.КоличествоФакт, 0) - ЕСТЬNULL(уже.Расфасовано, 0) = 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Цена КАК Цена
	|ПОМЕСТИТЬ ц
	|ИЗ
	|	РегистрСведений._ЦеныФасовкиПродукции.СрезПоследних(
	|			&Дата,
	|			Номенклатура В
	|				(ВЫБРАТЬ
	|					т.Номенклатура КАК Номенклатура
	|				ИЗ
	|					вт КАК т)) КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номенклатура КАК Номенклатура,
	|	вт.Остаток КАК Остаток,
	|	ЕСТЬNULL(ц.Цена, 0) КАК Цена,
	|	вт.Количество КАК Количество,
	|	вт.Количество * ЕСТЬNULL(ц.Цена, 0) КАК Сумма
	|ИЗ
	|	вт КАК вт
	|		ЛЕВОЕ СОЕДИНЕНИЕ ц КАК ц
	|		ПО вт.Номенклатура = ц.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ном
	|		ПО вт.Номенклатура = ном.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ном.Наименование";

	МассивСтрок = Новый Массив;
	Табл = Запрос.Выполнить().Выгрузить();
	Для Каждого Стр Из Табл Цикл
		МассивСтрок.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;

	Возврат МассивСтрок;
КонецФункции

&НаСервере
Процедура ЗаполнитьФасовкаПродукция(Результат)
	НомерБригады = Результат.НомерБригады;
	МассивСтрок = Результат.МассивСтрок;

	ФасовкаБригады = Объект.ФасовкаБригады;
	ФасовкаПродукция = Объект.ФасовкаПродукция;

	Строки = ФасовкаПродукция.НайтиСтроки(Новый Структура("НомерБригады", НомерБригады));
	Для Каждого Стр Из Строки Цикл
		ФасовкаПродукция.Удалить(Стр);
	КонецЦикла;

	Для Каждого Стр Из МассивСтрок Цикл
		НовСтр = ФасовкаПродукция.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
	КонецЦикла;

	КоличествоВБригаде = ПолучитьКоличествоВБригаде(ФасовкаБригады, НомерБригады);

	Если КоличествоВБригаде = 0 Тогда
		Возврат;
	КонецЕсли;

	ИтогоСумма = ПолучитьСуммуБригады(НомерБригады);

	Для Каждого Стр Из ФасовкаБригады Цикл
		Если Стр.НомерБригады = НомерБригады Тогда
			Стр.Сумма = ?(КоличествоВБригаде = 0, 0, ИтогоСумма / КоличествоВБригаде) * ?(Стр.Подработка
				= Объект.Подработка, Объект.Подработка, Стр.Подработка);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПолучитьКоличествоВБригаде(ФасовкаБригады, НомерБригады)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НомерБригады", НомерБригады);
	Запрос.УстановитьПараметр("ФасовкаБригады", ФасовкаБригады.Выгрузить());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.НомерБригады КАК НомерБригады,
	|	т.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	&ФасовкаБригады КАК т
	|ГДЕ
	|	т.НомерБригады = &НомерБригады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(вт.Сотрудник) КАК КоличествоСотрудников
	|ИЗ
	|	вт КАК вт";
	Рез = Запрос.Выполнить();

	Выб = Рез.Выбрать();
	Выб.Следующий();

	Возврат ?(Выб.КоличествоСотрудников = Null, 0, Выб.КоличествоСотрудников);
КонецФункции

&НаСервере
Процедура ПоказатьБригады()
	ТабПродукция =        Объект.Продукция.Выгрузить();
	ТабФасовкаБригады =   Объект.ФасовкаБригады.Выгрузить();
	ТабФасовкаПродукция = Объект.ФасовкаПродукция.Выгрузить();

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Продукция", ТабПродукция);
	Запрос.УстановитьПараметр("ФасовкаПродукция", ТабФасовкаПродукция);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.НомерСтроки КАК НомерСтроки,
	|	т.Номенклатура КАК Номенклатура,
	|	т.КоличествоПлан КАК КоличествоПлан,
	|	т.КоличествоФакт КАК КоличествоФакт
	|ПОМЕСТИТЬ прод
	|ИЗ
	|	&Продукция КАК т
	|ГДЕ
	|	НЕ(т.КоличествоПлан = 0
	|				И т.КоличествоФакт = 0)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.НомерБригады КАК НомерБригады,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Количество КАК Количество
	|ПОМЕСТИТЬ тов
	|ИЗ
	|	&ФасовкаПродукция КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	прод.НомерСтроки КАК НомерСтроки,
	|	прод.Номенклатура КАК Номенклатура,
	|	прод.КоличествоПлан КАК КоличествоПлан,
	|	прод.КоличествоФакт КАК КоличествоФакт
	|ИЗ
	|	прод КАК прод
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	тов.НомерБригады КАК НомерБригады,
	|	тов.Номенклатура КАК Номенклатура,
	|	тов.Количество КАК Количество
	|ИЗ
	|	тов КАК тов";

	Рез = Запрос.ВыполнитьПакет();

	ТабПродукция = Рез[2].Выгрузить();
	ТабФасовка = Рез[3].Выгрузить();
    
    //
	Фасовка.Очистить();
	СКД = Документы.AMS_ПроизводствоЗаСмену.ПолучитьМакет("скдФасовка");

	Настройки = СКД.НастройкиПоУмолчанию;

	ВнешниеНаборыДанных = Новый Структура;
	ВнешниеНаборыДанных.Вставить("Продукция", ТабПродукция);
	ВнешниеНаборыДанных.Вставить("Фасовка", ТабФасовка);

	мср.ПолучитьДанныеНаОснованииСКД(СКД, Фасовка, Настройки, Неопределено, , , ВнешниеНаборыДанных);
    
    //
	КоличествоБригадФасовки = Объект.КоличествоБригадФасовки;
	Для Сч = 1 По КоличествоБригадФасовки Цикл
        //@skip-check query-in-loop
		ПоказатьБригаду(ТабФасовкаБригады, ТабФасовкаПродукция, Формат(Сч, "ЧГ="));
	КонецЦикла;

	ПодсчетКоличествоРаботы();
КонецПроцедуры

&НаСервере
Процедура ПоказатьБригаду(ТабФасовкаБригады, ТабФасовкаПродукция, НомерБригады)
	ИмяТабСостав = "Состав" + НомерБригады;
	ИмяТабТовары = "Товары" + НомерБригады;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НомерБригады", НомерБригады);
	Запрос.УстановитьПараметр("ФасовкаБригады", ТабФасовкаБригады);
	Запрос.УстановитьПараметр("ФасовкаПродукция", ТабФасовкаПродукция);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Сотрудник КАК Сотрудник,
	|	т.Подработка КАК Подработка,
	|	т.Сумма КАК Сумма
	|ПОМЕСТИТЬ Состав
	|ИЗ
	|	&ФасовкаБригады КАК т
	|ГДЕ
	|	т.НомерБригады = &НомерБригады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	т.Цена КАК Цена,
	|	т.Количество КАК Количество,
	|	т.Сумма КАК Сумма
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	&ФасовкаПродукция КАК т
	|ГДЕ
	|	т.НомерБригады = &НомерБригады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Состав.Сотрудник КАК Сотрудник,
	|	Состав.Подработка КАК Подработка,
	|	Состав.Сумма КАК Сумма
	|ИЗ
	|	Состав КАК Состав
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Цена КАК Цена,
	|	Товары.Количество КАК Количество,
	|	Товары.Сумма КАК Сумма
	|ИЗ
	|	Товары КАК Товары";

	Рез = Запрос.ВыполнитьПакет();

	ФасовкаБригады = Рез[2].Выгрузить();
	ФасовкаПродукция = Рез[3].Выгрузить();
	Табл = РеквизитФормыВЗначение(ИмяТабСостав);
	Табл.Очистить();
	Для Каждого Стр Из ФасовкаБригады Цикл
		НовСтр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
	КонецЦикла;
	ЗначениеВРеквизитФормы(Табл, ИмяТабСостав);

	Табл = РеквизитФормыВЗначение(ИмяТабТовары);
	Табл.Очистить();
	Для Каждого Стр Из ФасовкаПродукция Цикл
		НовСтр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
	КонецЦикла;
	ЗначениеВРеквизитФормы(Табл, ИмяТабТовары);
КонецПроцедуры

&НаСервере
Процедура ПодработкаПриИзмененииНаСервере()
	КоличествоБригадФасовки = Объект.КоличествоБригадФасовки;
	ФасовкаБригады = Объект.ФасовкаБригады;

	Для Сч = 1 По КоличествоБригадФасовки Цикл
		НомерБригады = Формат(Сч, "ЧГ=");
		
    	//@skip-check query-in-loop
		КоличествоВБригаде = ПолучитьКоличествоВБригаде(ФасовкаБригады, НомерБригады);
		
		//@skip-check query-in-loop
		ИтогоСумма = ПолучитьСуммуБригады(НомерБригады);

		Для Каждого Стр Из ФасовкаБригады Цикл
			Если Стр.НомерБригады = НомерБригады Тогда
				Стр.Сумма = ?(КоличествоВБригаде = 0, 0, ИтогоСумма / КоличествоВБригаде) * ?(Стр.Подработка
					= Объект.Подработка, Объект.Подработка, Стр.Подработка);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОжидания

&НаКлиенте
Процедура ПослеЗаписиОбработчикОжидания()
	ПоказатьОтчетПередачаПродукции();
КонецПроцедуры

&НаКлиенте
Процедура РасходСырьяПриАктивизацииСтрокиОбработчикОжидания()
	ТекущиеДанные = Элементы.РасходСырья.ТекущиеДанные;

	Если Не ТекущиеДанные = Неопределено Тогда
		ПоказатьОтчетРасшифровкаРасходСырья(ТекущиеДанные.Номенклатура);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РасходУпаковкиПриАктивизацииСтрокиОбработчикОжидания()
	ТекущиеДанные = Элементы.РасходУпаковки.ТекущиеДанные;

	Если Не ТекущиеДанные = Неопределено Тогда
		ПоказатьОтчетРасшифровкаРасходУпаковки(ТекущиеДанные.Номенклатура);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДокументыПроизводстваПриАктивизацииСтрокиОбработчикОжидания()
	ТекущиеДанные = Элементы.ДокументыПроизводства.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПоказатьТоварыДокументыПроизводства(ТекущиеДанные.ДокСсылка, ТекущиеДанные.Операция);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОповещений

&НаКлиенте
Процедура ОткрытьФормуВыбораТовараЗавершение(Результат, ДополнительныеПераметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ОткрытьФормуПланированияПроизводства(Результат.Номенклатура);
КонецПроцедуры

&НаКлиенте
Процедура ОбратоткаКомандыУдалитьПродукциюЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		УдалитьПродукциюНаСервере(ДополнительныеПараметры.Продукция, ДополнительныеПараметры.Фабрикат);
		ПоказатьТовары();
		Модифицированность = Истина;
	КонецЕсли;
КонецПроцедуры

