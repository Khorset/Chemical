
#Область ОписаниеПеременных

&НаКлиенте
Перем ТекДата;

&НаКлиенте
Перем ТекСмена;

&НаКлиенте
Перем ТекСтатус;

&НаКлиенте
Перем ТекЦех;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Объект.Организация = AMS_ВызовСервера.ПолучитьОсновнуюОрганизацию();
	
	Элементы.Склад.СписокВыбора.Добавить(AMS_ВызовСервера.Цех1());
	Элементы.Склад.СписокВыбора.Добавить(AMS_ВызовСервера.Цех2());
	Элементы.Склад.СписокВыбора.Добавить(AMS_ВызовСервера.Цех3());
	Элементы.Склад.СписокВыбора.Добавить(AMS_ВызовСервера.Цех4());
	
	Цех1 = Объект.Склад = AMS_ВызовСервера.Цех1();
	Цех2 = Объект.Склад = AMS_ВызовСервера.Цех2();
	Цех3 = Объект.Склад = AMS_ВызовСервера.Цех3();
	Цех4 = Объект.Склад = AMS_ВызовСервера.Цех4();
	
	Элементы.Утвержден.Видимость           = Не Цех4;
	Элементы.ПродукцияУтверждено.Видимость = Не Цех4;
	Элементы.ПродукцияГруппа1.Видимость    = Не Цех4;
	
	РольЦех1 = Пользователи.РолиДоступны("_Цех1");
	РольЦех2 = Пользователи.РолиДоступны("_Цех2");
	РольЦех3 = Пользователи.РолиДоступны("_Цех3");
	РольЦех4 = Пользователи.РолиДоступны("_Цех4");
	ЭтоБух   = Пользователи.РолиДоступны("AMS_БухгалтерПроизводства, _ГлавныйБухгалтер");
	Khors    = AMS_ВызовСервера.ЭтоKhors();
	
	ЭтоМойДок = (РольЦех1 И Цех1) Или (РольЦех2 И Цех2) Или (РольЦех3 И Цех3) Или (РольЦех4 И Цех4)
				Или ЭтоБух Или Khors;
				
	Элементы.ГруппаДокументы.Видимость = Khors;
	 
	УстановитьУсловноеОформление();

	Если Объект.Статус = Перечисления._СтатусыПроизводства.Выполнено Тогда
		Элементы.Статус.Доступность = Khors Или ЭтоБух;
	КонецЕсли;

	Элементы.Склад.Доступность = Khors Или ЭтоБух Или (РольЦех2 И РольЦех4);

	ПоказатьТолькоОтрицательныеОстаткиПоСырью    = Не Khors;
	ПоказатьТолькоОтрицательныеОстаткиПоУпаковке = Не Khors;

	Сотрудники = ПолучитьСотрудников(Объект.Склад);
	Элементы.ЗамесчикиСотрудник.СписокВыбора.ЗагрузитьЗначения(Сотрудники);
	Элементы.МеханикиСотрудник.СписокВыбора.ЗагрузитьЗначения(Сотрудники);
	Элементы.КладовщикиСотрудник.СписокВыбора.ЗагрузитьЗначения(Сотрудники);
	Элементы.ГрузчикиСотрудник.СписокВыбора.ЗагрузитьЗначения(Сотрудники);
	Элементы.ДопРаботыСотрудник.СписокВыбора.ЗагрузитьЗначения(Сотрудники);

	Если Объект.Склад = AMS_ВызовСервера.Цех1() Тогда
		Элементы.ЗамесчикиРабота.СписокВыбора.Добавить(Справочники._Работы.Замесчик1);

		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.Механик1);
		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.Механик1_);
		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.ПолучитьСсылку(Новый УникальныйИдентификатор("5968ae54-e76b-11ee-8e26-a4bf015601f8")));
		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.ПолучитьСсылку(Новый УникальныйИдентификатор("75a89fe7-b3da-11ef-8e35-a4bf015601f8")));

		Элементы.КладовщикиРабота.СписокВыбора.Добавить(Справочники._Работы.Кладовщик1);

		Элементы.ГрузчикиРабота.СписокВыбора.Добавить(Справочники._Работы.Грузчик1);
		Элементы.ГрузчикиРабота.СписокВыбора.Добавить(Справочники._Работы.Грузчик1_);

	ИначеЕсли Объект.Склад = AMS_ВызовСервера.Цех2() Тогда
		Элементы.ЗамесчикиРабота.СписокВыбора.Добавить(Справочники._Работы.Замесчик2);

		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.Механик2);
		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.ПолучитьСсылку(Новый УникальныйИдентификатор("fd5b6fa3-e76b-11ee-8e26-a4bf015601f8")));

		Элементы.КладовщикиРабота.СписокВыбора.Добавить(Справочники._Работы.Кладовщик2);

		Элементы.ГрузчикиРабота.СписокВыбора.Добавить(Справочники._Работы.Грузчик2);

	ИначеЕсли Объект.Склад = AMS_ВызовСервера.Цех3() Тогда
		Элементы.ЗамесчикиРабота.СписокВыбора.Добавить(Справочники._Работы.Замесчик3);

		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.Механик3_1);
		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.Механик3_2);
		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.Механик3_3);
		Элементы.МеханикиРабота.СписокВыбора.Добавить(Справочники._Работы.НайтиПоНаименованию("Наладчик производственного оборудования (механик 4 кат. цех 3)", Истина));

		Элементы.КладовщикиРабота.СписокВыбора.Добавить(Справочники._Работы.Кладовщик3);

		Элементы.ГрузчикиРабота.СписокВыбора.Добавить(Справочники._Работы.Грузчик3);
	КонецЕсли;

	Элементы.ДопРаботыРабота.СписокВыбора.ЗагрузитьЗначения(ПолучитьДопРаботы(Объект.Склад));

	ПоказатьТовары();
	ПоказатьСтраницуФасовка();
	ПолучитьДокументыПроизводстваПродукции();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Запись_ПеремещениеТоваров" Тогда
		ПоказатьТовары();
		ПолучитьДокументыПроизводстваПродукции();
		ПоказатьОтчетПередачаПродукции();
	
	ИначеЕсли ИмяСобытия = "Запись_ПроизводствоЗаСмену" Тогда
		ОбновитьОтображениеДанных();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("РежимЗаписи", ПараметрыЗаписи.РежимЗаписи);

	Оповестить("Запись_ПроизводствоТоваровЗаСмену", ПараметрыОповещения, Объект.Ссылка);

	Если Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.Выполнено") Или Объект.Статус
		= ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.РасчётЗарплаты") Тогда
		ЗаписатьСтоимостьПродукции(НачалоДня(Объект.Дата));
	КонецЕсли;

	Если Открыта() Тогда
		ПодключитьОбработчикОжидания("ПослеЗаписиОбработчикОжидания", 0.1, Истина);
	КонецЕсли;

	Состояние();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекДата = Объект.Дата;
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	Если НачалоДня(Объект.Дата) = НачалоДня(ТекДата) Тогда
		Объект.Дата = ТекДата;
		Возврат;
	КонецЕсли;

	Стр = ПолучитьНаличиеДокументовНаДату(Объект.Дата, Объект.Склад, Объект.Ссылка);

	СменаДневная  = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Дневная");
	СменаВечерняя = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Вечерняя");

	ЦехОсновной       = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._МестаПроизводства.Основной");
	ЦехДополнительный = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._МестаПроизводства.Дополнительный");

	Если Не Стр.ОсновнойДневная Тогда
		Объект.Дата  = НачалоДня(Объект.Дата) + AMS_ВызовСервера.ПолучитьВремя(9, 0);
		Объект.Цех   = ЦехОсновной;
		Объект.Смена = СменаДневная;

	ИначеЕсли Не Стр.ОсновнойВечерняя Тогда
		Объект.Дата  = НачалоДня(Объект.Дата) + AMS_ВызовСервера.ПолучитьВремя(12, 0);
		Объект.Цех   = ЦехОсновной;
		Объект.Смена = СменаВечерняя;

	ИначеЕсли Не Стр.ДополнительныйДневная Тогда
		Объект.Дата  = НачалоДня(Объект.Дата) + AMS_ВызовСервера.ПолучитьВремя(9, 5);
		Объект.Цех   = ЦехДополнительный;
		Объект.Смена = СменаДневная;

	ИначеЕсли Не Стр.ДополнительныйВечерняя Тогда
		Объект.Дата  = НачалоДня(Объект.Дата) + AMS_ВызовСервера.ПолучитьВремя(12, 5);
		Объект.Цех   = ЦехДополнительный;
		Объект.Смена = СменаВечерняя;

	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю("На " + Формат(Объект.Дата, "ДЛФ=Д") + " все документы созданы.");
		Объект.Дата = ТекДата;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СменаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекСмена = Объект.Смена;
КонецПроцедуры

&НаКлиенте
Процедура СменаПриИзменении(Элемент)
	Если Объект.Смена = ТекСмена Тогда
		Возврат;
	КонецЕсли;

	Стр = ПолучитьНаличиеДокументовНаДату(Объект.Дата, Объект.Склад, Объект.Ссылка);

	СменаДневная  = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Дневная");
	СменаВечерняя = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Вечерняя");

	ЦехОсновной       = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._МестаПроизводства.Основной");
	ЦехДополнительный = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._МестаПроизводства.Дополнительный");

	Если (Объект.Цех = ЦехОсновной И Объект.Смена = СменаДневная И Стр.ОсновнойДневная) Или (Объект.Цех
		= ЦехОсновной И Объект.Смена = СменаВечерняя И Стр.ОсновнойВечерняя) Или (Объект.Цех = ЦехДополнительный
		И Объект.Смена = СменаДневная И Стр.ДополнительныйДневная) Или (Объект.Цех = ЦехДополнительный И Объект.Смена
		= СменаВечерняя И Стр.ДополнительныйВечерняя) Тогда

		ОбщегоНазначенияКлиент.СообщитьПользователю("На " + Формат(Объект.Дата, "ДЛФ=Д")
			+ " такой документ уже созданы.");

		Объект.Смена = ТекСмена;
	КонецЕсли;
	
	УправлениеЭлементамиФормы();
КонецПроцедуры

&НаКлиенте
Процедура ЦехНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекЦех = Объект.Цех;
КонецПроцедуры

&НаКлиенте
Процедура ЦехПриИзменении(Элемент)
	Если Объект.Цех = ТекЦех Тогда
		Возврат;
	КонецЕсли;

	Стр = ПолучитьНаличиеДокументовНаДату(Объект.Дата, Объект.Склад, Объект.Ссылка);

	СменаДневная  = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Дневная");
	СменаВечерняя = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._ПроизводственныеСмены.Вечерняя");

	ЦехОсновной       = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._МестаПроизводства.Основной");
	ЦехДополнительный = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление._МестаПроизводства.Дополнительный");

	Если (Объект.Цех = ЦехОсновной И Объект.Смена = СменаДневная И Стр.ОсновнойДневная) Или (Объект.Цех
		= ЦехОсновной И Объект.Смена = СменаВечерняя И Стр.ОсновнойВечерняя) Или (Объект.Цех = ЦехДополнительный
		И Объект.Смена = СменаДневная И Стр.ДополнительныйДневная) Или (Объект.Цех = ЦехДополнительный И Объект.Смена
		= СменаВечерняя И Стр.ДополнительныйВечерняя) Тогда

		ОбщегоНазначенияКлиент.СообщитьПользователю("На " + Формат(Объект.Дата, "ДЛФ=Д")
			+ " такой документ уже созданы.");

		Объект.Цех = ТекЦех;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СкладПриИзменении(Элемент)
	ПоказатьТовары();
КонецПроцедуры

&НаКлиенте
Процедура СтатусНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ТекСтатус = Объект.Статус;
КонецПроцедуры

&НаКлиенте
Процедура СтатусПриИзменении(Элемент)
	Если AMS_ВызовСервера.ЭтоKhors() Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоЦех4 = (Объект.Склад = AMS_ВызовСервера.Цех4());

	Отказ = Ложь;

	Если Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.Проект") Тогда
		Если Не ЭтоЦех4 И Объект.Утвержден Тогда
			ТекстОшибки = "Установка статуса ""Проект"" утверждённого плана запрещена.";
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки, , , , Отказ);
		КонецЕсли;

		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
			ПроверкаНаличияДокументовПередачиПродукции(Объект.Ссылка, Отказ);
		КонецЕсли;

	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.План") Тогда
		ПроверкаРанееДокументВСтатусеПроект(Отказ);

	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.ВРаботе") Тогда
		ПроверкаРанееНеЗакрытыхДокументов(Отказ);
		ПроверкаРанееДокументВСтатусеПроектПлан(Отказ);

		Если Не ЭтоЦех4 И Не Объект.Утвержден Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю("Документ не утверждён.", , , , Отказ);
		КонецЕсли;

	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.Выполнено") 
		Или Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.РасчётЗарплаты") Тогда

		Если Не ЭтоЦех4 И Не Объект.Утвержден Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю("Документ не утверждён.", , , , Отказ);
		КонецЕсли;

		Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю("Необходимо предварительно провести документ в статусе ""В работе"".", , , , Отказ);
		КонецЕсли;

		Если Объект.Склад = AMS_ВызовСервера.Цех1() Или Объект.Склад = AMS_ВызовСервера.Цех2() Или Объект.Склад = AMS_ВызовСервера.Цех4() Тогда

			Массив = ПолучитьМассивНеотгруженныхТоваров(Объект.Ссылка);
			Если Массив.Количество() > 0 Тогда
				Для Каждого Стр Из Массив Цикл
					ТекстОшибки = "Не сдан на склад товар """ + Стр.Номенклатура + """ " + Стр.Количество + " "
						+ Стр.Упаковка + ".";
					ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки, , , , Отказ);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Если Отказ Тогда
		Объект.Статус = ТекСтатус;
	Иначе
		УправлениеЭлементамиФормы();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УтвержденПриИзменении(Элемент)
	Для Каждого Стр Из Объект.Продукция Цикл
		Если Объект.Утвержден Тогда
			Стр.Утверждено = Стр.КоличествоПлан;
		Иначе
			Стр.Утверждено = 0;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Стр Из Продукция Цикл
		Если Объект.Утвержден Тогда
			Стр.Утверждено = Стр.План;
		Иначе
			Стр.Утверждено = 0;
		КонецЕсли;
	КонецЦикла;
