		ДокументыПроизводства.Загрузить(Табл);
	КонецЕсли;
КонецПроцедуры

#Область Производство

&НаКлиенте
Процедура ОткрытьФормуПланированияПроизводства(Номенклатура)
	ПараметрыФормы = ПолучитьПараметрыНоменклатуры(Номенклатура);

	Если ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(Номенклатура, "_ИспользуетФабрикат") Тогда
		ОткрытьФорму("Документ.AMS_ПроизводствоЗаСмену.Форма.ФормаПродукцияСФабрикатом", ПараметрыФормы, , , , ,
			Новый ОписаниеОповещения("ОткрытьФормуСФабрикатомЗавершение", ЭтотОбъект, Новый Структура("Номенклатура",
			Номенклатура)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	Иначе
		ОткрытьФорму("Документ.AMS_ПроизводствоЗаСмену.Форма.ФормаПродукцияБезФабриката", ПараметрыФормы, , , , ,
			Новый ОписаниеОповещения("ОткрытьФормуБезФабрикатаЗавершение", ЭтотОбъект, Новый Структура("Номенклатура",
			Номенклатура)), РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПоказатьТовары()
	Если Не ЗначениеЗаполнено(Объект.Склад) Тогда
		Возврат;
	КонецЕсли;
	
	Табл = ПолучитьТаблицуФабрикаты();

	Фабрикаты.Загрузить(Табл);

	Табл = ПолучитьТаблицуПродукция();

	Продукция.Загрузить(Табл);

	ПоказатьРасходМатериалов();

	ПоказатьОтчетПередачаПродукции();

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("ПроизводствоЗаСмену", Объект.Ссылка);

		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ т.Ссылка) КАК Количество
		|ИЗ
		|	Документ.ПрочееОприходованиеТоваров КАК т
		|ГДЕ
		|	т._Основание = &ПроизводствоЗаСмену
		|	И т._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПроизводствоПродукции)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ т.Ссылка) КАК Количество
		|ИЗ
		|	Документ.ПеремещениеТоваров КАК т
		|ГДЕ
		|	т._Основание = &ПроизводствоЗаСмену
		|	И т._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПеремещениеПроизведеннойПродукции)";

		Рез = Запрос.ВыполнитьПакет();

		КоличествоПроизводство = Рез[0].Выгрузить().ВыгрузитьКолонку("Количество")[0];
		КоличествоПеремещения = Рез[1].Выгрузить().ВыгрузитьКолонку("Количество")[0];
	КонецЕсли;

	УправлениеЭлементамиФормы();
КонецПроцедуры

&НаСервере
Функция ПолучитьТаблицуФабрикаты()
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Фабрикаты", Объект.Фабрикаты.Выгрузить());
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Если Объект.Смена = Перечисления._ПроизводственныеСмены.Дневная Тогда
		Запрос.УстановитьПараметр("ДатаОстатков", НачалоДня(Объект.Дата) + AMS_ВызовСервера.ПолучитьВремя(8, 55));
	Иначе
		Запрос.УстановитьПараметр("ДатаОстатков", НачалоДня(Объект.Дата) + AMS_ВызовСервера.ПолучитьВремя(11, 55));
	КонецЕсли;

	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	т.НомерСтроки КАК НомерСтроки,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Спецификация КАК Спецификация,
	|	т.КоличествоПлан КАК КоличествоПлан,
	|	т.КоличествоФакт КАК КоличествоФакт,
	|	т.Цена КАК Цена
	|ПОМЕСТИТЬ ф
	|ИЗ
	|	&Фабрикаты КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ф.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(Ост.ВНаличииОстаток, 0) КАК ВНаличииОстаток
	|ПОМЕСТИТЬ Остаток
	|ИЗ
	|	ф КАК ф
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаОстатков, Склад = &Склад) КАК Ост
	|		ПО ф.Номенклатура = Ост.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ф.НомерСтроки КАК НомерСтроки,
	|	ф.Номенклатура КАК Номенклатура,
	|	ф.Спецификация КАК Спецификация,
	|	ЕСТЬNULL(Остаток.ВНаличииОстаток, 0) КАК НачОстаток,
	|	ф.КоличествоПлан КАК Приход,
	|	ф.КоличествоФакт КАК Расход,
	|	ЕСТЬNULL(Остаток.ВНаличииОстаток, 0) + ф.КоличествоПлан - ф.КоличествоФакт КАК КонОстаток,
	|	ф.Цена КАК Цена,
	|	ф.КоличествоПлан * ф.Цена КАК Сумма
	|ИЗ
	|	ф КАК ф
	|		ЛЕВОЕ СОЕДИНЕНИЕ Остаток КАК Остаток
	|		ПО ф.Номенклатура = Остаток.Номенклатура";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

&НаСервере
Функция ПолучитьТаблицуПродукция()
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Продукция", Объект.Продукция.Выгрузить());
	Запрос.УстановитьПараметр("СкладПродукции", AMS_ВызовСервера.СкладПродукции());
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("СсылкаЗаполнена", ЗначениеЗаполнено(Объект.Ссылка));
	Если Объект.Смена = Перечисления._ПроизводственныеСмены.Дневная Тогда
		Запрос.УстановитьПараметр("Дата", НачалоДня(Объект.Дата) + AMS_ВызовСервера.ПолучитьВремя(8, 55));
	Иначе
		Запрос.УстановитьПараметр("Дата", НачалоДня(Объект.Дата) + AMS_ВызовСервера.ПолучитьВремя(11, 55));
	КонецЕсли;

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.НомерСтроки КАК НомерСтроки,
	|	т.Фабрикат КАК Фабрикат,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Спецификация КАК Спецификация,
	|	т.Утверждено КАК Утверждено,
	|	т.КоличествоПлан КАК КоличествоПлан,
	|	т.КоличествоФакт КАК КоличествоФакт,
	|	т.Цена КАК Цена
	|ПОМЕСТИТЬ п
	|ИЗ
	|	&Продукция КАК т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	т.Номенклатура КАК Номенклатура,
	|	СУММА(т.Количество) КАК Количество
	|ПОМЕСТИТЬ Сдано
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК д
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров.Товары КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	д.Проведен
	|	И д.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПеремещенийТоваров.Принято)
	|	И д._Основание = &Ссылка
	|	И д._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПеремещениеПроизведеннойПродукции)
	|	И &СсылкаЗаполнена
	|
	|СГРУППИРОВАТЬ ПО
	|	т.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	п.НомерСтроки КАК НомерСтроки,
	|	п.Фабрикат КАК Фабрикат,
	|	п.Номенклатура КАК Номенклатура,
	|	п.Спецификация КАК Спецификация,
	|	Ном._Упаковка КАК Ед,
	|	п.Утверждено КАК Утверждено,
	|	п.КоличествоПлан КАК План,
	|	п.КоличествоФакт КАК Факт,
	|	ЕСТЬNULL(Ост.ВНаличииОстаток, 0) / Ном.КоэффициентЕдиницыДляОтчетов КАК НачОстаток,
	|	ЕСТЬNULL(Сдано.Количество, 0) / Ном.КоэффициентЕдиницыДляОтчетов КАК Сдано,
	|	(ЕСТЬNULL(Ост.ВНаличииОстаток, 0) + ЕСТЬNULL(Сдано.Количество, 0)) / Ном.КоэффициентЕдиницыДляОтчетов КАК КонОстаток,
	|	п.Цена КАК Цена,
	|	ЕСТЬNULL(п.КоличествоПлан, 0) * п.Цена КАК Сумма,
	|	Ном.Наименование КАК Наименование
	|ИЗ
	|	п КАК п
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Дата, Склад = &СкладПродукции) КАК Ост
	|		ПО п.Номенклатура = Ост.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО п.Номенклатура = Ном.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Сдано КАК Сдано
	|		ПО п.Номенклатура = Сдано.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

&НаСервере
Функция ПолучитьМассивСтрокПродукцияФакт()
	МассивСтрок = Новый Массив();
	Для Каждого Стр Из Объект.Продукция Цикл
		СтрСтроки = Новый Структура();
		СтрСтроки.Вставить("НомерСтроки", Стр.НомерСтроки);
		СтрСтроки.Вставить("Номенклатура", Стр.Номенклатура);
		СтрСтроки.Вставить("Утверждено", Стр.Утверждено);
		СтрСтроки.Вставить("КоличествоПлан", Стр.КоличествоПлан);
		СтрСтроки.Вставить("КоличествоФакт", Стр.КоличествоФакт);
		
		МассивСтрок.Добавить(СтрСтроки);
	КонецЦикла;

	Возврат МассивСтрок;
КонецФункции

&НаСервере
Процедура ПоказатьРасходМатериалов()
	Рез = РеквизитФормыВЗначение("Объект").ПолучитьДанныхПоРасходуМатериалов(ПоказатьТолькоОтрицательныеОстаткиПоСырью,
		ПоказатьТолькоОтрицательныеОстаткиПоУпаковке);

	Если Не Рез = Неопределено Тогда
		РасходСырья.Загрузить(Рез.Сырье);
		
		КоличествоСырья = РасходСырья.Количество();

		РасходУпаковки.Загрузить(Рез.Упаковка);
		
		КоличествоУпаковки = РасходУпаковки.Количество();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПоказатьОтчетПередачаПродукции()
	ПередачаПродукции.Очистить();

	Парам = Новый Структура;
