&НаСервере
Функция ПолучитьДанныеШаблона(Стр)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Родитель", Стр.Родитель);
	Запрос.УстановитьПараметр("Работа", Стр.Работа);
	Запрос.УстановитьПараметр("Подработка", Стр.Подработка);
	Запрос.УстановитьПараметр("Количество", Стр.Количество);
	Запрос.УстановитьПараметр("Цена", Стр.Цена);
	Запрос.УстановитьПараметр("Сумма", Стр.Сумма);

	Запрос.Текст =
	"ВЫБРАТЬ
	|   ФизическиеЛица.Ссылка КАК Сотрудник,
	|   &Работа КАК Работа,
	|   &Подработка КАК Подработка,
	|   &Количество КАК Количество,
	|   &Цена КАК Цена,
	|   &Сумма КАК Сумма
	|ИЗ
	|   Справочник.ФизическиеЛица КАК ФизическиеЛица
	|ГДЕ
	|   ФизическиеЛица.Ссылка В ИЕРАРХИИ(&Родитель)
	|   И НЕ ФизическиеЛица.ЭтоГруппа
	|   И НЕ ФизическиеЛица.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|   ФизическиеЛица.Наименование";

	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

&НаСервере
Функция ПолучитьСуммуБригады(НомерБригады)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НомерБригады", НомерБригады);
	Запрос.УстановитьПараметр("ФасовкаПродукция", Объект.ФасовкаПродукция.Выгрузить());
	Запрос.Текст =
	"ВЫБРАТЬ
	|   т.Сумма КАК Сумма
	|ПОМЕСТИТЬ вт
	|ИЗ
	|   &ФасовкаПродукция КАК т
	|ГДЕ
	|   т.НомерБригады = &НомерБригады
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|   СУММА(ЕСТЬNULL(вт.Сумма, 0)) КАК Сумма
	|ИЗ
	|   вт КАК вт";
	Рез = Запрос.Выполнить();

	Выб = Рез.Выбрать();
	Выб.Следующий();

	Возврат ?(Выб.Сумма = Null, 0, Выб.Сумма);
КонецФункции

&НаСервере
Процедура ПодсчетКоличествоРаботы()
	КоличествоРаботы = Объект.ФасовкаБригады.Количество() + Объект.Замесчики.Количество() + Объект.Механики.Количество()
		+ Объект.Кладовщики.Количество() + Объект.Грузчики.Количество() + Объект.ДопРаботы.Количество();
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьРабота(Вариант, Склад)
	Если Вариант = 1 Тогда
		Если Склад = AMS_ВызовСервера.Цех1() Тогда
			Работа = Справочники._Работы.Замесчик1;
			
		ИначеЕсли Склад = AMS_ВызовСервера.Цех2() Тогда
			Работа = Справочники._Работы.Замесчик2;
			
		ИначеЕсли Склад = AMS_ВызовСервера.Цех3() Тогда
			Работа = Справочники._Работы.Замесчик3;
		КонецЕсли;

	ИначеЕсли Вариант = 2 Тогда
		Если Склад = AMS_ВызовСервера.Цех1() Тогда
			Работа = Справочники._Работы.Механик1;
			
		ИначеЕсли Склад = AMS_ВызовСервера.Цех2() Тогда
			Работа = Справочники._Работы.Механик2;
			
		ИначеЕсли Склад = AMS_ВызовСервера.Цех3() Тогда 
			//Работа = Справочники._Работы.Механик3;
		КонецЕсли;

	ИначеЕсли Вариант = 3 Тогда
		Если Склад = AMS_ВызовСервера.Цех1() Тогда
			Работа = Справочники._Работы.Кладовщик1;
			
		ИначеЕсли Склад = AMS_ВызовСервера.Цех2() Тогда
			Работа = Справочники._Работы.Кладовщик2;
			
		ИначеЕсли Склад = AMS_ВызовСервера.Цех3() Тогда
			Работа = Справочники._Работы.Кладовщик3;
		КонецЕсли;

	ИначеЕсли Вариант = 4 Тогда
		Если Склад = AMS_ВызовСервера.Цех1() Тогда
			Работа = Справочники._Работы.Грузчик1;
			
		ИначеЕсли Склад = AMS_ВызовСервера.Цех2() Тогда
			Работа = Справочники._Работы.Грузчик2;
			
		ИначеЕсли Склад = AMS_ВызовСервера.Цех3() Тогда
			Работа = Справочники._Работы.Грузчик3;
		КонецЕсли;
	КонецЕсли;

	Возврат Работа;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСтоимостьРаботы(Работа, Дата)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Работа", Работа);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Работа КАК Работа,
	|	т.Цена КАК Цена
	|ИЗ
	|	РегистрСведений._ЦеныРабот.СрезПоследних(&Дата, Работа = &Работа) КАК т";
	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат 0;
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		Возврат Выб.Цена;
	КонецЕсли;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСотрудников(Склад)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ФизическиеЛица КАК т
	|ГДЕ
	|	НЕ т.ПометкаУдаления
	|	И НЕ т.ЭтоГруппа
	|	И т._РаботникПроизводства
	|	И т._Склад = &Склад
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Наименование";

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
КонецФункции

