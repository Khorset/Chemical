	|	Справочник._Работы КАК т
	|ГДЕ
	|	т.Склад = &Склад
	|	И НЕ т.ПометкаУдаления
	|	И НЕ т.Предопределенный
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Наименование";

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
КонецФункции

#КонецОбласти

#Область Фасовка

&НаСервере
Процедура ПоказатьСтраницуФасовка()
	КоличествоБригадФасовки = Объект.КоличествоБригадФасовки;

	Если КоличествоБригадФасовки > мКоличествоБригадФасовки Тогда
		Для Сч = мКоличествоБригадФасовки + 1 По КоличествоБригадФасовки Цикл
			НомерБригады = Формат(Сч, "ЧГ=");

			НастройкаФормыФасовка(НомерБригады);
		КонецЦикла;

	ИначеЕсли КоличествоБригадФасовки < мКоличествоБригадФасовки Тогда
		Для Сч = КоличествоБригадФасовки + 1 По мКоличествоБригадФасовки Цикл
			НомерБригады = Формат(Сч, "ЧГ=");

			УдалитьБригаду(НомерБригады);
		КонецЦикла;
	КонецЕсли;

	мКоличествоБригадФасовки = КоличествоБригадФасовки;

	ПоказатьБригады();
КонецПроцедуры

&НаСервере
Процедура НастройкаФормыФасовка(НомерБригады)

	ИмяСтраницы = "Бригада" + НомерБригады;
	ИмяТабСостав = "Состав" + НомерБригады;
	ИмяТабТовары = "Товары" + НомерБригады;

	ДобавляемыеРеквизиты = Новый Массив;
	
	// Описание таблиц значений как реквизитов формы
	МассивТипа = Новый Массив;
	МассивТипа.Добавить(Тип("ТаблицаЗначений"));
	ОписаниеТипаТЗ = Новый ОписаниеТипов(МассивТипа);
	
	// Добавить в массив реквизитов ТЗ "Состав"
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(ИмяТабСостав, ОписаниеТипаТЗ));
	ТЗ1 = Новый ТаблицаЗначений;
	ТЗ1.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТЗ1.Колонки.Добавить("Подработка", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(3, 1)));
	ТЗ1.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 2)));
	Для Каждого Колонка Из ТЗ1.Колонки Цикл
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Колонка.Имя, Колонка.ТипЗначения, ИмяТабСостав));
	КонецЦикла;	
	
	// Добавить в массив реквизитов ТЗ "Товары"
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(ИмяТабТовары, ОписаниеТипаТЗ));
	ТЗ2 = Новый ТаблицаЗначений;
	ТЗ2.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗ2.Колонки.Добавить("Цена", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 2)));
	ТЗ2.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10)));
	ТЗ2.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 2)));
	
	 // Добавление в массив реквизитов колонок ТаблицыЗначений
	Для Каждого Колонка Из ТЗ2.Колонки Цикл
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Колонка.Имя, Колонка.ТипЗначения, ИмяТабТовары));
	КонецЦикла;

	ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	// ВЫВОД НА ФОРМУ РЕКВИЗИТОВ ФОРМЫ

	Страница = Элементы.Добавить(ИмяСтраницы, Тип("ГруппаФормы"), Элементы.СтрФасовки);
	Страница.Вид = ВидГруппыФормы.Страница;
	Страница.Заголовок = "Бригада " + НомерБригады;
	Страница.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;

	ИмяГруппы = "Группа" + ИмяТабСостав;
	Группа  = Элементы.Добавить(ИмяГруппы, Тип("ГруппаФормы"), Элементы[ИмяСтраницы]);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Отображение = ОтображениеОбычнойГруппы.Нет;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	ИмяКоманды = "ПодборФасовкаБригады" + НомерБригады;
	Команда = Команды.Добавить(ИмяКоманды);
	Команда.Действие  = "Подключаемый_ПодборФасовкаБригады";
	Команда.Заголовок = "Подбор состава бригады";

	Кнопка = Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), Элементы[ИмяГруппы]);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = ИмяКоманды;

	ТП1 = Элементы.Добавить(ИмяТабСостав, Тип("ТаблицаФормы"), Элементы[ИмяГруппы]);
	ТП1.ПутьКДанным = ИмяТабСостав;
	ТП1.Отображение = ОтображениеТаблицы.Список;
	ТП1.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	ТП1.ТолькоПросмотр = Истина;
	ТП1.УстановитьДействие("Выбор", "СоставВыбор");

	Для Каждого Колонка Из ТЗ1.Колонки Цикл
		Элемент = Элементы.Добавить(ИмяТабСостав + Колонка.Имя, Тип("ПолеФормы"), ТП1);
		Элемент.ПутьКДанным = ИмяТабСостав + "." + Колонка.Имя;
		Элемент.Вид = ВидПоляФормы.ПолеВвода;
		Если Колонка.Имя = "Сумма" Тогда
			Элемент.ТолькоПросмотр = Истина;
		КонецЕсли;
	КонецЦикла;

	ИмяГруппы = "Группа" + ИмяТабТовары;
	Группа  = Элементы.Добавить(ИмяГруппы, Тип("ГруппаФормы"), Элементы[ИмяСтраницы]);
	Группа.Вид         = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Отображение = ОтображениеОбычнойГруппы.Нет;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	ИмяКоманды = "ПодборФасовкаПродукция" + НомерБригады;
	Команда = Команды.Добавить(ИмяКоманды);
	Команда.Действие  = "Подключаемый_ПодборФасовкаПродукция";
	Команда.Заголовок = "Подбор продукции для фасовки";

	Кнопка = Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), Элементы[ИмяГруппы]);
	Кнопка.Вид        = ВидКнопкиФормы.КнопкаКоманднойПанели;
	Кнопка.ИмяКоманды = ИмяКоманды;

	ТП2 = Элементы.Добавить(ИмяТабТовары, Тип("ТаблицаФормы"), Элементы[ИмяГруппы]);
	ТП2.ПутьКДанным = ИмяТабТовары;
	ТП2.Отображение = ОтображениеТаблицы.Список;
	ТП2.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	ТП2.ТолькоПросмотр = Истина;
	ТП2.УстановитьДействие("Выбор", "ТоварыВыбор");

	Для Каждого Колонка Из ТЗ2.Колонки Цикл
		Элемент = Элементы.Добавить(ИмяТабТовары + Колонка.Имя, Тип("ПолеФормы"), ТП2);
		Элемент.ПутьКДанным = ИмяТабТовары + "." + Колонка.Имя;
		Элемент.Вид = ВидПоляФормы.ПолеВвода;
		Если Колонка.Имя = "Цена" Или Колонка.Имя = "Сумма" Тогда
			Элемент.ТолькоПросмотр = Истина;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура УдалитьБригаду(НомерБригады)
	ИмяСтраницы = "Бригада" + НомерБригады;
	ИмяТабСостав = "Состав" + НомерБригады;
	ИмяТабТовары = "Товары" + НомерБригады;

	УдалитьЭлементФормы(ИмяТабСостав);
	УдалитьЭлементФормы(ИмяТабТовары);
	УдалитьЭлементФормы(ИмяСтраницы);

	УдаляемыеРеквизиты = Новый Массив;

	УдаляемыеРеквизиты.Добавить(ИмяТабСостав);
	УдаляемыеРеквизиты.Добавить(ИмяТабТовары);

	ИзменитьРеквизиты( , УдаляемыеРеквизиты);
КонецПроцедуры

&НаСервере
Процедура УдалитьЭлементФормы(ИмяЭлемента)
	ТекЭлемент = Элементы.Найти(ИмяЭлемента);
	Если ТекЭлемент <> Неопределено Тогда
		Элементы.Удалить(ТекЭлемент);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоставВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
