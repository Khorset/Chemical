	СКД = Документы.AMS_ПроизводствоЗаСмену.ПолучитьМакет("скдПередачаПродукции");

	Настройки = СКД.НастройкиПоУмолчанию;
	
	УстановитьПривилегированныйРежим(Истина);
	
	мср.ПолучитьДанныеНаОснованииСКД(СКД, ПередачаПродукции, Настройки, Парам);
КонецПроцедуры

