&НаСервере
Процедура ПоказатьТоварыДокументыПроизводства(Ссылка, Операция)
	ИмяСсылка = Ссылка.Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка); 
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.НомерСтроки КАК НомерСтроки,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Номенклатура.ЕдиницаИзмерения КАК Ед,
	|	т.Количество КАК Количество,
	|	т.Количество / т.Номенклатура.КоэффициентЕдиницыДляОтчетов КАК КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА т.Номенклатура._Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА т.Номенклатура.ЕдиницаДляОтчетов
	|		ИНАЧЕ т.Номенклатура._Упаковка
	|	КОНЕЦ КАК Упаковка
	|ИЗ
	|	Документ." + ИмяСсылка + ".Товары КАК т
	|ГДЕ
	|	т.Ссылка = &Ссылка"; 
	
	ДокументыПроизводстваТовары.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры  

&НаСервере
Процедура УправлениеЭлементамиФормы()
	Проект         = Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.Проект");
	План           = Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.План");
	ВРаботе        = Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.ВРаботе");
	РасчётЗарплаты = Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.РасчётЗарплаты");
	Выполнено      = Объект.Статус = ПредопределенноеЗначение("Перечисление._СтатусыПроизводства.Выполнено");
	
	Если AMS_ВызовСервера.ЭтоKhors() Тогда
		Возврат;
	КонецЕсли;

	УтверждатьПланПроизводства = AMS_ВызовСервера.ЕстьПравоАМС(Перечисления.AMS_Права.УтверждатьПланПроизводства);
	
	Элементы.Утвержден.Доступность = План И УтверждатьПланПроизводства;
	Элементы.ПродукцияУтверждено.Доступность = План И УтверждатьПланПроизводства;

	Элементы.СтраницаТЧ.Видимость = Ложь;
	Элементы.Дата.Доступность     = Ложь;

	Элементы.ПродукцияФакт.ТолькоПросмотр = Не ВРаботе;
	
	Элементы.ГруппаКомандПродукция.Видимость      = Ложь;
	Элементы.ДобавитьПеремещениеТоваров.Видимость = Ложь;

	Если УтверждатьПланПроизводства Тогда
		
	ИначеЕсли Пользователи.РолиДоступны("_Директор,_СтаршийМенеджер") Тогда
		Если План И Пользователи.РолиДоступны("_СтаршийМенеджер") Тогда
			ТолькоПросмотр = Не План;
		КонецЕсли;

		Элементы.Смена.Доступность     = Ложь;
		Элементы.Статус.Доступность    = Ложь;
		Элементы.Склад.Доступность     = Ложь;

		Элементы.Продукция.ТолькоПросмотр = Истина;
		Элементы.Фабрикаты.ТолькоПросмотр = Истина;
		Элементы.РасходСырья.ТолькоПросмотр = Истина;
		Элементы.РасходУпаковки.ТолькоПросмотр = Истина;

	ИначеЕсли Пользователи.РолиДоступны("_НачальникЦеха") И Не Пользователи.РолиДоступны("_Бухгалтер") Тогда
		ТолькоПросмотр = Не ЭтоМойДок;
		Элементы.ДобавитьПродукцию.Доступность = ЭтоМойДок;
		Элементы.УдалитьПродукцию.Доступность = ЭтоМойДок;
		Элементы.ПродукцияФакт.Доступность = ЭтоМойДок;
		Элементы.ДобавитьПеремещениеТоваров.Доступность = ЭтоМойДок;
	
		Элементы.ГруппаКомандПродукция.Видимость = (Проект Или План);
		Элементы.ДобавитьПеремещениеТоваров.Видимость = Не Выполнено;
		Элементы.ПродукцияГруппаСтоимость.Видимость   = Ложь;
		Элементы.ФабрикатыГруппаСтоимость.Видимость   = Ложь;
		
		Элементы.Дата.Доступность = Проект;

		Если Не (Проект Или (План И Не Объект.Утвержден)) Тогда
			Элементы.Смена.Доступность = Ложь;
		КонецЕсли;

	ИначеЕсли Пользователи.РолиДоступны("_МенеджерЗакупок") Тогда
		Элементы.Статус.ТолькоПросмотр = (Выполнено Или РасчётЗарплаты);

		Элементы.СтраницаПланирование.ТолькоПросмотр = Истина;
		Элементы.ГруппаКомандПродукция.Видимость     = Ложь;

		Элементы.ПродукцияГруппаСтоимость.Видимость = Ложь;
		Элементы.ФабрикатыГруппаСтоимость.Видимость = Ложь;

		Элементы.СтраницаРабота.Видимость            = Ложь;
		Элементы.СтраницаДополнительно.Видимость     = Ложь;

		Элементы.ДобавитьПеремещениеТоваров.Видимость = ВРаботе;

	Иначе
		ТолькоПросмотр = Истина;
	КонецЕсли;

	Если План Тогда
		Рез = РеквизитФормыВЗначение("Объект").ПолучитьДанныхПоРасходуМатериалов(Истина, Истина);
		
		Если Не Рез = Неопределено Тогда
			Если Рез.Сырье.Количество() > 0 Тогда
				Элементы.СтрРасходСырья.ЦветФона = ЦветаСтиля.ЦветОтрицательногоЧисла;
			Иначе
				Элементы.СтрРасходСырья.ЦветФона = ЦветаСтиля.ЦветФонаФормы;
			КонецЕсли;

			Если Рез.Упаковка.Количество() > 0 Тогда
				Элементы.СтрРасходУпаковки.ЦветФона = ЦветаСтиля.ЦветОтрицательногоЧисла;
			Иначе
				Элементы.СтрРасходУпаковки.ЦветФона = ЦветаСтиля.ЦветФонаФормы;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПроверкаНаличияДокументовПередачиПродукции(Ссылка, Отказ)
	ДокументыПеремещенияПродукцииНаСклад = Документы.AMS_ПроизводствоЗаСмену.ПолучитьДокументыПеремещенияПродукцииНаСклад(
		Ссылка);
	Если Не ДокументыПеремещенияПродукцииНаСклад = Неопределено Тогда
		ОбщегоНазначения.СообщитьПользователю(
			"Статус не изменён. Есть оформленные документы перемещения продукции на склад продукции!", , , , Отказ);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПроверкаРанееДокументВСтатусеПроект(Отказ)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Дата", Объект.Дата);

	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	т.Дата КАК Дата,
	|	т.Смена КАК Смена,
	|	т.Ссылка КАК Документ
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену КАК т
	|ГДЕ
	|	т.Склад = &Склад
	|	И НЕ т.Ссылка = &Ссылка
	|	И т.Статус = ЗНАЧЕНИЕ(Перечисление._СтатусыПроизводства.Проект)
	|	И т.Дата < &Дата
	|	И НЕ т.ПометкаУдаления
	|	И т.Организация = &Организация";
	Рез = Запрос.Выполнить();

	Если Не Рез.Пустой() Тогда
		ОбщегоНазначения.СообщитьПользователю("Статус не изменён. Есть ранее документы в статусе ""Проект"".", , , ,
			Отказ);
	КонецЕсли;
КонецПроцедуры

