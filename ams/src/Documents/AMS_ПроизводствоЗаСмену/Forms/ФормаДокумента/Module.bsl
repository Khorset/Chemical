	КонецЕсли;
	
	Парам = Новый Структура;
	Парам.Вставить("Организация", Объект.Организация);
	Парам.Вставить("Склад", Объект.Склад);
	Парам.Вставить("Товар", Товар);

	ОткрытьФорму("Документ.AMS_ПроизводствоЗаСмену.Форма.ФормаВыбораТовара", Парам, , , , ,
		Новый ОписаниеОповещения("ОткрытьФормуВыбораТовараЗавершение", ЭтотОбъект, ),
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьПродукцию(Команда)
	Стр = Элементы.Продукция.ТекущиеДанные;
	Если Стр = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Стр.Утверждено > 0 Тогда
		ТекстОшибки = "Документ утверждён, удаление запрещено.";
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;

	Если ЗначениеЗаполнено(Стр.Номенклатура) Тогда
		ТекстВопроса = ПолучитьТекстВопросаУдалитьПродукцию(Стр.Номенклатура);
		ПоказатьВопрос(Новый ОписаниеОповещения("ОбратоткаКомандыУдалитьПродукциюЗавершение", ЭтотОбъект,
			Новый Структура("Продукция, Фабрикат", Стр.Номенклатура, Стр.Фабрикат)), ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПеремещениеТоваров(Команда)
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("Дата", ОбщегоНазначенияКлиент.ДатаСеанса());
	ДанныеЗаполнения.Вставить("СкладОтправитель", Объект.Склад);
	
	Если Не Объект.Склад = AMS_ВызовСервера.Цех4() Тогда
		ДанныеЗаполнения.Вставить("СкладПолучатель", AMS_ВызовСервера.СкладПродукции());
	КонецЕсли;
	
	ДанныеЗаполнения.Вставить("Организация", Объект.Организация);
	ДанныеЗаполнения.Вставить("_Основание", Объект.Ссылка);
	ДанныеЗаполнения.Вставить("_ОперацияПроизводства", ПредопределенноеЗначение("Перечисление.AMS_ОперацииПроизводства.ПеремещениеПроизведеннойПродукции"));

	ДополнительныеПараметры = Новый Структура("ЗначенияЗаполнения", ДанныеЗаполнения);

	Если Модифицированность Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ДобавитьПеремещениеТоваровВопросЗавершение", ЭтотОбъект,
			ДополнительныеПараметры), НСтр("ru = 'Документ был изменён. Записать изменения и продолжить?'"),
			РежимДиалогаВопрос.ДаНет);

	Иначе
		ОткрытьФорму("Документ.ПеремещениеТоваров.ФормаОбъекта", ДополнительныеПараметры);
	КонецЕсли;
КонецПроцедуры

