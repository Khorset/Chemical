&НаСервере
Процедура ПодборФактЗавершить(Результат) 
	Сделано = Новый ТаблицаЗначений();
	Сделано.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Сделано.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	
    Для каждого Стр Из Результат Цикл
		НовСтр = Сделано.Добавить();
		НовСтр.Номенклатура = Стр.Номенклатура;
		НовСтр.Количество   = Стр.Количество;	
    КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Сделано", Сделано);
	Запрос.УстановитьПараметр("Продукция", Объект.Продукция.Выгрузить(, "Номенклатура, Фабрикат, Спецификация"));
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Сделано.Номенклатура КАК Номенклатура,
		|	Сделано.Количество КАК Количество
		|ПОМЕСТИТЬ Сделано
		|ИЗ
		|	&Сделано КАК Сделано
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Продукция.Номенклатура КАК Номенклатура,
		|	Продукция.Фабрикат КАК Фабрикат,
		|	Продукция.Спецификация КАК Спецификация
		|ПОМЕСТИТЬ Прод1
		|ИЗ
		|	&Продукция КАК Продукция
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Прод1.Номенклатура КАК Номенклатура,
		|	Прод1.Фабрикат КАК Фабрикат,
		|	Прод1.Спецификация КАК Спецификация,
		|	ЕСТЬNULL(Сделано.Количество, 0) КАК Количество
		|ПОМЕСТИТЬ Прод2
		|ИЗ
		|	Прод1 КАК Прод1
		|		ЛЕВОЕ СОЕДИНЕНИЕ Сделано КАК Сделано
		|		ПО Прод1.Номенклатура = Сделано.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Прод2.Номенклатура КАК Продукция,
		|	Прод2.Количество КАК КоличествоПродукция,
		|	Прод2.Фабрикат КАК Фабрикат,
		|	Спец.Количество * Прод2.Количество КАК КоличествоФабрикат
		|ПОМЕСТИТЬ вт
		|ИЗ
		|	Прод2 КАК Прод2
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник._ВариантыСпецификацийНоменклатуры.Товары КАК Спец
		|		ПО Прод2.Спецификация = Спец.Ссылка
		|			И Прод2.Фабрикат = Спец.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт.Продукция КАК Номенклатура,
		|	вт.КоличествоПродукция КАК КоличествоФакт
		|ИЗ
		|	вт КАК вт
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт.Фабрикат КАК Номенклатура,
		|	СУММА(вт.КоличествоФабрикат) КАК КоличествоФакт
		|ИЗ
		|	вт КАК вт
		|
		|СГРУППИРОВАТЬ ПО
		|	вт.Фабрикат";
	
	Пакет = Запрос.ВыполнитьПакет();
	
	Выб = Пакет[4].Выбрать();
	Пока Выб.Следующий() Цикл
		Строки = Объект.Продукция.НайтиСтроки(Новый Структура("Номенклатура", Выб.Номенклатура));
		Если Строки.Количество()> 0 Тогда
			Стр = Строки[0];
			Стр.КоличествоФакт = Выб.КоличествоФакт;
		КонецЕсли;
	КонецЦикла;

	Выб = Пакет[5].Выбрать();
	Пока Выб.Следующий() Цикл
		Строки = Объект.Фабрикаты.НайтиСтроки(Новый Структура("Номенклатура", Выб.Номенклатура));
		Если Строки.Количество()> 0 Тогда
			Стр = Строки[0];
			Стр.КоличествоФакт = Выб.КоличествоФакт;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОформитьСтрокуПродукцииСФабрикатом(Данные)
	ТекОбъект  = РеквизитФормыВЗначение("Объект");
	
	Стр = Данные.Фабрикат;
	
	//Фабрикат
	ТЧ_Фабрикаты = ТекОбъект.Фабрикаты;
	
	ТекСтр = ТЧ_Фабрикаты.Найти(Стр.Номенклатура, "Номенклатура");

	Если Стр.КоличествоПлан = 0 И Стр.КоличествоФакт = 0 Тогда
		Если ТекСтр <> Неопределено Тогда
			ТЧ_Фабрикаты.Удалить(ТекСтр);
		КонецЕсли;
	Иначе
		Если ТекСтр = Неопределено Тогда
			ТекСтр = ТЧ_Фабрикаты.Добавить();
		КонецЕсли;

		ЗаполнитьЗначенияСвойств(ТекСтр, Стр);

		ТЧ_Фабрикаты.Сортировать("Номенклатура");
	КонецЕсли;
	
	//Продукция
	ТЧ_Продукция  = ТекОбъект.Продукция;
	ТабПродукция = Данные.Продукция;

	Для Каждого Стр Из ТабПродукция Цикл
		ТекСтр = ТЧ_Продукция.Найти(Стр.Номенклатура, "Номенклатура");

		Если Стр.КоличествоПлан = 0 Тогда
			Если Не ТекСтр = Неопределено Тогда
				Если ТекСтр.Утверждено = 0 Тогда
					ТЧ_Продукция.Удалить(ТекСтр);

				Иначе
					ЗаполнитьЗначенияСвойств(ТекСтр, Стр);
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если ТекСтр = Неопределено Тогда
				ТекСтр = ТЧ_Продукция.Добавить();
			КонецЕсли;

			ЗаполнитьЗначенияСвойств(ТекСтр, Стр);
		КонецЕсли;
	КонецЦикла;

	ТЧ_Продукция.Сортировать("Номенклатура");

	ЗначениеВРеквизитФормы(ТекОбъект, "Объект");

	ЗаполнитьРасходМатериалов();
КонецПроцедуры

