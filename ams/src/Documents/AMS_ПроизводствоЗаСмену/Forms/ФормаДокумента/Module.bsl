		ТекстСообщения = НСтр("ru = 'Перед добавлением номенклатуры необходимо выбрать склад.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, ,"Склад", "Объект.Склад");
