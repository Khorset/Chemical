#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	НомерБригады = Параметры.НомерБригады;
	МассивСтрок = Параметры.МассивСтрок;

	НомерСтроки = 0;
	Для Каждого Стр Из МассивСтрок Цикл
		НовСтр = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтр, Стр);
		НомерСтроки = НомерСтроки + 1;
		НовСтр.НомерСтроки = НомерСтроки;
	КонецЦикла;

	ИтогоСумма = ПолучитьИтогоСумма();
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если Модифицированность Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект), НСтр(
			"ru = 'Данные были изменены. Перенести изменения в документ?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		ПеренестиВДокументНаКлиенте();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТовары

&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
	Модифицированность = Истина;

	Стр = ТекущийЭлемент.ТекущиеДанные;
	Стр.Сумма = Стр.Цена * Стр.Количество;

	ИтогоСумма = ПолучитьИтогоСумма();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	ПеренестиВДокументНаКлиенте();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	Если Ответ = КодВозвратаДиалога.Да Тогда
		ПеренестиВДокументНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиВДокументНаКлиенте()
	Парам = Новый Структура;
	Парам.Вставить("НомерБригады", НомерБригады);
	Парам.Вставить("МассивСтрок", ПолучитьМассивСтрок());
    
	//Снятие модифицированности, т.к. перед закрытием признак проверяется.
	Модифицированность = Ложь;

	Закрыть(Парам);
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивСтрок()
	МассивСтрок = Новый Массив;

	Для Каждого Стр Из Товары Цикл
		Если Стр.Количество Тогда
			Дано = Новый Структура("НомерБригады,Номенклатура,Количество", НомерБригады, Стр.Номенклатура,
				Стр.Количество);
			Дано.Вставить("Цена", Стр.Цена);
			Дано.Вставить("Сумма", Стр.Сумма);

			МассивСтрок.Добавить(Дано);
		КонецЕсли;
	КонецЦикла;

	Возврат МассивСтрок;
КонецФункции

&НаСервере
Функция ПолучитьИтогоСумма()
	Возврат Товары.Итог("Сумма");
КонецФункции

#КонецОбласти