Функция ПолучитьПеремещениеМатериаловВПроизводство(Основание) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Основание", Основание);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК т
	|ГДЕ
	|	т._Основание = &Основание
	|	И т._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПеремещениеМатериаловВПроизводство)";
	
	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		Возврат Выб.Ссылка;
	КонецЕсли;
КонецФункции

