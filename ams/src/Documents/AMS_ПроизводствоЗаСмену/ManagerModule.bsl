Функция ПолучитьДокументыПеремещенияПродукцииНаСклад(Ссылка) Экспорт
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Основание", Ссылка);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т._ОперацияПроизводства КАК ОперацияПроизводства,
	|	т.Ссылка КАК ДокСсылка
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК т
	|ГДЕ
	|	т._Основание = &Основание
	|	И т._ОперацияПроизводства = ЗНАЧЕНИЕ(Перечисление.AMS_ОперацииПроизводства.ПеремещениеПроизведеннойПродукции)";
	
	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат Рез.Выгрузить();
	КонецЕсли;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ЗаданиеНаОтгрузку") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,
			"ЗаданиеНаОтгрузку", "Задание на отгрузку", 
			СформироватьПечатнуюФормуЗаданиеНаОтгрузку(МассивОбъектов));
	КонецЕсли;

	ФормированиеПечатныхФорм.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов,
		КоллекцияПечатныхФорм);
КонецПроцедуры

Функция СформироватьПечатнуюФормуЗаданиеНаОтгрузку(МассивОбъектов)
	Док = МассивОбъектов[0];
	
	Данные = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Док, "Дата, Номер, Склад, Цех, Смена");
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	ТабличныйДокумент.ОриентацияСтраницы  = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.АвтоМасштаб         = Истина;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ЗаданиеНаОтгрузку";
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.AMS_ПроизводствоЗаСмену.ЗаданиеНаОтгрузку");
	
	ОбластьШапка  = Макет.ПолучитьОбласть("Шапка");
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
	
	ОбластьШапка.Параметры.Основание = "Производство товаров № " 
		+ ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Данные.Номер, Ложь, Истина)
		+ " от " + Формат(Данные.Дата, "ДФ = ""дд ММММ гггг """"г.""");
	
	ОбластьШапка.Параметры.Место = "Склад: " + Данные.Склад + ", Цех: " + Данные.Цех + ", Смена: " + Данные.Смена;

	ТабличныйДокумент.Вывести(ОбластьШапка);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Док);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.НомерСтроки КАК НомерСтроки,
	|	т.Номенклатура КАК Номенклатура,
	|	т.Номенклатура._Упаковка КАК Упаковка,
	|	т.КоличествоПлан КАК КоличествоПлан,
	|	т.Утверждено КАК Утверждено
	|ИЗ
	|	Документ.AMS_ПроизводствоЗаСмену.Продукция КАК т
	|ГДЕ
	|	т.Ссылка = &Ссылка";
	
	
	Рез = Запрос.Выполнить();
	
	Выб = Рез.Выбрать();
	
	Пока Выб.Следующий() Цикл
		ОбластьСтрока.Параметры.Заполнить(Выб);
		ТабличныйДокумент.Вывести(ОбластьСтрока);
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
КонецФункции

#КонецОбласти

#КонецЕсли