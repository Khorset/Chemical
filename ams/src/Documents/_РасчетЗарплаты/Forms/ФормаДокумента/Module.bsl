#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Заполнить(Команда)
	Если КоличествоОсновныхРабот > 0 Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ОбратоткаКомандыЗаполнитьЗавершение", ЭтотОбъект), НСтр(
			"ru = 'Данные об Основных работах будут очищены. Очистить данные и продолжить?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		Модифицированность = Истина;
		ЗаполнитьТЗРаботы();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтчетНачисленоПоДокументу(Команда)
	Если Модифицированность Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ОтчетНачисленоПоДокументуЗавершение", ЭтотОбъект), НСтр(
			"ru = 'Документ изменён. Записать документ и продолжить?'"), РежимДиалогаВопрос.ДаНет);

	Иначе
		ПоказатьНачисленоПоДокументу();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтчетНачисленоСотруднику(Команда)
	Если Модифицированность Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ОтчетНачисленоСотрудникуЗавершение", ЭтотОбъект), НСтр(
			"ru = 'Документ изменён. Записать документ и продолжить?'"), РежимДиалогаВопрос.ДаНет);

	Иначе
		ПоказатьНачисленоСотруднику();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтчетНачисленоЗаПериод(Команда)
	Если Модифицированность Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ОтчетНачисленоЗаПериодЗавершение", ЭтотОбъект), НСтр(
			"ru = 'Документ изменён. Записать документ и продолжить?'"), РежимДиалогаВопрос.ДаНет);

	Иначе
		ПоказатьНачисленоЗаПериод();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДвижениеДокумента(Команда)
	СсылкаНаОбъект = Объект.Ссылка;
	Если ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ВидимостьКомандВариантовОтчетов", Ложь);
		ПараметрыФормы.Вставить("СформироватьПриОткрытии", Истина);
		ПараметрыФормы.Вставить("ПараметрКоманды", СсылкаНаОбъект);

		ОткрытьФорму("Отчет.ДвиженияДокумента.Форма", ПараметрыФормы, ЭтотОбъект, Истина);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПолучитьДопРаботы()
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СкладПродукции", AMS_ВызовСервера.СкладПродукции());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник._Работы КАК т
	|ГДЕ
	|	т.Склад = &СкладПродукции
	|	И НЕ т.ПометкаУдаления
	|	И НЕ т.Предопределенный
	|
	|УПОРЯДОЧИТЬ ПО
	|	т.Наименование";

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
КонецФункции

&НаКлиенте
Процедура ОбратоткаКомандыЗаполнитьЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	Если Ответ = КодВозвратаДиалога.Да Тогда
		Модифицированность = Истина;
		ЗаполнитьТЗРаботы();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЗРаботы()
	Пакет = ПолучитьПакетРезультатовЗапросов(Объект.Дата, Объект.Склад);

	ЗаполнитьТЧ(Пакет.Водители, Объект.Водители);
	ЗаполнитьТЧ(Пакет.ГрузчикиВМашина, Объект.ГрузчикиВМашина);
	ЗаполнитьТЧ(Пакет.Кладовщики, Объект.Кладовщики);
	ЗаполнитьТЧ(Пакет.Комплектовщики, Объект.Комплектовщики);
	ЗаполнитьТЧ(Пакет.Обмотчики, Объект.Обмотчики);

	КоличествоОсновныхРабот = Объект.Водители.Количество() + Объект.ГрузчикиВМашина.Количество()
		+ Объект.Кладовщики.Количество() + Объект.Комплектовщики.Количество() + Объект.Обмотчики.Количество();
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьТЧ(Рез, Табл)
	Табл.Очистить();

	Выб = Рез.Выбрать();
	Пока Выб.Следующий() Цикл
		Стр = Табл.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Выб);
		Стр.Примечание = Выб.Номер + " от " + Формат(Выб.Дата, "ДЛФ=Д") + " г. " + Выб.Партнер;
	КонецЦикла;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПакетРезультатовЗапросов(Дата, Склад)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	д.Ссылка КАК Ссылка,
	|	д._ВесОсновной КАК ВесОсновной,
	|	д._ВесВерхний КАК ВесВерхний,
	|	т.Распоряжение КАК Распоряжение
	|ПОМЕСТИТЬ ордера
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары КАК д
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК т
	|		ПО д.Ссылка = т.Ссылка
	|ГДЕ
	|	д.Проведен
	|	И д.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Отгружен)
	|	И д.ДатаОтгрузки МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ордера.Ссылка КАК Ссылка,
	|	ордера.ВесОсновной КАК ВесОсновной,
	|	ордера.ВесВерхний КАК ВесВерхний,
	|	Реал.Номер КАК Номер,
	|	Реал.Дата КАК Дата,
	|	ПРЕДСТАВЛЕНИЕ(Реал.Партнер) КАК Партнер
	|ПОМЕСТИТЬ док
	|ИЗ
	|	ордера КАК ордера
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реал
	|		ПО ордера.Распоряжение = Реал.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ордера.Ссылка,
	|	ордера.ВесОсновной,
	|	ордера.ВесВерхний,
	|	Перемещение.Номер,
	|	Перемещение.Дата,
	|	ПРЕДСТАВЛЕНИЕ(Перемещение.Организация)
	|ИЗ
	|	ордера КАК ордера
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров КАК Перемещение
	|		ПО ордера.Распоряжение = Перемещение.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	док.Номер КАК Номер,
	|	док.Дата КАК Дата,
	|	док.Партнер КАК Партнер,
	|	РаботыВОрдере.МестоПогрузки КАК МестоПогрузки,
	|	РаботыВОрдере.Работа КАК Работа,
	|	РаботыВОрдере.Сотрудник КАК Сотрудник,
	|	1 КАК Подработка,
	|	ВЫБОР
	|		КОГДА РаботыВОрдере.МестоПогрузки = ЗНАЧЕНИЕ(Перечисление._МестаПогрузки.Основной)
	|			ТОГДА док.ВесОсновной
	|		ИНАЧЕ док.ВесВерхний
	|	КОНЕЦ КАК Количество,
	|	РегЦен.Цена КАК Цена,
	|	ВЫБОР
	|		КОГДА РаботыВОрдере.МестоПогрузки = ЗНАЧЕНИЕ(Перечисление._МестаПогрузки.Основной)
	|			ТОГДА док.ВесОсновной * РегЦен.Цена
	|		ИНАЧЕ док.ВесВерхний * РегЦен.Цена
	|	КОНЕЦ КАК Сумма
	|ПОМЕСТИТЬ вт
	|ИЗ
	|	док КАК док
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары._Работы КАК РаботыВОрдере
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений._ЦеныРабот.СрезПоследних(&Дата, ) КАК РегЦен
	|			ПО РаботыВОрдере.Работа = РегЦен.Работа
	|		ПО док.Ссылка = РаботыВОрдере.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номер КАК Номер,
	|	вт.Дата КАК Дата,
	|	вт.Партнер КАК Партнер,
	|	вт.МестоПогрузки КАК МестоПогрузки,
	|	вт.Работа КАК Работа,
	|	вт.Сотрудник КАК Сотрудник,
	|	вт.Подработка КАК Подработка,
	|	вт.Количество КАК Количество,
	|	вт.Цена КАК Цена,
	|	вт.Сумма КАК Сумма
	|ИЗ
	|	вт КАК вт
	|ГДЕ
	|	вт.Работа В (ЗНАЧЕНИЕ(Справочник._Работы.СкладВодитель), ЗНАЧЕНИЕ(Справочник._Работы.СкладВодительВерхний))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номер КАК Номер,
	|	вт.Дата КАК Дата,
	|	вт.Партнер КАК Партнер,
	|	вт.МестоПогрузки КАК МестоПогрузки,
	|	вт.Работа КАК Работа,
	|	вт.Сотрудник КАК Сотрудник,
	|	вт.Подработка КАК Подработка,
	|	вт.Количество КАК Количество,
	|	вт.Цена КАК Цена,
	|	вт.Сумма КАК Сумма
	|ИЗ
	|	вт КАК вт
	|ГДЕ
	|	вт.Работа В (ЗНАЧЕНИЕ(Справочник._Работы.СкладГрузчикВМашине), ЗНАЧЕНИЕ(Справочник._Работы.СкладГрузчикВМашинеВерхний))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номер КАК Номер,
	|	вт.Дата КАК Дата,
	|	вт.Партнер КАК Партнер,
	|	вт.МестоПогрузки КАК МестоПогрузки,
	|	вт.Работа КАК Работа,
	|	вт.Сотрудник КАК Сотрудник,
	|	вт.Подработка КАК Подработка,
	|	вт.Количество КАК Количество,
	|	вт.Цена КАК Цена,
	|	вт.Сумма КАК Сумма
	|ИЗ
	|	вт КАК вт
	|ГДЕ
	|	вт.Работа В (ЗНАЧЕНИЕ(Справочник._Работы.СкладКладовщик), ЗНАЧЕНИЕ(Справочник._Работы.СкладКладовщикВерхний))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номер КАК Номер,
	|	вт.Дата КАК Дата,
	|	вт.Партнер КАК Партнер,
	|	вт.МестоПогрузки КАК МестоПогрузки,
	|	вт.Работа КАК Работа,
	|	вт.Сотрудник КАК Сотрудник,
	|	вт.Подработка КАК Подработка,
	|	вт.Количество КАК Количество,
	|	вт.Цена КАК Цена,
	|	вт.Сумма КАК Сумма
	|ИЗ
	|	вт КАК вт
	|ГДЕ
	|	вт.Работа В (ЗНАЧЕНИЕ(Справочник._Работы.СкладКомплектовщик), ЗНАЧЕНИЕ(Справочник._Работы.СкладКомплектовщикВерхний))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	вт.Номер КАК Номер,
	|	вт.Дата КАК Дата,
	|	вт.Партнер КАК Партнер,
	|	вт.МестоПогрузки КАК МестоПогрузки,
	|	вт.Работа КАК Работа,
	|	вт.Сотрудник КАК Сотрудник,
	|	вт.Подработка КАК Подработка,
	|	вт.Количество КАК Количество,
	|	вт.Цена КАК Цена,
	|	вт.Сумма КАК Сумма
	|ИЗ
	|	вт КАК вт
	|ГДЕ
	|	вт.Работа В (ЗНАЧЕНИЕ(Справочник._Работы.СкладОбмотчик), ЗНАЧЕНИЕ(Справочник._Работы.СкладОбмотчикВерхний))";
	Рез = Запрос.ВыполнитьПакет();

	Пакет = Новый Структура;
	Пакет.Вставить("Водители", Рез[3]);
	Пакет.Вставить("ГрузчикиВМашина", Рез[4]);
	Пакет.Вставить("Кладовщики", Рез[5]);
	Пакет.Вставить("Комплектовщики", Рез[6]);
	Пакет.Вставить("Обмотчики", Рез[7]);

	Возврат Пакет;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСтоимостьРаботы(Работа, Дата)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Работа", Работа);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	т.Работа КАК Работа,
	|	т.Цена КАК Цена
	|ИЗ
	|	РегистрСведений._ЦеныРабот.СрезПоследних(&Дата, Работа = &Работа) КАК т";

	Рез = Запрос.Выполнить();

	Если Рез.Пустой() Тогда
		Возврат 0;

	Иначе
		Выб = Рез.Выбрать();
		Выб.Следующий();
		Возврат Выб.Цена;
	КонецЕсли;
КонецФункции

