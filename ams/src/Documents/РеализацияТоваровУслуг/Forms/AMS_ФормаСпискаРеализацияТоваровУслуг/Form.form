    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НАЧАЛОПЕРИОДА(Реал.Дата, ДЕНЬ) КАК Дата,
	Реал.Номер КАК Номер,
	Реал.Ссылка КАК Реализация,
	ВЫБОР
		КОГДА Реал.ПометкаУдаления
			ТОГДА 2
		ИНАЧЕ ВЫБОР
			КОГДА Реал.Проведен
				ТОГДА 1
			ИНАЧЕ 0
		КОНЕЦ
	КОНЕЦ КАК СостоянияРеализации,
	Корр.Дата КАК ДатаКорр,
	Корр.Номер КАК НомерКорр,
	Корр.Ссылка КАК Корректировка,
	ВЫБОР
		КОГДА Корр.Ссылка ЕСТЬ NULL
			ТОГДА 4
		КОГДА Корр.ПометкаУдаления
			ТОГДА 2
		КОГДА Корр.Проведен
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК СостоянияКорректировки,
	Реал.AMS_СтатусРеализации КАК Статус,
	Реал.Партнер КАК Клиент,
	Реал.Контрагент КАК Контрагент,
	Реал.Организация КАК Организация,
	Реал.СуммаДокумента КАК Сумма,
	ВЫРАЗИТЬ(Реал.Комментарий КАК СТРОКА(100)) КАК Комментарий,
	Реал.Менеджер КАК Менеджер,
	Реал.Автор КАК Автор,
	Реал.Партнер.ГруппаДоступа КАК ГруппаДоступа,
	Реал.AMS_ЭДО КАК ЭДО_Реал,
	Корр._ЭДО КАК ЭДО_Корр,
	ВЫБОР
		КОГДА Реал.AMS_ID = 0
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК В2В,
	Реал.AMS_ЭкспортЗУ КАК ЗУ,
	Реал.Склад КАК Склад,
	Реал.Ссылка КАК Ссылка
ИЗ
	Документ.РеализацияТоваровУслуг КАК Реал
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации КАК Корр
		ПО Реал.Ссылка = Корр.ДокументОснование
ГДЕ
	НЕ Реал.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ),
		ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))</queryText>
      <mainTable>Document.РеализацияТоваровУслуг</mainTable>
