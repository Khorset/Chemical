		<field xsi:type="DataSetFieldField">
			<dataPath>В2В</dataPath>
			<field>В2В</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>В2 В</v8:content>
				</v8:item>
