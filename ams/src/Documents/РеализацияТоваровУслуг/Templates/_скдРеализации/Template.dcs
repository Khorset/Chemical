		<field xsi:type="DataSetFieldField">
			<dataPath>ЗУ</dataPath>
			<field>ЗУ</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>ЗУ</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НАЧАЛОПЕРИОДА(т.Дата, ДЕНЬ) КАК Дата,
	т.Дата КАК Отгрузка,
	т.Номер КАК Номер,
	т.AMS_СтатусРеализации КАК Статус,
	т.Партнер КАК Клиент,
	т.Контрагент КАК Контрагент,
	т.Организация КАК Организация,
	т.СуммаДокумента КАК Сумма,
	т.Автор КАК Автор,
	т.Партнер.ГруппаДоступа КАК ГруппаДоступа,
	ВЫРАЗИТЬ(т.Основание КАК СТРОКА(100)) КАК Основание,
	ВЫБОР
		КОГДА т.СпособДоставки = ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.СиламиПеревозчикаПоАдресу)
			ТОГДА т.АдресДоставкиПеревозчика
		ИНАЧЕ т.АдресДоставки
	КОНЕЦ КАК АдресДоставки,
	т.AMS_ЦенаИзменена КАК ЦенаИзменена,
	ВЫБОР
		КОГДА т.ПометкаУдаления
			ТОГДА 2
		ИНАЧЕ ВЫБОР
				КОГДА т.Проведен
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК СостоянияРеализации,
	т.Ссылка КАК Ссылка,
	т.AMS_ЭДО КАК ЭДО_Реал,
	ВЫБОР
		КОГДА т.AMS_ID = 0
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК В2В,
	т.AMS_ЭкспортЗУ КАК ЗУ
ИЗ
	Документ.РеализацияТоваровУслуг КАК т
ГДЕ
	НЕ т.AMS_СтатусРеализации В (ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Заказ), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.Стикерование), ЗНАЧЕНИЕ(Перечисление.AMS_СтатусыРеализаций.КОтгрузке))
	И т.Дата МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания</query>
	</dataSet>
