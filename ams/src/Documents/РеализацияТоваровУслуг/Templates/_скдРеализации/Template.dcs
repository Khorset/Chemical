				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СостоянияКорректировки</dataPath>
			<field>СостоянияКорректировки</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Состояния корректировки</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЭДО_Корр</dataPath>
			<field>ЭДО_Корр</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>ЭДО корр</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	т.ДокументОснование КАК ДокументОснование,
	т.Ссылка КАК Корректировка,
	т.Номер КАК НомерКорр,
	т.Дата КАК ДатаКорр,
	ВЫБОР
		КОГДА т.ПометкаУдаления
			ТОГДА 2
		ИНАЧЕ ВЫБОР
				КОГДА т.Проведен
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК СостоянияКорректировки,
	т._ЭДО КАК ЭДО_Корр
ИЗ
	Документ.КорректировкаРеализации КАК т</query>
	</dataSet>
	<dataSetLink>
		<sourceDataSet>Реализации</sourceDataSet>
		<destinationDataSet>Корректировки</destinationDataSet>
		<sourceExpression>Ссылка</sourceExpression>
		<destinationExpression>ДокументОснование</destinationExpression>
	</dataSetLink>
	<calculatedField>
		<dataPath>СостоянияКорректировки</dataPath>
		<expression>ЕСТЬNULL(СостоянияКорректировки,4)</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Состояния корректировки</v8:content>
			</v8:item>
		</title>
	</calculatedField>
