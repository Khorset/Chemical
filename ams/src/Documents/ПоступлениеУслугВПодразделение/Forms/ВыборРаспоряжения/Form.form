            <content>
              <key>ru</key>
              <value>Константа вариант приемки</value>
            </content>
          </localValue>
        </title>
        <values xsi:type="core:UndefinedValue"/>
        <useRestriction>true</useRestriction>
      </parameters>
      <parameters>
