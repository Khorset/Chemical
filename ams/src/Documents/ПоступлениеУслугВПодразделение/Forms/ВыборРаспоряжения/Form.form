        <field>Дата</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Партнер</dataPath>
        <field>Партнер</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Контрагент</dataPath>
        <field>Контрагент</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Соглашение</dataPath>
        <field>Соглашение</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ХозяйственнаяОперация</dataPath>
        <field>ХозяйственнаяОперация</field>
        <title>
          <localValue>
            <content>
              <key>ru</key>
              <value>Хозяйственная операция</value>
            </content>
          </localValue>
        </title>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Организация</dataPath>
        <field>Организация</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Договор</dataPath>
        <field>Договор</field>
      </fields>
