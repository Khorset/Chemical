#Область ПроцедурыФункцииПечати

&НаСервереБезКонтекста
Функция ПолучитьПрежнееЗначениеШтрихкодаПечати(УзелПО, НомерСтроки)
	
	Возврат ПланыОбмена.ДатаМобайл_СписокТСД.ПолучитьПрежнееЗначениеШтрихкодаПечати(УзелПО, НомерСтроки);	
	
КонецФункции

&НаСервереБезКонтекста
Процедура ОчиститьУправляющийШтрихкод(Штрихкод, ТипОперации, УзелПО)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДатаМобайл_ВыборОперацииПечати.ТСД,
	|	ДатаМобайл_ВыборОперацииПечати.ОперацияПечати,
	|	ДатаМобайл_ВыборОперацииПечати.Штрихкод
	|ИЗ
	|	РегистрСведений.ДатаМобайл_ВыборОперацииПечати КАК ДатаМобайл_ВыборОперацииПечати
	|ГДЕ
	|	ДатаМобайл_ВыборОперацииПечати.ТСД = &УзелПО
	|	И НЕ ДатаМобайл_ВыборОперацииПечати.ОперацияПечати = &ТипОперации
	|	И НЕ ДатаМобайл_ВыборОперацииПечати.Штрихкод = &Штрихкод";
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	Запрос.УстановитьПараметр("ТипОперации", ТипОперации);
	Запрос.УстановитьПараметр("УзелПО", УзелПО);
	
	Результат = Запрос.Выполнить();
	
	НаборЗаписей = РегистрыСведений.ДатаМобайл_ВыборОперацииПечати.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ТСД.Установить(УзелПО);
	НаборЗаписей.Отбор.ОперацияПечати.Установить(ТипОперации); 
	НаборЗаписей.Прочитать();
		
	НаборЗаписей.Очистить();
	НаборЗаписей.Загрузить(Результат.Выгрузить());
	НаборЗаписей.Записать(Истина);
	
