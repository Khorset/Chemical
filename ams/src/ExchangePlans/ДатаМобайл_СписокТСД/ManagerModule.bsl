
#Область ПрограммныйИнтерфейс

Функция ПолучитьПрежнееЗначениеШтрихкодаПечати(УзелПО, НомерСтроки) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДатаМобайл_СписокТСДПечать.ШтрихкодОперации КАК ШтрихкодОперации
	|ИЗ
	|	ПланОбмена.ДатаМобайл_СписокТСД.Печать КАК ДатаМобайл_СписокТСДПечать
	|ГДЕ
	|	ДатаМобайл_СписокТСДПечать.Ссылка = &УзелПО
	|	И ДатаМобайл_СписокТСДПечать.НомерСтроки = &НомерСтроки";
	Запрос.УстановитьПараметр("УзелПО", УзелПО);
	Запрос.УстановитьПараметр("НомерСтроки", НомерСтроки);
	
	Результат = Запрос.Выполнить();
	
	ПрежнееЗначениеШтрихкода = "";
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ПрежнееЗначениеШтрихкода = Выборка.ШтрихкодОперации;
		
	КонецЦикла;	                                            
	
	Возврат ПрежнееЗначениеШтрихкода;
	
КонецФункции

Функция ПолучитьНастройкиТабличныхЧастейТСД(УзелПО, СтруктураНастроек) Экспорт
	
	СтруктураНастроекТСД = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ДатаМобайл_СписокТСДСклады.Склад КАК Склад
	|ПОМЕСТИТЬ Склады
	|ИЗ
	|	ПланОбмена.ДатаМобайл_СписокТСД.Склады КАК ДатаМобайл_СписокТСДСклады
	|ГДЕ
	|	ДатаМобайл_СписокТСДСклады.Ссылка = &УзелПО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДатаМобайл_СписокТСДШаблоны.Шаблон КАК Шаблон
	|ПОМЕСТИТЬ Шаблоны
	|ИЗ
	|	ПланОбмена.ДатаМобайл_СписокТСД.Шаблоны КАК ДатаМобайл_СписокТСДШаблоны
	|ГДЕ
	|	ДатаМобайл_СписокТСДШаблоны.Ссылка = &УзелПО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДатаМобайл_СписокТСДПомещения.Помещение КАК Помещение
	|ПОМЕСТИТЬ Помещения
	|ИЗ
	|	ПланОбмена.ДатаМобайл_СписокТСД.Помещения КАК ДатаМобайл_СписокТСДПомещения
	|ГДЕ
	|	ДатаМобайл_СписокТСДПомещения.Ссылка = &УзелПО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДатаМобайл_СписокТСДПечать.ШтрихкодОперации КАК ШтрихкодОперации,
	|	ДатаМобайл_СписокТСДПечать.ТипОперации КАК ТипОперации
	|ПОМЕСТИТЬ ШтрихкодыОперации
	|ИЗ
	|	ПланОбмена.ДатаМобайл_СписокТСД.Печать КАК ДатаМобайл_СписокТСДПечать
	|ГДЕ  
	|	НЕ ДатаМобайл_СписокТСДПечать.ШтрихкодОперации = """"
	|	И ДатаМобайл_СписокТСДПечать.Ссылка = &УзелПО";
	
	Запрос.УстановитьПараметр("УзелПО", УзелПО);
	
	МассивРезультатов = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	Если СтруктураНастроек.Свойство("Склады") Тогда
		
		Если МассивРезультатов[0].Пустой() Тогда	
			
			ВсеСклады = Истина; 
			СписокСкладов = Новый Массив;
			
		Иначе
			
			ВсеСклады = Ложь;
			СписокСкладов = МассивРезультатов[0].Выгрузить().ВыгрузитьКолонку("Склад");
			
		КонецЕсли;  
		
		СтруктураНастроекТСД.Вставить("ВсеСклады", ВсеСклады);
		СтруктураНастроекТСД.Вставить("СписокСкладов", СписокСкладов);
		
	КонецЕсли;	
	
	Если СтруктураНастроек.Свойство("Шаблоны") Тогда
	
		Если МассивРезультатов[1].Пустой() Тогда	
			
			ВсеШаблоны = Истина; 
			СписокШаблонов = Новый Массив;
			
		Иначе
			
			ВсеШаблоны = Ложь;
			СписокШаблонов = МассивРезультатов[1].Выгрузить().ВыгрузитьКолонку("Шаблон");
			
		КонецЕсли;  
		
		СтруктураНастроекТСД.Вставить("ВсеШаблоны", ВсеШаблоны);
		СтруктураНастроекТСД.Вставить("СписокШаблонов", СписокШаблонов);
		
	КонецЕсли;	 
	
	Если СтруктураНастроек.Свойство("Помещения") Тогда
	
		Если МассивРезультатов[2].Пустой() Тогда	
			
			ВсеПомещения = Истина; 
			СписокПомещений = Новый Массив;
			
		Иначе
			
			ВсеПомещения = Ложь;
			СписокПомещений = МассивРезультатов[2].Выгрузить().ВыгрузитьКолонку("Помещение");
			
		КонецЕсли;  
		
		СтруктураНастроекТСД.Вставить("ВсеПомещения", ВсеПомещения);
		СтруктураНастроекТСД.Вставить("СписокПомещений", СписокПомещений);
		
	КонецЕсли;
	
	Если СтруктураНастроек.Свойство("Печать") Тогда
	
		Если МассивРезультатов[3].Пустой() Тогда	
			
			ШтрихкодыОперации = Новый ТаблицаЗначений;
			
		Иначе
			
			ШтрихкодыОперации = МассивРезультатов[3].Выгрузить();
			
		КонецЕсли;  
		
		СтруктураНастроекТСД.Вставить("ШтрихкодыОперации", ШтрихкодыОперации);
		
	КонецЕсли;
	
	Возврат СтруктураНастроекТСД;
	
КонецФункции	

Функция ТекстЗапросаСпискаСтарыйРежимСовместимости() Экспорт

	ТекстЗапроса = 
	
	"ВЫБРАТЬ
	|	ПланОбменаДатаМобайл_СписокТСД.Ссылка КАК Ссылка,
	|	ПланОбменаДатаМобайл_СписокТСД.Код КАК Код,
	|	ПланОбменаДатаМобайл_СписокТСД.Наименование КАК Наименование,
	|	ЗначенияУзлаОбменаТСД1.Значение КАК ТекущийПользователь,
	|	ЗначенияУзлаОбменаТСД2.Значение КАК ДатаПоследнейЗагрузкиСправочников,
	|	ЗначенияУзлаОбменаТСД3.Значение КАК ДатаПоследнейАвторизацииПользователя,
	|	"""" КАК Документов,
	|	ПланОбменаДатаМобайл_СписокТСД.Описание КАК Описание,
	|	ЗначенияУзлаОбменаТСД4.Значение КАК ВерсияПО
	|ИЗ
	|	ПланОбмена.ДатаМобайл_СписокТСД КАК ПланОбменаДатаМобайл_СписокТСД
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатаМобайл_ЗначенияУзлаОбменаТСД КАК ЗначенияУзлаОбменаТСД1
	|		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ЗначенияУзлаОбменаТСД1.ТСД
	|			И (ЗначенияУзлаОбменаТСД1.ТипЗначения = ""ТекущийПользователь"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатаМобайл_ЗначенияУзлаОбменаТСД КАК ЗначенияУзлаОбменаТСД2
	|		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ЗначенияУзлаОбменаТСД2.ТСД
	|			И (ЗначенияУзлаОбменаТСД2.ТипЗначения = ""ДатаПоследнейЗагрузкиСправочников"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатаМобайл_ЗначенияУзлаОбменаТСД КАК ЗначенияУзлаОбменаТСД3
	|		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ЗначенияУзлаОбменаТСД3.ТСД
	|			И (ЗначенияУзлаОбменаТСД3.ТипЗначения = ""ДатаПоследнейАвторизацииПользователя"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДатаМобайл_ЗначенияУзлаОбменаТСД КАК ЗначенияУзлаОбменаТСД4
	|		ПО ПланОбменаДатаМобайл_СписокТСД.Ссылка = ЗначенияУзлаОбменаТСД4.ТСД
	|			И (ЗначенияУзлаОбменаТСД4.ТипЗначения = ""ВерсияПО"")";
	
	Возврат ТекстЗапроса;	
	
КонецФункции

Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
	Параметры.Отбор.Вставить("ЭтотУзел", Ложь);
	
КонецПроцедуры

